spec: struct_extra335
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == '' (empty string — struct is a top-level module, not a package). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__class__.__name__ == 'list'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__ == ['pack', 'unpack', 'pack_into', 'unpack_from', 'iter_unpack', 'calcsize', 'Struct', 'error'] (sorted: Struct, calcsize, error, iter_unpack, pack, pack_into, unpack, unpack_from). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('Struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('error') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__all__ is a list (not a tuple), unlike hashlib.__all__ which is a tuple."
    - "Note: struct.__all__ has 8 entries: the 6 module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) plus 2 types (Struct, error)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct')
# struct.__package__.__eq__('')
# struct.__spec__.name.__eq__('struct')
# struct.__doc__.__class__.__name__.__eq__('str')
#
# Wave 335 theme: struct module-level identity attributes.
#
# struct.__name__ is 'struct' — the canonical module name. struct.__package__
# is '' confirming struct is a top-level module. struct.__spec__.name is
# 'struct'. struct.__doc__.__class__.__name__ is 'str' — the module has a
# C-level docstring from _struct.c describing the pack/unpack format chars.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra335.module_identity_attrs:
  description: "struct.__name__.__eq__('struct')==True / __package__.__eq__('')==True / __spec__.name.__eq__('struct')==True / __doc__.__class__.__name__.__eq__('str')==True — struct is a top-level module (__package__==''); __spec__.name matches __name__; __doc__ is a str object (C-level docstring from _struct.c); first structid335 anchor for module identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: structid335

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      "__name__.__eq__",               ["struct"], true, "struct.__name__ is 'struct' — canonical module name"]
    - [package_eq,   "__package__.__eq__",            [""],       true, "struct.__package__ is '' (empty string) — struct is a top-level module, not a subpackage"]
    - [spec_name_eq, "__spec__.name.__eq__",          ["struct"], true, "struct.__spec__.name is 'struct' — ModuleSpec name matches __name__"]
    - [doc_class_eq, "__doc__.__class__.__name__.__eq__", ["str"], true, "struct.__doc__.__class__.__name__ is 'str' — module has a C-level docstring from _struct.c"]

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list')
# struct.__all__.__len__()==8
# struct.__all__.__contains__('pack')==True
# struct.__all__.__contains__('Struct')==True
# struct.__all__.__contains__('error')==True
#
# Wave 335 theme: struct.__all__ list attributes.
#
# struct.__all__ is a list (not a tuple) containing exactly 8 names:
# the 6 module-level functions (pack, unpack, pack_into, unpack_from,
# iter_unpack, calcsize) plus the Struct class and the error exception.
# struct_extra91-99 anchor struct function and class attributes extensively;
# this table anchors __all__ membership and class for the first time under
# structid335. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra335.all_list_attrs:
  description: "struct.__all__.__class__.__name__.__eq__('list')==True / __all__.__len__()==8 / __all__.__contains__('pack')==True / __all__.__contains__('Struct')==True / __all__.__contains__('error')==True — struct.__all__ is a list with 8 entries: 6 module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) plus Struct class and error exception; first structid335 anchor for __all__ attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: structid335

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_eq,      "__all__.__class__.__name__.__eq__", ["list"],   true, "struct.__all__.__class__.__name__ is 'list' — struct uses a list for __all__ (standard convention)"]
    - [all_len,           "__all__.__len__",                   [],         8,    "struct.__all__ has 8 entries (6 functions + Struct class + error exception)"]
    - [all_has_pack,      "__all__.__contains__",              ["pack"],   true, "struct.__all__ contains 'pack' (primary packing function)"]
    - [all_has_struct,    "__all__.__contains__",              ["Struct"], true, "struct.__all__ contains 'Struct' (compiled struct format class)"]
    - [all_has_error,     "__all__.__contains__",              ["error"],  true, "struct.__all__ contains 'error' (struct exception class)"]

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct') — standalone
#
# struct.__name__ is 'struct'. This is the canonical module name. Note that
# the Python-level struct module (Lib/struct.py) re-exports everything from
# the C extension _struct.c; both share the public name 'struct'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra335.name_is_struct:
  description: "struct.__name__.__eq__('struct') == True — struct.__name__ is the canonical module name 'struct'; the Python-level struct module re-exports from C extension _struct; both share the public name 'struct'; first standalone for struct.__name__ under structid335"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is '' (empty string). This confirms struct is a top-level
# module. The C extension is _struct; the Python wrapper module is struct.
# Neither is a subpackage — both are top-level in the standard library.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra335.package_is_empty:
  description: "struct.__package__.__eq__('') == True — struct.__package__ is empty string confirming struct is a top-level module (not a subpackage); the C extension _struct and Python wrapper struct are both top-level; first standalone for struct.__package__ under structid335"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# struct.__all__.__len__()==8 — standalone
#
# struct.__all__.__len__() is 8. The 8 entries are: pack, unpack, calcsize,
# pack_into, unpack_from, iter_unpack (the six module-level functions) plus
# Struct (the compiled-format class) and error (the exception type).
# This is a complete enumeration of the public API surface of the struct module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra335.all_len_8:
  description: "struct.__all__.__len__() == 8 — struct.__all__ has 8 entries: pack, unpack, calcsize, pack_into, unpack_from, iter_unpack (6 functions) plus Struct (compiled-format class) and error (exception type); complete public API enumeration; first standalone for struct.__all__.__len__() under structid335"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.__all__.__contains__('error')==True — standalone
#
# struct.__all__ contains 'error'. struct.error is the exception class raised
# by struct operations (pack, unpack, calcsize) when the format string or
# data is invalid. It is a subclass of Exception. Its presence in __all__
# means callers can explicitly import it: `from struct import error`.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra335.all_contains_error:
  description: "struct.__all__.__contains__('error') == True — struct.__all__ includes 'error', the exception class raised for invalid format strings or data; subclass of Exception; exported so callers can do 'from struct import error'; first standalone for __all__.__contains__('error') under structid335"
  category: module_identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["error"]
  expected: true
