spec: decimal_extra90
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra89

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra89.zspec.zsdl."
    - "This spec covers: decimal module identity (__name__, __package__, __loader__, __spec__) + decimal.Context class identity + rounding mode class names and values."
    - "decimal.__name__ = 'decimal' — the module's __name__ attribute equals its dotted name."
    - "decimal.__package__ = '' — decimal is NOT a package; it is a top-level module, so __package__ is an empty string."
    - "decimal.__loader__.__class__.__name__ = 'SourceFileLoader' — decimal is a pure Python module."
    - "decimal.__spec__.__class__.__name__ = 'ModuleSpec' — module spec is a ModuleSpec instance."
    - "decimal.Context.__name__ = 'Context' — the Context class short name."
    - "decimal.Context.__module__ = 'decimal' — Context is defined in the decimal module."
    - "decimal.Context.__bases__[0].__name__ = 'object' — Context directly extends object."
    - "decimal.Context.__mro__.__len__() = 2 — MRO is [Context, object]."
    - "decimal.Context.__class__.__name__ = 'type' — Context is a regular Python class (type)."
    - "decimal.ROUND_UP.__class__.__name__ = 'str' — rounding mode constants are plain strings."
    - "decimal.ROUND_UP = 'ROUND_UP', decimal.ROUND_DOWN = 'ROUND_DOWN', etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module identity: __name__, __package__, __loader__ class, __spec__ class
# decimal is NOT a package: __package__ == '' (empty string).
# __loader__ is SourceFileLoader (pure Python), __spec__ is ModuleSpec.
# ---------------------------------------------------------------------------

table decimal_extra90.module_identity:
  description: "decimal module identity: __name__, __package__, __loader__.__class__.__name__, __spec__.__class__.__name__"
  kind: python_call_eq
  category: module_identity
  id_prefix: decimalmodule90

  columns: [id, function, args, expected]
  rows:
    - [dec_name_eq,        __name__.__eq__,                       ["decimal"],          true]
    - [dec_name_not_dec2,  __name__.__eq__,                       ["decimal2"],         false]
    - [dec_pkg_empty,      __package__.__eq__,                    [""],                 true]
    - [dec_pkg_not_dec,    __package__.__eq__,                    ["decimal"],          false]
    - [dec_loader_cls_eq,  __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [dec_spec_cls_eq,    __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]

# ---------------------------------------------------------------------------
# decimal.Context class identity
# Context is a regular Python class (type). __module__ == 'decimal'.
# __bases__[0].__name__ == 'object'. __mro__.__len__() == 2.
# __class__.__name__ == 'type' (it is a type, not a metaclass or C extension type).
# ---------------------------------------------------------------------------

table decimal_extra90.Context_class_identity:
  description: "decimal.Context class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalmodule90

  columns: [id, function, args, expected]
  rows:
    - [ctx_name_eq,       Context.__name__.__eq__,                   ["Context"],  true]
    - [ctx_module_eq,     Context.__module__.__eq__,                 ["decimal"],  true]
    - [ctx_qualname_eq,   Context.__qualname__.__eq__,               ["Context"],  true]
    - [ctx_base_eq,       "Context.__bases__[0].__name__.__eq__",     ["object"],   true]
    - [ctx_base_not_exc,  "Context.__bases__[0].__name__.__eq__",     ["Exception"], false]
    - [ctx_mro_len,       Context.__mro__.__len__,                   [],           2]
    - [ctx_cls_type,      Context.__class__.__name__.__eq__,         ["type"],     true]

# ---------------------------------------------------------------------------
# decimal rounding mode class names
# ROUND_UP, ROUND_DOWN, ROUND_HALF_UP, ROUND_HALF_EVEN are all plain str constants.
# Their __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table decimal_extra90.rounding_mode_classnames:
  description: "decimal rounding mode constants class names — all are 'str'"
  kind: python_call_eq
  category: constant_type
  id_prefix: decimalmodule90

  columns: [id, function, args, expected]
  rows:
    - [roundup_cls_eq,       ROUND_UP.__class__.__name__.__eq__,       ["str"],   true]
    - [rounddown_cls_eq,     ROUND_DOWN.__class__.__name__.__eq__,     ["str"],   true]
    - [roundhalfup_cls_eq,   ROUND_HALF_UP.__class__.__name__.__eq__,  ["str"],   true]
    - [roundhalfeven_cls_eq, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],  true]
    - [roundup_not_int,      ROUND_UP.__class__.__name__.__eq__,       ["int"],   false]

# ---------------------------------------------------------------------------
# decimal rounding mode constant values
# ROUND_UP='ROUND_UP', ROUND_DOWN='ROUND_DOWN',
# ROUND_HALF_UP='ROUND_HALF_UP', ROUND_HALF_EVEN='ROUND_HALF_EVEN'
# ---------------------------------------------------------------------------

table decimal_extra90.rounding_mode_values:
  description: "decimal rounding mode constant string values"
  kind: python_call_eq
  category: constant_value
  id_prefix: decimalmodule90

  columns: [id, function, args, expected]
  rows:
    - [roundup_val_eq,       ROUND_UP.__eq__,       ["ROUND_UP"],       true]
    - [rounddown_val_eq,     ROUND_DOWN.__eq__,     ["ROUND_DOWN"],     true]
    - [roundhalfup_val_eq,   ROUND_HALF_UP.__eq__,  ["ROUND_HALF_UP"],  true]
    - [roundhalfeven_val_eq, ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
    - [roundup_not_down,     ROUND_UP.__eq__,       ["ROUND_DOWN"],     false]
    - [roundup_len,          ROUND_UP.__len__,      [],                 8]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra90.module.name_eq_decimal:
  description: "decimal.__name__ == 'decimal' (the module's __name__ attribute equals its dotted module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra90.module.package_is_empty_string:
  description: "decimal.__package__ == '' (decimal is a top-level module, not a package; __package__ is an empty string, unlike re or pathlib which are packages)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra90.Context.mro_len_2:
  description: "decimal.Context.__mro__.__len__() == 2 (MRO is [Context, object]; Context directly extends object)"
  category: class_identity
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra90.ROUND_UP.value_eq_ROUND_UP:
  description: "decimal.ROUND_UP == 'ROUND_UP' (rounding mode constants are plain strings whose value equals their name)"
  category: constant_value
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra90.ROUND_HALF_EVEN.classname_is_str:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' (all decimal rounding mode constants are plain str instances)"
  category: constant_type
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true
