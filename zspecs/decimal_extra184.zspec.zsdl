spec: decimal_extra184
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.Decimal.__lt__.__name__ == '__lt__' (len=6); __class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Decimal.__le__.__name__ == '__le__' (len=6); __class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Decimal.__gt__.__name__ == '__gt__' (len=6); __class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Decimal.__ge__.__name__ == '__ge__' (len=6); __class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Decimal.__eq__.__name__ == '__eq__' (len=6); __class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Decimal.__ne__.__name__ == '__ne__' (len=6); __class__.__name__ == 'wrapper_descriptor'."
    - "All 6 comparison dunders have __name__ length == 6 (tied); each name is exactly __(2 chars)XX(2 chars)__(2 chars)."
    - "decimal.Decimal.__hash__.__name__ == '__hash__' (len=8); __class__.__name__ == 'wrapper_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal ordering comparison dunder __name__ equality
# __lt__, __le__, __gt__, __ge__ — all length 6
# ---------------------------------------------------------------------------

table decimal_extra184.decimal_order_cmp_names:
  description: "decimal.Decimal ordering comparison dunder __name__ values: __lt__='__lt__'(6), __le__='__le__'(6), __gt__='__gt__'(6), __ge__='__ge__'(6)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcmp184

  columns: [id, function, args, expected, description]
  rows:
    - [lt_name_eq,  decimal.Decimal.__lt__.__name__.__eq__, ["__lt__"], true, "decimal.Decimal.__lt__.__name__ == '__lt__'; confirmed Python 3.14.3 macOS"]
    - [lt_name_len, decimal.Decimal.__lt__.__name__.__len__, [],        6,    "decimal.Decimal.__lt__.__name__.__len__() == 6 — _(1)_(2)l(3)t(4)_(5)_(6); confirmed Python 3.14.3 macOS"]
    - [le_name_eq,  decimal.Decimal.__le__.__name__.__eq__, ["__le__"], true, "decimal.Decimal.__le__.__name__ == '__le__'; confirmed Python 3.14.3 macOS"]
    - [gt_name_eq,  decimal.Decimal.__gt__.__name__.__eq__, ["__gt__"], true, "decimal.Decimal.__gt__.__name__ == '__gt__'; confirmed Python 3.14.3 macOS"]
    - [ge_name_eq,  decimal.Decimal.__ge__.__name__.__eq__, ["__ge__"], true, "decimal.Decimal.__ge__.__name__ == '__ge__'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal equality/inequality dunder __name__ and lengths
# __eq__(6), __ne__(6) — tied with the ordering dunders at length 6
# ---------------------------------------------------------------------------

table decimal_extra184.decimal_eq_ne_names:
  description: "decimal.Decimal equality dunder __name__ values: __eq__='__eq__'(6), __ne__='__ne__'(6); both length 6 matching ordering dunders"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcmp184

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name_eq,  decimal.Decimal.__eq__.__name__.__eq__, ["__eq__"], true, "decimal.Decimal.__eq__.__name__ == '__eq__'; confirmed Python 3.14.3 macOS"]
    - [eq_name_len, decimal.Decimal.__eq__.__name__.__len__, [],        6,    "decimal.Decimal.__eq__.__name__.__len__() == 6 — _(1)_(2)e(3)q(4)_(5)_(6); confirmed Python 3.14.3 macOS"]
    - [ne_name_eq,  decimal.Decimal.__ne__.__name__.__eq__, ["__ne__"], true, "decimal.Decimal.__ne__.__name__ == '__ne__'; confirmed Python 3.14.3 macOS"]
    - [ne_name_len, decimal.Decimal.__ne__.__name__.__len__, [],        6,    "decimal.Decimal.__ne__.__name__.__len__() == 6 — _(1)_(2)n(3)e(4)_(5)_(6); confirmed Python 3.14.3 macOS"]
    - [le_name_len, decimal.Decimal.__le__.__name__.__len__, [],        6,    "decimal.Decimal.__le__.__name__.__len__() == 6 — _(1)_(2)l(3)e(4)_(5)_(6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal __hash__ and wrapper_descriptor class type
# __hash__(8) — longer than all 6 comparison dunders; all are wrapper_descriptor
# ---------------------------------------------------------------------------

table decimal_extra184.decimal_hash_and_class_types:
  description: "decimal.Decimal __hash__ length 8 vs comparison dunders length 6; all are wrapper_descriptor instances"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcmp184

  columns: [id, function, args, expected, description]
  rows:
    - [hash_name_eq,    decimal.Decimal.__hash__.__name__.__eq__,    ["__hash__"],         true, "decimal.Decimal.__hash__.__name__ == '__hash__'; confirmed Python 3.14.3 macOS"]
    - [hash_name_len,   decimal.Decimal.__hash__.__name__.__len__,   [],                   8,    "decimal.Decimal.__hash__.__name__.__len__() == 8 — _(1)_(2)h(3)a(4)s(5)h(6)_(7)_(8); confirmed Python 3.14.3 macOS"]
    - [lt_class_eq,     decimal.Decimal.__lt__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "decimal.Decimal.__lt__.__class__.__name__ == 'wrapper_descriptor'; confirmed Python 3.14.3 macOS"]
    - [eq_class_eq,     decimal.Decimal.__eq__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor'; confirmed Python 3.14.3 macOS"]
    - [hash_class_eq,   decimal.Decimal.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra184.lt_name_eq:
  description: "decimal.Decimal.__lt__.__name__ == '__lt__' — less-than comparison dunder; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__lt__.__name__.__eq__
  args: ["__lt__"]
  expected: true

invariant decimal_extra184.le_name_eq:
  description: "decimal.Decimal.__le__.__name__ == '__le__' — less-than-or-equal comparison dunder; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__le__.__name__.__eq__
  args: ["__le__"]
  expected: true

invariant decimal_extra184.gt_name_eq:
  description: "decimal.Decimal.__gt__.__name__ == '__gt__' — greater-than comparison dunder; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__gt__.__name__.__eq__
  args: ["__gt__"]
  expected: true

invariant decimal_extra184.ge_name_eq:
  description: "decimal.Decimal.__ge__.__name__ == '__ge__' — greater-than-or-equal comparison dunder; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__ge__.__name__.__eq__
  args: ["__ge__"]
  expected: true

invariant decimal_extra184.eq_name_eq:
  description: "decimal.Decimal.__eq__.__name__ == '__eq__' — equality comparison dunder; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__eq__.__name__.__eq__
  args: ["__eq__"]
  expected: true

invariant decimal_extra184.ne_name_eq:
  description: "decimal.Decimal.__ne__.__name__ == '__ne__' — inequality comparison dunder; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__ne__.__name__.__eq__
  args: ["__ne__"]
  expected: true

invariant decimal_extra184.all_cmp_dunders_len_6:
  description: "decimal.Decimal.__eq__.__name__.__len__() == 6 — all 6 comparison dunders (__lt__, __le__, __gt__, __ge__, __eq__, __ne__) have name length 6; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__eq__.__name__.__len__
  args: []
  expected: 6

invariant decimal_extra184.hash_name_eq:
  description: "decimal.Decimal.__hash__.__name__ == '__hash__' — hashing dunder, length 8 unlike the 6 comparison dunders; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__hash__.__name__.__eq__
  args: ["__hash__"]
  expected: true

invariant decimal_extra184.hash_name_len_8:
  description: "decimal.Decimal.__hash__.__name__.__len__() == 8 — '__hash__' has 8 chars: _(1)_(2)h(3)a(4)s(5)h(6)_(7)_(8), 2 longer than the comparison dunders; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__hash__.__name__.__len__
  args: []
  expected: 8
