spec: written_number
version: ">=0.11.0"
backend: node(written-number)

docs: https://www.npmjs.com/package/written-number

provenance:
  derived_from:
    - "written-number README — https://www.npmjs.com/package/written-number"
    - "Test vectors verified with written-number via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "written-number source"
  notes:
    - "written-number is an npm package. Install: npm install written-number"
    - "writtenNumber(n) converts an integer to its English word representation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns English word string for the given integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table written_number.writtenNumber:
  kind: node_module_call_eq
  function: ~
  category: convert
  id_prefix: wnum

  columns: [id, args, expected]
  rows:
    - [zero,    [0],       "zero"]
    - [one,     [1],       "one"]
    - [forty_two,   [42],      "forty-two"]
    - [hundred,     [100],     "one hundred"]
    - [thousand,    [1000],    "one thousand"]
    - [million,     [1000000], "one million"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:30:14Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
