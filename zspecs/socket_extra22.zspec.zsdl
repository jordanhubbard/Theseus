spec: socket_extra22
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for socket class, error/timeout/gaierror/herror exceptions, create_server/setdefaulttimeout and table of gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection."
    - "socket_extra20.zspec.zsdl — covers __qualname__.__len__() for socket.socket class and module-level functions."
    - "socket_extra21.zspec.zsdl — covers __qualname__.__len__() for socket exception classes (error/timeout/gaierror/herror)."
  notes:
    - "This spec extends the socket chain through socket_extra21; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__eq__ for socket.socket instance methods (connect, bind, listen, accept, close, recv, send) — no prior spec checks the qualname of any socket.socket bound method or method descriptor. Verified values: connect='socket.connect', bind='socket.bind', listen='socket.listen', accept='socket.accept', close='socket.close', recv='socket.recv', send='socket.send'."
    - "socket_extra8 checks __qualname__.__eq__ for gethostname and getfqdn as module-level functions; those are NOT re-checked here — they are listed in the not_derived_from sentinel above."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — the class is named 'socket', so method qualnames take the form 'socket.<method>'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__ == 'socket.send'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket instance method __qualname__.__eq__ checks
#
# socket_extra8 covers __qualname__.__eq__ for the socket class itself
# (socket.socket.__qualname__ == 'socket') and for module-level functions.
# No prior spec in the socket family checks __qualname__ for any of the
# instance methods of socket.socket.
# The socket class is named 'socket', so method qualnames take the pattern
# 'socket.<method_name>'. All values verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra22.socket_method_qualnames:
  description: "__qualname__.__eq__ for socket.socket instance methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: smqn22

  columns: [id, function, args, expected]
  rows:
    - [connect, socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [bind,    socket.bind.__qualname__.__eq__,    ["socket.bind"],    true]
    - [listen,  socket.listen.__qualname__.__eq__,  ["socket.listen"],  true]
    - [accept,  socket.accept.__qualname__.__eq__,  ["socket.accept"],  true]
    - [close,   socket.close.__qualname__.__eq__,   ["socket.close"],   true]
    - [recv,    socket.recv.__qualname__.__eq__,    ["socket.recv"],    true]
    - [send,    socket.send.__qualname__.__eq__,    ["socket.send"],    true]
