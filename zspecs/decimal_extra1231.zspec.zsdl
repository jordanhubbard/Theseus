spec: decimal_extra1231
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.__dict__.__contains__ checks for module-level names: Decimal, Context, DecimalException, Overflow, Underflow, InvalidOperation, getcontext, setcontext, localcontext, ROUND_HALF_UP, ROUND_DOWN, MAX_PREC, Inexact; decimal.DecimalException.__dict__.__contains__ checks for exception class attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.__dict__.__contains__ for module-level class names, function names, and constant names exported by the decimal module; checks decimal.__dict__.__contains__ for names that should NOT be present (e.g. io-owned, re-owned names); checks decimal.DecimalException.__dict__.__contains__ for attributes defined directly on DecimalException vs. inherited from ArithmeticError; none of these decimal.__dict__.__contains__ or decimal.DecimalException.__dict__.__contains__ membership checks were covered in _extra1201, _extra1216, or any prior decimal_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1231.module_dict_contains_classes:
  description: "decimal.__dict__.__contains__ checks for module-level class names — Decimal, Context, DecimalException, Overflow, Underflow, InvalidOperation, Inexact all present in decimal.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1231mc
  columns: [id, function, args, expected]
  rows:
    - [dc1231mc001, decimal.__dict__.__contains__, ["Decimal"],           true]
    - [dc1231mc002, decimal.__dict__.__contains__, ["Context"],           true]
    - [dc1231mc003, decimal.__dict__.__contains__, ["DecimalException"],  true]
    - [dc1231mc004, decimal.__dict__.__contains__, ["Overflow"],          true]
    - [dc1231mc005, decimal.__dict__.__contains__, ["Underflow"],         true]
    - [dc1231mc006, decimal.__dict__.__contains__, ["InvalidOperation"],  true]
    - [dc1231mc007, decimal.__dict__.__contains__, ["Inexact"],           true]
    - [dc1231mc008, decimal.__dict__.__contains__, ["DivisionByZero"],   true]
    - [dc1231mc009, decimal.__dict__.__contains__, ["Rounded"],           true]
    - [dc1231mc010, decimal.__dict__.__contains__, ["Subnormal"],         true]

table decimal_extra1231.module_dict_contains_functions_and_constants:
  description: "decimal.__dict__.__contains__ checks for module-level functions and rounding constants — getcontext, setcontext, localcontext, ROUND_HALF_UP, ROUND_DOWN, MAX_PREC present; names from unrelated modules absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1231fc
  columns: [id, function, args, expected]
  rows:
    - [dc1231fc001, decimal.__dict__.__contains__, ["getcontext"],    true]
    - [dc1231fc002, decimal.__dict__.__contains__, ["setcontext"],    true]
    - [dc1231fc003, decimal.__dict__.__contains__, ["localcontext"],  true]
    - [dc1231fc004, decimal.__dict__.__contains__, ["ROUND_HALF_UP"], true]
    - [dc1231fc005, decimal.__dict__.__contains__, ["ROUND_DOWN"],    true]
    - [dc1231fc006, decimal.__dict__.__contains__, ["MAX_PREC"],      true]
    - [dc1231fc007, decimal.__dict__.__contains__, ["IOBase"],        false]
    - [dc1231fc008, decimal.__dict__.__contains__, ["Pattern"],       false]
    - [dc1231fc009, decimal.__dict__.__contains__, ["Path"],          false]
    - [dc1231fc010, decimal.__dict__.__contains__, ["ROUND_CEILING"], true]

table decimal_extra1231.decimal_exception_dict_contains:
  description: "decimal.DecimalException.__dict__.__contains__ checks for attributes defined directly on DecimalException — checks what DecimalException adds over ArithmeticError; arithmetic-only dunders and Decimal-specific methods absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1231de
  columns: [id, function, args, expected]
  rows:
    - [dc1231de001, decimal.DecimalException.__dict__.__contains__, ["__doc__"],       true]
    - [dc1231de002, decimal.DecimalException.__dict__.__contains__, ["__module__"],    true]
    - [dc1231de003, decimal.DecimalException.__dict__.__contains__, ["__add__"],       false]
    - [dc1231de004, decimal.DecimalException.__dict__.__contains__, ["__sub__"],       false]
    - [dc1231de005, decimal.DecimalException.__dict__.__contains__, ["__mul__"],       false]
    - [dc1231de006, decimal.DecimalException.__dict__.__contains__, ["as_tuple"],      false]
    - [dc1231de007, decimal.DecimalException.__dict__.__contains__, ["to_eng_string"], false]
    - [dc1231de008, decimal.DecimalException.__dict__.__contains__, ["sqrt"],          false]
    - [dc1231de009, decimal.Overflow.__dict__.__contains__,         ["__doc__"],       true]
    - [dc1231de010, decimal.Underflow.__dict__.__contains__,        ["__doc__"],       true]
    - [dc1231de011, decimal.InvalidOperation.__dict__.__contains__, ["__doc__"],       true]
    - [dc1231de012, decimal.Inexact.__dict__.__contains__,          ["__doc__"],       true]
