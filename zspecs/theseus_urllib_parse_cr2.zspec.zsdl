spec: theseus_urllib_parse_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_urllib_parse_cr2)
blocks: urllib

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html"
  notes:
    - "Clean-room extended URL parsing utilities. Do NOT import urllib or urllib.parse."
    - "urlencode(query): encode dict or list of pairs as query string."
    - "parse_qs(qs): parse query string into dict of lists."
    - "parse_qsl(qs): parse query string into list of (key, value) pairs."
    - "urljoin(base, url): resolve relative URL against base."
    - "urllib2_urlencode(): urlencode({'a':'1','b':'2'}) produces 'a=1&b=2' or similar."
    - "urllib2_parse_qs(): parse_qs('a=1&b=2') == {'a': ['1'], 'b': ['2']}."
    - "urllib2_urljoin(): urljoin('http://x.com/a/b', '../c') == 'http://x.com/a/c'."
    - "Export: urlencode, parse_qs, parse_qsl, urljoin."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_urllib_parse_cr2.urlencode:
  description: "urlencode({'key': 'val'}) produces 'key=val'"
  category: encode
  kind: python_call_eq
  function: urllib2_urlencode
  args: []
  expected: "key=val"

invariant theseus_urllib_parse_cr2.parse_qs:
  description: "parse_qs('a=1') == {'a': ['1']}"
  category: parse
  kind: python_call_eq
  function: urllib2_parse_qs
  args: []
  expected: {"a": ["1"]}

invariant theseus_urllib_parse_cr2.urljoin:
  description: "urljoin('http://x.com/a/', 'b') == 'http://x.com/a/b'"
  category: join
  kind: python_call_eq
  function: urllib2_urljoin
  args: []
  expected: "http://x.com/a/b"
