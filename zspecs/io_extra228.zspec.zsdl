spec: io_extra228
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io class __qualname__ contracts for BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper, IOBase, RawIOBase, BufferedIOBase, TextIOBase, and method __qualname__ for BytesIO.read, BytesIO.write, StringIO.read."
    - "io.BytesIO.__qualname__ == 'BytesIO'; verified with Python 3.14.3."
    - "io.StringIO.__qualname__ == 'StringIO'; verified with Python 3.14.3."
    - "io.FileIO.__qualname__ == 'FileIO'; verified with Python 3.14.3."
    - "io.BufferedReader.__qualname__ == 'BufferedReader'; verified with Python 3.14.3."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter'; verified with Python 3.14.3."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper'; verified with Python 3.14.3."
    - "io.IOBase.__qualname__ == 'IOBase'; verified with Python 3.14.3."
    - "io.RawIOBase.__qualname__ == 'RawIOBase'; verified with Python 3.14.3."
    - "io.BufferedIOBase.__qualname__ == 'BufferedIOBase'; verified with Python 3.14.3."
    - "io.TextIOBase.__qualname__ == 'TextIOBase'; verified with Python 3.14.3."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read'; verified with Python 3.14.3."
    - "io.BytesIO.write.__qualname__ == 'BytesIO.write'; verified with Python 3.14.3."
    - "io.StringIO.read.__qualname__ == 'StringIO.read'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __qualname__ values
# All public io classes; __qualname__ == __name__ for top-level classes.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table io_extra228.class_qualnames:
  description: "io class __qualname__ contracts for BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper, IOBase, RawIOBase, BufferedIOBase, TextIOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: ioclsqualname228

  columns: [id, function, args, expected]
  rows:
    - [bytesio_qualname,      BytesIO.__qualname__.__eq__,      ["BytesIO"],       true]
    - [stringio_qualname,     StringIO.__qualname__.__eq__,     ["StringIO"],      true]
    - [fileio_qualname,       FileIO.__qualname__.__eq__,       ["FileIO"],        true]
    - [bufread_qualname,      BufferedReader.__qualname__.__eq__, ["BufferedReader"], true]
    - [bufwrite_qualname,     BufferedWriter.__qualname__.__eq__, ["BufferedWriter"], true]
    - [textiowrap_qualname,   TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"], true]
    - [iobase_qualname,       IOBase.__qualname__.__eq__,       ["IOBase"],        true]
    - [rawiobase_qualname,    RawIOBase.__qualname__.__eq__,    ["RawIOBase"],     true]
    - [bufiobase_qualname,    BufferedIOBase.__qualname__.__eq__, ["BufferedIOBase"], true]
    - [textiobase_qualname,   TextIOBase.__qualname__.__eq__,   ["TextIOBase"],    true]

# ---------------------------------------------------------------------------
# io method __qualname__ values
# Methods encode their enclosing class: 'ClassName.method'.
# ---------------------------------------------------------------------------

table io_extra228.method_qualnames:
  description: "io method __qualname__ contracts for BytesIO.read, BytesIO.write, StringIO.read; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: iomethqualname228

  columns: [id, function, args, expected]
  rows:
    - [bytesio_read_qualname,   BytesIO.read.__qualname__.__eq__,   ["BytesIO.read"],   true]
    - [bytesio_write_qualname,  BytesIO.write.__qualname__.__eq__,  ["BytesIO.write"],  true]
    - [stringio_read_qualname,  StringIO.read.__qualname__.__eq__,  ["StringIO.read"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants for key __qualname__ values
# ---------------------------------------------------------------------------

invariant io_extra228.BytesIO.qualname:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra228.StringIO.qualname:
  description: "io.StringIO.__qualname__ == 'StringIO' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra228.BufferedReader.qualname:
  description: "io.BufferedReader.__qualname__ == 'BufferedReader' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra228.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra228.BytesIO.read.qualname:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read' — method qualname encodes the enclosing class; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__eq__
  args: ["BytesIO.read"]
  expected: true

invariant io_extra228.StringIO.read.qualname:
  description: "io.StringIO.read.__qualname__ == 'StringIO.read' — method qualname encodes the enclosing class; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: StringIO.read.__qualname__.__eq__
  args: ["StringIO.read"]
  expected: true
