spec: ft3136
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (ft3136): __call__, __len__, __getitem__ dict-presence checks for functools types."
    - "functools.partial and functools._lru_cache_wrapper define __call__ in their own __dict__; they are C-level callable types."
    - "functools.partialmethod and functools.cached_property do not define __call__ in their own __dict__."
    - "None of the four functools types define __len__ or __getitem__ in their own __dict__."
    - "functools._lru_cache_wrapper is accessed as type(functools.lru_cache(lambda: None)) at runtime; functools._lru_cache_wrapper is the internal C wrapper class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3136.call:
  description: "functools types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3136
  columns: [id, function, args, expected]
  rows:
    - ["ft3136001", operator.contains, [functools.partial.__dict__,            "__call__"], true]
    - ["ft3136002", operator.contains, [functools.partialmethod.__dict__,      "__call__"], false]
    - ["ft3136003", operator.contains, [functools.cached_property.__dict__,    "__call__"], false]
    - ["ft3136004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__call__"], true]

