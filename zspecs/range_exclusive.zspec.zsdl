spec: range_exclusive
version: ">=1.0.1"
backend: node(range-exclusive)

docs: https://www.npmjs.com/package/range-exclusive

provenance:
  derived_from:
    - "range-exclusive README — https://www.npmjs.com/package/range-exclusive"
    - "Test vectors verified with range-exclusive via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "range-exclusive source"
  notes:
    - "range-exclusive is an npm package. Install: npm install range-exclusive"
    - "Returns an array of integers from start up to (but not including) end."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table range_exclusive.range:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: rexc

  columns: [id, args, expected]
  rows:
    - [one_to_four, [1, 5], [1, 2, 3, 4]]
    - [zero_to_three,[0, 4], [0, 1, 2, 3]]
    - [empty,        [5, 5], []]
