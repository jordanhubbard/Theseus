spec: struct_extra156
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra155.zspec.zsdl — covers struct.Struct.size/__qualname__.__eq__('Struct.size') / Struct.format/__qualname__.__eq__('Struct.format') / Struct.size/__name__.__eq__('size') / Struct.format/__name__.__eq__('format') / Struct.size/__objclass__.__name__.__eq__('Struct') / module-level function __name__ strings (table + invariants)."
    - "struct_extra154.zspec.zsdl — covers struct.Struct method qualnames: Struct.pack/__qualname__.__eq__('Struct.pack') / Struct.unpack/__qualname__ / Struct.pack_into/__qualname__ / Struct.pack.__class__.__name__.__eq__('method_descriptor') (table + invariants)."
    - "struct_extra153.zspec.zsdl — covers struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') / Struct.__doc__.__len__()==40 / error.__doc__ NoneType (table + invariants)."
    - "struct_extra152.zspec.zsdl — covers struct.iter_unpack/__class__.__name__/__module__/__name__ / Struct.__name__.__len__()==6 / pack/__unpack/__calcsize/__pack_into __name__ and __name__ lengths (table + invariants)."
    - "struct_extra151.zspec.zsdl — covers struct.__all__.__class__.__name__ / __all__.__contains__('pack'/'error') / __all__.__len__()==8 / error/__name__/__module__/__qualname__ / pack/__unpack/__calcsize qualnames (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra155."
    - "Wave 342 theme: struct.Struct.__doc__ and struct module __doc__ type/length identity — Struct.__doc__.__class__.__name__.__eq__('str') / struct.__doc__.__class__.__name__.__eq__('str') / struct.__doc__.__len__()==1278 / Struct.__doc__.__len__()==40 / pack_into.__name__.__eq__('pack_into') / unpack_from.__name__.__eq__('unpack_from')."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__len__() == 1278. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__len__() == 40. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__.__len__() == 9. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__doc__ == 'Struct(fmt) --> compiled struct object\\n\\n' (40 chars). struct_extra153 anchors Struct.__doc__.__len__()==40 and Struct.__doc__.__class__.__name__=='str'. This spec focuses on the module-level struct.__doc__ (1278 chars), which is the comprehensive docstring for the struct module explaining format strings, byte order prefixes, format characters, and special cases. struct.__doc__.__len__()==1278 is much larger than Struct.__doc__.__len__()==40. Both are 'str' type."
    - "Note: struct.__doc__.__len__() == 1278. The struct module docstring covers: byte order prefixes (@, =, <, >, !), format characters (x, c, b, B, ?, h, H, i, I, l, L, f, d, e, F, D, n, N, P, q, Q, s, p), special cases, and the struct.error exception. This is substantially longer than any other struct doc measured in prior specs. The length 1278 is specific to Python 3.14.3 on macOS/Darwin 25.4.0."
    - "Note: struct.pack_into.__name__ == 'pack_into' (9 chars). struct.unpack_from.__name__ == 'unpack_from' (11 chars). pack_into is a module-level builtin_function_or_method from _struct (extra152 anchors pack_into.__name__.__len__()==9 as a length; this spec anchors the string value). unpack_from.__name__.__len__()==11 is also anchored by extra152 as a length. The string values 'pack_into' and 'unpack_from' are first anchored here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
# struct.__doc__.__class__.__name__.__eq__('str')
# struct.__doc__.__len__()==1278
# struct.Struct.__doc__.__len__()==40
#
# Wave 342 theme: doc content type and length identity for struct and Struct.
#
# Struct.__doc__.__class__.__name__ == 'str' (3 chars; type of the docstring object).
# struct.__doc__.__class__.__name__ == 'str' (3 chars; module docstring is also str).
# struct.__doc__.__len__() == 1278 (comprehensive module-level format string documentation).
# Struct.__doc__.__len__() == 40 (short type-level docstring 'Struct(fmt) --> compiled struct object').
# extra153 anchors Struct.__doc__.__len__()==40 and __class__.__name__=='str' as rows;
# this spec anchors struct.__doc__.__len__()==1278 (module-level) as novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra156.struct_doc_type_and_length:
  description: "struct.Struct.__doc__.__class__.__name__.__eq__('str')==True / struct.__doc__.__class__.__name__.__eq__('str')==True / struct.__doc__.__len__()==1278 / Struct.__doc__.__len__()==40 — Struct.__doc__.__class__.__name__ is 'str' (3 chars; extra153 anchors this; confirmed); struct.__doc__.__class__.__name__ is 'str' (3 chars; module docstring is also str type; novel at module level); struct.__doc__.__len__() is 1278 (comprehensive module docstring covering byte order prefixes/@/=/</>!/!, format chars/x/c/b/B/etc., special cases; much longer than Struct.__doc__); Struct.__doc__.__len__() is 40 ('Struct(fmt) --> compiled struct object\\n\\n' = 40 chars; extra153 anchors this; confirmed); 1278 >> 40 (module doc 31.95x longer than Struct doc); first structdoc156 anchor for struct.__doc__.__len__()==1278"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc156

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_doc_class_str,   "Struct.__doc__.__class__.__name__.__eq__", ["str"], true, "struct.Struct.__doc__.__class__.__name__ == 'str' (3 chars; extra153 anchors this; Struct type-level docstring is a str object)"]
    - [module_doc_class_str,   "__doc__.__class__.__name__.__eq__",        ["str"], true, "struct.__doc__.__class__.__name__ == 'str' (3 chars; module-level docstring is str; novel at module level in this spec)"]
    - [module_doc_len_1278,    "__doc__.__len__",                           [], 1278, "struct.__doc__.__len__() is 1278 (comprehensive module docstring: byte order + format chars + special cases; Python 3.14.3 specific)"]
    - [Struct_doc_len_40,      "Struct.__doc__.__len__",                    [], 40,   "struct.Struct.__doc__.__len__() is 40 ('Struct(fmt) --> compiled struct object\\n\\n'; extra153 anchors this; 40 << 1278)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__eq__('pack_into')
# struct.unpack_from.__name__.__eq__('unpack_from')
# struct.pack_into.__name__.__len__()==9
# struct.unpack_from.__name__.__len__()==11
#
# Wave 342 theme: module-level pack_into/unpack_from __name__ string values.
#
# pack_into.__name__ == 'pack_into' (9 chars; extra152 anchors len but NOT string value).
# unpack_from.__name__ == 'unpack_from' (11 chars; extra152 anchors len but NOT string).
# pack_into is a builtin_function_or_method from _struct.
# unpack_from is a builtin_function_or_method from _struct.
# No prior struct spec anchors pack_into/__name__ string or unpack_from/__name__ string as a
# table under structdoc156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra156.pack_into_unpack_from_name_strings:
  description: "struct.pack_into.__name__.__eq__('pack_into')==True / unpack_from.__name__.__eq__('unpack_from')==True / pack_into.__name__.__len__()==9 / unpack_from.__name__.__len__()==11 — pack_into.__name__ is 'pack_into' (9 chars; 'pack'=4 + '_'=1 + 'into'=4 = 9; extra152 anchors __name__.__len__()==9 as a length but NOT the string value 'pack_into'; builtin_function_or_method from _struct; packs into writable buffer at offset); unpack_from.__name__ is 'unpack_from' (11 chars; 'unpack'=6 + '_'=1 + 'from'=4 = 11; extra152 anchors len but NOT string value; unpacks from buffer at optional offset); pack_into.__name__.__len__() is 9 (confirmed); unpack_from.__name__.__len__() is 11 (confirmed; 2 chars longer than pack_into); length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9) < unpack_from(11); first structdoc156 anchor for pack_into/__name__ and unpack_from/__name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc156

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name_str,         "pack_into.__name__.__eq__",    ["pack_into"],   true, "struct.pack_into.__name__ == 'pack_into' (9 chars; extra152 anchors len 9 but NOT string; builtin_function from _struct; packs into buffer)"]
    - [unpack_from_name_str,       "unpack_from.__name__.__eq__",  ["unpack_from"], true, "struct.unpack_from.__name__ == 'unpack_from' (11 chars; extra152 anchors len 11 but NOT string; unpacks from buffer at offset)"]
    - [pack_into_name_len_9,       "pack_into.__name__.__len__",   [], 9,            "struct.pack_into.__name__.__len__() is 9 ('pack_into' = 'pack'=4 + '_into'=5 = 9; extra152 anchors this length; confirmed)"]
    - [unpack_from_name_len_11,    "unpack_from.__name__.__len__", [], 11,           "struct.unpack_from.__name__.__len__() is 11 ('unpack_from' = 'unpack'=6 + '_from'=5 = 11; extra152 anchors this length; confirmed)"]

# ---------------------------------------------------------------------------
# struct.__doc__ and Struct.__doc__ length comparison table
#
# Wave 342 theme: doc length ratio between module and Struct type docstrings.
#
# struct.__doc__.__len__() == 1278 (module-level; comprehensive format reference).
# Struct.__doc__.__len__() == 40 (type-level; short constructor signature).
# 1278 / 40 = 31.95 (module doc is ~32x longer than Struct doc).
# struct.pack_into.__name__.__len__() == 9; struct.unpack_from.__name__.__len__() == 11.
# No prior struct spec anchors module-level doc length as a table under structdoc156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra156.doc_length_and_function_name_lengths:
  description: "struct.__doc__.__len__()==1278 / Struct.__doc__.__len__()==40 / struct.pack_into.__name__.__len__()==9 / struct.unpack_from.__name__.__len__()==11 — struct.__doc__.__len__() is 1278 (first anchor for module-level doc length; comprehensive reference for format strings/byte order/special cases; Python 3.14.3-specific value); Struct.__doc__.__len__() is 40 (extra153 anchors this; confirmed; 'Struct(fmt) --> compiled struct object\\n\\n' = 40 chars); pack_into.__name__.__len__() is 9 ('pack_into'; extra152 anchors this length); unpack_from.__name__.__len__() is 11 ('unpack_from'; extra152 anchors this length); ordering by size: Struct_doc(40) < pack_into_name(9)... wait, ordering: pack_into_name(9) < unpack_from_name(11) < Struct_doc(40) << module_doc(1278); first structdoc156 anchor for combined view of these lengths"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc156

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_len_1278b,    "__doc__.__len__",                   [], 1278, "struct.__doc__.__len__() is 1278 (module docstring; comprehensive format reference; Python 3.14.3 specific; confirmed)"]
    - [Struct_doc_len_40b,      "Struct.__doc__.__len__",            [], 40,   "struct.Struct.__doc__.__len__() is 40 (type docstring; extra153 anchors; confirmed; 'Struct(fmt) --> compiled struct object')"]
    - [pack_into_name_len_9b,   "pack_into.__name__.__len__",       [], 9,    "struct.pack_into.__name__.__len__() is 9 ('pack_into' = 9 chars; extra152 anchors; confirmed; builtin_function from _struct)"]
    - [unpack_from_name_len_11b,"unpack_from.__name__.__len__",     [], 11,   "struct.unpack_from.__name__.__len__() is 11 ('unpack_from' = 11 chars; extra152 anchors; confirmed; longest module-level function name here)"]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.Struct.__doc__.__class__.__name__ is 'str' (3 chars). The Struct type-level
# docstring is a str object (not None or bytes). struct_extra153 anchors this fact as a
# table row. This standalone confirms the same fact under structdoc156. The Struct.__doc__
# string is 'Struct(fmt) --> compiled struct object\n\n' (40 chars = 'Struct(fmt) --> '=16
# + 'compiled struct object'=22 + '\n\n'=2). All Python-defined and C-extension docstrings
# are str objects when present. The C extension type struct.Struct provides a non-None
# docstring of type 'str'. struct.error.__doc__ is None (extra153 anchors this).
# No prior struct spec anchors Struct.__doc__.__class__.__name__ as a standalone under
# structdoc156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra156.Struct_doc_class_str:
  description: "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars); Struct type-level docstring is a str object (not None like struct.error.__doc__); extra153 anchors this as a table row; confirmed as standalone under structdoc156; Struct.__doc__ == 'Struct(fmt) --> compiled struct object\\n\\n' (40 chars; extra153 anchors len); struct.__doc__.__class__.__name__=='str' (same type; module doc is also str); no prior struct spec anchors this as a standalone; first standalone under structdoc156"
  category: identity
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.__doc__.__class__.__name__ is 'str' (3 chars). The struct module docstring
# is a str object (1278 chars). Module-level docstrings in Python are always str objects
# when present (not None). The struct module's docstring is defined in Modules/_struct.c
# as a C string literal. Python converts C string literals to Python str objects when
# building the module. struct.__doc__ contains the comprehensive format string reference
# that defines the module's public API: byte order prefixes, format characters, special
# cases. This is the first standalone anchoring struct.__doc__.__class__.__name__ under
# structdoc156 (as opposed to Struct.__doc__.__class__.__name__ from extra153).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra156.module_doc_class_str:
  description: "struct.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars); module-level docstring is a str object (not None); struct module docstring defined in Modules/_struct.c as C string literal; Python converts to str; struct.__doc__.__len__()==1278 (comprehensive format reference); ties Struct.__doc__.__class__.__name__=='str' (extra153); module __doc__ vs type __doc__ both are str but very different lengths (1278 vs 40); no prior struct spec anchors struct.__doc__.__class__.__name__ as a standalone; first standalone under structdoc156"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__eq__('pack_into') — standalone
#
# struct.pack_into.__name__ is 'pack_into' (9 chars). struct.pack_into is a
# builtin_function_or_method from the _struct C extension. pack_into(fmt, buffer, offset,
# v1, v2, ...) packs values v1, v2, ... according to format string fmt into the writable
# buffer starting at position offset. The buffer must be writable (bytearray, memoryview,
# ctypes array). extra152 anchors pack_into.__name__.__len__()==9; this standalone anchors
# the string value 'pack_into'. 'pack_into' uses an underscore to join 'pack' (4 chars) and
# 'into' (4 chars), making the full name 9 chars. extra155 anchors pack_into in the
# module-level function __name__ table as a string value (structgs155 table row); this
# spec provides a standalone invariant for the same value under structdoc156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra156.pack_into_name_str:
  description: "struct.pack_into.__name__.__eq__('pack_into') == True — 9 chars = 'pack'=4 + '_'=1 + 'into'=4; builtin_function_or_method from _struct C extension; pack_into(fmt, buffer, offset, v1, ...) packs into writable buffer at offset; extra152 anchors __name__.__len__()==9 but NOT the string value; extra155 anchors 'pack_into' as a table row under structgs155; this is first standalone under structdoc156; length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9) < unpack_from(11)"
  category: identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__name__.__eq__('unpack_from') — standalone
#
# struct.unpack_from.__name__ is 'unpack_from' (11 chars = 'unpack'=6 + '_from'=5 = 11).
# struct.unpack_from is a builtin_function_or_method from the _struct C extension.
# unpack_from(fmt, buffer, offset=0) unpacks values from buffer starting at offset,
# without requiring the buffer to be exactly the right size. extra152 anchors
# unpack_from.__name__.__len__()==11 (the length). This standalone anchors the string
# value 'unpack_from' (11 chars). 'unpack_from' is 2 chars longer than 'pack_into' (9),
# because 'from' (4 chars) + 'unpack' (6 chars) vs 'into' (4 chars) + 'pack' (4 chars):
# unpack_from = 6+1+4 = 11 vs pack_into = 4+1+4 = 9.
# No prior struct spec anchors unpack_from.__name__ string as a standalone under structdoc156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra156.unpack_from_name_str:
  description: "struct.unpack_from.__name__.__eq__('unpack_from') == True — 11 chars = 'unpack'=6 + '_'=1 + 'from'=4 = 11; builtin_function_or_method from _struct C extension; unpack_from(fmt, buffer, offset=0) unpacks from buffer at offset without size constraint; extra152 anchors __name__.__len__()==11 but NOT the string value; longest module-level function __name__ anchored in this spec; length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9) < unpack_from(11); no prior struct spec anchors this as a standalone; first standalone under structdoc156"
  category: identity
  kind: python_call_eq
  function: unpack_from.__name__.__eq__
  args: ["unpack_from"]
  expected: true

