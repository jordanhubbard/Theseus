spec: hashlib_extra154
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra153.zspec.zsdl — covers _hashlib.__dict__.__len__()==32 / _hashlib.__dict__.__class__.__name__.__eq__('dict') / _hashlib.__dict__.__contains__('HMAC'/'HASHXOF'/'compare_digest'/'hmac_digest'/'openssl_sha3_256'/'scrypt'/'new') / hashlib.__dict__.__len__()==33 (table + invariants)."
    - "hashlib_extra152.zspec.zsdl — covers hashlib.__dict__.__contains__('md5'/'sha256'/'sha512'/'new'/'algorithms_guaranteed'/'algorithms_available'/'file_digest') / hashlib.__dict__.__len__()==33 / hashlib.__dict__.__class__.__name__.__eq__('dict') (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra153."
    - "Wave 333 theme: hashlib.algorithms_guaranteed vs algorithms_available set membership — both are type 'set' (__class__.__name__=='set'); sha256/md5/sha1/sha512 are all in algorithms_guaranteed; len(algorithms_guaranteed)==14. Also class name type and len comparisons for the two algorithm sets."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha512') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.algorithms_guaranteed) == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (3 chars), not 'frozenset' (9 chars). Despite the name 'guaranteed', the object is a plain mutable set at runtime on CPython 3.14.3/macOS. algorithms_available also has __class__.__name__ == 'set' (3 chars). Both are plain Python sets, not frozensets. extra99 anchors algorithms_guaranteed.__len__()==14 as a standalone; this spec anchors the type name and member membership."
    - "Note: hashlib.algorithms_guaranteed contains exactly 14 algorithms on CPython 3.14.3/macOS: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. These 14 are guaranteed across all CPython platforms regardless of OpenSSL version. algorithms_available is a superset that may include additional OpenSSL-provided algorithms."
    - "Note: The four core hash algorithms in algorithms_guaranteed (sha256/md5/sha1/sha512) are also the four that have named constructor shortcuts at the module level (hashlib.sha256, hashlib.md5, etc.). extra152 anchors hashlib.__dict__.__contains__ for these same names. This spec anchors their membership in algorithms_guaranteed using __contains__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__name__.__len__()==3
#
# Wave 333 theme: algorithms_guaranteed and algorithms_available are both type 'set'.
#
# Both hashlib.algorithms_guaranteed and hashlib.algorithms_available have
# __class__.__name__ == 'set' (3 chars) on CPython 3.14.3/macOS — they are plain
# mutable sets, not frozensets. The type name 'set' (3 chars) is shorter than
# 'frozenset' (9 chars). No prior hashlib spec anchors algorithms_guaranteed
# or algorithms_available __class__.__name__ as a table under hashalg154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra154.algorithms_guaranteed_and_available_type:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__class__.__name__.__len__()==3 — both algorithm sets are plain 'set' (3 chars), not 'frozenset' (9 chars); type name 'set' is 6 chars shorter than 'frozenset'; extra99 anchors algorithms_guaranteed.__len__()==14; first hashalg154 anchor for __class__.__name__ of either algorithm set"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg154

  columns: [id, function, args, expected, description]
  rows:
    - [alg_guaranteed_class_set,     "algorithms_guaranteed.__class__.__name__.__eq__",  ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; plain mutable set, not frozenset)"]
    - [alg_available_class_set,      "algorithms_available.__class__.__name__.__eq__",   ["set"], true, "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars; plain mutable set, not frozenset)"]
    - [alg_guaranteed_class_len_3,   "algorithms_guaranteed.__class__.__name__.__len__", [],       3, "hashlib.algorithms_guaranteed.__class__.__name__.__len__() is 3 ('set' = 3 chars; 6 shorter than 'frozenset' = 9)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256')
# hashlib.algorithms_guaranteed.__contains__('md5')
# hashlib.algorithms_guaranteed.__contains__('sha1')
# hashlib.algorithms_guaranteed.__contains__('sha512')
#
# Wave 333 theme: four core hash algorithms are all in algorithms_guaranteed.
#
# sha256, md5, sha1, and sha512 are all members of hashlib.algorithms_guaranteed.
# These four are guaranteed across all CPython platforms. extra152 anchors
# hashlib.__dict__.__contains__ for the same names (module-level constructor shortcuts);
# no prior hashlib spec anchors algorithms_guaranteed.__contains__ for any name as a
# table under hashalg154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra154.algorithms_guaranteed_contains_core:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256')==True / __contains__('md5')==True / __contains__('sha1')==True / __contains__('sha512')==True — these four algorithms are guaranteed on all CPython platforms; all four also have named module-level constructor shortcuts (extra152 anchors dict membership); sha256 is SHA-2 32-byte digest; sha512 is SHA-2 64-byte digest; md5 and sha1 are legacy; first hashalg154 anchor for algorithms_guaranteed.__contains__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg154

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_sha256,  "algorithms_guaranteed.__contains__", ["sha256"], true, "hashlib.algorithms_guaranteed.__contains__('sha256') == True (SHA-2 family; 32-byte/256-bit digest; widely used)"]
    - [guaranteed_md5,     "algorithms_guaranteed.__contains__", ["md5"],    true, "hashlib.algorithms_guaranteed.__contains__('md5') == True (legacy; 16-byte/128-bit digest; guaranteed across platforms)"]
    - [guaranteed_sha1,    "algorithms_guaranteed.__contains__", ["sha1"],   true, "hashlib.algorithms_guaranteed.__contains__('sha1') == True (legacy; 20-byte/160-bit digest; guaranteed across platforms)"]
    - [guaranteed_sha512,  "algorithms_guaranteed.__contains__", ["sha512"], true, "hashlib.algorithms_guaranteed.__contains__('sha512') == True (SHA-2 family; 64-byte/512-bit digest)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
#
# Wave 333 theme: algorithms_guaranteed length is exactly 14.
#
# hashlib.algorithms_guaranteed has exactly 14 members on CPython 3.14.3/macOS:
# blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384,
# sha3_512, sha512, shake_128, shake_256. extra99 anchors this as a standalone;
# no prior hashlib spec anchors algorithms_guaranteed.__len__()==14 as a table under
# hashalg154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra154.algorithms_guaranteed_len_and_blake2_shake:
  description: "hashlib.algorithms_guaranteed.__len__()==14 / algorithms_guaranteed.__contains__('blake2b')==True / algorithms_guaranteed.__contains__('sha3_256')==True / algorithms_guaranteed.__contains__('shake_128')==True — 14 guaranteed algorithms: blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_224/sha3_256/sha3_384/sha3_512/sha512/shake_128/shake_256; blake2b and sha3_256 are modern; shake_128 is the XOF (extendable-output-function); extra99 anchors len==14 as standalone; first hashalg154 table anchor for len and these three names"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg154

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_len_14,    "algorithms_guaranteed.__len__",         [],            14, "hashlib.algorithms_guaranteed.__len__() is 14 (blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_*/sha512/shake_*)"]
    - [guaranteed_blake2b,   "algorithms_guaranteed.__contains__",    ["blake2b"],   true, "hashlib.algorithms_guaranteed.__contains__('blake2b') == True (modern hash; guaranteed; variable-length output)"]
    - [guaranteed_sha3_256,  "algorithms_guaranteed.__contains__",    ["sha3_256"],  true, "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True (SHA-3 family; Keccak-based; 32-byte digest)"]
    - [guaranteed_shake_128, "algorithms_guaranteed.__contains__",    ["shake_128"], true, "hashlib.algorithms_guaranteed.__contains__('shake_128') == True (XOF; extendable-output-function; variable length)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (3 chars). Despite the
# name 'algorithms_guaranteed' suggesting an immutable collection, the object is a
# plain mutable Python set at runtime on CPython 3.14.3/macOS. This is distinct from
# frozenset (9 chars), which would be the immutable counterpart. Both
# algorithms_guaranteed and algorithms_available have the same type name 'set' (3 chars).
# No prior hashlib spec anchors algorithms_guaranteed.__class__.__name__.__eq__('set')
# as a standalone under hashalg154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra154.algorithms_guaranteed_class_name_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — 'set' (3 chars); plain mutable set, not 'frozenset' (9 chars); both algorithms_guaranteed and algorithms_available are plain sets; no prior hashlib spec anchors this as a standalone; first standalone under hashalg154"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha256') is True. SHA-256 is the most
# widely used secure hash algorithm in modern cryptography. It produces a 32-byte
# (256-bit) digest and is a member of the SHA-2 family. Its guaranteed presence means
# it is always available on CPython regardless of the underlying OpenSSL version.
# extra152 anchors hashlib.__dict__.__contains__('sha256') (module-level constructor);
# no prior hashlib spec anchors algorithms_guaranteed.__contains__('sha256') as a
# standalone under hashalg154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra154.algorithms_guaranteed_contains_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — SHA-256 is guaranteed on all CPython platforms; 32-byte/256-bit digest; SHA-2 family; most widely used secure hash; extra152 anchors hashlib.__dict__.__contains__('sha256'); no prior hashlib spec anchors this as a standalone; first standalone under hashalg154"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('md5') is True. MD5 is a legacy hash
# algorithm that produces a 16-byte (128-bit) digest. Though MD5 is cryptographically
# broken (collision attacks are known), it remains in algorithms_guaranteed because
# it is useful for non-cryptographic purposes (checksums, content hashing, etc.) and
# is guaranteed to be available on all CPython platforms. extra152 anchors
# hashlib.__dict__.__contains__('md5') (module-level constructor shortcut); no prior
# hashlib spec anchors algorithms_guaranteed.__contains__('md5') as a standalone under
# hashalg154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra154.algorithms_guaranteed_contains_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — MD5 produces 16-byte/128-bit digest; cryptographically broken (collision attacks known) but guaranteed for non-security uses (checksums); extra152 anchors hashlib.__dict__.__contains__('md5'); no prior hashlib spec anchors this as a standalone; first standalone under hashalg154"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 guaranteed algorithms are:
# blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384,
# sha3_512, sha512, shake_128, shake_256. This set includes: 2 SHA-2 truncated variants
# (sha224, sha384), 4 SHA-3 variants (sha3_224/256/384/512), 2 SHAKE XOF functions
# (shake_128/shake_256), 2 BLAKE2 functions (blake2b/blake2s), and 4 classic algorithms
# (md5/sha1/sha256/sha512). extra99 anchors this as a standalone; no prior hashlib spec
# anchors algorithms_guaranteed.__len__()==14 as a standalone under hashalg154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra154.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — 14 guaranteed algorithms: 4 classic (md5/sha1/sha256/sha512) + 2 SHA-2 truncated (sha224/sha384) + 4 SHA-3 (sha3_224/sha3_256/sha3_384/sha3_512) + 2 SHAKE XOF (shake_128/shake_256) + 2 BLAKE2 (blake2b/blake2s); extra99 anchors this; no prior hashlib spec anchors this as a standalone under hashalg154; first standalone under hashalg154"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14
