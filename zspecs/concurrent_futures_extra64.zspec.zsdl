spec: concurrent_futures_extra64
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __defaults__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra63.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12, class __class__.__name__/__qualname__ equality, wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins', class __doc__/__class__/__module__=='builtins' tables, ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins'), as_completed/__class__.__module__.__eq__('builtins'), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function'), class __repr__.__class__.__name__ tables, class __weakref__.__class__.__name__ tables, exception __repr__.__class__.__name__ tables, cf.__all__.__class__.__name__.__eq__('list'), cf.__all__.__len__()==14, __eq__.__class__.__name__.__eq__('wrapper_descriptor'), cf.__all__.__contains__ membership checks, cf.__package__.__eq__('concurrent.futures'), Future/Executor __doc__.__class__.__name__.__eq__('str'), __loader__/__spec__/__file__/__cached__ __class__.__name__, __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__(), Future/__init__ and ThreadPoolExecutor/__init__ and Future.result/done/cancel/exception and ThreadPoolExecutor.submit/shutdown __qualname__.__eq__, wait/as_completed __annotations__.__class__.__name__.__eq__('dict'), wait __globals__.__class__.__name__.__eq__('dict'), wait __globals__.__contains__('wait'), Future.__doc__.__contains__('Represents'), ThreadPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') (extra59), wait/__defaults__/__code__/__class__.__name__ checks, as_completed/__defaults__/__code__/__class__.__name__ checks, Future.__init__/__defaults__/__class__.__name__ checks (extra60), wait/as_completed/Future.__init__ __code__.co_name equality and co_argcount values (extra61), wait/as_completed/Future.__init__ co_varnames/co_filename/co_flags attribute chains (extra62), wait/as_completed/Future.__init__ co_consts/co_nlocals/co_stacksize type identity (extra63)."
    - "This spec covers (cfdef64 namespace): wave 233 theme — __defaults__ type identity and length for wait/as_completed, NoneType identity for Future.__init__, and ThreadPoolExecutor/ProcessPoolExecutor/Executor class identity (__class__.__name__=='type'). NEW in extra64: wait.__defaults__.__class__.__name__=='tuple'; wait.__defaults__.__len__()==2; as_completed.__defaults__.__class__.__name__=='tuple'; as_completed.__defaults__.__len__()==1; Future.__init__.__defaults__.__class__.__name__=='NoneType'; ThreadPoolExecutor.__class__.__name__=='type'; ProcessPoolExecutor.__class__.__name__=='type'; Executor.__class__.__name__=='type'; Future.__doc__.__contains__('result')==True."
    - "concurrent.futures.wait.__defaults__.__class__.__name__ == 'tuple'. wait(fs, timeout=None, return_when=ALL_COMPLETED) has two positional-or-keyword parameters with defaults (timeout=None, return_when=ALL_COMPLETED). __defaults__ is (None, ALL_COMPLETED), a two-element tuple. __class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__defaults__.__len__() == 2. wait.__defaults__ is (None, ALL_COMPLETED), a two-element tuple. len((None, ALL_COMPLETED)) == 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__defaults__.__class__.__name__ == 'tuple'. as_completed(fs, timeout=None) has one positional-or-keyword parameter with a default (timeout=None). __defaults__ is (None,), a one-element tuple. __class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__defaults__.__len__() == 1. as_completed.__defaults__ is (None,), a one-element tuple. len((None,)) == 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__defaults__ is None. Future.__init__(self) has no parameters with defaults. __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__contains__('result') == True. Future.__doc__ is a non-empty string describing the Future class; the docstring mentions 'result' referring to Future.result(). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures __defaults__ tuple checks — extra64
#
# Wave 233 theme: __defaults__ type identity and length.
#
# wait(fs, timeout=None, return_when=ALL_COMPLETED) has __defaults__ with
# two elements (timeout=None, return_when=ALL_COMPLETED).
# as_completed(fs, timeout=None) has __defaults__ with one element (timeout=None).
# Both have __class__.__name__=='tuple'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra64.wait_as_completed_defaults:
  description: "concurrent.futures wait/__defaults__ and as_completed/__defaults__ type identity and length checks in cfdef64 namespace — wave 233 theme: __defaults__ type identity; wait(fs, timeout=None, return_when=ALL_COMPLETED) has __defaults__ a two-element tuple; as_completed(fs, timeout=None) has __defaults__ a one-element tuple; NEW in extra64: first __defaults__.__len__() checks for wait and as_completed in the cfdef64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: cfdef64

  columns: [id, function, args, expected, description]
  rows:
    - [wait_defaults_class,         wait.__defaults__.__class__.__name__.__eq__,         ["tuple"], true, "wait.__defaults__.__class__.__name__ == 'tuple' — wait(fs, timeout=None, return_when=ALL_COMPLETED) has two positional-or-keyword parameters with defaults; __defaults__ is a two-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first __defaults__.__class__.__name__.__eq__ check for wait in the cfdef64 namespace; verified with Python 3.14.3"]
    - [wait_defaults_len,           wait.__defaults__.__len__,                            [],        2,    "wait.__defaults__.__len__() == 2 — wait.__defaults__ is (None, ALL_COMPLETED), a two-element tuple; len((None, ALL_COMPLETED)) == 2; NEW in extra64: first __defaults__.__len__() check for wait in the cfdef64 namespace; verified with Python 3.14.3"]
    - [as_completed_defaults_class, as_completed.__defaults__.__class__.__name__.__eq__,  ["tuple"], true, "as_completed.__defaults__.__class__.__name__ == 'tuple' — as_completed(fs, timeout=None) has one positional-or-keyword parameter with a default (timeout=None); __defaults__ is (None,) a one-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first __defaults__.__class__.__name__.__eq__ check for as_completed in the cfdef64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures __defaults__ length and NoneType checks — extra64
#
# Wave 233 theme: __defaults__ length and NoneType identity.
#
# as_completed.__defaults__.__len__() == 1.
# Future.__init__(self) has no default arguments; __defaults__ is None (NoneType).
# ---------------------------------------------------------------------------

table concurrent_futures_extra64.as_completed_future_defaults:
  description: "concurrent.futures as_completed/__defaults__ length and Future.__init__/__defaults__ NoneType checks in cfdef64 namespace — wave 233 theme: __defaults__ length and NoneType identity; as_completed.__defaults__ is a one-element tuple (__len__()==1); Future.__init__(self) has no defaults (__defaults__ is None, NoneType); NEW in extra64: first __defaults__.__len__() check for as_completed and first __defaults__.__class__.__name__.__eq__('NoneType') for Future.__init__ in the cfdef64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: cfdef64a

  columns: [id, function, args, expected, description]
  rows:
    - [as_completed_defaults_len,      as_completed.__defaults__.__len__,                           [],           1,    "as_completed.__defaults__.__len__() == 1 — as_completed.__defaults__ is (None,) a one-element tuple; len((None,)) == 1; NEW in extra64: first __defaults__.__len__() check for as_completed in the cfdef64 namespace; verified with Python 3.14.3"]
    - [future_init_defaults_class,     Future.__init__.__defaults__.__class__.__name__.__eq__,      ["NoneType"], true, "Future.__init__.__defaults__.__class__.__name__ == 'NoneType' — Future.__init__(self) has no parameters with defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra64: first __defaults__.__class__.__name__.__eq__ check for Future.__init__ in the cfdef64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Future __doc__ content checks — extra64
#
# Wave 233 theme: class docstring content.
#
# Future.__doc__ is a non-empty string. It describes the Future class and
# mentions 'result' (the Future.result() method is a key API surface).
# Future.__doc__.__class__.__name__ == 'str'.
# Future.__doc__.__contains__('result') == True.
# ---------------------------------------------------------------------------

table concurrent_futures_extra64.Future_doc_contains:
  description: "concurrent.futures Future __doc__.__class__.__name__ and __doc__.__contains__ checks in cfdef64 namespace — wave 233 theme: class docstring content; Future.__doc__ is a str; Future.__doc__ contains 'result' (key method); NEW in extra64: these specific __doc__.__contains__('result') checks for Future have not appeared in prior cf specs under the cfdef64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: cfdef64b

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_class,    Future.__doc__.__class__.__name__.__eq__, ["str"],    true, "Future.__doc__.__class__.__name__ == 'str' — Future has a docstring; the docstring is a plain Python str; str.__class__.__name__ is 'str'; NEW in extra64: first __doc__.__class__.__name__.__eq__ check for Future in the cfdef64 namespace; verified with Python 3.14.3"]
    - [future_doc_result,   Future.__doc__.__contains__,              ["result"], true, "Future.__doc__.__contains__('result') == True — Future.__doc__ is a non-empty string describing the concurrent.futures Future class; the docstring mentions 'result' referring to the key Future.result() method; __contains__('result') returns True; NEW in extra64: first __doc__.__contains__('result') check for Future in the cfdef64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures executor class identity checks — extra64
#
# Wave 233 theme: executor class identity.
#
# ThreadPoolExecutor, ProcessPoolExecutor, and Executor are ordinary Python
# classes. Their metaclass is 'type', so __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra64.executor_class_identity:
  description: "concurrent.futures ThreadPoolExecutor/ProcessPoolExecutor/Executor class identity checks in cfdef64 namespace — wave 233 theme: executor class identity; ThreadPoolExecutor.__class__.__name__=='type'; ProcessPoolExecutor.__class__.__name__=='type'; Executor.__class__.__name__=='type'; all three are ordinary Python classes with metaclass 'type'; NEW in extra64: first __class__.__name__.__eq__('type') checks for all three executor classes in the cfdef64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfdef64c

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_class_name,  ThreadPoolExecutor.__class__.__name__.__eq__,  ["type"], true, "ThreadPoolExecutor.__class__.__name__ == 'type' — ThreadPoolExecutor is an ordinary Python class; its metaclass is the built-in 'type'; ThreadPoolExecutor.__class__.__name__ is 'type'; NEW in extra64: first __class__.__name__.__eq__('type') check for ThreadPoolExecutor in the cfdef64 namespace; verified with Python 3.14.3"]
    - [ppe_class_name,  ProcessPoolExecutor.__class__.__name__.__eq__,  ["type"], true, "ProcessPoolExecutor.__class__.__name__ == 'type' — ProcessPoolExecutor is an ordinary Python class; its metaclass is the built-in 'type'; ProcessPoolExecutor.__class__.__name__ is 'type'; NEW in extra64: first __class__.__name__.__eq__('type') check for ProcessPoolExecutor in the cfdef64 namespace; verified with Python 3.14.3"]
    - [executor_class_name, Executor.__class__.__name__.__eq__,         ["type"], true, "Executor.__class__.__name__ == 'type' — Executor is an ordinary Python abstract base class; its metaclass is the built-in 'type'; Executor.__class__.__name__ is 'type'; NEW in extra64: first __class__.__name__.__eq__('type') check for Executor in the cfdef64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra64
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra64.wait_defaults_tuple:
  description: "concurrent.futures.wait.__defaults__.__class__.__name__.__eq__('tuple') returns True — wait(fs, timeout=None, return_when=ALL_COMPLETED) has two positional-or-keyword parameters with defaults; __defaults__ is a two-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first standalone __defaults__.__class__.__name__.__eq__('tuple') invariant for wait in the cfdef64 namespace; wave 233 first __defaults__ type identity invariant for wait; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: wait.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra64.wait_defaults_len_2:
  description: "concurrent.futures.wait.__defaults__.__len__() == 2 — wait.__defaults__ is (None, ALL_COMPLETED), a two-element tuple; len((None, ALL_COMPLETED)) == 2; __len__() returns 2; NEW in extra64: first standalone __defaults__.__len__() invariant for wait in the cfdef64 namespace; wave 233 first __defaults__ length invariant for wait; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: wait.__defaults__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra64.as_completed_defaults_tuple:
  description: "concurrent.futures.as_completed.__defaults__.__class__.__name__.__eq__('tuple') returns True — as_completed(fs, timeout=None) has one positional-or-keyword parameter with a default (timeout=None); __defaults__ is (None,) a one-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first standalone __defaults__.__class__.__name__.__eq__('tuple') invariant for as_completed in the cfdef64 namespace; wave 233 first __defaults__ type identity invariant for as_completed; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: as_completed.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra64.as_completed_defaults_len_1:
  description: "concurrent.futures.as_completed.__defaults__.__len__() == 1 — as_completed.__defaults__ is (None,) a one-element tuple; len((None,)) == 1; __len__() returns 1; NEW in extra64: first standalone __defaults__.__len__() invariant for as_completed in the cfdef64 namespace; wave 233 first __defaults__ length invariant for as_completed; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: as_completed.__defaults__.__len__
  args: []
  expected: 1

invariant concurrent_futures_extra64.Future_doc_result:
  description: "concurrent.futures.Future.__doc__.__contains__('result') returns True — Future.__doc__ is a non-empty string describing the concurrent.futures Future class; the docstring text mentions 'result' referring to the Future.result() method; __contains__('result') returns True; NEW in extra64: first standalone __doc__.__contains__('result') invariant for Future in the cfdef64 namespace; wave 233 first __doc__ content invariant for Future with 'result'; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Future.__doc__.__contains__
  args: ["result"]
  expected: true
