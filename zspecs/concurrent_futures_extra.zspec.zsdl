spec: concurrent_futures_extra
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "concurrent.futures source: Lib/concurrent/futures/ (internal scheduling)"
  notes:
    - "Covers module checks and constant type checks not in concurrent_futures.zspec.zsdl."
    - "Future.__module__ == 'concurrent.futures._base' — the private implementation module."
    - "wait() and as_completed() are top-level module functions; their __name__ reflects the function object."
    - "CancelledError and TimeoutError are re-exported from concurrent.futures._base."
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are str constants used with wait()."
    - "All expected values verified by running Python 3.12 concurrent.futures on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — verifying __name__ for all public classes
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra.classes.Future_name:
  description: "concurrent.futures.Future.__name__ == 'Future'"
  category: classes
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra.classes.ThreadPoolExecutor_name:
  description: "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"
  category: classes
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra.classes.ProcessPoolExecutor_name:
  description: "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'"
  category: classes
  kind: python_call_eq
  function: ProcessPoolExecutor.__name__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra.classes.Executor_name:
  description: "concurrent.futures.Executor.__name__ == 'Executor'"
  category: classes
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra.classes.CancelledError_name:
  description: "concurrent.futures.CancelledError.__name__ == 'CancelledError'"
  category: classes
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra.classes.TimeoutError_name:
  description: "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'"
  category: classes
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant concurrent_futures_extra.classes.BrokenExecutor_name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"
  category: classes
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra.classes.InvalidStateError_name:
  description: "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'"
  category: classes
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — Future lives in concurrent.futures._base
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra.modules.Future_module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"
  category: modules
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks — wait and as_completed
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra.functions.wait_name:
  description: "concurrent.futures.wait.__name__ == 'wait'"
  category: functions
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra.functions.as_completed_name:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed'"
  category: functions
  kind: python_call_eq
  function: as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

# ---------------------------------------------------------------------------
# Constant type checks — FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are str
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra.constants.FIRST_COMPLETED_class:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra.constants.FIRST_EXCEPTION_class:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra.constants.ALL_COMPLETED_class:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true
