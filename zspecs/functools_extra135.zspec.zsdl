  args: []
  expected: 15

invariant functools_extra135.all_contains_reduce:
  description: "functools.__all__.__contains__('reduce') == True — 'reduce' is in functools.__all__; wave 260; new to extra135"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra135.all_contains_lru_cache:
  description: "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is in functools.__all__; wave 260; new to extra135"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra135.all_contains_cached_property:
  description: "functools.__all__.__contains__('cached_property') == True — 'cached_property' is in functools.__all__; wave 260; new to extra135"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["cached_property"]
  expected: true

