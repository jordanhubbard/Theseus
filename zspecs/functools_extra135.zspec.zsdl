# ---------------------------------------------------------------------------
# Table 1: functools.__all__ class identity and length
#
# Wave 260 theme: functools.__all__ list identity and length.
#
# functools.__all__.__class__.__name__ == 'list'
# len(functools.__all__) == 15
# functools.__all__.__class__.__name__.__eq__('list') == True
# functools.__all__.__len__() == 15
#
# functools.__all__ is a plain Python list. On Python 3.14.3 it contains 15
# entries. New to extra135.
# ---------------------------------------------------------------------------

table functools_extra135.all_list_identity:
  description: "functools.__all__ __class__.__name__ == 'list' and __len__() == 15; module-level list of exported names; wave 260; new to extra135"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsall135

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "functools.__all__.__class__.__name__.__eq__('list') == True — __all__ in functools is a plain Python list defined at module scope in Lib/functools.py; it controls what names are exported by 'from functools import *'; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra135"]
    - [all_len_eq_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — on Python 3.14.3 functools.__all__ contains 15 names: update_wrapper, wraps, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, total_ordering, cache, cmp_to_key, lru_cache, reduce, partial, partialmethod, singledispatch, singledispatchmethod, cached_property, Placeholder; list.__len__() returns 15; new to extra135"]
    - [all_class_bases_first_eq_list,
       "__all__.__class__.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.__all__.__class__.__bases__[0].__name__.__eq__('object') == True — list inherits directly from object; __class__.__bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra135"]

# ---------------------------------------------------------------------------
# Table 2: functools.__all__ membership for core decorator names
#
# Wave 260 theme: functools.__all__ contains expected decorator names.
#
# 'reduce' in functools.__all__ == True
# 'lru_cache' in functools.__all__ == True
# 'partial' in functools.__all__ == True
# 'wraps' in functools.__all__ == True
# 'total_ordering' in functools.__all__ == True
# 'cached_property' in functools.__all__ == True
# 'singledispatch' in functools.__all__ == True
#
# These are the most widely used functools decorators and utilities.
# New to extra135.
# ---------------------------------------------------------------------------

table functools_extra135.all_membership_decorators:
  description: "functools.__all__.__contains__ for reduce, lru_cache, partial, wraps, total_ordering, cached_property, singledispatch; core decorator names; wave 260; new to extra135"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsall135

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_reduce,
       "__all__.__contains__",
       ["reduce"],
       true,
       "functools.__all__.__contains__('reduce') == True — 'reduce' is listed in functools.__all__; it is the functional-programming reduce (fold-left) function; list.__contains__('reduce') returns True; new to extra135"]
    - [all_contains_lru_cache,
       "__all__.__contains__",
       ["lru_cache"],
       true,
       "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is listed in functools.__all__; it is the memoizing decorator backed by a least-recently-used cache; list.__contains__('lru_cache') returns True; new to extra135"]
    - [all_contains_partial,
       "__all__.__contains__",
       ["partial"],
       true,
       "functools.__all__.__contains__('partial') == True — 'partial' is listed in functools.__all__; it is the C-implemented partial application class from _functoolsmodule.c; list.__contains__('partial') returns True; new to extra135"]
    - [all_contains_wraps,
       "__all__.__contains__",
       ["wraps"],
       true,
       "functools.__all__.__contains__('wraps') == True — 'wraps' is listed in functools.__all__; it is the convenience decorator for preserving wrapper function metadata (calls update_wrapper); list.__contains__('wraps') returns True; new to extra135"]
    - [all_contains_total_ordering,
       "__all__.__contains__",
       ["total_ordering"],
       true,
       "functools.__all__.__contains__('total_ordering') == True — 'total_ordering' is listed in functools.__all__; it is a class decorator that fills in comparison methods from a minimal set; list.__contains__('total_ordering') returns True; new to extra135"]
    - [all_contains_cached_property,
       "__all__.__contains__",
       ["cached_property"],
       true,
       "functools.__all__.__contains__('cached_property') == True — 'cached_property' is listed in functools.__all__; it is a descriptor that computes the property once and caches the result in the instance dict; list.__contains__('cached_property') returns True; new to extra135"]
    - [all_contains_singledispatch,
       "__all__.__contains__",
       ["singledispatch"],
       true,
       "functools.__all__.__contains__('singledispatch') == True — 'singledispatch' is listed in functools.__all__; it is the single-dispatch generic function decorator; list.__contains__('singledispatch') returns True; new to extra135"]

# ---------------------------------------------------------------------------
# Table 3: functools.__all__ membership for additional names
#
# Wave 260 theme: functools.__all__ contains additional utility names.
#
# 'partialmethod' in functools.__all__ == True
# 'update_wrapper' in functools.__all__ == True
# 'cache' in functools.__all__ == True
# 'cmp_to_key' in functools.__all__ == True
# 'singledispatchmethod' in functools.__all__ == True
# '__version__' in functools.__all__ == False  (not in __all__)
#
# New to extra135.
# ---------------------------------------------------------------------------

table functools_extra135.all_membership_extra:
  description: "functools.__all__.__contains__ for partialmethod, update_wrapper, cache, cmp_to_key, singledispatchmethod; additional exported names; wave 260; new to extra135"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsall135

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_partialmethod,
       "__all__.__contains__",
       ["partialmethod"],
       true,
       "functools.__all__.__contains__('partialmethod') == True — 'partialmethod' is listed in functools.__all__; it is a descriptor version of partial for use inside class bodies; list.__contains__('partialmethod') returns True; new to extra135"]
    - [all_contains_update_wrapper,
       "__all__.__contains__",
       ["update_wrapper"],
       true,
       "functools.__all__.__contains__('update_wrapper') == True — 'update_wrapper' is listed in functools.__all__; it is the function that copies metadata from a wrapped function onto a wrapper; list.__contains__('update_wrapper') returns True; new to extra135"]
    - [all_contains_cache,
       "__all__.__contains__",
       ["cache"],
       true,
       "functools.__all__.__contains__('cache') == True — 'cache' is listed in functools.__all__; it is the unbounded memoizing decorator (equivalent to lru_cache with maxsize=None) added in Python 3.9; list.__contains__('cache') returns True; new to extra135"]
    - [all_contains_cmp_to_key,
       "__all__.__contains__",
       ["cmp_to_key"],
       true,
       "functools.__all__.__contains__('cmp_to_key') == True — 'cmp_to_key' is listed in functools.__all__; it converts a traditional comparison function (returning negative/zero/positive) into a key function for use with sorted(); list.__contains__('cmp_to_key') returns True; new to extra135"]
    - [all_contains_singledispatchmethod,
       "__all__.__contains__",
       ["singledispatchmethod"],
       true,
       "functools.__all__.__contains__('singledispatchmethod') == True — 'singledispatchmethod' is listed in functools.__all__; it is the class-method variant of singledispatch (added in Python 3.8); list.__contains__('singledispatchmethod') returns True; new to extra135"]

