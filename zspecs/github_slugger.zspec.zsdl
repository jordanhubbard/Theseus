spec: github_slugger
version: ">=2.0.0"
backend: node(github-slugger)

docs: https://github.com/Flet/github-slugger#readme

provenance:
  derived_from:
    - "github-slugger README — https://github.com/Flet/github-slugger#readme"
    - "Test vectors verified with github-slugger via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "github-slugger source"
  notes:
    - "Generates GitHub-style heading anchors from heading text. Maintains state across calls to deduplicate slugs (Hello → 'hello', second Hello → 'hello-1')."
    - "Install: npm install github-slugger"
    - "v2 ESM with CJS shim; constructor exposed under .default."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure within an instance; per-instance state for dedup counters."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh slugger."
  codes: {}

invariant github_slugger.basic_slug:
  description: "Hello World → hello-world"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {method: slug, args: ["Hello World"]}
  expected: "hello-world"

invariant github_slugger.removes_special_chars:
  description: "'Foo & Bar' → 'foo--bar' (special chars replaced)"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {method: slug, args: ["Foo & Bar"]}
  expected: "foo--bar"



invariant github_slugger.empty_input_yields_empty_slug:
  description: "Empty input yields empty slug"
  category: edge
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {method: slug, args: [""]}
  expected: ""

invariant github_slugger.unicode_passthrough:
  description: "Unicode letters are kept (lower-cased)"
  category: unicode
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {method: slug, args: ["Café"]}
  expected: "café"

invariant github_slugger.numbers_kept:
  description: "Numbers are preserved in slug"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {method: slug, args: ["Section 5"]}
  expected: "section-5"


# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:37:55Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
