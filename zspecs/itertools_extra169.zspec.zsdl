spec: itertools_extra169
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain.__class__.__name__ 'type'; itertools.repeat.__class__.__name__ 'type'; itertools.count.__class__.__name__ 'type'; itertools.cycle.__class__.__name__ 'type'; itertools.chain.from_iterable.__qualname__ 'chain.from_iterable'; itertools.chain.from_iterable.__qualname__.__len__() 19 (Wave 298)."
    - "itertools.chain.__class__.__name__ == 'type' — itertools.chain is a C extension type in itertoolsmodule.c that chains iterables end-to-end; being a C extension type (a class), its __class__.__name__ is 'type' (the metaclass). Verified with Python 3.14.3."
    - "itertools.repeat.__class__.__name__ == 'type' — itertools.repeat is a C extension type in itertoolsmodule.c that repeats a value indefinitely (or a given number of times); its __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.count.__class__.__name__ == 'type' — itertools.count is a C extension type in itertoolsmodule.c that makes an infinite counter; its __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.cycle.__class__.__name__ == 'type' — itertools.cycle is a C extension type in itertoolsmodule.c that cycles through an iterable indefinitely; its __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — chain.from_iterable is a classmethod of itertools.chain; its __qualname__ reflects the class-dotted path 'chain.from_iterable'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__.__len__() == 19 — the string 'chain.from_iterable' has 19 characters: c-h-a-i-n-.-f-r-o-m-_-i-t-e-r-a-b-l-e. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain and itertools.repeat __class__.__name__ == 'type'
#
# Wave 298 theme: itertools C extension types — confirming that chain and repeat
# have __class__.__name__ 'type' (all itertools iterator factories are C types).
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.repeat.__class__.__name__ == 'type'
# itertools.chain.__name__ == 'chain'
# itertools.repeat.__name__ == 'repeat'
#
# itertools.chain(*iterables) makes an iterator that returns elements from the
# first iterable until it is exhausted, then proceeds to the next iterable.
# itertools.repeat(object[, times]) returns object over and over again (or a
# fixed number of times). Both are C extension types in itertoolsmodule.c; as
# class objects their __class__.__name__ is 'type'. New to extra169.
# ---------------------------------------------------------------------------

table itertools_extra169.chain_repeat_class_type:
  description: "itertools.chain and repeat: __class__.__name__ 'type'; chain.__name__ 'chain', repeat.__name__ 'repeat'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscrct169

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_name_type,
       "chain.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — itertools.chain is a C extension type in itertoolsmodule.c that chains multiple iterables end-to-end; as a class object its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra169"]
    - [repeat_class_name_type,
       "repeat.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — itertools.repeat is a C extension type in itertoolsmodule.c that returns an object repeatedly; as a class object its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra169"]
    - [chain_name_chain,
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — itertools.chain is a C extension type whose type __name__ is 'chain'; str.__eq__('chain') returns True; new to extra169"]
    - [repeat_name_repeat,
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — itertools.repeat is a C extension type whose type __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra169"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count and itertools.cycle __class__.__name__ == 'type'
#
# Wave 298 theme: itertools C extension types — confirming that count and cycle
# have __class__.__name__ 'type'.
#
# itertools.count.__class__.__name__ == 'type'
# itertools.cycle.__class__.__name__ == 'type'
# itertools.count.__name__ == 'count'
# itertools.cycle.__name__ == 'cycle'
#
# itertools.count(start=0, step=1) makes an iterator returning evenly spaced
# values starting with start, counting forever. itertools.cycle(iterable) makes
# an iterator returning elements from the iterable and saving a copy; when the
# iterable is exhausted it repeats the saved copy indefinitely. Both are C
# extension types; their __class__.__name__ is 'type'. New to extra169.
# ---------------------------------------------------------------------------

table itertools_extra169.count_cycle_class_type:
  description: "itertools.count and cycle: __class__.__name__ 'type'; count.__name__ 'count', cycle.__name__ 'cycle'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsccct169

  columns: [id, function, args, expected, description]
  rows:
    - [count_class_name_type,
       "count.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — itertools.count is a C extension type in itertoolsmodule.c that makes an infinite counter (returning evenly spaced values from start with step); as a class object its metaclass is 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra169"]
    - [cycle_class_name_type,
       "cycle.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — itertools.cycle is a C extension type in itertoolsmodule.c that cycles through an iterable indefinitely by saving a copy; as a class object its metaclass is 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra169"]
    - [count_name_count,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — itertools.count is a C extension type whose type __name__ is 'count'; str.__eq__('count') returns True; new to extra169"]
    - [cycle_name_cycle,
       "cycle.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — itertools.cycle is a C extension type whose type __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra169"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain.from_iterable classmethod qualname identity
#
# Wave 298 theme: itertools.chain.from_iterable classmethod — __qualname__,
# __class__.__name__, and length of __qualname__.
#
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
# itertools.chain.from_iterable.__qualname__.__len__() == 19
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__ != 'from_iterable'
#
# itertools.chain.from_iterable is an alternative constructor for chain that
# accepts a single iterable of iterables rather than multiple positional
# arguments. It is exposed as a class method on the chain C extension type.
# Its __qualname__ is 'chain.from_iterable', reflecting the class-dotted path.
# 'chain.from_iterable' is 19 characters long. New to extra169.
# ---------------------------------------------------------------------------

table itertools_extra169.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable: __qualname__ 'chain.from_iterable', __len__() 19, __class__.__name__ 'builtin_function_or_method'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscfiq169

  columns: [id, function, args, expected, description]
  rows:
    - ["cfi_qualname_chain_from_iterable",
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable is a classmethod alternative constructor for chain; its __qualname__ is 'chain.from_iterable', reflecting the class-dotted path; str.__eq__('chain.from_iterable') returns True; new to extra169"]
    - ["cfi_qualname_len_19",
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — the string 'chain.from_iterable' has exactly 19 characters: c-h-a-i-n-.-f-r-o-m-_-i-t-e-r-a-b-l-e; str.__len__() returns 19; new to extra169"]
    - ["cfi_class_builtin",
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is a C builtin method (classmethod on the chain C extension type); its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra169"]
    - ["cfi_qualname_ne_from_iterable",
       "chain.from_iterable.__qualname__.__eq__",
       ["from_iterable"],
       false,
       "itertools.chain.from_iterable.__qualname__.__eq__('from_iterable') == False — the __qualname__ is 'chain.from_iterable' (class-dotted), not just 'from_iterable' (the unqualified name); qualnames for methods include the class name prefix; str.__eq__('from_iterable') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 4: cross-checks — chain, repeat, count, cycle all __class__.__name__
# 'type'; none is 'builtin_function_or_method'
#
# Wave 298 theme: cross-checks confirming all four C extension iterator types
# have __class__.__name__ 'type' (not 'builtin_function_or_method' or 'function').
#
# itertools.chain.__class__.__name__ != 'builtin_function_or_method'
# itertools.repeat.__class__.__name__ != 'function'
# itertools.count.__class__.__name__ != 'builtin_function_or_method'
# itertools.cycle.__class__.__name__ != 'function'
#
# chain, repeat, count, and cycle are C extension types (class objects). This
# distinguishes them from chain.from_iterable which is a builtin_function_or_method.
# None of them is a Python function. New to extra169.
# ---------------------------------------------------------------------------

table itertools_extra169.type_metaclass_negative_checks:
  description: "itertools: chain, repeat, count, cycle __class__.__name__ not 'builtin_function_or_method' or 'function'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolstmnc169

  columns: [id, function, args, expected, description]
  rows:
    - [chain_not_builtin,
       "chain.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "itertools.chain.__class__.__name__.__eq__('builtin_function_or_method') == False — itertools.chain is a C extension type (class), NOT a C builtin function; its __class__.__name__ is 'type', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; new to extra169"]
    - [repeat_not_function,
       "repeat.__class__.__name__.__eq__",
       ["function"],
       false,
       "itertools.repeat.__class__.__name__.__eq__('function') == False — itertools.repeat is a C extension type (class), NOT a Python function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; new to extra169"]
    - [count_not_builtin,
       "count.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "itertools.count.__class__.__name__.__eq__('builtin_function_or_method') == False — itertools.count is a C extension type (class), NOT a C builtin function; its __class__.__name__ is 'type', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; new to extra169"]
    - [cycle_not_function,
       "cycle.__class__.__name__.__eq__",
       ["function"],
       false,
       "itertools.cycle.__class__.__name__.__eq__('function') == False — itertools.cycle is a C extension type (class), NOT a Python function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 5: repeat and cycle module checks + cross-checks
#
# Wave 298 theme: confirming repeat and cycle have __module__ 'itertools'
# and cross-checks on distinct names.
#
# itertools.repeat.__module__ == 'itertools'
# itertools.cycle.__module__ == 'itertools'
# itertools.repeat.__name__ != 'cycle'
# itertools.chain.__class__.__name__ == itertools.cycle.__class__.__name__
#   (both 'type')
#
# repeat and cycle are C extension types declared in itertoolsmodule.c with
# __module__ 'itertools'. Their names are distinct. Like chain and count,
# their __class__.__name__ is 'type'. New to extra169.
# ---------------------------------------------------------------------------

table itertools_extra169.repeat_cycle_module_cross_checks:
  description: "itertools: repeat and cycle __module__ 'itertools'; repeat.__name__ != 'cycle'; chain and cycle share __class__.__name__ 'type'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsrcmcc169

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_module_itertools,
       "repeat.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — itertools.repeat is declared in itertoolsmodule.c with __module__ 'itertools'; str.__eq__('itertools') returns True; new to extra169"]
    - [cycle_module_itertools,
       "cycle.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — itertools.cycle is declared in itertoolsmodule.c with __module__ 'itertools'; str.__eq__('itertools') returns True; new to extra169"]
    - [repeat_name_ne_cycle,
       "repeat.__name__.__eq__",
       ["cycle"],
       false,
       "itertools.repeat.__name__.__eq__('cycle') == False — repeat.__name__ is 'repeat', not 'cycle'; repeat returns an object a fixed (or infinite) number of times while cycle loops through an iterable indefinitely; they are distinct C extension types; str.__eq__('cycle') returns False; new to extra169"]
    - [chain_class_eq_cycle_class,
       "chain.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — both chain and cycle have __class__.__name__ 'type'; all four new types (chain, repeat, count, cycle) share this; confirmed via chain cross-check; str.__eq__('type') returns True; new to extra169"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra169
# ---------------------------------------------------------------------------

invariant itertools_extra169.chain_class_name_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type; its metaclass is 'type'; wave 298; new to extra169"
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra169.repeat_class_name_type:
  description: "itertools.repeat.__class__.__name__ == 'type' — repeat is a C extension type; its metaclass is 'type'; wave 298; new to extra169"
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra169.count_class_name_type:
  description: "itertools.count.__class__.__name__ == 'type' — count is a C extension type; its metaclass is 'type'; wave 298; new to extra169"
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra169.cycle_class_name_type:
  description: "itertools.cycle.__class__.__name__ == 'type' — cycle is a C extension type; its metaclass is 'type'; wave 298; new to extra169"
  kind: python_call_eq
  function: cycle.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra169.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — classmethod alternative constructor; qualname includes class prefix; wave 298; new to extra169"
  kind: python_call_eq
  function: "chain.from_iterable.__qualname__.__eq__"
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra169.chain_from_iterable_qualname_len_19:
  description: "itertools.chain.from_iterable.__qualname__.__len__() == 19 — 'chain.from_iterable' is 19 characters long; wave 298; new to extra169"
  kind: python_call_eq
  function: "chain.from_iterable.__qualname__.__len__"
  args: []
  expected: 19

invariant itertools_extra169.repeat_module_itertools:
  description: "itertools.repeat.__module__ == 'itertools' — repeat is declared in itertoolsmodule.c; wave 298; new to extra169"
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra169.cycle_module_itertools:
  description: "itertools.cycle.__module__ == 'itertools' — cycle is declared in itertoolsmodule.c; wave 298; new to extra169"
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true
