spec: concurrent_futures_extra253
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14); __module__ == 'concurrent.futures._base' (len=24); __doc__.__class__.__name__ == 'str'."
    - "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' (len=12); __module__ == 'builtins' (len=8) — TimeoutError is a re-export of the builtin OSError subclass, hence module is 'builtins'."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14); __module__ == 'concurrent.futures._base' (len=24); __doc__.__class__.__name__ == 'str'."
    - "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17); __module__ == 'concurrent.futures._base' (len=24); __doc__.__class__.__name__ == 'str'."
    - "CancelledError.__qualname__ length (14) equals BrokenExecutor.__qualname__ length (14) — a coincidental length match between the cancellation and broken-executor exceptions."
    - "TimeoutError.__module__ == 'builtins' (len=8) differs from the other three exceptions whose __module__ == 'concurrent.futures._base' (len=24) — TimeoutError is the builtin, not a concurrent.futures-defined class."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception __qualname__ identity
#
# CancelledError.__qualname__ == 'CancelledError' (len=14)
# TimeoutError.__qualname__ == 'TimeoutError' (len=12)
# BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14)
# InvalidStateError.__qualname__ == 'InvalidStateError' (len=17)
# ---------------------------------------------------------------------------

table concurrent_futures_extra253.exception_qualname_identity:
  description: "concurrent.futures exception __qualname__ identity — CancelledError(len=14) and BrokenExecutor(len=14) share qualname length; TimeoutError(len=12); InvalidStateError(len=17); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: cf253qn

  columns: [id, function, args, expected, description]
  rows:
    - [ce_qualname_eq,  CancelledError.__qualname__.__eq__,      ["CancelledError"],       true, "concurrent.futures.CancelledError.__qualname__ == 'CancelledError'; verified with Python 3.14.4"]
    - [ce_qualname_len, CancelledError.__qualname__.__len__,     [],                        14,   "concurrent.futures.CancelledError.__qualname__.__len__() == 14; verified with Python 3.14.4"]
    - [ce_mod_eq,       CancelledError.__module__.__eq__,        ["concurrent.futures._base"], true, "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.4"]
    - [ce_mod_len,      CancelledError.__module__.__len__,       [],                        24,   "concurrent.futures.CancelledError.__module__.__len__() == 24; verified with Python 3.14.4"]
    - [te_qualname_eq,  TimeoutError.__qualname__.__eq__,        ["TimeoutError"],          true, "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError'; verified with Python 3.14.4"]
    - [te_qualname_len, TimeoutError.__qualname__.__len__,       [],                        12,   "concurrent.futures.TimeoutError.__qualname__.__len__() == 12; verified with Python 3.14.4"]
    - [te_mod_eq,       TimeoutError.__module__.__eq__,          ["builtins"],              true, "concurrent.futures.TimeoutError.__module__ == 'builtins' — TimeoutError is the builtin OSError subclass, not defined in concurrent.futures._base; verified with Python 3.14.4"]
    - [te_mod_len,      TimeoutError.__module__.__len__,         [],                        8,    "concurrent.futures.TimeoutError.__module__.__len__() == 8 — 'builtins' is length 8, contrasting with the other exceptions' module length of 24; verified with Python 3.14.4"]
    - [be_qualname_eq,  BrokenExecutor.__qualname__.__eq__,      ["BrokenExecutor"],        true, "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'; verified with Python 3.14.4"]
    - [be_qualname_len, BrokenExecutor.__qualname__.__len__,     [],                        14,   "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 — same length as CancelledError (14); verified with Python 3.14.4"]
    - [be_mod_eq,       BrokenExecutor.__module__.__eq__,        ["concurrent.futures._base"], true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.4"]
    - [be_mod_len,      BrokenExecutor.__module__.__len__,       [],                        24,   "concurrent.futures.BrokenExecutor.__module__.__len__() == 24; verified with Python 3.14.4"]
    - [ise_qualname_eq, InvalidStateError.__qualname__.__eq__,   ["InvalidStateError"],     true, "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'; verified with Python 3.14.4"]
    - [ise_qualname_len,InvalidStateError.__qualname__.__len__,  [],                        17,   "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17; verified with Python 3.14.4"]
    - [ise_mod_eq,      InvalidStateError.__module__.__eq__,     ["concurrent.futures._base"], true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.4"]
    - [ise_mod_len,     InvalidStateError.__module__.__len__,    [],                        24,   "concurrent.futures.InvalidStateError.__module__.__len__() == 24; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __doc__ class identity
#
# CancelledError.__doc__.__class__.__name__ == 'str'
# TimeoutError.__doc__.__class__.__name__ == 'str'
# BrokenExecutor.__doc__.__class__.__name__ == 'str'
# InvalidStateError.__doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table concurrent_futures_extra253.exception_doc_class_identity:
  description: "concurrent.futures exception __doc__ class identity — all four exceptions have __doc__ of type 'str' (not NoneType); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: cf253dc

  columns: [id, function, args, expected, description]
  rows:
    - [ce_doc_cls_eq,  CancelledError.__doc__.__class__.__name__.__eq__,     ["str"],   true, "concurrent.futures.CancelledError.__doc__.__class__.__name__ == 'str' — __doc__ is a non-None string; verified with Python 3.14.4"]
    - [te_doc_cls_eq,  TimeoutError.__doc__.__class__.__name__.__eq__,       ["str"],   true, "concurrent.futures.TimeoutError.__doc__.__class__.__name__ == 'str' — __doc__ is a non-None string; verified with Python 3.14.4"]
    - [be_doc_cls_eq,  BrokenExecutor.__doc__.__class__.__name__.__eq__,     ["str"],   true, "concurrent.futures.BrokenExecutor.__doc__.__class__.__name__ == 'str' — __doc__ is a non-None string; verified with Python 3.14.4"]
    - [ise_doc_cls_eq, InvalidStateError.__doc__.__class__.__name__.__eq__,  ["str"],   true, "concurrent.futures.InvalidStateError.__doc__.__class__.__name__ == 'str' — __doc__ is a non-None string; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra253
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra253.timeout_error_module_is_builtins:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — TimeoutError is a re-export of the builtin OSError subclass, not a new class defined in concurrent.futures._base; its __module__ is 'builtins'(len=8) rather than 'concurrent.futures._base'(len=24); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra253.cancelled_broken_qualname_length_match:
  description: "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 — a coincidental length match with CancelledError.__qualname__ (also len=14); both are defined in concurrent.futures._base(len=24); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__len__
  args: []
  expected: 14
