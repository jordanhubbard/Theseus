spec: inspect_extra216
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers more inspect exception-raising behavior and Parameter kind enum values (wave 382)."
    - "inspect.getfile(len) raises TypeError — len is a builtin with no associated file. Verified with Python 3.14.3."
    - "inspect.getsourcelines(len) raises TypeError — len is a C builtin with no Python source lines. Verified with Python 3.14.3."
    - "inspect.getsource('hello') raises TypeError — argument must be module/class/method/function/traceback/frame/code object; str is not. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs(42) raises AttributeError — 42 is an int instance, not a class; it has no __mro__. Verified with Python 3.14.3."
    - "inspect.Parameter('123bad', kind=POSITIONAL_OR_KEYWORD) raises ValueError — '123bad' is not a valid Python identifier. Verified with Python 3.14.3."
    - "inspect.Parameter kind enum values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getfile — exception on built-in function
#
# inspect.getfile(object) requires the object to be a module, class, method,
# function, traceback, frame, or code object. Passing a built-in function
# like len raises TypeError because builtins implemented in C have no
# associated Python source file.
# Verified: getfile(len) -> TypeError: module, class, method, function,
# traceback, frame, or code object was expected, got builtin_function_or_method.
# ---------------------------------------------------------------------------

table inspect_extra216.getfile_builtin:
  description: "getfile(builtin) raises TypeError — must be module/class/method/function/traceback/frame/code; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: inspectextra216

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_len_raises_TypeError,
       getfile,
       [len],
       TypeError,
       "inspect.getfile(len) raises TypeError — getfile() returns the name of the Python source file in which an object was defined; it requires a module, class, method, function, traceback, frame, or code object; len is a builtin_function_or_method implemented in C with no Python source file; Python raises TypeError: module, class, method, function, traceback, frame, or code object was expected, got builtin_function_or_method; new to extra216"]

# ---------------------------------------------------------------------------
# inspect.getsourcelines — exception on built-in function
#
# inspect.getsourcelines(object) returns a list of source lines for an object.
# Like getfile, it requires a module, class, method, function, traceback,
# frame, or code object. Built-in C functions raise TypeError immediately.
# Verified: getsourcelines(len) -> TypeError: module, class, method, function,
# traceback, frame, or code object was expected, got builtin_function_or_method.
# ---------------------------------------------------------------------------

table inspect_extra216.getsourcelines_builtin:
  description: "getsourcelines(builtin) raises TypeError — must be module/class/method/function/traceback/frame/code; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: inspectextra216

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcelines_len_raises_TypeError,
       getsourcelines,
       [len],
       TypeError,
       "inspect.getsourcelines(len) raises TypeError — getsourcelines() returns a list of source code lines and the starting line number; it requires a module, class, method, function, traceback, frame, or code object; len is a C builtin with no Python source; Python raises TypeError: module, class, method, function, traceback, frame, or code object was expected, got builtin_function_or_method; new to extra216"]

# ---------------------------------------------------------------------------
# inspect.getsource — exception on string argument
#
# inspect.getsource(object) requires the same category of object as getfile
# and getsourcelines. Passing a plain string raises TypeError immediately.
# Verified: getsource('hello') -> TypeError: module, class, method, function,
# traceback, frame, or code object was expected.
# ---------------------------------------------------------------------------

table inspect_extra216.getsource_string:
  description: "getsource(string) raises TypeError — must be module/class/method/function/traceback/frame/code; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: inspectextra216

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_str_raises_TypeError,
       getsource,
       ["hello"],
       TypeError,
       "inspect.getsource('hello') raises TypeError — getsource() retrieves Python source code for an object; it accepts only module, class, method, function, traceback, frame, or code objects; a plain string 'hello' is none of these; Python raises TypeError: module, class, method, function, traceback, frame, or code object was expected; new to extra216"]

# ---------------------------------------------------------------------------
# inspect.classify_class_attrs — exception on non-class argument
#
# inspect.classify_class_attrs(cls) returns a list of NamedTuples describing
# attributes of a class. It requires a class (an object with __mro__).
# Passing an instance like 42 raises AttributeError because int instances
# do not have __mro__ (only the int type itself does).
# Verified: classify_class_attrs(42) -> AttributeError: 'int' object has no
# attribute '__mro__'.
# ---------------------------------------------------------------------------

table inspect_extra216.classify_class_attrs_non_class:
  description: "classify_class_attrs(42) raises AttributeError — argument must be a class, not an instance; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: inspectextra216

  columns: [id, function, args, expected, description]
  rows:
    - [classify_class_attrs_int_raises_AttributeError,
       classify_class_attrs,
       [42],
       AttributeError,
       "inspect.classify_class_attrs(42) raises AttributeError — classify_class_attrs() introspects the attributes of a class by traversing its __mro__; 42 is an int instance and int instances do not have __mro__ (only the int type itself has __mro__); Python raises AttributeError: 'int' object has no attribute '__mro__'; new to extra216"]

# ---------------------------------------------------------------------------
# inspect.Parameter — exception on invalid (non-identifier) name
#
# inspect.Parameter(name, kind) requires name to be a valid Python identifier.
# Passing a string like '123bad' that starts with a digit raises ValueError.
# Verified: Parameter('123bad', kind=POSITIONAL_OR_KEYWORD) -> ValueError:
# '123bad' is not a valid parameter name.
# ---------------------------------------------------------------------------

table inspect_extra216.parameter_invalid_name:
  description: "Parameter('123bad', kind=POSITIONAL_OR_KEYWORD) raises ValueError — name must be a valid identifier; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: inspectextra216

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_nonidentifier_name_raises_ValueError,
       Parameter,
       ["123bad", 1],
       ValueError,
       "inspect.Parameter('123bad', kind=POSITIONAL_OR_KEYWORD) raises ValueError — the name argument to Parameter() must be a valid Python identifier because it represents a function parameter name; '123bad' starts with a digit and is not a valid identifier; Python raises ValueError: '123bad' is not a valid parameter name; kind=1 corresponds to POSITIONAL_OR_KEYWORD; new to extra216"]

# ---------------------------------------------------------------------------
# inspect.Parameter kind enum values
#
# The five Parameter.kind values are integers 0-4. Each corresponds to a
# specific parameter kind in a function signature.
#
# Verified with Python 3.14.3:
#   POSITIONAL_ONLY.value == 0
#   POSITIONAL_OR_KEYWORD.value == 1
#   VAR_POSITIONAL.value == 2
#   KEYWORD_ONLY.value == 3
#   VAR_KEYWORD.value == 4
# ---------------------------------------------------------------------------

table inspect_extra216.parameter_kind_values:
  description: "inspect.Parameter kind enum values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4; new to extra216"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra216kinds

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_value_eq_0,
       Parameter.POSITIONAL_ONLY.value.__eq__,
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY marks parameters that can only be passed positionally (not by keyword), as seen in many built-in functions; its integer value is 0; new to extra216"]
    - [positional_or_keyword_value_eq_1,
       Parameter.POSITIONAL_OR_KEYWORD.value.__eq__,
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD is the most common kind; it marks parameters that can be passed either positionally or by keyword; its integer value is 1; new to extra216"]
    - [var_positional_value_eq_2,
       Parameter.VAR_POSITIONAL.value.__eq__,
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL marks *args style parameters that collect any extra positional arguments into a tuple; its integer value is 2; new to extra216"]
    - [keyword_only_value_eq_3,
       Parameter.KEYWORD_ONLY.value.__eq__,
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY marks parameters that must be passed by keyword only (they appear after a * or *args in the function signature); its integer value is 3; new to extra216"]
    - [var_keyword_value_eq_4,
       Parameter.VAR_KEYWORD.value.__eq__,
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD marks **kwargs style parameters that collect any extra keyword arguments into a dict; its integer value is 4; new to extra216"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra216
# ---------------------------------------------------------------------------

invariant inspect_extra216.getfile_builtin_TypeError:
  description: "inspect.getfile(len) raises TypeError — len is a builtin with no associated Python file; new to extra216"
  kind: python_call_raises
  category: errors
  function: getfile
  args: [len]
  expected: TypeError

invariant inspect_extra216.getsourcelines_builtin_TypeError:
  description: "inspect.getsourcelines(len) raises TypeError — len is a C builtin with no Python source lines; new to extra216"
  kind: python_call_raises
  category: errors
  function: getsourcelines
  args: [len]
  expected: TypeError

invariant inspect_extra216.getsource_string_TypeError:
  description: "inspect.getsource('hello') raises TypeError — str is not a valid object type for getsource; new to extra216"
  kind: python_call_raises
  category: errors
  function: getsource
  args: ["hello"]
  expected: TypeError

invariant inspect_extra216.classify_class_attrs_int_AttributeError:
  description: "inspect.classify_class_attrs(42) raises AttributeError — 42 is an int instance, not a class; new to extra216"
  kind: python_call_raises
  category: errors
  function: classify_class_attrs
  args: [42]
  expected: AttributeError

invariant inspect_extra216.parameter_nonidentifier_ValueError:
  description: "inspect.Parameter('123bad', kind=1) raises ValueError — '123bad' is not a valid identifier; new to extra216"
  kind: python_call_raises
  category: errors
  function: Parameter
  args: ["123bad", 1]
  expected: ValueError

invariant inspect_extra216.positional_only_value:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0; new to extra216"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra216.positional_or_keyword_value:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1; new to extra216"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.value.__eq__
  args: [1]
  expected: true

invariant inspect_extra216.var_positional_value:
  description: "inspect.Parameter.VAR_POSITIONAL.value == 2; new to extra216"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.value.__eq__
  args: [2]
  expected: true

invariant inspect_extra216.keyword_only_value:
  description: "inspect.Parameter.KEYWORD_ONLY.value == 3; new to extra216"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.value.__eq__
  args: [3]
  expected: true

invariant inspect_extra216.var_keyword_value:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4; new to extra216"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

