spec: io_extra601
version: ">=3.9"
backend: python_module(io)
docs: "Behavioral spec for io class __doc__ type and FileIO method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers io class __doc__ attribute type and FileIO method qualname identity"
  created_at: "2026-04-12T00:00:00Z"

table io_extra601.io601dc:
  id_prefix: io601dc

  description: "io class __doc__ attributes are str instances"
  columns: [id, function, args, expected]
  rows:
    - [io601dc01, "io.IOBase.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [io601dc02, "io.RawIOBase.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [io601dc03, "io.BufferedIOBase.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [io601dc04, "io.TextIOBase.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [io601dc05, "io.FileIO.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [io601dc06, "io.BytesIO.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [io601dc07, "io.StringIO.__doc__.__class__.__name__.__eq__", ["str"], true]

table io_extra601.io601fn:
  id_prefix: io601fn

  description: "io.FileIO qualname and module identity"
  columns: [id, function, args, expected]
  rows:
    - [io601fn01, "io.FileIO.__qualname__.__eq__", ["FileIO"], true]
    - [io601fn02, "io.FileIO.__module__.__eq__", ["io"], true]

table io_extra601.io601qn:
  id_prefix: io601qn

  description: "io.FileIO method qualnames"
  columns: [id, function, args, expected]
  rows:
    - [io601qn01, "io.FileIO.read.__qualname__.__eq__", ["FileIO.read"], true]
    - [io601qn02, "io.FileIO.write.__qualname__.__eq__", ["FileIO.write"], true]
    - [io601qn03, "io.FileIO.readall.__qualname__.__eq__", ["FileIO.readall"], true]
    - [io601qn04, "io.FileIO.seek.__qualname__.__eq__", ["FileIO.seek"], true]
    - [io601qn05, "io.FileIO.tell.__qualname__.__eq__", ["FileIO.tell"], true]
