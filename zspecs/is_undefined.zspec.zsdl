spec: is_undefined
version: ">=1.0.12"
backend: node(is-undefined)

docs: https://www.npmjs.com/package/is-undefined

provenance:
  derived_from:
    - "is-undefined README — https://www.npmjs.com/package/is-undefined"
    - "Test vectors verified with is-undefined via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-undefined source"
  notes:
    - "is-undefined is an npm package. Install: npm install is-undefined"
    - "Returns true if the value is undefined."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_undefined.check:
  kind: node_module_call_eq
  function: ~
  category: validation
  id_prefix: isundef

  columns: [id, args, expected]
  rows:
    - [null_val,  [null],   false]
    - [zero,      [0],      false]
    - [empty_str, [""],     false]
