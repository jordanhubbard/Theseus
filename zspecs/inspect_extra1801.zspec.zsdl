spec: inspect_extra1801
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and container protocol dict-presence checks for inspect types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra1801.truth_protocol:
  description: "inspect types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1801

  columns: [id, function, args, expected]
  rows:
    - ["in1801001", "inspect.Parameter.__dict__.__contains__", ["__bool__"], false]
    - ["in1801002", "inspect.Parameter.__dict__.__contains__", ["__len__"], false]
    - ["in1801003", "inspect.Signature.__dict__.__contains__", ["__bool__"], false]
    - ["in1801004", "inspect.Signature.__dict__.__contains__", ["__len__"], false]
    - ["in1801005", "inspect.BoundArguments.__dict__.__contains__", ["__bool__"], false]
    - ["in1801006", "inspect.BoundArguments.__dict__.__contains__", ["__len__"], false]

table inspect_extra1801.container_protocol:
  description: "inspect types container protocol and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1801

  columns: [id, function, args, expected]
  rows:
    - ["in1801101", "inspect.Signature.__dict__.__contains__", ["__contains__"], false]
    - ["in1801102", "inspect.Signature.__dict__.__contains__", ["__getitem__"], false]
    - ["in1801103", "inspect.Signature.__dict__.__contains__", ["__iter__"], false]
    - ["in1801104", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"], false]
    - ["in1801105", "inspect.BoundArguments.__dict__.__contains__", ["__getitem__"], false]
    - ["in1801106", "inspect.Parameter.__dict__.__contains__", ["__hash__"], true]
    - ["in1801107", "inspect.Signature.__dict__.__contains__", ["__hash__"], false]
    - ["in1801108", "inspect.BoundArguments.__dict__.__contains__", ["__hash__"], false]

table inspect_extra1801.parameter_sentinel:
  description: "inspect.Parameter sentinel, kind constants, and property dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1801

  columns: [id, function, args, expected]
  rows:
    - ["in1801201", "inspect.Parameter.__dict__.__contains__", ["empty"], true]
    - ["in1801202", "inspect.Parameter.__dict__.__contains__", ["POSITIONAL_ONLY"], true]
    - ["in1801203", "inspect.Parameter.__dict__.__contains__", ["POSITIONAL_OR_KEYWORD"], true]
    - ["in1801204", "inspect.Parameter.__dict__.__contains__", ["VAR_POSITIONAL"], true]
    - ["in1801205", "inspect.Parameter.__dict__.__contains__", ["KEYWORD_ONLY"], true]
    - ["in1801206", "inspect.Parameter.__dict__.__contains__", ["VAR_KEYWORD"], true]
    - ["in1801207", "inspect.Parameter.__dict__.__contains__", ["name"], true]
    - ["in1801208", "inspect.Parameter.__dict__.__contains__", ["default"], true]
    - ["in1801209", "inspect.Parameter.__dict__.__contains__", ["annotation"], true]
    - ["in1801210", "inspect.Parameter.__dict__.__contains__", ["kind"], true]
