spec: pathlib_extra402
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path methods write_text, write_bytes, read_text, read_bytes, open, touch, mkdir, rmdir each report __name__ matching their Python-level name"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path write/read and filesystem method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra402.path_method_names:
  description: "pathlib.Path write/read and filesystem method __name__ identity — write_text, write_bytes, read_text, read_bytes, open, touch, mkdir, rmdir; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath402

  columns: [id, function, args, expected]
  rows:
    - [write_text_name,  pathlib.Path.write_text.__name__.__eq__,  ["write_text"],  true]
    - [write_bytes_name, pathlib.Path.write_bytes.__name__.__eq__, ["write_bytes"], true]
    - [read_text_name,   pathlib.Path.read_text.__name__.__eq__,   ["read_text"],   true]
    - [read_bytes_name,  pathlib.Path.read_bytes.__name__.__eq__,  ["read_bytes"],  true]
    - [open_name,        pathlib.Path.open.__name__.__eq__,        ["open"],        true]
    - [touch_name,       pathlib.Path.touch.__name__.__eq__,       ["touch"],       true]
    - [mkdir_name,       pathlib.Path.mkdir.__name__.__eq__,       ["mkdir"],       true]
    - [rmdir_name,       pathlib.Path.rmdir.__name__.__eq__,       ["rmdir"],       true]
