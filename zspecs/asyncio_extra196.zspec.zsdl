table asyncio_extra196.asyncio_Task_method_qualnames:
  description: "asyncio.Task method qualname checks in asynciotask196 namespace — Task.result.__qualname__=='Task.result' (len=11: 'Task'=4+'.'=1+'result'=6=11; result() returns the Task's result, raising CancelledError if cancelled or the stored exception if one was set); Task.done.__qualname__=='Task.done' (len=9: 'Task'=4+'.'=1+'done'=4=9; done() returns True when the Task is complete, cancelled, or has an exception); Task.get_name.__qualname__=='Task.get_name' (len=13: 'Task'=4+'.'=1+'get_name'=8=13; get_name() returns the Task's optional name string); get_name.__qualname__ (13) > cancel.__qualname__ (11) > done.__qualname__ (9) — length ordering of method qualnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: methods
  id_prefix: asynciotask196

  columns: [id, function, args, expected, description]
  rows:
    - [task_result_qn_eq,   asyncio.Task.result.__qualname__.__eq__,    ["Task.result"],   true, "asyncio.Task.result.__qualname__ == 'Task.result' (len=11; returns result or raises stored exception); verified Python 3.14.3"]
    - [task_result_qn_len,  asyncio.Task.result.__qualname__.__len__,   [],                11,   "asyncio.Task.result.__qualname__.__len__() == 11 ('Task.result'=11: 'Task'=4+'.'=1+'result'=6=11); verified Python 3.14.3"]
    - [task_done_qn_eq,     asyncio.Task.done.__qualname__.__eq__,      ["Task.done"],     true, "asyncio.Task.done.__qualname__ == 'Task.done' (len=9; returns True when Task is complete/cancelled/excepted); verified Python 3.14.3"]
    - [task_getname_qn_eq,  asyncio.Task.get_name.__qualname__.__eq__,  ["Task.get_name"], true, "asyncio.Task.get_name.__qualname__ == 'Task.get_name' (len=13; returns the optional Task name string); verified Python 3.14.3"]
    - [task_getname_qn_len, asyncio.Task.get_name.__qualname__.__len__, [],                13,   "asyncio.Task.get_name.__qualname__.__len__() == 13 ('Task.get_name'=13: 'Task'=4+'.'=1+'get_name'=8=13); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra196
# ---------------------------------------------------------------------------

invariant asyncio_extra196.asyncio_Task_name_eq:
  description: "asyncio.Task.__name__.__eq__('Task') returns True — Task.__name__=='Task' (len=4: T(1)a(2)s(3)k(4)); asyncio.Task is the primary high-level object for concurrent execution — it wraps a coroutine, schedules it on the running event loop, and provides a Future-compatible interface; Tasks are created by asyncio.create_task() or loop.create_task(); Task.__name__ (4) == Task.__class__.__name__ (4: 'type') — coincidentally the same length; Task.__name__ (4) < Task.__module__ (8) by 4; NEW in asynciotask196: first standalone Task.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra196.asyncio_Task_module_eq:
  description: "asyncio.Task.__module__.__eq__('_asyncio') returns True — Task.__module__=='_asyncio' (len=8: '_asyncio'=8: '_'=1+'asyncio'=7=8); Task is implemented in the C extension _asyncio for performance; the leading underscore marks it as a private C implementation detail; Task.__module__ (8) == asyncio.get_event_loop.__module__ (8) — both the Task class and get_event_loop are in the same C extension; Task.__module__ (8) < asyncio.run.__module__ (15: 'asyncio.runners') — C extension name is shorter than pure-Python module names; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra196.asyncio_Task_base_name_eq:
  description: "asyncio.Task.__bases__[0].__name__.__eq__('Future') returns True — Task.__bases__[0].__name__=='Future' (len=6: F(1)u(2)t(3)u(4)r(5)e(6)); Task directly inherits from asyncio.Future, gaining all Future semantics: result(), exception(), done(), cancel(), add_done_callback(), etc.; Task overrides these methods to integrate with coroutine scheduling; Task.__bases__[0].__name__ (6) > Task.__name__ (4) by 2 — the base class name is longer than the subclass name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra196.asyncio_Task_class_name_eq:
  description: "asyncio.Task.__class__.__name__.__eq__('type') returns True — Task.__class__.__name__=='type' (len=4); Task is a regular Python class, not a metaclass or descriptor; its metaclass is the built-in type (same as most Python classes); Task.__class__.__name__ (4: 'type') == Task.__name__ (4: 'Task') — coincidentally the same character count; Task.__class__.__name__ (4) < Task.__module__ (8) by 4 — metaclass name shorter than the C extension module name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra196.asyncio_Task_cancel_qualname_eq:
  description: "asyncio.Task.cancel.__qualname__.__eq__('Task.cancel') returns True — Task.cancel.__qualname__=='Task.cancel' (len=11: 'Task'=4+'.'=1+'cancel'=6=11); cancel() requests Task cancellation by injecting a CancelledError into the wrapped coroutine at the next await point; Task.cancel.__qualname__ (11) includes the class prefix, distinguishing it from a module-level function; Task.cancel.__qualname__ (11) == Task.result.__qualname__ (11) — both share the same qualname length; Task.cancel.__qualname__ (11) > Task.done.__qualname__ (9) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Task.cancel.__qualname__.__eq__
  args: ["Task.cancel"]
  expected: true

invariant asyncio_extra196.asyncio_Task_result_qualname_eq:
  description: "asyncio.Task.result.__qualname__.__eq__('Task.result') returns True — Task.result.__qualname__=='Task.result' (len=11: 'Task'=4+'.'=1+'result'=6=11); result() returns the Task's result; if the Task is not done it raises InvalidStateError; if the Task was cancelled it raises CancelledError; if the Task raised an exception it re-raises that exception; Task.result.__qualname__ (11) == Task.cancel.__qualname__ (11) — identical qualname lengths; Task.result.__qualname__ (11) > Task.done.__qualname__ (9) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Task.result.__qualname__.__eq__
  args: ["Task.result"]
  expected: true

invariant asyncio_extra196.asyncio_Task_done_qualname_eq:
  description: "asyncio.Task.done.__qualname__.__eq__('Task.done') returns True — Task.done.__qualname__=='Task.done' (len=9: 'Task'=4+'.'=1+'done'=4=9); done() returns True if the Task is finished — either completed normally, raised an exception, or was cancelled; Task.done.__qualname__ (9) is the shortest method qualname in this spec; Task.done.__qualname__ (9) < Task.cancel.__qualname__ (11) by 2; Task.done.__qualname__ (9) < Task.get_name.__qualname__ (13) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Task.done.__qualname__.__eq__
  args: ["Task.done"]
  expected: true

invariant asyncio_extra196.asyncio_Task_get_name_qualname_eq:
  description: "asyncio.Task.get_name.__qualname__.__eq__('Task.get_name') returns True — Task.get_name.__qualname__=='Task.get_name' (len=13: 'Task'=4+'.'=1+'get_name'=8=13); get_name() returns the Task's optional name string, which can be set with set_name() or at creation via the name= argument of create_task(); Task.get_name.__qualname__ (13) is the longest method qualname in this spec; Task.get_name.__qualname__ (13) > Task.cancel.__qualname__ (11) by 2; NEW in asynciotask196: completing 8-invariant coverage for asyncio.Task class identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Task.get_name.__qualname__.__eq__
  args: ["Task.get_name"]
  expected: true
