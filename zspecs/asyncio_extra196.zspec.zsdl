spec: asyncio_extra196
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio Task class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "asyncio.Task.__name__ == 'Task' (len=4: T(1)a(2)s(3)k(4)); the Task class wraps a coroutine and schedules its execution on the event loop."
    - "asyncio.Task.__module__ == '_asyncio' (len=8); Task is implemented in the C extension _asyncio, not pure Python."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' (len=6); Task inherits directly from asyncio.Future."
    - "asyncio.Task.__class__.__name__ == 'type' (len=4); Task is a regular Python class (its metaclass is type)."
    - "asyncio.Task.cancel.__qualname__ == 'Task.cancel' (len=11); qualname includes the class prefix 'Task.'."
    - "asyncio.Task.result.__qualname__ == 'Task.result' (len=11); qualname includes the class prefix 'Task.'."
    - "asyncio.Task.done.__qualname__ == 'Task.done' (len=9); qualname includes the class prefix 'Task.'."
    - "asyncio.Task.get_name.__qualname__ == 'Task.get_name' (len=13); qualname includes the class prefix 'Task.'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Task class identity — __name__, __module__, __bases__
#
# Task.__name__ == 'Task' (len=4)
# Task.__module__ == '_asyncio' (len=8)
# Task.__bases__[0].__name__ == 'Future' (len=6)
# ---------------------------------------------------------------------------

table asyncio_extra196.asyncio_Task_class_identity:
  description: "asyncio.Task class identity checks in asynciotask196 namespace — Task.__name__=='Task' (len=4: T(1)a(2)s(3)k(4); wraps a coroutine and schedules it on the running event loop); Task.__module__=='_asyncio' (len=8: '_asyncio'=8; implemented in the C extension for performance, not in pure-Python Lib/asyncio/tasks.py); Task.__bases__[0].__name__=='Future' (len=6: 'Future'=6; Task directly inherits from asyncio.Future, gaining result/exception/done/cancel semantics); Task.__module__ (8) == Task.__bases__[0].__name__ (6) ≠ — C module name vs base class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask196

  columns: [id, function, args, expected, description]
  rows:
    - [task_name_eq,    asyncio.Task.__name__.__eq__,                   ["Task"],     true, "asyncio.Task.__name__ == 'Task' (len=4; wraps a coroutine scheduled on the event loop); verified Python 3.14.3"]
    - [task_name_len,   asyncio.Task.__name__.__len__,                  [],           4,    "asyncio.Task.__name__.__len__() == 4 ('Task'=4: T(1)a(2)s(3)k(4)); verified Python 3.14.3"]
    - [task_module_eq,  asyncio.Task.__module__.__eq__,                 ["_asyncio"], true, "asyncio.Task.__module__ == '_asyncio' (len=8; C extension implementation, not pure-Python); verified Python 3.14.3"]
    - [task_module_len, asyncio.Task.__module__.__len__,                [],           8,    "asyncio.Task.__module__.__len__() == 8 ('_asyncio'=8: '_'=1+'asyncio'=7=8); verified Python 3.14.3"]
    - ["task_base_eq",  "asyncio.Task.__bases__[0].__name__.__eq__",    ["Future"],   true, "asyncio.Task.__bases__[0].__name__ == 'Future' (len=6; Task inherits directly from asyncio.Future); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
