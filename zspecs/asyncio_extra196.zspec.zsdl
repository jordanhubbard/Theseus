table asyncio_extra196.asyncio_Task_type_and_cancel:
  description: "asyncio.Task metaclass and cancel method identity in asynciotask196 namespace — Task.__class__.__name__=='type' (len=4; Task is a regular Python class; its metaclass is the built-in type); Task.__bases__[0].__name__.__len__()==6 (confirming 'Future'=6 as the direct base class); Task.cancel.__qualname__=='Task.cancel' (len=11: 'Task'=4+'.'=1+'cancel'=6=11; cancel() requests cancellation by injecting CancelledError into the coroutine); Task.cancel.__qualname__ (11) == Task.result.__qualname__ (11) — both method qualnames share the same length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask196

  columns: [id, function, args, expected, description]
  rows:
    - [task_class_eq,       asyncio.Task.__class__.__name__.__eq__,              ["type"],        true, "asyncio.Task.__class__.__name__ == 'type' (len=4; Task is a regular class, metaclass is type); verified Python 3.14.3"]
    - [task_class_len,      asyncio.Task.__class__.__name__.__len__,             [],              4,    "asyncio.Task.__class__.__name__.__len__() == 4 ('type'=4: t(1)y(2)p(3)e(4)); verified Python 3.14.3"]
    - ["task_base_len",     "asyncio.Task.__bases__[0].__name__.__len__",        [],              6,    "asyncio.Task.__bases__[0].__name__.__len__() == 6 ('Future'=6: F(1)u(2)t(3)u(4)r(5)e(6)); verified Python 3.14.3"]
    - [task_cancel_qn_eq,   asyncio.Task.cancel.__qualname__.__eq__,             ["Task.cancel"], true, "asyncio.Task.cancel.__qualname__ == 'Task.cancel' (len=11; qualname includes the class prefix); verified Python 3.14.3"]
    - [task_cancel_qn_len,  asyncio.Task.cancel.__qualname__.__len__,            [],              11,   "asyncio.Task.cancel.__qualname__.__len__() == 11 ('Task.cancel'=11: 'Task'=4+'.'=1+'cancel'=6=11); verified Python 3.14.3"]

