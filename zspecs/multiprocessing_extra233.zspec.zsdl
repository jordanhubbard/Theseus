spec: multiprocessing_extra233
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/ (internal implementation)"
  notes:
    - "This spec covers multiprocessing.TimeoutError and multiprocessing.BufferTooShort exception identity."
    - "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context' (not 'multiprocessing')."
    - "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context' (not 'multiprocessing')."
    - "TimeoutError.__bases__[0].__name__ == 'ProcessError' — TimeoutError is a subclass of ProcessError."
    - "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort is a subclass of ProcessError."
    - "Both exceptions have MRO length 5: [TimeoutError, ProcessError, Exception, BaseException, object]."
    - "TimeoutError.__name__.__len__() == 12; BufferTooShort.__name__.__len__() == 14."
    - "multiprocessing.TimeoutError.__class__.__name__ == 'type' (plain class, metaclass is type)."
    - "multiprocessing.BufferTooShort.__class__.__name__ == 'type' (plain class, metaclass is type)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TimeoutError identity
#
# multiprocessing.TimeoutError.__name__ == 'TimeoutError'
# multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'
# multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'
# multiprocessing.TimeoutError.__class__.__name__ == 'type'
# multiprocessing.TimeoutError.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra233.timeout_error_identity:
  description: "multiprocessing.TimeoutError exception identity checks — TimeoutError.__name__.__eq__('TimeoutError')==True (len=12); TimeoutError.__module__.__eq__('multiprocessing.context')==True (defined in Lib/multiprocessing/context.py); TimeoutError.__bases__[0].__name__.__eq__('ProcessError')==True (TimeoutError is a direct subclass of ProcessError, NOT OSError — confirmed with Python 3.14.3); TimeoutError.__class__.__name__.__eq__('type')==True (plain class, metaclass is type); TimeoutError.__mro__.__len__()==5 (MRO is [TimeoutError, ProcessError, Exception, BaseException, object]); TimeoutError.__name__.__len__()==12; TimeoutError.__module__.__len__()==23; verified with Python 3.14.3"
  kind: python_call_eq
  category: timeout_error_identity
  id_prefix: mpexc233

  columns: [id, function, args, expected, description]
  rows:
    - [te_name_eq,    TimeoutError.__name__.__eq__,                        ["TimeoutError"],             true, "multiprocessing.TimeoutError.__name__ == 'TimeoutError'; verified with Python 3.14.3"]
    - [te_name_len,   TimeoutError.__name__.__len__,                       [],                           12,   "multiprocessing.TimeoutError.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [te_module_eq,  TimeoutError.__module__.__eq__,                      ["multiprocessing.context"],  true, "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [te_module_len, TimeoutError.__module__.__len__,                     [],                           23,   "multiprocessing.TimeoutError.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [te_base0,      "TimeoutError.__bases__[0].__name__.__eq__",         ["ProcessError"],             true, "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [te_cls_nm,     TimeoutError.__class__.__name__.__eq__,              ["type"],                     true, "multiprocessing.TimeoutError.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [te_mro_len,    TimeoutError.__mro__.__len__,                        [],                           5,    "multiprocessing.TimeoutError.__mro__.__len__() == 5 ([TimeoutError, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BufferTooShort identity
#
# multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'
# multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context'
# multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# multiprocessing.BufferTooShort.__class__.__name__ == 'type'
# multiprocessing.BufferTooShort.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra233.buffer_too_short_identity:
  description: "multiprocessing.BufferTooShort exception identity checks — BufferTooShort.__name__.__eq__('BufferTooShort')==True (len=14, two more than TimeoutError len=12); BufferTooShort.__module__.__eq__('multiprocessing.context')==True (same module as TimeoutError, both defined in Lib/multiprocessing/context.py); BufferTooShort.__bases__[0].__name__.__eq__('ProcessError')==True (BufferTooShort is a direct subclass of ProcessError, same as TimeoutError); BufferTooShort.__class__.__name__.__eq__('type')==True (plain class, metaclass is type); BufferTooShort.__mro__.__len__()==5 (same MRO length as TimeoutError: [BufferTooShort, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: buffer_too_short_identity
  id_prefix: mpexc233b

  columns: [id, function, args, expected, description]
  rows:
    - [bts_name_eq,    BufferTooShort.__name__.__eq__,                     ["BufferTooShort"],           true, "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'; verified with Python 3.14.3"]
    - [bts_name_len,   BufferTooShort.__name__.__len__,                    [],                           14,   "multiprocessing.BufferTooShort.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [bts_module_eq,  BufferTooShort.__module__.__eq__,                   ["multiprocessing.context"],  true, "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [bts_module_len, BufferTooShort.__module__.__len__,                  [],                           23,   "multiprocessing.BufferTooShort.__module__.__len__() == 23 (same as TimeoutError module len); verified with Python 3.14.3"]
    - [bts_base0,      "BufferTooShort.__bases__[0].__name__.__eq__",      ["ProcessError"],             true, "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [bts_cls_nm,     BufferTooShort.__class__.__name__.__eq__,           ["type"],                     true, "multiprocessing.BufferTooShort.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [bts_mro_len,    BufferTooShort.__mro__.__len__,                     [],                           5,    "multiprocessing.BufferTooShort.__mro__.__len__() == 5 ([BufferTooShort, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra233
# ---------------------------------------------------------------------------

invariant multiprocessing_extra233.TimeoutError_base_is_ProcessError:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError') returns True — multiprocessing.TimeoutError inherits from multiprocessing.ProcessError (not from OSError); the MRO is [TimeoutError, ProcessError, Exception, BaseException, object] (length=5); this confirms TimeoutError.__bases__[0].__name__ is 'ProcessError', NOT 'OSError'; TimeoutError.__module__ is 'multiprocessing.context' (len=23); NEW in extra233: first standalone TimeoutError base class invariant in mpexc233 namespace; verified with Python 3.14.3"
  category: timeout_error_identity
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra233.BufferTooShort_base_is_ProcessError:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError') returns True — multiprocessing.BufferTooShort inherits from multiprocessing.ProcessError (same as TimeoutError); the MRO is [BufferTooShort, ProcessError, Exception, BaseException, object] (length=5); BufferTooShort.__module__ is 'multiprocessing.context' (len=23, same module as TimeoutError); NEW in extra233: first standalone BufferTooShort base class invariant in mpexc233 namespace; verified with Python 3.14.3"
  category: buffer_too_short_identity
  kind: python_call_eq
  function: "BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra233.TimeoutError_module_is_multiprocessing_context:
  description: "multiprocessing.TimeoutError.__module__.__eq__('multiprocessing.context') returns True — TimeoutError is defined in Lib/multiprocessing/context.py (the multiprocessing.context submodule), not in Lib/multiprocessing/__init__.py; __module__ is 'multiprocessing.context' (len=23); this contrasts with multiprocessing.Process.__module__ which is 'multiprocessing.process'; NEW in extra233: first standalone TimeoutError module invariant in mpexc233 namespace; verified with Python 3.14.3"
  category: timeout_error_identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra233.BufferTooShort_module_is_multiprocessing_context:
  description: "multiprocessing.BufferTooShort.__module__.__eq__('multiprocessing.context') returns True — BufferTooShort is defined in Lib/multiprocessing/context.py (same as TimeoutError); __module__ is 'multiprocessing.context' (len=23); both TimeoutError and BufferTooShort share the same __module__; NEW in extra233: first standalone BufferTooShort module invariant in mpexc233 namespace; verified with Python 3.14.3"
  category: buffer_too_short_identity
  kind: python_call_eq
  function: BufferTooShort.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra233.TimeoutError_mro_len_5:
  description: "multiprocessing.TimeoutError.__mro__.__len__() == 5 — TimeoutError's MRO is [TimeoutError, ProcessError, Exception, BaseException, object]; a 5-element chain: TimeoutError (the exception itself) -> ProcessError (direct base) -> Exception (standard exception base) -> BaseException (root of exception hierarchy) -> object (ultimate base); compare: multiprocessing.BufferTooShort.__mro__.__len__()==5 (identical structure); NEW in extra233: first standalone TimeoutError MRO length invariant in mpexc233 namespace; verified with Python 3.14.3"
  category: timeout_error_identity
  kind: python_call_eq
  function: TimeoutError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra233.BufferTooShort_mro_len_5:
  description: "multiprocessing.BufferTooShort.__mro__.__len__() == 5 — BufferTooShort's MRO is [BufferTooShort, ProcessError, Exception, BaseException, object]; same 5-element chain structure as TimeoutError; both TimeoutError and BufferTooShort are direct subclasses of ProcessError with the same MRO depth; NEW in extra233: first standalone BufferTooShort MRO length invariant in mpexc233 namespace; verified with Python 3.14.3"
  category: buffer_too_short_identity
  kind: python_call_eq
  function: BufferTooShort.__mro__.__len__
  args: []
  expected: 5
