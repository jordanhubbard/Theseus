# ---------------------------------------------------------------------------
# __del__ dict-presence — re types
# re.Pattern and re.Match are reference-counted C objects; the interpreter
# handles deallocation via tp_dealloc, not a Python-level __del__.
# ---------------------------------------------------------------------------

table re_extra1966.del_finalizer:
  description: "re type __dict__.__contains__('__del__') — all False (no Python-level finalizer)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1966

  columns: [id, function, args, expected]
  rows:
    - ["re1966017", "re.Pattern.__dict__.__contains__",   ["__del__"], false]
    - ["re1966018", "re.Match.__dict__.__contains__",     ["__del__"], false]
    - ["re1966019", "re.error.__dict__.__contains__",     ["__del__"], false]
    - ["re1966020", "re.RegexFlag.__dict__.__contains__", ["__del__"], false]

# ---------------------------------------------------------------------------
# Cross-protocol summary — re.Pattern: all five lifecycle protocol methods absent
# ---------------------------------------------------------------------------

table re_extra1966.pattern_no_protocol:
