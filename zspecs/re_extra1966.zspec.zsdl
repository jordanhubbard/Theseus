spec: re_extra1966
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "re.Pattern and re.Match are C-level types (implemented in _sre); neither defines CM protocol."
    - "re.error is an alias for re.PatternError since Python 3.13; re.error.__name__ == 'PatternError'."
    - "re.RegexFlag is an IntFlag enum subclass; it defines no context manager or finalizer methods."
    - "None of the re types define __aenter__ or __aexit__ — regex objects are sync-only."
    - "None of the re types define __del__ — no finalizer/resource cleanup protocol."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __enter__ dict-presence — re types
# re.Pattern, re.Match are C-level types; re.error (PatternError) is a Python
# exception class; re.RegexFlag is an IntFlag enum.  None define __enter__.
# ---------------------------------------------------------------------------

table re_extra1966.enter_protocol:
  description: "re type __dict__.__contains__('__enter__') — all False (no CM protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1966

  columns: [id, function, args, expected]
  rows:
    - ["re1966001", "re.Pattern.__dict__.__contains__",   ["__enter__"], false]
    - ["re1966002", "re.Match.__dict__.__contains__",     ["__enter__"], false]
    - ["re1966003", "re.error.__dict__.__contains__",     ["__enter__"], false]
    - ["re1966004", "re.RegexFlag.__dict__.__contains__", ["__enter__"], false]

