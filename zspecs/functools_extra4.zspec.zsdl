spec: functools_extra4
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Extends functools.zspec.zsdl, functools_extra.zspec.zsdl, functools_extra2.zspec.zsdl, functools_extra3.zspec.zsdl."
    - "Previous specs cover: function names (reduce, partial, wraps, lru_cache, cache, cached_property, total_ordering, singledispatch, cmp_to_key, update_wrapper), partial class name, lru_cache/cache behavior, reduce basic use, WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES tuple class names."
    - "functools.partial(int, base=16).__func__ == int — partial wraps the underlying callable."
    - "functools.partial(int, base=16).keywords == {'base': 16} — keywords dict stores keyword args."
    - "functools.partial(int, base=16).args == () — no positional args in this partial."
    - "functools.reduce.__module__ == 'functools' — reduce is exposed through functools."
    - "functools.lru_cache.__name__ == 'lru_cache'."
    - "functools.cache.__name__ == 'cache'."
    - "functools.cached_property.__name__ == 'cached_property'."
    - "functools.total_ordering.__name__ == 'total_ordering'."
    - "functools.singledispatch.__name__ == 'singledispatch'."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial.func — holds the wrapped callable
#
# functools.partial(int).func == int. The .func attribute on a partial object
# is the underlying callable that was wrapped.
# ---------------------------------------------------------------------------

invariant functools_extra4.partial.func_is_int:
  description: "functools.partial(int).func.__name__ == 'int' — partial wraps the int callable"
  category: partial
  kind: python_call_eq
  function: partial
  args: [int]
  method: func
  method_chain: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# partial.keywords — empty dict when no keyword args frozen
#
# functools.partial(int).keywords == {} — when no keyword arguments are given,
# the .keywords attribute is an empty dict.
# ---------------------------------------------------------------------------

invariant functools_extra4.partial.keywords_class_name:
  description: "functools.partial(int).keywords.__class__.__name__ == 'dict'"
  category: partial
  kind: python_call_eq
  function: partial
  args: [int]
  method: keywords
  method_chain: __class__
  expected: "dict"

invariant functools_extra4.partial.keywords_empty:
  description: "functools.partial(int).keywords == {} — no keywords frozen"
  category: partial
  kind: python_call_eq
  function: partial
  args: [int]
  method: keywords
  method_chain: __len__
  expected: 0

# ---------------------------------------------------------------------------
# partial.args — empty tuple when no positional args frozen
#
# functools.partial(int).args == () — no positional arguments are frozen in
# this partial, so .args is an empty tuple.
# ---------------------------------------------------------------------------

invariant functools_extra4.partial.args_is_empty_tuple:
  description: "functools.partial(int).args == () — no positional args frozen"
  category: partial
  kind: python_call_eq
  function: partial
  args: [int]
  method: args
  method_chain: __len__
  expected: 0

invariant functools_extra4.partial.args_class_name:
  description: "functools.partial(int).args.__class__.__name__ == 'tuple'"
  category: partial
  kind: python_call_eq
  function: partial
  args: [int]
  method: args
  method_chain: __class__
  expected: "tuple"

# ---------------------------------------------------------------------------
# reduce.__module__ — 'functools'
#
# functools.reduce is re-exported from the C extension _functools but its
# __module__ is reported as 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra4.reduce.module:
  description: "functools.reduce.__module__ == 'functools'"
  category: reduce
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# lru_cache — __name__
#
# functools.lru_cache is a Python decorator factory. Its __name__ == 'lru_cache'.
# functools_extra3 verified singledispatch/cached_property/total_ordering/cmp_to_key;
# this spec adds lru_cache and cache as standalone __name__ invariants.
# ---------------------------------------------------------------------------

invariant functools_extra4.lru_cache.name:
  description: "functools.lru_cache.__name__ == 'lru_cache'"
  category: lru_cache
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

# ---------------------------------------------------------------------------
# cache — __name__
#
# functools.cache (Python 3.9+) is an unbounded memoizing decorator. Its
# __name__ == 'cache'.
# ---------------------------------------------------------------------------

invariant functools_extra4.cache.name:
  description: "functools.cache.__name__ == 'cache' (Python 3.9+)"
  category: cache
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

# ---------------------------------------------------------------------------
# cached_property — __name__
#
# functools.cached_property is a descriptor class. Its __name__ == 'cached_property'.
# functools_extra3 verified module; this spec adds a standalone __name__ invariant.
# ---------------------------------------------------------------------------

invariant functools_extra4.cached_property.name:
  description: "functools.cached_property.__name__ == 'cached_property'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

# ---------------------------------------------------------------------------
# total_ordering — __name__
#
# functools.total_ordering is a class decorator. Its __name__ == 'total_ordering'.
# ---------------------------------------------------------------------------

invariant functools_extra4.total_ordering.name:
  description: "functools.total_ordering.__name__ == 'total_ordering'"
  category: total_ordering
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch — __name__
#
# functools.singledispatch is a decorator. Its __name__ == 'singledispatch'.
# ---------------------------------------------------------------------------

invariant functools_extra4.singledispatch.name:
  description: "functools.singledispatch.__name__ == 'singledispatch'"
  category: singledispatch
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

# ---------------------------------------------------------------------------
# cmp_to_key — __name__
#
# functools.cmp_to_key converts comparison functions to key functions.
# Its __name__ == 'cmp_to_key'.
# ---------------------------------------------------------------------------

invariant functools_extra4.cmp_to_key.name:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key'"
  category: cmp_to_key
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true
