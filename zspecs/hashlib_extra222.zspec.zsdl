spec: hashlib_extra222
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new('invalid_algorithm_xyz') raises ValueError — unsupported hash type."
    - "hashlib.md5(b'hello').digest().__len__() == 16 — MD5 raw digest is 16 bytes (128-bit)."
    - "hashlib.sha1(b'hello').digest().__len__() == 20 — SHA-1 raw digest is 20 bytes (160-bit)."
    - "hashlib.sha256(b'hello').digest().__len__() == 32 — SHA-256 raw digest is 32 bytes (256-bit)."
    - "hashlib.sha512(b'hello').digest().__len__() == 64 — SHA-512 raw digest is 64 bytes (512-bit)."
    - "hashlib.md5(b'hello').copy().__class__.__name__ == 'HASH' — copy returns same HASH type."
    - "hashlib.md5().update.__name__ == 'update'; hexdigest.__name__ == 'hexdigest'; digest.__name__ == 'digest'."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new — raises ValueError for unknown algorithm name
#
# hashlib.new('invalid_algorithm_xyz') raises ValueError
# ---------------------------------------------------------------------------

invariant hashlib_extra222.new_invalid_algo_raises:
  description: "hashlib.new('invalid_algorithm_xyz') raises ValueError — unknown hash algorithm names are rejected immediately with ValueError; 'invalid_algorithm_xyz' is not registered in hashlib.algorithms_available; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: hashlib.new
  args: ["invalid_algorithm_xyz"]
  expected_exception: ValueError

# ---------------------------------------------------------------------------
# HASH object digest() length checks (raw bytes, not hex)
#
# hashlib.md5(b'hello').digest().__len__()    == 16
# hashlib.sha1(b'hello').digest().__len__()   == 20
# hashlib.sha256(b'hello').digest().__len__() == 32
# hashlib.sha512(b'hello').digest().__len__() == 64
# ---------------------------------------------------------------------------

table hashlib_extra222.digest_lengths:
  description: "hashlib HASH object digest() raw byte length checks in hashlib222 namespace — wave 222 theme: md5 digest is 16 bytes (128-bit); sha1 is 20 bytes (160-bit); sha256 is 32 bytes (256-bit); sha512 is 64 bytes (512-bit); raw digest bytes are exactly digest_size bytes (half the hex digest length); verified with Python 3.14.3"
  kind: python_call_eq
  category: digest_length
  id_prefix: hashlib222

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_len,    "hashlib.md5(b'hello').digest().__len__",    [], 16, "hashlib.md5(b'hello').digest().__len__() == 16 — MD5 raw digest is 16 bytes (128-bit)"]
    - [sha1_digest_len,   "hashlib.sha1(b'hello').digest().__len__",   [], 20, "hashlib.sha1(b'hello').digest().__len__() == 20 — SHA-1 raw digest is 20 bytes (160-bit)"]
    - [sha256_digest_len, "hashlib.sha256(b'hello').digest().__len__", [], 32, "hashlib.sha256(b'hello').digest().__len__() == 32 — SHA-256 raw digest is 32 bytes (256-bit)"]
    - [sha512_digest_len, "hashlib.sha512(b'hello').digest().__len__", [], 64, "hashlib.sha512(b'hello').digest().__len__() == 64 — SHA-512 raw digest is 64 bytes (512-bit)"]

# ---------------------------------------------------------------------------
# HASH object copy() class identity
#
# hashlib.md5(b'hello').copy().__class__.__name__ == 'HASH'
# ---------------------------------------------------------------------------

invariant hashlib_extra222.md5_copy_class_name:
  description: "hashlib.md5(b'hello').copy().__class__.__name__ == 'HASH' — copy() returns an independent HASH object of the same type; the copy is the same OpenSSL-backed HASH class from _hashlib; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5(b'hello').copy().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# HASH object method __name__ checks
#
# hashlib.md5().update.__name__    == 'update'
# hashlib.md5().hexdigest.__name__ == 'hexdigest'
# hashlib.md5().digest.__name__    == 'digest'
# ---------------------------------------------------------------------------

table hashlib_extra222.hash_method_names:
  description: "hashlib HASH object method __name__ attribute checks in hashlib222a namespace — wave 222 theme: update.__name__=='update'; hexdigest.__name__=='hexdigest'; digest.__name__=='digest'; these are the three primary HASH object methods; method names match the public API names; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib222a

  columns: [id, function, args, expected, description]
  rows:
    - [update_name,    "hashlib.md5().update.__name__.__eq__",    ["update"],    true, "hashlib.md5().update.__name__ == 'update' — the update method name matches the public API name"]
    - [hexdigest_name, "hashlib.md5().hexdigest.__name__.__eq__", ["hexdigest"], true, "hashlib.md5().hexdigest.__name__ == 'hexdigest' — the hexdigest method name matches the public API name"]
    - [digest_name,    "hashlib.md5().digest.__name__.__eq__",    ["digest"],    true, "hashlib.md5().digest.__name__ == 'digest' — the digest method name matches the public API name"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available — class identity
#
# hashlib.algorithms_available.__class__.__name__ == 'set'
# ---------------------------------------------------------------------------

invariant hashlib_extra222.algorithms_available_class:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a frozenset-like set of hash algorithm names available on the current platform; its type is 'set' (plain Python set); verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.algorithms_available.__class__.__name__.__eq__"
  args: ["set"]
  expected: true
