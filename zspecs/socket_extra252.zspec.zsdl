spec: socket_extra252
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
  notes:
    - "Wave 252 theme: socket module IPPROTO_* and SO_*/TCP_* protocol and option constants — integer values and type identity."
    - "socket.IPPROTO_ICMP == 1. Internet Control Message Protocol. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IGMP == 2. Internet Group Management Protocol. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IP == 0. Dummy protocol for TCP/IP. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP == 6. Transmission Control Protocol. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP == 17. User Datagram Protocol. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IPV6 == 41. IPv6 header (protocol number for IPv6-in-IPv4 tunneling). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_RAW == 255. Raw IP packets. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_TCP == 6 on macOS/Darwin. SOL_TCP is the socket option level for TCP (equals IPPROTO_TCP). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.TCP_NODELAY == 1 on macOS/Darwin. Disables Nagle's algorithm. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.TCP_KEEPALIVE == 16 on macOS/Darwin. Sets TCP keepalive idle time (macOS-specific; POSIX uses TCP_KEEPIDLE). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_KEEPALIVE == 8 on macOS/Darwin. Enables SO_KEEPALIVE socket option. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_BROADCAST == 32 on macOS/Darwin. Enables broadcast messages on the socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.IPPROTO_ICMP).__name__ == 'int'. IPPROTO_* constants are plain int on macOS/Darwin (not IntEnum). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.TCP_NODELAY).__name__ == 'int'. TCP_* constants are plain int on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.SO_KEEPALIVE).__name__ == 'int'. SO_* constants are plain int on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: IPPROTO_* values follow IANA assigned IP protocol numbers (RFC 5237). ICMP=1, IGMP=2, TCP=6, UDP=17, IPv6=41, RAW=255."
    - "Note: SOL_TCP==IPPROTO_TCP==6 because the TCP socket option level uses the protocol number."
    - "Note: TCP_KEEPALIVE (value 16) is macOS-specific. Linux uses TCP_KEEPIDLE for the same purpose."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.IPPROTO_ICMP.__eq__(1)
# socket.IPPROTO_IGMP.__eq__(2)
# socket.IPPROTO_IP.__eq__(0)
# socket.IPPROTO_TCP.__eq__(6)
# socket.IPPROTO_UDP.__eq__(17)
# socket.IPPROTO_IPV6.__eq__(41)
# socket.IPPROTO_RAW.__eq__(255)
#
# Wave 252 theme: socket IPPROTO_* protocol number constant values.
#
# The IPPROTO_* constants represent IANA assigned IP protocol numbers as defined
# in RFC 5237 and earlier RFCs. These are used as the 'proto' argument to
# socket.socket() for raw sockets and as protocol level identifiers for
# socket options (setsockopt/getsockopt). ICMP=1, IGMP=2, IP=0 (dummy/base),
# TCP=6, UDP=17, IPv6=41 (IPv6-in-IPv4), RAW=255 (raw IP packets).
# All are plain int on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra252.ipproto_constant_values:
  description: "socket IPPROTO_* protocol number constants — IPPROTO_ICMP.__eq__(1)==True / IPPROTO_IGMP.__eq__(2)==True / IPPROTO_IP.__eq__(0)==True / IPPROTO_TCP.__eq__(6)==True / IPPROTO_UDP.__eq__(17)==True / IPPROTO_IPV6.__eq__(41)==True / IPPROTO_RAW.__eq__(255)==True — IANA assigned IP protocol numbers (RFC 5237); used as proto arg to socket.socket() and as setsockopt level; plain int on macOS/Darwin; wave 252 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant_values
  id_prefix: sockproto252

  columns: [id, function, args, expected, description]
  rows:
    - [icmp_val,  IPPROTO_ICMP.__eq__,  [1],   true, "socket.IPPROTO_ICMP == 1; IANA protocol 1 (Internet Control Message Protocol, RFC 792)"]
    - [igmp_val,  IPPROTO_IGMP.__eq__,  [2],   true, "socket.IPPROTO_IGMP == 2; IANA protocol 2 (Internet Group Management Protocol, RFC 1112)"]
    - [ip_val,    IPPROTO_IP.__eq__,    [0],   true, "socket.IPPROTO_IP == 0; dummy protocol for TCP/IP socket options (IP level)"]
    - [tcp_val,   IPPROTO_TCP.__eq__,   [6],   true, "socket.IPPROTO_TCP == 6; IANA protocol 6 (Transmission Control Protocol, RFC 793)"]
    - [udp_val,   IPPROTO_UDP.__eq__,   [17],  true, "socket.IPPROTO_UDP == 17; IANA protocol 17 (User Datagram Protocol, RFC 768)"]
    - [ipv6_val,  IPPROTO_IPV6.__eq__,  [41],  true, "socket.IPPROTO_IPV6 == 41; IANA protocol 41 (IPv6 encapsulation / IPv6-in-IPv4 tunneling)"]
    - [raw_val,   IPPROTO_RAW.__eq__,   [255], true, "socket.IPPROTO_RAW == 255; raw IP packet protocol number (send raw datagrams)"]

# ---------------------------------------------------------------------------
# socket.SOL_TCP.__eq__(6)
# socket.TCP_NODELAY.__eq__(1)
# socket.TCP_KEEPALIVE.__eq__(16)
#
# Wave 252 theme: socket TCP socket option level and option constants.
#
# SOL_TCP (value 6) is the socket option level for TCP options, equal to
# IPPROTO_TCP. TCP_NODELAY (value 1) disables Nagle's algorithm for low-latency
# applications. TCP_KEEPALIVE (value 16) is macOS-specific and sets the idle
# time before keepalives are sent (Linux uses TCP_KEEPIDLE for the same purpose).
# All are plain int on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra252.tcp_option_constant_values:
  description: "socket TCP option level and option constants — SOL_TCP.__eq__(6)==True / TCP_NODELAY.__eq__(1)==True / TCP_KEEPALIVE.__eq__(16)==True — SOL_TCP==IPPROTO_TCP==6 (TCP socket option level); TCP_NODELAY==1 disables Nagle's algorithm; TCP_KEEPALIVE==16 is macOS-specific keepalive idle time (Linux uses TCP_KEEPIDLE); plain int on macOS/Darwin; wave 252 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant_values
  id_prefix: sockproto252

  columns: [id, function, args, expected, description]
  rows:
    - [sol_tcp_val,      SOL_TCP.__eq__,      [6],  true, "socket.SOL_TCP == 6; TCP socket option level, equal to IPPROTO_TCP (use as level in setsockopt for TCP options)"]
    - [tcp_nodelay_val,  TCP_NODELAY.__eq__,  [1],  true, "socket.TCP_NODELAY == 1; disables Nagle's algorithm when set to 1 (reduces latency for small packets)"]
    - [tcp_keepalive_val, TCP_KEEPALIVE.__eq__, [16], true, "socket.TCP_KEEPALIVE == 16; macOS-specific TCP keepalive idle time option (Linux uses TCP_KEEPIDLE)"]

# ---------------------------------------------------------------------------
# socket.SO_KEEPALIVE.__eq__(8)
# socket.SO_BROADCAST.__eq__(32)
#
# Wave 252 theme: socket SO_* socket option constants.
#
# SO_KEEPALIVE (value 8 on macOS/Darwin) enables TCP keepalive packets to detect
# dead connections. SO_BROADCAST (value 32 on macOS/Darwin) allows sending
# broadcast datagrams on the socket. Both are set with setsockopt using
# SOL_SOCKET as the option level. Values are platform-dependent (different on
# Linux). Both are plain int on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra252.so_option_constant_values:
  description: "socket SO_* socket option constants on macOS/Darwin — SO_KEEPALIVE.__eq__(8)==True / SO_BROADCAST.__eq__(32)==True — SO_KEEPALIVE==8 enables keepalive packets to detect dead connections; SO_BROADCAST==32 allows broadcast datagrams; set with setsockopt(SOL_SOCKET, ...); values are macOS/Darwin-specific (differ on Linux); plain int; wave 252 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant_values
  id_prefix: sockproto252

  columns: [id, function, args, expected, description]
  rows:
    - [so_keepalive_val,  SO_KEEPALIVE.__eq__,  [8],  true, "socket.SO_KEEPALIVE == 8 on macOS/Darwin; enables TCP keepalive packets (use with SOL_SOCKET level)"]
    - [so_broadcast_val,  SO_BROADCAST.__eq__,  [32], true, "socket.SO_BROADCAST == 32 on macOS/Darwin; allows sending broadcast datagrams (use with SOL_SOCKET level)"]

# ---------------------------------------------------------------------------
# type(socket.IPPROTO_ICMP).__name__.__eq__('int')
# type(socket.TCP_NODELAY).__name__.__eq__('int')
# type(socket.SO_KEEPALIVE).__name__.__eq__('int')
# type(socket.SO_BROADCAST).__name__.__eq__('int')
#
# Wave 252 theme: socket protocol and option constant type identity.
#
# On macOS/Darwin, IPPROTO_*, TCP_*, and SO_* constants are plain int objects
# (not IntEnum members). This contrasts with AddressFamily (AF_*) and SocketKind
# (SOCK_*) which are IntEnum members on Python 3.4+. The protocol and option
# constants were not converted to IntEnum. type(socket.IPPROTO_ICMP).__name__
# is 'int'; socket_extra96 covers AF_*/SOCK_* class names; no prior socket spec
# anchors IPPROTO_*/TCP_*/SO_* type identity under sockproto252.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra252.protocol_option_constant_types:
  description: "socket protocol and option constant type identity — type(IPPROTO_ICMP).__name__.__eq__('int')==True / type(TCP_NODELAY).__name__.__eq__('int')==True / type(SO_KEEPALIVE).__name__.__eq__('int')==True / type(SO_BROADCAST).__name__.__eq__('int')==True — IPPROTO_*/TCP_*/SO_* constants are plain int (not IntEnum) on macOS/Darwin; contrasts with AF_*/SOCK_* which are IntEnum; socket_extra96 covers AF_*/SOCK_* class names; first sockproto252 anchor for protocol/option constant type identity; wave 252 theme"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockproto252

  columns: [id, function, args, expected, description]
  rows:
    - [icmp_type,      IPPROTO_ICMP.__class__.__name__.__eq__,  ["int"], true, "type(socket.IPPROTO_ICMP).__name__ == 'int'; IPPROTO_* constants are plain int (not IntEnum) on macOS/Darwin"]
    - [tcp_nd_type,    TCP_NODELAY.__class__.__name__.__eq__,   ["int"], true, "type(socket.TCP_NODELAY).__name__ == 'int'; TCP_* constants are plain int (not IntEnum) on macOS/Darwin"]
    - [so_ka_type,     SO_KEEPALIVE.__class__.__name__.__eq__,  ["int"], true, "type(socket.SO_KEEPALIVE).__name__ == 'int'; SO_* constants are plain int (not IntEnum) on macOS/Darwin"]
    - [so_bc_type,     SO_BROADCAST.__class__.__name__.__eq__,  ["int"], true, "type(socket.SO_BROADCAST).__name__ == 'int'; SO_* constants are plain int (not IntEnum) on macOS/Darwin"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_ICMP.__eq__(1) — standalone
#
# socket.IPPROTO_ICMP is 1. ICMP (Internet Control Message Protocol) is IANA
# assigned protocol number 1, defined in RFC 792. ICMP is used by network
# devices to send error messages and operational information (e.g., ping uses
# ICMP echo request/reply). To create a raw ICMP socket, one uses
# socket.socket(AF_INET, SOCK_RAW, IPPROTO_ICMP). IPPROTO_ICMP is a plain int
# (not IntEnum) on macOS/Darwin. This is the first standalone anchor for
# IPPROTO_ICMP.__eq__(1) under sockproto252. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra252.IPPROTO_ICMP_is_1:
  description: "socket.IPPROTO_ICMP.__eq__(1) == True — ICMP is IANA protocol number 1 (RFC 792); used for ping/traceroute via socket.socket(AF_INET, SOCK_RAW, IPPROTO_ICMP); plain int (not IntEnum) on macOS/Darwin; first standalone for IPPROTO_ICMP value under sockproto252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_values
  kind: python_call_eq
  function: IPPROTO_ICMP.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_RAW.__eq__(255) — standalone
#
# socket.IPPROTO_RAW is 255. IPPROTO_RAW (protocol number 255) is used to
# send raw IP datagrams where the IP header is included in the packet data
# by the application. It is the maximum valid protocol number in a 1-byte
# protocol field (0xFF). Using IPPROTO_RAW with SOCK_RAW creates a raw socket
# that bypasses transport layer processing entirely. IPPROTO_RAW is a plain int
# on macOS/Darwin. This is the first standalone anchor for IPPROTO_RAW.__eq__(255)
# under sockproto252. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra252.IPPROTO_RAW_is_255:
  description: "socket.IPPROTO_RAW.__eq__(255) == True — IPPROTO_RAW is protocol number 255 (0xFF), the maximum 1-byte value; used with SOCK_RAW to send raw IP datagrams with application-provided IP headers; bypasses transport layer processing; plain int on macOS/Darwin; first standalone for IPPROTO_RAW value under sockproto252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_values
  kind: python_call_eq
  function: IPPROTO_RAW.__eq__
  args: [255]
  expected: true

# ---------------------------------------------------------------------------
# socket.SO_KEEPALIVE.__eq__(8) — standalone (macOS/Darwin)
#
# socket.SO_KEEPALIVE is 8 on macOS/Darwin. SO_KEEPALIVE is a socket-level
# option (used with SOL_SOCKET as the level in setsockopt) that enables the
# periodic transmission of keepalive messages on a connected socket. If the
# remote end does not respond, the connection is considered dead and is closed.
# The numeric value (8) is platform-specific — macOS/Darwin assigns it 8.
# SO_KEEPALIVE is a plain int on macOS/Darwin (not IntEnum). This is the first
# standalone anchor for SO_KEEPALIVE.__eq__(8) under sockproto252.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra252.SO_KEEPALIVE_is_8:
  description: "socket.SO_KEEPALIVE.__eq__(8) == True on macOS/Darwin — SO_KEEPALIVE enables periodic keepalive messages on a connected socket; used with SOL_SOCKET level in setsockopt; value is 8 on macOS/Darwin (platform-specific); detects dead connections by probing unresponsive peers; plain int (not IntEnum); first standalone for SO_KEEPALIVE value under sockproto252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_values
  kind: python_call_eq
  function: SO_KEEPALIVE.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_IPV6.__eq__(41) — standalone
#
# socket.IPPROTO_IPV6 is 41. IANA protocol number 41 ('IPv6' or '6in4') is
# used for IPv6 encapsulation in IPv4 packets (IPv6-in-IPv4 tunneling). It is
# also used as the socket option level when setting IPv6-specific socket options
# via setsockopt(IPPROTO_IPV6, IPV6_V6ONLY, ...). The value 41 is defined in
# RFC 2473 for Generic Packet Tunneling in IPv6 and the IANA protocol number
# registry. IPPROTO_IPV6 is a plain int on macOS/Darwin. This is the first
# standalone anchor for IPPROTO_IPV6.__eq__(41) under sockproto252.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra252.IPPROTO_IPV6_is_41:
  description: "socket.IPPROTO_IPV6.__eq__(41) == True — IANA protocol number 41 is IPv6 encapsulation (6in4/IPv6-in-IPv4 tunneling, RFC 2473); also used as socket option level for IPv6-specific options (e.g., setsockopt(IPPROTO_IPV6, IPV6_V6ONLY, ...)); plain int on macOS/Darwin; first standalone for IPPROTO_IPV6 value under sockproto252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_values
  kind: python_call_eq
  function: IPPROTO_IPV6.__eq__
  args: [41]
  expected: true
