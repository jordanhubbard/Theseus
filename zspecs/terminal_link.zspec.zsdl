spec: terminal_link
version: ">=4.0.0"
backend: node(terminal-link)

docs: https://github.com/sindresorhus/terminal-link#readme

provenance:
  derived_from:
    - "terminal-link README — https://github.com/sindresorhus/terminal-link#readme"
    - "Test vectors verified with terminal-link via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "terminal-link source"
  notes:
    - "Hyperlinks in the terminal — uses the OSC-8 escape sequence on supported terminals, falls back to plain text."
    - "Install: npm install terminal-link"
    - "v4 ESM only; default export is the function; .isSupported / .stderr properties expose support detection."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant terminal_link.factory_arity:
  description: "terminalLink takes (text, url) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 2

invariant terminal_link.has_isSupported:
  description: "Module exposes .isSupported boolean"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.isSupported.constructor.name"}
  expected: "Boolean"

invariant terminal_link.has_stderr:
  description: "Module exposes .stderr — a separate function for stderr-targeted links"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.stderr.constructor.name"}
  expected: "Function"

invariant terminal_link.fallback_false_returns_plain_text:
  description: "{fallback: false} on unsupported terminal returns just the text"
  category: fallback
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["Click", "https://example.com", {fallback: false}]
  chain: []
  expected: "Click"

invariant terminal_link.default_fallback_returns_text_and_url:
  description: "Default fallback emits 'text url' on unsupported terminal"
  category: fallback
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["Click", "https://example.com"]
  chain: []
  expected: "Click https://example.com"

invariant terminal_link.empty_text:
  description: "Empty text + URL yields just the URL"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["", "https://example.com", {fallback: false}]
  chain: []
  expected: ""

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:30:27Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
