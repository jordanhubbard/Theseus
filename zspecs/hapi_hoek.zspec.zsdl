spec: hapi_hoek
version: ">=11.0.0"
backend: node(@hapi/hoek)

docs: https://github.com/hapijs/hoek#readme

provenance:
  derived_from:
    - "@hapi/hoek README — https://github.com/hapijs/hoek#readme"
    - "Test vectors verified with @hapi/hoek via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "@hapi/hoek source"
  notes:
    - "General-purpose utilities used throughout the Hapi ecosystem (clone, intersect, flatten, reach, escape*)."
    - "Install: npm install @hapi/hoek"
    - "v11 CJS; named exports for each helper."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; assert() throws AssertError on falsy input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    AssertError: "Raised by Hoek.assert(condition, message) when condition is falsy"

invariant hapi_hoek.intersect_simple:
  description: "intersect([1,2,3], [2,3,4]) is [2,3]"
  category: array
  kind: node_chain_eq
  entry: named
  function: intersect
  entry_args: [[1, 2, 3], [2, 3, 4]]
  chain: []
  expected: [2, 3]

invariant hapi_hoek.intersect_disjoint:
  description: "intersect of disjoint arrays is []"
  category: array
  kind: node_chain_eq
  entry: named
  function: intersect
  entry_args: [[1, 2], [3, 4]]
  chain: []
  expected: []

invariant hapi_hoek.flatten_two_levels:
  description: "flatten([[1,2],[3,4]]) is [1,2,3,4]"
  category: array
  kind: node_chain_eq
  entry: named
  function: flatten
  entry_args: [[[1, 2], [3, 4]]]
  chain: []
  expected: [1, 2, 3, 4]

invariant hapi_hoek.reach_dotted_path:
  description: "reach({a:{b:'hi'}}, 'a.b') retrieves 'hi'"
  category: reach
  kind: node_chain_eq
  entry: named
  function: reach
  entry_args: [{a: {b: "hi"}}, "a.b"]
  chain: []
  expected: "hi"

invariant hapi_hoek.reach_missing_path:
  description: "reach on a missing path returns undefined (null in JSON)"
  category: reach
  kind: node_chain_eq
  entry: named
  function: reach
  entry_args: [{a: {b: "hi"}}, "a.c"]
  chain: []
  expected: ~

invariant hapi_hoek.contain_substring:
  description: "contain('hello world', 'world') is true"
  category: contain
  kind: node_chain_eq
  entry: named
  function: contain
  entry_args: ["hello world", "world"]
  chain: []
  expected: true

invariant hapi_hoek.contain_negative:
  description: "contain('hello world', 'xyz') is false"
  category: contain
  kind: node_chain_eq
  entry: named
  function: contain
  entry_args: ["hello world", "xyz"]
  chain: []
  expected: false

invariant hapi_hoek.escapeRegex:
  description: "escapeRegex escapes regex metacharacters"
  category: escape
  kind: node_chain_eq
  entry: named
  function: escapeRegex
  entry_args: ["a.b*c"]
  chain: []
  expected: "a\\.b\\*c"

invariant hapi_hoek.escapeHtml:
  description: "escapeHtml('<a>') is '&lt;a&gt;'"
  category: escape
  kind: node_chain_eq
  entry: named
  function: escapeHtml
  entry_args: ["<a>"]
  chain: []
  expected: "&lt;a&gt;"

invariant hapi_hoek.deepEqual_same:
  description: "deepEqual on identical structures is true"
  category: equal
  kind: node_chain_eq
  entry: named
  function: deepEqual
  entry_args: [{a: 1, b: [1, 2]}, {a: 1, b: [1, 2]}]
  chain: []
  expected: true

invariant hapi_hoek.deepEqual_different:
  description: "deepEqual on differing structures is false"
  category: equal
  kind: node_chain_eq
  entry: named
  function: deepEqual
  entry_args: [{a: 1}, {a: 2}]
  chain: []
  expected: false
