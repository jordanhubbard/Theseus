spec: lodash_lte
version: ">=3.9.2"
backend: node(lodash.lte)

docs: https://lodash.com/docs/#lte

provenance:
  derived_from:
    - "lodash.lte README — https://www.npmjs.com/package/lodash.lte"
    - "Test vectors verified with lodash.lte@3.9.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.lte exports the _.lte function directly as module.exports."
    - "lte(value, other) checks if value is less than or equal to other."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_lte.lte:
  kind: node_module_call_eq
  function: ~
  category: lte
  id_prefix: llte

  columns: [id, args, expected]
  rows:
    - [less,     [1, 3],    true]
    - [equal,    [3, 3],    true]
    - [greater,  [3, 1],    false]
