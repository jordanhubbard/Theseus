spec: concurrent_futures_extra209
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers __qualname__ attributes of concurrent.futures classes: Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor, BrokenExecutor."
    - "concurrent.futures.Future.__qualname__ == 'Future' — top-level class; qualname equals name. len == 6. Verified Python 3.14.3."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' — top-level abstract base class; qualname equals name. len == 8. Verified Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — top-level class; qualname equals name. len == 18. Verified Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — top-level class; qualname equals name. len == 19. Verified Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' — top-level exception class; qualname equals name. len == 14. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures class __qualname__ equality — Future and Executor
#
# concurrent.futures.Future.__qualname__ == 'Future' (len 6)
# concurrent.futures.Executor.__qualname__ == 'Executor' (len 8)
# concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len 18)
# concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len 14)
#
# All are top-level classes so qualname equals their simple __name__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra209.future_executor_qualnames:
  description: "concurrent.futures Future/Executor/ThreadPoolExecutor/BrokenExecutor __qualname__ equality checks in cfqualname209 namespace — all top-level; qualname equals name; new to concurrent_futures_extra209"
  kind: python_call_eq
  category: qualnames
  id_prefix: cfqualname209

  columns: [id, function, args, expected, description]
  rows:
    - [future_qualname_eq,
       Future.__qualname__.__eq__,
       ["Future"],
       true,
       "concurrent.futures.Future.__qualname__.__eq__('Future') == True — Future is a top-level class in concurrent.futures._base; qualname equals name; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [executor_qualname_eq,
       Executor.__qualname__.__eq__,
       ["Executor"],
       true,
       "concurrent.futures.Executor.__qualname__.__eq__('Executor') == True — Executor is a top-level abstract base class; qualname equals name; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [thread_pool_executor_qualname_eq,
       ThreadPoolExecutor.__qualname__.__eq__,
       ["ThreadPoolExecutor"],
       true,
       "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor') == True — ThreadPoolExecutor is a top-level class in concurrent.futures.thread; qualname equals name; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [broken_executor_qualname_eq,
       BrokenExecutor.__qualname__.__eq__,
       ["BrokenExecutor"],
       true,
       "concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor') == True — BrokenExecutor is a top-level exception class; qualname equals name; new to concurrent_futures_extra209; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures class __qualname__ equality — ProcessPoolExecutor
#
# concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len 19)
#
# ProcessPoolExecutor has the longest qualname of the executor classes (19).
# Table also captures qualname lengths for Future and Executor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra209.process_pool_qualname:
  description: "concurrent.futures ProcessPoolExecutor __qualname__ equality and length checks in cfqualname209 namespace; new to concurrent_futures_extra209"
  kind: python_call_eq
  category: qualnames
  id_prefix: cfqualname209

  columns: [id, function, args, expected, description]
  rows:
    - [process_pool_executor_qualname_eq,
       ProcessPoolExecutor.__qualname__.__eq__,
       ["ProcessPoolExecutor"],
       true,
       "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor') == True — ProcessPoolExecutor is a top-level class in concurrent.futures.process; qualname equals name; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [process_pool_executor_qualname_len,
       ProcessPoolExecutor.__qualname__.__len__,
       [],
       19,
       "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [future_qualname_len,
       Future.__qualname__.__len__,
       [],
       6,
       "concurrent.futures.Future.__qualname__.__len__() == 6 — 'Future' has 6 characters; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [executor_qualname_len,
       Executor.__qualname__.__len__,
       [],
       8,
       "concurrent.futures.Executor.__qualname__.__len__() == 8 — 'Executor' has 8 characters; new to concurrent_futures_extra209; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures class __qualname__ lengths — all five classes
#
# Future: 6, Executor: 8, ThreadPoolExecutor: 18,
# ProcessPoolExecutor: 19, BrokenExecutor: 14
#
# Length axis for ThreadPoolExecutor and BrokenExecutor not yet captured.
# ---------------------------------------------------------------------------

table concurrent_futures_extra209.class_qualname_lengths:
  description: "concurrent.futures class __qualname__ lengths for all five classes in cfqualname209 namespace; new to concurrent_futures_extra209"
  kind: python_call_eq
  category: qualnames
  id_prefix: cfqualname209

  columns: [id, function, args, expected, description]
  rows:
    - [thread_pool_executor_qualname_len,
       ThreadPoolExecutor.__qualname__.__len__,
       [],
       18,
       "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [broken_executor_qualname_len,
       BrokenExecutor.__qualname__.__len__,
       [],
       14,
       "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 — 'BrokenExecutor' has 14 characters; new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [thread_longer_than_executor,
       ThreadPoolExecutor.__qualname__.__len__,
       [],
       18,
       "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — longer than Executor (8) and BrokenExecutor (14); new to concurrent_futures_extra209; verified Python 3.14.3"]
    - [process_longer_than_thread,
       ProcessPoolExecutor.__qualname__.__len__,
       [],
       19,
       "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — longest qualname among the five executor classes; new to concurrent_futures_extra209; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra209
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra209.Future.qualname_eq:
  description: "concurrent.futures.Future.__qualname__.__eq__('Future') == True — Future is a top-level class in concurrent.futures._base; its qualname equals its simple name; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra209.Executor.qualname_eq:
  description: "concurrent.futures.Executor.__qualname__.__eq__('Executor') == True — Executor is a top-level abstract base class; its qualname equals its simple name; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra209.ThreadPoolExecutor.qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor') == True — ThreadPoolExecutor is a top-level concrete Executor subclass; its qualname equals its simple name; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra209.ProcessPoolExecutor.qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor') == True — ProcessPoolExecutor is a top-level concrete Executor subclass; its qualname equals its simple name; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra209.BrokenExecutor.qualname_eq:
  description: "concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor') == True — BrokenExecutor is a top-level exception class raised when an executor is broken; its qualname equals its simple name; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra209.ProcessPoolExecutor.qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has exactly 19 characters; the longest qualname among the five executor/future classes; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra209.ThreadPoolExecutor.qualname_len:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor' has exactly 18 characters; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra209.BrokenExecutor.qualname_len:
  description: "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 — 'BrokenExecutor' has exactly 14 characters; new to concurrent_futures_extra209; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__len__
  args: []
  expected: 14
