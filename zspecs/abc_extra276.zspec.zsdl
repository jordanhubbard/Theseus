spec: abc_extra276
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
    - "abc_extra275.zspec.zsdl — covers collections.abc.Set, MutableSet class identity; collections.abc.Sequence class identity and method qualnames (index, count)"
  notes:
    - "This spec covers: collections.abc.Collection class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); collections.abc.Reversible class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); Collection bases list (Sized, Iterable, Container); Collection name length; Reversible name length. NEW in extra276: collections.abc.Collection.__name__=='Collection'; collections.abc.Collection.__module__=='collections.abc'; collections.abc.Collection.__qualname__=='Collection'; collections.abc.Collection.__bases__[0].__name__=='Sized'; collections.abc.Collection.__mro__.__len__()==5 ([Collection, Sized, Iterable, Container, object]); collections.abc.Collection.__name__.__len__()==10; collections.abc.Reversible.__name__=='Reversible'; collections.abc.Reversible.__module__=='collections.abc'; collections.abc.Reversible.__qualname__=='Reversible'; collections.abc.Reversible.__bases__[0].__name__=='Iterable'; collections.abc.Reversible.__mro__.__len__()==3 ([Reversible, Iterable, object]); collections.abc.Reversible.__name__.__len__()==10. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Collection.__mro__.__len__() == 5 — Collection's MRO is [Collection, Sized, Iterable, Container, object] (length=5); Collection has three direct bases (Sized, Iterable, Container); MRO linearisation produces 5 elements; compare MRO depths: Reversible=3, Collection=5, Set=6 (from abc_extra275). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Reversible.__mro__.__len__() == 3 — Reversible's MRO is [Reversible, Iterable, object] (length=3); Reversible has a single direct base (Iterable); this is the shortest MRO in this spec; Reversible is used as the first base of Sequence (see abc_extra275). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Collection.__bases__[0].__name__ == 'Sized' — Collection's first declared base is Sized; the three bases in declaration order are Sized, Iterable, Container. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Collection.__name__.__len__() == 10 and collections.abc.Reversible.__name__.__len__() == 10 — both class names happen to be exactly 10 characters: 'Collection'=10 and 'Reversible'=10. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Collection class identity — extra276
#
# Collection.__name__                    == 'Collection'
# Collection.__module__                  == 'collections.abc'
# Collection.__qualname__                == 'Collection'
# Collection.__bases__[0].__name__       == 'Sized'
# Collection.__mro__.__len__()           == 5
# Collection.__name__.__len__()          == 10
# ---------------------------------------------------------------------------

table abc_extra276.cabc_collection_identity:
  description: "collections.abc.Collection class identity checks in cabccoll276 namespace — Collection is defined in Lib/_collections_abc.py; Collection.__name__.__eq__('Collection')==True; Collection.__module__.__eq__('collections.abc')==True (len=15: 'collections'=11+'.abc'=4); Collection.__qualname__.__eq__('Collection')==True; Collection has three direct bases: Sized, Iterable, Container — declared in that order; Collection.__bases__[0].__name__.__eq__('Sized')==True (first base in declaration order); Collection.__mro__.__len__()==5 ([Collection, Sized, Iterable, Container, object]); Collection.__name__.__len__()==10 ('Collection'=10); Collection is the base for Set (see abc_extra275: Set.__bases__[0].__name__=='Collection'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabccoll276

  columns: [id, function, args, expected, description]
  rows:
    - [coll_name_eq,    collections.abc.Collection.__name__.__eq__,                          ["Collection"],       true, "collections.abc.Collection.__name__ == 'Collection'; verified with Python 3.14.3"]
    - [coll_mod_eq,     collections.abc.Collection.__module__.__eq__,                        ["collections.abc"],  true, "collections.abc.Collection.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [coll_qn_eq,      collections.abc.Collection.__qualname__.__eq__,                      ["Collection"],       true, "collections.abc.Collection.__qualname__ == 'Collection' (module-level class); verified with Python 3.14.3"]
    - [coll_base0_eq,   "collections.abc.Collection.__bases__[0].__name__.__eq__",           ["Sized"],            true, "collections.abc.Collection.__bases__[0].__name__ == 'Sized' (first of three declared bases); verified with Python 3.14.3"]
    - [coll_mro_len,    collections.abc.Collection.__mro__.__len__,                          [],                   5,    "collections.abc.Collection.__mro__.__len__() == 5 — [Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [coll_name_len,   collections.abc.Collection.__name__.__len__,                         [],                   10,   "collections.abc.Collection.__name__.__len__() == 10 ('Collection'=10); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
