# ---------------------------------------------------------------------------

table abc_extra276.cabc_reversible_identity:
  description: "collections.abc.Reversible class identity checks in cabcrev276 namespace — Reversible is defined in Lib/_collections_abc.py; Reversible.__name__.__eq__('Reversible')==True; Reversible.__module__.__eq__('collections.abc')==True (len=15, same as Collection); Reversible.__qualname__.__eq__('Reversible')==True; Reversible has a single direct base: Iterable; Reversible.__bases__[0].__name__.__eq__('Iterable')==True; Reversible.__mro__.__len__()==3 ([Reversible, Iterable, object], shortest in spec); Reversible.__name__.__len__()==10 ('Reversible'=10, same as Collection.__name__.__len__()==10); Reversible is the first base of Sequence (abc_extra275 covers Sequence); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcrev276

  columns: [id, function, args, expected, description]
  rows:
    - [rev_name_eq,    collections.abc.Reversible.__name__.__eq__,                          ["Reversible"],       true, "collections.abc.Reversible.__name__ == 'Reversible'; verified with Python 3.14.3"]
    - [rev_mod_eq,     collections.abc.Reversible.__module__.__eq__,                        ["collections.abc"],  true, "collections.abc.Reversible.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [rev_qn_eq,      collections.abc.Reversible.__qualname__.__eq__,                      ["Reversible"],       true, "collections.abc.Reversible.__qualname__ == 'Reversible' (module-level class); verified with Python 3.14.3"]
    - [rev_base0_eq,   "collections.abc.Reversible.__bases__[0].__name__.__eq__",           ["Iterable"],         true, "collections.abc.Reversible.__bases__[0].__name__ == 'Iterable' (single base); verified with Python 3.14.3"]
    - [rev_mro_len,    collections.abc.Reversible.__mro__.__len__,                          [],                   3,    "collections.abc.Reversible.__mro__.__len__() == 3 — [Reversible, Iterable, object] (shortest in spec); verified with Python 3.14.3"]
    - [rev_name_len,   collections.abc.Reversible.__name__.__len__,                         [],                   10,   "collections.abc.Reversible.__name__.__len__() == 10 ('Reversible'=10, same length as Collection); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra276
# ---------------------------------------------------------------------------

invariant abc_extra276.Collection_module_is_collections_abc:
  description: "collections.abc.Collection.__module__.__eq__('collections.abc') returns True — Collection is defined in Lib/_collections_abc.py and exposed as collections.abc.Collection; its __module__ is 'collections.abc' (len=15: 'collections'=11+'.abc'=4); Collection combines three ABCs: Sized (has __len__), Iterable (has __iter__), and Container (has __contains__); Collection.__bases__[0].__name__ is 'Sized' (first declared base); Collection.__mro__.__len__() is 5 ([Collection, Sized, Iterable, Container, object]); Collection serves as base for Set (abc_extra275: Set.__bases__[0].__name__=='Collection'); NEW in extra276: first standalone Collection.__module__ invariant in cabccoll276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra276.Collection_base0_is_Sized:
  description: "collections.abc.Collection.__bases__[0].__name__.__eq__('Sized') returns True — Collection's first declared base is Sized; the three bases in declaration order are Sized, Iterable, Container; __bases__[0].__name__ is 'Sized' (the first); Collection.__mro__.__len__() is 5 ([Collection, Sized, Iterable, Container, object]); this confirms that Collection aggregates three independent interface ABCs into a single combined ABC; Collection.__module__ is 'collections.abc'; Collection.__name__.__len__() is 10; NEW in extra276: first standalone Collection.__bases__[0] name invariant in cabccoll276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Collection.__bases__[0].__name__.__eq__"
  args: ["Sized"]
  expected: true

invariant abc_extra276.Collection_mro_len_is_5:
  description: "collections.abc.Collection.__mro__.__len__() == 5 — Collection's MRO is [Collection, Sized, Iterable, Container, object] (length=5); Collection has three direct bases (Sized, Iterable, Container), each of which has Iterable or object as their base; the C3 linearisation merges them into a 5-element chain; compare MRO depths in collections.abc: Reversible=3, Collection=5, Set=6 (abc_extra275), MutableSet=7, Sequence=7; Collection.__bases__[0].__name__ is 'Sized'; Collection.__module__ is 'collections.abc'; NEW in extra276: first standalone Collection MRO length invariant in cabccoll276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__mro__.__len__
  args: []
  expected: 5

invariant abc_extra276.Reversible_module_is_collections_abc:
  description: "collections.abc.Reversible.__module__.__eq__('collections.abc') returns True — Reversible is defined in Lib/_collections_abc.py; its __module__ is 'collections.abc' (len=15, same as Collection); Reversible has a single direct base: Iterable; Reversible.__mro__.__len__() is 3 ([Reversible, Iterable, object]); Reversible.__name__.__len__() is 10 ('Reversible'=10, same as Collection.__name__.__len__()==10); Reversible is the first base of Sequence (from abc_extra275: Sequence.__bases__[0].__name__=='Reversible'); Reversible requires __reversed__ to be implemented; NEW in extra276: first standalone Reversible.__module__ invariant in cabcrev276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Reversible.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra276.Reversible_mro_len_is_3:
  description: "collections.abc.Reversible.__mro__.__len__() == 3 — Reversible's MRO is [Reversible, Iterable, object] (length=3); this is the shortest MRO in this spec; Reversible has a single base (Iterable) which itself has object as its base, giving a 3-element chain; compare MRO depths: Reversible=3, Collection=5, Set=6 (abc_extra275); Reversible.__bases__[0].__name__ is 'Iterable'; Reversible.__module__ is 'collections.abc'; NEW in extra276: first standalone Reversible MRO length invariant in cabcrev276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Reversible.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra276.Collection_and_Reversible_name_len_both_10:
  description: "collections.abc.Collection.__name__.__len__() == 10 — Collection.__name__ is 'Collection' (len=10) and Reversible.__name__ is 'Reversible' (also len=10); both class names are exactly 10 characters; this name-length equality is a coincidence of naming; Collection.__name__.__len__() and Reversible.__name__.__len__() are both 10; Collection.__module__ and Reversible.__module__ are both 'collections.abc' (len=15); despite equal name lengths, their MRO depths differ significantly: Collection=5, Reversible=3; NEW in extra276: first standalone Collection name length invariant in cabccoll276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__name__.__len__
  args: []
  expected: 10
