spec: socket_extra2491
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra.zspec.zsdl — covers getaddrinfo, gethostname, setblocking, timeout attrs"
    - "socket_extra2.zspec.zsdl — covers additional socket method and attr coverage"
    - "socket_extra2131.zspec.zsdl — covers exception protocol dict-presence for socket exception types"
  notes:
    - "Wave extra2491, theme: __setitem__, __delitem__, and __missing__ dict-presence."
    - "Checks whether socket.socket defines mutable item access or missing-key protocol in its class __dict__."
    - "socket.socket is a network I/O class, not a mapping; it defines no subscript-access or missing-key protocol."
    - "socket.socket.__dict__ contains: __doc__, __enter__, __exit__, __firstlineno__, __getstate__, __init__, __module__, __repr__, __slots__, __static_attributes__, __weakref__, _check_sendfile_params, _closed, _decref_socketios, _io_refs, _real_close, _sendfile_use_send, _sendfile_use_sendfile, accept, close, detach, dup, family, get_inheritable, makefile, sendfile, set_inheritable, type."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — __setitem__ absent from class __dict__
# socket.socket is not a mutable mapping; no subscript-assignment protocol
# is defined in its class __dict__.
# ---------------------------------------------------------------------------

table socket_extra2491.socket_setitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2491

  columns: [id, function, args, expected]
  rows:
    - ["sk2491001", socket.__dict__.__contains__, ["__setitem__"], false]

# ---------------------------------------------------------------------------
# socket.socket — __delitem__ absent from class __dict__
# Subscript deletion protocol is not defined on socket.socket.
# ---------------------------------------------------------------------------

table socket_extra2491.socket_delitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2491

  columns: [id, function, args, expected]
  rows:
    - ["sk2491002", socket.__dict__.__contains__, ["__delitem__"], false]

# ---------------------------------------------------------------------------
# socket.socket — __missing__ absent from class __dict__
# Missing-key fallback protocol is not defined on socket.socket.
# ---------------------------------------------------------------------------

table socket_extra2491.socket_missing_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2491

  columns: [id, function, args, expected]
  rows:
    - ["sk2491003", socket.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# socket.socket — __getitem__ also absent (related sanity check)
# Confirms socket.socket defines no subscript read protocol either.
# ---------------------------------------------------------------------------

table socket_extra2491.socket_getitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2491

  columns: [id, function, args, expected]
  rows:
    - ["sk2491004", socket.__dict__.__contains__, ["__getitem__"], false]

# ---------------------------------------------------------------------------
# socket.socket — real methods present in __dict__ (positive anchors)
# Verifies that __dict__.__contains__ works correctly for socket.socket.
# These are methods and attributes documented in the socket public API.
# ---------------------------------------------------------------------------

table socket_extra2491.socket_real_methods_present:
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2491

  columns: [id, function, args, expected]
  rows:
    - ["sk2491005", socket.__dict__.__contains__, ["__init__"],         true]
    - ["sk2491006", socket.__dict__.__contains__, ["__repr__"],         true]
    - ["sk2491007", socket.__dict__.__contains__, ["__slots__"],        true]
    - ["sk2491008", socket.__dict__.__contains__, ["__enter__"],        true]
    - ["sk2491009", socket.__dict__.__contains__, ["__exit__"],         true]
    - ["sk2491010", socket.__dict__.__contains__, ["accept"],           true]
    - ["sk2491011", socket.__dict__.__contains__, ["close"],            true]
    - ["sk2491012", socket.__dict__.__contains__, ["detach"],           true]
    - ["sk2491013", socket.__dict__.__contains__, ["dup"],              true]
    - ["sk2491014", socket.__dict__.__contains__, ["makefile"],         true]
    - ["sk2491015", socket.__dict__.__contains__, ["sendfile"],         true]
    - ["sk2491016", socket.__dict__.__contains__, ["family"],           true]
    - ["sk2491017", socket.__dict__.__contains__, ["type"],             true]
    - ["sk2491018", socket.__dict__.__contains__, ["get_inheritable"],  true]
    - ["sk2491019", socket.__dict__.__contains__, ["set_inheritable"],  true]
