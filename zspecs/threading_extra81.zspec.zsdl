spec: threading_extra81
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra80.zspec.zsdl."
    - "This spec covers: threading Thread method code attributes — start/run/is_alive/getName/setName/isDaemon/setDaemon/__repr__ (Wave 245)."
    - "Thread is a pure-Python class defined in Lib/threading.py; all listed methods have __code__. Verified with Python 3.14.3."
    - "Thread.start.__code__.co_name == 'start' — code object name matches method name. Verified with Python 3.14.3."
    - "Thread.start.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Thread.run.__code__.co_name == 'run' — code object name matches method name. Verified with Python 3.14.3."
    - "Thread.run.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Thread.is_alive.__code__.co_name == 'is_alive' — code object name matches method name. Verified with Python 3.14.3."
    - "Thread.is_alive.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Thread.getName.__code__.co_name == 'getName' — deprecated but still present in Python 3.14.3. Verified with Python 3.14.3."
    - "Thread.getName.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Thread.setName.__code__.co_name == 'setName' — deprecated but still present. Verified with Python 3.14.3."
    - "Thread.setName.__code__.co_argcount == 2 — self and name. Verified with Python 3.14.3."
    - "Thread.isDaemon.__code__.co_name == 'isDaemon' — deprecated but still present. Verified with Python 3.14.3."
    - "Thread.isDaemon.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Thread.setDaemon.__code__.co_name == 'setDaemon' — deprecated but still present. Verified with Python 3.14.3."
    - "Thread.setDaemon.__code__.co_argcount == 2 — self and daemonic. Verified with Python 3.14.3."
    - "Thread.__repr__.__code__.co_name == '__repr__' — code object name matches method name. Verified with Python 3.14.3."
    - "Thread.__repr__.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.start and Thread.run code objects — extra81
#
# Wave 245 theme: Thread.start and Thread.run code object attributes.
#
# threading.Thread.start.__code__.co_name     == 'start'
# threading.Thread.start.__code__.co_argcount == 1
# threading.Thread.run.__code__.co_name       == 'run'
# threading.Thread.run.__code__.co_argcount   == 1
#
# No prior threading spec checks Thread.start/run code objects via threadingextra81. New to extra81.
# ---------------------------------------------------------------------------

table threading_extra81.Thread_start_run_code:
  description: "Thread.start.__code__.co_name=='start', co_argcount==1; run co_name=='run', co_argcount==1; wave 245 Thread start/run code attrs; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra81

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_start_code_co_name_eq_start,
       Thread.start.__code__.co_name.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__code__.co_name.__eq__('start') == True — Thread is a pure-Python class defined in Lib/threading.py; its start method's code object co_name records the method name 'start' (5 chars); str.__eq__('start') returns True; no prior threading spec checks Thread.start.__code__.co_name via threadingextra81; new to extra81"]
    - [Thread_start_code_co_argcount_eq_1,
       Thread.start.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Thread.start.__code__.co_argcount.__eq__(1) == True — Thread.start(self) takes exactly one positional argument, self; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks Thread.start.__code__.co_argcount via threadingextra81; new to extra81"]
    - [Thread_run_code_co_name_eq_run,
       Thread.run.__code__.co_name.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__code__.co_name.__eq__('run') == True — Thread is a pure-Python class defined in Lib/threading.py; its run method's code object co_name records the method name 'run' (3 chars); str.__eq__('run') returns True; no prior threading spec checks Thread.run.__code__.co_name via threadingextra81; new to extra81"]
    - [Thread_run_code_co_argcount_eq_1,
       Thread.run.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Thread.run.__code__.co_argcount.__eq__(1) == True — Thread.run(self) takes exactly one positional argument, self; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks Thread.run.__code__.co_argcount via threadingextra81; new to extra81"]

