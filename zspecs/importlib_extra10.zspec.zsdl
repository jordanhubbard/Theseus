spec: importlib_extra10
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
    - "importlib_machinery.zspec.zsdl — covers importlib.machinery classes via python_module(importlib.machinery) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra9.zspec.zsdl."
    - "importlib.import_module.__name__ == 'import_module' — function name attribute."
    - "importlib.reload.__name__ == 'reload' — function name attribute."
    - "importlib.find_loader does not exist in Python 3.12 (removed); this spec skips it."
    - "importlib.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance."
    - "importlib.__package__ == 'importlib' — the module is inside the importlib package."
    - "importlib.__name__ == 'importlib' — the module name."
    - "importlib.import_module.__module__ == 'importlib' — defined in the importlib module."
    - "importlib.reload.__module__ == 'importlib' — defined in the importlib module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# import_module and reload — __name__ attributes
#
# Prior specs cover __qualname__ and __module__ for these functions in earlier
# extras. This spec anchors __name__ as standalone invariants in the extra10
# namespace, providing a new coverage axis.
# ---------------------------------------------------------------------------

invariant importlib_extra10.import_module.name:
  description: "importlib.import_module.__name__ == 'import_module'"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__name__.__eq__
  args: ["import_module"]
  expected: true

invariant importlib_extra10.reload.name:
  description: "importlib.reload.__name__ == 'reload'"
  category: function_attrs
  kind: python_call_eq
  function: reload.__name__.__eq__
  args: ["reload"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__spec__.__class__.__name__ == 'ModuleSpec'
#
# importlib_extra9 checks __spec__.name == 'importlib' (via util/__spec__.name).
# No prior spec checks __spec__.__class__.__name__ == 'ModuleSpec' for the
# importlib module itself via the python_module(importlib) backend.
# ---------------------------------------------------------------------------

invariant importlib_extra10.spec_class_name:
  description: "importlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__package__ == 'importlib'
#
# pkgutil_extra6 covers pkgutil.__package__ == ''. No prior importlib spec
# checks importlib.__package__ directly as a standalone invariant.
# importlib is itself a package, so __package__ == 'importlib'.
# ---------------------------------------------------------------------------

invariant importlib_extra10.package:
  description: "importlib.__package__ == 'importlib' — module is a package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__name__ == 'importlib'
#
# importlib_extra3 covers __name__ via a table. This standalone invariant
# re-anchors the __name__ check in the extra10 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra10.module_name:
  description: "importlib.__name__ == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# import_module and reload — __module__ attributes (table)
#
# Both functions are defined in the importlib package. This table groups
# the __module__ checks for both functions together. Prior specs cover
# __module__ for these functions but in different namespaces; this table
# consolidates them in the extra10 namespace.
# ---------------------------------------------------------------------------

table importlib_extra10.core_functions_module:
  description: "__module__ for importlib.import_module and importlib.reload"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fn_module

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__module__.__eq__, ["importlib"], true]
    - [reload,        reload.__module__.__eq__,        ["importlib"], true]
