spec: cli_table3
version: ">=0.6.0"
backend: node(cli-table3)

docs: https://github.com/cli-table/cli-table3#readme

provenance:
  derived_from:
    - "cli-table3 README — https://github.com/cli-table/cli-table3#readme"
    - "Test vectors verified with cli-table3 via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "cli-table3 source"
  notes:
    - "Pretty Unicode tables for the terminal — fork of cli-table that handles wide chars."
    - "Install: npm install cli-table3"
    - "v0.6 CJS; module export IS the Table constructor; .toString() renders the box-drawn table."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor never throws; toString never throws."
  stderr: "null"
  stickiness: "N/A — each Table instance independent."
  codes: {}

invariant cli_table3.module_is_constructor:
  description: "Module export is the Table class"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant cli_table3.empty_table_length:
  description: "Fresh Table([]).length is 0 (zero rows)"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{head: ["A", "B"]}]
  chain:
    - {get: length}
  expected: 0

invariant cli_table3.push_then_length:
  description: "After push, table.length is 1"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{head: ["A", "B"]}]
  chain:
    - {method: push, args: [["1", "2"]], tap: true}
    - {get: length}
  expected: 1

invariant cli_table3.options_head_preserved:
  description: ".options.head reflects constructor input"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{head: ["A", "B", "C"]}]
  chain:
    - {get: "options.head"}
  expected: ["A", "B", "C"]

invariant cli_table3.toString_returns_string:
  description: "toString() returns a String (the rendered table)"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{head: ["A"]}]
  chain:
    - {method: toString, args: []}
    - {get: "constructor.name"}
  expected: "String"

invariant cli_table3.toString_contains_header:
  description: "Rendered table contains the header text"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{head: ["MyHeader"]}]
  chain:
    - {method: toString, args: []}
    - {method: includes, args: ["MyHeader"]}
  expected: true

invariant cli_table3.options_chars_default_present:
  description: "Default options has a chars table for box-drawing"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: "options.chars.top"}
    - {get: "constructor.name"}
  expected: "String"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:19:53Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
