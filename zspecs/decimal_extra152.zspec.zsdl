spec: decimal_extra152
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context method __qualname__ values — quantize, sqrt, power, add, subtract, multiply, divide, create_decimal."
    - "All Context method qualnames follow the 'Context.<method>' pattern. The 'Context.' prefix is 8 characters."
    - "decimal.Context.quantize.__qualname__ == 'Context.quantize' (len=16; 'Context.' (8) + 'quantize' (8) = 16; elegant symmetry where prefix and method name are equal length)."
    - "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' (len=12; 'Context.' (8) + 'sqrt' (4) = 12)."
    - "decimal.Context.power.__qualname__ == 'Context.power' (len=13; 'Context.' (8) + 'power' (5) = 13)."
    - "decimal.Context.add.__qualname__ == 'Context.add' (len=11; 'Context.' (8) + 'add' (3) = 11; shortest of the arithmetic Context method qualnames)."
    - "decimal.Context.subtract.__qualname__ == 'Context.subtract' (len=16; tied with Context.quantize at 16)."
    - "decimal.Context.multiply.__qualname__ == 'Context.multiply' (len=16; tied with Context.quantize and Context.subtract at 16)."
    - "decimal.Context.divide.__qualname__ == 'Context.divide' (len=14; 'Context.' (8) + 'divide' (6) = 14)."
    - "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' (len=22; 'Context.' (8) + 'create_decimal' (14) = 22; the longest Context method qualname covered here)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context arithmetic method __qualname__ values (group 1)
# add, subtract, multiply, divide, power — the four basic operations plus power.
# 'Context.' prefix = 8 chars.
# add = 11, divide = 14, power = 13, subtract = 16, multiply = 16
# ---------------------------------------------------------------------------

table decimal_extra152.Context_arithmetic_method_qualnames:
  description: "decimal.Context arithmetic method __qualname__ values: add=11, power=13, divide=14, subtract=16, multiply=16; all 'Context.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: decctxq152

  columns: [id, function, args, expected, description]
  rows:
    - [add_qeq,      Context.add.__qualname__.__eq__,       ["Context.add"],      true, "decimal.Context.add.__qualname__ == 'Context.add' (len=11; 'Context.' (8) + 'add' (3) = 11; the shortest Context arithmetic method qualname; Context.add(a, b) performs decimal addition in the context — equivalent to a + b but using the Context for rounding and signal handling; this is distinct from Decimal.add() on the Decimal class)"]
    - [power_qeq,    Context.power.__qualname__.__eq__,     ["Context.power"],    true, "decimal.Context.power.__qualname__ == 'Context.power' (len=13; 'Context.' (8) + 'power' (5) = 13; Context.power(a, b) or Context.power(a, b, modulo) computes a raised to the power b within the context; the modulo form computes (a**b) % modulo efficiently; 'Context.power' is tied with neither the shorter add (11) nor the longer subtract/multiply (both 16))"]
    - [divide_qeq,   Context.divide.__qualname__.__eq__,    ["Context.divide"],   true, "decimal.Context.divide.__qualname__ == 'Context.divide' (len=14; 'Context.' (8) + 'divide' (6) = 14; Context.divide(a, b) performs decimal division in the context; raises DivisionByZero signal when b is zero; 'Context.divide' is distinct from Context.divide_int which returns the integer quotient)"]
    - [subtract_qeq, Context.subtract.__qualname__.__eq__,  ["Context.subtract"], true, "decimal.Context.subtract.__qualname__ == 'Context.subtract' (len=16; 'Context.' (8) + 'subtract' (8) = 16; Context.subtract(a, b) performs decimal subtraction within the context; the method name 'subtract' (8 chars) equals the 'Context.' prefix length (8 chars) — the same elegant symmetry as Context.quantize (also len=16))"]
    - [multiply_qeq, Context.multiply.__qualname__.__eq__,  ["Context.multiply"], true, "decimal.Context.multiply.__qualname__ == 'Context.multiply' (len=16; 'Context.' (8) + 'multiply' (8) = 16; Context.multiply(a, b) performs decimal multiplication within the context; tied with Context.subtract and Context.quantize at qualname length 16 — all three have 8-character method names that exactly match the 'Context.' prefix length)"]

# ---------------------------------------------------------------------------
# decimal.Context rounding and creation method __qualname__ values (group 2)
# quantize, sqrt, create_decimal
# quantize = 16, sqrt = 12, create_decimal = 22
# ---------------------------------------------------------------------------

table decimal_extra152.Context_rounding_creation_qualnames:
  description: "decimal.Context rounding and creation method __qualname__ values: sqrt=12, quantize=16, create_decimal=22; create_decimal is the longest Context method qualname covered here"
  kind: python_call_eq
  category: qualname
  id_prefix: decctxq152

  columns: [id, function, args, expected, description]
  rows:
    - [sqrt_qeq,            Context.sqrt.__qualname__.__eq__,            ["Context.sqrt"],            true, "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' (len=12; 'Context.' (8) + 'sqrt' (4) = 12; Context.sqrt(a) computes the square root of a within the context precision; the Context version differs from Decimal.sqrt() in that it uses the given Context rather than the thread-local context; compare with Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (also len=12) from decimal_extra150)"]
    - [quantize_qeq,        Context.quantize.__qualname__.__eq__,        ["Context.quantize"],        true, "decimal.Context.quantize.__qualname__ == 'Context.quantize' (len=16; 'Context.' (8) + 'quantize' (8) = 16; Context.quantize(a, b) rounds a to the same exponent as b within the context; compare with Decimal.quantize.__qualname__ == 'Decimal.quantize' (also len=16 — same length but different class prefix, both 8+8=16 symmetry); quantize() is critical for financial applications rounding to cents)"]
    - [create_decimal_qeq,  Context.create_decimal.__qualname__.__eq__,  ["Context.create_decimal"], true, "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' (len=22; 'Context.' (8) + 'create_decimal' (14) = 22; the longest Context method qualname in this spec; Context.create_decimal(num) creates a new Decimal from num using the given context for rounding and signal handling; differs from the Decimal() constructor which uses the thread-local context)"]
    - [sqrt_qlen,           Context.sqrt.__qualname__.__len__,           [],                          12,   "decimal.Context.sqrt.__qualname__.__len__() == 12 ('Context.sqrt' has 12 characters; 'Context.' (8) + 'sqrt' (4) = 12; tied with Decimal.sqrt.__qualname__.__len__() (also 12 from decimal_extra150) — the same method name 'sqrt' produces the same qualname length regardless of whether it lives on Context or Decimal, since both class name prefixes happen to be 8 characters: 'Decimal.' and 'Context.' are both 8 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra152.Context_add_qualname_eq:
  description: "decimal.Context.add.__qualname__ == 'Context.add' — add() is the Context arithmetic method for decimal addition; its qualname has 11 characters ('Context.' (8) + 'add' (3) = 11) making it the shortest arithmetic Context method qualname in this spec; Context arithmetic methods (add, subtract, multiply, divide, power) all use 'Context.' prefix and report __qualname__ values with the public class name 'Context'; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Context.add.__qualname__.__eq__
  args: ["Context.add"]
  expected: true

invariant decimal_extra152.Context_quantize_qualname_eq:
  description: "decimal.Context.quantize.__qualname__ == 'Context.quantize' — Context.quantize(a, b) rounds a to the same exponent as b using this Context for signal handling; qualname length 16 ('Context.' (8) + 'quantize' (8) = 16); the elegant symmetry: the method name 'quantize' (8 chars) equals the prefix 'Context.' (8 chars); this same 8+8=16 symmetry also applies to Context.subtract (8+8=16) and Context.multiply (8+8=16); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Context.quantize.__qualname__.__eq__
  args: ["Context.quantize"]
  expected: true

invariant decimal_extra152.Context_create_decimal_qualname_eq:
  description: "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' — create_decimal() converts a number to Decimal using this Context's settings; its qualname has 22 characters ('Context.' (8) + 'create_decimal' (14) = 22) making it the longest Context method qualname in this spec; 'create_decimal' (14 chars) is considerably longer than the arithmetic method names (add=3, sqrt=4, power=5, divide=6, quantize/subtract/multiply=8); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__eq__
  args: ["Context.create_decimal"]
  expected: true

invariant decimal_extra152.Context_subtract_qualname_eq:
  description: "decimal.Context.subtract.__qualname__ == 'Context.subtract' — subtract() performs decimal subtraction in the given Context; qualname length 16 ('Context.' (8) + 'subtract' (8) = 16); tied with Context.quantize (16) and Context.multiply (16) — all three have method names exactly 8 characters long, equaling the 'Context.' prefix length; this three-way tie at qualname length 16 is a notable pattern in the decimal.Context API"
  category: qualname
  kind: python_call_eq
  function: Context.subtract.__qualname__.__eq__
  args: ["Context.subtract"]
  expected: true

invariant decimal_extra152.Context_multiply_qualname_eq:
  description: "decimal.Context.multiply.__qualname__ == 'Context.multiply' — multiply() performs decimal multiplication in the given Context; qualname length 16 ('Context.' (8) + 'multiply' (8) = 16); completes the three-way tie at length 16 with Context.quantize and Context.subtract; in contrast, Decimal.multiply does not exist as a public method — the Decimal class uses operator overloading (* operator) rather than a named multiply() method; Context explicitly provides arithmetic methods by name"
  category: qualname
  kind: python_call_eq
  function: Context.multiply.__qualname__.__eq__
  args: ["Context.multiply"]
  expected: true

