spec: hashlib_extra118
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra117.zspec.zsdl — covers shake_128/shake_256 XOF instance name/block_size/digest_size/class/method qualnames (table + invariants)."
    - "hashlib_extra116.zspec.zsdl — covers HASH instance method type identity and qualname / sha256().__class__.__module__ equality (table + invariants)."
    - "hashlib_extra115.zspec.zsdl — covers hash object .name attribute equality and lengths / hashlib.new function identity / pbkdf2_hmac module and type (table + invariants)."
    - "hashlib_extra113.zspec.zsdl — covers HASH class-level descriptor types / HASH descriptor qualnames and __objclass__ (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality / qualname length groupings (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2) (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra117; it does NOT duplicate invariants present in those files."
    - "Wave 275 theme: hashlib.algorithms_guaranteed and hashlib.algorithms_available set attributes not yet covered — class identity (set, not frozenset), module (builtins), __len__() values, __contains__ membership tests for sha256/md5/sha1/blake2b, issubset/issuperset relationship, class name length."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('notreal') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.issuperset(hashlib.algorithms_guaranteed) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 (len('set')). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__module__.__len__() == 8 (len('builtins')). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: algorithms_guaranteed is a plain Python set (not frozenset — the docstring implies immutability but CPython implements it as set). algorithms_available is also a set. Both have __class__.__module__ == 'builtins'. algorithms_guaranteed has 14 members on CPython 3.14.3 macOS; algorithms_available has 19 (includes additional OpenSSL-provided names). algorithms_guaranteed is always a subset of algorithms_available."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__module__.__eq__('builtins')
# hashlib.algorithms_guaranteed.__len__() == 14
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__len__() == 19
#
# Wave 275 theme: algorithms_guaranteed and algorithms_available class identity and len.
#
# Both algorithms_guaranteed and algorithms_available are plain Python set objects
# (not frozenset). Their __class__.__name__ is 'set' and __class__.__module__ is
# 'builtins'. algorithms_guaranteed has 14 members (the guaranteed portable set);
# algorithms_available has 19 (OpenSSL-provided algorithms on macOS/Darwin 25.4.0).
# No prior hashlib spec anchors the class identity or __len__() of these module-level
# set attributes as a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra118.algorithms_set_class_identity_and_len:
  description: "algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__class__.__module__.__eq__('builtins')==True / algorithms_guaranteed.__len__()==14 / algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_available.__len__()==19 — both are plain set (not frozenset); __module__=='builtins'; guaranteed has 14 members (portable); available has 19 (includes OpenSSL extras on macOS); no prior hashlib spec anchors these set attributes; first algset118 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: algset118

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_class_name,   "algorithms_guaranteed.__class__.__name__.__eq__",   ["set"],      true, "hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (plain set, not frozenset; mutable container type)"]
    - [guaranteed_class_module, "algorithms_guaranteed.__class__.__module__.__eq__", ["builtins"], true, "hashlib.algorithms_guaranteed.__class__.__module__ is 'builtins' (set is a built-in type; no import needed)"]
    - [guaranteed_len,          "algorithms_guaranteed.__len__",                     [],           14,   "hashlib.algorithms_guaranteed.__len__() is 14 (portable hash algorithms guaranteed on all CPython platforms)"]
    - [available_class_name,    "algorithms_available.__class__.__name__.__eq__",    ["set"],      true, "hashlib.algorithms_available.__class__.__name__ is 'set' (same type as algorithms_guaranteed; also a plain set)"]
    - [available_len,           "algorithms_available.__len__",                      [],           19,   "hashlib.algorithms_available.__len__() is 19 (includes OpenSSL-provided algorithms on macOS/Darwin 25.4.0)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256')
# hashlib.algorithms_guaranteed.__contains__('md5')
# hashlib.algorithms_guaranteed.__contains__('sha1')
# hashlib.algorithms_guaranteed.__contains__('blake2b')
# hashlib.algorithms_guaranteed.__contains__('notreal')
#
# Wave 275 theme: algorithms_guaranteed membership tests via __contains__.
#
# The __contains__ method of a set is the same as the 'in' operator. Testing
# specific algorithm names against algorithms_guaranteed confirms which algorithms
# are guaranteed portable. sha256, md5, sha1, and blake2b are all in
# algorithms_guaranteed. 'notreal' is not a valid algorithm and returns False.
# No prior hashlib spec anchors __contains__ membership tests on algorithms_guaranteed
# as a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra118.algorithms_guaranteed_membership_tests:
  description: "algorithms_guaranteed.__contains__('sha256')==True / algorithms_guaranteed.__contains__('md5')==True / algorithms_guaranteed.__contains__('sha1')==True / algorithms_guaranteed.__contains__('blake2b')==True / algorithms_guaranteed.__contains__('notreal')==False — sha256/md5/sha1/blake2b are guaranteed portable across CPython platforms; 'notreal' is not a valid algorithm and is absent; __contains__ is the set membership method (equivalent to 'in' operator); no prior spec anchors these membership tests; first algset118 anchor"
  kind: python_call_eq
  category: membership
  id_prefix: algset118

  columns: [id, function, args, expected, description]
  rows:
    - [contains_sha256,  "algorithms_guaranteed.__contains__", ["sha256"],  true,  "hashlib.algorithms_guaranteed.__contains__('sha256') is True (SHA-256 is guaranteed portable; standard cryptographic hash)"]
    - [contains_md5,     "algorithms_guaranteed.__contains__", ["md5"],     true,  "hashlib.algorithms_guaranteed.__contains__('md5') is True (MD5 is guaranteed; widely used though cryptographically broken)"]
    - [contains_sha1,    "algorithms_guaranteed.__contains__", ["sha1"],    true,  "hashlib.algorithms_guaranteed.__contains__('sha1') is True (SHA-1 is guaranteed; deprecated for security but still portable)"]
    - [contains_blake2b, "algorithms_guaranteed.__contains__", ["blake2b"], true,  "hashlib.algorithms_guaranteed.__contains__('blake2b') is True (BLAKE2b is guaranteed; modern fast hash with 512-bit output)"]
    - [contains_notreal, "algorithms_guaranteed.__contains__", ["notreal"], false, "hashlib.algorithms_guaranteed.__contains__('notreal') is False ('notreal' is not a valid hash algorithm name)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__('sha256')
# hashlib.algorithms_available.__contains__('blake2b')
# hashlib.algorithms_available.__class__.__module__.__eq__('builtins')
# hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3
# hashlib.algorithms_guaranteed.__class__.__module__.__len__() == 8
#
# Wave 275 theme: algorithms_available membership and class name/module lengths.
#
# sha256 and blake2b are guaranteed algorithms so also appear in algorithms_available.
# algorithms_available has __class__.__module__ == 'builtins' (same as guaranteed).
# The class name 'set' has length 3; the module name 'builtins' has length 8.
# No prior hashlib spec anchors these combinations. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra118.algorithms_set_available_membership_and_class_lens:
  description: "algorithms_available.__contains__('sha256')==True / algorithms_available.__contains__('blake2b')==True / algorithms_available.__class__.__module__.__eq__('builtins')==True / algorithms_guaranteed.__class__.__name__.__len__()==3 / algorithms_guaranteed.__class__.__module__.__len__()==8 — sha256 and blake2b appear in both guaranteed and available sets; available class module is 'builtins' (same as guaranteed); class name 'set' is 3 chars; module 'builtins' is 8 chars; no prior spec anchors these; first algset118 anchor"
  kind: python_call_eq
  category: set_relations
  id_prefix: algset118

  columns: [id, function, args, expected, description]
  rows:
    - [available_sha256,       "algorithms_available.__contains__",                 ["sha256"],  true, "hashlib.algorithms_available.__contains__('sha256') is True (sha256 is in both guaranteed and available sets)"]
    - [available_blake2b,      "algorithms_available.__contains__",                 ["blake2b"], true, "hashlib.algorithms_available.__contains__('blake2b') is True (blake2b is guaranteed so also available)"]
    - [available_class_module, "algorithms_available.__class__.__module__.__eq__",  ["builtins"],true, "hashlib.algorithms_available.__class__.__module__ is 'builtins' (set is a built-in type; same as algorithms_guaranteed)"]
    - [class_name_len,         "algorithms_guaranteed.__class__.__name__.__len__",  [],          3,    "hashlib.algorithms_guaranteed.__class__.__name__.__len__() is 3 (len('set')==3; shortest container type name)"]
    - [class_module_len,       "algorithms_guaranteed.__class__.__module__.__len__",[],          8,    "hashlib.algorithms_guaranteed.__class__.__module__.__len__() is 8 (len('builtins')==8)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set'. The Python docs
# describe algorithms_guaranteed as a set of hash names guaranteed to be
# supported by the hashlib module on all platforms. Despite the immutability
# implied by "guaranteed", it is implemented as a plain mutable set (not
# frozenset) in CPython. Its __class__.__name__ is 'set' and __class__.__module__
# is 'builtins'. No prior hashlib spec anchors algorithms_guaranteed class name
# equality as a standalone under algset118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra118.guaranteed_class_name_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — class name is 'set' (3 chars; plain mutable set not frozenset; despite immutability implied by 'guaranteed'); __class__.__module__=='builtins'; no prior hashlib spec anchors this as standalone; first standalone under algset118"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__() == 14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 guaranteed algorithms
# on CPython 3.14.3 macOS are: blake2b, blake2s, md5, sha1, sha224, sha256,
# sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256.
# This count is the portable baseline across all CPython platforms (Windows,
# Linux, macOS). algorithms_available has 19 elements (5 additional OpenSSL-
# provided names on macOS). No prior hashlib spec anchors the guaranteed set
# length as a standalone under algset118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra118.guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — 14 portable hash algorithms on CPython 3.14.3 macOS: blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_224/sha3_256/sha3_384/sha3_512/sha512/shake_128/shake_256; algorithms_available has 19 (5 additional OpenSSL extras); no prior hashlib spec anchors guaranteed len as standalone; first standalone under algset118"
  category: set_size
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha256') is True. sha256 is the
# most widely used secure hash function in modern cryptography (TLS, Bitcoin,
# Git, etc.). It produces a 256-bit (32-byte) digest and is NIST-approved.
# Being in algorithms_guaranteed means it is available on all CPython platforms
# without relying on optional OpenSSL support. No prior hashlib spec anchors
# algorithms_guaranteed.__contains__('sha256') as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra118.guaranteed_contains_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is a guaranteed portable algorithm (256-bit NIST-approved hash; used in TLS/Bitcoin/Git); available on all CPython platforms; algorithms_guaranteed.__len__()==14 includes sha256; no prior hashlib spec anchors this as standalone; first standalone under algset118"
  category: membership
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__() == 19 — standalone
#
# hashlib.algorithms_available.__len__() is 19 on macOS/Darwin 25.4.0.
# algorithms_available is the set of algorithms available via the hashlib
# module in the current Python environment, including both the 14 guaranteed
# algorithms and 5 additional OpenSSL-provided ones on macOS. Like
# algorithms_guaranteed, it is a plain set (not frozenset). The count of 19
# is platform-specific (Linux/Windows may have different counts). No prior
# hashlib spec anchors algorithms_available.__len__() as a standalone under
# algset118. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra118.available_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — 19 available algorithms on macOS/Darwin 25.4.0 (14 guaranteed + 5 OpenSSL extras); platform-specific count; algorithms_available is also a plain set (class name 'set'); superset of algorithms_guaranteed; no prior hashlib spec anchors available len as standalone; first standalone under algset118"
  category: set_size
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('md5') is True. MD5 (Message
# Digest 5) is a 128-bit hash function that produces a 16-byte digest. Despite
# being cryptographically broken (collision attacks have been demonstrated),
# MD5 remains in algorithms_guaranteed because it is still used for non-security
# purposes (checksums, data deduplication, legacy compatibility). Its continued
# inclusion in the guaranteed set reflects CPython's conservative approach to
# removing widely-used functions. No prior hashlib spec anchors
# algorithms_guaranteed.__contains__('md5') as a standalone under algset118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra118.guaranteed_contains_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is a guaranteed portable algorithm (128-bit hash; cryptographically broken but used for checksums/legacy); available on all CPython platforms; no prior hashlib spec anchors this as standalone; first standalone under algset118"
  category: membership
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true
