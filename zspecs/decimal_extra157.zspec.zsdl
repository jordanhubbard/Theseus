spec: decimal_extra157
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal __bool__, __abs__, __neg__, __pos__ method qualnames, and Decimal class identity."
    - "All Decimal method qualnames follow the 'Decimal.<method>' pattern. The 'Decimal.' prefix is 8 characters."
    - "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' (len=16; 'Decimal.' (8) + '__bool__' (8) = 16; the longest of the four dunders in this spec)."
    - "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (len=15; 'Decimal.' (8) + '__abs__' (7) = 15; tied with __neg__ and __pos__ at 15)."
    - "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (len=15; 'Decimal.' (8) + '__neg__' (7) = 15; tied with __abs__ and __pos__ at 15)."
    - "decimal.Decimal.__pos__.__qualname__ == 'Decimal.__pos__' (len=15; 'Decimal.' (8) + '__pos__' (7) = 15; tied with __abs__ and __neg__ at 15)."
    - "Three-way tie at 15: __abs__, __neg__, __pos__ — all have 7-character dunder names ('__xxx__' with 3-char operator name)."
    - "__bool__ stands alone at 16 — its core name 'bool' (4 chars) makes '__bool__' (8 chars) one longer than '__abs__'/'__neg__'/'__pos__' (each 7 chars)."
    - "decimal.Decimal.__class__.__name__ == 'type' (Decimal is a type/class, so its __class__ is type)."
    - "Length ranking: __abs__=__neg__=__pos__=15, __bool__=16."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal __abs__, __neg__, __pos__ method __qualname__ values
# All three tied at length 15: 'Decimal.' (8) + '__xxx__' (7) = 15.
# Core names: abs (3), neg (3), pos (3) — all 3-character operator abbreviations.
# These are the unary numeric operation dunders.
# ---------------------------------------------------------------------------

table decimal_extra157.Decimal_unary_op_qualnames:
  description: "decimal.Decimal unary op dunder __qualname__ values: __abs__=__neg__=__pos__='Decimal.__xxx__' (all len=15); three-way tie at 15; all use 'Decimal.' prefix (8 chars) with 7-char dunder names"
  kind: python_call_eq
  category: qualname
  id_prefix: decuq157

  columns: [id, function, args, expected, description]
  rows:
    - [abs_qeq,  "Decimal.__abs__.__qualname__.__eq__",  ["Decimal.__abs__"],  true, "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (Decimal.__abs__() implements the abs() built-in for Decimal objects; abs(Decimal('-3.14')) == Decimal('3.14'); __abs__ returns a new Decimal with the sign removed; 'Decimal.__abs__' has 15 characters: 'Decimal.' (8) + '__abs__' (7) = 15; part of the three-way tie at 15 with __neg__ and __pos__; '__abs__' (7 chars) uses the 3-character core name 'abs' sandwiched between double underscores; Decimal.__abs__() respects the current context and may signal InvalidOperation for special values)"]
    - [neg_qeq,  "Decimal.__neg__.__qualname__.__eq__",  ["Decimal.__neg__"],  true, "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (Decimal.__neg__() implements the unary negation operator (-x) for Decimal objects; -Decimal('3.14') == Decimal('-3.14'); __neg__ returns a new Decimal with the sign flipped; 'Decimal.__neg__' has 15 characters: 'Decimal.' (8) + '__neg__' (7) = 15; tied with __abs__ and __pos__ at 15; '__neg__' (7 chars) uses the 3-character abbreviation 'neg' for 'negate'; Decimal.__neg__() differs from multiplying by -1 when the sign of zero matters in the decimal context)"]
    - [pos_qeq,  "Decimal.__pos__.__qualname__.__eq__",  ["Decimal.__pos__"],  true, "decimal.Decimal.__pos__.__qualname__ == 'Decimal.__pos__' (Decimal.__pos__() implements the unary positive operator (+x) for Decimal objects; +Decimal('3.14') returns a new Decimal, not necessarily the same object; for Decimal, __pos__ may apply rounding according to the current context, unlike for int and float where +x == x always; 'Decimal.__pos__' has 15 characters: 'Decimal.' (8) + '__pos__' (7) = 15; tied with __abs__ and __neg__ at 15; '__pos__' uses the 3-character abbreviation 'pos' for 'positive'; completes the three-way tie with __abs__ and __neg__)"]
    - [abs_qlen, "Decimal.__abs__.__qualname__.__len__", [],                    15,   "decimal.Decimal.__abs__.__qualname__.__len__() == 15 ('Decimal.__abs__' has 15 characters: 'Decimal.' (8) + '__abs__' (7) = 15; part of the three-way tie at 15 with __neg__ and __pos__; the three-way tie at 15 mirrors the five-way tie at 15 for Decimal arithmetic dunders (__add__, __sub__, __mul__, __mod__, __pow__) from decimal_extra155 — all share the same qualname length of 15 because all use 7-char dunder names with the 'Decimal.' prefix; length 15 = 8-char prefix + 7-char dunder is a recurring pattern across Decimal method qualnames)"]

# ---------------------------------------------------------------------------
# decimal.Decimal __bool__ method __qualname__ and Decimal class identity
# __bool__ stands alone at length 16 (8-character dunder name).
# Decimal.__class__.__name__ == 'type' — Decimal is itself a type.
# ---------------------------------------------------------------------------

table decimal_extra157.Decimal_bool_and_class_identity:
  description: "decimal.Decimal __bool__ __qualname__ and class identity: __bool__='Decimal.__bool__' (len=16; stands alone); Decimal.__class__.__name__='type' (len=4; Decimal is a type)"
  kind: python_call_eq
  category: qualname
  id_prefix: decuq157

  columns: [id, function, args, expected, description]
  rows:
    - [bool_qeq,       "Decimal.__bool__.__qualname__.__eq__",       ["Decimal.__bool__"],  true, "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' (Decimal.__bool__() implements truth-value testing for Decimal objects; bool(Decimal('0')) is False; bool(Decimal('0.00')) is False; bool(Decimal('1')) is True; bool(Decimal('NaN')) is True (NaN is truthy for Decimal); 'Decimal.__bool__' has 16 characters: 'Decimal.' (8) + '__bool__' (8) = 16; __bool__ stands alone at 16 — its core name 'bool' (4 chars) is one longer than 'abs', 'neg', 'pos' (each 3 chars), making '__bool__' (8 chars) one longer than '__abs__', '__neg__', '__pos__' (each 7 chars))"]
    - [bool_qlen,      "Decimal.__bool__.__qualname__.__len__",      [],                    16,   "decimal.Decimal.__bool__.__qualname__.__len__() == 16 ('Decimal.__bool__' has 16 characters: 'Decimal.' (8) + '__bool__' (8) = 16; the longest Decimal dunder qualname in this spec; __bool__ stands alone at 16 while __abs__, __neg__, __pos__ are all tied at 15; the one-character difference comes from 'bool' (4 chars) vs 'abs'/'neg'/'pos' (each 3 chars); 'Decimal.__bool__' (16) matches 'Decimal.__hash__' (16) from decimal_extra154 and 'Context.__init__' (16) from decimal_extra156 — a recurring length-16 pattern for dunders with 4-character core names under the 'Decimal.' prefix)"]
    - [class_name_eq,  decimal.Decimal.__class__.__name__.__eq__,   ["type"],               true, "decimal.Decimal.__class__.__name__ == 'type' (Decimal is a class/type, and every class in Python has __class__ == type at the metaclass level; 'type' has 4 characters; this confirms that Decimal is an ordinary Python type (not a special metaclass or enum); Decimal.__class__ is the built-in 'type' metaclass, just like int.__class__.__name__ == 'type' and float.__class__.__name__ == 'type'; all regular Python classes created with 'class' keyword have __class__.__name__ == 'type' unless a custom metaclass is used)"]
    - [class_name_len, decimal.Decimal.__class__.__name__.__len__,  [],                     4,   "decimal.Decimal.__class__.__name__.__len__() == 4 ('type' has 4 characters; 'type' is the built-in metaclass name; all standard Python classes have __class__.__name__ == 'type'; 'type' (4 chars) is the shortest identifier in this spec; compare with 'Decimal' (7 chars) — the class name itself is nearly twice as long as the metaclass name; the metaclass 'type' (4 chars) is also the same length as 'bool' (4 chars), which is the core name of the __bool__ dunder; length 4 for 'type' is consistent across all standard Python class objects)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra157.Decimal_abs_neg_pos_three_way_tie_at_15:
  description: "decimal.Decimal.__abs__.__qualname__.__len__() == 15 — 'Decimal.__abs__' has 15 characters: 'Decimal.' (8) + '__abs__' (7) = 15; __abs__ is part of a three-way tie at 15 with __neg__ (also 15: 'Decimal.' (8) + '__neg__' (7) = 15) and __pos__ (also 15: 'Decimal.' (8) + '__pos__' (7) = 15); the three-way tie at 15 occurs because 'abs', 'neg', and 'pos' are all exactly 3-character operator abbreviations; this ties with the five-way tie at 15 for arithmetic dunders (__add__, __sub__, __mul__, __mod__, __pow__) from decimal_extra155; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__abs__.__qualname__.__len__"
  args: []
  expected: 15

invariant decimal_extra157.Decimal_bool_stands_alone_at_16:
  description: "decimal.Decimal.__bool__.__qualname__.__len__() == 16 — 'Decimal.__bool__' has 16 characters: 'Decimal.' (8) + '__bool__' (8) = 16; __bool__ stands alone at 16 while the three unary op dunders (__abs__, __neg__, __pos__) are tied at 15; the one-character separation arises because 'bool' (4 chars) is one longer than 'abs', 'neg', 'pos' (each 3 chars); 'Decimal.__bool__' (16) equals 'Decimal.__hash__' (16) and 'Context.__init__' (16) from earlier decimal specs — all have 4-character core dunder names under an 8-character prefix; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__bool__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra157.Decimal_class_is_type:
  description: "decimal.Decimal.__class__.__name__ == 'type' — Decimal's metaclass is 'type' (4 chars), the standard Python metaclass for all ordinary classes; Decimal is a C-accelerated type defined in '_decimal' but exposed through the 'decimal' module; despite being C-implemented, Decimal.__class__ is still 'type' because it is a regular type object at the Python level; this contrasts with enum classes (e.g., re.RegexFlag) whose metaclass is 'EnumType' or similar, not plain 'type'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra157.Decimal_neg_qualname_eq:
  description: "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' — __neg__ implements the unary minus operator for Decimal; its qualname uses the public class name 'Decimal' (7 chars) + '.' (1) + '__neg__' (7) = 15 characters total; 'Decimal.__neg__' (15) equals 'Decimal.__abs__' (15) and 'Decimal.__pos__' (15) — the three-way tie among unary numeric operation dunders; all three share the same qualname length because 'abs', 'neg', and 'pos' are all 3-character abbreviations; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__neg__.__qualname__.__eq__"
  args: ["Decimal.__neg__"]
  expected: true

