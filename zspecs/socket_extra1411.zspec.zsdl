spec: socket_extra1411
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ and __reduce_ex__ method type checks for socket.socket, socket.error, and socket.timeout."
    - "socket.socket.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited; '__sizeof__' is NOT in socket.socket.__dict__."
    - "socket.socket.__reduce_ex__.__class__.__name__ == 'method_descriptor' — inherited; '__reduce_ex__' is NOT in socket.socket.__dict__."
    - "socket.error is an alias for OSError; socket.timeout is a subclass of OSError. Both inherit __sizeof__ and __reduce_ex__ as method_descriptors and neither stores them in its own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1411.socket_sizeof_type_checks:
  description: "socket.socket, socket.error, and socket.timeout __sizeof__ method type and dict-presence checks — all three inherit __sizeof__ as a method_descriptor and none stores it in its own __dict__"
  kind: python_call_eq
  category: sizeof_checks
  id_prefix: sk1411sw
  columns: [id, function, args, expected]
  rows:
    - [sk1411sw001, socket.socket.__sizeof__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [sk1411sw002, socket.error.__sizeof__.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [sk1411sw003, socket.timeout.__sizeof__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [sk1411sw004, socket.socket.__dict__.__contains__,                   ["__sizeof__"],        false]
    - [sk1411sw005, socket.error.__dict__.__contains__,                    ["__sizeof__"],        false]
    - [sk1411sw006, socket.timeout.__dict__.__contains__,                  ["__sizeof__"],        false]

table socket_extra1411.socket_reduce_ex_type_checks:
  description: "socket.socket, socket.error, and socket.timeout __reduce_ex__ method type and dict-presence checks — all three inherit __reduce_ex__ as a method_descriptor and none stores it in its own __dict__"
  kind: python_call_eq
  category: reduce_ex_checks
  id_prefix: sk1411rx
  columns: [id, function, args, expected]
  rows:
    - [sk1411rx001, socket.socket.__reduce_ex__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [sk1411rx002, socket.error.__reduce_ex__.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [sk1411rx003, socket.timeout.__reduce_ex__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [sk1411rx004, socket.socket.__dict__.__contains__,                      ["__reduce_ex__"],     false]
    - [sk1411rx005, socket.error.__dict__.__contains__,                       ["__reduce_ex__"],     false]
    - [sk1411rx006, socket.timeout.__dict__.__contains__,                     ["__reduce_ex__"],     false]

table socket_extra1411.socket_class_identity_checks:
  description: "socket.socket, socket.error, and socket.timeout class identity checks — socket is a Python class, error is OSError alias, timeout is OSError subclass; all have metaclass type"
  kind: python_call_eq
  category: class_identity_checks
  id_prefix: sk1411ci
  columns: [id, function, args, expected]
  rows:
    - [sk1411ci001, socket.socket.__name__.__eq__,               ["socket"],   true]
    - [sk1411ci002, socket.error.__name__.__eq__,                ["OSError"],  true]
    - [sk1411ci003, socket.timeout.__name__.__eq__,              ["timeout"],  true]
    - [sk1411ci004, socket.socket.__class__.__name__.__eq__,     ["type"],     true]
    - [sk1411ci005, socket.error.__class__.__name__.__eq__,      ["type"],     true]
    - [sk1411ci006, socket.timeout.__class__.__name__.__eq__,    ["type"],     true]
