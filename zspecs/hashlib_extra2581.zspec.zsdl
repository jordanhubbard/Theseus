spec: hashlib_extra2581
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
  notes:
    - "Wave 2581 theme: __call__ dict-presence — checking whether _hashlib.HASH defines __call__ in its class __dict__ (making hash objects callable functors)."
    - "_hashlib.HASH is the C-extension type returned by hashlib.md5(), hashlib.sha256(), etc."
    - "_hashlib.HASH.__dict__.__contains__('__call__') == False — hash objects are not callable functors; they expose a fixed API (update/digest/hexdigest/copy) but cannot be invoked with ()."
    - "Attempting to call a hash instance raises TypeError: '_hashlib.HASH' object is not callable. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "_hashlib.HASH.__dict__.__contains__('update') == True — update() is the core method for feeding data."
    - "_hashlib.HASH.__dict__.__contains__('digest') == True — digest() returns the binary hash value."
    - "_hashlib.HASH.__dict__.__contains__('hexdigest') == True — hexdigest() returns the hex-encoded hash value."
    - "_hashlib.HASH.__dict__.__contains__('copy') == True — copy() snapshots the current hash state."
    - "_hashlib.HASH.__dict__.__contains__('name') == True — name is a descriptor exposing the algorithm name."
    - "_hashlib.HASH.__dict__.__contains__('digest_size') == True — digest_size is a descriptor exposing the output size in bytes."
    - "_hashlib.HASH.__dict__.__contains__('block_size') == True — block_size is a descriptor exposing the internal block size."
    - "_hashlib.HASH.__dict__.__contains__('__repr__') == True — the type defines its own __repr__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ absence — _hashlib.HASH is not a callable functor
#
# _hashlib.HASH does not define __call__ in its class __dict__.
# Hash objects are stateful accumulators, not functors.
# Contrasted with methods that ARE present in __dict__.
# ---------------------------------------------------------------------------

table hashlib_extra2581.call_absent:
  description: "__call__ is absent from _hashlib.HASH.__dict__ — hash objects are not callable functors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2581

  columns: [id, function, args, expected]
  rows:
    - ["hl2581001", "md5().__class__.__dict__.__contains__",    ["__call__"],  false]
    - ["hl2581002", "sha256().__class__.__dict__.__contains__", ["__call__"],  false]
    - ["hl2581003", "sha1().__class__.__dict__.__contains__",   ["__call__"],  false]

# ---------------------------------------------------------------------------
# Core API presence — methods that ARE in _hashlib.HASH.__dict__
#
# These True entries contrast with the __call__ absence above, confirming
# that the __dict__ lookup mechanism is working and the class has a real API.
# ---------------------------------------------------------------------------

table hashlib_extra2581.core_api_present:
  description: "Core hash API methods are present in _hashlib.HASH.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2581

  columns: [id, function, args, expected]
  rows:
    - ["hl2581004", "md5().__class__.__dict__.__contains__", ["update"],      true]
    - ["hl2581005", "md5().__class__.__dict__.__contains__", ["digest"],      true]
    - ["hl2581006", "md5().__class__.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl2581007", "md5().__class__.__dict__.__contains__", ["copy"],        true]
    - ["hl2581008", "md5().__class__.__dict__.__contains__", ["name"],        true]
    - ["hl2581009", "md5().__class__.__dict__.__contains__", ["digest_size"], true]
    - ["hl2581010", "md5().__class__.__dict__.__contains__", ["block_size"],  true]

# ---------------------------------------------------------------------------
# Representation and documentation dunders
#
# _hashlib.HASH defines __repr__ and __doc__ in its own __dict__.
# These are among the few dunder attributes the C extension type owns.
# ---------------------------------------------------------------------------

table hashlib_extra2581.repr_doc_present:
  description: "__repr__ and __doc__ are present in _hashlib.HASH.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2581

  columns: [id, function, args, expected]
  rows:
    - ["hl2581011", "md5().__class__.__dict__.__contains__", ["__repr__"], true]
    - ["hl2581012", "md5().__class__.__dict__.__contains__", ["__doc__"],  true]

# ---------------------------------------------------------------------------
# Cross-check via sha256 — same HASH type, __call__ still absent
#
# hashlib.sha256() returns the same _hashlib.HASH C-extension type as md5().
# The __call__ absence is a property of the class, not the algorithm.
# The core API is also uniformly present across algorithms.
# ---------------------------------------------------------------------------

table hashlib_extra2581.sha256_cross_check:
  description: "__call__ absent and core API present via sha256() — same _hashlib.HASH type"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2581

  columns: [id, function, args, expected]
  rows:
    - ["hl2581013", "sha256().__class__.__dict__.__contains__", ["__call__"],  false]
    - ["hl2581014", "sha256().__class__.__dict__.__contains__", ["update"],    true]
    - ["hl2581015", "sha256().__class__.__dict__.__contains__", ["hexdigest"], true]
    - ["hl2581016", "sha256().__class__.__dict__.__contains__", ["digest"],    true]
    - ["hl2581017", "sha256().__class__.__dict__.__contains__", ["copy"],      true]
