spec: json_extra_rust
version: ">=3.9"
backend: rust_module(json_extra_rust)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json documentation"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
  notes:
    - "Additional json test vectors covering nested structures and edge cases."
    - "loads('{\"a\": [1, 2, 3]}') == {'a': [1, 2, 3]} — nested list value."
    - "loads('[{\"key\": \"val\"}]') == [{'key': 'val'}] — list of dicts."
    - "loads('{\"x\": null, \"y\": true}') == {'x': None, 'y': True} — special values."
    - "loads('{\"n\": 1000000}') == {'n': 1000000} — large integer."
    - "loads('{}') == {} — empty object."
    - "loads('[]') == [] — empty array."
    - "All test vectors verified against Python 3.14.3 json module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# loads — complex nested structures
table json_extra_rust.loads.nested:
  kind: python_call_eq
  category: loads_nested
  id_prefix: jex_loads
  function: loads

  columns: [id, args, expected]
  rows:
    - [nested_list,   ["{\"a\": [1, 2, 3]}"],              {a: [1, 2, 3]}]
    - [null_val,      ["{\"x\": null}"],                    {x: null}]
    - [bool_val,      ["{\"y\": true, \"z\": false}"],      {y: true, z: false}]
    - [large_int,     ["{\"n\": 1000000}"],                 {n: 1000000}]
    - [empty_obj,     ["{}"],                               {}]
    - [empty_arr,     ["[]"],                               []]
    - [nested_dict,   ["{\"a\": {\"b\": 42}}"],             {a: {b: 42}}]

# dumps — additional serialization cases
table json_extra_rust.dumps.additional:
  kind: python_call_eq
  category: dumps_extra
  id_prefix: jex_dumps
  function: dumps

  columns: [id, args, expected]
  rows:
    - [nested_list, [{a: [1, 2, 3]}],   "{\"a\": [1, 2, 3]}"]
    - [empty_dict,  [{}],               "{}"]
    - [float_val,   [3.14],             "3.14"]
    - [neg_int,     [-42],              "-42"]

