  columns: [id, function, args, expected]
  rows:
    - ["uu2176009", "uuid.SafeUUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu2176010", "uuid.SafeUUID.__dict__.__contains__", ["__next__"], false]
    - ["uu2176011", "uuid.SafeUUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu2176012", "uuid.SafeUUID.__dict__.__contains__", ["__anext__"], false]
    - ["uu2176013", "uuid.SafeUUID.__dict__.__contains__", ["__await__"], false]
    - ["uu2176014", "uuid.SafeUUID.__dict__.__contains__", ["__length_hint__"], false]
    - ["uu2176015", "uuid.SafeUUID.__dict__.__contains__", ["__reversed__"], false]
    - ["uu2176016", "uuid.SafeUUID.__dict__.__contains__", ["__missing__"], false]

