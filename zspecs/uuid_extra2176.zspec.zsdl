spec: uuid_extra2176
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/uuid.html"
    - "CPython source: Lib/uuid.py"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2176: iterator/sequence protocol dict-presence — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "uuid.UUID is a pure Python class with __slots__. It is not an iterator, awaitable, or mapping."
    - "uuid.SafeUUID is an IntEnum subclass. It is not an iterator, awaitable, or mapping."
    - "Neither UUID nor SafeUUID defines any of the 8 iterator/sequence protocol dunders in its own __dict__."
    - "uuid.UUID.__dict__ contains property objects (bytes, hex, urn, version, fields, etc.) and member_descriptor objects (int, is_safe)."
    - "uuid.SafeUUID.__dict__ contains enum bookkeeping keys and member values (safe, unsafe, unknown)."
    - "All expected values (false) verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2176.uuid_iterator_protocol:
  description: "uuid.UUID iterator/sequence protocol dict-presence — UUID is a pure Python value type, not an iterator or awaitable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2176

  columns: [id, function, args, expected]
  rows:
    - ["uu2176001", "uuid.UUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu2176002", "uuid.UUID.__dict__.__contains__", ["__next__"], false]
    - ["uu2176003", "uuid.UUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu2176004", "uuid.UUID.__dict__.__contains__", ["__anext__"], false]
    - ["uu2176005", "uuid.UUID.__dict__.__contains__", ["__await__"], false]
    - ["uu2176006", "uuid.UUID.__dict__.__contains__", ["__length_hint__"], false]
    - ["uu2176007", "uuid.UUID.__dict__.__contains__", ["__reversed__"], false]
    - ["uu2176008", "uuid.UUID.__dict__.__contains__", ["__missing__"], false]

table uuid_extra2176.safeuuid_iterator_protocol:
  description: "uuid.SafeUUID iterator/sequence protocol dict-presence — SafeUUID is an IntEnum subclass, not an iterator or awaitable"
