spec: struct_extra1216
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module Struct class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/size/format/__sizeof__ keys; struct.Struct.__dict__ class identity; and struct.Struct.__mro__.__len__ count"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1216.struct_dict_contains_methods:
  description: "struct.Struct.__dict__.__contains__ checks for core method keys"
  kind: python_call_eq
  category: struct_dict_contains_methods
  id_prefix: st1216dm
  columns: [id, function, args, expected]
  rows:
    - [st1216dm001, struct.Struct.__dict__.__contains__,                  ["pack"],         true]
    - [st1216dm002, struct.Struct.__dict__.__contains__,                  ["unpack"],       true]
    - [st1216dm003, struct.Struct.__dict__.__contains__,                  ["pack_into"],    true]
    - [st1216dm004, struct.Struct.__dict__.__contains__,                  ["unpack_from"],  true]
    - [st1216dm005, struct.Struct.__dict__.__contains__,                  ["iter_unpack"],  true]
    - [st1216dm006, struct.Struct.__dict__.__contains__,                  ["__sizeof__"],   true]
    - [st1216dm007, struct.Struct.__dict__.__contains__,                  ["__repr__"],     true]
    - [st1216dm008, struct.Struct.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]
    - [st1216dm009, struct.Struct.__dict__.__class__.__qualname__.__eq__, ["mappingproxy"], true]

table struct_extra1216.struct_dict_contains_attrs:
  description: "struct.Struct.__dict__.__contains__ checks for size and format descriptor keys"
  kind: python_call_eq
  category: struct_dict_contains_attrs
  id_prefix: st1216da
  columns: [id, function, args, expected]
  rows:
    - [st1216da001, struct.Struct.__dict__.__contains__,                  ["size"],         true]
    - [st1216da002, struct.Struct.__dict__.__contains__,                  ["format"],       true]
    - [st1216da003, struct.Struct.__dict__.__class__.__module__.__eq__,   ["builtins"],     true]
    - [st1216da004, struct.Struct.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st1216da005, struct.Struct.__dict__.__class__.__module__.__class__.__name__.__eq__, ["str"], true]
    - [st1216da006, struct.Struct.__name__.__eq__,                        ["Struct"],       true]
    - [st1216da007, struct.Struct.__module__.__eq__,                      ["_struct"],      true]
    - [st1216da008, struct.Struct.__name__.__class__.__name__.__eq__,     ["str"],          true]
    - [st1216da009, struct.Struct.__module__.__class__.__name__.__eq__,   ["str"],          true]

table struct_extra1216.struct_mro_len:
  description: "struct.Struct.__mro__.__len__ and __mro__ class identity"
  kind: python_call_eq
  category: struct_mro_len
  id_prefix: st1216ml
  columns: [id, function, args, expected]
  rows:
    - [st1216ml001, struct.Struct.__mro__.__len__,                        [],              2]
    - [st1216ml002, struct.Struct.__mro__.__class__.__name__.__eq__,      ["tuple"],       true]
    - [st1216ml003, struct.Struct.__mro__.__class__.__qualname__.__eq__,  ["tuple"],       true]
    - [st1216ml004, struct.Struct.__mro__.__class__.__module__.__eq__,    ["builtins"],    true]
    - [st1216ml005, struct.Struct.__mro__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st1216ml006, struct.error.__mro__.__len__,                         [],              5]
    - [st1216ml007, struct.error.__mro__.__class__.__name__.__eq__,       ["tuple"],       true]
