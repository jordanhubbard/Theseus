spec: date_fns
version: ">=4.0.0"
backend: node(date-fns)

docs: https://date-fns.org

provenance:
  derived_from:
    - "date-fns docs — https://date-fns.org"
    - "Test vectors verified with date-fns via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "date-fns source"
  notes:
    - "Modular date utility — every function is a separate import; functional, immutable, tree-shakeable."
    - "Install: npm install date-fns"
    - "v4 ESM only."
    - "Test vectors use ISO strings with explicit Z suffix to avoid timezone-dependent results."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on valid Date/string inputs; isValid returns false for malformed inputs."
  stderr: "null"
  stickiness: "N/A — every function is pure."
  codes: {}

invariant date_fns.parseISO_round_trip_utc:
  description: "parseISO('2024-01-15T00:00:00Z').getTime() is 1705276800000 (UTC epoch ms)"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parseISO
  entry_args: ["2024-01-15T00:00:00Z"]
  chain:
    - {method: getTime, args: []}
  expected: 1705276800000

invariant date_fns.parseISO_unix_epoch:
  description: "parseISO('1970-01-01T00:00:00Z').getTime() is 0"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parseISO
  entry_args: ["1970-01-01T00:00:00Z"]
  chain:
    - {method: getTime, args: []}
  expected: 0

invariant date_fns.parseISO_returns_date_instance:
  description: "parseISO returns a Date instance (constructor.name === 'Date')"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parseISO
  entry_args: ["2024-01-15T00:00:00Z"]
  chain:
    - {get: "constructor.name"}
  expected: "Date"

invariant date_fns.differenceInDays_january:
  description: "differenceInDays('2024-02-15', '2024-01-15') is 31"
  category: arithmetic
  kind: node_chain_eq
  entry: named
  function: differenceInDays
  entry_args: ["2024-02-15T00:00:00Z", "2024-01-15T00:00:00Z"]
  chain: []
  expected: 31

invariant date_fns.differenceInDays_full_year:
  description: "Difference across a non-leap year is 366 days from Jan 1 → Jan 1 of leap year"
  category: arithmetic
  kind: node_chain_eq
  entry: named
  function: differenceInDays
  entry_args: ["2025-01-01T00:00:00Z", "2024-01-01T00:00:00Z"]
  chain: []
  expected: 366

invariant date_fns.addDays_month_boundary:
  description: "addDays('2024-01-01', 30).getTime() crosses to '2024-01-31'"
  category: arithmetic
  kind: node_chain_eq
  entry: named
  function: addDays
  entry_args: ["2024-01-01T00:00:00Z", 30]
  chain:
    - {method: getTime, args: []}
  expected: 1706659200000

invariant date_fns.addHours_simple:
  description: "addHours(epoch, 1).getTime() is 3600000"
  category: arithmetic
  kind: node_chain_eq
  entry: named
  function: addHours
  entry_args: ["1970-01-01T00:00:00Z", 1]
  chain:
    - {method: getTime, args: []}
  expected: 3600000

invariant date_fns.addMinutes_simple:
  description: "addMinutes(epoch, 5).getTime() is 300000"
  category: arithmetic
  kind: node_chain_eq
  entry: named
  function: addMinutes
  entry_args: ["1970-01-01T00:00:00Z", 5]
  chain:
    - {method: getTime, args: []}
  expected: 300000

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T16:57:43Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
