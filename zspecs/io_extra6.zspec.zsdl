spec: io_extra6
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Extends io.zspec.zsdl, io_extra.zspec.zsdl, io_extra2.zspec.zsdl, io_extra3.zspec.zsdl, io_extra4.zspec.zsdl, io_extra5.zspec.zsdl."
    - "io_extra4.zspec.zsdl covers __module__ for: IOBase=='_io', RawIOBase=='_io', BufferedIOBase=='_io', TextIOBase=='_io', StringIO=='_io', BytesIO=='_io', FileIO=='_io', BufferedReader=='_io', BufferedWriter=='_io'."
    - "CORRECTION: On Python 3.12+ macOS, actual __module__ values are: BytesIO.__module__=='_io', StringIO.__module__=='_io', BufferedReader.__module__=='_io', BufferedWriter.__module__=='_io', RawIOBase.__module__=='io', IOBase.__module__=='io'. Verified 2026-04-09."
    - "io_extra3.zspec.zsdl covers: BytesIO.__bases__[0].__name__=='_BufferedIOBase', StringIO.__bases__[0].__name__=='_TextIOBase', FileIO.__bases__[0].__name__=='_RawIOBase'."
    - "This spec provides standalone named invariants for module/base checks under the io_extra6 namespace, and adds TextIOWrapper/BufferedReader/BufferedWriter base class checks."
    - "io.BytesIO.__module__ == '_io' — implemented in the _io C extension (public io re-exports it)."
    - "io.StringIO.__module__ == '_io' — implemented in the _io C extension."
    - "io.TextIOWrapper.__module__ == '_io' — implemented in the _io C extension."
    - "io.BufferedReader.__module__ == '_io' — implemented in the _io C extension."
    - "io.BufferedWriter.__module__ == '_io' — implemented in the _io C extension."
    - "io.RawIOBase.__module__ == 'io' — re-exported via the public io module."
    - "io.IOBase.__module__ == 'io' — re-exported via the public io module."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — C-level private base class."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — C-level private base class."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — C-level private base class."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — C-level private base class."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — C-level private base class."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — C-level private base class."
    - "io.open.__name__ == 'open' — io.open is the built-in open function."
    - "io.open.__module__ == '_io' — open is implemented in the _io C extension."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — standalone named invariants
#
# io_extra4.zspec.zsdl already covers many of these; this spec provides
# additional named invariants under the io_extra6 namespace with verified values.
# ---------------------------------------------------------------------------

invariant io_extra6.BytesIO.module:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the _io C extension"
  category: module
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra6.StringIO.module:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the _io C extension"
  category: module
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra6.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is implemented in the _io C extension"
  category: module
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra6.BufferedReader.module:
  description: "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in the _io C extension"
  category: module
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra6.BufferedWriter.module:
  description: "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in the _io C extension"
  category: module
  kind: python_call_eq
  function: BufferedWriter.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra6.RawIOBase.module:
  description: "io.RawIOBase.__module__ == 'io' — RawIOBase is re-exported via the public io module"
  category: module
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra6.IOBase.module:
  description: "io.IOBase.__module__ == 'io' — IOBase is re-exported via the public io module"
  category: module
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

# ---------------------------------------------------------------------------
# Base class checks
#
# The io class hierarchy uses private C-level base classes (_BufferedIOBase,
# _TextIOBase, _RawIOBase) as the direct bases. These names are implementation
# details but stable across CPython releases.
# io_extra3.zspec.zsdl covers BytesIO, StringIO, FileIO.
# This spec adds: BufferedReader, BufferedWriter, TextIOWrapper.
# ---------------------------------------------------------------------------

invariant io_extra6.BytesIO.base:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO extends C-level _BufferedIOBase"
  category: hierarchy
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_BufferedIOBase"

invariant io_extra6.StringIO.base:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO extends C-level _TextIOBase"
  category: hierarchy
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_TextIOBase"

invariant io_extra6.FileIO.base:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO extends C-level _RawIOBase"
  category: hierarchy
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_RawIOBase"

invariant io_extra6.BufferedReader.base:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader extends C-level _BufferedIOBase"
  category: hierarchy
  kind: python_call_eq
  function: BufferedReader.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_BufferedIOBase"

invariant io_extra6.BufferedWriter.base:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter extends C-level _BufferedIOBase"
  category: hierarchy
  kind: python_call_eq
  function: BufferedWriter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_BufferedIOBase"

invariant io_extra6.TextIOWrapper.base:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper extends C-level _TextIOBase"
  category: hierarchy
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_TextIOBase"

# ---------------------------------------------------------------------------
# io.open — function name and module
#
# io.open is the same object as the built-in open function.
# io_extra3.zspec.zsdl covers io.open.__name__ == 'open'; this spec adds
# a standalone named invariant under io_extra6 and checks __module__.
# ---------------------------------------------------------------------------

invariant io_extra6.open.name:
  description: "io.open.__name__ == 'open' — io.open is the built-in open function"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra6.open.module:
  description: "io.open.__module__ == '_io' — open is implemented in the _io C extension"
  category: functions
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true
