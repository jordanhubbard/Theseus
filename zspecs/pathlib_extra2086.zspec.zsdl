table pathlib_extra2086.bytes_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl2086005", "pathlib.PurePath.__dict__.__contains__", ["__bytes__"], true]
    - ["pl2086006", "pathlib.PurePosixPath.__dict__.__contains__", ["__bytes__"], false]
    - ["pl2086007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__bytes__"], false]
    - ["pl2086008", "pathlib.Path.__dict__.__contains__", ["__bytes__"], false]

