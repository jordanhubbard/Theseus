table pathlib_extra2086.buffer_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl2086013", "pathlib.PurePath.__dict__.__contains__", ["__buffer__"], false]
    - ["pl2086014", "pathlib.PurePath.__dict__.__contains__", ["__release_buffer__"], false]
    - ["pl2086015", "pathlib.PurePosixPath.__dict__.__contains__", ["__buffer__"], false]
    - ["pl2086016", "pathlib.PurePosixPath.__dict__.__contains__", ["__release_buffer__"], false]
    - ["pl2086017", "pathlib.PureWindowsPath.__dict__.__contains__", ["__buffer__"], false]
    - ["pl2086018", "pathlib.PureWindowsPath.__dict__.__contains__", ["__release_buffer__"], false]
    - ["pl2086019", "pathlib.Path.__dict__.__contains__", ["__buffer__"], false]
