    - ["pl2086010", "pathlib.PurePosixPath.__dict__.__contains__", ["__fspath__"], false]
    - ["pl2086011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__fspath__"], false]
    - ["pl2086012", "pathlib.Path.__dict__.__contains__", ["__fspath__"], false]

