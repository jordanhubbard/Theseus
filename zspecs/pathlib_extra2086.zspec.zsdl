spec: pathlib_extra2086
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "pathlib.PurePath defines __bytes__ and __fspath__ directly in its __dict__ — both return True."
    - "pathlib.Path, PurePosixPath, PureWindowsPath do NOT define __bytes__ or __fspath__ in their own __dict__ — they inherit from PurePath."
    - "None of the pathlib classes define __format__, __buffer__, or __release_buffer__ in their own __dict__."
    - "__fspath__ on PurePath raises TypeError at runtime (pure paths are not concrete); nonetheless the method IS present in PurePath.__dict__."
    - "All expected values verified by running Python 3.12 pathlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table pathlib_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl2086001", "pathlib.PurePath.__dict__.__contains__", ["__format__"], false]
    - ["pl2086002", "pathlib.PurePosixPath.__dict__.__contains__", ["__format__"], false]
    - ["pl2086003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__format__"], false]
    - ["pl2086004", "pathlib.Path.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# __bytes__ bytes conversion protocol dict-presence
