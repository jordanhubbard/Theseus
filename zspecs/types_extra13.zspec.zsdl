spec: types_extra13
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType"
    - "types_extra12.zspec.zsdl — covers MRO[0] self-identity for MethodType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/TracebackType/FrameType/NoneType; __name__.__len__ for AsyncGeneratorType/TracebackType/FrameType/BuiltinFunctionType"
    - "types_extra11.zspec.zsdl — covers __name__.__len__ for FunctionType/MethodType/ModuleType/GeneratorType/CoroutineType/SimpleNamespace/MappingProxyType; MRO[0] for FunctionType/ModuleType/SimpleNamespace"
  notes:
    - "This spec covers __mro__.__len__, __bases__.__len__, and __name__.__len__ for GeneratorType, CoroutineType, NoneType, and UnionType — all newly verified."
    - "NOT yet covered: types.GeneratorType.__mro__.__len__() == 2."
    - "NOT yet covered: types.CoroutineType.__mro__.__len__() == 2."
    - "NOT yet covered: types.NoneType.__mro__.__len__() == 2."
    - "NOT yet covered: types.UnionType.__mro__.__len__() == 2."
    - "NOT yet covered: types.GeneratorType.__bases__.__len__() == 1."
    - "NOT yet covered: types.CoroutineType.__bases__.__len__() == 1."
    - "NOT yet covered: types.NoneType.__bases__.__len__() == 1."
    - "NOT yet covered: types.UnionType.__bases__.__len__() == 1."
    - "NOT yet covered: types.GeneratorType.__name__.__len__() == 9."
    - "NOT yet covered: types.CoroutineType.__name__.__len__() == 9."
    - "NOT yet covered: types.NoneType.__name__.__len__() == 8."
    - "NOT yet covered: types.UnionType.__name__.__len__() == 5 (UnionType.__name__ is 'Union')."
    - "types.GeneratorType.__mro__.__len__() == 2."
    - "types.CoroutineType.__mro__.__len__() == 2."
    - "types.NoneType.__mro__.__len__() == 2."
    - "types.UnionType.__mro__.__len__() == 2."
    - "types.GeneratorType.__bases__.__len__() == 1."
    - "types.CoroutineType.__bases__.__len__() == 1."
    - "types.NoneType.__bases__.__len__() == 1."
    - "types.UnionType.__bases__.__len__() == 1."
    - "types.GeneratorType.__name__.__len__() == 9 ('generator' is 9 characters)."
    - "types.CoroutineType.__name__.__len__() == 9 ('coroutine' is 9 characters)."
    - "types.NoneType.__name__.__len__() == 8 ('NoneType' is 8 characters)."
    - "types.UnionType.__name__.__len__() == 5 ('Union' is 5 characters)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for GeneratorType, CoroutineType, NoneType, UnionType
#
# types_extra12 covers MRO[0] self-identity for these types. No prior spec
# checks __mro__.__len__(). All four are simple types with exactly two MRO
# entries: [the class itself, object].
# ---------------------------------------------------------------------------

table types_extra13.mro_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mrolen

  columns: [id, function, args, expected]
  rows:
    - [GeneratorType, GeneratorType.__mro__.__len__, [], 2]
    - [CoroutineType, CoroutineType.__mro__.__len__, [], 2]
    - [NoneType,      NoneType.__mro__.__len__,      [], 2]
    - [UnionType,     UnionType.__mro__.__len__,      [], 2]

# ---------------------------------------------------------------------------
# __bases__.__len__() for GeneratorType, CoroutineType, NoneType, UnionType
#
# No prior spec checks __bases__.__len__() for any of these four types.
# Each has exactly one direct base (object).
# ---------------------------------------------------------------------------

table types_extra13.bases_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: baseslen

  columns: [id, function, args, expected]
  rows:
    - [GeneratorType, GeneratorType.__bases__.__len__, [], 1]
    - [CoroutineType, CoroutineType.__bases__.__len__, [], 1]
    - [NoneType,      NoneType.__bases__.__len__,      [], 1]
    - [UnionType,     UnionType.__bases__.__len__,     [], 1]

# ---------------------------------------------------------------------------
# __name__.__len__() for GeneratorType, CoroutineType, NoneType, UnionType
#
# types_extra11/12 cover __name__.__len__ for FunctionType/MethodType/
# ModuleType/GeneratorType/CoroutineType/SimpleNamespace/MappingProxyType/
# AsyncGeneratorType/TracebackType/FrameType/BuiltinFunctionType.
# No prior spec checks __name__.__len__() for NoneType or UnionType.
# GeneratorType and CoroutineType name lengths are also uncovered.
# ---------------------------------------------------------------------------

table types_extra13.name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [GeneratorType, GeneratorType.__name__.__len__, [], 9]
    - [CoroutineType, CoroutineType.__name__.__len__, [], 9]
    - [NoneType,      NoneType.__name__.__len__,      [], 8]
    - [UnionType,     UnionType.__name__.__len__,     [], 5]
