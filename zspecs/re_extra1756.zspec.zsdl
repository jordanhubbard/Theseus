spec: re_extra1756
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "re.Pattern: C-extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "re.Match: C-extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "re.error (PatternError): exception subclass — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "re.RegexFlag: IntFlag-based enum; inherits bitwise operators from int and IntFlag but does NOT define arithmetic dunders __add__, __sub__, __mul__, __truediv__, __floordiv__, __pow__, __neg__, __pos__ in its own __dict__."
    - "re.RegexFlag.__dict__.__contains__('__or__') — RegexFlag may define __or__ (bitwise OR, used for combining flags); however __or__ is NOT one of the eight arithmetic operators in this wave's theme."
    - "re.RegexFlag.__dict__.__contains__('__and__') — bitwise AND for flag intersection; also NOT in the arithmetic theme."
    - "re.RegexFlag.__dict__.__contains__('__xor__') — bitwise XOR for flag difference; also NOT in the arithmetic theme."
    - "re.RegexFlag.__dict__.__contains__('__invert__') — bitwise NOT for flag complement; also NOT in the arithmetic theme."
    - "Complementary checks confirm re.RegexFlag bitwise operators are in __dict__ (inherited/defined by IntFlag), while arithmetic dunders are absent."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence for re.Pattern and re.Match
#
# Wave 564 theme: which re types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# re.Pattern: the compiled regular expression type — purely for pattern
#   matching, not numeric. No arithmetic dunders defined.
# re.Match: the match result type — provides group(), span(), etc.
#   Not numeric, no arithmetic dunders.
# re.error (PatternError): an exception type — inherits from Exception.
#   No arithmetic operators.
# ---------------------------------------------------------------------------

table re_extra1756.arithmetic_operators_pattern_match:
  description: "re.Pattern, re.Match, re.error arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1756

  columns: [id, function, args, expected]
  rows:
    - ["re1756001", "re.Pattern.__dict__.__contains__", ["__add__"], false]
    - ["re1756002", "re.Pattern.__dict__.__contains__", ["__sub__"], false]
    - ["re1756003", "re.Pattern.__dict__.__contains__", ["__mul__"], false]
    - ["re1756004", "re.Pattern.__dict__.__contains__", ["__truediv__"], false]
    - ["re1756005", "re.Pattern.__dict__.__contains__", ["__floordiv__"], false]
    - ["re1756006", "re.Pattern.__dict__.__contains__", ["__pow__"], false]
    - ["re1756007", "re.Pattern.__dict__.__contains__", ["__neg__"], false]
    - ["re1756008", "re.Pattern.__dict__.__contains__", ["__pos__"], false]
    - ["re1756009", "re.Match.__dict__.__contains__", ["__add__"], false]
    - ["re1756010", "re.Match.__dict__.__contains__", ["__sub__"], false]
    - ["re1756011", "re.Match.__dict__.__contains__", ["__mul__"], false]
    - ["re1756012", "re.Match.__dict__.__contains__", ["__neg__"], false]
    - ["re1756013", "re.error.__dict__.__contains__", ["__add__"], false]
    - ["re1756014", "re.error.__dict__.__contains__", ["__mul__"], false]
    - ["re1756015", "re.error.__dict__.__contains__", ["__truediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: re.RegexFlag arithmetic vs bitwise operator dict-presence
#
# re.RegexFlag is an IntFlag-based enum. It inherits or defines bitwise
# operators (__or__, __and__, __xor__, __invert__) for combining flags,
# but it does NOT define arithmetic dunders in its own __dict__.
#
# The bitwise operators (__or__, __and__, __xor__, __invert__) are
# NOT part of the arithmetic operator theme for this wave — they are
# included here as complementary checks to distinguish the two families.
# ---------------------------------------------------------------------------

table re_extra1756.RegexFlag_operators:
  description: "re.RegexFlag operator dict-presence: arithmetic dunders absent (False), bitwise operators present (True) — IntFlag defines bitwise but not arithmetic operators — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1756

  columns: [id, function, args, expected]
  rows:
    - ["re1756016", "re.RegexFlag.__dict__.__contains__", ["__add__"], false]
    - ["re1756017", "re.RegexFlag.__dict__.__contains__", ["__sub__"], false]
    - ["re1756018", "re.RegexFlag.__dict__.__contains__", ["__mul__"], false]
    - ["re1756019", "re.RegexFlag.__dict__.__contains__", ["__truediv__"], false]
    - ["re1756020", "re.RegexFlag.__dict__.__contains__", ["__floordiv__"], false]
    - ["re1756021", "re.RegexFlag.__dict__.__contains__", ["__pow__"], false]
    - ["re1756022", "re.RegexFlag.__dict__.__contains__", ["__neg__"], false]
    - ["re1756023", "re.RegexFlag.__dict__.__contains__", ["__pos__"], false]
    - ["re1756024", "re.RegexFlag.__dict__.__contains__", ["__or__"], true]
    - ["re1756025", "re.RegexFlag.__dict__.__contains__", ["__and__"], true]
    - ["re1756026", "re.RegexFlag.__dict__.__contains__", ["__xor__"], true]
    - ["re1756027", "re.RegexFlag.__dict__.__contains__", ["__invert__"], true]
