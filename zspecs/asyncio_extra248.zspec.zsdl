spec: asyncio_extra248
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html#asyncio.Queue — Queue class"
    - "https://docs.python.org/3/library/asyncio-queue.html#asyncio.QueueFull — QueueFull exception"
    - "https://docs.python.org/3/library/asyncio-queue.html#asyncio.QueueEmpty — QueueEmpty exception"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py (internal implementation)"
  notes:
    - "This spec covers asyncio.Queue class identity and QueueFull/QueueEmpty exception identity."
    - "asyncio.Queue.__name__ == 'Queue' (len=5); __module__ == 'asyncio.queues' (len=14)."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' — Queue inherits from the loop-bound mixin."
    - "asyncio.QueueFull.__bases__[0].__name__ == 'Exception'; asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'."
    - "asyncio.QueueFull.__module__ == 'asyncio.queues' (len=14); asyncio.QueueEmpty.__module__ == 'asyncio.queues' (len=14)."
    - "put_nowait() on a full queue raises QueueFull; get_nowait() on an empty queue raises QueueEmpty."
    - "Queue(maxsize=0).maxsize == 0 means unbounded; Queue(maxsize=5).maxsize == 5."
    - "Queue().empty() == True for a freshly created queue; Queue().qsize() == 0."
    - "Queue(maxsize=1).full() == True after put_nowait(1) fills the single slot."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue class identity
#
# Queue.__name__ == 'Queue' (len=5)
# Queue.__module__ == 'asyncio.queues' (len=14)
# Queue.__bases__[0].__name__ == '_LoopBoundMixin'
# ---------------------------------------------------------------------------

table asyncio_extra248.queue_identity:
  description: "asyncio.Queue class identity — Queue.__name__.__eq__('Queue')==True (len=5); Queue.__module__.__eq__('asyncio.queues')==True (len=14); Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Queue inherits from the asyncio loop-bound mixin, not object directly); Queue.__name__.__len__()==5; Queue.__module__.__len__()==14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aioq248id

  columns: [id, function, args, expected, description]
  rows:
    - [q_name_eq,    Queue.__name__.__eq__,                   ["Queue"],           true, "asyncio.Queue.__name__ == 'Queue'; verified with Python 3.14.3"]
    - [q_name_len,   Queue.__name__.__len__,                  [],                  5,    "asyncio.Queue.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [q_mod_eq,     Queue.__module__.__eq__,                 ["asyncio.queues"],  true, "asyncio.Queue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [q_mod_len,    Queue.__module__.__len__,                [],                  14,   "asyncio.Queue.__module__.__len__() == 14; verified with Python 3.14.3"]
    - [q_base_eq,    "Queue.__bases__[0].__name__.__eq__",    ["_LoopBoundMixin"], true, "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.QueueFull and asyncio.QueueEmpty exception class identity
#
# QueueFull.__name__ == 'QueueFull' (len=9)
# QueueFull.__module__ == 'asyncio.queues' (len=14)
# QueueFull.__bases__[0].__name__ == 'Exception'
# QueueEmpty.__name__ == 'QueueEmpty' (len=10)
# QueueEmpty.__module__ == 'asyncio.queues' (len=14)
# QueueEmpty.__bases__[0].__name__ == 'Exception'
# ---------------------------------------------------------------------------

table asyncio_extra248.queue_exception_identity:
  description: "asyncio.QueueFull and QueueEmpty exception class identity — QueueFull.__name__.__eq__('QueueFull')==True (len=9); QueueFull.__module__.__eq__('asyncio.queues')==True (len=14); QueueFull.__bases__[0].__name__.__eq__('Exception')==True; QueueEmpty.__name__.__eq__('QueueEmpty')==True (len=10); QueueEmpty.__module__.__eq__('asyncio.queues')==True (len=14); QueueEmpty.__bases__[0].__name__.__eq__('Exception')==True; both exceptions live in the same asyncio.queues module as Queue; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aioq248exc

  columns: [id, function, args, expected, description]
  rows:
    - [qf_name_eq,   QueueFull.__name__.__eq__,                 ["QueueFull"],       true, "asyncio.QueueFull.__name__ == 'QueueFull'; verified with Python 3.14.3"]
    - [qf_name_len,  QueueFull.__name__.__len__,                [],                  9,    "asyncio.QueueFull.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [qf_mod_eq,    QueueFull.__module__.__eq__,               ["asyncio.queues"],  true, "asyncio.QueueFull.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [qf_base_eq,   "QueueFull.__bases__[0].__name__.__eq__",  ["Exception"],       true, "asyncio.QueueFull.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]
    - [qe_name_eq,   QueueEmpty.__name__.__eq__,                ["QueueEmpty"],      true, "asyncio.QueueEmpty.__name__ == 'QueueEmpty'; verified with Python 3.14.3"]
    - [qe_name_len,  QueueEmpty.__name__.__len__,               [],                  10,   "asyncio.QueueEmpty.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [qe_mod_eq,    QueueEmpty.__module__.__eq__,              ["asyncio.queues"],  true, "asyncio.QueueEmpty.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [qe_base_eq,   "QueueEmpty.__bases__[0].__name__.__eq__", ["Exception"],       true, "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra248
# ---------------------------------------------------------------------------

invariant asyncio_extra248.queuefull_single_base_raises_indexerror:
  description: "asyncio.QueueFull.__bases__[1] raises IndexError — QueueFull has exactly one direct base class (Exception); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms the single-inheritance contract: QueueFull -> Exception -> BaseException -> object; QueueFull.__bases__[0].__name__ == 'Exception'; QueueFull.__module__ == 'asyncio.queues' (len=14); QueueFull.__name__ == 'QueueFull' (len=9); NEW in extra248: first standalone QueueFull single-base IndexError invariant in aioq248 namespace; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "QueueFull.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant asyncio_extra248.queueempty_single_base_raises_indexerror:
  description: "asyncio.QueueEmpty.__bases__[1] raises IndexError — QueueEmpty has exactly one direct base class (Exception); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms the single-inheritance contract: QueueEmpty -> Exception -> BaseException -> object; QueueEmpty.__bases__[0].__name__ == 'Exception'; QueueEmpty.__module__ == 'asyncio.queues' (len=14); QueueEmpty.__name__ == 'QueueEmpty' (len=10); NEW in extra248: first standalone QueueEmpty single-base IndexError invariant; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "QueueEmpty.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant asyncio_extra248.queue_name_eq:
  description: "asyncio.Queue.__name__.__eq__('Queue') returns True — the class is named 'Queue' (len=5); it lives in asyncio.queues (len=14); Queue.__bases__[0].__name__ == '_LoopBoundMixin' (inherits from the asyncio loop-bound mixin); Queue.__name__.__len__()==5; QueueFull.__name__.__len__()==9; QueueEmpty.__name__.__len__()==10; among Queue and its two exception types, Queue has the shortest name; NEW in extra248: first standalone Queue name equality invariant in aioq248id namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra248.queuefull_module_eq:
  description: "asyncio.QueueFull.__module__.__eq__('asyncio.queues') returns True — QueueFull is defined in Lib/asyncio/queues.py; __module__ == 'asyncio.queues' (len=14); QueueEmpty.__module__ == 'asyncio.queues' (same module); Queue.__module__ == 'asyncio.queues' (all three live together); QueueFull.__name__ == 'QueueFull' (len=9); QueueFull.__bases__[0].__name__ == 'Exception'; NEW in extra248: first standalone QueueFull module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: QueueFull.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true
