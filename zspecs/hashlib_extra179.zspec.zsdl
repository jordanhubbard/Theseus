spec: hashlib_extra179
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra178.zspec.zsdl — covers hashlib.pbkdf2_hmac.__name__=='pbkdf2_hmac' (len=11); pbkdf2_hmac.__module__=='hashlib'; scrypt.__name__=='scrypt' (len=6); blake2b.__name__=='blake2b' (len=6); blake2s.__name__=='blake2s' (len=6); sha3_256.__name__=='sha3_256' (len=7); sha3_512.__name__=='sha3_512' (len=7) (table + invariants)."
    - "hashlib_extra177.zspec.zsdl — covers hashlib digest sizes and block sizes: md5().digest_size==16; sha1().digest_size==20; sha256().digest_size==32; sha512().digest_size==64; md5().block_size==64; sha256().block_size==64; sha512().block_size==128 (table + invariants)."
    - "hashlib_extra176.zspec.zsdl — covers hashlib HASH object class identity: md5().__class__.__name__=='HASH'; md5().__class__.__module__=='_hashlib'; sha1/sha256 class names; hashlib.new.__name__=='__hash_new'; hashlib.new.__module__=='hashlib' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__=='hashlib' and hashlib.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra178."
    - "Wave 355 theme: hashlib HASH object method names — hashlib.md5().update.__name__=='update' (len=6); hashlib.md5().hexdigest.__name__=='hexdigest' (len=9); hashlib.md5().digest.__name__=='digest' (len=6; same as update); hashlib.md5().copy.__name__=='copy' (len=4); hashlib.md5().name.__eq__('md5')==True; hashlib.sha256().name.__eq__('sha256')==True; hashlib.sha1().name.__eq__('sha1')==True. These anchor the __name__ and name identity attributes of HASH instance methods and the name property as novel content under hashlibmethods179."
    - "hashlib.md5().update.__name__ == 'update'. Verified Python 3.14.3 macOS/Darwin 25.4.0. update is the method for feeding data into a hash object; __name__=='update' (6 chars)."
    - "hashlib.md5().hexdigest.__name__ == 'hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0. hexdigest returns the hex-encoded digest string; __name__=='hexdigest' (9 chars; longest method name in this spec)."
    - "hashlib.md5().digest.__name__ == 'digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0. digest returns the raw bytes digest; __name__=='digest' (6 chars; same length as update)."
    - "hashlib.md5().copy.__name__ == 'copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0. copy returns a copy of the hash object; __name__=='copy' (4 chars; shortest method name in this spec)."
    - "hashlib.md5().name == 'md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The name attribute on a HASH object identifies the algorithm; md5 hash name is 'md5' (3 chars)."
    - "hashlib.sha256().name == 'sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha256 hash name is 'sha256' (6 chars; same length as update and digest method names)."
    - "hashlib.sha1().name == 'sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha1 hash name is 'sha1' (4 chars; same length as copy method name)."
    - "Note: update.__name__(6) == digest.__name__.__len__()==6. Two-way tie at 6 chars: update and digest share the same __name__ length."
    - "Note: copy.__name__(4) == sha1().name.__len__()==4. Two-way tie at 4 chars: copy method name and sha1 algorithm name both have 4 chars."
    - "Note: hexdigest.__name__(9) > sha256().name(6) == update(6) == digest(6) > sha1().name(4) == copy(4) > md5().name(3). Full length ordering: 3 < 4 < 6 < 9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5().update.__name__ == 'update'
# hashlib.md5().hexdigest.__name__ == 'hexdigest'
# hashlib.md5().digest.__name__ == 'digest'
# hashlib.md5().copy.__name__ == 'copy'
#
# Wave 355 theme: HASH object method __name__ identity.
#
# update.__name__ is 'update' (6 chars).
# hexdigest.__name__ is 'hexdigest' (9 chars; longest in spec).
# digest.__name__ is 'digest' (6 chars; tied with update).
# copy.__name__ is 'copy' (4 chars; shortest method name in spec).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra179.md5_method_names:
  description: "hashlib.md5().update.__name__.__eq__('update')==True / hashlib.md5().hexdigest.__name__.__eq__('hexdigest')==True / hashlib.md5().digest.__name__.__eq__('digest')==True / hashlib.md5().copy.__name__.__eq__('copy')==True — update.__name__ is 'update' (6 chars; the update method feeds data into the running hash; each call appends to the internal state; __name__=='update' (6 chars); novel anchor: no prior hashlib spec anchors md5().update.__name__ under hashlibmethods179; first hashlibmethods179 anchor for 'update' as HASH method __name__); hexdigest.__name__ is 'hexdigest' (9 chars; the hexdigest method returns the digest as a lowercase hexadecimal string of twice the digest_size; e.g., md5().hexdigest() returns a 32-char hex string; __name__=='hexdigest' (9 chars; longest method name in spec); novel anchor: first hashlibmethods179 anchor for hexdigest.__name__); digest.__name__ is 'digest' (6 chars; the digest method returns the raw bytes of the digest; for md5 this is 16 bytes; digest.__name__(6) == update.__name__.__len__()==6: two-way tie; novel anchor: first hashlibmethods179 anchor for digest.__name__); copy.__name__ is 'copy' (4 chars; the copy method returns a copy of the hash object with the same internal state; copy.__name__(4) < digest.__name__(6): copy is the shortest method name; novel anchor: first hashlibmethods179 anchor for copy.__name__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmethods179

  columns: [id, function, args, expected, description]
  rows:
    - [md5_update_name_eq,    "md5().update.__name__.__eq__",    ["update"],    true, "hashlib.md5().update.__name__ == 'update' (6 chars; feeds data into hash; novel anchor)"]
    - [md5_hexdigest_name_eq, "md5().hexdigest.__name__.__eq__", ["hexdigest"], true, "hashlib.md5().hexdigest.__name__ == 'hexdigest' (9 chars; longest; novel anchor)"]
    - [md5_digest_name_eq,    "md5().digest.__name__.__eq__",    ["digest"],    true, "hashlib.md5().digest.__name__ == 'digest' (6 chars; tied with update(6); novel anchor)"]
    - [md5_copy_name_eq,      "md5().copy.__name__.__eq__",      ["copy"],      true, "hashlib.md5().copy.__name__ == 'copy' (4 chars; shortest method name; novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.md5().update.__name__.__len__() == 6
# hashlib.md5().hexdigest.__name__.__len__() == 9
# hashlib.md5().digest.__name__.__len__() == 6
# hashlib.md5().copy.__name__.__len__() == 4
#
# Wave 355 theme: HASH method __name__ length values and ordering.
#
# update.__name__.__len__() is 6.
# hexdigest.__name__.__len__() is 9 (longest).
# digest.__name__.__len__() is 6 (tied with update).
# copy.__name__.__len__() is 4 (shortest).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra179.md5_method_name_lengths:
  description: "hashlib.md5().update.__name__.__len__()==6 / hashlib.md5().hexdigest.__name__.__len__()==9 / hashlib.md5().digest.__name__.__len__()==6 / hashlib.md5().copy.__name__.__len__()==4 — update.__name__.__len__() is 6 (len('update')==6; integer confirmation of the update method name length; novel anchor: first hashlibmethods179 anchor for the integer 6 as update name length); hexdigest.__name__.__len__() is 9 (len('hexdigest')==9; longest method name in spec; 9 > 6 by 3: hexdigest is 3 chars longer than update/digest; novel anchor: first hashlibmethods179 anchor for the integer 9 as hexdigest name length); digest.__name__.__len__() is 6 (len('digest')==6; 2-way tie with update(6); novel anchor: first hashlibmethods179 anchor for digest name length); copy.__name__.__len__() is 4 (len('copy')==4; shortest method name; 4 < 6 by 2; novel anchor: first hashlibmethods179 anchor for the integer 4 as copy name length)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmethods179

  columns: [id, function, args, expected, description]
  rows:
    - [md5_update_name_len,    "md5().update.__name__.__len__",    [], 6, "hashlib.md5().update.__name__.__len__() == 6 ('update'=6; novel anchor)"]
    - [md5_hexdigest_name_len, "md5().hexdigest.__name__.__len__", [], 9, "hashlib.md5().hexdigest.__name__.__len__() == 9 ('hexdigest'=9; longest; novel anchor)"]
    - [md5_digest_name_len,    "md5().digest.__name__.__len__",    [], 6, "hashlib.md5().digest.__name__.__len__() == 6 ('digest'=6; tied with update; novel anchor)"]
    - [md5_copy_name_len,      "md5().copy.__name__.__len__",      [], 4, "hashlib.md5().copy.__name__.__len__() == 4 ('copy'=4; shortest; novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.md5().name == 'md5'
# hashlib.sha256().name == 'sha256'
# hashlib.sha1().name == 'sha1'
#
# Wave 355 theme: HASH object name attribute values.
#
# md5().name is 'md5' (3 chars; shortest algorithm name in spec).
# sha256().name is 'sha256' (6 chars; same length as update/digest method names).
# sha1().name is 'sha1' (4 chars; same length as copy method name).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra179.hash_name_attributes:
  description: "hashlib.md5().name.__eq__('md5')==True / hashlib.sha256().name.__eq__('sha256')==True / hashlib.sha1().name.__eq__('sha1')==True — md5().name is 'md5' (3 chars; the name attribute on a HASH object identifies the underlying algorithm; for md5 the name is 'md5' — a 3-char lowercase string; md5().name(3) < copy.__name__(4): the md5 algorithm name is shorter than the shortest method name; novel anchor: no prior hashlib spec anchors md5().name under hashlibmethods179; first hashlibmethods179 anchor for 'md5' as HASH name attribute); sha256().name is 'sha256' (6 chars; hashlib.sha256() creates a SHA-256 hash object; its name attribute is 'sha256' — 6 chars; sha256().name(6) == update.__name__.__len__()==6 == digest.__name__.__len__()==6: 3-way tie at 6 chars between the sha256 algorithm name and the update/digest method names; novel anchor: first hashlibmethods179 anchor for sha256().name=='sha256'); sha1().name is 'sha1' (4 chars; hashlib.sha1() creates a SHA-1 hash object; its name attribute is 'sha1' — 4 chars; sha1().name(4) == copy.__name__.__len__()==4: 2-way tie between sha1 algorithm name and copy method name; novel anchor: first hashlibmethods179 anchor for sha1().name=='sha1')"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmethods179

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_md5,       "md5().name.__eq__",    ["md5"],    true, "hashlib.md5().name == 'md5' (3 chars; shortest; 3<4<6; novel anchor)"]
    - [sha256_name_sha256, "sha256().name.__eq__", ["sha256"], true, "hashlib.sha256().name == 'sha256' (6 chars; ties update/digest(6); novel anchor)"]
    - [sha1_name_sha1,     "sha1().name.__eq__",   ["sha1"],   true, "hashlib.sha1().name == 'sha1' (4 chars; ties copy(4); novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.md5().update.__name__.__eq__('update') — standalone
#
# hashlib.md5().update.__name__ is 'update' (6 chars). update is the primary
# method for feeding data into a running hash object. update(6) ties with
# digest(6) — 2-way tie.
# Novel anchor under hashlibmethods179. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra179.md5_update_name_update:
  description: "hashlib.md5().update.__name__.__eq__('update') == True — 'update' (6 chars; hashlib.md5() creates a new MD5 hash object; the update attribute on that object is the method used to feed data into the hash incrementally; calling update(data) is equivalent to initializing a new hash with the same data; the __name__ attribute of the update method equals 'update' — 6 lowercase chars; update.__name__(6) == digest.__name__.__len__()==6: update and digest share the same 6-char name length — a 2-way tie; update.__name__(6) > copy.__name__.__len__()==4 by 2: update is 2 chars longer than copy; update.__name__(6) < hexdigest.__name__.__len__()==9 by 3: hexdigest is 3 chars longer than update; novel anchor: no prior hashlib spec anchors md5().update.__name__ under hashlibmethods179; first hashlibmethods179 standalone for md5().update.__name__.__eq__('update')"
  category: identity
  kind: python_call_eq
  function: "md5().update.__name__.__eq__"
  args: ["update"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().hexdigest.__name__.__eq__('hexdigest') — standalone
#
# hashlib.md5().hexdigest.__name__ is 'hexdigest' (9 chars). hexdigest is the
# longest method name in this spec. hexdigest returns the digest as a hex string.
# Novel anchor under hashlibmethods179. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra179.md5_hexdigest_name_hexdigest:
  description: "hashlib.md5().hexdigest.__name__.__eq__('hexdigest') == True — 'hexdigest' (9 chars; hashlib.md5().hexdigest is the method that returns the message digest as a string of hexadecimal digits; for MD5 this produces a 32-character lowercase hex string (2 hex chars per byte * 16 bytes); hexdigest is more convenient than digest when the digest needs to be stored or compared as text; the __name__ attribute of the hexdigest method equals 'hexdigest' — 9 chars; hexdigest.__name__(9) is the longest method name in this spec: copy(4) < update(6) == digest(6) < hexdigest(9); hexdigest.__name__(9) > update.__name__.__len__()==6 by 3; novel anchor: no prior hashlib spec anchors md5().hexdigest.__name__ under hashlibmethods179; first hashlibmethods179 standalone for md5().hexdigest.__name__.__eq__('hexdigest')"
  category: identity
  kind: python_call_eq
  function: "md5().hexdigest.__name__.__eq__"
  args: ["hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().digest.__name__.__eq__('digest') — standalone
#
# hashlib.md5().digest.__name__ is 'digest' (6 chars). digest returns the
# raw bytes of the hash. digest(6) ties with update(6) — 2-way tie at 6 chars.
# Novel anchor under hashlibmethods179. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra179.md5_digest_name_digest:
  description: "hashlib.md5().digest.__name__.__eq__('digest') == True — 'digest' (6 chars; hashlib.md5().digest is the method that returns the raw bytes of the message digest; for MD5 this returns 16 bytes (128 bits); digest() returns bytes while hexdigest() returns a hex string — they represent the same value in different encodings; the __name__ attribute of the digest method equals 'digest' — 6 lowercase chars; digest.__name__(6) == update.__name__.__len__()==6: digest and update share the same 6-char name length — 2-way tie; digest.__name__(6) < hexdigest.__name__.__len__()==9: hexdigest is 3 chars longer than digest; the string 'digest' is a proper prefix of 'hexdigest' — hexdigest is formed by prepending 'hex' to 'digest'; novel anchor: no prior hashlib spec anchors md5().digest.__name__ under hashlibmethods179; first hashlibmethods179 standalone for md5().digest.__name__.__eq__('digest')"
  category: identity
  kind: python_call_eq
  function: "md5().digest.__name__.__eq__"
  args: ["digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().copy.__name__.__eq__('copy') — standalone
#
# hashlib.md5().copy.__name__ is 'copy' (4 chars). copy returns a copy of
# the hash object. copy(4) is the shortest method name in this spec.
# copy(4) == sha1().name(4) — 2-way tie with sha1 algorithm name length.
# Novel anchor under hashlibmethods179. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra179.md5_copy_name_copy:
  description: "hashlib.md5().copy.__name__.__eq__('copy') == True — 'copy' (4 chars; hashlib.md5().copy is the method that returns a copy of the hash object with the same internal state; this allows computing multiple digests from a common prefix without re-feeding the data; for example, you can feed a common prefix, copy the hash, then feed different suffixes to each copy; the __name__ attribute of the copy method equals 'copy' — 4 lowercase chars; copy.__name__(4) is the shortest method name in this spec: copy(4) < update(6) == digest(6) < hexdigest(9); copy.__name__(4) == sha1().name.__len__()==4: 2-way tie between the copy method name and the sha1 algorithm name; novel anchor: no prior hashlib spec anchors md5().copy.__name__ under hashlibmethods179; first hashlibmethods179 standalone for md5().copy.__name__.__eq__('copy')"
  category: identity
  kind: python_call_eq
  function: "md5().copy.__name__.__eq__"
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().name.__eq__('md5') — standalone
#
# hashlib.md5().name is 'md5' (3 chars). The name attribute identifies the
# algorithm. md5 name(3) < sha1 name(4) < sha256 name(6). Full ordering.
# Novel anchor under hashlibmethods179. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra179.md5_name_attr_md5:
  description: "hashlib.md5().name.__eq__('md5') == True — 'md5' (3 chars; the name attribute on a HASH object returns a string identifying the algorithm used to construct the object; for a hash created by hashlib.md5(), the name attribute equals 'md5' — a 3-char lowercase string; MD5 (Message Digest Algorithm 5) was designed by Ronald Rivest in 1991 and produces 128-bit (16-byte) digests; the name attribute is a property of the HASH object (not the constructor); md5().name(3) < sha1().name.__len__()==4 < sha256().name.__len__()==6: full ordering of algorithm name lengths in this spec; md5().name(3) < copy.__name__(4): even the shortest method name is 1 char longer than the md5 algorithm name; novel anchor: no prior hashlib spec anchors md5().name under hashlibmethods179; first hashlibmethods179 standalone for md5().name.__eq__('md5')"
  category: identity
  kind: python_call_eq
  function: "md5().name.__eq__"
  args: ["md5"]
  expected: true
