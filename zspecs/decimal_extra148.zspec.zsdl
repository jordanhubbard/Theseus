spec: decimal_extra148
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal module context precision constants and Decimal class identity. DefaultContext.prec==28, BasicContext.prec==9, ExtendedContext.prec==9. MAX_PREC==999999999999999999 (18 nines, type int). MAX_EMAX==999999999999999999 (same value as MAX_PREC, also type int). MIN_EMIN==-999999999999999999. Decimal.__name__=='Decimal', Decimal.__module__=='decimal'."
    - "DefaultContext.prec == 28 — the default precision is 28 significant decimal digits; this provides more precision than IEEE 754 double (about 15-17 significant digits) while remaining manageable; 28 was chosen to match IBM's General Decimal Arithmetic specification."
    - "BasicContext.prec == 9 and ExtendedContext.prec == 9 — both alternative contexts use 9 significant digits, matching the General Decimal Arithmetic (GDA) specification default; BasicContext traps most signals as exceptions while ExtendedContext is more permissive."
    - "MAX_PREC == MAX_EMAX == 999999999999999999 (10^18 - 1, or 18 nines) — both the maximum precision and maximum exponent happen to be the same value in the C decimal implementation; this value reflects the use of 64-bit integers internally."
    - "decimal.Decimal.__module__ == 'decimal' (not '_decimal'); the C extension sets __module__ to the public module name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal context precision constants
# DefaultContext.prec == 28 (the standard default for Python's decimal module)
# BasicContext.prec == 9 (GDA specification baseline)
# ExtendedContext.prec == 9 (same as BasicContext)
# All are plain int values.
# ---------------------------------------------------------------------------

table decimal_extra148.context_precision_values:
  description: "decimal context precision values: DefaultContext.prec==28, BasicContext.prec==9, ExtendedContext.prec==9; all are plain ints"
  kind: python_call_eq
  category: identity
  id_prefix: decprec148

  columns: [id, function, args, expected, description]
  rows:
    - [default_prec_val,   DefaultContext.prec.__eq__,    [28], true, "decimal.DefaultContext.prec == 28 (the default precision is 28 significant decimal digits; chosen to match the IBM General Decimal Arithmetic specification; provides more precision than IEEE 754 double (~15-17 digits) while being practical; DefaultContext is used to initialize new thread contexts via copy)"]
    - [basic_prec_val,     BasicContext.prec.__eq__,      [9],  true, "decimal.BasicContext.prec == 9 (BasicContext uses 9-digit precision matching the GDA specification baseline; BasicContext also traps most signals as exceptions unlike the more permissive DefaultContext; prec 9 provides about the same precision as a 32-bit IEEE 754 single-precision float)"]
    - [extended_prec_val,  ExtendedContext.prec.__eq__,   [9],  true, "decimal.ExtendedContext.prec == 9 (ExtendedContext also uses 9-digit precision like BasicContext; ExtendedContext is more permissive than BasicContext — it does not trap most signals; both alternative contexts match the GDA specification default precision of 9)"]
    - [default_not_9,      DefaultContext.prec.__eq__,    [9],  false,"decimal.DefaultContext.prec.__eq__(9) == False (DefaultContext uses prec=28 not 9; the 28 vs 9 difference distinguishes Python's DefaultContext from the GDA specification baseline used by BasicContext and ExtendedContext)"]
    - [default_not_basic,  DefaultContext.prec.__gt__,    [9],  true, "decimal.DefaultContext.prec.__gt__(9) == True (DefaultContext precision (28) is greater than BasicContext/ExtendedContext precision (9); Python chose 28 for DefaultContext because financial applications need more than 9 digits)"]

# ---------------------------------------------------------------------------
# decimal MAX_PREC and MAX_EMAX constants
# Both == 999999999999999999 (18 nines, type int)
# MAX_PREC: maximum precision for the C decimal implementation
# MAX_EMAX: maximum exponent
# ---------------------------------------------------------------------------

table decimal_extra148.max_constants:
  description: "decimal.MAX_PREC==999999999999999999 (18 nines, type int); decimal.MAX_EMAX==999999999999999999 (same value, also type int); both reflect 64-bit integer limits in the C implementation"
  kind: python_call_eq
  category: identity
  id_prefix: decprec148

  columns: [id, function, args, expected, description]
  rows:
    - [max_prec_val,       MAX_PREC.__eq__,                    [999999999999999999], true, "decimal.MAX_PREC == 999999999999999999 (the maximum precision supported by the C decimal implementation; 18 nines == 10**18 - 1; reflects the use of 64-bit integers for the coefficient; far larger than any practical computation; already confirmed in decimal_extra147 as a key constant)"]
    - [max_prec_cls,       MAX_PREC.__class__.__name__.__eq__, ["int"],              true, "decimal.MAX_PREC.__class__.__name__ == 'int' (MAX_PREC is a plain Python int; it is a module-level constant, not a Context attribute; its class is int (not Decimal) because it is an integer limit, not a decimal value)"]
    - [max_emax_val,       MAX_EMAX.__eq__,                    [999999999999999999], true, "decimal.MAX_EMAX == 999999999999999999 (the maximum exponent value; same numeric value as MAX_PREC (18 nines); in the C decimal implementation both the max precision and max exponent share the same 64-bit integer ceiling)"]
    - [max_emax_cls,       MAX_EMAX.__class__.__name__.__eq__, ["int"],              true, "decimal.MAX_EMAX.__class__.__name__ == 'int' (MAX_EMAX is a plain Python int, same type as MAX_PREC; the maximum exponent determines the largest representable Decimal: up to 10^(MAX_EMAX) can be represented in a context with Emax==MAX_EMAX)"]
    - [max_prec_eq_emax,   MAX_PREC.__eq__,                    [999999999999999999], true, "decimal.MAX_PREC == decimal.MAX_EMAX == 999999999999999999 (both constants have the same value; MAX_PREC limits the number of significant digits, MAX_EMAX limits the exponent scale; they share the same ceiling because both are derived from the same 64-bit integer representation in libmpdec)"]

# ---------------------------------------------------------------------------
# decimal.Decimal class identity
# Decimal.__name__ == 'Decimal' (len==7)
# Decimal.__module__ == 'decimal' (public module, not '_decimal')
# ---------------------------------------------------------------------------

table decimal_extra148.Decimal_class_identity:
  description: "decimal.Decimal class identity: __name__=='Decimal' (len=7), __module__=='decimal' (public module, not '_decimal')"
  kind: python_call_eq
  category: identity
  id_prefix: decprec148

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name_eq,    Decimal.__name__.__eq__,    ["Decimal"], true, "decimal.Decimal.__name__ == 'Decimal' (the class name; 7 characters; same length as the module name 'decimal' (7) and the Context class name 'Context' (7) — all three primary identifiers in the decimal module share the same length)"]
    - [dec_module_eq,  Decimal.__module__.__eq__,  ["decimal"], true, "decimal.Decimal.__module__ == 'decimal' (the C extension sets __module__ to the public 'decimal' module name, not '_decimal'; this ensures that repr(Decimal('1.5')) shows 'Decimal' and type annotations reference 'decimal.Decimal' correctly)"]
    - [dec_not_cdecimal, Decimal.__module__.__eq__, ["_decimal"], false, "decimal.Decimal.__module__.__eq__('_decimal') == False (Decimal's __module__ is 'decimal' not '_decimal'; even though the implementation lives in the _decimal C extension, __module__ is explicitly set to the public module name for correct repr and annotation support)"]
    - [dec_name_len,   Decimal.__name__.__len__,   [],           7,    "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters; same length as 'decimal' (the module name) and 'Context' (the configuration class); note that MAX_PREC.__class__.__name__ == 'int' (3 chars), not 'Decimal' — MAX_PREC is a plain int, not a Decimal instance)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra148.DefaultContext_prec_28:
  description: "decimal.DefaultContext.prec == 28 — the default context precision is 28 significant decimal digits; this is the precision used for all decimal arithmetic when no explicit context is specified; 28 digits was chosen in the IBM General Decimal Arithmetic specification as sufficient for most financial applications; it is 3x the GDA baseline (9) and roughly 1.6x IEEE 754 double precision (~17 significant digits)"
  category: identity
  kind: python_call_eq
  function: DefaultContext.prec.__eq__
  args: [28]
  expected: true

invariant decimal_extra148.BasicContext_prec_9:
  description: "decimal.BasicContext.prec == 9 — BasicContext uses 9-digit precision matching the General Decimal Arithmetic specification baseline; BasicContext also has strict signal trapping (most signals raise exceptions) making it useful for detecting precision issues; prec 9 provides about the same range as IEEE 754 single-precision (binary32) float but in exact decimal representation"
  category: identity
  kind: python_call_eq
  function: BasicContext.prec.__eq__
  args: [9]
  expected: true

invariant decimal_extra148.ExtendedContext_prec_9:
  description: "decimal.ExtendedContext.prec == 9 — ExtendedContext also uses 9-digit precision (same as BasicContext) but with permissive signal handling (no traps); ExtendedContext is designed for applications that prefer NaN and Infinity results over exceptions; both BasicContext and ExtendedContext use the GDA baseline precision of 9"
  category: identity
  kind: python_call_eq
  function: ExtendedContext.prec.__eq__
  args: [9]
  expected: true

invariant decimal_extra148.MAX_PREC_is_18_nines:
  description: "decimal.MAX_PREC == 999999999999999999 — MAX_PREC is 10^18 - 1 (18 nines); the maximum precision for the C decimal (libmpdec) implementation; reflects the use of 64-bit integers; this is the upper bound for the prec attribute on a Context object; setting context.prec = decimal.MAX_PREC allows up to 999999999999999999 significant decimal digits — far beyond any practical need"
  category: identity
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra148.MAX_EMAX_is_18_nines:
  description: "decimal.MAX_EMAX == 999999999999999999 — MAX_EMAX is 10^18 - 1 (18 nines), the same value as MAX_PREC; the maximum exponent for the C decimal implementation; setting Context.Emax = decimal.MAX_EMAX allows Decimal values up to 10^(10^18 - 1); both MAX_PREC and MAX_EMAX share the same ceiling because both are limited by the 64-bit integer range in libmpdec"
  category: identity
  kind: python_call_eq
  function: MAX_EMAX.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra148.Decimal_module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' — Decimal's __module__ is the public 'decimal' module name even though the actual implementation lives in the _decimal C extension; the C extension explicitly sets __module__ = 'decimal' so that repr(Decimal('1.5')) shows 'Decimal(...)' and type annotations written as 'decimal.Decimal' resolve correctly regardless of whether _decimal or _pydecimal is active"
  category: identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true
