spec: inspect_extra93
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra92

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra92.zspec.zsdl."
    - "This spec covers: inspect Parameter and Signature class identity — class names, modules, qualnames, base classes, mro lengths, and Parameter.kind enum member values (Wave 253)."
    - "inspect.Parameter.__name__ == 'Parameter'. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter'. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter has no custom base class. Verified with Python 3.14.3."
    - "inspect.Parameter.__mro__.__len__() == 2 — mro is [Parameter, object]. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_ONLY.value == 0, __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_OR_KEYWORD.value == 1, __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.VAR_POSITIONAL.value == 2, __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.KEYWORD_ONLY.value == 3, __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.VAR_KEYWORD.value == 4, __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature'. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "inspect.Signature.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Parameter class identity (__name__, __module__, __qualname__)
#
# Wave 253 theme: inspect.Parameter class identity attributes.
#
# inspect.Parameter.__name__.__eq__('Parameter')  == True
# inspect.Parameter.__module__.__eq__('inspect')  == True
# inspect.Parameter.__qualname__.__eq__('Parameter') == True
#
# Parameter is a pure-Python class defined in Lib/inspect.py at module scope.
# Prior spec extra92 checked __code__.co_argcount; this spec (extra93) checks class identity. New to extra93.
# ---------------------------------------------------------------------------

table inspect_extra93.parameter_class_identity:
  description: "inspect.Parameter __name__, __module__, __qualname__ identity; pure-Python class in Lib/inspect.py; wave 253; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamclass93

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq_Parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a pure-Python class defined with 'class Parameter:' in Lib/inspect.py; __name__ is set by the class definition to 'Parameter'; str.__eq__('Parameter') returns True; prior spec extra92 checked __code__.co_argcount; this spec (extra93) checks class identity; new to extra93"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; the module attribute reflects the file's __name__ which is 'inspect'; str.__eq__('inspect') returns True; new to extra93"]
    - [parameter_qualname_eq_Parameter,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is defined at module scope in Lib/inspect.py; its __qualname__ is the simple class name 'Parameter' with no enclosing scope prefix; str.__eq__('Parameter') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Table 2: Parameter.kind enum member values
#
# Wave 253 theme: inspect.Parameter kind sentinel integer values.
#
# Parameter.POSITIONAL_ONLY.value.__eq__(0)        == True
# Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1)  == True
# Parameter.VAR_POSITIONAL.value.__eq__(2)         == True
# Parameter.KEYWORD_ONLY.value.__eq__(3)           == True
# Parameter.VAR_KEYWORD.value.__eq__(4)            == True
#
# All five kind constants are _ParameterKind enum members with integer values 0-4. New to extra93.
# ---------------------------------------------------------------------------

table inspect_extra93.parameter_kind_values:
  description: "Parameter.POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD/VAR_POSITIONAL/KEYWORD_ONLY/VAR_KEYWORD integer values 0-4; wave 253; new to extra93"
  kind: python_call_eq
  category: integer_identity
  id_prefix: inspectparamclass93

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_value_eq_0,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY is a _ParameterKind enum member with integer value 0; it represents parameters that can only be passed positionally (e.g. in C-implemented functions); int.__eq__(0) returns True; new to extra93"]
    - [positional_or_keyword_value_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD is a _ParameterKind enum member with integer value 1; it is the default kind for normal Python function parameters; int.__eq__(1) returns True; new to extra93"]
    - [var_positional_value_eq_2,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL is a _ParameterKind enum member with integer value 2; it represents *args parameters; int.__eq__(2) returns True; new to extra93"]
    - [keyword_only_value_eq_3,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY is a _ParameterKind enum member with integer value 3; it represents parameters after * or *args that must be passed by keyword; int.__eq__(3) returns True; new to extra93"]
    - [var_keyword_value_eq_4,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD is a _ParameterKind enum member with integer value 4; it represents **kwargs parameters; int.__eq__(4) returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Table 3: Signature class identity (__name__, __module__, __bases__[0].__name__)
#
# Wave 253 theme: inspect.Signature class identity.
#
# inspect.Signature.__name__.__eq__('Signature')         == True
# inspect.Signature.__module__.__eq__('inspect')         == True
# inspect.Signature.__bases__[0].__name__.__eq__('object') == True
#
# Signature is a pure-Python class in Lib/inspect.py with only object as its base. New to extra93.
# ---------------------------------------------------------------------------

table inspect_extra93.signature_class_identity:
  description: "inspect.Signature __name__, __module__, __bases__[0].__name__ identity; pure-Python class in Lib/inspect.py; wave 253; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamclass93

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq_Signature,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a pure-Python class defined with 'class Signature:' in Lib/inspect.py; __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra93"]
    - [signature_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra93"]
    - [signature_base_name_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature has no explicit base class so it inherits from object; __bases__[0] is <class 'object'>; __name__ is 'object'; str.__eq__('object') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Table 4: BoundArguments class identity + Parameter/Signature __mro__.__len__()
#
# Wave 253 theme: inspect.BoundArguments identity and mro lengths.
#
# inspect.BoundArguments.__name__.__eq__('BoundArguments')         == True
# inspect.BoundArguments.__module__.__eq__('inspect')              == True
# inspect.BoundArguments.__bases__[0].__name__.__eq__('object')    == True
# inspect.Parameter.__mro__.__len__().__eq__(2)                    == True
# inspect.Signature.__mro__.__len__().__eq__(2)                    == True
#
# BoundArguments has only object as a base. Parameter and Signature both have mro length 2. New to extra93.
# ---------------------------------------------------------------------------

table inspect_extra93.boundarguments_and_mro:
  description: "BoundArguments class identity and Parameter/Signature __mro__.__len__() == 2; wave 253; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamclass93

  columns: [id, function, args, expected, description]
  rows:
    - [boundarguments_name_eq_BoundArguments,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra93"]
    - [boundarguments_module_eq_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra93"]
    - [boundarguments_base_name_eq_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits from object only; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra93"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter's mro is [Parameter, object]; no intermediate base classes; tuple.__len__() returns 2; int.__eq__(2) is True; new to extra93"]
    - [signature_mro_len_eq_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature's mro is [Signature, object]; no intermediate base classes; tuple.__len__() returns 2; new to extra93"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant inspect_extra93.parameter_name_eq_Parameter:
  description: "inspect.Parameter.__name__ == 'Parameter' — pure-Python class defined in Lib/inspect.py; wave 253; new to extra93"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra93.parameter_module_eq_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in Lib/inspect.py; wave 253; new to extra93"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra93.positional_only_value_eq_0:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0 — POSITIONAL_ONLY is the first kind constant; wave 253; new to extra93"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra93.var_keyword_value_eq_4:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4 — VAR_KEYWORD is the last kind constant at value 4; wave 253; new to extra93"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

invariant inspect_extra93.parameter_mro_len_eq_2:
  description: "inspect.Parameter.__mro__.__len__() == 2 — mro is [Parameter, object]; wave 253; new to extra93"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2
