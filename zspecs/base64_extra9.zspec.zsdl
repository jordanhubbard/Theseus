spec: base64_extra9
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings, October 2006"
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "CPython source: Modules/binascii.c"
    - "base64.zspec.zsdl — covers b64encode/b64decode RFC 4648 vectors; urlsafe; b32encode foo/foobar; b16encode; roundtrip; b64decode invalid raises"
    - "base64_extra4.zspec.zsdl — covers urlsafe/b16/b32/b85 hello vectors; return type checks"
    - "base64_extra5.zspec.zsdl — covers b64encode/__name__, __module__; return type checks; b64encode length 1/3/6; zero-byte encode/decode"
    - "base64_extra6.zspec.zsdl — covers b32encode A/empty; b32decode; b16encode/decode abc/ff/00; b85encode/decode hello; b64decode empty; b64encode two bytes"
    - "base64_extra7.zspec.zsdl — covers b16/b32/b85 __name__ and __module__; b16encode null/ff; b64encode Man; urlsafe return class"
    - "base64_extra8.zspec.zsdl — covers b32encode/decode RFC 4648 §10 f/fo/foob/fooba; urlsafe_b64encode/decode abc/foobar; urlsafe_b64encode/decode empty; b64encode two-byte length"
  notes:
    - "This spec extends base64 through base64_extra8; it does NOT duplicate invariants present in those files."
    - "Focus: a85encode/decode (Ascii85) vectors not tested in any prior spec; b85encode additional vectors; b16encode length checks; b32encode hello world vector."
    - "base64.a85encode and a85decode are not covered in any prior base64 spec."
    - "base64.a85encode.__name__ == 'a85encode' — not in any prior spec."
    - "base64.a85decode.__name__ == 'a85decode' — not in any prior spec."
    - "base64.a85encode(b'hello') == b'BOu!rDZ' — Ascii85 encoding of 5-byte input."
    - "base64.a85decode(b'BOu!rDZ') == b'hello' — decode back to original."
    - "base64.a85encode(b'Man') == b'9jqo' — 3-byte group encodes to 4 Ascii85 chars."
    - "base64.b85encode(b'abc') == b'VPaz' — RFC 1924 Base85 vector."
    - "base64.b85decode(b'VPaz') == b'abc' — decode back."
    - "base64.b85encode(b'') == b'' — empty input produces empty bytes."
    - "len(base64.b16encode(b'abc')) == 6 — 3 bytes -> 6 uppercase hex chars."
    - "len(base64.b16encode(b'HELLO')) == 10 — 5 bytes -> 10 uppercase hex chars."
    - "base64.b32encode(b'hello world') == b'NBSWY3DPEB3W64TMMQ======' — 11-byte input."
    - "base64.b32decode(b'NBSWY3DPEB3W64TMMQ======') == b'hello world' — roundtrip."
    - "base64.b16encode(bytes([1,2,3,4])) == b'01020304' — binary input with leading zero hex digits."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# a85encode / a85decode — function __name__ attributes
#
# base64_extra7 covers __name__ for b16/b32/b85/urlsafe functions.
# No prior base64 spec covers a85encode.__name__ or a85decode.__name__.
# ---------------------------------------------------------------------------

table base64_extra9.a85_function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: a85name

  columns: [id, function, args, expected]
  rows:
    - [a85encode, a85encode.__name__.__eq__, ["a85encode"], true]
    - [a85decode, a85decode.__name__.__eq__, ["a85decode"], true]

# ---------------------------------------------------------------------------
# a85encode — Ascii85 encoding vectors
#
# No prior base64 spec covers a85encode at all.
# a85encode(b'Man') == b'9jqo': 3-byte group encodes to 4 Ascii85 characters.
# a85encode(b'hello') == b'BOu!rDZ': 5-byte input.
# Vectors verified with Python 3.12 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant base64_extra9.a85encode.man:
  description: "base64.a85encode(b'Man') == b'9jqo' — 3-byte input encodes to 4 Ascii85 chars"
  category: a85
  kind: python_call_eq
  function: a85encode
  args: [!ascii "Man"]
  expected: !ascii "9jqo"

invariant base64_extra9.a85encode.hello:
  description: "base64.a85encode(b'hello') == b'BOu!rDZ' — 5-byte input Ascii85 encoding"
  category: a85
  kind: python_call_eq
  function: a85encode
  args: [!ascii "hello"]
  expected: !ascii "BOu!rDZ"

# ---------------------------------------------------------------------------
# a85decode — Ascii85 decoding vectors
#
# No prior base64 spec covers a85decode.
# ---------------------------------------------------------------------------

invariant base64_extra9.a85decode.hello:
  description: "base64.a85decode(b'BOu!rDZ') == b'hello' — decode Ascii85 back to original bytes"
  category: a85
  kind: python_call_eq
  function: a85decode
  args: [!ascii "BOu!rDZ"]
  expected: !ascii "hello"

invariant base64_extra9.a85decode.man:
  description: "base64.a85decode(b'9jqo') == b'Man' — decode 4 Ascii85 chars to 3 bytes"
  category: a85
  kind: python_call_eq
  function: a85decode
  args: [!ascii "9jqo"]
  expected: !ascii "Man"

# ---------------------------------------------------------------------------
# b85encode additional vectors — abc and empty
#
# base64_extra4 and base64_extra6 cover b85encode/decode for b'hello'.
# Not yet covered: b85encode(b'abc') and b85encode(b'').
# ---------------------------------------------------------------------------

invariant base64_extra9.b85encode.abc:
  description: "base64.b85encode(b'abc') == b'VPaz' — RFC 1924 Base85 vector"
  category: b85
  rfc: "RFC 4648"
  kind: python_call_eq
  function: b85encode
  args: [!ascii "abc"]
  expected: !ascii "VPaz"

invariant base64_extra9.b85decode.abc:
  description: "base64.b85decode(b'VPaz') == b'abc' — decode RFC 1924 Base85 vector"
  category: b85
  rfc: "RFC 4648"
  kind: python_call_eq
  function: b85decode
  args: [!ascii "VPaz"]
  expected: !ascii "abc"

invariant base64_extra9.b85encode.empty:
  description: "base64.b85encode(b'') == b'' — empty input produces empty output"
  category: b85
  kind: python_call_eq
  function: b85encode
  args: [!ascii ""]
  expected: !ascii ""

# ---------------------------------------------------------------------------
# b16encode output length checks
#
# base64_extra6 covers b16encode values for abc/ff/00. base64_extra7 covers
# b16encode for null and ff bytes. No prior spec asserts the output length:
# b16encode always produces 2 * len(input) uppercase hex characters.
# ---------------------------------------------------------------------------

invariant base64_extra9.b16encode.abc_len:
  description: "len(base64.b16encode(b'abc')) == 6 — 3 bytes encode to 6 uppercase hex chars"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16encode
  args: [!ascii "abc"]
  method: __len__
  method_args: []
  expected: 6

invariant base64_extra9.b16encode.hello_len:
  description: "len(base64.b16encode(b'HELLO')) == 10 — 5 bytes encode to 10 uppercase hex chars"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16encode
  args: [!ascii "HELLO"]
  method: __len__
  method_args: []
  expected: 10

# ---------------------------------------------------------------------------
# b32encode / b32decode — hello world vector
#
# No prior base64 spec covers b32encode/b32decode for the string 'hello world'.
# The 11-byte input (not divisible by 5) requires padding to the nearest
# multiple of 8 base32 characters.
# ---------------------------------------------------------------------------

invariant base64_extra9.b32encode.hello_world:
  description: "base64.b32encode(b'hello world') == b'NBSWY3DPEB3W64TMMQ======'"
  category: b32
  rfc: "RFC 4648 §6"
  kind: python_call_eq
  function: b32encode
  args: [!ascii "hello world"]
  expected: !ascii "NBSWY3DPEB3W64TMMQ======"

invariant base64_extra9.b32decode.hello_world:
  description: "base64.b32decode(b'NBSWY3DPEB3W64TMMQ======') == b'hello world'"
  category: b32
  rfc: "RFC 4648 §6"
  kind: python_call_eq
  function: b32decode
  args: [!ascii "NBSWY3DPEB3W64TMMQ======"]
  expected: !ascii "hello world"
