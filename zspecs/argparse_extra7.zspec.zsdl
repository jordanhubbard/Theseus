spec: argparse_extra7
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ table for all public classes, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ tables, FileType, BooleanOptionalAction __bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/Namespace/HelpFormatter/ArgumentError/Action __name__/__module__, Action.__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers __module__ table for formatters/exceptions, __bases__[0].__name__ invariants for ArgumentParser/Namespace/ArgumentError/ArgumentTypeError/HelpFormatter/RawText*/RawDescription*/ArgumentDefaults*"
    - "argparse_extra3.zspec.zsdl — covers class_names table, nargs_constants table, ArgumentParser/__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0], ArgumentParser().prog type"
    - "argparse_extra4.zspec.zsdl — covers __qualname__ table for ArgumentParser/Namespace/Action/FileType/HelpFormatter/RawDescription*/RawText*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError"
    - "argparse_extra5.zspec.zsdl — covers argparse module __name__, FileType/__bases__[0], BooleanOptionalAction/__bases__[0], SUPPRESS/REMAINDER/ONE_OR_MORE/ZERO_OR_MORE/OPTIONAL __class__.__name__"
    - "argparse_extra6.zspec.zsdl — covers BooleanOptionalAction/__qualname__, PARSER value/class, Namespace/__bases__[0].__name__, HelpFormatter/__bases__[0].__name__, ArgumentParser method names (set_defaults/format_help/format_usage/parse_known_args), ArgumentParser().description"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __module__ checks for Action/FileType not in any prior spec; ONE_OR_MORE value cross-verification via __ne__ and __len__; formatter __name__ standalone invariants; ArgumentParser().prefix_chars default; ArgumentParser().add_help default; MetavarTypeHelpFormatter/__bases__[0].__name__; RawDescriptionHelpFormatter/__bases__[0].__name__; RawTextHelpFormatter/__bases__[0].__name__."
    - "argparse.Action.__module__ == 'argparse' — Action is defined in Lib/argparse.py; extra covers __name__ and __bases__[0] but not __module__."
    - "argparse.FileType.__module__ == 'argparse' — covered by argparse_extra for __name__; __module__ not verified independently after extra."
    - "argparse.ONE_OR_MORE == '+' — verified in extra5 as __class__.__name__; value confirmed in base spec; cross-check via __ne__ with '?' is a new vector."
    - "argparse.ArgumentParser().prefix_chars == '-' — default option prefix; no prior spec checks this attribute."
    - "argparse.ArgumentParser().add_help == True — default help flag; no prior spec checks this attribute."
    - "argparse.MetavarTypeHelpFormatter.__bases__[0].__name__ == 'HelpFormatter' — extra2/formatters cover Raw*/ArgumentDefaults* bases; MetavarType* base not checked."
    - "argparse.RawDescriptionHelpFormatter.__bases__[0].__name__ == 'HelpFormatter' — formatters spec covers this; cross-verified here under a distinct ID."
    - "argparse.RawTextHelpFormatter.__bases__[0].__name__ == 'RawDescriptionHelpFormatter' — RawText* inherits from RawDescription*, not directly from HelpFormatter."
    - "argparse.ArgumentDefaultsHelpFormatter.__bases__[0].__name__ == 'HelpFormatter' — formatters covers this; standalone cross-verification vector here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for Action and FileType.
# argparse_extra covers __name__/__module__ for ArgumentParser/Namespace/
# HelpFormatter/ArgumentError/Action; extra2 covers formatters/exceptions module.
# Action.__module__ was listed in extra but not put in a dedicated table here;
# FileType.__module__ confirmed in extra only indirectly. Standalone invariants.
# ---------------------------------------------------------------------------

invariant argparse_extra7.Action.module:
  description: "argparse.Action.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: Action.__module__.__eq__
  args: ["argparse"]
  expected: true

invariant argparse_extra7.FileType.module:
  description: "argparse.FileType.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: FileType.__module__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# Formatter base class hierarchy — new vectors.
# extra2/formatters cover Raw*/ArgumentDefaults* __bases__[0] but not
# MetavarTypeHelpFormatter. RawTextHelpFormatter inherits from
# RawDescriptionHelpFormatter (not directly from HelpFormatter).
# ---------------------------------------------------------------------------

table argparse_extra7.formatter_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: fmtbase7

  columns: [id, function, args, expected]
  rows:
    - [MetavarTypeHelpFormatter,       MetavarTypeHelpFormatter.__bases__.__getitem__,       [0], "HelpFormatter"]
    - [ArgumentDefaultsHelpFormatter,  ArgumentDefaultsHelpFormatter.__bases__.__getitem__,  [0], "HelpFormatter"]
    - [RawDescriptionHelpFormatter,    RawDescriptionHelpFormatter.__bases__.__getitem__,    [0], "HelpFormatter"]
    - [RawTextHelpFormatter,           RawTextHelpFormatter.__bases__.__getitem__,           [0], "RawDescriptionHelpFormatter"]

# ---------------------------------------------------------------------------
# ONE_OR_MORE value cross-verification.
# Base spec confirms ONE_OR_MORE == '+'; extra5 checks __class__.__name__.
# __ne__ with '?' is a new vector confirming it is distinct from OPTIONAL.
# __eq__ with '+' repeated here under a new invariant ID for tracking.
# ---------------------------------------------------------------------------

invariant argparse_extra7.ONE_OR_MORE.ne_optional:
  description: "argparse.ONE_OR_MORE != '?' — ONE_OR_MORE ('+') is distinct from OPTIONAL ('?')"
  category: constants
  kind: python_call_eq
  function: ONE_OR_MORE.__ne__
  args: ["?"]
  expected: true

invariant argparse_extra7.ONE_OR_MORE.len:
  description: "len(argparse.ONE_OR_MORE) == 1 — ONE_OR_MORE is a single-character string"
  category: constants
  kind: python_call_eq
  function: ONE_OR_MORE.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# ArgumentParser instance default attributes.
# extra6 covers description (None) and PARSER value/class.
# prefix_chars and add_help are new vectors not in any prior spec.
# ---------------------------------------------------------------------------

invariant argparse_extra7.ArgumentParser.prefix_chars_default:
  description: "argparse.ArgumentParser().prefix_chars == '-' — default option prefix character"
  category: ArgumentParser
  kind: python_call_eq
  function: ArgumentParser
  args: []
  method: prefix_chars
  method_args: []
  expected: "-"

invariant argparse_extra7.ArgumentParser.add_help_default:
  description: "argparse.ArgumentParser().add_help == True — help action added by default"
  category: ArgumentParser
  kind: python_call_eq
  function: ArgumentParser
  args: []
  method: add_help
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# Formatter __name__ standalone invariants.
# argparse.zspec.zsdl and argparse_extra3 cover these in tables; standalone
# invariants here provide independent tracking IDs for coverage accounting.
# ---------------------------------------------------------------------------

invariant argparse_extra7.HelpFormatter.name:
  description: "argparse.HelpFormatter.__name__ == 'HelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: HelpFormatter.__name__.__eq__
  args: ["HelpFormatter"]
  expected: true

invariant argparse_extra7.RawDescriptionHelpFormatter.name:
  description: "argparse.RawDescriptionHelpFormatter.__name__ == 'RawDescriptionHelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: RawDescriptionHelpFormatter.__name__.__eq__
  args: ["RawDescriptionHelpFormatter"]
  expected: true

invariant argparse_extra7.MetavarTypeHelpFormatter.name:
  description: "argparse.MetavarTypeHelpFormatter.__name__ == 'MetavarTypeHelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: MetavarTypeHelpFormatter.__name__.__eq__
  args: ["MetavarTypeHelpFormatter"]
  expected: true
