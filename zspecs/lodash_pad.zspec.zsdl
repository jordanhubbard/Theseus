spec: lodash_pad
version: ">=4.0.0"
backend: node(lodash.pad)

docs: https://lodash.com/docs/#pad

provenance:
  derived_from:
    - "lodash.pad README — https://www.npmjs.com/package/lodash.pad"
    - "Test vectors verified with lodash.pad@4.5.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pad exports the _.pad function directly as module.exports."
    - "pad(string, length, chars) pads string on both sides to the given length."
    - "Pads with spaces by default. Extra padding added to the right when length is odd."
    - "pad('abc', 9) → '   abc   ' (3 spaces each side for even split)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a padded string. Returns original if length <= string length."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pad.pad:
  kind: node_module_call_eq
  function: ~
  category: pad
  id_prefix: lpad

  columns: [id, args, expected]
  rows:
    - [even_spaces,    ["abc", 9],          "   abc   "]
    - [custom_char,    ["abc", 9, "-"],      "---abc---"]
    - [no_padding,     ["hello", 3],         "hello"]
    - [exact_length,   ["abc", 3],           "abc"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
