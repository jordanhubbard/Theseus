spec: abc_extra7
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra6.zspec.zsdl."
    - "Focus: __module__ for deprecated decorators; __class__.__name__ for ABCMeta and deprecated types."
    - "abc.abstractproperty.__module__ == 'abc' — deprecated since 3.3, still present in 3.12."
    - "abc.abstractclassmethod.__module__ == 'abc' — deprecated since 3.3, still present in 3.12."
    - "abc.abstractstaticmethod.__module__ == 'abc' — deprecated since 3.3, still present in 3.12."
    - "abc.ABCMeta.__class__.__name__ == 'type' — ABCMeta is itself a class whose metaclass is the builtin type."
    - "abc.abstractproperty.__class__.__name__ == 'type' — abstractproperty is a class (type), not a plain function."
    - "abc.abstractclassmethod.__class__.__name__ == 'type' — abstractclassmethod is a class."
    - "abc.abstractstaticmethod.__class__.__name__ == 'type' — abstractstaticmethod is a class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for deprecated abstract decorators
#
# abc_extra6 covers __qualname__ and __name__ for abstractproperty,
# abstractclassmethod, abstractstaticmethod. This spec adds __module__,
# confirming all three are defined in the abc module itself.
# ---------------------------------------------------------------------------

table abc_extra7.deprecated_modules:
  kind: python_call_eq
  category: deprecated
  id_prefix: depmod

  columns: [id, function, args, expected]
  rows:
    - [abstractproperty,     abstractproperty.__module__.__eq__,     ["abc"], true]
    - [abstractclassmethod,  abstractclassmethod.__module__.__eq__,  ["abc"], true]
    - [abstractstaticmethod, abstractstaticmethod.__module__.__eq__, ["abc"], true]

# ---------------------------------------------------------------------------
# ABCMeta type check — ABCMeta.__class__.__name__ == 'type'
#
# ABCMeta is a class whose metaclass is the built-in 'type'. This is distinct
# from abc_extra5 which checks ABC.__class__.__name__ == 'ABCMeta'.
# abc.zspec.zsdl checks ABCMeta.__bases__[0].__name__ == 'type'.
# This invariant checks ABCMeta's own metaclass via __class__.__name__.
# ---------------------------------------------------------------------------

invariant abc_extra7.ABCMeta.metaclass_name:
  description: "abc.ABCMeta.__class__.__name__ == 'type' — ABCMeta is an instance of the builtin type"
  category: class_types
  kind: python_call_eq
  function: ABCMeta.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Deprecated decorators — __class__.__name__ checks
#
# abstractproperty, abstractclassmethod, and abstractstaticmethod are all
# class objects (type instances), not plain functions. This distinguishes them
# from abstractmethod which is a plain function.
# abc_extra6 verified their __name__ and __qualname__; abc_extra5 notes that
# abstractmethod.__class__.__name__ == 'function'. This spec adds type checks
# for the three deprecated class-based decorators.
# ---------------------------------------------------------------------------

invariant abc_extra7.abstractproperty.class_type:
  description: "abc.abstractproperty.__class__.__name__ == 'type' — abstractproperty is a class"
  category: deprecated_types
  kind: python_call_eq
  function: abstractproperty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra7.abstractclassmethod.class_type:
  description: "abc.abstractclassmethod.__class__.__name__ == 'type' — abstractclassmethod is a class"
  category: deprecated_types
  kind: python_call_eq
  function: abstractclassmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra7.abstractstaticmethod.class_type:
  description: "abc.abstractstaticmethod.__class__.__name__ == 'type' — abstractstaticmethod is a class"
  category: deprecated_types
  kind: python_call_eq
  function: abstractstaticmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true
