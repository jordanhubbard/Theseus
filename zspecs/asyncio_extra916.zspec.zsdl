    - [as916q003, asyncio.Queue.__class__.__name__.__eq__,           ["type"],                 true]
    - [as916q004, asyncio.LifoQueue.__qualname__.__eq__,             ["LifoQueue"],            true]
    - [as916q005, asyncio.PriorityQueue.__qualname__.__eq__,         ["PriorityQueue"],        true]
    - [as916q006, asyncio.QueueEmpty.__qualname__.__eq__,            ["QueueEmpty"],           true]
    - [as916q007, asyncio.QueueFull.__qualname__.__eq__,             ["QueueFull"],            true]

table asyncio_extra916.sync_primitive_qualnames:
