spec: asyncio_extra916
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module Task, Future, Queue, Lock, Event, Semaphore, Condition documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio class __qualname__ identity for core synchronization and task primitives"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra916.task_future_qualnames:
  description: "asyncio.Task and asyncio.Future __qualname__ identity"
  kind: python_call_eq
  category: task_future_qualnames
  id_prefix: as916tf
  columns: [id, function, args, expected]
  rows:
    - [as916tf001, asyncio.Task.__qualname__.__eq__,                 ["Task"],                 true]
    - [as916tf002, asyncio.Future.__qualname__.__eq__,               ["Future"],               true]
    - [as916tf003, asyncio.Task.__module__.__eq__,                   ["asyncio.tasks"],        true]
    - [as916tf004, asyncio.Future.__module__.__eq__,                 ["asyncio.futures"],      true]
    - [as916tf005, asyncio.Task.__class__.__name__.__eq__,           ["type"],                 true]
    - [as916tf006, asyncio.Future.__class__.__name__.__eq__,         ["type"],                 true]
    - [as916tf007, asyncio.Task.__qualname__.__class__.__name__.__eq__, ["str"],               true]

