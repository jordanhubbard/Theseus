spec: socket_extra107
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra106.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/ICMP/IPV6 class names (all 'int') and integer values / SOL_SOCKET class name (int) and value (65535) / IPPROTO_TCP class module ('builtins') and bases ('object') (table + invariants)."
    - "socket_extra105.zspec.zsdl — covers AF_*/SOCK_* class module/qualname/mro / AF_*/SOCK_* IntEnum base and int values / AddressFamily/SocketKind name/module/metaclass/base identity (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types (method_descriptor) / socket.socket method qualname lengths / socket.socket Python-level method types (function) and class identity (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop __class__.__name__ and qualname lengths / htons/htonl/ntohs/ntohl class names and qualname lengths / herror/gaierror __mro__.__len__()==5 / AddressFamily/SocketKind __mro__.__len__()==6 (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket/__qualname__/__name__/__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra106; it does NOT duplicate invariants present in those files."
    - "Wave 269 theme: socket SO_* option constants (SO_REUSEADDR, SO_KEEPALIVE, SO_SNDBUF, SO_RCVBUF, SO_REUSEPORT) class names and integer values / socket.error and socket.timeout class identity and MRO."
    - "socket.SO_REUSEADDR.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SO_REUSEADDR) == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_KEEPALIVE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SO_KEEPALIVE) == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_SNDBUF.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SO_SNDBUF) == 4097. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_RCVBUF.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SO_RCVBUF) == 4098. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_REUSEPORT.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SO_REUSEPORT) == 512. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__mro__.__len__() == 4 (OSError, Exception, BaseException, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__mro__.__len__() == 5 (TimeoutError, OSError, Exception, BaseException, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_REUSEADDR.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_REUSEADDR.__class__.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: SO_REUSEADDR=4, SO_KEEPALIVE=8, SO_REUSEPORT=512 on macOS/Darwin 25.4.0. SO_SNDBUF=4097 (0x1001) and SO_RCVBUF=4098 (0x1002) are macOS-specific values; Linux uses SO_SNDBUF=7 and SO_RCVBUF=8."
    - "Note: All SO_* constants are plain 'int' objects (not IntEnum like AF_INET/SOCK_STREAM). Their __class__.__module__ is 'builtins' and __class__.__bases__[0].__name__ is 'object'. This is the same pattern as IPPROTO_* constants (anchored in extra106)."
    - "Note: socket.error is an alias for OSError (socket.error is OSError evaluates to True). socket.timeout is an alias for TimeoutError. MRO: error(OSError)=4, timeout(TimeoutError)=5."
    - "Note: socket.error.__mro__ is (OSError, Exception, BaseException, object) — depth 4. socket.timeout.__mro__ is (TimeoutError, OSError, Exception, BaseException, object) — depth 5. extra103 anchors herror/gaierror with MRO depth 5; error has depth 4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.SO_REUSEADDR.__class__.__name__.__eq__('int')
# socket.SO_KEEPALIVE.__class__.__name__.__eq__('int')
# socket.SO_SNDBUF.__class__.__name__.__eq__('int')
# socket.SO_RCVBUF.__class__.__name__.__eq__('int')
# socket.SO_REUSEPORT.__class__.__name__.__eq__('int')
#
# Wave 269 theme: SO_* option constants are plain 'int' objects.
#
# SO_REUSEADDR, SO_KEEPALIVE, SO_SNDBUF, SO_RCVBUF, and SO_REUSEPORT are
# plain Python int objects (not IntEnum like AF_INET or SOCK_STREAM). Their
# __class__.__name__ is 'int'. This is the same pattern as IPPROTO_* constants
# anchored in socket_extra106. socket_extra96 anchors AF_*/SOCK_* as IntEnum.
# No prior socket spec anchors SO_* __class__.__name__ as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra107.SO_option_class_names:
  description: "SO_REUSEADDR.__class__.__name__.__eq__('int')==True / SO_KEEPALIVE.__class__.__name__.__eq__('int')==True / SO_SNDBUF.__class__.__name__.__eq__('int')==True / SO_RCVBUF.__class__.__name__.__eq__('int')==True / SO_REUSEPORT.__class__.__name__.__eq__('int')==True — all SO_* constants are plain 'int' (not IntEnum); same pattern as IPPROTO_* constants (extra106); extra96 anchors AF_*/SOCK_* as IntEnum; no prior socket spec anchors SO_* class names; first sockso107 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockso107

  columns: [id, function, args, expected, description]
  rows:
    - [so_reuseaddr_class,  "SO_REUSEADDR.__class__.__name__.__eq__",  ["int"], true, "SO_REUSEADDR.__class__.__name__ is 'int' (plain int, not IntEnum)"]
    - [so_keepalive_class,  "SO_KEEPALIVE.__class__.__name__.__eq__",  ["int"], true, "SO_KEEPALIVE.__class__.__name__ is 'int' (plain int, not IntEnum)"]
    - [so_sndbuf_class,     "SO_SNDBUF.__class__.__name__.__eq__",     ["int"], true, "SO_SNDBUF.__class__.__name__ is 'int' (plain int, not IntEnum)"]
    - [so_rcvbuf_class,     "SO_RCVBUF.__class__.__name__.__eq__",     ["int"], true, "SO_RCVBUF.__class__.__name__ is 'int' (plain int, not IntEnum)"]
    - [so_reuseport_class,  "SO_REUSEPORT.__class__.__name__.__eq__",  ["int"], true, "SO_REUSEPORT.__class__.__name__ is 'int' (plain int, not IntEnum)"]

# ---------------------------------------------------------------------------
# int(socket.SO_REUSEADDR).__eq__(4)
# int(socket.SO_KEEPALIVE).__eq__(8)
# int(socket.SO_SNDBUF).__eq__(4097)
# int(socket.SO_RCVBUF).__eq__(4098)
# int(socket.SO_REUSEPORT).__eq__(512)
#
# Wave 269 theme: SO_* option constant integer values on macOS/Darwin 25.4.0.
#
# SO_REUSEADDR=4, SO_KEEPALIVE=8, SO_REUSEPORT=512 are used as the optname
# argument to getsockopt/setsockopt at the SOL_SOCKET level (SOL_SOCKET=65535
# on macOS, anchored in extra106). SO_SNDBUF=4097 (0x1001) and SO_RCVBUF=4098
# (0x1002) are macOS-specific values; Linux uses SO_SNDBUF=7 and SO_RCVBUF=8.
# No prior socket spec anchors SO_* integer values as a grouped table under
# sockso107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra107.SO_option_int_values:
  description: "int(SO_REUSEADDR)==4 / int(SO_KEEPALIVE)==8 / int(SO_SNDBUF)==4097 / int(SO_RCVBUF)==4098 / int(SO_REUSEPORT)==512 — SO_REUSEADDR=4, SO_KEEPALIVE=8, SO_REUSEPORT=512 on macOS; SO_SNDBUF=4097(0x1001) and SO_RCVBUF=4098(0x1002) are macOS-specific (Linux uses 7 and 8); all used as optname arg with SOL_SOCKET(65535) in getsockopt/setsockopt; no prior socket spec anchors SO_* int values; first sockso107 anchor"
  kind: python_call_eq
  category: constant_values
  id_prefix: sockso107

  columns: [id, function, args, expected, description]
  rows:
    - [so_reuseaddr_val,  "SO_REUSEADDR.__int__",  [],    4,    "int(SO_REUSEADDR)==4 — enable/disable reuse of local address (macOS/Darwin value)"]
    - [so_keepalive_val,  "SO_KEEPALIVE.__int__",  [],    8,    "int(SO_KEEPALIVE)==8 — enable/disable keepalive probes on idle TCP connections"]
    - [so_sndbuf_val,     "SO_SNDBUF.__int__",     [], 4097,    "int(SO_SNDBUF)==4097 (0x1001) — send buffer size option (macOS-specific; Linux uses 7)"]
    - [so_rcvbuf_val,     "SO_RCVBUF.__int__",     [], 4098,    "int(SO_RCVBUF)==4098 (0x1002) — receive buffer size option (macOS-specific; Linux uses 8)"]
    - [so_reuseport_val,  "SO_REUSEPORT.__int__",  [],  512,    "int(SO_REUSEPORT)==512 — enable reuse of local port (macOS/Darwin value)"]

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError')
# socket.error.__bases__[0].__name__.__eq__('Exception')
# socket.error.__mro__.__len__()==4
# socket.timeout.__name__.__eq__('TimeoutError')
# socket.timeout.__mro__.__len__()==5
#
# Wave 269 theme: socket.error and socket.timeout class identity and MRO.
#
# socket.error is an alias for OSError (__name__=='OSError'). Its MRO is
# (OSError, Exception, BaseException, object) — depth 4. socket.timeout is
# an alias for TimeoutError (__name__=='TimeoutError'). Its MRO is
# (TimeoutError, OSError, Exception, BaseException, object) — depth 5.
# socket_extra102 anchors socket.error.__name__=='OSError' via __eq__; this
# spec groups error and timeout class identity and MRO depths as a new table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra107.error_and_timeout_identity:
  description: "error.__name__.__eq__('OSError')==True / error.__bases__[0].__name__.__eq__('Exception')==True / error.__mro__.__len__()==4 / timeout.__name__.__eq__('TimeoutError')==True / timeout.__mro__.__len__()==5 — socket.error is OSError alias (MRO depth 4: OSError,Exception,BaseException,object); socket.timeout is TimeoutError alias (MRO depth 5: +OSError before Exception); extra102 anchors error.__name__=='OSError' but not MRO depth; no prior spec anchors timeout.__name__/MRO; first sockso107 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockso107

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,        "error.__name__.__eq__",               ["OSError"],      true, "socket.error.__name__ is 'OSError' (socket.error is an alias for OSError)"]
    - [error_bases_eq,       "error.__bases__[0].__name__.__eq__",  ["Exception"],    true, "socket.error.__bases__[0].__name__ is 'Exception' (OSError directly inherits from Exception)"]
    - [error_mro_len,        "error.__mro__.__len__",               [],               4,    "socket.error.__mro__.__len__() is 4 (OSError, Exception, BaseException, object)"]
    - [timeout_name_eq,      "timeout.__name__.__eq__",             ["TimeoutError"], true, "socket.timeout.__name__ is 'TimeoutError' (socket.timeout is an alias for TimeoutError)"]
    - [timeout_mro_len,      "timeout.__mro__.__len__",             [],               5,    "socket.timeout.__mro__.__len__() is 5 (TimeoutError, OSError, Exception, BaseException, object)"]

# ---------------------------------------------------------------------------
# int(socket.SO_REUSEADDR).__eq__(4) — standalone
#
# int(socket.SO_REUSEADDR) is 4 on macOS/Darwin 25.4.0. SO_REUSEADDR is used
# with setsockopt(SOL_SOCKET, SO_REUSEADDR, 1) to allow a socket to bind to
# a local address that is already in use (e.g., after a server restart while
# the previous socket is in TIME_WAIT state). SO_REUSEADDR=4 is the macOS/Darwin
# value. No prior socket spec anchors SO_REUSEADDR's integer value as a
# standalone under sockso107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra107.SO_REUSEADDR_val_4:
  description: "int(socket.SO_REUSEADDR) == 4 — macOS/Darwin 25.4.0 value; used with setsockopt(SOL_SOCKET, SO_REUSEADDR, 1) to allow binding to TIME_WAIT addresses; SOL_SOCKET=65535 on macOS (anchored in extra106); no prior socket spec anchors SO_REUSEADDR value as standalone; first standalone under sockso107"
  category: constant_values
  kind: python_call_eq
  function: "SO_REUSEADDR.__int__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# int(socket.SO_KEEPALIVE).__eq__(8) — standalone
#
# int(socket.SO_KEEPALIVE) is 8 on macOS/Darwin 25.4.0. SO_KEEPALIVE is used
# with setsockopt(SOL_SOCKET, SO_KEEPALIVE, 1) to enable TCP keepalive probes
# on idle connections. When enabled, the OS periodically sends keepalive probes
# and closes the connection if the peer does not respond, preventing silent
# half-open connections. SO_KEEPALIVE=8 is the macOS/Darwin value. No prior
# socket spec anchors SO_KEEPALIVE's value as a standalone under sockso107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra107.SO_KEEPALIVE_val_8:
  description: "int(socket.SO_KEEPALIVE) == 8 — macOS/Darwin 25.4.0 value; used with setsockopt(SOL_SOCKET, SO_KEEPALIVE, 1) to enable TCP keepalive probes on idle connections; prevents silent half-open connections; no prior socket spec anchors SO_KEEPALIVE value as standalone; first standalone under sockso107"
  category: constant_values
  kind: python_call_eq
  function: "SO_KEEPALIVE.__int__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# socket.error.__mro__.__len__()==4 — standalone
#
# socket.error.__mro__.__len__() is 4. socket.error is an alias for OSError.
# The MRO is (OSError, Exception, BaseException, object) — depth 4.
# This contrasts with socket.timeout (alias for TimeoutError) which has MRO
# depth 5 (TimeoutError, OSError, Exception, BaseException, object). Also
# contrasts with socket.herror and socket.gaierror which have MRO depth 5
# (anchored in socket_extra103). socket_extra102 anchors socket.error.__name__
# equality but not MRO depth; no prior socket spec anchors error MRO depth as
# a standalone under sockso107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra107.socket_error_mro_len_4:
  description: "socket.error.__mro__.__len__() == 4 — MRO is (OSError, Exception, BaseException, object); depth 4 contrasts with timeout (depth 5) and herror/gaierror (depth 5, anchored in extra103); extra102 anchors error.__name__=='OSError' but not MRO depth; first standalone under sockso107"
  category: type_identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError'. socket.timeout is an alias for
# the built-in TimeoutError exception (not a socket-specific exception class).
# In Python 3.3+, socket.timeout was merged with the built-in TimeoutError,
# so socket.timeout is TimeoutError evaluates to True. Its __name__ is
# 'TimeoutError' (not 'timeout'), reflecting its role as the built-in timeout
# exception. No prior socket spec anchors socket.timeout.__name__ as a
# standalone under sockso107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra107.socket_timeout_name_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout is an alias for the built-in TimeoutError; merged in Python 3.3+ (socket.timeout is TimeoutError evaluates to True); __name__ is 'TimeoutError' not 'timeout'; no prior socket spec anchors socket.timeout.__name__ as standalone; first standalone under sockso107"
  category: type_identity
  kind: python_call_eq
  function: "timeout.__name__.__eq__"
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# int(socket.SO_SNDBUF).__eq__(4097) — standalone
#
# int(socket.SO_SNDBUF) is 4097 (0x1001) on macOS/Darwin 25.4.0. SO_SNDBUF
# is used with getsockopt/setsockopt to get/set the send buffer size for a
# socket. The macOS value 4097 (0x1001) differs from Linux which uses 7.
# This platform difference is significant for portable socket programming.
# SO_SNDBUF and SO_RCVBUF form a pair: SNDBUF=4097, RCVBUF=4098 (consecutive
# hex values 0x1001 and 0x1002 on macOS). No prior socket spec anchors
# SO_SNDBUF's value as a standalone under sockso107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra107.SO_SNDBUF_val_4097:
  description: "int(socket.SO_SNDBUF) == 4097 — macOS/Darwin value 0x1001; Linux uses SO_SNDBUF=7; SO_SNDBUF and SO_RCVBUF are consecutive: 0x1001/0x1002 on macOS; used with getsockopt/setsockopt to get/set send buffer size; platform portability concern; no prior socket spec anchors SO_SNDBUF value as standalone; first standalone under sockso107"
  category: constant_values
  kind: python_call_eq
  function: "SO_SNDBUF.__int__"
  args: []
  expected: 4097

