spec: concurrent_futures_extra1936
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor, InterpreterPoolExecutor, BrokenExecutor, InvalidStateError, CancelledError, TimeoutError are not descriptor types."
    - "None of the concurrent.futures classes define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "concurrent.futures module __class__.__name__ == 'module'; concurrent.futures class objects have __class__.__name__ == 'type'."
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra1936.descriptor_get:
  description: "concurrent.futures types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1936

  columns: [id, function, args, expected]
  rows:
    - ["cf1936001", "concurrent.futures.Future.__dict__.__contains__",                 ["__get__"], false]
    - ["cf1936002", "concurrent.futures.Executor.__dict__.__contains__",               ["__get__"], false]
    - ["cf1936003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",     ["__get__"], false]
    - ["cf1936004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",    ["__get__"], false]
    - ["cf1936005", "concurrent.futures.BrokenExecutor.__dict__.__contains__",         ["__get__"], false]
    - ["cf1936006", "concurrent.futures.CancelledError.__dict__.__contains__",         ["__get__"], false]
    - ["cf1936007", "concurrent.futures.TimeoutError.__dict__.__contains__",           ["__get__"], false]
    - ["cf1936008", "concurrent.futures.InvalidStateError.__dict__.__contains__",      ["__get__"], false]

