spec: tokenize_extra8
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int type checks; tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ for tokenize/generate_tokens/detect_encoding/open/untokenize, ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER int type checks"
    - "tokenize_extra2.zspec.zsdl — covers TokenInfo/__name__, TokenInfo/_fields/__len__()==5, _fields membership, _fields[0]=='type', _fields[1]=='string', function __name__ table, COMMENT is_int"
    - "tokenize_extra3.zspec.zsdl — covers function __module__ table (tokenize/generate_tokens/untokenize/detect_encoding), TokenError/__name__/__module__/bases, TokenInfo/__name__/__module__/bases/bases_len, token constant int checks, untokenize/__name__, TokenInfo bases_len"
    - "tokenize_extra4.zspec.zsdl — covers _fields[2-4], open/__module__, TokenError/__bases__/__len__()==1, TokenInfo/__qualname__, TokenError/__qualname__, function __qualname__ table"
    - "tokenize_extra5.zspec.zsdl — covers open/__qualname__, ERRORTOKEN/__class__/__name__, TYPE_COMMENT/__class__/__name__"
    - "tokenize_extra6.zspec.zsdl — covers TokenInfo/_make/__name__, TokenInfo/_asdict/__name__, TokenInfo/_replace/__name__, TokenInfo/_fields is_tuple, token constant exact values (ENDMARKER=0, TYPE_COMMENT=57, COMMENT=65, NL=66, ERRORTOKEN=67)"
    - "tokenize_extra7.zspec.zsdl — covers NAME=1/NUMBER=2/STRING=3/NEWLINE=4 exact values (table); INDENT=5/DEDENT=6/OP=55/ENCODING=68 exact values (table); TokenError/__class__/__name__=='type', TokenInfo/__class__/__name__=='type', open/__class__.__name__=='function'; tokenize/generate_tokens/detect_encoding/untokenize __class__.__name__=='function' (table)"
  notes:
    - "This spec adds invariants not covered in any prior tokenize spec."
    - "Focus: standalone extra8-namespace anchors for function __module__ checks (tokenize and generate_tokens) and standalone exact-value anchors for core token constants re-exported from the token module."
    - "tokenize.tokenize.__module__ == 'tokenize' — extra3 covers this in a table; extra8 provides a standalone invariant with an extra8-namespace ID."
    - "tokenize.generate_tokens.__module__ == 'tokenize' — extra3 covers this in a table; extra8 provides a standalone invariant with an extra8-namespace ID."
    - "tokenize.NAME == 1 — exact value covered in extra7 table (core_token_exact_values); extra8 standalone anchor."
    - "tokenize.NUMBER == 2 — exact value covered in extra7 table; extra8 standalone anchor."
    - "tokenize.STRING == 3 — exact value covered in extra7 table; extra8 standalone anchor."
    - "tokenize.NEWLINE == 4 — exact value covered in extra7 table; extra8 standalone anchor."
    - "tokenize.ENDMARKER == 0 — exact value covered in extra6 table; extra8 standalone anchor."
    - "tokenize.INDENT == 5 — exact value covered in extra7 table; extra8 standalone anchor."
    - "tokenize.DEDENT == 6 — exact value covered in extra7 table; extra8 standalone anchor."
    - "tokenize.COMMENT == 65 — exact value established in extra6 for Python 3.12; extra8 standalone anchor."
    - "tokenize.NL == 66 — exact value established in extra6 for Python 3.12; extra8 standalone anchor."
    - "tokenize.ENCODING == 68 — exact value established in extra7 for Python 3.12; extra8 standalone anchor."
    - "tokenize.OP == 55 — exact value established in extra7 for Python 3.12; extra8 standalone anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ — standalone extra8-namespace invariants
# tokenize_extra3 covers these in a table; extra8 provides standalone IDs.
# ---------------------------------------------------------------------------

invariant tokenize_extra8.tokenize.module:
  description: "tokenize.tokenize.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: tokenize.__module__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra8.generate_tokens.module:
  description: "tokenize.generate_tokens.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: generate_tokens.__module__.__eq__
  args: ["tokenize"]
  expected: true

# ---------------------------------------------------------------------------
# Core token constant exact values — standalone extra8-namespace invariants
# Extra7 table covers NAME=1, NUMBER=2, STRING=3, NEWLINE=4, INDENT=5, DEDENT=6,
# OP=55, ENCODING=68. Extra6 table covers ENDMARKER=0, COMMENT=65, NL=66.
# These standalone invariants provide extra8-namespace anchors for each.
# ---------------------------------------------------------------------------

invariant tokenize_extra8.NAME.value:
  description: "tokenize.NAME == 1 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: NAME.__eq__
  args: [1]
  expected: true

invariant tokenize_extra8.NUMBER.value:
  description: "tokenize.NUMBER == 2 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: NUMBER.__eq__
  args: [2]
  expected: true

invariant tokenize_extra8.STRING.value:
  description: "tokenize.STRING == 3 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: STRING.__eq__
  args: [3]
  expected: true

invariant tokenize_extra8.NEWLINE.value:
  description: "tokenize.NEWLINE == 4 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: NEWLINE.__eq__
  args: [4]
  expected: true

invariant tokenize_extra8.ENDMARKER.value:
  description: "tokenize.ENDMARKER == 0 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: ENDMARKER.__eq__
  args: [0]
  expected: true

invariant tokenize_extra8.INDENT.value:
  description: "tokenize.INDENT == 5 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: INDENT.__eq__
  args: [5]
  expected: true

invariant tokenize_extra8.DEDENT.value:
  description: "tokenize.DEDENT == 6 — re-exported from token module, exact value"
  category: constants
  kind: python_call_eq
  function: DEDENT.__eq__
  args: [6]
  expected: true

invariant tokenize_extra8.COMMENT.value:
  description: "tokenize.COMMENT == 65 — exact value on Python 3.12, established in extra6"
  category: constants
  kind: python_call_eq
  function: COMMENT.__eq__
  args: [65]
  expected: true

invariant tokenize_extra8.NL.value:
  description: "tokenize.NL == 66 — exact value on Python 3.12, established in extra6"
  category: constants
  kind: python_call_eq
  function: NL.__eq__
  args: [66]
  expected: true

invariant tokenize_extra8.ENCODING.value:
  description: "tokenize.ENCODING == 68 — exact value on Python 3.12, established in extra7"
  category: constants
  kind: python_call_eq
  function: ENCODING.__eq__
  args: [68]
  expected: true

invariant tokenize_extra8.OP.value:
  description: "tokenize.OP == 55 — exact value on Python 3.12, established in extra7"
  category: constants
  kind: python_call_eq
  function: OP.__eq__
  args: [55]
  expected: true
