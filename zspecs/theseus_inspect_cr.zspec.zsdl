spec: theseus_inspect_cr
version: ">=3.9"
backend: python_cleanroom(theseus_inspect_cr)
blocks: inspect

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
  notes:
    - "Clean-room code introspection utilities. Do NOT import inspect."
    - "isfunction(obj): True if obj is a Python function."
    - "isclass(obj): True if obj is a class."
    - "getmembers(obj): list of (name, value) pairs for all members."
    - "signature(fn): function signature with parameter names."
    - "inspect_isfunction(): isfunction(lambda: None) == True."
    - "inspect_isclass(): isclass(int) == True."
    - "inspect_getmembers_has_dunder(): '__class__' in dict(getmembers(42))."
    - "Export: isfunction, isclass, ismethod, ismodule, getmembers, getsource."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_inspect_cr.isfunction:
  description: "isfunction(lambda: None) == True"
  category: predicates
  kind: python_call_eq
  function: inspect_isfunction
  args: []
  expected: true

invariant theseus_inspect_cr.isclass:
  description: "isclass(int) == True"
  category: predicates
  kind: python_call_eq
  function: inspect_isclass
  args: []
  expected: true

invariant theseus_inspect_cr.isfunction_str:
  description: "isfunction('hello') == False"
  category: predicates
  kind: python_call_eq
  function: inspect_isfunction_str
  args: []
  expected: false
