spec: time_extra20
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra19.zspec.zsdl — covers tzname len (2) and class name len (5); struct_time __mro__/__bases__[0]/__name__/__dict__ lengths; n_sequence_fields (9), n_unnamed_fields (0), n_fields (11); process_time_ns (15), thread_time (11), thread_time_ns (14), get_clock_info (14) qualname lengths."
    - "time_extra18.zspec.zsdl — covers __qualname__.__len__() for time(4)/sleep(5)/monotonic(9)/perf_counter(12)/process_time(12)/gmtime(6)/localtime(9); __name__/__module__.__len__() for gmtime through perf_counter_ns."
    - "time_extra17.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time."
  notes:
    - "This spec extends time_extra19.zspec.zsdl."
    - "Prior specs covered: time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/ctime/struct_time __name__/__module__/__qualname__ and lengths; timezone/altzone/daylight __class__.__name__; monotonic_ns/__name__; qualname lengths for 11 timing functions; n_sequence/unnamed/fields constants."
    - "This spec covers NEW angles: mktime (6), strftime (8), strptime (8), asctime (7), ctime (5), monotonic_ns (12), perf_counter_ns (15), time_ns (7), clock_getres (12), clock_gettime (13), clock_gettime_ns (16), clock_settime (13), clock_settime_ns (16), tzset (5) __qualname__.__len__(); time.__name__.__len__()==4; time.timezone/__class__.__name__.__len__()==3; time.altzone/__class__.__name__.__len__()==3; time.daylight/__class__.__name__.__len__()==3."
    - "clock_gettime_ns (16) and clock_settime_ns (16) are the longest qualnames in the time module; they tie for the series maximum."
    - "monotonic_ns (12) ties perf_counter (12), process_time (12), clock_getres (12), and monotonic_ns (12) for mid-range."
    - "time.timezone, time.altzone, time.daylight are all plain int objects; class name 'int' has len 3."
    - "time.__name__ == 'time' (len 4) — module's own name attribute."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for conversion/formatting functions
#
# mktime/strftime/strptime were mentioned in earlier provenance notes but not
# covered as invariants. asctime and ctime have not appeared in any prior spec.
# All are C builtins with flat qualnames (qualname == name):
#   mktime  -> 'mktime'  (6)
#   strftime -> 'strftime' (8)
#   strptime -> 'strptime' (8)
#   asctime  -> 'asctime'  (7)
#   ctime    -> 'ctime'    (5)
# ---------------------------------------------------------------------------

table time_extra20.conversion_function_qualname_lens:
  description: "__qualname__.__len__() for mktime (6), strftime (8), strptime (8), asctime (7), ctime (5)"
  kind: python_call_eq
  category: function_identity
  id_prefix: tqa20a

  columns: [id, function, args, expected]
  rows:
    - [mktime,   mktime.__qualname__.__len__,   [], 6]
    - [strftime, strftime.__qualname__.__len__,  [], 8]
    - [strptime, strptime.__qualname__.__len__,  [], 8]
    - [asctime,  asctime.__qualname__.__len__,   [], 7]
    - [ctime,    ctime.__qualname__.__len__,     [], 5]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for nanosecond and clock API functions
#
# These functions extend the time module's nanosecond and POSIX clock
# interfaces. None have been covered in any prior time spec:
#   monotonic_ns    -> 'monotonic_ns'    (12)
#   perf_counter_ns -> 'perf_counter_ns' (15)
#   time_ns         -> 'time_ns'         (7)
#   clock_getres    -> 'clock_getres'    (12) — resolution query
#   clock_gettime   -> 'clock_gettime'   (13)
#   clock_gettime_ns -> 'clock_gettime_ns' (16) — longest in module
#   clock_settime   -> 'clock_settime'   (13)
#   clock_settime_ns -> 'clock_settime_ns' (16) — tied with clock_gettime_ns
#   tzset           -> 'tzset'           (5)
# ---------------------------------------------------------------------------

table time_extra20.nanosecond_and_clock_qualname_lens:
  description: "__qualname__.__len__() for monotonic_ns (12), perf_counter_ns (15), time_ns (7), clock_getres (12), clock_gettime (13), clock_gettime_ns (16), clock_settime (13), clock_settime_ns (16), tzset (5)"
  kind: python_call_eq
  category: function_identity
  id_prefix: tqa20b

  columns: [id, function, args, expected]
  rows:
    - [monotonic_ns,     monotonic_ns.__qualname__.__len__,     [], 12]
    - [perf_counter_ns,  perf_counter_ns.__qualname__.__len__,  [], 15]
    - [time_ns,          time_ns.__qualname__.__len__,           [],  7]
    - [clock_getres,     clock_getres.__qualname__.__len__,      [], 12]
    - [clock_gettime,    clock_gettime.__qualname__.__len__,     [], 13]
    - [clock_gettime_ns, clock_gettime_ns.__qualname__.__len__,  [], 16]
    - [clock_settime,    clock_settime.__qualname__.__len__,     [], 13]
    - [clock_settime_ns, clock_settime_ns.__qualname__.__len__,  [], 16]
    - [tzset,            tzset.__qualname__.__len__,              [],  5]

# ---------------------------------------------------------------------------
# time module integer constants — class name lengths
#
# time.timezone, time.altzone, and time.daylight are all plain int objects.
# 'int' has 3 characters. No prior time spec records these __class__.__name__
# lengths (extra19 notes mention the values but does not record __class__.__name__
# for altzone or daylight).
# ---------------------------------------------------------------------------

table time_extra20.integer_constant_class_name_lens:
  description: "time.timezone/__class__.__name__.__len__() (3), altzone (3), daylight (3) — all are 'int'"
  kind: python_call_eq
  category: module_constants
  id_prefix: tqa20c

  columns: [id, function, args, expected]
  rows:
    - [timezone_class_name_len, timezone.__class__.__name__.__len__, [], 3]
    - [altzone_class_name_len,  altzone.__class__.__name__.__len__,  [], 3]
    - [daylight_class_name_len, daylight.__class__.__name__.__len__, [], 3]

# ---------------------------------------------------------------------------
# time.__name__.__len__() == 4 — standalone (extra20 namespace)
#
# The time module's __name__ attribute is 'time' (4 characters). No prior
# time spec records this standalone value.
# ---------------------------------------------------------------------------

invariant time_extra20.module_name_len:
  description: "time.__name__.__len__() == 4 — module name 'time' has 4 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 4
