spec: itertools_extra224
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools pairwise, batched, chain.from_iterable, and count.__new__ attribute contracts."
    - "itertools.pairwise.__name__ == 'pairwise' — pairwise added in Python 3.10. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.pairwise.__bases__[0].__name__ == 'object' — pairwise inherits directly from object. Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' — batched added in Python 3.12. Verified with Python 3.14.3."
    - "itertools.batched.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.batched.__bases__[0].__name__ == 'object' — batched inherits directly from object. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'. Verified with Python 3.14.3."
    - "itertools.count.__new__.__qualname__ == 'count.__new__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools pairwise and batched class attribute checks
#
# Verified with Python 3.14.3:
#   itertools.pairwise.__name__ == 'pairwise'
#   itertools.pairwise.__module__ == 'itertools'
#   itertools.batched.__name__ == 'batched'
#   itertools.batched.__module__ == 'itertools'
# ---------------------------------------------------------------------------

table itertools_extra224.pairwise_batched_attrs:
  description: "itertools pairwise and batched class __name__ and __module__ checks; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra224pwbatch

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_name_eq,
       pairwise.__name__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise is a C extension type added in Python 3.10; its __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra224"]
    - [pairwise_module_eq,
       pairwise.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is defined in the itertools C extension module; str.__eq__('itertools') returns True; new to extra224"]
    - [batched_name_eq,
       batched.__name__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched is a C extension type added in Python 3.12; its __name__ is 'batched'; str.__eq__('batched') returns True; new to extra224"]
    - [batched_module_eq,
       batched.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is defined in the itertools C extension module; str.__eq__('itertools') returns True; new to extra224"]
    - [chain_from_iterable_name_eq,
       chain.from_iterable.__name__.__eq__,
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — chain.from_iterable is a classmethod descriptor; its __name__ is 'from_iterable'; str.__eq__('from_iterable') returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Table 2: itertools chain.from_iterable and count.__new__ attribute checks
#
# Verified with Python 3.14.3:
#   itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
#   itertools.count.__new__.__qualname__ == 'count.__new__'
# ---------------------------------------------------------------------------

table itertools_extra224.chain_count_attrs:
  description: "itertools chain.from_iterable __qualname__ and count.__new__.__qualname__ checks; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra224chaincount

  columns: [id, function, args, expected, description]
  rows:
    - [chain_from_iterable_qualname_eq,
       chain.from_iterable.__qualname__.__eq__,
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — qualname includes the owning class chain; str.__eq__('chain.from_iterable') returns True; new to extra224"]
    - [count_new_qualname_eq,
       count.__new__.__qualname__.__eq__,
       ["count.__new__"],
       true,
       "itertools.count.__new__.__qualname__.__eq__('count.__new__') == True — count.__new__ is defined as count.__new__ in the C extension; str.__eq__('count.__new__') returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra224
# ---------------------------------------------------------------------------

invariant itertools_extra224.pairwise_name:
  description: "itertools.pairwise.__name__ == 'pairwise' — pairwise added in Python 3.10; new to extra224"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra224.pairwise_module:
  description: "itertools.pairwise.__module__ == 'itertools' — pairwise is in the itertools module; new to extra224"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra224.pairwise_bases_name:
  description: "itertools.pairwise.__bases__[0].__name__ == 'object' — pairwise's sole base class is object; new to extra224"
  kind: python_call_eq
  function: pairwise.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant itertools_extra224.batched_name:
  description: "itertools.batched.__name__ == 'batched' — batched added in Python 3.12; new to extra224"
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra224.batched_module:
  description: "itertools.batched.__module__ == 'itertools' — batched is in the itertools module; new to extra224"
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra224.batched_bases_name:
  description: "itertools.batched.__bases__[0].__name__ == 'object' — batched's sole base class is object; new to extra224"
  kind: python_call_eq
  function: batched.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant itertools_extra224.chain_from_iterable_name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' — classmethod name; new to extra224"
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra224.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — qualname includes class; new to extra224"
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra224.count_new_qualname:
  description: "itertools.count.__new__.__qualname__ == 'count.__new__' — __new__ is bound to count; new to extra224"
  kind: python_call_eq
  function: count.__new__.__qualname__.__eq__
  args: ["count.__new__"]
  expected: true
