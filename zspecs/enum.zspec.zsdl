spec: enum
version: ">=3.6"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "Python enum documentation — https://docs.python.org/3/library/enum.html"
    - "Test vectors verified by running Python 3.14.3 enum module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "enum.Enum is the base class for all enumerations."
    - "The functional API enum.Enum(typename, names) creates an enum class from a space-separated string of member names."
    - "Members are auto-assigned integer values starting from 1 when created via the functional API."
    - "enum.IntEnum members are both enum members and integers (int subclass)."
    - "enum.Flag supports bitwise operations; member values are powers of two."
    - "enum.StrEnum members are both enum members and str instances (Python 3.11+)."
    - "enum._member_names_ is a list of member name strings on the enum class."
    - "enum.Enum class supports __len__ via EnumType metaclass."
    - "enum.auto() generates automatic values; outside a class body .value is _auto_null (implementation detail)."
    - "enum.unique is a decorator that raises ValueError if an enum has duplicate values."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class names — Enum, IntEnum, Flag, IntFlag, StrEnum, auto, unique
#
# Verifies that the module exports the expected names and that each is the
# correctly-typed object (class or function with the right __name__).
# ---------------------------------------------------------------------------

invariant enum.names.Enum:
  description: "enum.Enum.__name__ == 'Enum'"
  category: names
  kind: python_call_eq
  function: Enum.__name__.__eq__
  args: ["Enum"]
  expected: true

invariant enum.names.IntEnum:
  description: "enum.IntEnum.__name__ == 'IntEnum'"
  category: names
  kind: python_call_eq
  function: IntEnum.__name__.__eq__
  args: ["IntEnum"]
  expected: true

invariant enum.names.Flag:
  description: "enum.Flag.__name__ == 'Flag'"
  category: names
  kind: python_call_eq
  function: Flag.__name__.__eq__
  args: ["Flag"]
  expected: true

invariant enum.names.IntFlag:
  description: "enum.IntFlag.__name__ == 'IntFlag'"
  category: names
  kind: python_call_eq
  function: IntFlag.__name__.__eq__
  args: ["IntFlag"]
  expected: true

invariant enum.names.StrEnum:
  description: "enum.StrEnum.__name__ == 'StrEnum' (Python 3.11+)"
  category: names
  kind: python_call_eq
  function: StrEnum.__name__.__eq__
  args: ["StrEnum"]
  expected: true

invariant enum.names.auto:
  description: "enum.auto.__name__ == 'auto'"
  category: names
  kind: python_call_eq
  function: auto.__name__.__eq__
  args: ["auto"]
  expected: true

invariant enum.names.unique:
  description: "enum.unique.__name__ == 'unique'"
  category: names
  kind: python_call_eq
  function: unique.__name__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# Enum functional API — Enum(typename, names) creates an enumeration class
#
# enum.Enum('Color', 'RED GREEN BLUE') creates a Color enum with three members.
# Members are assigned integer values 1, 2, 3 automatically.
# We verify the class via __len__ and _member_names_.
# ---------------------------------------------------------------------------

invariant enum.functional.color_len:
  description: "len(enum.Enum('Color', 'RED GREEN BLUE')) == 3"
  category: functional
  kind: python_call_eq
  function: Enum
  args: ["Color", "RED GREEN BLUE"]
  method: __len__
  expected: 3

invariant enum.functional.color_member_names:
  description: "enum.Enum('Color', 'RED GREEN BLUE')._member_names_ == ['RED', 'GREEN', 'BLUE']"
  category: functional
  kind: python_call_eq
  function: Enum
  args: ["Color", "RED GREEN BLUE"]
  method: _member_names_
  expected: ["RED", "GREEN", "BLUE"]

invariant enum.functional.color_member_names_count:
  description: "len(enum.Enum('Color', 'RED GREEN BLUE')._member_names_) == 3"
  category: functional
  kind: python_call_eq
  function: Enum
  args: ["Color", "RED GREEN BLUE"]
  method: _member_names_
  method_chain: __len__
  expected: 3

invariant enum.functional.color_first_member:
  description: "enum.Enum('Color', 'RED GREEN BLUE')._member_names_[0] == 'RED'"
  category: functional
  kind: python_call_eq
  function: Enum
  args: ["Color", "RED GREEN BLUE"]
  method: _member_names_
  method_chain: __getitem__
  method_chain_args: [0]
  expected: "RED"

invariant enum.functional.color_second_member:
  description: "enum.Enum('Color', 'RED GREEN BLUE')._member_names_[1] == 'GREEN'"
  category: functional
  kind: python_call_eq
  function: Enum
  args: ["Color", "RED GREEN BLUE"]
  method: _member_names_
  method_chain: __getitem__
  method_chain_args: [1]
  expected: "GREEN"

invariant enum.functional.color_third_member:
  description: "enum.Enum('Color', 'RED GREEN BLUE')._member_names_[2] == 'BLUE'"
  category: functional
  kind: python_call_eq
  function: Enum
  args: ["Color", "RED GREEN BLUE"]
  method: _member_names_
  method_chain: __getitem__
  method_chain_args: [2]
  expected: "BLUE"

# ---------------------------------------------------------------------------
# IntEnum functional API
#
# enum.IntEnum('Status', 'ACTIVE INACTIVE PENDING') — values 1, 2, 3.
# Members are int subclasses so len and _member_names_ behave the same.
# ---------------------------------------------------------------------------

invariant enum.intenum.status_len:
  description: "len(enum.IntEnum('Status', 'ACTIVE INACTIVE PENDING')) == 3"
  category: intenum
  kind: python_call_eq
  function: IntEnum
  args: ["Status", "ACTIVE INACTIVE PENDING"]
  method: __len__
  expected: 3

invariant enum.intenum.status_member_names:
  description: "enum.IntEnum('Status', 'ACTIVE INACTIVE PENDING')._member_names_ == ['ACTIVE', 'INACTIVE', 'PENDING']"
  category: intenum
  kind: python_call_eq
  function: IntEnum
  args: ["Status", "ACTIVE INACTIVE PENDING"]
  method: _member_names_
  expected: ["ACTIVE", "INACTIVE", "PENDING"]

# ---------------------------------------------------------------------------
# Flag functional API
#
# enum.Flag('Perm', 'R W X') creates a Flag enum with three members.
# Flags support bitwise combination; members have power-of-two values.
# ---------------------------------------------------------------------------

invariant enum.flag.perm_len:
  description: "len(enum.Flag('Perm', 'R W X')) == 3"
  category: flag
  kind: python_call_eq
  function: Flag
  args: ["Perm", "R W X"]
  method: __len__
  expected: 3

invariant enum.flag.perm_member_names:
  description: "enum.Flag('Perm', 'R W X')._member_names_ == ['R', 'W', 'X']"
  category: flag
  kind: python_call_eq
  function: Flag
  args: ["Perm", "R W X"]
  method: _member_names_
  expected: ["R", "W", "X"]

# ---------------------------------------------------------------------------
# StrEnum functional API (Python 3.11+)
#
# enum.StrEnum('Direction', 'NORTH SOUTH EAST WEST') creates a StrEnum
# with four members. StrEnum members are both enum members and str instances.
# ---------------------------------------------------------------------------

invariant enum.strenum.direction_len:
  description: "len(enum.StrEnum('Direction', 'NORTH SOUTH EAST WEST')) == 4"
  category: strenum
  kind: python_call_eq
  function: StrEnum
  args: ["Direction", "NORTH SOUTH EAST WEST"]
  method: __len__
  expected: 4

invariant enum.strenum.direction_member_names:
  description: "enum.StrEnum('Direction', 'NORTH SOUTH EAST WEST')._member_names_ == ['NORTH', 'SOUTH', 'EAST', 'WEST']"
  category: strenum
  kind: python_call_eq
  function: StrEnum
  args: ["Direction", "NORTH SOUTH EAST WEST"]
  method: _member_names_
  expected: ["NORTH", "SOUTH", "EAST", "WEST"]

