spec: socket_extra1141
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.__package__/__loader__ class attrs, socket.socket.__weakref__ class attrs, socket.AF_UNSPEC/AF_UNIX AddressFamily class attrs, socket.AF_INET/__int__ and SOCK_STREAM/__int__ qualname and class name, socket.create_connection class/module/qualname attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1141.package_and_loader_attrs:
  description: "socket.__package__ and socket.__loader__ class identity"
  kind: python_call_eq
  category: package_loader_attrs
  id_prefix: sk1141pl
  columns: [id, function, args, expected]
  rows:
    - [sk1141pl001, socket.__package__.__eq__,                                  [""],                            true]
    - [sk1141pl002, socket.__package__.__class__.__name__.__eq__,               ["str"],                         true]
    - [sk1141pl003, socket.__package__.__class__.__qualname__.__eq__,           ["str"],                         true]
    - [sk1141pl004, socket.__package__.__class__.__module__.__eq__,             ["builtins"],                    true]
    - [sk1141pl005, socket.__loader__.__class__.__name__.__eq__,                ["SourceFileLoader"],             true]
    - [sk1141pl006, socket.__loader__.__class__.__qualname__.__eq__,            ["SourceFileLoader"],             true]
    - [sk1141pl007, socket.__loader__.__class__.__module__.__eq__,              ["_frozen_importlib_external"],   true]
    - [sk1141pl008, socket.__package__.__class__.__name__.__class__.__name__.__eq__, ["str"],                    true]

