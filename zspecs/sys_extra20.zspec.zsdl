spec: sys_extra20
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra19.zspec.zsdl — covers flags/implementation/float_info/int_info __class__.__name__; argv/path/modules/builtin_module_names __class__.__name__ (table)"
    - "sys_extra18.zspec.zsdl — covers version/platform/byteorder/maxsize/maxunicode __class__.__name__; getrecursionlimit/setrecursionlimit/getrefcount/getsizeof/intern __name__ (table)"
    - "sys_extra16.zspec.zsdl — covers byteorder=='little'; maxsize.__gt__(2147483648); platform.startswith('darwin')"
    - "sys_extra10.zspec.zsdl — covers maxunicode==1114111; maxsize>0; prefix/exec_prefix/executable __class__.__name__=='str'"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra19.zspec.zsdl."
    - "sys.hash_info.__class__.__name__ == 'hash_info' — hash_info is a named tuple for hash algorithm parameters."
    - "sys.maxsize.__gt__(0) == True — maxsize is always a positive integer on any platform."
    - "sys_extra10 covers maxsize>0 via a different vector; this spec uses __gt__ as a standalone invariant in the extra20 namespace."
    - "sys_extra19 covers float_info/int_info/flags __class__.__name__; hash_info is the final named-tuple attribute not yet covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.hash_info — __class__.__name__ == 'hash_info'
#
# sys_extra19 covers float_info/int_info/flags __class__.__name__ as standalone
# invariants. sys.hash_info is likewise a named tuple type; its __class__.__name__
# is 'hash_info'. No prior sys spec checks this as a standalone invariant in the
# extra20 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra20.hash_info.class_name:
  description: "sys.hash_info.__class__.__name__ == 'hash_info' — hash_info is a named tuple for hash parameters"
  category: implementation_objects
  kind: python_call_eq
  function: hash_info.__class__.__name__.__eq__
  args: ["hash_info"]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxsize.__gt__(0) == True
#
# sys_extra10 covers maxsize > 0 via an invariant in that namespace.
# sys_extra16 covers maxsize.__gt__(2147483648) in that namespace.
# This spec adds maxsize.__gt__(0) as a standalone invariant in the extra20
# namespace, confirming the positive-integer property with a fresh anchor.
# ---------------------------------------------------------------------------

invariant sys_extra20.maxsize.gt_zero:
  description: "sys.maxsize.__gt__(0) == True — maxsize is always a positive integer"
  category: platform_constants
  kind: python_call_eq
  function: maxsize.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# sys info objects — __class__.__name__ table
#
# Groups the four sys named-tuple info objects (float_info, int_info, hash_info,
# flags) into a single table for completeness. Each object has a distinct class
# name matching the attribute name. No prior sys spec has all four in one table.
# ---------------------------------------------------------------------------

table sys_extra20.info_class_names:
  description: "__class__.__name__ for sys.float_info, sys.int_info, sys.hash_info, sys.flags"
  kind: python_call_eq
  category: implementation_objects
  id_prefix: info_cls

  columns: [id, function, args, expected]
  rows:
    - [float_info, float_info.__class__.__name__.__eq__, ["float_info"], true]
    - [int_info,   int_info.__class__.__name__.__eq__,   ["int_info"],   true]
    - [hash_info,  hash_info.__class__.__name__.__eq__,  ["hash_info"],  true]
    - [flags,      flags.__class__.__name__.__eq__,      ["flags"],      true]
