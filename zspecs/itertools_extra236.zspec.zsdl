spec: itertools_extra236
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.zip_longest fill_value, output contracts, and class identity."
    - "itertools.zip_longest.__name__ == 'zip_longest' (len=11) — the C extension type name. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' (len=9) — zip_longest is in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' (len=11). Verified with Python 3.14.3."
    - "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C extension type. Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — inherits from object. Verified with Python 3.14.3."
    - "list(itertools.zip_longest([1,2],[3])) == [(1,3),(2,None)] — shorter list padded with None. Verified with Python 3.14.3."
    - "len(list(itertools.zip_longest([1,2],[3]))) == 2 — result length is max of input lengths. Verified with Python 3.14.3."
    - "list(itertools.zip_longest([1,2],[3],fillvalue=0)) == [(1,3),(2,0)] — fillvalue replaces None. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__contains__('fillvalue') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.zip_longest class identity contracts
#
# itertools.zip_longest.__name__ == 'zip_longest' (len=11)
# itertools.zip_longest.__module__ == 'itertools' (len=9)
# itertools.zip_longest.__qualname__ == 'zip_longest' (len=11)
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.zip_longest.__bases__[0].__name__ == 'object'
#
# zip_longest is a C extension type in itertoolsmodule.c. New to extra236.
# ---------------------------------------------------------------------------

table itertools_extra236.zip_longest_class_identity:
  description: "itertools.zip_longest class identity: name, module, qualname, metaclass type, base object; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra236zipclassid

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_name_eq,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C extension type that zips iterables padding with fillvalue; __name__ is 'zip_longest' (len=11); new to extra236"]
    - [zip_longest_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has exactly 11 characters (z-i-p-_-l-o-n-g-e-s-t); str.__len__() returns 11; new to extra236"]
    - [zip_longest_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is defined in the itertools C extension; __module__ is 'itertools' (len=9); new to extra236"]
    - [zip_longest_qualname_eq,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — zip_longest is a top-level C extension type with unqualified qualname 'zip_longest'; new to extra236"]
    - [zip_longest_class_is_type,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — zip_longest is a C extension type; its metaclass is the built-in type; new to extra236"]

# ---------------------------------------------------------------------------
# Table 2: itertools.zip_longest base, MRO, and doc contracts
#
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.zip_longest.__mro__[0].__name__ == 'zip_longest'
# itertools.zip_longest.__mro__[1].__name__ == 'object'
# itertools.zip_longest.__doc__.__contains__('fillvalue') == True
# itertools.zip_longest.__doc__.__contains__('longest') == True
#
# zip_longest has a two-element MRO and a fillvalue parameter. New to extra236.
# ---------------------------------------------------------------------------

table itertools_extra236.zip_longest_mro_and_doc:
  description: "itertools.zip_longest base is object; MRO slots; doc contains fillvalue and longest; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra236zipmrodoc

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_base_is_object,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — zip_longest inherits directly from object; __bases__[0].__name__ is 'object'; new to extra236"]
    - [zip_longest_mro0_eq,
       "zip_longest.__mro__[0].__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__mro__[0].__name__.__eq__('zip_longest') == True — MRO slot 0 is the class itself; __mro__[0].__name__ is 'zip_longest'; new to extra236"]
    - [zip_longest_mro1_eq,
       "zip_longest.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__mro__[1].__name__.__eq__('object') == True — MRO slot 1 is object; zip_longest has a two-element MRO; new to extra236"]
    - [zip_longest_doc_contains_fillvalue,
       zip_longest.__doc__.__contains__,
       ["fillvalue"],
       true,
       "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — docstring describes fillvalue keyword parameter used to pad shorter iterables; str.__contains__('fillvalue') returns True; new to extra236"]
    - [zip_longest_doc_contains_longest,
       zip_longest.__doc__.__contains__,
       ["longest"],
       true,
       "itertools.zip_longest.__doc__.__contains__('longest') == True — docstring describes iteration continuing until the longest iterable is exhausted; str.__contains__('longest') returns True; new to extra236"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest output contracts with and without fillvalue
#
# len(list(zip_longest([1,2],[3]))) == 2
# len(list(zip_longest([1],[2,3,4]))) == 3
# list(zip_longest([1,2],[3]))[1] == (2, None)
# list(zip_longest([1,2],[3],fillvalue=0))[1] == (2, 0)
# list(zip_longest([1,2],[3]))[0] == (1, 3)
#
# zip_longest output length and fill value behavior. New to extra236.
# ---------------------------------------------------------------------------

table itertools_extra236.zip_longest_output:
  description: "itertools.zip_longest output contracts: result length, None fill, custom fillvalue; new to extra236"
  kind: python_call_eq
  category: output
  id_prefix: itertoolsextra236zipoutput

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_len_two_one,
       list.__len__,
       ["list(zip_longest([1,2],[3]))"],
       2,
       "len(list(itertools.zip_longest([1,2],[3]))) == 2 — result length equals the longest iterable (length 2); new to extra236"]
    - [zip_longest_len_one_three,
       list.__len__,
       ["list(zip_longest([1],[2,3,4]))"],
       3,
       "len(list(itertools.zip_longest([1],[2,3,4]))) == 3 — result length equals the longest iterable (length 3); new to extra236"]
    - [zip_longest_module_len_9,
       zip_longest.__module__.__len__,
       [],
       9,
       "itertools.zip_longest.__module__.__len__() == 9 — 'itertools' has exactly 9 characters (i-t-e-r-t-o-o-l-s); str.__len__() returns 9; new to extra236"]
    - [zip_longest_qualname_len_11,
       zip_longest.__qualname__.__len__,
       [],
       11,
       "itertools.zip_longest.__qualname__.__len__() == 11 — 'zip_longest' qualname has exactly 11 characters; str.__len__() returns 11; new to extra236"]
    - [zip_longest_doc_class_is_str,
       zip_longest.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.zip_longest.__doc__.__class__.__name__.__eq__('str') == True — the zip_longest docstring is a plain Python str object; new to extra236"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra236
# ---------------------------------------------------------------------------

invariant itertools_extra236.zip_longest_name_eq:
  description: "itertools.zip_longest.__name__ == 'zip_longest' (len=11); new to extra236"
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra236.zip_longest_name_len_11:
  description: "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters; new to extra236"
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra236.zip_longest_module_eq:
  description: "itertools.zip_longest.__module__ == 'itertools'; new to extra236"
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra236.zip_longest_module_len_9:
  description: "itertools.zip_longest.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra236"
  kind: python_call_eq
  function: zip_longest.__module__.__len__
  args: []
  expected: 9

invariant itertools_extra236.zip_longest_qualname_eq:
  description: "itertools.zip_longest.__qualname__ == 'zip_longest'; new to extra236"
  kind: python_call_eq
  function: zip_longest.__qualname__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra236.zip_longest_class_is_type:
  description: "itertools.zip_longest.__class__.__name__ == 'type' — C extension type; new to extra236"
  kind: python_call_eq
  function: zip_longest.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra236.zip_longest_base_is_object:
  description: "itertools.zip_longest.__bases__[0].__name__ == 'object'; new to extra236"
  kind: python_call_eq
  function: "zip_longest.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra236.zip_longest_mro0_eq:
  description: "itertools.zip_longest.__mro__[0].__name__ == 'zip_longest'; new to extra236"
  kind: python_call_eq
  function: "zip_longest.__mro__[0].__name__.__eq__"
  args: ["zip_longest"]
  expected: true

invariant itertools_extra236.zip_longest_mro1_eq:
  description: "itertools.zip_longest.__mro__[1].__name__ == 'object'; new to extra236"
  kind: python_call_eq
  function: "zip_longest.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra236.zip_longest_doc_contains_fillvalue:
  description: "itertools.zip_longest.__doc__.__contains__('fillvalue') == True; new to extra236"
  kind: python_call_eq
  function: zip_longest.__doc__.__contains__
  args: ["fillvalue"]
  expected: true

invariant itertools_extra236.zip_longest_doc_contains_longest:
  description: "itertools.zip_longest.__doc__.__contains__('longest') == True; new to extra236"
  kind: python_call_eq
  function: zip_longest.__doc__.__contains__
  args: ["longest"]
  expected: true

invariant itertools_extra236.zip_longest_qualname_len_11:
  description: "itertools.zip_longest.__qualname__.__len__() == 11 — 'zip_longest' has 11 characters; new to extra236"
  kind: python_call_eq
  function: zip_longest.__qualname__.__len__
  args: []
