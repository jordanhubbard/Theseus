spec: functools_extra215
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra214.zspec.zsdl — covers __annotations__.__class__.__name__ and partial.__doc__ length checks"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES and callable type checks"
  notes:
    - "functools.reduce.__doc__.__contains__('iterable') == True — reduce docstring describes the iterable parameter. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('maxsize') == True — lru_cache docstring documents the maxsize parameter. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__contains__('partial') == True — partial docstring mentions 'partial application'. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property implements the descriptor protocol via __get__. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__contains__('attrname') == False — 'attrname' is NOT in cached_property.__dict__ on Python 3.14.3; the attribute is set internally via __set_name__ but is an instance attribute, not a class dict entry. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('dispatch') == True — singledispatch docstring mentions 'dispatch'. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__len__() == 10 — the class dict contains: __module__, __firstlineno__, __init__, __set_name__, __get__, __class_getitem__, __static_attributes__, __dict__, __weakref__, __doc__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools docstring __contains__ checks for reduce, lru_cache, partial
#
# reduce.__doc__.__contains__('iterable')  == True
# lru_cache.__doc__.__contains__('maxsize') == True
# partial.__doc__.__contains__('partial')   == True
# partial.__doc__.__contains__('keywords')  == True
# ---------------------------------------------------------------------------

table functools_extra215.doc_contains_primary:
  description: "functools reduce/lru_cache/partial docstring __contains__ checks in functrepr215 namespace — reduce.__doc__ documents the iterable parameter ('iterable' present); lru_cache.__doc__ documents the maxsize parameter ('maxsize' present); partial.__doc__ mentions partial application ('partial' present); partial.__doc__ also mentions keywords ('keywords' present); all four __doc__.__contains__(word)==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_contains
  id_prefix: functrepr215

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_has_iterable,
       reduce.__doc__.__contains__,
       ["iterable"],
       true,
       "functools.reduce.__doc__.__contains__('iterable') == True — reduce docstring describes applying a function cumulatively to the items of an iterable; the word 'iterable' appears in the docstring; __contains__('iterable') returns True; verified with Python 3.14.3"]
    - [lru_cache_doc_has_maxsize,
       lru_cache.__doc__.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__doc__.__contains__('maxsize') == True — lru_cache docstring documents the maxsize parameter controlling the cache size; the word 'maxsize' appears in the docstring; __contains__('maxsize') returns True; verified with Python 3.14.3"]
    - [partial_doc_has_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — partial docstring mentions 'partial application'; the word 'partial' appears in the docstring; __contains__('partial') returns True; verified with Python 3.14.3"]
    - [partial_doc_has_keywords,
       partial.__doc__.__contains__,
       ["keywords"],
       true,
       "functools.partial.__doc__.__contains__('keywords') == True — partial docstring mentions keyword arguments; the word 'keywords' appears in the docstring; __contains__('keywords') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatch.__doc__ and functools.cached_property.__dict__ checks
#
# singledispatch.__doc__.__contains__('dispatch') == True
# singledispatch.__doc__.__contains__('generic')  == True
# cached_property.__dict__.__contains__('__get__') == True
# cached_property.__dict__.__contains__('__init__') == True
# ---------------------------------------------------------------------------

table functools_extra215.singledispatch_and_cached_property:
  description: "functools singledispatch docstring and cached_property dict checks in functrepr215sg namespace — singledispatch.__doc__ contains 'dispatch' (the word appears in the single-dispatch generic function documentation); singledispatch.__doc__ contains 'generic'; cached_property.__dict__ contains '__get__' (implements the descriptor protocol); cached_property.__dict__ contains '__init__'; all four __contains__ calls return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_contains
  id_prefix: functrepr215sg

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_doc_has_dispatch,
       singledispatch.__doc__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatch.__doc__.__contains__('dispatch') == True — singledispatch docstring mentions dispatch; the word 'dispatch' appears in 'Single-dispatch generic function decorator'; __contains__('dispatch') returns True; verified with Python 3.14.3"]
    - [singledispatch_doc_has_generic,
       singledispatch.__doc__.__contains__,
       ["generic"],
       true,
       "functools.singledispatch.__doc__.__contains__('generic') == True — singledispatch docstring describes it as a generic function decorator; the word 'generic' appears; __contains__('generic') returns True; verified with Python 3.14.3"]
    - [cached_property_dict_has_get,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property implements the descriptor protocol; __get__ is defined in its class dict to return the cached value on attribute access; __contains__('__get__') returns True; verified with Python 3.14.3"]
    - [cached_property_dict_has_init,
       "cached_property.__dict__.__contains__",
       ["__init__"],
       true,
       "functools.cached_property.__dict__.__contains__('__init__') == True — cached_property defines __init__ in its class dict to accept a function argument; __contains__('__init__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property.__dict__ membership — presence and absence
#
# cached_property.__dict__.__contains__('__set_name__') == True
# cached_property.__dict__.__contains__('__doc__')      == True
# cached_property.__dict__.__contains__('attrname')     == False  (NOT in class dict)
# cached_property.__dict__.__len__()                    == 10
# ---------------------------------------------------------------------------

table functools_extra215.cached_property_dict_membership:
  description: "functools.cached_property.__dict__ membership checks in functrepr215cp namespace — __set_name__ is present (called when the descriptor is assigned to a class attribute, sets the attribute name); __doc__ is present (class docstring); attrname is NOT in the class dict (it is set as an instance attribute by __set_name__, not as a class dict entry); __dict__.__len__() == 10; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: functrepr215cp

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_dict_has_set_name,
       "cached_property.__dict__.__contains__",
       ["__set_name__"],
       true,
       "functools.cached_property.__dict__.__contains__('__set_name__') == True — cached_property defines __set_name__ in its class dict; __set_name__ is called when the descriptor is assigned to a class attribute and records the attribute name; __contains__('__set_name__') returns True; verified with Python 3.14.3"]
    - [cached_property_dict_has_doc,
       "cached_property.__dict__.__contains__",
       ["__doc__"],
       true,
       "functools.cached_property.__dict__.__contains__('__doc__') == True — cached_property has a class-level docstring stored in __doc__; __contains__('__doc__') returns True; verified with Python 3.14.3"]
    - [cached_property_dict_no_attrname,
       "cached_property.__dict__.__contains__",
       ["attrname"],
       false,
       "functools.cached_property.__dict__.__contains__('attrname') == False — 'attrname' is NOT in the class dict; it is stored as an instance attribute set by __set_name__, not as a class-level entry; __contains__('attrname') returns False; verified with Python 3.14.3"]
    - [cached_property_dict_len_10,
       "cached_property.__dict__.__len__",
       [],
       10,
       "functools.cached_property.__dict__.__len__() == 10 — the class dict contains exactly 10 entries: __module__, __firstlineno__, __init__, __set_name__, __get__, __class_getitem__, __static_attributes__, __dict__, __weakref__, __doc__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra215
# ---------------------------------------------------------------------------

invariant functools_extra215.reduce_doc_has_iterable:
  description: "functools.reduce.__doc__.__contains__('iterable') == True — reduce docstring documents the iterable parameter in its description of cumulative left-to-right application; new to extra215; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant functools_extra215.reduce_doc_has_function:
  description: "functools.reduce.__doc__.__contains__('function') == True — reduce docstring documents the function argument (a function of two arguments); new to extra215; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true

invariant functools_extra215.lru_cache_doc_has_maxsize:
  description: "functools.lru_cache.__doc__.__contains__('maxsize') == True — lru_cache docstring documents the maxsize parameter; new to extra215; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["maxsize"]
  expected: true

invariant functools_extra215.lru_cache_doc_has_typed:
  description: "functools.lru_cache.__doc__.__contains__('typed') == True — lru_cache docstring documents the typed parameter; new to extra215; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["typed"]
  expected: true

invariant functools_extra215.singledispatch_doc_has_dispatch:
  description: "functools.singledispatch.__doc__.__contains__('dispatch') == True — singledispatch docstring mentions dispatch in its description as a single-dispatch generic function decorator; new to extra215; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["dispatch"]
  expected: true

invariant functools_extra215.cached_property_dict_has_get:
  description: "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property implements the descriptor protocol; __get__ is defined in its class dict; new to extra215; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "cached_property.__dict__.__contains__"
  args: ["__get__"]
  expected: true

invariant functools_extra215.cached_property_dict_no_attrname:
  description: "functools.cached_property.__dict__.__contains__('attrname') == False — 'attrname' is not a class dict entry; it is set as an instance attribute by __set_name__; __contains__('attrname') returns False; new to extra215; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "cached_property.__dict__.__contains__"
  args: ["attrname"]
  expected: false

invariant functools_extra215.cached_property_dict_len_10:
  description: "functools.cached_property.__dict__.__len__() == 10 — the class dict has exactly 10 entries: __module__, __firstlineno__, __init__, __set_name__, __get__, __class_getitem__, __static_attributes__, __dict__, __weakref__, __doc__; new to extra215; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "cached_property.__dict__.__len__"
  args: []
  expected: 10

