spec: multiprocessing_extra107
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec extends multiprocessing_extra106.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.Lock and multiprocessing.RLock are factory functions (type=='method'); multiprocessing.synchronize.Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition class identity. NEW in extra107: type(multiprocessing.Lock).__name__=='method' (factory function); type(multiprocessing.RLock).__name__=='method' (factory function); type(multiprocessing.Semaphore).__name__=='method' (factory function); type(multiprocessing.BoundedSemaphore).__name__=='method' (factory function); type(multiprocessing.Event).__name__=='method' (factory function); type(multiprocessing.Condition).__name__=='method' (factory function); multiprocessing.synchronize.Lock.__name__=='Lock', __bases__[0].__name__=='SemLock', __mro__.__len__()==3; multiprocessing.synchronize.Semaphore.__name__=='Semaphore', __bases__[0].__name__=='SemLock', __mro__.__len__()==3; multiprocessing.synchronize.BoundedSemaphore.__name__=='BoundedSemaphore', __bases__[0].__name__=='Semaphore', __mro__.__len__()==4; multiprocessing.synchronize.Event.__name__=='Event', __bases__[0].__name__=='object', __mro__.__len__()==2; multiprocessing.synchronize.Condition.__name__=='Condition', __bases__[0].__name__=='object', __mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Lock is a factory function (type=='method') not a class, so it returns a C-level SemLock object. The actual class is multiprocessing.synchronize.Lock which inherits from SemLock (MRO length=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'. BoundedSemaphore inherits from Semaphore (which inherits from SemLock), giving MRO [BoundedSemaphore, Semaphore, SemLock, object] (length=4 — longest MRO in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.synchronize.Event.__bases__[0].__name__ == 'object'. Event inherits directly from object (MRO length=2). multiprocessing.synchronize.Condition.__bases__[0].__name__ == 'object'. Condition also inherits directly from object (MRO length=2). Both Event and Condition have shorter MROs than Lock/RLock/Semaphore (len=3) and BoundedSemaphore (len=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing top-level sync primitives are factory functions — extra107
#
# Wave 254 theme: multiprocessing.Lock etc. are factory methods, not classes.
#
# type(multiprocessing.Lock).__name__            == 'method'
# type(multiprocessing.Semaphore).__name__       == 'method'
# type(multiprocessing.Condition).__name__       == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra107.mp_sync_factory_types:
  description: "multiprocessing top-level synchronization primitive type checks in mpsync107 namespace — wave 254 theme: type(multiprocessing.Lock).__name__.__eq__('method')==True (Lock is a bound method/factory on the context object, not a class — calling multiprocessing.Lock() returns a C-level SemLock instance); type(multiprocessing.RLock).__name__.__eq__('method')==True (same pattern); type(multiprocessing.Semaphore).__name__.__eq__('method')==True; type(multiprocessing.BoundedSemaphore).__name__.__eq__('method')==True; type(multiprocessing.Event).__name__.__eq__('method')==True; type(multiprocessing.Condition).__name__.__eq__('method')==True; all six multiprocessing top-level primitives are factory methods on the multiprocessing context, not class objects; contrast with multiprocessing.synchronize.Lock which IS a class (type=='type'); multiprocessing.Lock.__module__=='multiprocessing.context' (confirmed by module attribute); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsync107

  columns: [id, function, args, expected, description]
  rows:
    - [lock_type_eq,    type(multiprocessing.Lock).__name__.__eq__,                    ["method"],            true, "type(multiprocessing.Lock).__name__ == 'method' (factory method, not a class); verified with Python 3.14.3"]
    - [rlock_type_eq,   type(multiprocessing.RLock).__name__.__eq__,                   ["method"],            true, "type(multiprocessing.RLock).__name__ == 'method' (factory method, not a class); verified with Python 3.14.3"]
    - [sema_type_eq,    type(multiprocessing.Semaphore).__name__.__eq__,               ["method"],            true, "type(multiprocessing.Semaphore).__name__ == 'method' (factory method, not a class); verified with Python 3.14.3"]
    - [bsema_type_eq,   type(multiprocessing.BoundedSemaphore).__name__.__eq__,        ["method"],            true, "type(multiprocessing.BoundedSemaphore).__name__ == 'method' (factory method, not a class); verified with Python 3.14.3"]
    - [event_type_eq,   type(multiprocessing.Event).__name__.__eq__,                   ["method"],            true, "type(multiprocessing.Event).__name__ == 'method' (factory method, not a class); verified with Python 3.14.3"]
    - [cond_type_eq,    type(multiprocessing.Condition).__name__.__eq__,               ["method"],            true, "type(multiprocessing.Condition).__name__ == 'method' (factory method, not a class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.synchronize Lock, RLock, Semaphore class identity — extra107
#
# Wave 254 theme: synchronize module class hierarchy.
#
# multiprocessing.synchronize.Lock.__bases__[0].__name__       == 'SemLock'  (mro len=3)
# multiprocessing.synchronize.RLock.__bases__[0].__name__      == 'SemLock'  (mro len=3)
# multiprocessing.synchronize.Semaphore.__bases__[0].__name__  == 'SemLock'  (mro len=3)
# ---------------------------------------------------------------------------

table multiprocessing_extra107.mp_synchronize_lock_rlock_semaphore:
  description: "multiprocessing.synchronize.Lock, RLock, and Semaphore class identity checks in mpsync107 namespace — wave 254 theme: multiprocessing.synchronize.Lock.__name__.__eq__('Lock')==True (len=4, shortest name in spec); multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__('SemLock')==True (Lock inherits from SemLock, MRO=[Lock, SemLock, object], length=3); multiprocessing.synchronize.Lock.__mro__.__len__()==3; multiprocessing.synchronize.Lock.__module__.__eq__('multiprocessing.synchronize')==True; multiprocessing.synchronize.RLock.__name__.__eq__('RLock')==True (len=5); multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__('SemLock')==True (MRO=[RLock, SemLock, object], length=3); multiprocessing.synchronize.RLock.__mro__.__len__()==3; multiprocessing.synchronize.Semaphore.__name__.__eq__('Semaphore')==True (len=9); multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__('SemLock')==True (MRO=[Semaphore, SemLock, object], length=3); multiprocessing.synchronize.Semaphore.__mro__.__len__()==3; Lock, RLock, Semaphore all have same mro len=3 and same direct base SemLock; compare name lengths: Lock=4 < RLock=5 < Semaphore=9; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mpsync107a

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,    multiprocessing.synchronize.Lock.__name__.__eq__,              ["Lock"],              true, "Lock.__name__ == 'Lock' (len=4, shortest name in spec); verified with Python 3.14.3"]
    - [lock_base_eq,    "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__", ["SemLock"],         true, "Lock.__bases__[0].__name__ == 'SemLock' (Lock inherits from SemLock); verified with Python 3.14.3"]
    - [lock_mro_len,    multiprocessing.synchronize.Lock.__mro__.__len__,              [],                    3,    "Lock.__mro__.__len__() == 3 ([Lock, SemLock, object]); verified with Python 3.14.3"]
    - [lock_module_eq,  multiprocessing.synchronize.Lock.__module__.__eq__,            ["multiprocessing.synchronize"], true, "Lock.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [rlock_name_eq,   multiprocessing.synchronize.RLock.__name__.__eq__,             ["RLock"],             true, "RLock.__name__ == 'RLock' (len=5); verified with Python 3.14.3"]
    - [rlock_base_eq,   "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__", ["SemLock"],        true, "RLock.__bases__[0].__name__ == 'SemLock' (RLock inherits from SemLock); verified with Python 3.14.3"]
    - [rlock_mro_len,   multiprocessing.synchronize.RLock.__mro__.__len__,             [],                    3,    "RLock.__mro__.__len__() == 3 ([RLock, SemLock, object]); verified with Python 3.14.3"]
    - [sema_name_eq,    multiprocessing.synchronize.Semaphore.__name__.__eq__,         ["Semaphore"],         true, "Semaphore.__name__ == 'Semaphore' (len=9); verified with Python 3.14.3"]
    - [sema_base_eq,    "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__", ["SemLock"],    true, "Semaphore.__bases__[0].__name__ == 'SemLock' (Semaphore inherits from SemLock); verified with Python 3.14.3"]
    - [sema_mro_len,    multiprocessing.synchronize.Semaphore.__mro__.__len__,         [],                    3,    "Semaphore.__mro__.__len__() == 3 ([Semaphore, SemLock, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.synchronize BoundedSemaphore, Event, Condition identity — extra107
#
# Wave 254 theme: BoundedSemaphore, Event, Condition class identity.
#
# BoundedSemaphore.__bases__[0].__name__  == 'Semaphore'   (mro len=4, longest in spec)
# Event.__bases__[0].__name__             == 'object'      (mro len=2)
# Condition.__bases__[0].__name__         == 'object'      (mro len=2)
# ---------------------------------------------------------------------------

table multiprocessing_extra107.mp_synchronize_bsema_event_condition:
  description: "multiprocessing.synchronize.BoundedSemaphore, Event, and Condition class identity checks in mpsync107 namespace — wave 254 theme: multiprocessing.synchronize.BoundedSemaphore.__name__.__eq__('BoundedSemaphore')==True (len=16, longest name in spec); multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')==True (BoundedSemaphore inherits from Semaphore, MRO=[BoundedSemaphore, Semaphore, SemLock, object], length=4 — longest MRO in spec); multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__()==4; multiprocessing.synchronize.Event.__name__.__eq__('Event')==True (len=5); multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__('object')==True (Event inherits directly from object, MRO=[Event, object], length=2 — shortest MRO in spec); multiprocessing.synchronize.Event.__mro__.__len__()==2; multiprocessing.synchronize.Condition.__name__.__eq__('Condition')==True (len=9); multiprocessing.synchronize.Condition.__bases__[0].__name__.__eq__('object')==True (Condition inherits directly from object, MRO=[Condition, object], length=2); multiprocessing.synchronize.Condition.__mro__.__len__()==2; compare mro lengths: Event=Condition=2 (shortest) < Lock=RLock=Semaphore=3 < BoundedSemaphore=4 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mpsync107b

  columns: [id, function, args, expected, description]
  rows:
    - [bsema_name_eq,   multiprocessing.synchronize.BoundedSemaphore.__name__.__eq__,  ["BoundedSemaphore"],  true, "BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16, longest name in spec); verified with Python 3.14.3"]
    - [bsema_name_len,  multiprocessing.synchronize.BoundedSemaphore.__name__.__len__, [],                    16,   "BoundedSemaphore.__name__.__len__() == 16 ('BoundedSemaphore'=16, longest in spec); verified with Python 3.14.3"]
    - [bsema_base_eq,   "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"], true, "BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (BoundedSemaphore inherits from Semaphore); verified with Python 3.14.3"]
    - [bsema_mro_len,   multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__,  [],                    4,    "BoundedSemaphore.__mro__.__len__() == 4 ([BoundedSemaphore, Semaphore, SemLock, object], longest MRO in spec); verified with Python 3.14.3"]
    - [event_name_eq,   multiprocessing.synchronize.Event.__name__.__eq__,             ["Event"],             true, "Event.__name__ == 'Event' (len=5); verified with Python 3.14.3"]
    - [event_base_eq,   "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__", ["object"],         true, "Event.__bases__[0].__name__ == 'object' (Event inherits directly from object); verified with Python 3.14.3"]
    - [event_mro_len,   multiprocessing.synchronize.Event.__mro__.__len__,             [],                    2,    "Event.__mro__.__len__() == 2 ([Event, object], shortest MRO in spec tied with Condition); verified with Python 3.14.3"]
    - [cond_name_eq,    multiprocessing.synchronize.Condition.__name__.__eq__,         ["Condition"],         true, "Condition.__name__ == 'Condition' (len=9); verified with Python 3.14.3"]
    - [cond_base_eq,    "multiprocessing.synchronize.Condition.__bases__[0].__name__.__eq__", ["object"],     true, "Condition.__bases__[0].__name__ == 'object' (Condition inherits directly from object); verified with Python 3.14.3"]
    - [cond_mro_len,    multiprocessing.synchronize.Condition.__mro__.__len__,         [],                    2,    "Condition.__mro__.__len__() == 2 ([Condition, object], shortest MRO in spec tied with Event); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant multiprocessing_extra107.Lock_is_factory_method:
  description: "type(multiprocessing.Lock).__name__.__eq__('method') returns True — multiprocessing.Lock is a bound method on the process context, not a class; calling multiprocessing.Lock() returns an instance of multiprocessing.synchronize.Lock (which itself inherits from SemLock); similarly type(multiprocessing.RLock).__name__=='method', type(multiprocessing.Semaphore).__name__=='method', type(multiprocessing.BoundedSemaphore).__name__=='method', type(multiprocessing.Event).__name__=='method', type(multiprocessing.Condition).__name__=='method'; contrast: multiprocessing.synchronize.Lock is a class (type(multiprocessing.synchronize.Lock).__name__=='type'); multiprocessing.Lock.__module__=='multiprocessing.context'; the factory design allows the synchronization primitives to be context-aware (spawn vs fork etc.); NEW in extra107: first standalone Lock factory type invariant in mpsync107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(multiprocessing.Lock).__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra107.synchronize_Lock_base_is_SemLock:
  description: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__('SemLock') returns True — Lock inherits from SemLock giving MRO [Lock, SemLock, object] (length=3); Lock.__module__=='multiprocessing.synchronize'; Lock.__name__=='Lock' (len=4, shortest name in spec); RLock and Semaphore also have SemLock as their direct base (both with mro len=3); BoundedSemaphore inherits from Semaphore (not SemLock directly) giving mro len=4; SemLock is the C extension class wrapping the OS semaphore primitive; Lock.__name__.__len__()==4 < RLock=5 < Semaphore=9 < Condition=9 < Event=5 < BoundedSemaphore=16 (longest); NEW in extra107: first standalone synchronize.Lock base invariant in mpsync107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra107.BoundedSemaphore_mro_len_4:
  description: "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__() == 4 — BoundedSemaphore has MRO [BoundedSemaphore, Semaphore, SemLock, object] (length=4, longest MRO in spec); BoundedSemaphore.__bases__[0].__name__=='Semaphore' (inherits from Semaphore, not SemLock directly); BoundedSemaphore.__name__.__len__()==16 (longest class name in spec: 'BoundedSemaphore'=16); compare mro lengths in spec: Event=Condition=2 (shortest), Lock=RLock=Semaphore=3, BoundedSemaphore=4 (longest); mro len=4 reflects the 4-level chain: BoundedSemaphore inherits Semaphore which inherits SemLock which inherits object; BoundedSemaphore adds an upper bound to the semaphore count (acquire fails if count would exceed the initial value); NEW in extra107: first standalone BoundedSemaphore mro length invariant in mpsync107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra107.Event_base_is_object:
  description: "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__('object') returns True — Event inherits directly from object with MRO [Event, object] (length=2, tied with Condition for shortest MRO in spec); Event.__module__=='multiprocessing.synchronize'; Event.__name__=='Event' (len=5); compare: Lock, RLock, Semaphore all have base==SemLock (mro len=3); BoundedSemaphore has base==Semaphore (mro len=4); Event and Condition both have base==object (mro len=2 — shortest in spec); this means Event and Condition do NOT inherit from SemLock (they use different OS primitives internally); Event is used for signaling between processes; mro len=2 for Event: shortest possible mro for a new class; NEW in extra107: first standalone Event base invariant in mpsync107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra107.BoundedSemaphore_base_is_Semaphore:
  description: "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — BoundedSemaphore inherits from Semaphore (not from SemLock directly); MRO=[BoundedSemaphore, Semaphore, SemLock, object] (length=4); BoundedSemaphore.__name__.__len__()==16 (longest class name in spec: 'Bounded'=7 + 'Semaphore'=9 = 16); compare direct bases in spec: Lock.__base__==SemLock, RLock.__base__==SemLock, Semaphore.__base__==SemLock, BoundedSemaphore.__base__==Semaphore (inherits from the already-SemLock-based Semaphore), Event.__base__==object, Condition.__base__==object; BoundedSemaphore is the only class in spec that inherits from another spec class (Semaphore) rather than directly from SemLock or object; NEW in extra107: first standalone BoundedSemaphore base invariant in mpsync107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true
