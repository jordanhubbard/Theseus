spec: functools_extra2416
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "CPython source — Lib/functools.py and Modules/_functoolsmodule.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "functools.partial, partialmethod, cached_property, and _lru_cache_wrapper are NOT iterable."
    - "None of these classes define __iter__ or __next__ in their own __dict__."
    - "These classes do not implement the iterator protocol; iterating over instances raises TypeError."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ not in class __dict__ for functools types
# ===

table functools_extra2416.iter_not_in_dict:
  description: "__iter__ is absent from __dict__ for all four functools callable-wrapper types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2416
  columns: [id, function, args, expected]
  rows:
    - ["ft2416001", "functools.partial.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416002", "functools.partialmethod.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416003", "functools.cached_property.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ not in class __dict__ for functools types
# ===

table functools_extra2416.next_not_in_dict:
  description: "__next__ is absent from __dict__ for all four functools callable-wrapper types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2416
  columns: [id, function, args, expected]
  rows:
    - ["ft2416005", "functools.partial.__dict__.__contains__", ["__next__"], false]
    - ["ft2416006", "functools.partialmethod.__dict__.__contains__", ["__next__"], false]
    - ["ft2416007", "functools.cached_property.__dict__.__contains__", ["__next__"], false]
    - ["ft2416008", "functools._lru_cache_wrapper.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: non-iterable classification cross-checks
# ===

table functools_extra2416.non_iterable_classification:
  description: "Confirms neither __iter__ nor __next__ appears in any of the four functools class dicts (cross-check)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2416
  columns: [id, function, args, expected]
  rows:
    - ["ft2416009", "functools.partial.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416010", "functools.partial.__dict__.__contains__", ["__next__"], false]
    - ["ft2416011", "functools.partialmethod.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416012", "functools.partialmethod.__dict__.__contains__", ["__next__"], false]
    - ["ft2416013", "functools.cached_property.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416014", "functools.cached_property.__dict__.__contains__", ["__next__"], false]
    - ["ft2416015", "functools._lru_cache_wrapper.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416016", "functools._lru_cache_wrapper.__dict__.__contains__", ["__next__"], false]

# ===
# Table 4: iterator protocol absence confirmed via hasattr on inherited object
# ===

table functools_extra2416.object_iter_absent:
  description: "object itself does not define __iter__ or __next__; functools types share this non-iterable base"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2416
  columns: [id, function, args, expected]
  rows:
    - ["ft2416017", "object.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416018", "object.__dict__.__contains__", ["__next__"], false]
    - ["ft2416019", "functools.partial.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416020", "functools._lru_cache_wrapper.__dict__.__contains__", ["__next__"], false]
    - ["ft2416021", "functools.cached_property.__dict__.__contains__", ["__iter__"], false]
    - ["ft2416022", "functools.partialmethod.__dict__.__contains__", ["__next__"], false]
