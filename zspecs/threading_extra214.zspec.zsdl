# Thread.__doc__.__contains__('thread')          == True
# Thread.__doc__.__contains__('subclass')        == True
# Lock.__doc__.__contains__('lock')              == True
# Lock.__doc__.__contains__('synchronization')   == True
# ---------------------------------------------------------------------------

table threading_extra214.doc_contains_group1:
  description: "threading __doc__.__contains__ checks for Thread and Lock in threaddoccontains214g1 namespace — Thread.__doc__ contains 'thread' (True), Thread.__doc__ contains 'subclass' (True), Lock.__doc__ contains 'lock' (True), Lock.__doc__ contains 'synchronization' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: threaddoccontains214g1

  columns: [id, function, args, expected, description]
  rows:
    - [thread_doc_contains_thread,
       "Thread.__doc__.__contains__",
       ["thread"],
       true,
       "threading.Thread.__doc__.__contains__('thread') == True — the Thread docstring says 'A class that represents a thread of control'; the word 'thread' (lowercase) appears; __contains__('thread') returns True; verified with Python 3.14.3"]
    - [thread_doc_contains_subclass,
       "Thread.__doc__.__contains__",
       ["subclass"],
       true,
       "threading.Thread.__doc__.__contains__('subclass') == True — the Thread docstring says 'This class can be safely subclassed in a limited fashion'; __contains__('subclass') returns True; verified with Python 3.14.3"]
    - [lock_doc_contains_lock,
       "Lock.__doc__.__contains__",
       ["lock"],
       true,
       "threading.Lock.__doc__.__contains__('lock') == True — the Lock C type docstring says 'A lock object is a synchronization primitive'; __contains__('lock') returns True; verified with Python 3.14.3"]
    - [lock_doc_contains_synchronization,
       "Lock.__doc__.__contains__",
       ["synchronization"],
       true,
       "threading.Lock.__doc__.__contains__('synchronization') == True — the Lock docstring says 'A lock object is a synchronization primitive'; __contains__('synchronization') returns True; verified with Python 3.14.3"]

