spec: threading_extra214
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra213.zspec.zsdl — covers threading __qualname__ equality and length checks"
    - "threading_sync.zspec.zsdl — covers threading synchronization primitive behavior"
    - "threading.zspec.zsdl — covers core threading function behavior"
  notes:
    - "threading.Thread.__doc__.__contains__('thread') == True — the Thread docstring says 'A class that represents a thread of control'; the word 'thread' appears. Verified with Python 3.14.3."
    - "threading.Thread.__doc__.__contains__('subclass') == True — the Thread docstring says 'This class can be safely subclassed in a limited fashion.' Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__contains__('lock') == True — threading.Lock has a non-None docstring from the C type; it says 'A lock object is a synchronization primitive'. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__contains__('synchronization') == True — the Lock docstring says 'A lock object is a synchronization primitive'. Verified with Python 3.14.3."
    - "threading.Event.__doc__.__contains__('event') == True — the Event docstring says 'Class implementing event objects'. Verified with Python 3.14.3."
    - "threading.Event.__doc__.__contains__('flag') == True — the Event docstring says 'Events manage a flag that can be set to true'. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__contains__('semaphore') == True — the Semaphore docstring says 'This class implements semaphore objects'. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__contains__('counter') == True — the Semaphore docstring says 'Semaphores manage a counter representing'. Verified with Python 3.14.3."
    - "threading.RLock.__doc__.__contains__('reentrant') == True — the RLock docstring says 'Factory function that returns a new reentrant lock'. Verified with Python 3.14.3."
    - "threading.Condition.__doc__.__contains__('condition') == True — the Condition docstring says 'Class that implements a condition variable'. Verified with Python 3.14.3."
    - "threading.Thread.__doc__.__len__() == 247 — the Thread docstring has exactly 247 characters. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__len__() == 469 — the Lock docstring has exactly 469 characters. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__len__() == 307 — the Semaphore docstring has exactly 307 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

