table decimal_extra1936.class_name:
  description: "__class__.__name__ checks: decimal module, decimal types, and ROUND_UP string constant"
  kind: python_call_eq
  category: class_identity
  id_prefix: dc1936

  columns: [id, function, args, expected]
  rows:
    - ["dc1936013", "decimal.__class__.__name__.__eq__",               ["module"], true]
    - ["dc1936014", "decimal.Decimal.__class__.__name__.__eq__",       ["type"],   true]
    - ["dc1936015", "decimal.Context.__class__.__name__.__eq__",       ["type"],   true]
    - ["dc1936016", "decimal.DecimalException.__class__.__name__.__eq__", ["type"], true]
    - ["dc1936017", "decimal.ROUND_UP.__class__.__name__.__eq__",      ["str"],    true]

table decimal_extra1936.descriptor_cross:
  description: "Cross-type descriptor absence checks to reach 30-row minimum"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1936

  columns: [id, function, args, expected]
  rows:
    - ["dc1936018", "decimal.Decimal.__dict__.__contains__",          ["__set__"],      false]
    - ["dc1936019", "decimal.Decimal.__dict__.__contains__",          ["__delete__"],   false]
    - ["dc1936020", "decimal.Decimal.__dict__.__contains__",          ["__set_name__"], false]
    - ["dc1936021", "decimal.Context.__dict__.__contains__",          ["__get__"],      false]
    - ["dc1936022", "decimal.Context.__dict__.__contains__",          ["__delete__"],   false]
    - ["dc1936023", "decimal.Context.__dict__.__contains__",          ["__set_name__"], false]
    - ["dc1936024", "decimal.DecimalException.__dict__.__contains__", ["__get__"],      false]
    - ["dc1936025", "decimal.DecimalException.__dict__.__contains__", ["__set__"],      false]
    - ["dc1936026", "decimal.DecimalException.__dict__.__contains__", ["__set_name__"], false]
    - ["dc1936027", "decimal.ROUND_DOWN.__class__.__name__.__eq__",   ["str"],          true]
    - ["dc1936028", "decimal.ROUND_HALF_UP.__class__.__name__.__eq__", ["str"],         true]
    - ["dc1936029", "decimal.ROUND_CEILING.__class__.__name__.__eq__", ["str"],         true]
    - ["dc1936030", "decimal.ROUND_FLOOR.__class__.__name__.__eq__",  ["str"],          true]
