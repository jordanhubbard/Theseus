spec: decimal_extra1936
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl"
    - "_decimal.zspec.zsdl"
    - "decimal_extra.zspec.zsdl"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal, decimal.Context, decimal.DecimalException are not descriptor types."
    - "None of the decimal types define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "decimal module __class__.__name__ == 'module'; decimal.Decimal.__class__.__name__ == 'type'."
    - "decimal.ROUND_UP is a string constant; decimal.ROUND_UP.__class__.__name__ == 'str'."
  created_at: "2026-04-12"
error_model: python_exceptions

table decimal_extra1936.descriptor_get:
  description: "decimal types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1936

  columns: [id, function, args, expected]
  rows:
    - ["dc1936001", "decimal.Decimal.__dict__.__contains__",          ["__get__"], false]
    - ["dc1936002", "decimal.Context.__dict__.__contains__",          ["__get__"], false]
    - ["dc1936003", "decimal.DecimalException.__dict__.__contains__", ["__get__"], false]

