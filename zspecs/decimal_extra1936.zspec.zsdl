  rows:
    - ["dc1936004", "decimal.Decimal.__dict__.__contains__",          ["__set__"], false]
    - ["dc1936005", "decimal.Context.__dict__.__contains__",          ["__set__"], false]
    - ["dc1936006", "decimal.DecimalException.__dict__.__contains__", ["__set__"], false]

