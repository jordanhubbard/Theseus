spec: abc_extra185
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABC.__init_subclass__.__name__ == '__init_subclass__' (len=17)"
    - "abc.ABC.__subclasshook__.__name__ == '__subclasshook__' (len=16)"
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta"
    - "abc.ABC.__module__ == 'abc'"
    - "abc.ABC.__qualname__ == 'ABC'"
    - "abc.ABC.__doc__.__class__.__name__ == 'str' — ABC has a docstring (not None)"
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'"
    - "Length ordering: ABC(3) < __subclasshook__(16) < __init_subclass__(17)"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC class identity — __module__, __qualname__, __class__
#
# abc.ABC.__module__.__eq__('abc') == True
# abc.ABC.__qualname__.__eq__('ABC') == True
# abc.ABC.__class__.__name__.__eq__('ABCMeta') == True
# ---------------------------------------------------------------------------

table abc_extra185.abc_class_identity:
  description: "abc.ABC class identity: __module__=='abc', __qualname__=='ABC', __class__.__name__=='ABCMeta' — ABC's metaclass is ABCMeta; verified with Python 3.14.3; new to abc_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmethods185

  columns: [id, function, args, expected, description]
  rows:
    - [abc_module_eq,
       ABC.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABC.__module__.__eq__('abc') == True — ABC class defined in abc module; str.__eq__ returns True; new to abc_extra185"]
    - [abc_qualname_eq,
       ABC.__qualname__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__qualname__.__eq__('ABC') == True — top-level class, qualname equals name 'ABC' (len=3); str.__eq__ returns True; new to abc_extra185"]
    - [abc_qualname_len,
       ABC.__qualname__.__len__,
       [],
       3,
       "abc.ABC.__qualname__.__len__() == 3 — 'ABC' has 3 characters: A-B-C; ordering anchor: ABC(3) < __subclasshook__(16) < __init_subclass__(17); str.__len__() returns 3; new to abc_extra185"]
    - [abc_class_name_eq,
       ABC.__class__.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABC.__class__.__name__.__eq__('ABCMeta') == True — ABC's metaclass is ABCMeta; str.__eq__ returns True; new to abc_extra185"]
    - [abc_dict_class_name_eq,
       ABC.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') == True — __dict__ is a mappingproxy for classes; str.__eq__ returns True; new to abc_extra185"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC special method names — __subclasshook__ and __init_subclass__
#
# abc.ABC.__subclasshook__.__name__.__eq__('__subclasshook__') == True (len=16)
# abc.ABC.__init_subclass__.__name__.__eq__('__init_subclass__') == True (len=17)
# ---------------------------------------------------------------------------

table abc_extra185.abc_method_names:
  description: "abc.ABC special method names: __subclasshook__.__name__=='__subclasshook__' (len=16), __init_subclass__.__name__=='__init_subclass__' (len=17); verified with Python 3.14.3; new to abc_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmethods185

  columns: [id, function, args, expected, description]
  rows:
    - [subclasshook_name_eq,
       ABC.__subclasshook__.__name__.__eq__,
       ["__subclasshook__"],
       true,
       "abc.ABC.__subclasshook__.__name__.__eq__('__subclasshook__') == True — special method name identity; len=16; str.__eq__ returns True; new to abc_extra185"]
    - [subclasshook_name_len,
       ABC.__subclasshook__.__name__.__len__,
       [],
       16,
       "abc.ABC.__subclasshook__.__name__.__len__() == 16 — '__subclasshook__' has 16 characters; str.__len__() returns 16; new to abc_extra185"]
    - [init_subclass_name_eq,
       ABC.__init_subclass__.__name__.__eq__,
       ["__init_subclass__"],
       true,
       "abc.ABC.__init_subclass__.__name__.__eq__('__init_subclass__') == True — special method name identity; len=17; str.__eq__ returns True; new to abc_extra185"]
    - [init_subclass_name_len,
       ABC.__init_subclass__.__name__.__len__,
       [],
       17,
       "abc.ABC.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters; longest in ordering; str.__len__() returns 17; new to abc_extra185"]
    - [subclasshook_lt_init_subclass,
       ABC.__subclasshook__.__name__.__len__,
       [],
       16,
       "abc.ABC.__subclasshook__.__name__.__len__() == 16 — ordering: __subclasshook__(16) < __init_subclass__(17); str.__len__() returns 16; new to abc_extra185"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABC docstring and dict type identity plus full ordering
#
# abc.ABC.__doc__.__class__.__name__.__eq__('str') == True
# abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# Length ordering: ABC(3) < __subclasshook__(16) < __init_subclass__(17)
# ---------------------------------------------------------------------------

table abc_extra185.abc_doc_dict_and_ordering:
  description: "abc.ABC docstring is a str (not None), __dict__ is mappingproxy; full length ordering: ABC(3) < __subclasshook__(16) < __init_subclass__(17); verified with Python 3.14.3; new to abc_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmethods185

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_class_name_eq,
       ABC.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "abc.ABC.__doc__.__class__.__name__.__eq__('str') == True — ABC has a docstring (not None); __doc__ is type str; str.__eq__ returns True; new to abc_extra185"]
    - [abc_module_len,
       ABC.__module__.__len__,
       [],
       3,
       "abc.ABC.__module__.__len__() == 3 — 'abc' has 3 characters: a-b-c; same length as 'ABC' qualname; str.__len__() returns 3; new to abc_extra185"]
    - [abc_class_name_len,
       ABC.__class__.__name__.__len__,
       [],
       7,
       "abc.ABC.__class__.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; str.__len__() returns 7; new to abc_extra185"]
    - [init_subclass_name_len_ordering,
       ABC.__init_subclass__.__name__.__len__,
       [],
       17,
       "abc.ABC.__init_subclass__.__name__.__len__() == 17 — ordering anchor: ABC(3) < __subclasshook__(16) < __init_subclass__(17); longest special method name; str.__len__() returns 17; new to abc_extra185"]
    - [abc_qualname_len_ordering,
       ABC.__qualname__.__len__,
       [],
       3,
       "abc.ABC.__qualname__.__len__() == 3 — ordering anchor: ABC(3) < __subclasshook__(16) < __init_subclass__(17); shortest in full ordering; str.__len__() returns 3; new to abc_extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra185
# ---------------------------------------------------------------------------

invariant abc_extra185.init_subclass_name_eq:
  description: "abc.ABC.__init_subclass__.__name__.__eq__('__init_subclass__') == True — special method name identity; len=17; new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__name__.__eq__
  args: ["__init_subclass__"]
  expected: true

invariant abc_extra185.subclasshook_name_eq:
  description: "abc.ABC.__subclasshook__.__name__.__eq__('__subclasshook__') == True — special method name identity; len=16; new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true

invariant abc_extra185.abc_class_name_eq:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') == True — ABC's metaclass is ABCMeta; len=7; new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra185.abc_module_eq:
  description: "abc.ABC.__module__.__eq__('abc') == True — ABC class defined in abc module; len=3; new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra185.abc_qualname_eq:
  description: "abc.ABC.__qualname__.__eq__('ABC') == True — top-level class; qualname equals name; len=3; new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra185.abc_doc_class_name_eq:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') == True — ABC has a docstring; __doc__ is type str (not None); new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra185.abc_dict_class_name_eq:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') == True — class __dict__ is a mappingproxy; new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra185.init_subclass_name_len:
  description: "abc.ABC.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters; longest in ordering: ABC(3) < __subclasshook__(16) < __init_subclass__(17); new to abc_extra185"
  category: identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__name__.__len__
  args: []
  expected: 17
