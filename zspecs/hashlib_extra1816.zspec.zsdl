spec: hashlib_extra1816
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "hashlib module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party hashlib library"
  notes:
    - "Tests __format__, __repr__, __str__ presence in hashlib constructor class __dict__"
    - "Tests __reduce__, __copy__, __deepcopy__ presence for copy/pickle protocol"
    - "Tests additional hashlib module-level functions and attributes"
  created_at: "2026-04-12"

table hashlib_extra1816.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl1816-fp-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__format__"], false]
    - ["hl1816-fp-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__repr__"], false]
    - ["hl1816-fp-003", "hashlib.sha256.__class__.__dict__.__contains__", ["__str__"], false]
    - ["hl1816-fp-004", "hashlib.md5.__class__.__dict__.__contains__", ["__format__"], false]
    - ["hl1816-fp-005", "hashlib.md5.__class__.__dict__.__contains__", ["__repr__"], false]
    - ["hl1816-fp-006", "hashlib.__dict__.__contains__", ["__doc__"], true]
    - ["hl1816-fp-007", "hashlib.__dict__.__contains__", ["__version__"], false]
    - ["hl1816-fp-008", "hashlib.__dict__.__contains__", ["__all__"], false]

table hashlib_extra1816.copy_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl1816-cp-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__reduce__"], false]
    - ["hl1816-cp-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__copy__"], false]
    - ["hl1816-cp-003", "hashlib.sha256.__class__.__dict__.__contains__", ["__deepcopy__"], false]
    - ["hl1816-cp-004", "hashlib.md5.__class__.__dict__.__contains__", ["__reduce__"], false]
    - ["hl1816-cp-005", "hashlib.sha512.__class__.__dict__.__contains__", ["__reduce__"], false]
    - ["hl1816-cp-006", "hashlib.__dict__.__contains__", ["__reduce__"], false]
    - ["hl1816-cp-007", "hashlib.__dict__.__contains__", ["__copy__"], false]
    - ["hl1816-cp-008", "hashlib.__dict__.__contains__", ["__deepcopy__"], false]

table hashlib_extra1816.hashlib_extra_functions:
