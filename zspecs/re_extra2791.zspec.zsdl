spec: re_extra2791
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "re_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "re_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "re_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "re_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 633 (re_extra2791) theme: __iand__, __ior__, and __ixor__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __iand__, __ior__, or __ixor__ in its own __dict__."
    - "__iand__ supports the &= operator; regex objects are pattern-matching types, not numeric or set-like types."
    - "__ior__ supports the |= operator; regex objects do not implement in-place bitwise-OR semantics."
    - "__ixor__ supports the ^= operator; regex objects do not implement in-place bitwise-XOR semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __iand__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2791.no_iand_in_re_classes:
  description: "__iand__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the &= in-place bitwise-AND protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2791

  columns: [id, function, args, expected]
  rows:
    - ["re2791001", "re.Pattern.__dict__.__contains__", ["__iand__"], false]
    - ["re2791002", "re.Match.__dict__.__contains__",   ["__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2791.no_ior_in_re_classes:
  description: "__ior__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the |= in-place bitwise-OR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2791

  columns: [id, function, args, expected]
  rows:
    - ["re2791003", "re.Pattern.__dict__.__contains__", ["__ior__"], false]
    - ["re2791004", "re.Match.__dict__.__contains__",   ["__ior__"], false]

# ---------------------------------------------------------------------------
# __ixor__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2791.no_ixor_in_re_classes:
  description: "__ixor__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the ^= in-place bitwise-XOR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2791

  columns: [id, function, args, expected]
  rows:
    - ["re2791005", "re.Pattern.__dict__.__contains__", ["__ixor__"], false]
    - ["re2791006", "re.Match.__dict__.__contains__",   ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not in-place bitwise operator hooks
# Confirms that regex objects are pattern-matching types, not numeric or set-like types
# ---------------------------------------------------------------------------

table re_extra2791.re_has_regex_methods_not_inplace_bitwise_operator_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __iand__/__ior__/__ixor__; re.Match defines group/groups/start/end but NOT __iand__/__ior__/__ixor__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2791

  columns: [id, function, args, expected]
  rows:
    - ["re2791007", "re.Pattern.__dict__.__contains__", ["match"],    true]
    - ["re2791008", "re.Pattern.__dict__.__contains__", ["search"],   true]
    - ["re2791009", "re.Pattern.__dict__.__contains__", ["sub"],      true]
    - ["re2791010", "re.Pattern.__dict__.__contains__", ["findall"],  true]
    - ["re2791011", "re.Pattern.__dict__.__contains__", ["__iand__"], false]
    - ["re2791012", "re.Pattern.__dict__.__contains__", ["__ior__"],  false]
    - ["re2791013", "re.Pattern.__dict__.__contains__", ["__ixor__"], false]
    - ["re2791014", "re.Match.__dict__.__contains__",   ["group"],    true]
    - ["re2791015", "re.Match.__dict__.__contains__",   ["groups"],   true]
    - ["re2791016", "re.Match.__dict__.__contains__",   ["start"],    true]
    - ["re2791017", "re.Match.__dict__.__contains__",   ["end"],      true]
    - ["re2791018", "re.Match.__dict__.__contains__",   ["__iand__"], false]
    - ["re2791019", "re.Match.__dict__.__contains__",   ["__ior__"],  false]
    - ["re2791020", "re.Match.__dict__.__contains__",   ["__ixor__"], false]
