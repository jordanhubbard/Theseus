spec: asyncio_extra198
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — Python asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "asyncio.CancelledError.__name__ == 'CancelledError' (len=14); raised when a Future or Task is cancelled."
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions' (len=18); defined in the pure-Python asyncio.exceptions submodule."
    - "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' (len=13); CancelledError inherits directly from BaseException, not Exception."
    - "asyncio.TimeoutError.__name__ == 'TimeoutError' (len=12); raised when a future operation exceeds the time limit."
    - "asyncio.TimeoutError.__module__ == 'builtins' (len=8); asyncio.TimeoutError is an alias for the built-in TimeoutError."
    - "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' (len=7); TimeoutError inherits from OSError (as a built-in exception)."
    - "asyncio.InvalidStateError.__name__ == 'InvalidStateError' (len=17); raised when an operation is not allowed in the current state."
    - "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' (len=18); defined in the pure-Python asyncio.exceptions submodule alongside CancelledError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

