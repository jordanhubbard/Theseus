# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra198
# ---------------------------------------------------------------------------

invariant asyncio_extra198.asyncio_CancelledError_name_eq:
  description: "asyncio.CancelledError.__name__.__eq__('CancelledError') returns True — CancelledError.__name__=='CancelledError' (len=14: C(1)a(2)n(3)c(4)e(5)l(6)l(7)e(8)d(9)E(10)r(11)r(12)o(13)r(14)); CancelledError is raised when a Task or Future is cancelled via cancel(); in Python 3.8+ CancelledError was changed to inherit from BaseException instead of Exception, allowing it to propagate through broad except Exception handlers; CancelledError.__name__ (14) > CancelledError.__bases__[0].__name__ (13: 'BaseException') by 1; NEW in asyncioexceptions198: first standalone CancelledError.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra198.asyncio_CancelledError_module_eq:
  description: "asyncio.CancelledError.__module__.__eq__('asyncio.exceptions') returns True — CancelledError.__module__=='asyncio.exceptions' (len=18); CancelledError is defined in the pure-Python asyncio.exceptions submodule, not in the C extension _asyncio; CancelledError.__module__ (18: 'asyncio.exceptions') > CancelledError.__name__ (14: 'CancelledError') by 4 — the module path is longer than the class name; CancelledError.__module__ (18) == InvalidStateError.__module__ (18: 'asyncio.exceptions') — both are defined in the same file; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra198.asyncio_CancelledError_base_name_eq:
  description: "asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException') returns True — CancelledError.__bases__[0].__name__=='BaseException' (len=13); CancelledError inherits directly from BaseException, bypassing Exception — this is a deliberate design choice so that except Exception clauses do not accidentally swallow cancellation; CancelledError.__bases__[0].__name__ (13: 'BaseException') < CancelledError.__name__ (14: 'CancelledError') by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.CancelledError.__bases__[0].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant asyncio_extra198.asyncio_TimeoutError_name_eq:
  description: "asyncio.TimeoutError.__name__.__eq__('TimeoutError') returns True — TimeoutError.__name__=='TimeoutError' (len=12); asyncio.TimeoutError is a direct alias to the built-in TimeoutError; it is raised by asyncio.wait_for() when the timeout expires; TimeoutError.__name__ (12) < CancelledError.__name__ (14) by 2; TimeoutError.__name__ (12) < InvalidStateError.__name__ (17) by 5; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant asyncio_extra198.asyncio_TimeoutError_module_eq:
  description: "asyncio.TimeoutError.__module__.__eq__('builtins') returns True — TimeoutError.__module__=='builtins' (len=8); asyncio.TimeoutError is an alias for the built-in TimeoutError defined in the 'builtins' module — it is not re-defined in asyncio.exceptions; TimeoutError.__module__ (8: 'builtins') < CancelledError.__module__ (18: 'asyncio.exceptions') by 10; TimeoutError.__module__ (8) == len('builtins'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra198.asyncio_TimeoutError_base_name_eq:
  description: "asyncio.TimeoutError.__bases__[0].__name__.__eq__('OSError') returns True — TimeoutError.__bases__[0].__name__=='OSError' (len=7); the built-in TimeoutError inherits from OSError as part of the OS error hierarchy; this is different from CancelledError whose base is BaseException; TimeoutError.__bases__[0].__name__ (7: 'OSError') < CancelledError.__bases__[0].__name__ (13: 'BaseException') by 6; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.TimeoutError.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant asyncio_extra198.asyncio_InvalidStateError_name_eq:
  description: "asyncio.InvalidStateError.__name__.__eq__('InvalidStateError') returns True — InvalidStateError.__name__=='InvalidStateError' (len=17); InvalidStateError is raised when an operation is performed on a Future or Task in an invalid state, e.g. calling result() before set_result() is called on a pending Future; InvalidStateError.__name__ (17) is the longest exception class name in this spec; InvalidStateError.__name__ (17) > CancelledError.__name__ (14) by 3; InvalidStateError.__name__ (17) < InvalidStateError.__module__ (18) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant asyncio_extra198.asyncio_InvalidStateError_module_eq:
  description: "asyncio.InvalidStateError.__module__.__eq__('asyncio.exceptions') returns True — InvalidStateError.__module__=='asyncio.exceptions' (len=18); InvalidStateError is defined in the same pure-Python asyncio.exceptions submodule as CancelledError; InvalidStateError.__module__ (18) == CancelledError.__module__ (18) — confirming both are co-located in asyncio.exceptions; InvalidStateError.__module__ (18) > TimeoutError.__module__ (8: 'builtins') by 10; NEW in asyncioexceptions198: completing 8-invariant coverage for asyncio exception class identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true
