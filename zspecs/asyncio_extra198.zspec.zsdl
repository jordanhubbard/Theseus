# ---------------------------------------------------------------------------

table asyncio_extra198.asyncio_CancelledError_identity:
  description: "asyncio.CancelledError class identity checks in asyncioexceptions198 namespace — CancelledError.__name__=='CancelledError' (len=14: C(1)a(2)n(3)c(4)e(5)l(6)l(7)e(8)d(9)E(10)r(11)r(12)o(13)r(14); raised when an asyncio Future or Task is cancelled via cancel()); CancelledError.__module__=='asyncio.exceptions' (len=18: 'asyncio.exceptions'=18; defined in the pure-Python asyncio.exceptions submodule, not the C extension); CancelledError.__bases__[0].__name__=='BaseException' (len=13; CancelledError inherits from BaseException directly, not from Exception — this allows it to propagate through broad except Exception handlers); CancelledError.__module__ (18) > CancelledError.__name__ (14) by 4; CancelledError.__name__ (14) > CancelledError.__bases__[0].__name__ (13) by 1; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexceptions198

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_name_eq,    asyncio.CancelledError.__name__.__eq__,                  ["CancelledError"],    true, "asyncio.CancelledError.__name__ == 'CancelledError' (len=14; raised when a Future/Task is cancelled); verified Python 3.14.3"]
    - [cancelled_name_len,   asyncio.CancelledError.__name__.__len__,                 [],                    14,   "asyncio.CancelledError.__name__.__len__() == 14 ('CancelledError'=14); verified Python 3.14.3"]
    - [cancelled_module_eq,  asyncio.CancelledError.__module__.__eq__,                ["asyncio.exceptions"], true, "asyncio.CancelledError.__module__ == 'asyncio.exceptions' (len=18; pure-Python asyncio submodule); verified Python 3.14.3"]
    - [cancelled_module_len, asyncio.CancelledError.__module__.__len__,               [],                    18,   "asyncio.CancelledError.__module__.__len__() == 18 ('asyncio.exceptions'=18); verified Python 3.14.3"]
    - ["cancelled_base_eq",  "asyncio.CancelledError.__bases__[0].__name__.__eq__",   ["BaseException"],     true, "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' (len=13; inherits from BaseException, not Exception); verified Python 3.14.3"]

