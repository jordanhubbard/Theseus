    - [invalid_name_len,   asyncio.InvalidStateError.__name__.__len__,   [],                      17,   "asyncio.InvalidStateError.__name__.__len__() == 17 ('InvalidStateError'=17); verified Python 3.14.3"]
    - [invalid_module_eq,  asyncio.InvalidStateError.__module__.__eq__,  ["asyncio.exceptions"],  true, "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' (len=18; same submodule as CancelledError); verified Python 3.14.3"]
