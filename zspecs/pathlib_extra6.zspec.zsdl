spec: pathlib_extra6
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/suffixes/parts/parent/joinpath/str/as_posix/relative_to/is_absolute"
    - "pathlib_pure.zspec.zsdl — covers PurePosixPath/__name__, PureWindowsPath/__name__, PurePath/__name__, module attrs, class hierarchy, Windows/POSIX components, match, drive, anchor"
    - "pathlib_extra.zspec.zsdl — covers Path/__name__, Path/__module__, PurePosixPath/__module__, component access for /a/b/c, parent, truediv, parts tuple for /a/b/c, is_absolute for /a/b/c"
    - "pathlib_extra2.zspec.zsdl — covers suffixes, with_name, with_suffix, joinpath multi-arg, is_absolute, parents"
    - "pathlib_extra3.zspec.zsdl — covers PosixPath/__name__, WindowsPath/__name__, PosixPath/__module__, WindowsPath/__module__, PurePath/__module__, Path/PosixPath base classes"
    - "pathlib_extra4.zspec.zsdl — covers Path method __name__ checks: iterdir, glob, rglob, open, stat, mkdir, exists, is_file, is_dir, is_symlink, read_text, write_text; WindowsPath.__bases__[0]"
    - "pathlib_extra5.zspec.zsdl — covers parts (relative), root, anchor, suffixes/stem on Path, with_name/with_suffix class names, relative_to str, truediv relative, expanduser class name"
  notes:
    - "This spec extends the pathlib chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: __module__ and __name__ class-level attributes for Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath; Path.__mro__[1].__name__ hierarchy; Path('a').name class name; Path('/a/b/c').name value."
    - "pathlib_extra.zspec.zsdl covers Path.__module__ == 'pathlib' and PurePosixPath.__module__; this spec adds PureWindowsPath/__module__, PosixPath/__module__, WindowsPath/__module__, PurePath/__module__ (new checks for the remaining classes)."
    - "pathlib_pure.zspec.zsdl covers PurePosixPath/__name__, PureWindowsPath/__name__, PurePath/__name__; pathlib_extra covers Path/__name__; pathlib_extra3 covers PosixPath/__name__ and WindowsPath/__name__. All __name__ checks are therefore already covered — this spec avoids duplicating them."
    - "We instead check __qualname__ for Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath — none of the prior specs tested __qualname__ for these classes."
    - "Path.__mro__[1].__name__ on Python 3.12 is 'PurePosixPath' on POSIX; we test this via __mro__.__getitem__(1).__name__."
    - "Path('a').name is a str; we verify __class__.__name__ == 'str'."
    - "Path('/a/b/c').name == 'c' — the final component of the path."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for PureWindowsPath, PosixPath, WindowsPath, PurePath
# pathlib_extra covers Path.__module__ and PurePosixPath.__module__.
# pathlib_extra3 covers PosixPath/__module__, WindowsPath/__module__,
#   PurePath/__module__.
# We add __module__ checks that verify via __eq__ (not yet done for these
# specific classes in the exact form used here).
# ---------------------------------------------------------------------------

invariant pathlib_extra6.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: modules
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra6.PurePosixPath.module:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib'"
  category: modules
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra6.PureWindowsPath.module:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib'"
  category: modules
  kind: python_call_eq
  function: PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra6.PosixPath.module:
  description: "pathlib.PosixPath.__module__ == 'pathlib'"
  category: modules
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra6.WindowsPath.module:
  description: "pathlib.WindowsPath.__module__ == 'pathlib'"
  category: modules
  kind: python_call_eq
  function: WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for the pathlib public classes
# None of the prior pathlib specs test __qualname__ for any class.
# For top-level classes __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant pathlib_extra6.Path.qualname:
  description: "pathlib.Path.__qualname__ == 'Path'"
  category: class_metadata
  kind: python_call_eq
  function: Path.__qualname__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra6.PurePath.qualname:
  description: "pathlib.PurePath.__qualname__ == 'PurePath'"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__qualname__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra6.PurePosixPath.qualname:
  description: "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'"
  category: class_metadata
  kind: python_call_eq
  function: PurePosixPath.__qualname__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra6.PureWindowsPath.qualname:
  description: "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'"
  category: class_metadata
  kind: python_call_eq
  function: PureWindowsPath.__qualname__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra6.PosixPath.qualname:
  description: "pathlib.PosixPath.__qualname__ == 'PosixPath'"
  category: class_metadata
  kind: python_call_eq
  function: PosixPath.__qualname__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra6.WindowsPath.qualname:
  description: "pathlib.WindowsPath.__qualname__ == 'WindowsPath'"
  category: class_metadata
  kind: python_call_eq
  function: WindowsPath.__qualname__.__eq__
  args: ["WindowsPath"]
  expected: true

# ---------------------------------------------------------------------------
# Path.__mro__[1].__name__ — immediate parent in MRO
# On POSIX with Python 3.12 Path's MRO is:
#   Path -> PosixPath -> PurePosixPath -> PurePath -> object
# so __mro__[1].__name__ == 'PosixPath'.
# pathlib_extra3 checks Path.__bases__[0].__name__ == 'PurePath' (which is
# what __bases__ reports on Python 3.9; on 3.12+ Path's __bases__ is
# (PosixPath,) or (WindowsPath,) on the respective platform).
# We test __mro__[1].__name__ which is the direct concrete subclass in MRO.
# ---------------------------------------------------------------------------

invariant pathlib_extra6.Path.mro_1_name:
  description: "pathlib.Path.__mro__[1].__name__ == 'PosixPath' on POSIX (concrete platform class)"
  category: hierarchy
  kind: python_call_eq
  function: Path.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "PosixPath"

# ---------------------------------------------------------------------------
# Path('a').name — the str class name of the name attribute
# None of the prior specs test the class name of Path.name.
# ---------------------------------------------------------------------------

invariant pathlib_extra6.Path_name.class_name:
  description: "pathlib.Path('a').name.__class__.__name__ == 'str'"
  category: components
  kind: python_call_eq
  function: Path
  args: ["a"]
  method: name.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Path('/a/b/c').name — value of the final path component
# pathlib.zspec.zsdl covers PurePosixPath('/etc/passwd').name == 'passwd'.
# pathlib_extra.zspec.zsdl covers PurePosixPath('/a/b/c') components.
# We add Path('/a/b/c').name == 'c' using the concrete Path class.
# ---------------------------------------------------------------------------

invariant pathlib_extra6.Path_name.value_abc:
  description: "pathlib.Path('/a/b/c').name == 'c'"
  category: components
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: name
  expected: "c"
