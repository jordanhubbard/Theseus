spec: errno_extra11
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno_extra10.zspec.zsdl."
    - "Prior specs covered: errno.__name__/__package__; ; errorcode type/length; errno.errorcode.__class__.__name__."
    - "This spec covers: errno.errorcode.__class__.__module__, errno.EPERM.__class__.__module__, errno.ENOENT.__class__.__module__, errno.EINVAL.__class__.__module__, len(errno.errorcode), errno.errorcode.__len__(), errno.EPERM.__class__.__name__=='int', errno.ENOENT.__class__.__name__=='int', errno.errorcode[errno.EPERM]=='EPERM', errno.errorcode[errno.ENOENT]=='ENOENT', errno.errorcode[errno.EINVAL]=='EINVAL', errno.errorcode[errno.EACCES]=='EACCES'."
    - "errno.errorcode.__class__.__module__ == 'builtins' — errorcode is a plain Python dict; dict is defined in builtins. Verified at runtime."
    - "errno.EPERM.__class__.__module__ == 'builtins' — errno constants are plain Python ints; int is defined in builtins. Verified at runtime."
    - "errno.ENOENT.__class__.__module__ == 'builtins'. Verified at runtime."
    - "errno.EINVAL.__class__.__module__ == 'builtins'. Verified at runtime."
    - "len(errno.errorcode) == 107 on macOS/Darwin 25.4.0. Verified at runtime."
    - "errno.EPERM.__class__.__name__ == 'int'. Verified at runtime."
    - "errno.ENOENT.__class__.__name__ == 'int'. Verified at runtime."
    - "errno.EPERM == 1 on macOS/Darwin; errno.errorcode[1] == 'EPERM'. Verified at runtime."
    - "errno.ENOENT == 2 on macOS/Darwin; errno.errorcode[2] == 'ENOENT'. Verified at runtime."
    - "errno.EINVAL == 22 on macOS/Darwin; errno.errorcode[22] == 'EINVAL'. Verified at runtime."
    - "errno.EACCES == 13 on macOS/Darwin; errno.errorcode[13] == 'EACCES'. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# errorcode.__class__.__module__
#
# errno.errorcode is a plain Python dict; dict is defined in the builtins
# module. No prior spec verifies errorcode.__class__.__module__ as a
# standalone invariant (prior extra10 covers __class__.__name__ == 'dict').
# Verified at runtime: 'builtins'.
# ---------------------------------------------------------------------------

invariant errno_extra11.errorcode.class_module:
  description: "errno.errorcode.__class__.__module__ == 'builtins' — errorcode is a plain dict from builtins"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# errno constant __class__.__module__ — EPERM, ENOENT, EINVAL
#
# All errno constants are plain Python ints; int is defined in the builtins
# module. No prior spec verifies __class__.__module__ for any errno constant
# as a standalone invariant.
# Verified at runtime: all three equal 'builtins'.
# ---------------------------------------------------------------------------

invariant errno_extra11.EPERM.class_module:
  description: "errno.EPERM.__class__.__module__ == 'builtins' — EPERM is a plain int from builtins"
  category: constants
  kind: python_call_eq
  function: EPERM.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant errno_extra11.ENOENT.class_module:
  description: "errno.ENOENT.__class__.__module__ == 'builtins' — ENOENT is a plain int from builtins"
  category: constants
  kind: python_call_eq
  function: ENOENT.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant errno_extra11.EINVAL.class_module:
  description: "errno.EINVAL.__class__.__module__ == 'builtins' — EINVAL is a plain int from builtins"
  category: constants
  kind: python_call_eq
  function: EINVAL.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# len(errno.errorcode) == 107
#
# On macOS/Darwin 25.4.0, errno.errorcode contains exactly 107 entries.
# No prior spec verifies this length as a standalone invariant via __len__.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra11.errorcode.len:
  description: "len(errno.errorcode) == 107 on macOS/Darwin 25.4.0"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__len__
  args: []
  expected: 107

# ---------------------------------------------------------------------------
# errno constant __class__.__name__ — EPERM, ENOENT
#
# Prior spec (errno_extra9) verifies ENOTSOCK.__class__.__name__=='int' and
# ECONNRESET.__class__.__name__=='int'. No prior spec verifies EPERM or
# ENOENT class name as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra11.EPERM.class_name:
  description: "errno.EPERM.__class__.__name__ == 'int' — EPERM is a plain int"
  category: constants
  kind: python_call_eq
  function: EPERM.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra11.ENOENT.class_name:
  description: "errno.ENOENT.__class__.__name__ == 'int' — ENOENT is a plain int"
  category: constants
  kind: python_call_eq
  function: ENOENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# errorcode reverse-lookups for EPERM, ENOENT, EINVAL, EACCES
#
# On macOS/Darwin: EPERM==1, ENOENT==2, EINVAL==22, EACCES==13.
# No prior spec verifies errorcode[1], errorcode[2], errorcode[22], or
# errorcode[13] as standalone reverse-lookup invariants.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra11.errorcode.eperm_lookup:
  description: "errno.errorcode[1] == 'EPERM' — reverse-lookup of errno 1 (EPERM) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [1]
  expected: "EPERM"

invariant errno_extra11.errorcode.enoent_lookup:
  description: "errno.errorcode[2] == 'ENOENT' — reverse-lookup of errno 2 (ENOENT) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [2]
  expected: "ENOENT"

invariant errno_extra11.errorcode.einval_lookup:
  description: "errno.errorcode[22] == 'EINVAL' — reverse-lookup of errno 22 (EINVAL) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [22]
  expected: "EINVAL"

invariant errno_extra11.errorcode.eacces_lookup:
  description: "errno.errorcode[13] == 'EACCES' — reverse-lookup of errno 13 (EACCES) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [13]
  expected: "EACCES"

# ---------------------------------------------------------------------------
# Table: errno constant __class__ identity — module and name
#
# Groups __class__.__module__ checks for errorcode, EPERM, ENOENT, EINVAL,
# and __class__.__name__ checks for EPERM and ENOENT in one indexed table.
# No prior table covers __class__.__module__ for any errno object.
# All verified at runtime.
# ---------------------------------------------------------------------------

table errno_extra11.constant_class_identity:
  description: "errno constant and errorcode __class__ identity checks — module and name"
  kind: python_call_eq
  category: constants
  id_prefix: e11cci

  columns: [id, function, args, expected]
  rows:
    - [errorcode_cls_module, errorcode.__class__.__module__.__eq__, ["builtins"], true]
    - [EPERM_cls_module,     EPERM.__class__.__module__.__eq__,    ["builtins"], true]
    - [ENOENT_cls_module,    ENOENT.__class__.__module__.__eq__,   ["builtins"], true]
    - [EINVAL_cls_module,    EINVAL.__class__.__module__.__eq__,   ["builtins"], true]
    - [EPERM_cls_name,       EPERM.__class__.__name__.__eq__,      ["int"],      true]
    - [ENOENT_cls_name,      ENOENT.__class__.__name__.__eq__,     ["int"],      true]

# ---------------------------------------------------------------------------
# Table: errorcode reverse-lookups for EPERM, ENOENT, EINVAL, EACCES
#
# Groups the four fundamental errorcode reverse-lookup checks in one indexed
# table. Values verified: EPERM=1, ENOENT=2, EINVAL=22, EACCES=13 on macOS.
# No prior table covers these lookups.
# All verified at runtime.
# ---------------------------------------------------------------------------

table errno_extra11.errorcode_fundamental_lookups:
  description: "errno.errorcode reverse-lookups for EPERM/ENOENT/EINVAL/EACCES — fundamental POSIX error codes"
  kind: python_call_eq
  category: errorcode
  id_prefix: e11efl

  columns: [id, function, args, expected]
  rows:
    - [eperm,  errorcode.__getitem__, [1],  "EPERM"]
    - [enoent, errorcode.__getitem__, [2],  "ENOENT"]
    - [einval, errorcode.__getitem__, [22], "EINVAL"]
    - [eacces, errorcode.__getitem__, [13], "EACCES"]
