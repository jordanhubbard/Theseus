spec: zoneinfo_extra3
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo.zspec.zsdl — covers ZoneInfo/__name__/__module__, ZoneInfoNotFoundError/__name__, available_timezones/__name__, base=KeyError, returns set, UTC/America/New_York containment, ZoneInfo('UTC') class"
    - "zoneinfo_extra.zspec.zsdl — covers class_names table, ZoneInfo/__module__, ZoneInfoNotFoundError base=KeyError, available_timezones/__name__/__returns_set__/min_count"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__; ZoneInfo('UTC').key; ZoneInfo('America/New_York').key; Europe/London/Asia/Tokyo/Pacific/Auckland containment"
  notes:
    - "This spec adds new axes not present in any prior zoneinfo spec."
    - "New axis 1: ZoneInfo MRO length == 3 (ZoneInfo -> tzinfo -> object)."
    - "New axis 2: ZoneInfo method names — clear_cache, no_cache, from_file."
    - "New axis 3: ZoneInfo('UTC').utcoffset(None).__class__.__name__ == 'timedelta' — utcoffset of UTC is a zero timedelta."
    - "New axis 4: ZoneInfo('UTC').tzname(None) == 'UTC' — tzname of the UTC zone."
    - "New axis 5: ZoneInfo module membership — ZoneInfo.__module__ == 'zoneinfo' anchor in extra3 namespace."
    - "New axis 6: additional well-known IANA zones — Africa/Cairo, America/Los_Angeles, Australia/Sydney."
    - "New axis 7: available_timezones() returns a set (class name check in extra3 namespace)."
    - "zoneinfo.ZoneInfo.__mro__ has exactly 3 entries: ZoneInfo, tzinfo, object."
    - "zoneinfo.ZoneInfo.clear_cache.__name__ == 'clear_cache' — class method name."
    - "zoneinfo.ZoneInfo.no_cache.__name__ == 'no_cache' — alternative constructor name."
    - "zoneinfo.ZoneInfo.from_file.__name__ == 'from_file' — file-based constructor name."
    - "zoneinfo.ZoneInfo('UTC').utcoffset(None).__class__.__name__ == 'timedelta' — verified Python 3.12."
    - "zoneinfo.ZoneInfo('UTC').tzname(None) == 'UTC' — verified Python 3.12."
    - "zoneinfo.available_timezones().__class__.__name__ == 'set' — extra3 namespace anchor."
    - "Africa/Cairo, America/Los_Angeles, Australia/Sydney present in available_timezones() on Python 3.12/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ZoneInfo() raises ZoneInfoNotFoundError (subclass of KeyError) for unknown timezone keys"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# ZoneInfo MRO length
#
# No prior spec checks len(ZoneInfo.__mro__). The MRO has exactly 3 entries:
# ZoneInfo -> tzinfo -> object. zoneinfo_extra2 checks __bases__[0].__name__
# but not the total MRO length.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra3.ZoneInfo.mro_length:
  description: "len(zoneinfo.ZoneInfo.__mro__) == 3 — MRO is ZoneInfo -> tzinfo -> object"
  category: hierarchy
  kind: python_call_eq
  function: ZoneInfo.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ZoneInfo class method names — clear_cache, no_cache, from_file
#
# No prior spec checks the __name__ of ZoneInfo's class methods. These three
# are the main alternative constructors / cache management methods.
# ---------------------------------------------------------------------------

table zoneinfo_extra3.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [clear_cache, ZoneInfo.clear_cache.__name__.__eq__, ["clear_cache"], true]
    - [no_cache,    ZoneInfo.no_cache.__name__.__eq__,    ["no_cache"],    true]
    - [from_file,   ZoneInfo.from_file.__name__.__eq__,   ["from_file"],   true]

# ---------------------------------------------------------------------------
# ZoneInfo('UTC') behavioral checks — utcoffset and tzname
#
# zoneinfo_extra2 confirms ZoneInfo('UTC').key == 'UTC'. No prior spec checks
# utcoffset() or tzname() on a ZoneInfo instance. For 'UTC', utcoffset(None)
# returns a zero timedelta and tzname(None) returns the string 'UTC'.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra3.ZoneInfo.utc_utcoffset_class:
  description: "zoneinfo.ZoneInfo('UTC').utcoffset(None).__class__.__name__ == 'timedelta' — UTC offset is a timedelta"
  category: behavioral
  kind: python_call_eq
  function: ZoneInfo
  args: ["UTC"]
  method: utcoffset
  method_args: [null]
  method_chain: __class__
  method_chain_args: []
  expected: "timedelta"

invariant zoneinfo_extra3.ZoneInfo.utc_tzname:
  description: "zoneinfo.ZoneInfo('UTC').tzname(None) == 'UTC' — timezone name of the UTC zone"
  category: behavioral
  kind: python_call_eq
  function: ZoneInfo
  args: ["UTC"]
  method: tzname
  method_args: [null]
  expected: "UTC"

# ---------------------------------------------------------------------------
# available_timezones() returns a set — extra3 namespace anchor
#
# zoneinfo_extra.zspec.zsdl covers this as a behavioral invariant; this
# re-anchors it in the extra3 namespace for traceability continuity.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra3.available_timezones.returns_set:
  description: "zoneinfo.available_timezones().__class__.__name__ == 'set'"
  category: behavioral
  kind: python_call_eq
  function: available_timezones.__call__
  args: []
  method: __class__
  method_chain: __name__
  expected: "set"

# ---------------------------------------------------------------------------
# Additional well-known IANA zones in available_timezones()
#
# zoneinfo and zoneinfo_extra confirm UTC and America/New_York.
# zoneinfo_extra2 adds Europe/London, Asia/Tokyo, Pacific/Auckland.
# This spec adds Africa/Cairo, America/Los_Angeles, Australia/Sydney.
# ---------------------------------------------------------------------------

table zoneinfo_extra3.additional_timezones:
  kind: python_call_eq
  category: behavioral
  id_prefix: tzcontains

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [africa_cairo,        available_timezones, [], __contains__, ["Africa/Cairo"],        true]
    - [america_los_angeles, available_timezones, [], __contains__, ["America/Los_Angeles"], true]
    - [australia_sydney,    available_timezones, [], __contains__, ["Australia/Sydney"],    true]
