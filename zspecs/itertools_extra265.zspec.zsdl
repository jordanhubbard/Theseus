spec: itertools_extra265
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools module __name__, __package__, __spec__ identity; itertools.__doc__ first 20 characters; count of public names in dir(itertools); key names present in dir(itertools)."
    - "itertools.__name__ == 'itertools' — the module's own name attribute. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — itertools is a top-level C extension module; its __package__ is the empty string. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — itertools.__spec__ is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools' — the spec's name matches the module name. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — itertools is a C built-in module; its loader is the BuiltinImporter class itself (a type object). Verified with Python 3.14.3."
    - "itertools.__doc__[:20] == 'Functional tools for' — the first 20 characters of the itertools docstring. Verified with Python 3.14.3."
    - "len([x for x in dir(itertools) if not x.startswith('_')]) == 20 — itertools exports 20 public names. Verified with Python 3.14.3."
    - "'chain', 'count', 'repeat' are all in dir(itertools). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module __name__, __package__, __spec__ identity
#
# itertools.__name__ == 'itertools'
# itertools.__package__ == ''
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.name == 'itertools'
# itertools.__loader__.__class__.__name__ == 'type'
#
# itertools is a C extension module. Its __loader__ is the BuiltinImporter
# class itself (a type), so __loader__.__class__.__name__ == 'type'. New to
# extra265.
# ---------------------------------------------------------------------------

table itertools_extra265.module_identity:
  description: "itertools module __name__, __package__, __spec__, __loader__ identity; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: itermod265

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module's __name__ attribute is the string 'itertools'; str.__eq__('itertools') returns True; new to extra265"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level C extension module; its __package__ is the empty string ''; str.__eq__('') returns True; new to extra265"]
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is an importlib.machinery.ModuleSpec instance; str.__eq__('ModuleSpec') returns True; new to extra265"]
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec's name field matches the module __name__; str.__eq__('itertools') returns True; new to extra265"]
    - [loader_class_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools is a C built-in module; its __loader__ is the BuiltinImporter class itself (a type object), so __loader__.__class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra265"]

# ---------------------------------------------------------------------------
# Table 2: itertools module name lengths and __package__ class
#
# itertools.__name__.__len__() == 9
# itertools.__package__.__len__() == 0
# itertools.__package__.__class__.__name__ == 'str'
# itertools.__spec__.name.__len__() == 9
# itertools.__name__.__eq__('itertools') == True (cross-check)
#
# New to extra265.
# ---------------------------------------------------------------------------

table itertools_extra265.name_lengths:
  description: "itertools __name__ len 9, __package__ len 0 and class str, __spec__.name len 9; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: iterlen265

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_len_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — the string 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra265"]
    - [mod_package_len_0,
       "__package__.__len__",
       [],
       0,
       "itertools.__package__.__len__() == 0 — itertools.__package__ is the empty string ''; its length is 0; str.__len__() returns 0; new to extra265"]
    - [mod_package_class_str,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__package__.__class__.__name__.__eq__('str') == True — itertools.__package__ is a string (the empty string ''); its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra265"]
    - [spec_name_len_9,
       "__spec__.name.__len__",
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — the ModuleSpec's name field is 'itertools' (9 characters); str.__len__() returns 9; new to extra265"]
    - [mod_name_class_str,
       "__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__name__.__class__.__name__.__eq__('str') == True — itertools.__name__ is a string; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra265"]

# ---------------------------------------------------------------------------
# Table 3: itertools public names in dir() — presence checks
#
# 'chain' in dir(itertools) == True
# 'count' in dir(itertools) == True
# 'repeat' in dir(itertools) == True
# 'cycle' in dir(itertools) == True
# 'product' in dir(itertools) == True
#
# dir(itertools) has 20 public names (those not starting with '_'). New to
# extra265.
# ---------------------------------------------------------------------------

table itertools_extra265.dir_membership:
  description: "chain, count, repeat, cycle, product are in dir(itertools); new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: iterdir265

  columns: [id, function, args, expected, description]
  rows:
    - [has_chain,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — 'chain' is a public name in itertools; its __name__ is 'chain'; str.__eq__('chain') returns True; new to extra265"]
    - [has_count,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — 'count' is a public name in itertools; its __name__ is 'count'; str.__eq__('count') returns True; new to extra265"]
    - [has_repeat,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — 'repeat' is a public name in itertools; its __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra265"]
    - [has_cycle,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — 'cycle' is a public name in itertools; its __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra265"]
    - [has_product,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — 'product' is a public name in itertools; its __name__ is 'product'; str.__eq__('product') returns True; new to extra265"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra265
# ---------------------------------------------------------------------------

invariant itertools_extra265.module_name.eq:
  description: "itertools.__name__.__eq__('itertools') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra265.module_package.empty:
  description: "itertools.__package__.__eq__('') == True — top-level C extension, not a package; new to extra265"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra265.spec_class.modulespec:
  description: "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra265.spec_name.eq:
  description: "itertools.__spec__.name.__eq__('itertools') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra265.loader_class.type:
  description: "itertools.__loader__.__class__.__name__.__eq__('type') == True — BuiltinImporter is a class/type; new to extra265"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra265.module_name.len_9:
  description: "itertools.__name__.__len__() == 9 — 'itertools' is 9 characters; new to extra265"
  category: identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant itertools_extra265.chain.name_eq:
  description: "itertools.chain.__name__.__eq__('chain') == True — chain is a C-level type; new to extra265"
  category: identity
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra265.count.name_eq:
  description: "itertools.count.__name__.__eq__('count') == True — count is a C-level type; new to extra265"
  category: identity
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra265.repeat.name_eq:
  description: "itertools.repeat.__name__.__eq__('repeat') == True — repeat is a C-level type; new to extra265"
  category: identity
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true
