spec: asyncio_extra249
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html#asyncio.Lock — Lock class"
    - "https://docs.python.org/3/library/asyncio-sync.html#asyncio.Semaphore — Semaphore class"
    - "https://docs.python.org/3/library/asyncio-sync.html#asyncio.BoundedSemaphore — BoundedSemaphore class"
    - "https://docs.python.org/3/library/asyncio-sync.html#asyncio.Condition — Condition class"
    - "https://docs.python.org/3/library/asyncio-sync.html#asyncio.Event — Event class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py (internal implementation)"
  notes:
    - "This spec covers asyncio Lock, Semaphore, BoundedSemaphore, Condition, and Event class identity contracts."
    - "asyncio.Lock.__name__ == 'Lock' (len=4); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == '_ContextManagerMixin'."
    - "asyncio.Semaphore.__name__ == 'Semaphore' (len=9); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == '_ContextManagerMixin'."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); __bases__[0].__name__ == 'Semaphore' (inherits from Semaphore, not _ContextManagerMixin directly)."
    - "asyncio.Condition.__name__ == 'Condition' (len=9); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == '_ContextManagerMixin'."
    - "asyncio.Event.__name__ == 'Event' (len=5); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == '_LoopBoundMixin' (different from the others)."
    - "All five synchronization primitives live in asyncio.locks (len=13); Event is the only one with _LoopBoundMixin as its base."
    - "BoundedSemaphore is the only primitive whose direct base is another asyncio class (Semaphore) rather than a mixin."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Lock and asyncio.Semaphore class identity
#
# Lock.__name__ == 'Lock' (len=4)
# Lock.__module__ == 'asyncio.locks' (len=13)
# Lock.__bases__[0].__name__ == '_ContextManagerMixin'
# Semaphore.__name__ == 'Semaphore' (len=9)
# Semaphore.__module__ == 'asyncio.locks' (len=13)
# Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'
# ---------------------------------------------------------------------------

table asyncio_extra249.lock_semaphore_identity:
  description: "asyncio.Lock and asyncio.Semaphore class identity — Lock.__name__.__eq__('Lock')==True (len=4); Lock.__module__.__eq__('asyncio.locks')==True (len=13); Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Lock inherits from the asyncio context manager mixin); Semaphore.__name__.__eq__('Semaphore')==True (len=9); Semaphore.__module__.__eq__('asyncio.locks')==True (len=13, same module as Lock); Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (same base as Lock); Lock.__name__.__len__()==4; Semaphore.__name__.__len__()==9; both live in asyncio.locks (len=13); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aio249ls

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,   Lock.__name__.__eq__,                      ["Lock"],                true, "asyncio.Lock.__name__ == 'Lock'; verified with Python 3.14.3"]
    - [lock_name_len,  Lock.__name__.__len__,                     [],                      4,    "asyncio.Lock.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [lock_mod_eq,    Lock.__module__.__eq__,                    ["asyncio.locks"],        true, "asyncio.Lock.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [lock_mod_len,   Lock.__module__.__len__,                   [],                      13,   "asyncio.Lock.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [lock_base_eq,   "Lock.__bases__[0].__name__.__eq__",       ["_ContextManagerMixin"], true, "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]
    - [sem_name_eq,    Semaphore.__name__.__eq__,                 ["Semaphore"],            true, "asyncio.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [sem_name_len,   Semaphore.__name__.__len__,                [],                      9,    "asyncio.Semaphore.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [sem_mod_eq,     Semaphore.__module__.__eq__,               ["asyncio.locks"],        true, "asyncio.Semaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [sem_mod_len,    Semaphore.__module__.__len__,              [],                      13,   "asyncio.Semaphore.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [sem_base_eq,    "Semaphore.__bases__[0].__name__.__eq__",  ["_ContextManagerMixin"], true, "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore class identity
#
# BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16)
# BoundedSemaphore.__module__ == 'asyncio.locks' (len=13)
# BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# ---------------------------------------------------------------------------

table asyncio_extra249.boundedsemaphore_identity:
  description: "asyncio.BoundedSemaphore class identity — BoundedSemaphore.__name__.__eq__('BoundedSemaphore')==True (len=16, longest name in this spec); BoundedSemaphore.__module__.__eq__('asyncio.locks')==True (len=13, same module as all other primitives); BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')==True (BoundedSemaphore inherits from Semaphore, not from _ContextManagerMixin directly — it extends Semaphore to add an upper-bound check); BoundedSemaphore.__name__.__len__()==16; contrast: Semaphore.__name__.__len__()==9; Lock.__name__.__len__()==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aio249bs

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_name_eq,   BoundedSemaphore.__name__.__eq__,                  ["BoundedSemaphore"],  true, "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'; verified with Python 3.14.3"]
    - [bsem_name_len,  BoundedSemaphore.__name__.__len__,                 [],                    16,   "asyncio.BoundedSemaphore.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [bsem_mod_eq,    BoundedSemaphore.__module__.__eq__,                ["asyncio.locks"],      true, "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [bsem_mod_len,   BoundedSemaphore.__module__.__len__,               [],                    13,   "asyncio.BoundedSemaphore.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [bsem_base_eq,   "BoundedSemaphore.__bases__[0].__name__.__eq__",   ["Semaphore"],          true, "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Event class identity
#
# Condition.__name__ == 'Condition' (len=9)
# Condition.__module__ == 'asyncio.locks' (len=13)
# Condition.__bases__[0].__name__ == '_ContextManagerMixin'
# Event.__name__ == 'Event' (len=5)
# Event.__module__ == 'asyncio.locks' (len=13)
# Event.__bases__[0].__name__ == '_LoopBoundMixin'
# ---------------------------------------------------------------------------

table asyncio_extra249.condition_event_identity:
  description: "asyncio.Condition and asyncio.Event class identity — Condition.__name__.__eq__('Condition')==True (len=9, same length as Semaphore); Condition.__module__.__eq__('asyncio.locks')==True (len=13); Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Condition shares its base with Lock and Semaphore); Event.__name__.__eq__('Event')==True (len=5); Event.__module__.__eq__('asyncio.locks')==True (len=13, same module as all primitives); Event.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Event's base is _LoopBoundMixin, not _ContextManagerMixin — Event is the outlier among the five primitives); Condition.__name__.__len__()==9; Event.__name__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aio249ce

  columns: [id, function, args, expected, description]
  rows:
    - [cond_name_eq,   Condition.__name__.__eq__,                ["Condition"],           true, "asyncio.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [cond_name_len,  Condition.__name__.__len__,               [],                      9,    "asyncio.Condition.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [cond_mod_eq,    Condition.__module__.__eq__,              ["asyncio.locks"],        true, "asyncio.Condition.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [cond_mod_len,   Condition.__module__.__len__,             [],                      13,   "asyncio.Condition.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [cond_base_eq,   "Condition.__bases__[0].__name__.__eq__", ["_ContextManagerMixin"], true, "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]
    - [evt_name_eq,    Event.__name__.__eq__,                    ["Event"],               true, "asyncio.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [evt_name_len,   Event.__name__.__len__,                   [],                      5,    "asyncio.Event.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [evt_mod_eq,     Event.__module__.__eq__,                  ["asyncio.locks"],        true, "asyncio.Event.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [evt_mod_len,    Event.__module__.__len__,                 [],                      13,   "asyncio.Event.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [evt_base_eq,    "Event.__bases__[0].__name__.__eq__",     ["_LoopBoundMixin"],      true, "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra249
# ---------------------------------------------------------------------------

invariant asyncio_extra249.lock_name_eq:
  description: "asyncio.Lock.__name__.__eq__('Lock') returns True — the class is named 'Lock' (len=4, shortest name among the five primitives in this spec); it lives in asyncio.locks (len=13); Lock.__bases__[0].__name__ == '_ContextManagerMixin'; Semaphore.__name__ == 'Semaphore' (len=9); BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16, longest); Condition.__name__ == 'Condition' (len=9); Event.__name__ == 'Event' (len=5); all five share asyncio.locks module; NEW in extra249: first standalone Lock name equality invariant in aio249ls namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra249.boundedsemaphore_base_is_semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — BoundedSemaphore inherits from Semaphore (not from _ContextManagerMixin directly); this makes BoundedSemaphore the only primitive in this spec that has another asyncio class as its direct base; inheritance chain: BoundedSemaphore -> Semaphore -> _ContextManagerMixin; BoundedSemaphore.__module__ == 'asyncio.locks' (len=13); BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); NEW in extra249: first standalone BoundedSemaphore base invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra249.boundedsemaphore_single_base_raises_indexerror:
  description: "asyncio.BoundedSemaphore.__bases__[1] raises IndexError — BoundedSemaphore has exactly one direct base class (Semaphore); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms the single-inheritance contract: BoundedSemaphore -> Semaphore -> _ContextManagerMixin; BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); BoundedSemaphore.__module__ == 'asyncio.locks' (len=13); NEW in extra249: first standalone BoundedSemaphore single-base IndexError invariant; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "BoundedSemaphore.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant asyncio_extra249.event_base_is_loopboundmixin:
  description: "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — Event is the only synchronization primitive among the five (Lock, Semaphore, BoundedSemaphore, Condition, Event) that inherits from _LoopBoundMixin rather than _ContextManagerMixin; Event.__module__ == 'asyncio.locks' (len=13); Event.__name__ == 'Event' (len=5); Lock, Semaphore, and Condition all have _ContextManagerMixin as their base; BoundedSemaphore has Semaphore; NEW in extra249: first standalone Event base invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true
