spec: hashlib_extra128
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra127.zspec.zsdl — covers algorithms_guaranteed/__iter__().__class__.__name__=='set_iterator' / algorithms_available/__iter__().__class__.__name__=='set_iterator' / algorithms_available.__len__()==19 / guaranteed.issubset(available) / available.issuperset(guaranteed) / algorithms_available.__contains__ for ripemd160/sm3/sha512_224/sha512_256/md5-sha1 (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s __class__.__name__=='type' and __module__=='_blake2' and __qualname__ equality / new __class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_224/sha3_256/sha3_384/sha3_512/shake_128/shake_256 constructor __qualname__/__module__/__class__.__name__=='builtin_function_or_method' / file_digest __class__.__name__/__qualname__/__module__/co_argcount / __all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__()==10 (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier hashlib specs."
    - "Wave 276 theme: hashlib sha3 and blake2 instance attributes — digest_size, block_size, name, and __class__.__name__ of hash instances."
    - "hashlib.sha3_224().digest_size == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384().digest_size == 48. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224().block_size == 144. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().block_size == 136. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384().block_size == 104. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().block_size == 72. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().__class__.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b().digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s().digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b().block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b().__class__.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s().__class__.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha3 instances (sha3_224/sha3_256/sha3_384/sha3_512) all have __class__.__name__=='HASH', unlike the constructor functions which are 'builtin_function_or_method'. The HASH type is the OpenSSL-backed hash object type from _hashlib."
    - "Note: blake2b/blake2s instances have __class__.__name__ equal to their algorithm name ('blake2b'/'blake2s') because blake2b and blake2s are C-extension type objects (not OpenSSL-backed functions). The constructor IS the type."
    - "Note: sha3 block sizes differ: sha3_224 (144), sha3_256 (136), sha3_384 (104), sha3_512 (72). These reflect the Keccak sponge rate (1600 - 2*digest_size_bits) in bytes."
    - "Note: blake2b block_size (128) reflects the 1024-bit block size of the BLAKE2b algorithm. blake2s block_size (64) reflects the 512-bit block size of BLAKE2s."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_224().digest_size.__eq__(28)
# hashlib.sha3_256().digest_size.__eq__(32)
# hashlib.sha3_384().digest_size.__eq__(48)
# hashlib.sha3_512().digest_size.__eq__(64)
#
# Wave 276 theme: sha3 family instance digest_size values.
#
# The sha3 family follows the NIST standard: sha3_224 yields 28-byte digests,
# sha3_256 yields 32, sha3_384 yields 48, sha3_512 yields 64. These match
# the SHA-2 family digest sizes with the same numeric suffix. All sha3 instances
# are HASH objects from the _hashlib C extension. No prior hashlib spec anchors
# sha3 instance digest_size values under hashlibinst128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra128.sha3_digest_sizes:
  description: "hashlib.sha3_224().digest_size.__eq__(28)==True / sha3_256().digest_size.__eq__(32)==True / sha3_384().digest_size.__eq__(48)==True / sha3_512().digest_size.__eq__(64)==True — sha3 family instances; digest sizes match SHA-2 numeric suffix convention; all return HASH objects from _hashlib; no prior hashlib spec anchors sha3 instance digest_size; first hashlibinst128 anchor"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hashlibinst128

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_digest, "sha3_224().digest_size.__eq__", [28], true, "sha3_224 produces 28-byte (224-bit) digests per NIST FIPS 202"]
    - [sha3_256_digest, "sha3_256().digest_size.__eq__", [32], true, "sha3_256 produces 32-byte (256-bit) digests per NIST FIPS 202"]
    - [sha3_384_digest, "sha3_384().digest_size.__eq__", [48], true, "sha3_384 produces 48-byte (384-bit) digests per NIST FIPS 202"]
    - [sha3_512_digest, "sha3_512().digest_size.__eq__", [64], true, "sha3_512 produces 64-byte (512-bit) digests per NIST FIPS 202"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224().block_size.__eq__(144)
# hashlib.sha3_256().block_size.__eq__(136)
# hashlib.sha3_384().block_size.__eq__(104)
# hashlib.sha3_512().block_size.__eq__(72)
#
# Wave 276 theme: sha3 family instance block_size values.
#
# SHA-3 uses the Keccak sponge function. The block_size (rate) is
# (1600 - 2 * digest_bits) / 8 bytes: sha3_224: (1600-448)/8=144,
# sha3_256: (1600-512)/8=136, sha3_384: (1600-768)/8=104,
# sha3_512: (1600-1024)/8=72. No prior hashlib spec anchors sha3 instance
# block_size values under hashlibinst128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra128.sha3_block_sizes:
  description: "hashlib.sha3_224().block_size.__eq__(144)==True / sha3_256().block_size.__eq__(136)==True / sha3_384().block_size.__eq__(104)==True / sha3_512().block_size.__eq__(72)==True — Keccak sponge rate = (1600 - 2*digest_bits)/8 bytes; sha3_224: 144, sha3_256: 136, sha3_384: 104, sha3_512: 72; no prior hashlib spec anchors sha3 instance block_size; first hashlibinst128 anchor"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hashlibinst128

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_block, "sha3_224().block_size.__eq__", [144], true, "sha3_224 block_size is 144 (Keccak rate: (1600-448)/8)"]
    - [sha3_256_block, "sha3_256().block_size.__eq__", [136], true, "sha3_256 block_size is 136 (Keccak rate: (1600-512)/8)"]
    - [sha3_384_block, "sha3_384().block_size.__eq__", [104], true, "sha3_384 block_size is 104 (Keccak rate: (1600-768)/8)"]
    - [sha3_512_block, "sha3_512().block_size.__eq__", [72],  true, "sha3_512 block_size is 72 (Keccak rate: (1600-1024)/8)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256().__class__.__name__.__eq__('HASH')
# hashlib.sha3_512().__class__.__name__.__eq__('HASH')
# hashlib.blake2b().digest_size.__eq__(64)
# hashlib.blake2s().digest_size.__eq__(32)
# hashlib.blake2b().block_size.__eq__(128)
# hashlib.blake2s().block_size.__eq__(64)
# hashlib.blake2b().__class__.__name__.__eq__('blake2b')
# hashlib.blake2s().__class__.__name__.__eq__('blake2s')
#
# Wave 276 theme: sha3 instance class name and blake2 instance properties.
#
# sha3 instances (HASH objects from _hashlib) have __class__.__name__ == 'HASH',
# unlike the constructor functions which are 'builtin_function_or_method'.
# blake2b and blake2s instances have __class__.__name__ equal to their algorithm
# name because the constructor IS the type (a C-extension class from _blake2).
# blake2b block_size is 128 (1024-bit BLAKE2b block); blake2s is 64 (512-bit BLAKE2s).
# No prior hashlib spec anchors any of these under hashlibinst128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra128.sha3_class_and_blake2_props:
  description: "sha3_256().__class__.__name__.__eq__('HASH')==True / sha3_512().__class__.__name__.__eq__('HASH')==True / blake2b().digest_size.__eq__(64)==True / blake2s().digest_size.__eq__(32)==True / blake2b().block_size.__eq__(128)==True / blake2s().block_size.__eq__(64)==True / blake2b().__class__.__name__.__eq__('blake2b')==True / blake2s().__class__.__name__.__eq__('blake2s')==True — sha3 instances are HASH objects; blake2 instances ARE the type object (constructor is the class); no prior spec anchors these; first hashlibinst128 anchor"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hashlibinst128

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_class,    "sha3_256().__class__.__name__.__eq__",  ["HASH"],    true, "sha3_256() instance __class__.__name__ is 'HASH' (OpenSSL-backed hash object from _hashlib)"]
    - [sha3_512_class,    "sha3_512().__class__.__name__.__eq__",  ["HASH"],    true, "sha3_512() instance __class__.__name__ is 'HASH' (same HASH type for all sha3 variants)"]
    - [blake2b_digest,    "blake2b().digest_size.__eq__",          [64],        true, "blake2b() default digest_size is 64 bytes (512-bit output; can be shortened via digest_size arg)"]
    - [blake2s_digest,    "blake2s().digest_size.__eq__",          [32],        true, "blake2s() default digest_size is 32 bytes (256-bit output; can be shortened via digest_size arg)"]
    - [blake2b_block,     "blake2b().block_size.__eq__",           [128],       true, "blake2b() block_size is 128 bytes (1024-bit BLAKE2b block size)"]
    - [blake2s_block,     "blake2s().block_size.__eq__",           [64],        true, "blake2s() block_size is 64 bytes (512-bit BLAKE2s block size)"]
    - [blake2b_instclass, "blake2b().__class__.__name__.__eq__",   ["blake2b"], true, "blake2b() instance __class__.__name__ is 'blake2b' (constructor IS the C-extension class)"]
    - [blake2s_instclass, "blake2s().__class__.__name__.__eq__",   ["blake2s"], true, "blake2s() instance __class__.__name__ is 'blake2s' (constructor IS the C-extension class)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256().digest_size.__eq__(32) — standalone
#
# hashlib.sha3_256().digest_size is 32. sha3_256 produces 32-byte (256-bit)
# digests conforming to NIST FIPS 202. The digest_size attribute on the hash
# instance reflects the output length in bytes. For SHA-3, the digest_size
# equals the numeric suffix divided by 8 (256/8 = 32). No prior hashlib spec
# anchors sha3_256().digest_size as a standalone under hashlibinst128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra128.sha3_256_digest_size_32:
  description: "hashlib.sha3_256().digest_size.__eq__(32) == True — sha3_256 produces 32-byte (256-bit) digests per NIST FIPS 202; digest_size equals numeric suffix / 8 (256/8=32); no prior hashlib spec anchors sha3_256().digest_size as standalone; first standalone under hashlibinst128"
  category: hash_properties
  kind: python_call_eq
  function: "sha3_256().digest_size.__eq__"
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512().digest_size.__eq__(64) — standalone
#
# hashlib.sha3_512().digest_size is 64. sha3_512 produces 64-byte (512-bit)
# digests. The sha3_512 digest_size equals blake2b's default digest_size (64),
# but the two algorithms are independent: sha3_512 comes from _hashlib (OpenSSL),
# blake2b from _blake2. No prior hashlib spec anchors sha3_512().digest_size
# as a standalone under hashlibinst128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra128.sha3_512_digest_size_64:
  description: "hashlib.sha3_512().digest_size.__eq__(64) == True — sha3_512 produces 64-byte (512-bit) digests; same numeric value as blake2b default digest_size but independent algorithms from different C extensions (_hashlib vs _blake2); no prior spec anchors sha3_512().digest_size as standalone; first standalone under hashlibinst128"
  category: hash_properties
  kind: python_call_eq
  function: "sha3_512().digest_size.__eq__"
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256().__class__.__name__.__eq__('HASH') — standalone
#
# hashlib.sha3_256().__class__.__name__ is 'HASH'. The HASH type is the
# C-level hash object type from the _hashlib extension. All sha3 variants
# (sha3_224, sha3_256, sha3_384, sha3_512) return HASH instances. This contrasts
# with the constructor functions themselves (sha3_256.__class__.__name__ is
# 'builtin_function_or_method'). No prior hashlib spec anchors the sha3 instance
# class name as a standalone under hashlibinst128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra128.sha3_256_instance_class_HASH:
  description: "hashlib.sha3_256().__class__.__name__.__eq__('HASH') == True — sha3_256 instance is a HASH object from _hashlib (not the same as the constructor function which is 'builtin_function_or_method'); all sha3 variants return HASH instances; no prior spec anchors sha3 instance class name as standalone; first standalone under hashlibinst128"
  category: hash_properties
  kind: python_call_eq
  function: "sha3_256().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b().digest_size.__eq__(64) — standalone
#
# hashlib.blake2b().digest_size is 64. The blake2b default digest size is
# 64 bytes (512-bit), the maximum for BLAKE2b. The digest_size can be reduced
# by passing digest_size=N to the constructor (N in 1..64). blake2b and blake2s
# are unique among hashlib algorithms in allowing variable-length output.
# No prior hashlib spec anchors blake2b().digest_size as a standalone under
# hashlibinst128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra128.blake2b_digest_size_64:
  description: "hashlib.blake2b().digest_size.__eq__(64) == True — blake2b default digest_size is 64 bytes (512-bit maximum for BLAKE2b); digest_size can be shortened via constructor arg (1..64); BLAKE2b allows variable-length output unlike fixed-size sha3 variants; no prior spec anchors blake2b().digest_size as standalone; first standalone under hashlibinst128"
  category: hash_properties
  kind: python_call_eq
  function: "blake2b().digest_size.__eq__"
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s().block_size.__eq__(64) — standalone
#
# hashlib.blake2s().block_size is 64. BLAKE2s uses a 512-bit (64-byte) block
# size, suited for 8-bit to 32-bit platforms. blake2b by contrast uses a
# 1024-bit (128-byte) block size, optimized for 64-bit platforms. The block_size
# attribute is available on all hash instances and is used by HMAC to compute
# padding. No prior hashlib spec anchors blake2s().block_size as a standalone
# under hashlibinst128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra128.blake2s_block_size_64:
  description: "hashlib.blake2s().block_size.__eq__(64) == True — BLAKE2s uses a 64-byte (512-bit) block size suited for 32-bit platforms; blake2b uses 128-byte (1024-bit) blocks for 64-bit platforms; block_size is used by HMAC for padding; no prior spec anchors blake2s().block_size as standalone; first standalone under hashlibinst128"
  category: hash_properties
  kind: python_call_eq
  function: "blake2s().block_size.__eq__"
  args: [64]
  expected: true
