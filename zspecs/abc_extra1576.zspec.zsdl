spec: abc_extra1576
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "Tests cover __str__ and __repr__ of abc.ABC, abc.ABCMeta, and abc.abstractmethod."
    - "abc.ABC is a helper class with ABCMeta as its metaclass. Its str and repr are the standard class representations."
    - "abc.ABCMeta is a metaclass (subclass of type). Its str/repr are the standard type representations."
    - "abc.abstractmethod is a decorator function; its __name__ == 'abstractmethod'."
    - "abc.get_cache_token() returns an int whose value increases each time ABCMeta.__subclasshook__ is called."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Class __name__ identity checks
# ---------------------------------------------------------------------------

table abc_extra1576.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: ab1576

  columns: [id, function, args, expected]
  rows:
    - ["ab1576_001", "ABC.__name__.__eq__",            ["ABC"],            true]
    - ["ab1576_002", "ABCMeta.__name__.__eq__",        ["ABCMeta"],        true]
    - ["ab1576_003", "abstractmethod.__name__.__eq__", ["abstractmethod"], true]

# ---------------------------------------------------------------------------
# __str__ of class objects — str(SomeClass) == "<class 'module.SomeClass'>"
# The exact module path may vary; we verify the fixed prefix "<class '" and
# that the class name appears within the string.
# ---------------------------------------------------------------------------

invariant abc_extra1576.abc.str_contains_class_prefix:
  description: "str(abc.ABC) starts with '<class'"
  category: str_repr
  kind: python_call_eq
  function: ABC.__str__
  args: []
  method_chain: startswith
  expected: true

invariant abc_extra1576.abc.str_exact:
  description: "str(abc.ABC) == \"<class 'abc.ABC'>\""
  category: str_repr
  kind: python_call_eq
  function: ABC.__str__
  args: []
  expected: "<class 'abc.ABC'>"

invariant abc_extra1576.abcmeta.str_exact:
  description: "str(abc.ABCMeta) == \"<class 'abc.ABCMeta'>\""
  category: str_repr
  kind: python_call_eq
  function: ABCMeta.__str__
  args: []
  expected: "<class 'abc.ABCMeta'>"

# ---------------------------------------------------------------------------
# __repr__ of class objects — repr() is the same as str() for type objects
# ---------------------------------------------------------------------------

invariant abc_extra1576.abc.repr_exact:
  description: "repr(abc.ABC) == \"<class 'abc.ABC'>\""
  category: str_repr
  kind: python_call_eq
  function: ABC.__repr__
  args: []
  expected: "<class 'abc.ABC'>"

invariant abc_extra1576.abcmeta.repr_exact:
  description: "repr(abc.ABCMeta) == \"<class 'abc.ABCMeta'>\""
  category: str_repr
  kind: python_call_eq
  function: ABCMeta.__repr__
  args: []
  expected: "<class 'abc.ABCMeta'>"

# ---------------------------------------------------------------------------
# abstractmethod — __name__, __qualname__, __module__
# abstractmethod is a plain Python function (decorator).
# ---------------------------------------------------------------------------

invariant abc_extra1576.abstractmethod.name:
  description: "abc.abstractmethod.__name__ == 'abstractmethod'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra1576.abstractmethod.qualname:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra1576.abstractmethod.module_is_abc:
  description: "abc.abstractmethod.__module__ == 'abc'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra1576.abstractmethod.is_callable:
  description: "abstractmethod is callable — type(abstractmethod).__name__ == 'function'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# abstractmethod applied to a lambda — the decorator sets __isabstractmethod__
# and preserves the wrapped function identity.
# abstractmethod(lambda: None).__isabstractmethod__ == True
# abstractmethod(lambda: None).__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

# NOTE: lambdas cannot be passed as JSON args. We test the __isabstractmethod__
# attribute via the decorator's own __isabstractmethod__ attribute flag, and
# verify abstractmethod identity via __name__ as above.

# ---------------------------------------------------------------------------
# Inheritance — ABCMeta is a subclass of type
# ---------------------------------------------------------------------------

invariant abc_extra1576.abcmeta.parent_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from type"
  category: inheritance
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

invariant abc_extra1576.abc.metaclass_is_abcmeta:
  description: "type(abc.ABC).__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta"
  category: inheritance
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra1576.abc.parent_is_object:
  description: "abc.ABC.__bases__[0].__name__ == 'object'"
  category: inheritance
  kind: python_call_eq
  function: ABC.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# get_cache_token() — returns an int; str() of it is numeric
# ---------------------------------------------------------------------------

invariant abc_extra1576.get_cache_token.returns_int:
  description: "type(abc.get_cache_token()).__name__ == 'int'"
  category: cache_token
  kind: python_call_eq
  function: get_cache_token
  args: []
  method_chain: __class__.__name__
  expected: "int"

invariant abc_extra1576.get_cache_token.str_is_numeric:
  description: "str(abc.get_cache_token()).isnumeric() == True"
  category: cache_token
  kind: python_call_eq
  function: get_cache_token
  args: []
  method_chain: __str__.__call__
  expected: true

invariant abc_extra1576.get_cache_token.class_name_is_int:
  description: "abc.get_cache_token().__class__.__name__ == 'int'"
  category: cache_token
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# str() content checks — class str contains the class name
# ---------------------------------------------------------------------------

table abc_extra1576.class_str_contains_name:
  kind: python_call_eq
  category: str_repr
  id_prefix: ab1576

  columns: [id, function, args, expected]
  rows:
    - ["ab1576_010", "ABC.__str__.__call__.__contains__",    ["ABC"],    true]
    - ["ab1576_011", "ABCMeta.__str__.__call__.__contains__", ["ABCMeta"], true]

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

table abc_extra1576.module_membership:
  kind: python_call_eq
  category: module
  id_prefix: ab1576

  columns: [id, function, args, expected]
  rows:
    - ["ab1576_020", "ABC.__module__.__eq__",            ["abc"], true]
    - ["ab1576_021", "ABCMeta.__module__.__eq__",        ["abc"], true]
    - ["ab1576_022", "abstractmethod.__module__.__eq__", ["abc"], true]

# ---------------------------------------------------------------------------
# abstractmethod.__str__ — str() of the function object contains 'abstractmethod'
# ---------------------------------------------------------------------------

invariant abc_extra1576.abstractmethod.str_contains_name:
  description: "str(abc.abstractmethod) contains 'abstractmethod'"
  category: str_repr
  kind: python_call_eq
  function: abstractmethod.__str__
  args: []
  method_chain: __contains__
  expected: true

invariant abc_extra1576.abstractmethod.str_contains_function:
  description: "str(abc.abstractmethod) contains 'function'"
  category: str_repr
  kind: python_call_eq
  function: abstractmethod.__repr__
  args: []
  method_chain: startswith
  expected: true
