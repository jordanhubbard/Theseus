spec: decimal_extra1426
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers __format__ and __dir__ method type/presence for decimal module classes. The key distinguishing fact in this batch: decimal.Decimal.__dict__.__contains__('__format__')==True (Decimal is a C-level type from _decimal that defines its own __format__ in its __dict__; this is the only class in this batch with '__format__' in its own dict). All other classes (Context, DecimalException, InvalidOperation) have __format__.__class__.__name__=='method_descriptor' but do NOT have '__format__' in their own __dict__. No class in this batch defines '__dir__' in its own __dict__. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal.__dict__.__contains__('__format__')==True is the key distinguishing invariant: Decimal defines __format__ in its own C-level dict (allowing format specifiers like '{:f}', '{:e}', '{:g}' to work on Decimal objects). decimal.Decimal.__format__.__class__.__name__=='method_descriptor' (it is still a method_descriptor even in Decimal's own dict, as it is a C-level method). decimal.Context.__dict__.__contains__('__format__')==False (Context does not define __format__ in its own dict). decimal.DecimalException and decimal.InvalidOperation likewise do not define __format__ in their own dicts. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __format__ type and dict presence checks — extra1426
#
# decimal.Decimal.__format__.__class__.__name__                   == 'method_descriptor'
# decimal.Decimal.__dict__.__contains__('__format__')            == True   (KEY FACT)
# decimal.Context.__format__.__class__.__name__                   == 'method_descriptor'
# decimal.Context.__dict__.__contains__('__format__')            == False
# decimal.DecimalException.__format__.__class__.__name__          == 'method_descriptor'
# decimal.DecimalException.__dict__.__contains__('__format__')   == False
# decimal.InvalidOperation.__format__.__class__.__name__          == 'method_descriptor'
# decimal.InvalidOperation.__dict__.__contains__('__format__')   == False
# ---------------------------------------------------------------------------

table decimal_extra1426.decimal_format_type:
  description: "decimal class __format__ method type and __dict__ presence checks — wave 542 extra1426 theme. The key distinguishing fact: decimal.Decimal.__dict__.__contains__('__format__')==True (Decimal is a C-level type from _decimal that defines its own __format__ method to support format specifiers like '{:f}', '{:e}', '{:g}'; this makes Decimal the only class in this batch with '__format__' in its own __dict__). decimal.Decimal.__format__.__class__.__name__=='method_descriptor' (even though it is in Decimal's own dict, the descriptor type is still 'method_descriptor' as it is a C-level method). decimal.Context.__dict__.__contains__('__format__')==False (Context is also C-level but does not define __format__). decimal.DecimalException.__dict__.__contains__('__format__')==False (exception class inherits from ArithmeticError->Exception->BaseException->object). decimal.InvalidOperation.__dict__.__contains__('__format__')==False. All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_introspection
  id_prefix: dc1426fm

  columns: [id, function, args, expected, description]
  rows:
    - [dc1426fm001, decimal.Decimal.__format__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Decimal.__format__.__class__.__name__ == 'method_descriptor' (C-level method; Decimal defines its own __format__ to support format specifiers); verified with Python 3.14.4"]
    - [dc1426fm002, decimal.Decimal.__dict__.__contains__,                         ["__format__"],         true,  "decimal.Decimal.__dict__.__contains__('__format__') == True (KEY FACT: Decimal is the only class in this batch that defines __format__ in its own __dict__; supports '{:f}' etc.); verified with Python 3.14.4"]
    - [dc1426fm003, decimal.Context.__format__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Context.__format__.__class__.__name__ == 'method_descriptor' (C-level type; inherits object.__format__); verified with Python 3.14.4"]
    - [dc1426fm004, decimal.Context.__dict__.__contains__,                         ["__format__"],         false, "decimal.Context.__dict__.__contains__('__format__') == False (Context does not define __format__ in its own dict); verified with Python 3.14.4"]
    - [dc1426fm005, decimal.DecimalException.__format__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.DecimalException.__format__.__class__.__name__ == 'method_descriptor' (inherits from ArithmeticError->Exception->BaseException->object chain); verified with Python 3.14.4"]
    - [dc1426fm006, decimal.DecimalException.__dict__.__contains__,                ["__format__"],         false, "decimal.DecimalException.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [dc1426fm007, decimal.InvalidOperation.__format__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.InvalidOperation.__format__.__class__.__name__ == 'method_descriptor' (MRO: [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object] len=6); verified with Python 3.14.4"]
    - [dc1426fm008, decimal.InvalidOperation.__dict__.__contains__,                ["__format__"],         false, "decimal.InvalidOperation.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# decimal class __dir__ type and dict presence checks — extra1426
#
# decimal.Decimal.__dir__.__class__.__name__                   == 'method_descriptor'
# decimal.Decimal.__dict__.__contains__('__dir__')            == False
# decimal.Context.__dir__.__class__.__name__                   == 'method_descriptor'
# decimal.Context.__dict__.__contains__('__dir__')            == False
# decimal.DecimalException.__dir__.__class__.__name__          == 'method_descriptor'
# decimal.InvalidOperation.__dict__.__contains__('__dir__')   == False
# ---------------------------------------------------------------------------

table decimal_extra1426.decimal_dir_type:
  description: "decimal class __dir__ method type and __dict__ presence checks — wave 542 extra1426 theme. Unlike __format__ (where Decimal defines its own), no decimal class defines '__dir__' in its own __dict__. decimal.Decimal.__dir__.__class__.__name__=='method_descriptor' (Decimal defines __format__ in own dict but not __dir__). decimal.Decimal.__dict__.__contains__('__dir__')==False. decimal.Context.__dir__.__class__.__name__=='method_descriptor'. decimal.Context.__dict__.__contains__('__dir__')==False. decimal.DecimalException.__dir__.__class__.__name__=='method_descriptor' (inherits via ArithmeticError chain). decimal.InvalidOperation.__dict__.__contains__('__dir__')==False. All verified with Python 3.14.4."
  kind: python_call_eq
  category: dir_introspection
  id_prefix: dc1426dr

  columns: [id, function, args, expected, description]
  rows:
    - [dc1426dr001, decimal.Decimal.__dir__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Decimal.__dir__.__class__.__name__ == 'method_descriptor' (Decimal defines __format__ but not __dir__ in own dict); verified with Python 3.14.4"]
    - [dc1426dr002, decimal.Decimal.__dict__.__contains__,                       ["__dir__"],            false, "decimal.Decimal.__dict__.__contains__('__dir__') == False (despite Decimal having __format__ in own dict, __dir__ is absent); verified with Python 3.14.4"]
    - [dc1426dr003, decimal.Context.__dir__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Context.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426dr004, decimal.Context.__dict__.__contains__,                       ["__dir__"],            false, "decimal.Context.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [dc1426dr005, decimal.DecimalException.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.DecimalException.__dir__.__class__.__name__ == 'method_descriptor' (inherits via ArithmeticError->Exception->BaseException->object chain); verified with Python 3.14.4"]
    - [dc1426dr006, decimal.DecimalException.__dict__.__contains__,              ["__dir__"],            false, "decimal.DecimalException.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [dc1426dr007, decimal.InvalidOperation.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.InvalidOperation.__dir__.__class__.__name__ == 'method_descriptor' (MRO len=6); verified with Python 3.14.4"]
    - [dc1426dr008, decimal.InvalidOperation.__dict__.__contains__,              ["__dir__"],            false, "decimal.InvalidOperation.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# decimal class __format__ and __dir__ cross-checks — extra1426
#
# Key asymmetry: Decimal.__dict__ contains '__format__' (True) but NOT '__dir__' (False).
# All other decimal classes have neither in their own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1426.decimal_format_dir_cross:
  description: "decimal class __format__ and __dir__ cross-checks — wave 542 extra1426. The key asymmetry in this batch: decimal.Decimal.__dict__.__contains__('__format__')==True but decimal.Decimal.__dict__.__contains__('__dir__')==False. Decimal defines __format__ in its own C-level dict (to support numeric format specifiers) but does not define __dir__. All other decimal classes (Context, DecimalException, InvalidOperation) have neither '__format__' nor '__dir__' in their own __dict__. Across all four classes, both __format__.__class__.__name__ and __dir__.__class__.__name__ are always 'method_descriptor'. All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_dir_cross
  id_prefix: dc1426cx

  columns: [id, function, args, expected, description]
  rows:
    - [dc1426cx001, decimal.Decimal.__format__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Decimal.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx002, decimal.Decimal.__dir__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "decimal.Decimal.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx003, decimal.Decimal.__dict__.__contains__,                         ["__format__"],         true,  "decimal.Decimal.__dict__.__contains__('__format__') == True (Decimal owns __format__); verified with Python 3.14.4"]
    - [dc1426cx004, decimal.Decimal.__dict__.__contains__,                         ["__dir__"],            false, "decimal.Decimal.__dict__.__contains__('__dir__') == False (Decimal does NOT own __dir__; key asymmetry); verified with Python 3.14.4"]
    - [dc1426cx005, decimal.Context.__format__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Context.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx006, decimal.Context.__dir__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "decimal.Context.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx007, decimal.Context.__dict__.__contains__,                         ["__format__"],         false, "decimal.Context.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [dc1426cx008, decimal.Context.__dict__.__contains__,                         ["__dir__"],            false, "decimal.Context.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [dc1426cx009, decimal.DecimalException.__format__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.DecimalException.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx010, decimal.DecimalException.__dir__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "decimal.DecimalException.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx011, decimal.InvalidOperation.__format__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.InvalidOperation.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [dc1426cx012, decimal.InvalidOperation.__dir__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "decimal.InvalidOperation.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
