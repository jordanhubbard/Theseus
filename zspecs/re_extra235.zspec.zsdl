spec: re_extra235
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern object method name contracts."
    - "re.Pattern.match.__name__ == 'match' — Pattern.match method name; verified Python 3.14.3 macOS."
    - "re.Pattern.search.__name__ == 'search' — Pattern.search method name; verified Python 3.14.3 macOS."
    - "re.Pattern.findall.__name__ == 'findall' — Pattern.findall method name; length 7; verified Python 3.14.3 macOS."
    - "re.Pattern.finditer.__name__ == 'finditer' — Pattern.finditer method name; length 8; verified Python 3.14.3 macOS."
    - "re.Pattern.sub.__name__ == 'sub' — Pattern.sub method name; length 3; verified Python 3.14.3 macOS."
    - "re.Pattern.subn.__name__ == 'subn' — Pattern.subn method name; length 4; verified Python 3.14.3 macOS."
    - "re.Pattern.split.__name__ == 'split' — Pattern.split method name; length 5; verified Python 3.14.3 macOS."
    - "re.Pattern.fullmatch.__name__ == 'fullmatch' — Pattern.fullmatch method name; length 9; verified Python 3.14.3 macOS."
    - "re.Pattern.__name__ == 'Pattern' — the Pattern class name; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __name__ contracts
# All standard Pattern methods carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra235.Pattern_method_names:
  description: "re.Pattern method __name__ contracts — match, search, findall, finditer, sub, subn, split, fullmatch; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: repatternmnames235

  columns: [id, function, args, expected]
  rows:
    - [pattern_match_name,     Pattern.match.__name__.__eq__,     ["match"],     true]
    - [pattern_search_name,    Pattern.search.__name__.__eq__,    ["search"],    true]
    - [pattern_findall_name,   Pattern.findall.__name__.__eq__,   ["findall"],   true]
    - [pattern_finditer_name,  Pattern.finditer.__name__.__eq__,  ["finditer"],  true]
    - [pattern_sub_name,       Pattern.sub.__name__.__eq__,       ["sub"],       true]
    - [pattern_subn_name,      Pattern.subn.__name__.__eq__,      ["subn"],      true]
    - [pattern_split_name,     Pattern.split.__name__.__eq__,     ["split"],     true]
    - [pattern_fullmatch_name, Pattern.fullmatch.__name__.__eq__, ["fullmatch"], true]

# ---------------------------------------------------------------------------
# re.Pattern class __name__ contract
# The Pattern class itself carries the canonical name 'Pattern'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra235.Pattern.class_name:
  description: "re.Pattern.__name__ == 'Pattern' — the Pattern class name is 'Pattern'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

# ---------------------------------------------------------------------------
# re.Pattern method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra235.Pattern.sub.name_length:
  description: "re.Pattern.sub.__name__.__len__() == 3 — 'sub' has 3 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Pattern.sub.__name__.__len__
  args: []
  expected: 3

invariant re_extra235.Pattern.subn.name_length:
  description: "re.Pattern.subn.__name__.__len__() == 4 — 'subn' has 4 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Pattern.subn.__name__.__len__
  args: []
  expected: 4

invariant re_extra235.Pattern.findall.name_length:
  description: "re.Pattern.findall.__name__.__len__() == 7 — 'findall' has 7 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Pattern.findall.__name__.__len__
  args: []
  expected: 7

invariant re_extra235.Pattern.finditer.name_length:
  description: "re.Pattern.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Pattern.finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra235.Pattern.fullmatch.name_length:
  description: "re.Pattern.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Pattern.fullmatch.__name__.__len__
  args: []
  expected: 9
