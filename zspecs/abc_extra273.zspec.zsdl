spec: abc_extra273
version: ">=3.12"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "https://docs.python.org/3/whatsnew/3.12.html#new-features — Python 3.12 new features (collections.abc.Buffer added)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "This spec covers: collections.abc.Buffer (added in Python 3.12) and collections.abc.ByteString (deprecated but present) class identity. NEW in extra273: collections.abc.Buffer.__name__=='Buffer'; collections.abc.Buffer.__module__=='collections.abc'; collections.abc.Buffer.__bases__[0].__name__=='object'; collections.abc.Buffer.__mro__.__len__()==2; collections.abc.Buffer.__qualname__=='Buffer'; collections.abc.Buffer.__name__.__len__()==6; collections.abc.ByteString.__name__=='ByteString'; collections.abc.ByteString.__module__=='collections.abc'; collections.abc.ByteString.__bases__[0].__name__=='Sequence'; collections.abc.ByteString.__mro__.__len__()==8 ([ByteString, Sequence, Reversible, Collection, Sized, Iterable, Container, object]); collections.abc.ByteString.__name__.__len__()==10. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Buffer was added in Python 3.12 (PEP 688). Buffer is a minimal ABC for objects that support the buffer protocol (__buffer__ method); Buffer.__mro__.__len__() is 2 ([Buffer, object]); Buffer.__bases__[0].__name__ is 'object' (direct subclass, no intermediate base). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.ByteString.__mro__.__len__() == 8. ByteString's MRO is [ByteString, Sequence, Reversible, Collection, Sized, Iterable, Container, object] — the longest MRO of any class in this spec; ByteString is deprecated since Python 3.12 but still present in 3.14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.ByteString.__bases__[0].__name__ == 'Sequence'. ByteString inherits from Sequence (not from Buffer or object directly); Sequence.__module__ is 'collections.abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "spec version is '>=3.12' (not '>=3.9') because collections.abc.Buffer was added in Python 3.12 and is required by this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Buffer class identity — extra273
# (added in Python 3.12, PEP 688)
#
# collections.abc.Buffer.__name__               == 'Buffer'
# collections.abc.Buffer.__module__             == 'collections.abc'
# collections.abc.Buffer.__bases__[0].__name__  == 'object'
# collections.abc.Buffer.__mro__.__len__()      == 2
# collections.abc.Buffer.__qualname__           == 'Buffer'
# collections.abc.Buffer.__name__.__len__()     == 6
# ---------------------------------------------------------------------------

table abc_extra273.cabc_buffer_identity:
  description: "collections.abc.Buffer class identity checks in cabcbuffer273 namespace — collections.abc.Buffer was added in Python 3.12 (PEP 688: Making the Buffer Protocol Accessible in Python); Buffer is the ABC for objects supporting the buffer protocol via __buffer__; Buffer.__name__.__eq__('Buffer')==True; Buffer.__module__.__eq__('collections.abc')==True (len=15: 'collections'=11+'.abc'=4); Buffer.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, minimal single-level hierarchy); Buffer.__mro__.__len__()==2 ([Buffer, object], minimal MRO); Buffer.__qualname__.__eq__('Buffer')==True (module-level class, qualname equals name); Buffer.__name__.__len__()==6 ('Buffer'=6, the shortest class name in this spec); this spec requires Python >=3.12 because Buffer did not exist in earlier versions; Buffer.__module__ is 'collections.abc' shared with ByteString and all other ABC classes in this spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcbuffer273

  columns: [id, function, args, expected, description]
  rows:
    - [buf_name_eq,    collections.abc.Buffer.__name__.__eq__,                  ["Buffer"],           true, "collections.abc.Buffer.__name__ == 'Buffer' (added Python 3.12); verified with Python 3.14.3"]
    - [buf_mod_eq,     collections.abc.Buffer.__module__.__eq__,                ["collections.abc"],  true, "collections.abc.Buffer.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [buf_base0_eq,   "collections.abc.Buffer.__bases__[0].__name__.__eq__",   ["object"],           true, "collections.abc.Buffer.__bases__[0].__name__ == 'object' — direct subclass of object; verified with Python 3.14.3"]
    - [buf_mro_len,    collections.abc.Buffer.__mro__.__len__,                  [],                   2,    "collections.abc.Buffer.__mro__.__len__() == 2 — [Buffer, object]; verified with Python 3.14.3"]
    - [buf_qn_eq,      collections.abc.Buffer.__qualname__.__eq__,              ["Buffer"],           true, "collections.abc.Buffer.__qualname__ == 'Buffer' (module-level class); verified with Python 3.14.3"]
    - [buf_name_len,   collections.abc.Buffer.__name__.__len__,                 [],                   6,    "collections.abc.Buffer.__name__.__len__() == 6 ('Buffer'=6, shortest class name in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc.ByteString class identity — extra273
# (deprecated since Python 3.12 but still present in 3.14)
#
# collections.abc.ByteString.__name__               == 'ByteString'
# collections.abc.ByteString.__module__             == 'collections.abc'
# collections.abc.ByteString.__bases__[0].__name__  == 'Sequence'
# collections.abc.ByteString.__mro__.__len__()      == 8
# collections.abc.ByteString.__qualname__           == 'ByteString'
# collections.abc.ByteString.__name__.__len__()     == 10
# ---------------------------------------------------------------------------

table abc_extra273.cabc_bytestring_identity:
  description: "collections.abc.ByteString class identity checks in cabcbuffer273a namespace — collections.abc.ByteString is deprecated since Python 3.12 but remains accessible in Python 3.14 (still present in Lib/_collections_abc.py); ByteString.__name__.__eq__('ByteString')==True; ByteString.__module__.__eq__('collections.abc')==True (len=15, same as Buffer); ByteString.__bases__[0].__name__.__eq__('Sequence')==True (ByteString inherits from Sequence as its sole direct base); ByteString.__mro__.__len__()==8 ([ByteString, Sequence, Reversible, Collection, Sized, Iterable, Container, object], the longest MRO in this spec); ByteString.__qualname__.__eq__('ByteString')==True (module-level class, qualname equals name); ByteString.__name__.__len__()==10 ('ByteString'=10, longer than Buffer.__name__.__len__()==6); the MRO depth 8 arises from Sequence's deep inheritance chain through Reversible, Collection, Sized, Iterable, and Container; compare MRO depths in this spec: Buffer=2 (new, minimal), ByteString=8 (old, deeply inherited); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcbuffer273a

  columns: [id, function, args, expected, description]
  rows:
    - [bs_name_eq,    collections.abc.ByteString.__name__.__eq__,                  ["ByteString"],       true, "collections.abc.ByteString.__name__ == 'ByteString' (deprecated since 3.12, still present in 3.14); verified with Python 3.14.3"]
    - [bs_mod_eq,     collections.abc.ByteString.__module__.__eq__,                ["collections.abc"],  true, "collections.abc.ByteString.__module__ == 'collections.abc' (len=15, same as Buffer); verified with Python 3.14.3"]
    - [bs_base0_eq,   "collections.abc.ByteString.__bases__[0].__name__.__eq__",   ["Sequence"],         true, "collections.abc.ByteString.__bases__[0].__name__ == 'Sequence' (inherits from Sequence, not from Buffer); verified with Python 3.14.3"]
    - [bs_mro_len,    collections.abc.ByteString.__mro__.__len__,                  [],                   8,    "collections.abc.ByteString.__mro__.__len__() == 8 — [ByteString, Sequence, Reversible, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [bs_qn_eq,      collections.abc.ByteString.__qualname__.__eq__,              ["ByteString"],       true, "collections.abc.ByteString.__qualname__ == 'ByteString' (module-level class); verified with Python 3.14.3"]
    - [bs_name_len,   collections.abc.ByteString.__name__.__len__,                 [],                   10,   "collections.abc.ByteString.__name__.__len__() == 10 ('ByteString'=10, longer than Buffer's 6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra273
# ---------------------------------------------------------------------------

invariant abc_extra273.Buffer_module_is_collections_abc:
  description: "collections.abc.Buffer.__module__.__eq__('collections.abc') returns True — collections.abc.Buffer is defined in Lib/_collections_abc.py and exposed as collections.abc.Buffer; added in Python 3.12 via PEP 688 (Making the Buffer Protocol Accessible in Python); Buffer.__module__ is 'collections.abc' (len=15: 'collections'=11+'.abc'=4); Buffer is the minimal ABC for objects supporting the buffer protocol; Buffer.__mro__.__len__() is 2 ([Buffer, object]); Buffer.__bases__[0].__name__ is 'object' (direct subclass, no intermediate base); Buffer.__name__.__len__() is 6 ('Buffer'=6); this spec requires Python >=3.12; all other collections.abc classes (ByteString, Awaitable, Buffer) share the same __module__ 'collections.abc'; NEW in extra273: first standalone Buffer.__module__ invariant in cabcbuffer273 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Buffer.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra273.Buffer_mro_len_is_2:
  description: "collections.abc.Buffer.__mro__.__len__() == 2 — Buffer's MRO is [Buffer, object] (length=2); this minimal 2-element chain reflects Buffer's direct inheritance from object with no intermediate ABC; Buffer is the simplest ABC in terms of MRO depth in this spec; compare MRO depths: Buffer=2 (minimal, new in 3.12), ByteString=8 (deep, deprecated since 3.12); Buffer requires only __buffer__() as its abstract method; the minimal depth reflects that Buffer is designed to be a simple, composable marker for the buffer protocol rather than a deep abstraction hierarchy; Buffer.__bases__[0].__name__ is 'object'; Buffer.__module__ is 'collections.abc'; NEW in extra273: first standalone Buffer MRO length invariant in cabcbuffer273 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Buffer.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra273.Buffer_base_is_object:
  description: "collections.abc.Buffer.__bases__[0].__name__.__eq__('object') returns True — Buffer inherits directly from object as its sole direct base; Buffer is designed to be a minimal ABC requiring only __buffer__() implementation; the direct-from-object inheritance (MRO length=2) makes Buffer easy to add to any existing class's bases without introducing hierarchy conflicts; contrast with ByteString (inherits from Sequence, MRO length=8) and Coroutine (inherits from Awaitable, MRO length=3); Buffer.__qualname__ is 'Buffer'; Buffer.__name__.__len__() is 6 ('Buffer'=6); Buffer was added in Python 3.12 alongside the deprecation of ByteString, providing a cleaner way to mark buffer-compatible types; NEW in extra273: first standalone Buffer base class invariant in cabcbuffer273 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Buffer.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra273.ByteString_module_is_collections_abc:
  description: "collections.abc.ByteString.__module__.__eq__('collections.abc') returns True — ByteString is defined in Lib/_collections_abc.py; its __module__ is 'collections.abc' (len=15, shared with Buffer); ByteString has been deprecated since Python 3.12 (use bytes, bytearray, or memoryview instead) but remains accessible in Python 3.14; ByteString.__bases__[0].__name__ is 'Sequence' (inherits from Sequence, which provides the deep 8-element MRO via Reversible, Collection, Sized, Iterable, Container, object); ByteString.__mro__.__len__() is 8, the longest in this spec; ByteString and Buffer were both affected by Python 3.12 changes: Buffer was added to provide a cleaner protocol-level hook while ByteString was deprecated; NEW in extra273: first standalone ByteString.__module__ invariant in cabcbuffer273 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.ByteString.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra273.ByteString_mro_len_is_8:
  description: "collections.abc.ByteString.__mro__.__len__() == 8 — ByteString's MRO is [ByteString, Sequence, Reversible, Collection, Sized, Iterable, Container, object] (length=8); this is the longest MRO in this spec; the deep chain arises from Sequence's own hierarchy: Sequence inherits from Reversible (which inherits from Iterable) and Collection (which inherits from Sized, Iterable, and Container); compare MRO depths in this spec: Buffer=2 (new, minimal), ByteString=8 (deprecated, deep); the MRO length difference between Buffer (2) and ByteString (8) is 6; ByteString.__bases__[0].__name__ is 'Sequence'; ByteString.__module__ is 'collections.abc'; ByteString.__name__.__len__() is 10 ('ByteString'=10); NEW in extra273: first standalone ByteString MRO length invariant in cabcbuffer273 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.ByteString.__mro__.__len__
  args: []
  expected: 8

invariant abc_extra273.ByteString_base_is_Sequence:
  description: "collections.abc.ByteString.__bases__[0].__name__.__eq__('Sequence') returns True — ByteString inherits from Sequence as its sole direct base; Sequence.__module__ is 'collections.abc'; Sequence's own MRO is [Sequence, Reversible, Collection, Sized, Iterable, Container, object] (length=7); adding ByteString at the front gives ByteString's MRO length 8 ([ByteString]+7); ByteString does not inherit from Buffer (Buffer was added in 3.12 after ByteString's deprecation also in 3.12); ByteString represents objects that act like sequences of bytes (bytes, bytearray, memoryview) but the type is deprecated because it did not work well in practice (e.g., isinstance(b'', ByteString) returned True but issubclass checks were fragile); ByteString.__name__.__len__() is 10 ('ByteString'=10); NEW in extra273: first standalone ByteString base class invariant in cabcbuffer273 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.ByteString.__bases__[0].__name__.__eq__"
  args: ["Sequence"]
  expected: true
