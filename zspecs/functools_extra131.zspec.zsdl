spec: functools_extra131
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES tuple identity; functools.wraps code object attributes (Wave 258)."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_ASSIGNMENTS) == 6 — contains '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS[0] == '__module__' — first element is '__module__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_UPDATES) == 1 — contains only '__dict__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES[0] == '__dict__'. Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a pure-Python decorator factory. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames[0] == 'wrapped' — first parameter is 'wrapped'. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 — takes wrapped, assigned, updated. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' (len 5). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.WRAPPER_ASSIGNMENTS tuple identity and membership
#
# Wave 258 theme: functools.WRAPPER_ASSIGNMENTS module-level tuple constant.
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
# functools.WRAPPER_ASSIGNMENTS[0] == '__module__'
#
# WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py
# listing the attributes copied from the wrapped function by functools.wraps.
# In Python 3.14 it has 6 members. New to extra131.
# ---------------------------------------------------------------------------

table functools_extra131.wrapper_assignments_identity:
  description: "functools.WRAPPER_ASSIGNMENTS tuple identity: class name, len==6, contains __module__/__name__/__qualname__, first elem; wave 258; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper131

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_name_eq_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py that lists the attributes to copy from the wrapped function when using functools.wraps; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra131"]
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS contains exactly 6 elements: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; len() == 6; new to extra131"]
    - [wrapper_assignments_contains_module,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element in WRAPPER_ASSIGNMENTS; functools.wraps copies the __module__ attribute from the wrapped function to the wrapper; tuple.__contains__('__module__') returns True; new to extra131"]
    - [wrapper_assignments_contains_name,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is included in WRAPPER_ASSIGNMENTS; functools.wraps copies __name__ from the wrapped function so the wrapper appears to have the same name; tuple.__contains__('__name__') returns True; new to extra131"]
    - [wrapper_assignments_contains_qualname,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is included in WRAPPER_ASSIGNMENTS so that functools.wraps copies the qualname from the wrapped function to the wrapper function; tuple.__contains__('__qualname__') returns True; new to extra131"]
    - [wrapper_assignments_first_elem_eq_module,
       "WRAPPER_ASSIGNMENTS[0].__eq__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS[0].__eq__('__module__') == True — the first element of WRAPPER_ASSIGNMENTS is '__module__'; the tuple is ordered with __module__ first; str.__eq__('__module__') returns True; new to extra131"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_UPDATES tuple identity
#
# Wave 258 theme: functools.WRAPPER_UPDATES module-level tuple constant.
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_UPDATES) == 1
# functools.WRAPPER_UPDATES[0] == '__dict__'
# functools.WRAPPER_UPDATES.__contains__('__dict__') == True
#
# WRAPPER_UPDATES is a module-level tuple constant listing the attributes
# that are updated (not replaced) by functools.wraps; it contains only '__dict__'.
# New to extra131.
# ---------------------------------------------------------------------------

table functools_extra131.wrapper_updates_identity:
  description: "functools.WRAPPER_UPDATES tuple identity: class name 'tuple', len==1, contains '__dict__', first elem '__dict__'; wave 258; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper131

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_class_name_eq_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant in Lib/functools.py that lists the attributes to update (dict.update) rather than replace; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra131"]
    - [wrapper_updates_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains exactly one element: '__dict__'; functools.wraps calls wrapper.__dict__.update(wrapped.__dict__) to merge the wrapped function's __dict__ into the wrapper; len() == 1; new to extra131"]
    - [wrapper_updates_first_elem_eq_dict,
       "WRAPPER_UPDATES[0].__eq__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES[0].__eq__('__dict__') == True — the single element of WRAPPER_UPDATES is '__dict__'; functools.wraps uses this to update the wrapper's __dict__ with any attributes set on the wrapped function; str.__eq__('__dict__') returns True; new to extra131"]
    - [wrapper_updates_contains_dict,
       "WRAPPER_UPDATES.__contains__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the only element in WRAPPER_UPDATES; tuple.__contains__('__dict__') returns True; new to extra131"]

# ---------------------------------------------------------------------------
# Table 3: functools.wraps code object attributes
#
# Wave 258 theme: functools.wraps decorator factory code object identity.
#
# functools.wraps.__class__.__name__ == 'function'
# functools.wraps.__code__.co_varnames[0] == 'wrapped'
# functools.wraps.__code__.co_argcount == 3
# functools.wraps.__qualname__ == 'wraps' (len 5)
# functools.wraps.__module__ == 'functools'
#
# wraps is a pure-Python decorator factory defined in Lib/functools.py;
# it takes three arguments: wrapped, assigned, and updated. New to extra131.
# ---------------------------------------------------------------------------

table functools_extra131.wraps_code_attrs:
  description: "functools.wraps code object: __class__.__name__=='function', co_varnames[0]=='wrapped', co_argcount==3, __qualname__ len==5, __module__=='functools'; wave 258; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper131

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_name_eq_function,
       "wraps.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a pure-Python decorator factory defined with 'def wraps(wrapped, ...)' in Lib/functools.py; it is a plain Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra131"]
    - [wraps_co_varnames_first_eq_wrapped,
       "wraps.__code__.co_varnames[0].__eq__",
       ["wrapped"],
       true,
       "functools.wraps.__code__.co_varnames[0].__eq__('wrapped') == True — wraps is defined as 'def wraps(wrapped, assigned=..., updated=...)'; its first parameter is named 'wrapped' (the function to be decorated); co_varnames[0] is 'wrapped'; str.__eq__('wrapped') returns True; new to extra131"]
    - [wraps_co_argcount_eq_3,
       "wraps.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps takes three positional arguments: 'wrapped' (the function to be wrapped), 'assigned' (defaults to WRAPPER_ASSIGNMENTS), and 'updated' (defaults to WRAPPER_UPDATES); co_argcount is 3; int.__eq__(3) returns True; new to extra131"]
    - [wraps_qualname_eq_wraps,
       "wraps.__qualname__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is defined at module scope in Lib/functools.py; its __qualname__ is the simple function name 'wraps'; str.__eq__('wraps') returns True; new to extra131"]
    - [wraps_qualname_len_eq_5,
       "wraps.__qualname__.__len__",
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — __qualname__ is 'wraps' which has exactly 5 characters; len('wraps') == 5; new to extra131"]
    - [wraps_module_eq_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra131"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra131
# ---------------------------------------------------------------------------

invariant functools_extra131.wrapper_assignments_class_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — module-level tuple constant; wave 258; new to extra131"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra131.wrapper_assignments_len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 — six attributes copied by wraps in Python 3.14; wave 258; new to extra131"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra131.wrapper_updates_len:
  description: "len(functools.WRAPPER_UPDATES) == 1 — only '__dict__' is updated by wraps; wave 258; new to extra131"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra131.wraps_co_argcount:
  description: "functools.wraps.__code__.co_argcount == 3 — takes wrapped, assigned, updated; wave 258; new to extra131"
  kind: python_call_eq
  function: wraps.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra131.wraps_co_varnames_first:
  description: "functools.wraps.__code__.co_varnames[0] == 'wrapped' — first parameter is the function to be decorated; wave 258; new to extra131"
  kind: python_call_eq
  function: wraps.__code__.co_varnames[0].__eq__
  args: ["wrapped"]
  expected: true
