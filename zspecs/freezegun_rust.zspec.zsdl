spec: freezegun_rust
version: ">=3.9"
backend: rust_module(freezegun_rust)

docs: https://github.com/spulec/freezegun

provenance:
  derived_from:
    - "https://github.com/spulec/freezegun — freezegun documentation"
  not_derived_from:
    - "freezegun source: freezegun/__init__.py"
  notes:
    - "freezegun allows freezing time for tests."
    - "from freezegun import freeze_time; freeze_time is callable."
    - "freezegun.freeze_time is available."
    - "freezegun.api.freeze_time is available."
    - "freezegun.__version__ is a non-empty string."
    - "Expose freezegun_has_freeze() -> bool: hasattr(freezegun, 'freeze_time')."
    - "Expose freezegun_freeze_callable() -> bool: callable(freezegun.freeze_time)."
    - "Expose freezegun_version_nonempty() -> bool: len(freezegun.__version__) > 0."
    - "All test vectors verified against freezegun 1.5.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# freezegun_has_freeze — freeze_time present
invariant freezegun_rust.module.has_freeze:
  description: "freezegun.freeze_time is available"
  category: module
  kind: python_call_eq
  function: freezegun_has_freeze
  args: []
  expected: true

# freezegun_freeze_callable — freeze_time is callable
invariant freezegun_rust.module.freeze_callable:
  description: "freezegun.freeze_time is callable"
  category: callable
  kind: python_call_eq
  function: freezegun_freeze_callable
  args: []
  expected: true

# freezegun_version_nonempty — version non-empty
invariant freezegun_rust.version.nonempty:
  description: "freezegun.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: freezegun_version_nonempty
  args: []
  expected: true

