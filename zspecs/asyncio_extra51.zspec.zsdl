invariant asyncio_extra51.Lock_acquire_qualname_eq:
  description: "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' — method defined directly on asyncio.Lock; __qualname__ is 12 chars"
  category: method_names
  kind: python_call_eq
  function: Lock.acquire.__qualname__.__eq__
  args: ["Lock.acquire"]
  expected: true

invariant asyncio_extra51.Lock_release_qualname_eq:
  description: "asyncio.Lock.release.__qualname__ == 'Lock.release' — method defined directly on asyncio.Lock; __qualname__ is 12 chars"
