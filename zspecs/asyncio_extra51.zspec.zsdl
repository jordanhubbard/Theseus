spec: asyncio_extra51
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec extends asyncio_extra50.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() (extra30: Queue.put/get/put_nowait/get_nowait/join/task_done; Lock.acquire/release), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, MRO depths, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event/Semaphore method __qualname__ string values, BoundedSemaphore/Condition/TaskGroup/Runner identity, shield/ensure_future/create_task/get_event_loop/get_running_loop/new_event_loop/run/iscoroutine/iscoroutinefunction qualname/module, class/function __qualname__ string equality tables, Task/Future/Runner __qualname__.__len__(), Task/Future __name__/__module__/__qualname__, Task/__bases__[0].__name__=='Future', Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner/Task/Future __class__.__name__=='type', gather/sleep/run __class__.__name__=='function', class/function __class__.__name__.__len__() tables (extra47), Queue/Lock/Event/Semaphore/Task/Future __class__.__qualname__=='type', gather/sleep/run __class__.__qualname__=='function', class/function __class__.__qualname__.__len__() tables (extra48), QueueEmpty/QueueFull __class__.__name__=='type', QueueEmpty/QueueFull __bases__[0].__name__=='Exception', QueueEmpty/QueueFull __mro__.__len__()==4, exception __module__ string equality for QueueEmpty/QueueFull/InvalidStateError/TimeoutError/CancelledError (extra49), Queue/__doc__/__class__/__name__=='str' through asyncio module __doc__/__class__/__name__=='str', Queue/__doc__/__class__/__qualname__=='str', Lock/__doc__/__class__/__qualname__=='str', module __doc__/__class__/__qualname__=='str' (extra50). Queue.put_nowait qualname string equality == 'Queue.put_nowait' (extra30 standalone)."
    - "This spec covers: asyncio.Queue method __qualname__ string equality for put/get/get_nowait/join/task_done; asyncio.Lock method __qualname__ string equality for acquire/release; asyncio.__all__.__class__.__name__ == 'list'."
    - "asyncio.Queue.put.__qualname__ == 'Queue.put'. The put method is defined directly on asyncio.Queue in Lib/asyncio/queues.py; its __qualname__ follows the 'ClassName.method_name' pattern. 'Queue.put' is 9 characters (matching the length from extra30). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.get.__qualname__ == 'Queue.get'. The get method is defined directly on asyncio.Queue; its __qualname__ is 'Queue.get' (9 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait'. The get_nowait method is defined directly on asyncio.Queue; its __qualname__ is 'Queue.get_nowait' (16 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.join.__qualname__ == 'Queue.join'. The join method is defined directly on asyncio.Queue; its __qualname__ is 'Queue.join' (10 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.task_done.__qualname__ == 'Queue.task_done'. The task_done method is defined directly on asyncio.Queue; its __qualname__ is 'Queue.task_done' (15 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire'. The acquire method is defined directly on asyncio.Lock in Lib/asyncio/locks.py; its __qualname__ is 'Lock.acquire' (12 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.release.__qualname__ == 'Lock.release'. The release method is defined directly on asyncio.Lock; its __qualname__ is 'Lock.release' (12 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__class__.__name__ == 'list'. The asyncio module exposes __all__ as a plain Python list of exported names. list is a built-in type; __class__.__name__ == 'list'. This is distinct from the __all__.__len__() == 95 check in earlier specs; the present check observes the container type, not its cardinality. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue method __qualname__ string equality — extra51
#
# Prior spec extra30 captured __qualname__.__len__() for all six Queue public
# methods, and also captured Queue.put_nowait as a standalone string equality
# invariant. Extra51 completes the string equality checks for the remaining
# five methods:
#   Queue.put.__qualname__      == 'Queue.put'       (9 chars)
#   Queue.get.__qualname__      == 'Queue.get'       (9 chars)
#   Queue.get_nowait.__qualname__ == 'Queue.get_nowait' (16 chars)
#   Queue.join.__qualname__     == 'Queue.join'      (10 chars)
#   Queue.task_done.__qualname__ == 'Queue.task_done' (15 chars)
# Queue.put_nowait string equality was already captured as a standalone
# invariant in extra30 and is excluded here to avoid duplication.
# ---------------------------------------------------------------------------

table asyncio_extra51.queue_method_qualname_eq:
  description: "asyncio.Queue method __qualname__ string equality in extra51 namespace — complementing the length checks in asyncio_extra30"
  kind: python_call_eq
  category: method_names
  id_prefix: asynciometh51queuequal

  columns: [id, function, args, expected, description]
  rows:
    - [put,       Queue.put.__qualname__.__eq__,       ["Queue.put"],       true, "Queue.put.__qualname__ == 'Queue.put' (9 chars) — method defined directly on asyncio.Queue"]
    - [get,       Queue.get.__qualname__.__eq__,       ["Queue.get"],       true, "Queue.get.__qualname__ == 'Queue.get' (9 chars) — method defined directly on asyncio.Queue"]
    - [get_nowait, Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true, "Queue.get_nowait.__qualname__ == 'Queue.get_nowait' (16 chars) — method defined directly on asyncio.Queue"]
    - [join,      Queue.join.__qualname__.__eq__,      ["Queue.join"],      true, "Queue.join.__qualname__ == 'Queue.join' (10 chars) — method defined directly on asyncio.Queue"]
    - [task_done, Queue.task_done.__qualname__.__eq__, ["Queue.task_done"], true, "Queue.task_done.__qualname__ == 'Queue.task_done' (15 chars) — method defined directly on asyncio.Queue"]

# ---------------------------------------------------------------------------
# asyncio.Lock method __qualname__ string equality — extra51
#
# Prior spec extra30 captured __qualname__.__len__() for Lock.acquire (12)
# and Lock.release (12). Extra51 completes the full string equality checks:
#   Lock.acquire.__qualname__ == 'Lock.acquire'  (12 chars)
#   Lock.release.__qualname__ == 'Lock.release'  (12 chars)
# Both acquire and release are 7-character method names, yielding the same
# qualname length under the 'Lock.' (5-char) prefix.
# ---------------------------------------------------------------------------

table asyncio_extra51.lock_method_qualname_eq:
  description: "asyncio.Lock method __qualname__ string equality in extra51 namespace — complementing the length checks in asyncio_extra30"
  kind: python_call_eq
  category: method_names
  id_prefix: asynciometh51lockqual

  columns: [id, function, args, expected, description]
  rows:
    - [acquire, Lock.acquire.__qualname__.__eq__, ["Lock.acquire"], true, "Lock.acquire.__qualname__ == 'Lock.acquire' (12 chars) — method defined directly on asyncio.Lock"]
    - [release, Lock.release.__qualname__.__eq__, ["Lock.release"], true, "Lock.release.__qualname__ == 'Lock.release' (12 chars) — method defined directly on asyncio.Lock"]

# ---------------------------------------------------------------------------
# asyncio.__all__.__class__.__name__ — extra51
#
# asyncio exposes __all__ as a plain Python list (not a tuple or frozenset).
# Prior specs measured asyncio.__all__.__len__() == 95 (extra31 or similar),
# but never observed the container type itself. The list type is a built-in
# type; __class__.__name__ == 'list'. This is a distinct behavioral property
# from the cardinality check.
# ---------------------------------------------------------------------------

invariant asyncio_extra51.all_class_name_eq:
  description: "asyncio.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list; list is a built-in type with __class__.__name__ == 'list'"
  category: class_names
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra51
# ---------------------------------------------------------------------------

invariant asyncio_extra51.Queue_put_qualname_eq:
  description: "asyncio.Queue.put.__qualname__ == 'Queue.put' — method defined directly on asyncio.Queue; __qualname__ follows 'ClassName.method_name' pattern (9 chars)"
  category: method_names
  kind: python_call_eq
  function: Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true

invariant asyncio_extra51.Queue_get_qualname_eq:
  description: "asyncio.Queue.get.__qualname__ == 'Queue.get' — method defined directly on asyncio.Queue; __qualname__ follows 'ClassName.method_name' pattern (9 chars)"
  category: method_names
  kind: python_call_eq
  function: Queue.get.__qualname__.__eq__
  args: ["Queue.get"]
  expected: true

invariant asyncio_extra51.Queue_get_nowait_qualname_eq:
  description: "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait' — method defined directly on asyncio.Queue; __qualname__ is 16 chars"
  category: method_names
  kind: python_call_eq
  function: Queue.get_nowait.__qualname__.__eq__
  args: ["Queue.get_nowait"]
  expected: true

invariant asyncio_extra51.Queue_join_qualname_eq:
  description: "asyncio.Queue.join.__qualname__ == 'Queue.join' — method defined directly on asyncio.Queue; __qualname__ is 10 chars"
  category: method_names
  kind: python_call_eq
  function: Queue.join.__qualname__.__eq__
  args: ["Queue.join"]
  expected: true

invariant asyncio_extra51.Queue_task_done_qualname_eq:
  description: "asyncio.Queue.task_done.__qualname__ == 'Queue.task_done' — method defined directly on asyncio.Queue; __qualname__ is 15 chars"
  category: method_names
  kind: python_call_eq
  function: Queue.task_done.__qualname__.__eq__
  args: ["Queue.task_done"]
