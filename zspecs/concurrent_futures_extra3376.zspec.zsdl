    - ["cf3376011", operator.contains, [concurrent.futures.Future.__dict__,              "__round__"], false]
    - ["cf3376012", operator.contains, [concurrent.futures.Future.__dict__,              "__index__"], false]
    - ["cf3376013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__trunc__"], false]
