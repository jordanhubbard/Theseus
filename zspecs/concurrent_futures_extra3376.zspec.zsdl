    - ["cf3376015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__index__"], false]
    - ["cf3376016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__trunc__"], false]
