spec: cf3376
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (cf3376): __trunc__, __round__, __index__ dict-presence (math.trunc(x), round(x), operator.index(x)) for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__trunc__): all 3 concurrent.futures classes return false for __trunc__. math.trunc() delegates to __trunc__ (numbers.Real protocol) when defined. concurrent.futures types define no arithmetic protocol of any kind — confirmed false across waves 658–671 for all arithmetic, bitwise, reflected, in-place augmented assignment, unary numeric, and rounding operators. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine; math.trunc(future) is not a valid Python expression for a state-machine object. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); math.trunc(executor) is not defined."
    - "Key finding (__round__): all 3 concurrent.futures classes return false for __round__. round() delegates to __round__ (numbers.Real protocol). concurrent.futures types implement no numeric magnitude — a Future represents a pending asynchronous computation, not a scalar value that can be rounded. ThreadPoolExecutor/ProcessPoolExecutor are lifecycle managers for worker pools; round(executor, n) is not a defined Python operation. No numeric rounding protocol is implemented by any concurrent.futures type."
    - "Key finding (__index__): all 3 concurrent.futures classes return false for __index__. operator.index() requires __index__, which signals lossless integer conversion for use as a sequence index or in bin()/hex()/oct(). concurrent.futures types are not integer types. concurrent.futures.Future is a state-machine result handle, not an integer; it cannot be used as a slice index. ThreadPoolExecutor/ProcessPoolExecutor are pool lifecycle managers; the pool size is a constructor argument, not an __index__-accessible integer on the executor object itself."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, bitwise, unary numeric, numeric rounding, or integer-index protocol of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — operator.contains(Cls.__dict__, '__trunc__')
#
# All 3 concurrent.futures classes return false for __trunc__.
# math.trunc() delegates to __trunc__ (numbers.Real protocol) when defined.
# concurrent.futures.Future: a result handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; math.trunc(future) is not a valid Python expression for
#   a state-machine object. Future manages asynchronous results through
#   callbacks and state transitions, not numeric truncation.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   math.trunc(executor) is not defined. Pool configuration is not exposed
#   as a numeric value subject to truncation.
# ---------------------------------------------------------------------------

table cf3376.trunc:
  description: "concurrent.futures types __trunc__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3376

  columns: [id, function, args, expected]
  rows:
    - ["cf3376001", operator.contains, [concurrent.futures.Future.__dict__,              "__trunc__"], false]
    - ["cf3376002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__trunc__"], false]
    - ["cf3376003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__trunc__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — operator.contains(Cls.__dict__, '__round__')
#
# All 3 concurrent.futures classes return false for __round__.
# round() delegates to __round__ (numbers.Real protocol). concurrent.futures
#   types implement no numeric magnitude.
# concurrent.futures.Future: a state-machine result handle, not a numeric type;
#   round(future, n) is not a meaningful operation. Future state is one of
#   PENDING/RUNNING/CANCELLED/FINISHED — none of these are a scalar value
#   that can be rounded.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types that encapsulate pools
#   of worker threads or processes; round(executor, n) is not a defined Python
#   operation. Pool configuration is accessed through constructor arguments
#   and context manager protocol, not numeric rounding methods.
# ---------------------------------------------------------------------------

table cf3376.round:
  description: "concurrent.futures types __round__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3376

  columns: [id, function, args, expected]
  rows:
    - ["cf3376004", operator.contains, [concurrent.futures.Future.__dict__,              "__round__"], false]
    - ["cf3376005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__round__"], false]
    - ["cf3376006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__round__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.contains(Cls.__dict__, '__index__')
#
# All 3 concurrent.futures classes return false for __index__.
# operator.index() requires __index__, which signals lossless integer
#   conversion for use as a sequence index or in bin()/hex()/oct().
# concurrent.futures.Future: a state-machine result handle, not an integer type;
#   it cannot be used as a slice index or passed to bin()/hex()/oct().
#   Future's value is retrieved via result() or callbacks, not via __index__.
# ThreadPoolExecutor/ProcessPoolExecutor: pool lifecycle managers whose entire
#   API is submit(), map(), shutdown(), and context manager protocol.
#   The executor object itself is not an integer; executor[i] and
#   bin(executor) are not defined Python expressions.
# ---------------------------------------------------------------------------

table cf3376.index:
  description: "concurrent.futures types __index__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3376

  columns: [id, function, args, expected]
  rows:
    - ["cf3376007", operator.contains, [concurrent.futures.Future.__dict__,              "__index__"], false]
    - ["cf3376008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__index__"], false]
    - ["cf3376009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__index__"], false]

# ---------------------------------------------------------------------------
# combined — __trunc__, __round__, __index__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __trunc__: false for all 3 — numeric truncation toward zero is not defined.
# __round__: false for all 3 — numeric rounding is not defined.
# __index__: false for all 3 — lossless integer index conversion is not defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire public
#   surface is method-based: submit(), map(), result(), cancel(), done(),
#   running(), cancelled(), add_done_callback(), shutdown(). Waves 658–671
#   established that no arithmetic, bitwise, reflected, in-place augmented
#   assignment, unary numeric, or numeric rounding operator appears anywhere
#   in the concurrent.futures type hierarchy. The truncation, rounding, and
#   integer-index operators tested here follow the same pattern.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric, set, or dict-like type. __trunc__, __round__,
#   and __index__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate a
#   pool of worker threads or processes; they expose only lifecycle and dispatch
#   methods. No numeric truncation, rounding, or integer-index overloads are
#   defined.
# ---------------------------------------------------------------------------

