spec: theseus_sndhdr_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sndhdr_cr)
blocks: sndhdr

docs: https://docs.python.org/3/library/sndhdr.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sndhdr.html"
  not_derived_from:
    - "CPython source: Lib/sndhdr.py"
  notes:
    - "Clean-room sndhdr module. Do NOT import sndhdr."

error_model: python_exceptions

invariant theseus_sndhdr_cr.sndhdr2_what:
  description: "what() function returns None or a SoundHeader for non-sound files"
  category: behavior
  kind: python_call_eq
  function: sndhdr2_what
  args: []
  expected: true

invariant theseus_sndhdr_cr.sndhdr2_whathdr:
  description: "whathdr() detects file types by header"
  category: behavior
  kind: python_call_eq
  function: sndhdr2_whathdr
  args: []
  expected: true

invariant theseus_sndhdr_cr.sndhdr2_tests:
  description: "tests list contains type-detection functions"
  category: behavior
  kind: python_call_eq
  function: sndhdr2_tests
  args: []
  expected: true
