spec: concurrent_futures_extra282
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — executor class hierarchy, Future, and utility function module membership"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "Executor.__module__ == 'concurrent.futures._base' (internal submodule)"
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"
    - "FIRST_COMPLETED is a plain str constant with value 'FIRST_COMPLETED'"
    - "wait and as_completed are defined in concurrent.futures._base"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra282.class_names:
  description: "concurrent.futures class __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: cf282n

  columns: [id, function, args, expected, description]
  rows:
    - [cf282n001, concurrent.futures.Executor.__name__.__eq__, ["Executor"], true, "Executor __name__"]
    - [cf282n002, concurrent.futures.ThreadPoolExecutor.__name__.__eq__, ["ThreadPoolExecutor"], true, "ThreadPoolExecutor __name__"]
    - [cf282n003, concurrent.futures.ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true, "ProcessPoolExecutor __name__"]
    - [cf282n004, concurrent.futures.Future.__name__.__eq__, ["Future"], true, "Future __name__"]

table concurrent_futures_extra282.class_modules:
  description: "concurrent.futures class __module__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: cf282m

  columns: [id, function, args, expected, description]
  rows:
    - [cf282m001, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true, "Executor __module__"]
    - [cf282m002, concurrent.futures.ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true, "ThreadPoolExecutor __module__"]
    - [cf282m003, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true, "ProcessPoolExecutor __module__"]
    - [cf282m004, concurrent.futures.Future.__module__.__eq__, ["concurrent.futures._base"], true, "Future __module__"]

invariant concurrent_futures_extra282.executor_base:
  description: "Executor base class is object"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant concurrent_futures_extra282.thread_pool_base:
  description: "ThreadPoolExecutor base class is Executor"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra282.process_pool_base:
  description: "ProcessPoolExecutor base class is Executor"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra282.future_base:
  description: "Future base class is object"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant concurrent_futures_extra282.wait_module:
  description: "wait function is defined in concurrent.futures._base"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra282.as_completed_module:
  description: "as_completed function is defined in concurrent.futures._base"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra282.first_completed_type:
  description: "FIRST_COMPLETED constant is a str instance"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true
