spec: castarray
version: ">=1.0.0"
backend: node(castarray)

docs: https://www.npmjs.com/package/castarray

provenance:
  derived_from:
    - "castarray README — https://www.npmjs.com/package/castarray"
    - "Test vectors verified with castarray via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "castarray source"
  notes:
    - "castarray is an npm package. Install: npm install castarray"
    - "Wraps a value in an array if it isn't already one. Unlike ensure-array, null is wrapped as [null]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table castarray.wrap:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: castarr

  columns: [id, args, expected]
  rows:
    - [scalar,  [1],          [1]]
    - [string,  ["hello"],    ["hello"]]
    - [already, [[1, 2, 3]],  [1, 2, 3]]
    - [null_v,  [null],       [null]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:09:57Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
