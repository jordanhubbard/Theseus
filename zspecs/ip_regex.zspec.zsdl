spec: ip_regex
version: ">=5.0.0"
backend: node(ip-regex)

docs: https://github.com/sindresorhus/ip-regex#readme

provenance:
  derived_from:
    - "ip-regex README — https://github.com/sindresorhus/ip-regex#readme"
    - "Test vectors verified with ip-regex via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "ip-regex source"
  notes:
    - "ip-regex returns regular expressions that match IPv4 and IPv6 addresses."
    - "Install: npm install ip-regex"
    - "v5+ is ESM with a CJS shim; the parser is exposed as default; default.v4({exact:true}) and default.v6({exact:true}) return RegExps with .test()."
    - "Spec uses entry: named, function: default.v4 (dotted) to access the v4 builder, then chains .test(input)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Returns a RegExp object; .test() returns boolean; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# v4({exact: true}).test(input)
table ip_regex.v4_exact:
  kind: node_chain_eq
  category: v4_exact
  entry: named
  function: default.v4
  id_prefix: v4

  columns: [id, entry_args, chain, expected]
  rows:
    - [valid,
       [{exact: true}],
       [{method: test, args: ["1.2.3.4"]}],
       true]

    - [valid_zero,
       [{exact: true}],
       [{method: test, args: ["0.0.0.0"]}],
       true]

    - [valid_max,
       [{exact: true}],
       [{method: test, args: ["255.255.255.255"]}],
       true]

    - [out_of_range,
       [{exact: true}],
       [{method: test, args: ["256.0.0.0"]}],
       false]

    - [not_ip,
       [{exact: true}],
       [{method: test, args: ["not-an-ip"]}],
       false]

    - [v6_rejected_in_v4_exact,
       [{exact: true}],
       [{method: test, args: ["::1"]}],
       false]

# v6({exact: true}).test(input)
table ip_regex.v6_exact:
  kind: node_chain_eq
  category: v6_exact
  entry: named
  function: default.v6
  id_prefix: v6

  columns: [id, entry_args, chain, expected]
  rows:
    - [loopback,
       [{exact: true}],
       [{method: test, args: ["::1"]}],
       true]

    - [unspecified,
       [{exact: true}],
       [{method: test, args: ["::"]}],
       true]

    - [full_form,
       [{exact: true}],
       [{method: test, args: ["2001:0db8:0000:0000:0000:0000:0000:0001"]}],
       true]

    - [link_local,
       [{exact: true}],
       [{method: test, args: ["fe80::1"]}],
       true]

    - [v4_rejected_in_v6_exact,
       [{exact: true}],
       [{method: test, args: ["1.2.3.4"]}],
       false]

    - [not_ip,
       [{exact: true}],
       [{method: test, args: ["not-an-ip"]}],
       false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:21:03Z
  iterations: 1
  pass_count: 12
  fail_count: 0
  total_invariants: 12
  notes: Synthesis succeeded in 1 iteration(s). 12 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
