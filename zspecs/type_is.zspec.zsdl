spec: type_is
version: ">=2.0.0"
backend: node(type-is)

docs: https://github.com/jshttp/type-is#readme

provenance:
  derived_from:
    - "type-is README — https://github.com/jshttp/type-is#readme"
    - "RFC 9110 (HTTP/1.1 semantics) media-type matching"
    - "Test vectors verified with type-is via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "type-is source"
  notes:
    - "Express-style content-type matching helper — used by body-parser and friends."
    - "Install: npm install type-is"
    - "v2 CJS; default export is the typeIs() function; .is / .match / .normalize / .hasBody attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# .is — match content-type against a list of types
invariant type_is.is_json_match:
  description: "is('application/json', ['json']) returns 'json'"
  category: is
  kind: node_chain_eq
  entry: named
  function: is
  entry_args: ["application/json", ["json"]]
  chain: []
  expected: "json"

invariant type_is.is_html_match:
  description: "is('text/html', ['html']) returns 'html'"
  category: is
  kind: node_chain_eq
  entry: named
  function: is
  entry_args: ["text/html", ["html"]]
  chain: []
  expected: "html"

invariant type_is.is_no_match:
  description: "is('text/html', ['json']) returns false"
  category: is
  kind: node_chain_eq
  entry: named
  function: is
  entry_args: ["text/html", ["json"]]
  chain: []
  expected: false

invariant type_is.is_multipart_match:
  description: "is('multipart/form-data', ['multipart']) returns 'multipart'"
  category: is
  kind: node_chain_eq
  entry: named
  function: is
  entry_args: ["multipart/form-data", ["multipart"]]
  chain: []
  expected: "multipart"

# .normalize — short → full
invariant type_is.normalize_html:
  description: "normalize('html') returns 'text/html'"
  category: normalize
  kind: node_chain_eq
  entry: named
  function: normalize
  entry_args: ["html"]
  chain: []
  expected: "text/html"

invariant type_is.normalize_json:
  description: "normalize('json') returns 'application/json'"
  category: normalize
  kind: node_chain_eq
  entry: named
  function: normalize
  entry_args: ["json"]
  chain: []
  expected: "application/json"

invariant type_is.normalize_already_full:
  description: "normalize on a full type passes through unchanged"
  category: normalize
  kind: node_chain_eq
  entry: named
  function: normalize
  entry_args: ["application/json"]
  chain: []
  expected: "application/json"

# .match — pattern matching
invariant type_is.match_full_match:
  description: "match('application/json', 'application/json') is true"
  category: match
  kind: node_chain_eq
  entry: named
  function: match
  entry_args: ["application/json", "application/json"]
  chain: []
  expected: true

invariant type_is.match_wildcard_subtype:
  description: "match('application/*', 'application/json') is true"
  category: match
  kind: node_chain_eq
  entry: named
  function: match
  entry_args: ["application/*", "application/json"]
  chain: []
  expected: true

invariant type_is.match_no_match:
  description: "match('text/*', 'application/json') is false"
  category: match
  kind: node_chain_eq
  entry: named
  function: match
  entry_args: ["text/*", "application/json"]
  chain: []
  expected: false
