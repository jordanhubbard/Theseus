spec: lxml_etree_rust
version: ">=3.9"
backend: rust_module(lxml_etree_rust)

docs: https://lxml.de/apidoc/lxml.etree.html

provenance:
  derived_from:
    - "https://lxml.de/apidoc/lxml.etree.html — lxml etree documentation"
  not_derived_from:
    - "lxml source: lxml/etree.pyx"
  notes:
    - "Clean-room Rust reimplementation of lxml.etree XML parsing, exposed via PyO3."
    - "fromstring(xml_bytes) parses XML from bytes and returns an Element."
    - "Element.tag returns the tag name string."
    - "Element.findtext(tag) returns text of the first matching child, or None."
    - "Element.__len__() returns the number of child elements."
    - "Element.get(attr) returns the attribute value or None."
    - "All test vectors verified against lxml 6.0.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# fromstring — tag attribute
table lxml_etree_rust.fromstring.tag:
  kind: python_call_eq
  category: tag
  id_prefix: lxml_tag
  function: fromstring
  method: tag

  columns: [id, args, expected]
  rows:
    - [root_tag, [!b64 PHJvb3Q+PGl0ZW0+aGVsbG88L2l0ZW0+PG5hbWU+QWxpY2U8L25hbWU+PC9yb290Pg==], "root"]
    - [item_tag, [!b64 PGl0ZW0+aGVsbG88L2l0ZW0+],                                               "item"]
    - [p_tag,    [!b64 PHAgY2xhc3M9ImxlYWQiPkhlbGxvPC9wPg==],                                  "p"]

# fromstring — findtext
table lxml_etree_rust.fromstring.findtext:
  kind: python_call_eq
  category: findtext
  id_prefix: lxml_ft
  function: fromstring
  method: findtext

  columns: [id, args, method_args, expected]
  rows:
    - [item_text,  [!b64 PHJvb3Q+PGl0ZW0+aGVsbG88L2l0ZW0+PG5hbWU+QWxpY2U8L25hbWU+PC9yb290Pg==], ["item"],    "hello"]
    - [name_text,  [!b64 PHJvb3Q+PGl0ZW0+aGVsbG88L2l0ZW0+PG5hbWU+QWxpY2U8L25hbWU+PC9yb290Pg==], ["name"],    "Alice"]
    - [a_text,     [!b64 PHJvb3Q+PGE+MTwvYT48Yj4yPC9iPjxjPjM8L2M+PC9yb290Pg==],                  ["a"],       "1"]
    - [missing,    [!b64 PHJvb3Q+PGl0ZW0+aGVsbG88L2l0ZW0+PC9yb290Pg==],                          ["missing"], null]

# fromstring — __len__ (number of children)
table lxml_etree_rust.fromstring.len:
  kind: python_call_eq
  category: len
  id_prefix: lxml_len
  function: fromstring
  method: __len__

  columns: [id, args, expected]
  rows:
    - [two_children,   [!b64 PHJvb3Q+PGl0ZW0+aGVsbG88L2l0ZW0+PG5hbWU+QWxpY2U8L25hbWU+PC9yb290Pg==], 2]
    - [three_children, [!b64 PHJvb3Q+PGE+MTwvYT48Yj4yPC9iPjxjPjM8L2M+PC9yb290Pg==],                  3]

# fromstring — get (attribute access)
invariant lxml_etree_rust.fromstring.get_class:
  description: "fromstring('<p class=\"lead\">Hello</p>').get('class') == 'lead'"
  category: get
  kind: python_call_eq
  function: fromstring
  args: [!b64 PHAgY2xhc3M9ImxlYWQiPkhlbGxvPC9wPg==]
  method: get
  method_args: ["class"]
  expected: "lead"

invariant lxml_etree_rust.fromstring.get_missing:
  description: "fromstring('<p>Hello</p>').get('class') == None"
  category: get
  kind: python_call_eq
  function: fromstring
  args: [!b64 PGl0ZW0+aGVsbG88L2l0ZW0+]
  method: get
  method_args: ["class"]
  expected: null

