spec: snakecase_keys
version: ">=9.0.2"
backend: node(snakecase-keys)

docs: https://www.npmjs.com/package/snakecase-keys

provenance:
  derived_from:
    - "snakecase-keys README — https://www.npmjs.com/package/snakecase-keys"
    - "Test vectors verified with snakecase-keys via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "snakecase-keys source"
  notes:
    - "snakecase-keys is an npm package. Install: npm install snakecase-keys"
    - "Converts object keys from camelCase to snake_case. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object with snake_case keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table snakecase_keys.snakecaseKeys:
  kind: node_module_call_eq
  function: "default"
  category: transform
  id_prefix: skkeys

  columns: [id, args, expected]
  rows:
    - [camel_keys, [{"fooBar": 1, "bazQux": 2}], {"foo_bar": 1, "baz_qux": 2}]
    - [single,     [{"helloWorld": "hi"}],         {"hello_world": "hi"}]
