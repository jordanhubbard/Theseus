spec: shutil_extra6
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl and prior extras."
    - "shutil.Error.__name__ == 'Error' — table form with new id_prefix se6."
    - "shutil.SameFileError.__name__ == 'SameFileError' — in table form."
    - "shutil.ReadError.__name__ == 'ReadError' — NEW: ReadError not covered in prior shutil specs."
    - "shutil.Error.__module__ == 'shutil' — checked in shutil_extra3 as standalone; this is table form."
    - "shutil.SameFileError.__bases__[0].__name__ == 'Error' — covered in shutil_extra3/extra4 string form; new bool form here."
    - "shutil.ReadError.__bases__[0].__name__ == 'OSError' — NEW: ReadError inherits from OSError."
    - "shutil.Error.__qualname__ == 'Error' — covered in shutil_extra5 table; standalone invariant here."
    - "shutil.ReadError.__qualname__ == 'ReadError' — NEW: qualname for ReadError."
    - "shutil.ReadError.__module__ == 'shutil' — NEW: module identity for ReadError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class __name__ checks — table form with new id_prefix se6
# New: includes ReadError not in any prior shutil spec.
# ---------------------------------------------------------------------------

table shutil_extra6.exception_names:
  kind: python_call_eq
  category: class_names
  id_prefix: se6

  columns: [id, function, args, expected]
  rows:
    - [Error,         Error.__name__.__eq__,         ["Error"],         true]
    - [SameFileError, SameFileError.__name__.__eq__, ["SameFileError"], true]
    - [ReadError,     ReadError.__name__.__eq__,     ["ReadError"],     true]

# ---------------------------------------------------------------------------
# Exception class __module__ checks — table form
# shutil_extra3 covers Error.__module__ as standalone invariant;
# shutil_extra5 covers Error/SameFileError.__module__ in class_modules table.
# This table adds ReadError.__module__ (new) alongside the others.
# ---------------------------------------------------------------------------

table shutil_extra6.exception_modules:
  kind: python_call_eq
  category: module
  id_prefix: emod6

  columns: [id, function, args, expected]
  rows:
    - [Error,         Error.__module__.__eq__,         ["shutil"], true]
    - [SameFileError, SameFileError.__module__.__eq__, ["shutil"], true]
    - [ReadError,     ReadError.__module__.__eq__,     ["shutil"], true]

# ---------------------------------------------------------------------------
# Exception class __qualname__ checks
# shutil_extra5 covers Error/SameFileError __qualname__ in table form.
# New: ReadError.__qualname__ (not in any prior spec).
# Error.__qualname__ standalone invariant form is also new.
# ---------------------------------------------------------------------------

invariant shutil_extra6.Error.qualname_eq:
  description: "shutil.Error.__qualname__ == 'Error' — top-level exception class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

invariant shutil_extra6.ReadError.qualname_eq:
  description: "shutil.ReadError.__qualname__ == 'ReadError' — top-level exception class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: ReadError.__qualname__.__eq__
  args: ["ReadError"]
  expected: true

# ---------------------------------------------------------------------------
# SameFileError base class — bool form via __eq__
# shutil_extra3 checks: method: __name__, expected: "Error"  (string form).
# shutil_extra4 checks: method: __name__, expected: "Error"  (string form).
# This is a distinct bool form: method: __name__.__eq__, method_args: ["Error"],
# expected: true.
# ---------------------------------------------------------------------------

invariant shutil_extra6.SameFileError.base_name_bool:
  description: "shutil.SameFileError.__bases__[0].__name__ == 'Error' — SameFileError inherits from shutil.Error"
  category: hierarchy
  kind: python_call_eq
  function: SameFileError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# ReadError base class — NEW: not in any prior shutil spec
# shutil.ReadError inherits from OSError.
# ---------------------------------------------------------------------------

invariant shutil_extra6.ReadError.base_name_bool:
  description: "shutil.ReadError.__bases__[0].__name__ == 'OSError' — ReadError inherits from OSError"
  category: hierarchy
  kind: python_call_eq
  function: ReadError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# ReadError base class — string form (complementing bool form above)
# Returns the string "OSError" directly.
# ---------------------------------------------------------------------------

invariant shutil_extra6.ReadError.base_name_str:
  description: "shutil.ReadError.__bases__[0].__name__ == 'OSError' — string form"
  category: hierarchy
  kind: python_call_eq
  function: ReadError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"
