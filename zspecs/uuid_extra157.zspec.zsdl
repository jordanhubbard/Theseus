spec: uuid_extra157
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra156.zspec.zsdl — covers uuid.UUID.__dict__ property membership checks (hex/int/bytes/version/variant/__init__/__str__/__repr__) and meta-attributes (__len__()==37/__class__.__name__=='mappingproxy') (table + invariants)."
    - "uuid_extra155.zspec.zsdl — covers uuid.UUID.__init__.__code__.co_argcount==7 / co_name / __qualname__ / co_varnames.__len__()==15 (table + invariants)."
    - "uuid_extra154.zspec.zsdl — covers uuid.UUID.__lt__/__le__/__gt__/__ge__/__eq__ qualname strings and lengths (table + invariants)."
    - "uuid_extra153.zspec.zsdl — covers uuid.UUID.__slots__ attribute details (table + invariants)."
    - "uuid_extra149.zspec.zsdl — covers uuid.UUID.__init__.__qualname__/__code__.co_argcount==7 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra156."
    - "Wave 347 theme: uuid.UUID class identity — UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__bases__[0].__name__=='object' / NAMESPACE_DNS.__class__.__name__=='UUID' / NAMESPACE_URL.__class__.__name__=='UUID' / NAMESPACE_OID.__class__.__name__=='UUID' / NAMESPACE_X500.__class__.__name__=='UUID'. These cover the class's own identity metadata and the four predefined UUID namespace constants."
    - "uuid.UUID.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__name__ == 'UUID' (4 chars). The UUID class's own __name__ is 'UUID' (4 chars). uuid.UUID.__module__ == 'uuid' (4 chars). Both __name__ and __module__ are 4 chars: 'UUID'=='uuid' in length (case-insensitive). 'UUID' is the class name; 'uuid' is the module it belongs to."
    - "Note: uuid.UUID.__bases__[0].__name__ == 'object'. UUID inherits directly from Python's built-in object class. It has a single base class (object), so __bases__ is a 1-tuple containing only object. uuid.UUID.__bases__[0].__name__ == 'object' (6 chars)."
    - "Note: uuid.NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are four predefined UUID constants from RFC 4122. Each is an instance of uuid.UUID. These namespace UUIDs are used as the namespace argument in uuid.uuid3() and uuid.uuid5() to generate version-3 and version-5 UUIDs respectively. All four share __class__.__name__ == 'UUID' (4 chars)."
    - "Note: NAMESPACE_DNS == UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') (DNS namespace). NAMESPACE_URL == UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8') (URL namespace). NAMESPACE_OID == UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8') (OID namespace). NAMESPACE_X500 == UUID('6ba7b814-9dad-11d1-80b4-00c04fd430c8') (X.500 DN namespace). These are defined as module-level constants in Lib/uuid.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__module__.__eq__('uuid')
# uuid.UUID.__bases__[0].__name__.__eq__('object')
# uuid.UUID.__name__.__len__()==4
#
# Wave 347 theme: uuid.UUID class identity metadata.
#
# UUID.__name__ == 'UUID' (4 chars; the class name).
# UUID.__module__ == 'uuid' (4 chars; the module it belongs to).
# UUID.__bases__[0].__name__ == 'object' (6 chars; single base class is object).
# UUID.__name__.__len__() == 4 ('UUID' = 4 chars).
# No prior uuid spec anchors UUID.__name__, UUID.__module__, or UUID.__bases__ as a table
# under uuidclass157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra157.UUID_class_identity:
  description: "uuid.UUID.__name__.__eq__('UUID')==True / UUID.__module__.__eq__('uuid')==True / UUID.__bases__[0].__name__.__eq__('object')==True / UUID.__name__.__len__()==4 — UUID.__name__ is 'UUID' (4 chars; the class name; same string as the public name in the uuid module namespace; 'UUID' is an acronym for Universally Unique IDentifier); UUID.__module__ is 'uuid' (4 chars; the module where UUID is defined, Lib/uuid.py; 'uuid' (4 chars lowercase) == 'UUID' (4 chars) in length though different case; UUID.__name__.__len__()==UUID.__module__.__len__()==4); UUID.__bases__[0].__name__ is 'object' (6 chars; UUID inherits from Python's built-in object class; UUID has a single base class so __bases__ is a 1-tuple; __bases__[0] is object; 'object' = 6 chars; UUID does not use multiple inheritance); UUID.__name__.__len__() is 4 ('UUID' = 'U'+'U'+'I'+'D' = 4 chars; both __name__ and __module__ have length 4); first uuidclass157 anchor for UUID.__name__, UUID.__module__, and UUID.__bases__"
  kind: python_call_eq
  category: identity
  id_prefix: uuidclass157

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_class_name,      "UUID.__name__.__eq__",                ["UUID"],   true, "uuid.UUID.__name__ == 'UUID' (4 chars; the class name; acronym for Universally Unique IDentifier; same as public name in uuid namespace)"]
    - [uuid_class_module,    "UUID.__module__.__eq__",              ["uuid"],   true, "uuid.UUID.__module__ == 'uuid' (4 chars; defined in Lib/uuid.py; 'uuid' lowercase; same length as 'UUID' = 4 chars)"]
    - [uuid_bases_object,    "UUID.__bases__[0].__name__.__eq__",  ["object"], true, "uuid.UUID.__bases__[0].__name__ == 'object' (6 chars; UUID inherits from object; single base class; __bases__ is a 1-tuple)"]
    - [uuid_name_len_4,      "UUID.__name__.__len__",               [],         4,   "uuid.UUID.__name__.__len__() is 4 ('UUID' = 4 chars; same length as UUID.__module__=='uuid'.__len__()==4)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS and NAMESPACE_URL class names
#
# Wave 347 theme: predefined UUID namespace constants are UUID instances.
#
# NAMESPACE_DNS.__class__.__name__ == 'UUID' (4 chars).
# NAMESPACE_URL.__class__.__name__ == 'UUID' (4 chars).
# UUID.__name__.__eq__('UUID') (confirmed).
# UUID.__module__.__eq__('uuid') (confirmed).
# No prior uuid spec anchors NAMESPACE_DNS or NAMESPACE_URL as a table under uuidclass157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra157.namespace_dns_url_class_names:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL.__class__.__name__.__eq__('UUID')==True / UUID.__name__.__eq__('UUID')==True / UUID.__module__.__eq__('uuid')==True — NAMESPACE_DNS.__class__.__name__ is 'UUID' (4 chars; NAMESPACE_DNS is an instance of uuid.UUID; it represents the DNS namespace from RFC 4122; NAMESPACE_DNS == UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'); used as namespace arg to uuid.uuid3() and uuid.uuid5() to generate DNS-based UUIDs); NAMESPACE_URL.__class__.__name__ is 'UUID' (4 chars; NAMESPACE_URL is an instance of uuid.UUID; it represents the URL namespace from RFC 4122; NAMESPACE_URL == UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8'); used for URL-based version-3 and version-5 UUIDs); UUID.__name__ is 'UUID' (confirmed; 4 chars; same string as the class name returned by __class__.__name__ for the namespace instances); UUID.__module__ is 'uuid' (confirmed; 4 chars; Lib/uuid.py); first uuidclass157 anchor for NAMESPACE_DNS and NAMESPACE_URL class names"
  kind: python_call_eq
  category: identity
  id_prefix: uuidclass157

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class_uuid,  "NAMESPACE_DNS.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (4 chars; RFC 4122 DNS namespace; UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'))"]
    - [ns_url_class_uuid,  "NAMESPACE_URL.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' (4 chars; RFC 4122 URL namespace; UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8'))"]
    - [uuid_name_uuid_b,   "UUID.__name__.__eq__",                     ["UUID"], true, "uuid.UUID.__name__ == 'UUID' (confirmed; 4 chars; same string returned by NAMESPACE_DNS.__class__.__name__)"]
    - [uuid_module_uuid_b, "UUID.__module__.__eq__",                   ["uuid"], true, "uuid.UUID.__module__ == 'uuid' (confirmed; 4 chars; Lib/uuid.py; module where all four namespace constants are defined)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_OID and NAMESPACE_X500 class names
#
# Wave 347 theme: predefined UUID namespace constants OID and X500.
#
# NAMESPACE_OID.__class__.__name__ == 'UUID' (4 chars).
# NAMESPACE_X500.__class__.__name__ == 'UUID' (4 chars).
# NAMESPACE_DNS.__class__.__name__.__eq__('UUID') (confirmed).
# UUID.__bases__[0].__name__.__eq__('object') (confirmed).
# No prior uuid spec anchors NAMESPACE_OID or NAMESPACE_X500 as a table under uuidclass157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra157.namespace_oid_x500_class_names:
  description: "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500.__class__.__name__.__eq__('UUID')==True / NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / UUID.__bases__[0].__name__.__eq__('object')==True — NAMESPACE_OID.__class__.__name__ is 'UUID' (4 chars; NAMESPACE_OID is an instance of uuid.UUID; it represents the ISO OID (Object Identifier) namespace from RFC 4122; NAMESPACE_OID == UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8'); used for OID-based version-3 and version-5 UUIDs); NAMESPACE_X500.__class__.__name__ is 'UUID' (4 chars; NAMESPACE_X500 is an instance of uuid.UUID; it represents the X.500 Distinguished Name namespace from RFC 4122; NAMESPACE_X500 == UUID('6ba7b814-9dad-11d1-80b4-00c04fd430c8'); used for X.500 DN-based version-3 and version-5 UUIDs); NAMESPACE_DNS.__class__.__name__ is 'UUID' (confirmed; all four namespace constants are UUID instances); UUID.__bases__[0].__name__ is 'object' (confirmed; 6 chars; single base class); first uuidclass157 anchor for NAMESPACE_OID and NAMESPACE_X500 class names"
  kind: python_call_eq
  category: identity
  id_prefix: uuidclass157

  columns: [id, function, args, expected, description]
  rows:
    - [ns_oid_class_uuid,   "NAMESPACE_OID.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' (4 chars; RFC 4122 ISO OID namespace; UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8'))"]
    - [ns_x500_class_uuid,  "NAMESPACE_X500.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' (4 chars; RFC 4122 X.500 DN namespace; UUID('6ba7b814-9dad-11d1-80b4-00c04fd430c8'))"]
    - [ns_dns_class_uuid_b, "NAMESPACE_DNS.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (confirmed; all four namespace constants are uuid.UUID instances)"]
    - [uuid_bases_object_b, "UUID.__bases__[0].__name__.__eq__",         ["object"], true, "uuid.UUID.__bases__[0].__name__ == 'object' (confirmed; 6 chars; UUID inherits from object; single base)"]

# ---------------------------------------------------------------------------
# uuid.UUID class module length and bases length
#
# Wave 347 theme: UUID class meta-attribute lengths.
#
# UUID.__name__.__len__() == 4 ('UUID' = 4 chars).
# UUID.__module__.__len__() == 4 ('uuid' = 4 chars).
# UUID.__bases__[0].__name__.__len__() == 6 ('object' = 6 chars).
# NAMESPACE_OID.__class__.__name__.__len__() == 4 ('UUID' = 4 chars).
# No prior uuid spec anchors these lengths as a table under uuidclass157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra157.UUID_class_name_lengths:
  description: "uuid.UUID.__name__.__len__()==4 / UUID.__module__.__len__()==4 / UUID.__bases__[0].__name__.__len__()==6 / NAMESPACE_OID.__class__.__name__.__len__()==4 — UUID.__name__.__len__() is 4 ('UUID' = 'U'+'U'+'I'+'D' = 4 chars; the class name is a 4-letter acronym); UUID.__module__.__len__() is 4 ('uuid' = 'u'+'u'+'i'+'d' = 4 chars; same 4 chars as 'UUID' but lowercase; UUID.__name__.__len__()==UUID.__module__.__len__()==4, an unusual equality where the class name and module name have the same length); UUID.__bases__[0].__name__.__len__() is 6 ('object' = 6 chars; the built-in base class name; 'object' is 2 chars longer than 'UUID'/'uuid' (4 chars) = 6 > 4 by 2); NAMESPACE_OID.__class__.__name__.__len__() is 4 ('UUID' = 4 chars; same as UUID.__name__.__len__()==4; all four namespace constants are UUID instances with __class__.__name__=='UUID'(4)); length ordering: 'UUID'/'uuid'/'UUID'(4) < 'object'(6); first uuidclass157 anchor for these name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: uuidclass157

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_name_len_4_b,       "UUID.__name__.__len__",                      [], 4, "uuid.UUID.__name__.__len__() is 4 ('UUID' = 4 chars; 4-letter acronym; same length as 'uuid' module name)"]
    - [uuid_module_len_4,       "UUID.__module__.__len__",                    [], 4, "uuid.UUID.__module__.__len__() is 4 ('uuid' = 4 chars; same length as 'UUID'=4; class name and module name have equal length)"]
    - [uuid_bases_name_len_6,   "UUID.__bases__[0].__name__.__len__",         [], 6, "uuid.UUID.__bases__[0].__name__.__len__() is 6 ('object' = 6 chars; 2 chars longer than 'UUID'/'uuid'=4)"]
    - [ns_oid_cls_name_len_4,   "NAMESPACE_OID.__class__.__name__.__len__",   [], 4, "uuid.NAMESPACE_OID.__class__.__name__.__len__() is 4 ('UUID' = 4 chars; all four namespace constants are UUID instances with __class__.__name__=='UUID')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# uuid.UUID.__name__ is 'UUID' (4 chars). The UUID class's __name__ attribute stores the
# bare class name as it was defined in the source code ('class UUID:'). 'UUID' (4 chars)
# is an acronym for Universally Unique IDentifier. uuid.UUID.__name__ == 'UUID' (4 chars)
# == uuid.UUID.__module__ 'uuid' (4 chars) in length — an unusual case where the class name
# and its module name have the same character count (though different case). No prior uuid
# spec anchors UUID.__name__ as a standalone under uuidclass157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra157.UUID_name_eq_UUID:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — 'UUID' (4 chars; acronym for Universally Unique IDentifier; bare class name from 'class UUID:' definition); UUID.__module__=='uuid' (4 chars; same length as 'UUID'; unusual equality UUID.__name__.__len__()==UUID.__module__.__len__()==4); UUID.__bases__[0].__name__=='object' (6 chars; single base class); UUID.__dict__.__len__()==37 (uuid_extra156 anchors); first uuidclass157 standalone for UUID.__name__"
  category: identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__module__.__eq__('uuid') — standalone
#
# uuid.UUID.__module__ is 'uuid' (4 chars). The UUID class is defined in Lib/uuid.py, so
# its __module__ is 'uuid' (the module name). 'uuid' (4 chars lowercase) is the same length
# as 'UUID' (4 chars uppercase) — an interesting symmetry where the class name and its
# module name share the same length but differ in case. uuid.UUID.__module__ == 'uuid'
# confirms that the UUID class is defined in the uuid module (Lib/uuid.py), not inherited
# from or delegated to a private C extension. No prior uuid spec anchors UUID.__module__
# as a standalone under uuidclass157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra157.UUID_module_eq_uuid:
  description: "uuid.UUID.__module__.__eq__('uuid') == True — 'uuid' (4 chars; lowercase module name; same length as 'UUID'=4 chars uppercase class name; class name and module name share length); UUID is defined in Lib/uuid.py (pure Python class, no private C extension); UUID.__name__=='UUID' (4 chars; same length as 'uuid'); UUID.__module__.__len__()==4 == UUID.__name__.__len__()==4; first uuidclass157 standalone for UUID.__module__"
  category: identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__bases__[0].__name__.__eq__('object') — standalone
#
# uuid.UUID.__bases__[0].__name__ is 'object' (6 chars). UUID inherits directly from
# Python's built-in object class. UUID.__bases__ is a 1-tuple containing only object,
# confirming that UUID uses single inheritance without any intermediate base classes.
# 'object' is Python's ultimate base class — all Python classes ultimately inherit from
# object. UUID's __bases__ has exactly one element (__bases__[0] is object) because UUID
# is not a mixin or multiple-inheritance class. 'object' (6 chars) is 2 chars longer
# than 'UUID' and 'uuid' (both 4 chars). No prior uuid spec anchors UUID.__bases__[0].__name__
# as a standalone under uuidclass157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra157.UUID_bases_object:
  description: "uuid.UUID.__bases__[0].__name__.__eq__('object') == True — 'object' (6 chars; Python's built-in ultimate base class; all classes ultimately inherit from object); UUID uses single inheritance (UUID.__bases__ is a 1-tuple); __bases__[0] is object (only base class); 'object'(6) > 'UUID'/'uuid'(4) by 2 chars; UUID.__name__=='UUID' (4 chars); first uuidclass157 standalone for UUID.__bases__[0].__name__"
  category: identity
  kind: python_call_eq
  function: "UUID.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_DNS is a module-level
# constant defined in Lib/uuid.py as an instance of the UUID class. It represents the DNS
# namespace from RFC 4122 Section 4.3: UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8').
# NAMESPACE_DNS is passed as the namespace argument to uuid.uuid3() and uuid.uuid5() to
# generate version-3 and version-5 UUIDs for DNS names. Its __class__.__name__ == 'UUID'
# (4 chars) confirms it is a uuid.UUID instance. No prior uuid spec anchors
# NAMESPACE_DNS.__class__.__name__ as a standalone under uuidclass157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra157.NAMESPACE_DNS_class_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars; NAMESPACE_DNS is a uuid.UUID instance); RFC 4122 DNS namespace constant; NAMESPACE_DNS == UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'); used as namespace arg to uuid3()/uuid5() for DNS-based UUIDs; NAMESPACE_DNS.__class__ is uuid.UUID; UUID.__name__=='UUID' (4 chars; same string); first uuidclass157 standalone for NAMESPACE_DNS.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_URL.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_URL is a module-level
# constant in Lib/uuid.py as an instance of uuid.UUID. It represents the URL namespace from
# RFC 4122: UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8'). NAMESPACE_URL is used as the
# namespace argument to uuid.uuid3() and uuid.uuid5() to generate version-3 and version-5
# UUIDs for URLs. No prior uuid spec anchors NAMESPACE_URL.__class__.__name__ as a standalone
# under uuidclass157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra157.NAMESPACE_URL_class_UUID:
  description: "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars; NAMESPACE_URL is a uuid.UUID instance); RFC 4122 URL namespace constant; NAMESPACE_URL == UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8'); used as namespace arg to uuid3()/uuid5() for URL-based UUIDs; all four namespace constants (DNS/URL/OID/X500) are UUID instances with __class__.__name__=='UUID'; first uuidclass157 standalone for NAMESPACE_URL.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_OID.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_OID is a module-level
# constant in Lib/uuid.py as an instance of uuid.UUID. It represents the ISO OID (Object
# Identifier) namespace from RFC 4122: UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8').
# OIDs (Object Identifiers) are used in various standards (X.509 certificates, SNMP MIBs,
# ASN.1 schemas). NAMESPACE_OID allows generating stable UUIDs for OID-identified objects.
# No prior uuid spec anchors NAMESPACE_OID.__class__.__name__ as a standalone under
# uuidclass157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra157.NAMESPACE_OID_class_UUID:
  description: "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars; NAMESPACE_OID is a uuid.UUID instance); RFC 4122 ISO OID namespace constant; NAMESPACE_OID == UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8'); used as namespace arg to uuid3()/uuid5() for OID-based UUIDs; OIDs are used in X.509/SNMP/ASN.1; first uuidclass157 standalone for NAMESPACE_OID.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_X500.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_X500 is a
# module-level constant in Lib/uuid.py as an instance of uuid.UUID. It represents the
