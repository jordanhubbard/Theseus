table multiprocessing_extra244.queue_method_identity:
  description: "multiprocessing.queues queue method identity — Queue.put and Queue.get both have __name__ len=3; JoinableQueue.join.__name__=='join'(len=4); JoinableQueue.task_done.__name__=='task_done'(len=9); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp244mt

  columns: [id, function, args, expected, description]
  rows:
    - [put_name_eq,   Queue.put.__name__.__eq__,              ["put"],           true, "multiprocessing.queues.Queue.put.__name__ == 'put'; verified with Python 3.14.3"]
    - [put_name_len,  Queue.put.__name__.__len__,             [],                3,    "multiprocessing.queues.Queue.put.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [put_qname_eq,  Queue.put.__qualname__.__eq__,          ["Queue.put"],     true, "multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put'; verified with Python 3.14.3"]
    - [get_name_eq,   Queue.get.__name__.__eq__,              ["get"],           true, "multiprocessing.queues.Queue.get.__name__ == 'get'; verified with Python 3.14.3"]
    - [get_name_len,  Queue.get.__name__.__len__,             [],                3,    "multiprocessing.queues.Queue.get.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [get_qname_eq,  Queue.get.__qualname__.__eq__,          ["Queue.get"],     true, "multiprocessing.queues.Queue.get.__qualname__ == 'Queue.get'; verified with Python 3.14.3"]
    - [jn_name_eq,    JoinableQueue.join.__name__.__eq__,     ["join"],          true, "multiprocessing.queues.JoinableQueue.join.__name__ == 'join'; verified with Python 3.14.3"]
    - [jn_name_len,   JoinableQueue.join.__name__.__len__,    [],                4,    "multiprocessing.queues.JoinableQueue.join.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [td_name_eq,    JoinableQueue.task_done.__name__.__eq__, ["task_done"],    true, "multiprocessing.queues.JoinableQueue.task_done.__name__ == 'task_done'; verified with Python 3.14.3"]
    - [td_name_len,   JoinableQueue.task_done.__name__.__len__, [],              9,    "multiprocessing.queues.JoinableQueue.task_done.__name__.__len__() == 9; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra244
# ---------------------------------------------------------------------------

invariant multiprocessing_extra244.joinable_queue_inherits_queue:
  description: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__('Queue') returns True — JoinableQueue(len=13) extends Queue(len=5) adding join() and task_done() coordination methods; SimpleQueue is a separate, simpler class that does not inherit from Queue; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "JoinableQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra244.simple_queue_base_is_object:
  description: "multiprocessing.queues.SimpleQueue.__bases__[0].__name__.__eq__('object') returns True — SimpleQueue(len=11) inherits directly from object, independent of Queue; this distinguishes it from JoinableQueue which inherits from Queue; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "SimpleQueue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
