spec: multiprocessing_extra244
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5); __module__ == 'multiprocessing.queues' (len=22); __bases__[0].__name__ == 'object' — Queue inherits directly from object."
    - "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue' (len=11); __module__ == 'multiprocessing.queues' (len=22); __bases__[0].__name__ == 'object' — SimpleQueue also inherits directly from object, independent of Queue."
    - "multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue' (len=13); __module__ == 'multiprocessing.queues' (len=22); __bases__[0].__name__ == 'Queue' — JoinableQueue extends Queue."
    - "multiprocessing.queues.Queue.put.__name__ == 'put' (len=3); Queue.get.__name__ == 'get' (len=3) — both core queue methods share the same short name length."
    - "multiprocessing.queues.JoinableQueue.join.__name__ == 'join' (len=4); task_done.__name__ == 'task_done' (len=9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.queues class identity
#
# Queue.__name__ == 'Queue' (len=5)
# Queue.__module__ == 'multiprocessing.queues' (len=22)
# Queue.__bases__[0].__name__ == 'object' (len=6)
# SimpleQueue.__name__ == 'SimpleQueue' (len=11)
# SimpleQueue.__module__ == 'multiprocessing.queues' (len=22)
# SimpleQueue.__bases__[0].__name__ == 'object' (len=6)
# JoinableQueue.__name__ == 'JoinableQueue' (len=13)
# JoinableQueue.__module__ == 'multiprocessing.queues' (len=22)
# JoinableQueue.__bases__[0].__name__ == 'Queue' (len=5)
# ---------------------------------------------------------------------------

table multiprocessing_extra244.queue_class_identity:
  description: "multiprocessing.queues class identity — Queue(len=5) and SimpleQueue(len=11) both inherit from object; JoinableQueue(len=13) inherits from Queue; all three share __module__ == 'multiprocessing.queues'(len=22); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp244cl

  columns: [id, function, args, expected, description]
  rows:
    - [q_name_eq,    Queue.__name__.__eq__,                        ["Queue"],                    true, "multiprocessing.queues.Queue.__name__ == 'Queue'; verified with Python 3.14.3"]
    - [q_name_len,   Queue.__name__.__len__,                       [],                           5,    "multiprocessing.queues.Queue.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [q_mod_eq,     Queue.__module__.__eq__,                      ["multiprocessing.queues"],   true, "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'; verified with Python 3.14.3"]
    - [q_mod_len,    Queue.__module__.__len__,                     [],                           22,   "multiprocessing.queues.Queue.__module__.__len__() == 22; verified with Python 3.14.3"]
    - [q_base_eq,    "Queue.__bases__[0].__name__.__eq__",         ["object"],                   true, "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object; verified with Python 3.14.3"]
    - [sq_name_eq,   SimpleQueue.__name__.__eq__,                  ["SimpleQueue"],              true, "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue'; verified with Python 3.14.3"]
    - [sq_name_len,  SimpleQueue.__name__.__len__,                 [],                           11,   "multiprocessing.queues.SimpleQueue.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [sq_mod_eq,    SimpleQueue.__module__.__eq__,                ["multiprocessing.queues"],   true, "multiprocessing.queues.SimpleQueue.__module__ == 'multiprocessing.queues'; verified with Python 3.14.3"]
    - [sq_mod_len,   SimpleQueue.__module__.__len__,               [],                           22,   "multiprocessing.queues.SimpleQueue.__module__.__len__() == 22; verified with Python 3.14.3"]
    - [sq_base_eq,   "SimpleQueue.__bases__[0].__name__.__eq__",   ["object"],                   true, "multiprocessing.queues.SimpleQueue.__bases__[0].__name__ == 'object' — SimpleQueue is independent of Queue; both inherit from object; verified with Python 3.14.3"]
    - [jq_name_eq,   JoinableQueue.__name__.__eq__,                ["JoinableQueue"],            true, "multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue'; verified with Python 3.14.3"]
    - [jq_name_len,  JoinableQueue.__name__.__len__,               [],                           13,   "multiprocessing.queues.JoinableQueue.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [jq_mod_eq,    JoinableQueue.__module__.__eq__,              ["multiprocessing.queues"],   true, "multiprocessing.queues.JoinableQueue.__module__ == 'multiprocessing.queues'; verified with Python 3.14.3"]
    - [jq_mod_len,   JoinableQueue.__module__.__len__,             [],                           22,   "multiprocessing.queues.JoinableQueue.__module__.__len__() == 22; verified with Python 3.14.3"]
    - [jq_base_eq,   "JoinableQueue.__bases__[0].__name__.__eq__", ["Queue"],                    true, "multiprocessing.queues.JoinableQueue.__bases__[0].__name__ == 'Queue' — JoinableQueue extends Queue; verified with Python 3.14.3"]
    - [jq_base_len,  "JoinableQueue.__bases__[0].__name__.__len__", [],                          5,    "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__len__() == 5; verified with Python 3.14.3"]

