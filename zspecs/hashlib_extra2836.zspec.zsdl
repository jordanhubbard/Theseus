spec: hashlib_extra2836
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra2821.zspec.zsdl — covers __radd__, __rsub__, and __rmul__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for HASH, blake2b, blake2s."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "hashlib.HASH.__dict__.__contains__('__rtruediv__') == False — HASH (the OpenSSL-backed C type) does not define the reflected true division operator; cryptographic hash objects are not numeric operands; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__rfloordiv__') == False — HASH does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__rmod__') == False — HASH does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__rtruediv__') == False — blake2b does not define the reflected true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__rfloordiv__') == False — blake2b does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__rmod__') == False — blake2b does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__rtruediv__') == False — blake2s does not define the reflected true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__rfloordiv__') == False — blake2s does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__rmod__') == False — blake2s does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# HASH is the C type for OpenSSL-backed hash objects (sha256, md5, sha1, etc.).
# Reflected division/modulo operators (__rtruediv__, __rfloordiv__, __rmod__)
# are invoked when the left operand does not support the operation; hash digest
# objects are cryptographic primitives, not numeric operands, so none are defined.
# ---------------------------------------------------------------------------

table hashlib_extra2836.hash_dict_rtruediv_rfloordiv_rmod:
  description: "hashlib.HASH.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — HASH is a cryptographic digest type, not a numeric operand; reflected division and modulo operators are absent; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2836

  columns: [id, function, args, expected]
  rows:
    - ["hl2836-hash-rtruediv",  hashlib.HASH.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["hl2836-hash-rfloordiv", hashlib.HASH.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["hl2836-hash-rmod",      hashlib.HASH.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2b.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# blake2b is the C type for BLAKE2b hash objects.
# Like HASH, it defines no reflected division or modulo operators.
# ---------------------------------------------------------------------------

table hashlib_extra2836.blake2b_dict_rtruediv_rfloordiv_rmod:
  description: "hashlib.blake2b.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — the BLAKE2b hash type defines no reflected division or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2836

  columns: [id, function, args, expected]
  rows:
    - ["hl2836-b2b-rtruediv",  hashlib.blake2b.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["hl2836-b2b-rfloordiv", hashlib.blake2b.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["hl2836-b2b-rmod",      hashlib.blake2b.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2s.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# blake2s is the C type for BLAKE2s hash objects.
# Like HASH and blake2b, it defines no reflected division or modulo operators.
# ---------------------------------------------------------------------------

table hashlib_extra2836.blake2s_dict_rtruediv_rfloordiv_rmod:
  description: "hashlib.blake2s.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — the BLAKE2s hash type defines no reflected division or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2836

  columns: [id, function, args, expected]
  rows:
    - ["hl2836-b2s-rtruediv",  hashlib.blake2s.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["hl2836-b2s-rfloordiv", hashlib.blake2s.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["hl2836-b2s-rmod",      hashlib.blake2s.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — all three hash types absent for all three dunders
# Consolidates one row per (type, dunder) pair for easy cross-type comparison.
# ---------------------------------------------------------------------------

table hashlib_extra2836.all_types_all_dunders_absent:
  description: "HASH, blake2b, and blake2s all lack __rtruediv__, __rfloordiv__, and __rmod__ in __dict__ — no hashlib hash type defines reflected true division, floor division, or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2836

  columns: [id, function, args, expected]
  rows:
    - ["hl2836-x-hash-rtruediv",  hashlib.HASH.__dict__.__contains__,    ["__rtruediv__"],  false]
    - ["hl2836-x-hash-rfloordiv", hashlib.HASH.__dict__.__contains__,    ["__rfloordiv__"], false]
    - ["hl2836-x-hash-rmod",      hashlib.HASH.__dict__.__contains__,    ["__rmod__"],      false]
    - ["hl2836-x-b2b-rtruediv",   hashlib.blake2b.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["hl2836-x-b2b-rfloordiv",  hashlib.blake2b.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["hl2836-x-b2b-rmod",       hashlib.blake2b.__dict__.__contains__, ["__rmod__"],      false]
    - ["hl2836-x-b2s-rtruediv",   hashlib.blake2s.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["hl2836-x-b2s-rfloordiv",  hashlib.blake2s.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["hl2836-x-b2s-rmod",       hashlib.blake2s.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra2836.hash_no_rtruediv:
  description: "hashlib.HASH.__dict__.__contains__('__rtruediv__') == False — HASH (OpenSSL-backed C type) does not define the reflected true division operator; hash objects are cryptographic primitives, not numeric operands; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__rtruediv__"]
  expected: false

invariant hashlib_extra2836.hash_no_rfloordiv:
  description: "hashlib.HASH.__dict__.__contains__('__rfloordiv__') == False — HASH does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__rfloordiv__"]
  expected: false

invariant hashlib_extra2836.hash_no_rmod:
  description: "hashlib.HASH.__dict__.__contains__('__rmod__') == False — HASH does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__rmod__"]
  expected: false

