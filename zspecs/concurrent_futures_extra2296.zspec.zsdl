spec: concurrent_futures_extra2296
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "concurrent.futures.Future and Executor report __module__ as 'concurrent.futures._base' (private submodule)."
    - "concurrent.futures.ThreadPoolExecutor reports __module__ as 'concurrent.futures.thread'."
    - "concurrent.futures.ProcessPoolExecutor reports __module__ as 'concurrent.futures.process'."
    - "concurrent.futures.CancelledError, BrokenExecutor, and InvalidStateError report __module__ as 'concurrent.futures._base'."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2296.future_executor_module:
  description: "concurrent.futures.Future and Executor __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf2296

  columns: [id, function, args, expected]
  rows:
    - ["cf2296001", "concurrent.futures.Future.__module__", [], "concurrent.futures._base"]
    - ["cf2296002", "concurrent.futures.Future.__qualname__", [], "Future"]
    - ["cf2296003", "concurrent.futures.Executor.__module__", [], "concurrent.futures._base"]
    - ["cf2296004", "concurrent.futures.Executor.__qualname__", [], "Executor"]

table concurrent_futures_extra2296.pool_executors_module:
  description: "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf2296

  columns: [id, function, args, expected]
  rows:
    - ["cf2296005", "concurrent.futures.ThreadPoolExecutor.__module__", [], "concurrent.futures.thread"]
    - ["cf2296006", "concurrent.futures.ThreadPoolExecutor.__qualname__", [], "ThreadPoolExecutor"]
    - ["cf2296007", "concurrent.futures.ProcessPoolExecutor.__module__", [], "concurrent.futures.process"]
    - ["cf2296008", "concurrent.futures.ProcessPoolExecutor.__qualname__", [], "ProcessPoolExecutor"]

table concurrent_futures_extra2296.exceptions_module:
  description: "concurrent.futures exception classes __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf2296

  columns: [id, function, args, expected]
  rows:
    - ["cf2296009", "concurrent.futures.CancelledError.__module__", [], "concurrent.futures._base"]
    - ["cf2296010", "concurrent.futures.CancelledError.__qualname__", [], "CancelledError"]
    - ["cf2296011", "concurrent.futures.BrokenExecutor.__module__", [], "concurrent.futures._base"]
    - ["cf2296012", "concurrent.futures.BrokenExecutor.__qualname__", [], "BrokenExecutor"]
    - ["cf2296013", "concurrent.futures.InvalidStateError.__module__", [], "concurrent.futures._base"]
    - ["cf2296014", "concurrent.futures.InvalidStateError.__qualname__", [], "InvalidStateError"]
    - ["cf2296015", "concurrent.futures.TimeoutError.__module__", [], "builtins"]
    - ["cf2296016", "concurrent.futures.TimeoutError.__qualname__", [], "TimeoutError"]

table concurrent_futures_extra2296.module_name_checks:
  description: "Verify __name__ matches class name for all key concurrent.futures classes"
