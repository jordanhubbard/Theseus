spec: uuid_extra2581
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  notes:
    - "Wave 2581 theme: __call__ dict-presence — checking whether uuid.UUID defines __call__ in its class __dict__ (making UUID objects callable functors)."
    - "uuid.UUID.__dict__.__contains__('__call__') == False — UUID instances are value objects; they hold a 128-bit integer and expose accessor properties, but cannot be invoked with ()."
    - "Attempting to call a UUID instance raises TypeError: 'UUID' object is not callable. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID defines a rich set of dunder methods: __eq__, __hash__, __int__, __str__, __repr__, __setattr__ — but not __call__."
    - "uuid.UUID.__dict__.__contains__('hex') == True — hex is a property returning the UUID as a 32-char hex string."
    - "uuid.UUID.__dict__.__contains__('bytes') == True — bytes is a property returning the UUID as a 16-byte big-endian bytes object."
    - "uuid.UUID.__dict__.__contains__('version') == True — version is a property returning the UUID version number (1-5)."
    - "uuid.UUID.__dict__.__contains__('variant') == True — variant is a property returning the UUID variant."
    - "uuid.UUID.__dict__.__contains__('fields') == True — fields is a property returning a tuple of the six UUID integer fields."
    - "uuid.UUID.__dict__.__contains__('urn') == True — urn is a property returning the UUID as a URN string."
    - "uuid.UUID.__dict__.__contains__('is_safe') == True — is_safe is a property indicating whether the UUID was generated safely."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ absence — uuid.UUID is not a callable functor
#
# uuid.UUID is a value-object class. Instances hold a UUID value and expose
# it via properties and dunder methods, but they are not callable functors.
# __call__ is absent from uuid.UUID.__dict__.
# ---------------------------------------------------------------------------

table uuid_extra2581.call_absent:
  description: "__call__ is absent from uuid.UUID.__dict__ — UUID instances are value objects, not callable functors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2581

  columns: [id, function, args, expected]
  rows:
    - ["uu2581001", "uuid.UUID.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Comparison and hashing dunders present in uuid.UUID.__dict__
#
# uuid.UUID defines __eq__, __hash__, __int__, __lt__, __gt__, __le__, __ge__
# in its own __dict__, making UUID instances sortable, hashable, and
# comparable. None of these imply callability.
# ---------------------------------------------------------------------------

table uuid_extra2581.comparison_protocol_present:
  description: "Comparison and hashing dunders are present in uuid.UUID.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2581

  columns: [id, function, args, expected]
  rows:
    - ["uu2581002", "uuid.UUID.__dict__.__contains__", ["__eq__"],   true]
    - ["uu2581003", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu2581004", "uuid.UUID.__dict__.__contains__", ["__int__"],  true]
    - ["uu2581005", "uuid.UUID.__dict__.__contains__", ["__lt__"],   true]
    - ["uu2581006", "uuid.UUID.__dict__.__contains__", ["__gt__"],   true]
    - ["uu2581007", "uuid.UUID.__dict__.__contains__", ["__le__"],   true]
    - ["uu2581008", "uuid.UUID.__dict__.__contains__", ["__ge__"],   true]

# ---------------------------------------------------------------------------
# String representation dunders present in uuid.UUID.__dict__
#
# uuid.UUID defines __str__ and __repr__ in its own __dict__,
# providing human-readable representations of the UUID value.
# ---------------------------------------------------------------------------

table uuid_extra2581.repr_protocol_present:
  description: "__str__ and __repr__ are present in uuid.UUID.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2581

  columns: [id, function, args, expected]
  rows:
    - ["uu2581009", "uuid.UUID.__dict__.__contains__", ["__str__"],  true]
    - ["uu2581010", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# UUID-specific property descriptors present in uuid.UUID.__dict__
#
# uuid.UUID exposes its value through a set of property descriptors defined
# directly in its __dict__: hex, bytes, version, variant, fields, urn, is_safe.
# These are the domain-specific API of the UUID class.
# ---------------------------------------------------------------------------

table uuid_extra2581.uuid_properties_present:
  description: "UUID-domain property descriptors are present in uuid.UUID.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2581

  columns: [id, function, args, expected]
  rows:
    - ["uu2581011", "uuid.UUID.__dict__.__contains__", ["hex"],     true]
    - ["uu2581012", "uuid.UUID.__dict__.__contains__", ["bytes"],   true]
    - ["uu2581013", "uuid.UUID.__dict__.__contains__", ["version"], true]
    - ["uu2581014", "uuid.UUID.__dict__.__contains__", ["variant"], true]
    - ["uu2581015", "uuid.UUID.__dict__.__contains__", ["fields"],  true]
    - ["uu2581016", "uuid.UUID.__dict__.__contains__", ["urn"],     true]
    - ["uu2581017", "uuid.UUID.__dict__.__contains__", ["is_safe"], true]
    - ["uu2581018", "uuid.UUID.__dict__.__contains__", ["node"],    true]
    - ["uu2581019", "uuid.UUID.__dict__.__contains__", ["time"],    true]
