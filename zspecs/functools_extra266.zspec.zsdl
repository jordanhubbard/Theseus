spec: functools_extra266
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS contents/length, WRAPPER_UPDATES, callable types"
    - "functools_extra.zspec.zsdl — covers __name__/__module__ for reduce, partial, cached_property, cmp_to_key, total_ordering, singledispatch"
    - "functools_extra265.zspec.zsdl — covers wraps and update_wrapper identity"
  notes:
    - "functools.lru_cache.__name__ == 'lru_cache'; __qualname__ == 'lru_cache'; __module__ == 'functools'; __class__.__name__ == 'function'."
    - "functools._lru_cache_wrapper is a C-level type: __class__.__name__ == 'type'; __module__ == 'functools'; __bases__[0].__name__ == 'object'."
    - "functools.cache.__name__ == 'cache'; __qualname__ == 'cache'; __module__ == 'functools'; __class__.__name__ == 'function'."
    - "functools.cache is NOT the same object as functools.lru_cache — cache is a separate Python function that calls lru_cache(maxsize=None)."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.lru_cache — decorator identity
#
# lru_cache is a Python function (decorator factory).
# Its __name__, __qualname__, __module__, and __class__.__name__ are verified.
# ---------------------------------------------------------------------------

invariant functools_extra266.lru_cache.name:
  description: "functools.lru_cache.__name__ == 'lru_cache'"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra266.lru_cache.qualname:
  description: "functools.lru_cache.__qualname__ == 'lru_cache'"
  category: identity
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra266.lru_cache.module:
  description: "functools.lru_cache.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra266.lru_cache.class_name:
  description: "functools.lru_cache.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# functools._lru_cache_wrapper — C-level wrapper type identity
#
# _lru_cache_wrapper is the C-level type that wraps a function decorated with
# lru_cache. It is a class object (__class__.__name__ == 'type').
# Its module is 'functools' and its sole base class is object.
# ---------------------------------------------------------------------------

invariant functools_extra266._lru_cache_wrapper.name:
  description: "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper'"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__name__.__eq__
  args: ["_lru_cache_wrapper"]
  expected: true

invariant functools_extra266._lru_cache_wrapper.module:
  description: "functools._lru_cache_wrapper.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra266._lru_cache_wrapper.base_name:
  description: "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant functools_extra266._lru_cache_wrapper.class_name:
  description: "functools._lru_cache_wrapper.__class__.__name__ == 'type' — it is a class object"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# functools.cache — alias identity
#
# cache is a separate Python function from lru_cache (not the same object).
# It behaves like lru_cache(maxsize=None) but is its own named function.
# ---------------------------------------------------------------------------

invariant functools_extra266.cache.name:
  description: "functools.cache.__name__ == 'cache'"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra266.cache.qualname:
  description: "functools.cache.__qualname__ == 'cache'"
  category: identity
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra266.cache.module:
  description: "functools.cache.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra266.cache.class_name:
  description: "functools.cache.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra266.cache.not_same_as_lru_cache:
  description: "functools.cache is not functools.lru_cache — cache is a distinct function object"
  category: identity
  kind: python_call_eq
  function: cache.__eq__
  args: [lru_cache]
  expected: false
