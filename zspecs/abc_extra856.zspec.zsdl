spec: abc_extra856
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - abc standard library module
    - CPython source: Lib/abc.py and Modules/_abc.c
  not_derived_from:
    - any third-party ABC replacement
    - zope.interface or similar alternative abstract base systems
  notes:
    - Covers abc.abstractproperty (deprecated since 3.3 but available in >=3.9)
    - Covers descriptor protocol method qualnames for abstractproperty
    - Covers ABCMeta instance/subclass check doc presence and subclasshook qualname
  created_at: "2026-04-12"

table abc_extra856.abstractproperty_identity:
  description: abc.abstractproperty qualname, module, and class identity
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab856ap
  columns: [id, function, args, expected]
  rows:
    - [ab856ap001, abc.abstractproperty.__qualname__.__eq__, ["abstractproperty"], true]
    - [ab856ap002, abc.abstractproperty.__module__.__eq__, ["abc"], true]
    - [ab856ap003, abc.abstractproperty.__class__.__name__.__eq__, ["type"], true]
    - [ab856ap004, abc.abstractproperty.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab856ap005, abc.abstractproperty.__isabstractmethod__.__class__.__name__.__eq__, ["bool"], true]

table abc_extra856.abstractproperty_descriptor:
  description: abc.abstractproperty descriptor protocol method qualnames
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab856dp
  columns: [id, function, args, expected]
  rows:
    - [ab856dp001, abc.abstractproperty.__init__.__qualname__.__eq__, ["abstractproperty.__init__"], true]
    - [ab856dp002, abc.abstractproperty.__get__.__qualname__.__eq__, ["abstractproperty.__get__"], true]
    - [ab856dp003, abc.abstractproperty.__set__.__qualname__.__eq__, ["abstractproperty.__set__"], true]
    - [ab856dp004, abc.abstractproperty.__delete__.__qualname__.__eq__, ["abstractproperty.__delete__"], true]

table abc_extra856.abcmeta_checks:
  description: abc.ABCMeta instance/subclass check doc presence and subclasshook qualname
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab856mc
  columns: [id, function, args, expected]
  rows:
    - [ab856mc001, abc.ABCMeta.__instancecheck__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab856mc002, abc.ABCMeta.__subclasscheck__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab856mc003, abc.ABCMeta.__subclasshook__.__qualname__.__eq__, ["ABCMeta.__subclasshook__"], true]
