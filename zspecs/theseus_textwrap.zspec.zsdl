spec: theseus_textwrap
version: ">=3.9"
backend: python_cleanroom(theseus_textwrap)
blocks: textwrap

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://en.wikipedia.org/wiki/Word_wrap — word wrap algorithm"
  notes:
    - "Clean-room text wrapping. Do NOT import textwrap or any text formatting library."
    - "Implement word-wrap and fill using only Python string operations."
    - "wrap('hello world foo bar', width=10) returns a list of lines each <=10 chars."
    - "fill('hello world foo bar', width=10) returns wrapped text joined by newlines."
    - "dedent('  hello\\n  world') returns 'hello\\nworld'."
    - "Export: wrap(text, width) -> list[str], fill(text, width) -> str, dedent(text) -> str."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_textwrap.wrap_returns_list:
  description: "wrap('hello world foo bar', 10) is a list"
  category: wrap
  kind: python_call_eq
  function: textwrap_wrap_is_list
  args: []
  expected: true

invariant theseus_textwrap.fill_has_newline:
  description: "fill('hello world foo bar', 10) contains newline"
  category: fill
  kind: python_call_eq
  function: textwrap_fill_has_newline
  args: []
  expected: true

invariant theseus_textwrap.dedent_basic:
  description: "dedent('  hello') == 'hello'"
  category: dedent
  kind: python_call_eq
  function: textwrap_dedent_basic
  args: []
  expected: "hello"
