spec: functools_extra56
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra55.zspec.zsdl."
    - "Prior specs covered: __doc__.__class__.__name__=='str' for wraps/lru_cache/reduce/partial/cached_property/total_ordering/singledispatch (extra55); __all__.__len__()==15 and __all__.__class__.__name__.__len__()==4 (extra36); WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') (extra3/extra5/extra8/extra23/extra24/extra30/extra44); WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') (extra5/extra11); WRAPPER_ASSIGNMENTS.__len__()==6 (extra19/extra36); WRAPPER_UPDATES.__len__()==1 (extra19); functools.__name__.__len__()==9 (extra37); reduce/__name__/__qualname__/__module__ (many early specs); WRAPPER_ASSIGNMENTS is a tuple whose elements are strings."
    - "This spec covers: functools.__all__.__class__.__name__.__eq__('list')==true; functools.__all__.__class__.__qualname__.__eq__('list')==true; functools.WRAPPER_ASSIGNMENTS.__class__.__qualname__.__eq__('tuple')==true; functools.WRAPPER_UPDATES.__class__.__qualname__.__eq__('tuple')==true; functools.WRAPPER_ASSIGNMENTS.__class__.__qualname__.__len__()==5; functools.WRAPPER_UPDATES.__class__.__qualname__.__len__()==5; functools.__name__.__eq__('functools')==true."
    - "Key findings: functools.__all__ is a plain Python list (not a tuple or set). The list built-in type has __name__ == __qualname__ == 'list' (4 chars) and __module__ == 'builtins'. Therefore __all__.__class__.__name__.__eq__('list') and __all__.__class__.__qualname__.__eq__('list') both return True. WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are both tuple objects. The tuple built-in type has __qualname__ == __name__ == 'tuple' (5 chars). Prior specs confirmed __class__.__name__ == 'tuple' for both (via __eq__ in early specs and via __len__ in extra36); this spec records __class__.__qualname__.__eq__('tuple') which is the first time the qualname string form is checked for these constants. functools.__name__.__eq__('functools') is new: extra37 recorded __name__.__len__() == 9 but not the string equality form. All seven invariants are new to extra56."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.__all__ class metadata — extra56 namespace
#
# functools.__all__ is a Python list containing the 15 public names exported
# by the functools module on Python 3.14. The list built-in type is a top-level
# built-in class whose __name__ and __qualname__ are both 'list' (4 chars).
# Prior specs recorded __all__.__len__() == 15 (extra36) and
# __all__.__class__.__name__.__len__() == 4 (extra36), but did not record the
# __eq__ forms for either __name__ or __qualname__ of the list class.
# Both are new to extra56.
# ---------------------------------------------------------------------------

table functools_extra56.all_class_name_qualname:
  description: "functools.__all__.__class__.__name__ == 'list' and __class__.__qualname__ == 'list' — __all__ is a plain Python list; the list built-in type has __name__ == __qualname__ == 'list' (4 chars); holds on all CPython versions"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmod56

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq,
       __all__.__class__.__name__.__eq__,
       ["list"],
       true,
       "functools.__all__.__class__.__name__ == 'list' — functools.__all__ is a Python list object; the list built-in type is a top-level class in the builtins module with __name__ == 'list' (4 chars); all standard library modules that define __all__ use a list (not a tuple or frozenset); prior extra36 confirmed __class__.__name__.__len__()==4; this confirms the actual string value"]
    - [all_class_qualname_eq,
       __all__.__class__.__qualname__.__eq__,
       ["list"],
       true,
       "functools.__all__.__class__.__qualname__ == 'list' — the list built-in type is defined at the top level of the builtins module so __qualname__ == __name__ == 'list' (4 chars); no dotted prefix because list is not a nested class; same value as __class__.__name__; new to extra56"]

# ---------------------------------------------------------------------------
# functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES __class__.__qualname__
# — extra56 namespace
#
# functools.WRAPPER_ASSIGNMENTS is a tuple containing the attribute names that
# update_wrapper copies to the wrapper function. On Python 3.14 it has 6
# elements: ('__module__', '__name__', '__qualname__', '__doc__',
# '__annotate__', '__type_params__'). Its __class__ is the built-in tuple type.
# The tuple type has __qualname__ == __name__ == 'tuple' (5 chars) because it
# is a top-level built-in type. Prior specs confirmed __class__.__name__ for
# both via __eq__ (early specs) but never checked __class__.__qualname__ via
# __eq__. Both qualname equality checks are new to extra56.
# ---------------------------------------------------------------------------

table functools_extra56.wrapper_constants_class_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES __class__.__qualname__ == 'tuple' — both are tuple objects; the tuple built-in type has __qualname__ == __name__ == 'tuple' (5 chars); first time __class__.__qualname__.__eq__ is recorded for these constants"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmod56

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_class_qualname,
       WRAPPER_ASSIGNMENTS.__class__.__qualname__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__qualname__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple of 6 attribute name strings on Python 3.14 (up from 5 in older versions due to PEP 563/695 additions); its __class__ is the built-in tuple type; tuple is a top-level built-in so __qualname__ == __name__ == 'tuple' (5 chars); early specs confirmed __class__.__name__ via __eq__; this is the first __class__.__qualname__.__eq__ check"]
    - [WRAPPER_UPDATES_class_qualname,
       WRAPPER_UPDATES.__class__.__qualname__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__qualname__ == 'tuple' — WRAPPER_UPDATES is a 1-element tuple containing '__dict__'; its __class__ is the built-in tuple type; tuple.__qualname__ == 'tuple' (5 chars); prior specs confirmed __class__.__name__ == 'tuple' via __eq__ (extra5/extra11); this is the first __class__.__qualname__.__eq__ check for WRAPPER_UPDATES"]
    - [WRAPPER_ASSIGNMENTS_class_qualname_len,
       WRAPPER_ASSIGNMENTS.__class__.__qualname__.__len__,
       [],
       5,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__qualname__.__len__() == 5 — 'tuple' is 5 chars; consistent with WRAPPER_ASSIGNMENTS.__class__.__name__.__len__() == 5 because tuple.__qualname__ == tuple.__name__; new to extra56"]
    - [WRAPPER_UPDATES_class_qualname_len,
       WRAPPER_UPDATES.__class__.__qualname__.__len__,
       [],
       5,
       "functools.WRAPPER_UPDATES.__class__.__qualname__.__len__() == 5 — 'tuple' is 5 chars; WRAPPER_UPDATES is the 1-element tuple ('__dict__',) that lists attributes merged (not copied) onto the wrapper by update_wrapper; tuple.__qualname__ length matches tuple.__name__ length at 5; new to extra56"]

# ---------------------------------------------------------------------------
# functools.__name__.__eq__('functools') — extra56 namespace
#
# functools.__name__ is the canonical module name 'functools' (9 chars).
# functools_extra37 recorded __name__.__len__() == 9 as a standalone invariant,
# but no prior spec records __name__.__eq__('functools') — the string equality
# form. This is new to extra56. The module name 'functools' matches the public
# package name and the filename (Lib/functools.py).
# ---------------------------------------------------------------------------

invariant functools_extra56.module_name_eq:
  description: "functools.__name__.__eq__('functools') == True — the module name is 'functools' (9 chars); extra37 confirmed __name__.__len__()==9; this is the first string equality check for the module name in the extra56 namespace"
  category: identity
  kind: python_call_eq
  function: functools.__name__.__eq__
  args: ["functools"]
  expected: true
