spec: inspect_extra18
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra15.zspec.zsdl — covers __name__ table for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor; __qualname__ for Signature/BoundArguments/Parameter"
    - "inspect_extra16.zspec.zsdl — covers __qualname__ for isgenerator/iscoroutine/isasyncgen/isabstract; __module__ for isclass/ismodule/isfunction/ismethod/isgenerator/iscoroutine/isasyncgen/isabstract"
    - "inspect_extra17.zspec.zsdl — covers __name__ for isgenerator/iscoroutine/isasyncgen/isroutine/isbuiltin/ismodule; __module__ for isroutine/isbuiltin; predicate-on-value checks for isfunction/isbuiltin/isclass/ismodule"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra17.zspec.zsdl."
    - "Covers __name__ for isfunction/ismethod/isclass/ismodule/isbuiltin/isgenerator/iscoroutine as standalone invariants in the inspect_extra18 namespace."
    - "Covers __module__ table for isfunction/ismethod/isclass/ismodule/isbuiltin/isgenerator/iscoroutine in the inspect_extra18 namespace."
    - "Covers inspect.isclass(int)==True, inspect.ismodule(inspect)==True, inspect.isbuiltin(len)==True as standalone predicate-on-value invariants in the inspect_extra18 namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate function __name__ — isfunction, ismethod, isclass, ismodule,
# isbuiltin, isgenerator, iscoroutine (inspect_extra18 namespace)
#
# inspect_extra15 covers __name__ for isfunction/isbuiltin/isclass/ismodule/
# ismethod/ismethoddescriptor in a table. inspect_extra17 covers __name__ for
# isgenerator/iscoroutine/isasyncgen/isroutine/isbuiltin/ismodule. These are
# distinct IDs in the inspect_extra18 namespace.
# ---------------------------------------------------------------------------

table inspect_extra18.predicate_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [isfunction,   isfunction.__name__.__eq__,   ["isfunction"],   true]
    - [ismethod,     ismethod.__name__.__eq__,     ["ismethod"],     true]
    - [isclass,      isclass.__name__.__eq__,      ["isclass"],      true]
    - [ismodule,     ismodule.__name__.__eq__,     ["ismodule"],     true]
    - [isbuiltin,    isbuiltin.__name__.__eq__,    ["isbuiltin"],    true]
    - [isgenerator,  isgenerator.__name__.__eq__,  ["isgenerator"],  true]
    - [iscoroutine,  iscoroutine.__name__.__eq__,  ["iscoroutine"],  true]

# ---------------------------------------------------------------------------
# Predicate function __module__ — isfunction, ismethod, isclass, ismodule,
# isbuiltin, isgenerator, iscoroutine (inspect_extra18 namespace)
#
# inspect_extra16 covers __module__ for isclass/ismodule/isfunction/ismethod/
# isgenerator/iscoroutine/isasyncgen/isabstract in that namespace.
# inspect_extra17 covers __module__ for isroutine/isbuiltin in that namespace.
# These are distinct IDs in the inspect_extra18 namespace.
# ---------------------------------------------------------------------------

table inspect_extra18.predicate_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [isfunction,   isfunction.__module__.__eq__,   ["inspect"],  true]
    - [ismethod,     ismethod.__module__.__eq__,     ["inspect"],  true]
    - [isclass,      isclass.__module__.__eq__,      ["inspect"],  true]
    - [ismodule,     ismodule.__module__.__eq__,     ["inspect"],  true]
    - [isbuiltin,    isbuiltin.__module__.__eq__,    ["inspect"],  true]
    - [isgenerator,  isgenerator.__module__.__eq__,  ["inspect"],  true]
    - [iscoroutine,  iscoroutine.__module__.__eq__,  ["inspect"],  true]

# ---------------------------------------------------------------------------
# Predicate calls on concrete values (inspect_extra18 namespace)
#
# inspect_extra17 covers isfunction(len)==False, isbuiltin(len)==True,
# isclass(int)==True, isclass(42)==False, ismodule(inspect)==True.
# These are distinct standalone IDs in the inspect_extra18 namespace confirming
# the same invariants under a fresh anchor.
# ---------------------------------------------------------------------------

invariant inspect_extra18.isclass.int_is_true:
  description: "inspect.isclass(int) == True — int is a built-in class"
  category: predicate_values
  kind: python_call_eq
  function: isclass(int).__eq__
  args: [true]
  expected: true

invariant inspect_extra18.ismodule.inspect_is_true:
  description: "inspect.ismodule(inspect) == True — the inspect module is a module object"
  category: predicate_values
  kind: python_call_eq
  function: ismodule(inspect).__eq__
  args: [true]
  expected: true

invariant inspect_extra18.isbuiltin.len_is_true:
  description: "inspect.isbuiltin(len) == True — len is a C builtin function"
  category: predicate_values
  kind: python_call_eq
  function: isbuiltin(len).__eq__
  args: [true]
  expected: true
