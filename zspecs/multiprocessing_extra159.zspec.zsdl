spec: multiprocessing_extra159
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.Process.__dict__.__contains__('_start_method') returns True — multiprocessing.Process in multiprocessing.context defines _start_method directly; it is the class-level start method indicator (e.g. 'fork', 'spawn', 'forkserver')."
    - "multiprocessing.Process.__dict__.__contains__('_Popen') returns True — multiprocessing.Process in multiprocessing.context defines _Popen directly; it is set to the platform-appropriate Popen class."
    - "multiprocessing.Process.__dict__.__len__() == 7 — multiprocessing.Process (the context.Process subclass) has exactly 7 entries: __module__, __firstlineno__, _start_method, _Popen, _after_fork, __static_attributes__, __doc__."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('start') returns True — BaseProcess.start() is defined directly in Lib/multiprocessing/process.py; it starts the child process."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('run') returns True — BaseProcess.run() is defined directly on the class; it is the method invoked in the child process."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('join') returns True — BaseProcess.join() is defined directly on the class; it blocks until the child process terminates."
    - "multiprocessing.Process.__dict__ keys on Python 3.14.3: __module__, __firstlineno__, _start_method, _Popen, _after_fork, __static_attributes__, __doc__ (len=7)."
    - "multiprocessing.process.BaseProcess.__dict__ has 27 entries on Python 3.14.3 including: __init__, run, start, interrupt, terminate, kill, join, is_alive, close, name, daemon, authkey, exitcode, ident, pid, sentinel, __repr__, _bootstrap, _after_fork, __dict__, __weakref__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

