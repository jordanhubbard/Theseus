# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra159
# ---------------------------------------------------------------------------

invariant multiprocessing_extra159.process_dict_contains_start_method:
  description: "multiprocessing.Process.__dict__.__contains__('_start_method') returns True — multiprocessing.Process (the platform-specific subclass in multiprocessing.context) defines _start_method directly as a class attribute; it holds the start method string (e.g. 'fork' on Linux, 'spawn' on macOS); '_start_method' is in Process.__dict__ (not inherited from BaseProcess); NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["_start_method"]
  expected: true

invariant multiprocessing_extra159.process_dict_contains_popen:
  description: "multiprocessing.Process.__dict__.__contains__('_Popen') returns True — multiprocessing.Process defines _Popen directly as a class attribute; it is set to the Popen class appropriate for the platform start method (e.g. popen_fork.Popen on macOS fork, popen_spawn_posix.Popen on spawn); '_Popen' is in Process.__dict__ (not inherited from BaseProcess); NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["_Popen"]
  expected: true

invariant multiprocessing_extra159.process_dict_len_seven:
  description: "multiprocessing.Process.__dict__.__len__() returns 7 — multiprocessing.Process (context.Process) is a thin platform-specific subclass with only 7 entries: __module__, __firstlineno__, _start_method, _Popen, _after_fork, __static_attributes__, __doc__; the actual process management logic lives in multiprocessing.process.BaseProcess which Process inherits from; NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__len__
  args: []
  expected: 7

invariant multiprocessing_extra159.base_process_dict_contains_start:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('start') returns True — multiprocessing.process.BaseProcess defines start() directly in its class body in Lib/multiprocessing/process.py; BaseProcess.start() starts the child process; it creates and starts the Popen object (_Popen(self)); must not be called more than once per process object; 'start' is in BaseProcess.__dict__; NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["start"]
  expected: true

invariant multiprocessing_extra159.base_process_dict_contains_run:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('run') returns True — multiprocessing.process.BaseProcess defines run() directly in its class body; BaseProcess.run() represents the process's activity; it calls self._target(*self._args, **self._kwargs) if a target was provided; subclasses override run() to provide custom process behavior; 'run' is in BaseProcess.__dict__; NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["run"]
  expected: true

invariant multiprocessing_extra159.base_process_dict_contains_join:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('join') returns True — multiprocessing.process.BaseProcess defines join() directly in its class body; BaseProcess.join(timeout=None) blocks the calling process until the child process whose join() method is called terminates; if timeout is given, at most timeout seconds are waited; 'join' is in BaseProcess.__dict__; NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["join"]
  expected: true

invariant multiprocessing_extra159.base_process_dict_contains_kill:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('kill') returns True — multiprocessing.process.BaseProcess defines kill() directly in its class body; BaseProcess.kill() is the same as terminate() but uses SIGKILL signal on Unix for immediate forced termination without cleanup; 'kill' is in BaseProcess.__dict__; NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["kill"]
  expected: true

invariant multiprocessing_extra159.base_process_dict_len_twentyseven:
  description: "multiprocessing.process.BaseProcess.__dict__.__len__() returns 27 — multiprocessing.process.BaseProcess has 27 entries in its class dict on Python 3.14.3: __module__, __firstlineno__, __doc__, _Popen, __init__, _check_closed, run, start, interrupt, terminate, kill, join, is_alive, close, name, daemon, authkey, exitcode, ident, pid, sentinel, __repr__, _bootstrap, _after_fork, __static_attributes__, __dict__, __weakref__; NEW in extra159; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
