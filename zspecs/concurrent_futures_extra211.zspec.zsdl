spec: concurrent_futures_extra211
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec covers: __doc__ string contains checks using NEW words for concurrent.futures.Future, Executor, as_completed, and wait — none of these words appeared in wave 379."
    - "concurrent.futures.Future.__doc__ == 'Represents the result of an asynchronous computation.' (len=53). Wave 379 used 'future','result'. NEW: 'asynchronous'==True, 'computation'==True, 'Represents'==True. Verified with Python 3.14.3."
    - "concurrent.futures.Executor.__doc__ == 'This is an abstract base class for concrete asynchronous executors.' (len=67). Wave 379 used 'executor','submit','completed','timeout'. NEW: 'abstract'==True, 'concrete'==True, 'asynchronous'==True. Verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__doc__ (len=570): 'iterator'==True, 'yield'==True, 'cancelled'==True. Wave 379 used 'completed','timeout'. Verified with Python 3.14.3."
    - "concurrent.futures.wait.__doc__ (len=1054): 'wait'==True, 'set'==True, 'not_done'==True, 'sequence'==True, 'done'==True. New function not covered at all in wave 379. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future __doc__ new-word contains checks — extra211
#
# Future.__doc__ == 'Represents the result of an asynchronous computation.'
# len == 53
# NEW (not in wave 379): 'asynchronous'==True, 'computation'==True, 'Represents'==True
# ---------------------------------------------------------------------------

table concurrent_futures_extra211.cf_future_doc_new_words:
  description: "concurrent.futures.Future.__doc__ contains checks using words NOT in wave 379 — cfe211fut: 'asynchronous'==True; 'computation'==True; 'Represents'==True; wave 379 covered 'future','result'; len==53; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe211fut

  columns: [id, function, args, expected, description]
  rows:
    - [fut_doc_has_asynchronous, concurrent.futures.Future.__doc__.__contains__, ["asynchronous"], true,  "concurrent.futures.Future.__doc__.__contains__('asynchronous') == True; verified with Python 3.14.3"]
    - [fut_doc_has_computation,  concurrent.futures.Future.__doc__.__contains__, ["computation"],  true,  "concurrent.futures.Future.__doc__.__contains__('computation') == True; verified with Python 3.14.3"]
    - [fut_doc_has_Represents,   concurrent.futures.Future.__doc__.__contains__, ["Represents"],   true,  "concurrent.futures.Future.__doc__.__contains__('Represents') == True; opens with 'Represents the result'; verified with Python 3.14.3"]
    - [fut_doc_no_cancel,        concurrent.futures.Future.__doc__.__contains__, ["cancel"],       false, "concurrent.futures.Future.__doc__.__contains__('cancel') == False; 'cancel' not in brief 53-char docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor __doc__ new-word contains checks — extra211
#
# Executor.__doc__ == 'This is an abstract base class for concrete asynchronous executors.'
# len == 67
# NEW (not in wave 379): 'abstract'==True, 'concrete'==True, 'asynchronous'==True
# ---------------------------------------------------------------------------

table concurrent_futures_extra211.cf_executor_doc_new_words:
  description: "concurrent.futures.Executor.__doc__ contains checks using words NOT in wave 379 — cfe211exe: 'abstract'==True; 'concrete'==True; 'asynchronous'==True; wave 379 covered 'executor'; full doc: 'This is an abstract base class for concrete asynchronous executors.' (len=67); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe211exe

  columns: [id, function, args, expected, description]
  rows:
    - [exe_doc_has_abstract,     concurrent.futures.Executor.__doc__.__contains__, ["abstract"],     true,  "concurrent.futures.Executor.__doc__.__contains__('abstract') == True; 'abstract base class'; verified with Python 3.14.3"]
    - [exe_doc_has_concrete,     concurrent.futures.Executor.__doc__.__contains__, ["concrete"],     true,  "concurrent.futures.Executor.__doc__.__contains__('concrete') == True; 'for concrete asynchronous executors'; verified with Python 3.14.3"]
    - [exe_doc_has_asynchronous, concurrent.futures.Executor.__doc__.__contains__, ["asynchronous"], true,  "concurrent.futures.Executor.__doc__.__contains__('asynchronous') == True; 'concrete asynchronous executors'; verified with Python 3.14.3"]
    - [exe_doc_no_shutdown,      concurrent.futures.Executor.__doc__.__contains__, ["shutdown"],     false, "concurrent.futures.Executor.__doc__.__contains__('shutdown') == False; 'shutdown' not in brief 67-char docstring; verified with Python 3.14.3"]
    - [exe_doc_len,              concurrent.futures.Executor.__doc__.__len__,      [],               67,    "concurrent.futures.Executor.__doc__.__len__() == 67; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed __doc__ new-word contains checks — extra211
#
# as_completed.__doc__ (len=570): iterator that yields futures as they finish
# NEW (not in wave 379): 'iterator'==True, 'yield'==True, 'cancelled'==True
# ---------------------------------------------------------------------------

table concurrent_futures_extra211.cf_as_completed_doc_new_words:
  description: "concurrent.futures.as_completed.__doc__ contains checks using words NOT in wave 379 — cfe211asc: 'iterator'==True ('An iterator over the given futures'); 'yield'==True ('yields each as it completes'); 'cancelled'==True; wave 379 covered 'completed','timeout'; len==570; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe211asc

  columns: [id, function, args, expected, description]
  rows:
    - [asc_doc_has_iterator,  concurrent.futures.as_completed.__doc__.__contains__, ["iterator"],  true, "concurrent.futures.as_completed.__doc__.__contains__('iterator') == True; 'An iterator over the given futures'; verified with Python 3.14.3"]
    - [asc_doc_has_yield,     concurrent.futures.as_completed.__doc__.__contains__, ["yield"],     true, "concurrent.futures.as_completed.__doc__.__contains__('yield') == True; 'yields each as it completes'; verified with Python 3.14.3"]
    - [asc_doc_has_cancelled, concurrent.futures.as_completed.__doc__.__contains__, ["cancelled"], true, "concurrent.futures.as_completed.__doc__.__contains__('cancelled') == True; finished or cancelled futures; verified with Python 3.14.3"]
    - [asc_doc_len,           concurrent.futures.as_completed.__doc__.__len__,      [],            570,  "concurrent.futures.as_completed.__doc__.__len__() == 570; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.wait __doc__ contains checks — extra211 (new function vs wave 379)
#
# wait.__doc__ (len=1054): Wait for futures to complete, returns named 2-tuple of sets
# 'wait'==True, 'set'==True, 'not_done'==True, 'sequence'==True, 'done'==True
# ---------------------------------------------------------------------------

table concurrent_futures_extra211.cf_wait_doc_contains:
  description: "concurrent.futures.wait.__doc__ contains checks — cfe211wait: new function not covered in wave 379; 'wait'==True; 'sequence'==True ('sequence of Futures'); 'done'==True ('set named done'); 'not_done'==True ('set named not_done'); 'set'==True; len==1054; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe211wait

  columns: [id, function, args, expected, description]
  rows:
    - [wait_doc_has_wait,     concurrent.futures.wait.__doc__.__contains__, ["wait"],     true, "concurrent.futures.wait.__doc__.__contains__('wait') == True; verified with Python 3.14.3"]
    - [wait_doc_has_sequence, concurrent.futures.wait.__doc__.__contains__, ["sequence"], true, "concurrent.futures.wait.__doc__.__contains__('sequence') == True; 'the given sequence of Futures'; verified with Python 3.14.3"]
    - [wait_doc_has_done,     concurrent.futures.wait.__doc__.__contains__, ["done"],     true, "concurrent.futures.wait.__doc__.__contains__('done') == True; named set 'done' in return tuple; verified with Python 3.14.3"]
    - [wait_doc_has_not_done, concurrent.futures.wait.__doc__.__contains__, ["not_done"], true, "concurrent.futures.wait.__doc__.__contains__('not_done') == True; named set 'not_done' in return tuple; verified with Python 3.14.3"]
    - [wait_doc_has_set,      concurrent.futures.wait.__doc__.__contains__, ["set"],      true, "concurrent.futures.wait.__doc__.__contains__('set') == True; return value is named 2-tuple of sets; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra211
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra211.future_doc_has_computation:
  description: "concurrent.futures.Future.__doc__.__contains__('computation') returns True — Future.__doc__ is 'Represents the result of an asynchronous computation.' (len=53); 'computation' not used in wave 379 (which used 'future','result'); a Future holds the outcome of a deferred computation; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__doc__.__contains__
  args: ["computation"]
  expected: true

invariant concurrent_futures_extra211.executor_doc_has_abstract:
  description: "concurrent.futures.Executor.__doc__.__contains__('abstract') returns True — Executor.__doc__ is 'This is an abstract base class for concrete asynchronous executors.' (len=67); 'abstract' not used for Executor in wave 379; 'shutdown' is False in the brief docstring; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__doc__.__contains__
  args: ["abstract"]
  expected: true

invariant concurrent_futures_extra211.wait_doc_has_not_done:
  description: "concurrent.futures.wait.__doc__.__contains__('not_done') returns True — wait.__doc__ (len=1054) describes the return value as 'A named 2-tuple of sets. The first set, named done, contains futures that completed ... The second set, named not_done, contains uncompleted futures.'; wait not covered in wave 379; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__doc__.__contains__
  args: ["not_done"]
  expected: true

invariant concurrent_futures_extra211.as_completed_doc_has_yield:
  description: "concurrent.futures.as_completed.__doc__.__contains__('yield') returns True — as_completed.__doc__ (len=570) opens with 'An iterator over the given futures that yields each as it completes.'; 'yield' not used in wave 379 (which used 'completed','timeout'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__doc__.__contains__
  args: ["yield"]
  expected: true
