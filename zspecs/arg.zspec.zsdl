spec: arg
version: ">=5.0.0"
backend: node(arg)

docs: https://github.com/vercel/arg#readme

provenance:
  derived_from:
    - "arg README — https://github.com/vercel/arg#readme"
    - "Test vectors verified with arg via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "arg source"
  notes:
    - "Vercel's typed CLI parser — schema is {flag: type} where type is String/Number/Boolean."
    - "Install: npm install arg"
    - "v5 CJS; module export IS the parse function; .flag / .COUNT / .ArgError attached."
    - "Spec uses {argv: [...]} option to bypass process.argv."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws ArgError on unknown flags or wrong-type values."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    ArgError: "Wrong-type value or unknown flag"

invariant arg.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant arg.has_flag_helper:
  description: ".flag() helper for boolean flags exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "flag.constructor.name"}
  expected: "Function"

invariant arg.has_COUNT_helper:
  description: ".COUNT helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: COUNT}
    - {get: "constructor.name"}
  expected: "Function"

invariant arg.has_ArgError_class:
  description: ".ArgError class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ArgError.constructor.name"}
  expected: "Function"

invariant arg.module_arity:
  description: "Module function declared length is 1 (spec required, options optional)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant arg.ArgError_name:
  description: "ArgError.name is 'ArgError'"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ArgError.name"}
  expected: "ArgError"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:34:12Z
  iterations: 2
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 2 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
