spec: multiprocessing_extra141
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Manager — Manager documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Value — Value documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Array — Array documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py, Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: multiprocessing.Manager — __qualname__=='BaseContext.Manager' (len=19); __module__=='multiprocessing.context' (len=23); __doc__.__len__()==165. multiprocessing.Value — __qualname__=='BaseContext.Value' (len=17); __module__=='multiprocessing.context' (len=23); __doc__.__eq__('Returns a synchronized shared object')==True (len=36). multiprocessing.Array — __qualname__=='BaseContext.Array' (len=17); __module__=='multiprocessing.context' (len=23); __doc__.__eq__('Returns a synchronized shared array')==True (len=35). multiprocessing.cpu_count — __qualname__=='BaseContext.cpu_count' (len=21); __module__=='multiprocessing.context' (len=23); __doc__.__eq__('Returns the number of CPUs in the system')==True (len=40). multiprocessing.current_process — __qualname__=='current_process' (len=15); __module__=='multiprocessing.process' (len=23); __doc__.__len__()==56. multiprocessing.active_children — __qualname__=='active_children' (len=15); __module__=='multiprocessing.process' (len=23); __doc__.__len__()==70. multiprocessing.Pipe — __qualname__=='BaseContext.Pipe' (len=16); __module__=='multiprocessing.context' (len=23); __doc__.__len__()==49. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Manager, Value, Array, cpu_count, and Pipe are all bound methods of the DefaultContext object — their __module__=='multiprocessing.context' (len=23) and __qualname__ starts with 'BaseContext.'. multiprocessing.current_process and active_children are module-level functions with __module__=='multiprocessing.process' (len=23: same length as context). cpu_count.__code__.co_argcount==1 (takes 'self', the context instance); current_process and active_children co_argcount==0 (module-level, no self). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Manager, Value, Array — __qualname__, __module__, __doc__ — extra141
#
# multiprocessing.Manager.__qualname__       == 'BaseContext.Manager' (len=19)
# multiprocessing.Manager.__module__         == 'multiprocessing.context' (len=23)
# multiprocessing.Manager.__doc__.__len__()  == 165
# multiprocessing.Value.__qualname__         == 'BaseContext.Value'  (len=17)
# multiprocessing.Value.__doc__              == 'Returns a synchronized shared object' (len=36)
# multiprocessing.Array.__qualname__         == 'BaseContext.Array'  (len=17)
# multiprocessing.Array.__doc__              == 'Returns a synchronized shared array'  (len=35)
# ---------------------------------------------------------------------------

table multiprocessing_extra141.manager_value_array:
  description: "multiprocessing.Manager, Value, and Array __qualname__, __module__, and __doc__ checks — Manager.__qualname__.__eq__('BaseContext.Manager')==True (len=19: 'BaseContext'=11+'.'=1+'Manager'=7=19); Manager.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); Manager.__doc__.__len__()==165 (multi-line doc describing Manager as returning a manager associated with a running server process and listing available methods); Value.__qualname__.__eq__('BaseContext.Value')==True (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17); Value.__doc__.__eq__('Returns a synchronized shared object')==True (len=36: a terse one-sentence description); Array.__qualname__.__eq__('BaseContext.Array')==True (len=17: same length as Value qualname); Array.__doc__.__eq__('Returns a synchronized shared array')==True (len=35: one shorter than Value doc, 'array' vs 'object'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmva141

  columns: [id, function, args, expected, description]
  rows:
    - [mgr_qn_eq,   multiprocessing.Manager.__qualname__.__eq__,   ["BaseContext.Manager"],  true,  "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager' (len=19); verified with Python 3.14.3"]
    - [mgr_qn_len,  multiprocessing.Manager.__qualname__.__len__,   [],                      19,    "multiprocessing.Manager.__qualname__.__len__() == 19; verified with Python 3.14.3"]
    - [mgr_mod_eq,  multiprocessing.Manager.__module__.__eq__,     ["multiprocessing.context"], true, "multiprocessing.Manager.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [mgr_mod_len, multiprocessing.Manager.__module__.__len__,     [],                      23,    "multiprocessing.Manager.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [mgr_doc_len, multiprocessing.Manager.__doc__.__len__,        [],                      165,   "multiprocessing.Manager.__doc__.__len__() == 165; verified with Python 3.14.3"]
    - [val_qn_eq,   multiprocessing.Value.__qualname__.__eq__,     ["BaseContext.Value"],    true,  "multiprocessing.Value.__qualname__ == 'BaseContext.Value' (len=17); verified with Python 3.14.3"]
    - [val_qn_len,  multiprocessing.Value.__qualname__.__len__,     [],                      17,    "multiprocessing.Value.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [val_doc_eq,  multiprocessing.Value.__doc__.__eq__,          ["Returns a synchronized shared object"], true, "multiprocessing.Value.__doc__ == 'Returns a synchronized shared object' (len=36); verified with Python 3.14.3"]
    - [val_doc_len, multiprocessing.Value.__doc__.__len__,          [],                      36,    "multiprocessing.Value.__doc__.__len__() == 36; verified with Python 3.14.3"]
    - [arr_qn_eq,   multiprocessing.Array.__qualname__.__eq__,     ["BaseContext.Array"],    true,  "multiprocessing.Array.__qualname__ == 'BaseContext.Array' (len=17); verified with Python 3.14.3"]
    - [arr_qn_len,  multiprocessing.Array.__qualname__.__len__,     [],                      17,    "multiprocessing.Array.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [arr_doc_eq,  multiprocessing.Array.__doc__.__eq__,          ["Returns a synchronized shared array"], true, "multiprocessing.Array.__doc__ == 'Returns a synchronized shared array' (len=35); verified with Python 3.14.3"]
    - [arr_doc_len, multiprocessing.Array.__doc__.__len__,          [],                      35,    "multiprocessing.Array.__doc__.__len__() == 35; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.cpu_count and Pipe — extra141
#
# multiprocessing.cpu_count.__qualname__        == 'BaseContext.cpu_count' (len=21)
# multiprocessing.cpu_count.__module__          == 'multiprocessing.context' (len=23)
# multiprocessing.cpu_count.__doc__             == 'Returns the number of CPUs in the system' (len=40)
# multiprocessing.cpu_count.__code__.co_argcount == 1
# multiprocessing.Pipe.__qualname__             == 'BaseContext.Pipe' (len=16)
# multiprocessing.Pipe.__doc__.__len__()        == 49
# ---------------------------------------------------------------------------

table multiprocessing_extra141.cpu_count_and_pipe:
  description: "multiprocessing.cpu_count and Pipe __qualname__, __module__, __doc__, and code checks — cpu_count.__qualname__.__eq__('BaseContext.cpu_count')==True (len=21: 'BaseContext'=11+'.'=1+'cpu_count'=9=21, the longest BaseContext qualname in this spec); cpu_count.__module__.__eq__('multiprocessing.context')==True (len=23); cpu_count.__doc__.__eq__('Returns the number of CPUs in the system')==True (len=40); cpu_count.__code__.co_argcount.__eq__(1)==True (takes 'self' — the context — as the only argument, so bound methods bind 'self' and the caller provides no extra arguments); Pipe.__qualname__.__eq__('BaseContext.Pipe')==True (len=16: 'BaseContext'=11+'.'=1+'Pipe'=4=16); Pipe.__module__.__eq__('multiprocessing.context')==True (len=23); Pipe.__doc__.__len__()==49 (describes Pipe as creating a connection pair); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcpu141

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_qn_eq,    multiprocessing.cpu_count.__qualname__.__eq__,     ["BaseContext.cpu_count"],  true,  "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21); verified with Python 3.14.3"]
    - [cpu_qn_len,   multiprocessing.cpu_count.__qualname__.__len__,     [],                        21,    "multiprocessing.cpu_count.__qualname__.__len__() == 21; verified with Python 3.14.3"]
    - [cpu_mod_len,  multiprocessing.cpu_count.__module__.__len__,       [],                        23,    "multiprocessing.cpu_count.__module__.__len__() == 23 ('multiprocessing.context'); verified with Python 3.14.3"]
    - [cpu_doc_eq,   multiprocessing.cpu_count.__doc__.__eq__,          ["Returns the number of CPUs in the system"], true, "multiprocessing.cpu_count.__doc__ == 'Returns the number of CPUs in the system' (len=40); verified with Python 3.14.3"]
    - [cpu_doc_len,  multiprocessing.cpu_count.__doc__.__len__,          [],                        40,    "multiprocessing.cpu_count.__doc__.__len__() == 40; verified with Python 3.14.3"]
    - [cpu_argc,     multiprocessing.cpu_count.__code__.co_argcount.__eq__, [1],                    true,  "multiprocessing.cpu_count.__code__.co_argcount == 1 (takes 'self', the context object); verified with Python 3.14.3"]
    - [pipe_qn_eq,   multiprocessing.Pipe.__qualname__.__eq__,          ["BaseContext.Pipe"],       true,  "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' (len=16); verified with Python 3.14.3"]
    - [pipe_qn_len,  multiprocessing.Pipe.__qualname__.__len__,          [],                        16,    "multiprocessing.Pipe.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [pipe_mod_len, multiprocessing.Pipe.__module__.__len__,            [],                        23,    "multiprocessing.Pipe.__module__.__len__() == 23 ('multiprocessing.context'); verified with Python 3.14.3"]
    - [pipe_doc_len, multiprocessing.Pipe.__doc__.__len__,               [],                        49,    "multiprocessing.Pipe.__doc__.__len__() == 49; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.current_process and active_children — extra141
#
# multiprocessing.current_process.__qualname__       == 'current_process' (len=15)
# multiprocessing.current_process.__module__         == 'multiprocessing.process' (len=23)
# multiprocessing.current_process.__doc__.__len__()  == 56
# multiprocessing.active_children.__qualname__       == 'active_children' (len=15)
# multiprocessing.active_children.__module__         == 'multiprocessing.process' (len=23)
# multiprocessing.active_children.__doc__.__len__()  == 70
# ---------------------------------------------------------------------------

table multiprocessing_extra141.current_process_active_children:
  description: "multiprocessing.current_process and active_children __qualname__, __module__, __doc__, and code checks — current_process.__qualname__.__eq__('current_process')==True (len=15: top-level module function, qualname equals name); current_process.__module__.__eq__('multiprocessing.process')==True (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); current_process.__doc__.__len__()==56 (doc is '\\nReturn process object representing the current process\\n' with leading and trailing newlines); current_process.__code__.co_argcount.__eq__(0)==True (takes no arguments); active_children.__qualname__.__eq__('active_children')==True (len=15: ties with current_process qualname); active_children.__module__.__eq__('multiprocessing.process')==True (len=23: same module as current_process); active_children.__doc__.__len__()==70 (doc is '\\nReturn list of process objects corresponding to live child processes\\n' with leading and trailing newlines, 14 chars longer than current_process doc); active_children.__code__.co_argcount.__eq__(0)==True (takes no arguments); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpproc141

  columns: [id, function, args, expected, description]
  rows:
    - [cp_qn_eq,    multiprocessing.current_process.__qualname__.__eq__,      ["current_process"],           true,  "multiprocessing.current_process.__qualname__ == 'current_process' (len=15); verified with Python 3.14.3"]
    - [cp_qn_len,   multiprocessing.current_process.__qualname__.__len__,      [],                            15,    "multiprocessing.current_process.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [cp_mod_eq,   multiprocessing.current_process.__module__.__eq__,        ["multiprocessing.process"],   true,  "multiprocessing.current_process.__module__ == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]
    - [cp_mod_len,  multiprocessing.current_process.__module__.__len__,        [],                            23,    "multiprocessing.current_process.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [cp_doc_len,  multiprocessing.current_process.__doc__.__len__,           [],                            56,    "multiprocessing.current_process.__doc__.__len__() == 56; verified with Python 3.14.3"]
    - [cp_argc,     multiprocessing.current_process.__code__.co_argcount.__eq__, [0],                         true,  "multiprocessing.current_process.__code__.co_argcount == 0 (no arguments); verified with Python 3.14.3"]
    - [ac_qn_eq,    multiprocessing.active_children.__qualname__.__eq__,      ["active_children"],            true,  "multiprocessing.active_children.__qualname__ == 'active_children' (len=15); verified with Python 3.14.3"]
    - [ac_qn_len,   multiprocessing.active_children.__qualname__.__len__,      [],                            15,    "multiprocessing.active_children.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [ac_mod_len,  multiprocessing.active_children.__module__.__len__,        [],                            23,    "multiprocessing.active_children.__module__.__len__() == 23 ('multiprocessing.process'); verified with Python 3.14.3"]
    - [ac_doc_len,  multiprocessing.active_children.__doc__.__len__,           [],                            70,    "multiprocessing.active_children.__doc__.__len__() == 70; verified with Python 3.14.3"]
    - [ac_argc,     multiprocessing.active_children.__code__.co_argcount.__eq__, [0],                         true,  "multiprocessing.active_children.__code__.co_argcount == 0 (no arguments); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra141
# ---------------------------------------------------------------------------

invariant multiprocessing_extra141.manager_doc_len_165:
  description: "multiprocessing.Manager.__doc__.__len__() == 165 — multiprocessing.Manager.__doc__ is a 165-char multi-line doc describing Manager as returning a manager associated with a running server process and listing Lock(), Condition(), Queue() etc. as available methods; Manager.__qualname__=='BaseContext.Manager' (len=19); Manager.__module__=='multiprocessing.context' (len=23); NEW in extra141: first standalone Manager doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Manager.__doc__.__len__
  args: []
  expected: 165

invariant multiprocessing_extra141.cpu_count_qualname_len_21:
  description: "multiprocessing.cpu_count.__qualname__.__len__() == 21 — multiprocessing.cpu_count.__qualname__ is 'BaseContext.cpu_count' (21 chars: 'BaseContext'=11+'.'=1+'cpu_count'=9=21); this is the longest BaseContext qualname of the context-bound methods in this spec (compare: Manager=19, Pipe=16, Value=Array=17); cpu_count.__module__=='multiprocessing.context' (len=23); cpu_count.__code__.co_argcount==1; NEW in extra141: first standalone cpu_count qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra141.active_children_doc_len_70:
  description: "multiprocessing.active_children.__doc__.__len__() == 70 — multiprocessing.active_children.__doc__ is '\\nReturn list of process objects corresponding to live child processes\\n' (70 chars including leading and trailing newlines); this is 14 chars longer than current_process.__doc__ (56); active_children.__qualname__=='active_children' (len=15); active_children.__module__=='multiprocessing.process' (len=23); active_children co_argcount==0; NEW in extra141: first standalone active_children doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.active_children.__doc__.__len__
  args: []
  expected: 70

invariant multiprocessing_extra141.current_process_doc_len_56:
  description: "multiprocessing.current_process.__doc__.__len__() == 56 — multiprocessing.current_process.__doc__ is '\\nReturn process object representing the current process\\n' (56 chars including leading and trailing newlines); current_process.__qualname__=='current_process' (len=15); current_process.__module__=='multiprocessing.process' (len=23); co_argcount==0 (no parameters); NEW in extra141: first standalone current_process doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.current_process.__doc__.__len__
  args: []
  expected: 56

invariant multiprocessing_extra141.value_doc_len_36:
  description: "multiprocessing.Value.__doc__.__len__() == 36 — multiprocessing.Value.__doc__ is 'Returns a synchronized shared object' (36 chars: a terse one-sentence description); one more than Array.__doc__ len (35: 'Returns a synchronized shared array'); Value.__qualname__=='BaseContext.Value' (len=17); Value.__module__=='multiprocessing.context' (len=23); NEW in extra141: first standalone Value doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__doc__.__len__
  args: []
  expected: 36

invariant multiprocessing_extra141.manager_qualname_len_19:
  description: "multiprocessing.Manager.__qualname__.__len__() == 19 — multiprocessing.Manager.__qualname__ is 'BaseContext.Manager' (19 chars: 'BaseContext'=11+'.'=1+'Manager'=7=19); Manager, Value, Array, Pipe and cpu_count are all bound methods of the DefaultContext object with __qualname__ beginning 'BaseContext.'; Manager has the second-longest qualname (19) after cpu_count (21); Manager.__module__=='multiprocessing.context' (len=23); NEW in extra141: first standalone Manager qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Manager.__qualname__.__len__
