spec: getopt_extra
version: ">=3.9"
backend: python_module(getopt)

docs: https://docs.python.org/3/library/getopt.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/getopt.html — Python getopt module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/getopt.py"
  notes:
    - "This spec covers getopt behaviors not in getopt.zspec.zsdl."
    - "getopt.getopt.__name__ == 'getopt' and getopt.getopt.__module__ == 'getopt'."
    - "getopt.gnu_getopt.__name__ == 'gnu_getopt'."
    - "getopt.GetoptError.__name__ == 'GetoptError' — the documented exception class."
    - "getopt.error is an alias for getopt.GetoptError; both have __name__ == 'GetoptError'."
    - "GetoptError inherits directly from Exception."
    - "GetoptError.msg and GetoptError.opt are instance attributes set in __init__; not accessible at class level."
    - "GetoptError.__module__ == 'getopt' — the class is defined in the getopt module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getopt function — name and module
# ---------------------------------------------------------------------------

invariant getopt_extra.getopt.name:
  description: "getopt.getopt.__name__ == 'getopt'"
  category: functions
  kind: python_call_eq
  function: getopt.__name__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra.getopt.module:
  description: "getopt.getopt.__module__ == 'getopt'"
  category: functions
  kind: python_call_eq
  function: getopt.__module__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra.getopt.is_function:
  description: "type(getopt.getopt).__name__ == 'function'"
  category: functions
  kind: python_call_eq
  function: getopt.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# gnu_getopt function — name and module
# ---------------------------------------------------------------------------

invariant getopt_extra.gnu_getopt.name:
  description: "getopt.gnu_getopt.__name__ == 'gnu_getopt'"
  category: functions
  kind: python_call_eq
  function: gnu_getopt.__name__.__eq__
  args: ["gnu_getopt"]
  expected: true

invariant getopt_extra.gnu_getopt.module:
  description: "getopt.gnu_getopt.__module__ == 'getopt'"
  category: functions
  kind: python_call_eq
  function: gnu_getopt.__module__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra.gnu_getopt.is_function:
  description: "type(getopt.gnu_getopt).__name__ == 'function'"
  category: functions
  kind: python_call_eq
  function: gnu_getopt.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# GetoptError class — name and module
# ---------------------------------------------------------------------------

invariant getopt_extra.GetoptError.name:
  description: "getopt.GetoptError.__name__ == 'GetoptError'"
  category: classes
  kind: python_call_eq
  function: GetoptError.__name__.__eq__
  args: ["GetoptError"]
  expected: true

invariant getopt_extra.GetoptError.module:
  description: "getopt.GetoptError.__module__ == 'getopt'"
  category: classes
  kind: python_call_eq
  function: GetoptError.__module__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra.GetoptError.is_type:
  description: "type(getopt.GetoptError).__name__ == 'type' — GetoptError is a class"
  category: classes
  kind: python_call_eq
  function: GetoptError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# GetoptError class hierarchy — inherits from Exception
# ---------------------------------------------------------------------------

invariant getopt_extra.GetoptError.base_is_Exception:
  description: "getopt.GetoptError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: GetoptError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant getopt_extra.GetoptError.bases_len:
  description: "len(getopt.GetoptError.__bases__) == 1 — single direct base class"
  category: hierarchy
  kind: python_call_eq
  function: GetoptError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# getopt.error alias — same class as GetoptError
# ---------------------------------------------------------------------------

invariant getopt_extra.error.alias_name:
  description: "getopt.error.__name__ == 'GetoptError' — error is an alias for GetoptError"
  category: classes
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["GetoptError"]
  expected: true

invariant getopt_extra.error.alias_module:
  description: "getopt.error.__module__ == 'getopt'"
  category: classes
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["getopt"]
  expected: true

# ---------------------------------------------------------------------------
# GetoptError instance attributes — msg and opt are set by __init__
#
# These are instance attributes, not class-level; we verify the __init__
# method is present and that the class has the expected __init__ name.
# ---------------------------------------------------------------------------

invariant getopt_extra.GetoptError.init_name:
  description: "getopt.GetoptError.__init__.__name__ == '__init__'"
  category: attributes
  kind: python_call_eq
  function: GetoptError.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant getopt_extra.GetoptError.str_name:
  description: "getopt.GetoptError.__str__.__name__ == '__str__'"
  category: attributes
  kind: python_call_eq
  function: GetoptError.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true
