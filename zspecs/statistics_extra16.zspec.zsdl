spec: statistics_extra16
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra15.zspec.zsdl."
    - "Prior specs focus on NormalDist parameter sets and distribution methods."
    - "No prior spec covers statistics.mean([1,2,3,4,5]) == 3."
    - "No prior spec covers statistics.median([1,2,3,4,5]) == 3 (odd-length list)."
    - "No prior spec covers statistics.median([1,2,3,4]) == 2.5 (even-length list interpolation)."
    - "No prior spec covers statistics.mode([1,1,2,3]) == 1."
    - "No prior spec covers statistics.variance([2,4,4,4,5,5,7,9]) == 4.571428571428571."
    - "No prior spec covers statistics.stdev([2,4,4,4,5,5,7,9]).__class__.__name__ == 'float'."
    - "No prior spec covers a table of __name__ attributes for the seven core statistics functions."
    - "statistics.mean([1,2,3,4,5]) == 3 — arithmetic mean of 1..5 is exactly 3 (integer result)."
    - "statistics.median([1,2,3,4,5]) == 3 — middle value of five elements."
    - "statistics.median([1,2,3,4]) == 2.5 — average of inner two for even-length sequence."
    - "statistics.mode([1,1,2,3]) == 1 — most common element."
    - "statistics.variance([2,4,4,4,5,5,7,9]) == 4.571428571428571 — sample variance (n-1 denominator)."
    - "statistics.stdev returns a float — __class__.__name__ == 'float'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Core descriptive statistics — mean, median, mode, variance
#
# These are the fundamental functions in the statistics module.
# No prior spec covers any of these call results directly.
# ---------------------------------------------------------------------------

invariant statistics_extra16.mean.list_1_to_5:
  description: "statistics.mean([1,2,3,4,5]) == 3 — arithmetic mean of integers 1 through 5"
  category: descriptive
  kind: python_call_eq
  function: mean
  args: [[1, 2, 3, 4, 5]]
  expected: 3

invariant statistics_extra16.median.odd_length:
  description: "statistics.median([1,2,3,4,5]) == 3 — median of five sorted elements is the middle value"
  category: descriptive
  kind: python_call_eq
  function: median
  args: [[1, 2, 3, 4, 5]]
  expected: 3

invariant statistics_extra16.median.even_length:
  description: "statistics.median([1,2,3,4]) == 2.5 — even-length list returns average of two middle values"
  category: descriptive
  kind: python_call_eq
  function: median
  args: [[1, 2, 3, 4]]
  expected: 2.5

invariant statistics_extra16.mode.most_common:
  description: "statistics.mode([1,1,2,3]) == 1 — most frequently occurring element"
  category: descriptive
  kind: python_call_eq
  function: mode
  args: [[1, 1, 2, 3]]
  expected: 1

invariant statistics_extra16.variance.sample_8:
  description: "statistics.variance([2,4,4,4,5,5,7,9]) == 4.571428571428571 — sample variance with n-1 denominator"
  category: descriptive
  kind: python_call_eq
  function: variance
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 4.571428571428571

# ---------------------------------------------------------------------------
# stdev return type — __class__.__name__ == 'float'
#
# statistics.stdev always returns a Python float regardless of input type.
# No prior spec verifies this return type.
# ---------------------------------------------------------------------------

invariant statistics_extra16.stdev.return_type:
  description: "statistics.stdev([2,4,4,4,5,5,7,9]).__class__.__name__ == 'float' — stdev always returns float"
  category: descriptive
  kind: python_call_eq
  function: stdev
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ attributes for core statistics functions
#
# No prior spec records the __name__ attribute of the seven core functions.
# Each function's __name__ equals its bare identifier as defined in the module.
# ---------------------------------------------------------------------------

table statistics_extra16.function_names:
  kind: python_call_eq
  category: introspection
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [mean_name,     mean.__name__.__eq__,     ["mean"],     true]
    - [median_name,   median.__name__.__eq__,   ["median"],   true]
    - [mode_name,     mode.__name__.__eq__,     ["mode"],     true]
    - [variance_name, variance.__name__.__eq__, ["variance"], true]
    - [stdev_name,    stdev.__name__.__eq__,    ["stdev"],    true]
    - [pvariance_name, pvariance.__name__.__eq__, ["pvariance"], true]
    - [pstdev_name,   pstdev.__name__.__eq__,   ["pstdev"],   true]
