  rows:
    - ["io1681023", IOBase.__dict__.__contains__,          ["__iter__"], true]
    - ["io1681024", IOBase.__dict__.__contains__,          ["__next__"], true]
    - ["io1681025", RawIOBase.__dict__.__contains__,       ["__iter__"], false]
    - ["io1681026", RawIOBase.__dict__.__contains__,       ["__next__"], false]
    - ["io1681027", BufferedIOBase.__dict__.__contains__,   ["__iter__"], false]
