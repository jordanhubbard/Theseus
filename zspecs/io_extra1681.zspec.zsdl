spec: io_extra1681
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "io_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which io types define __call__ in their own __dict__."
    - "No io type (abstract or concrete) defines __call__ in its own __dict__. io classes are stream objects, not callables."
    - "IOBase defines __enter__ and __exit__ (context manager protocol) in its own __dict__."
    - "IOBase defines __iter__ and __next__ (iterator protocol) in its own __dict__."
    - "Concrete stream types (StringIO, BytesIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper) do NOT define __call__ in their own __dict__."
    - "Abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) do NOT define __call__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table io_extra1681.callable_protocol
# __call__ is absent from every io type's own __dict__.
# io stream objects are not callable; they are context managers and iterators.
# ---------------------------------------------------------------------------

table io_extra1681.callable_protocol:
  description: "io types __call__ dict-presence checks — no io type defines __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1681

  columns: [id, function, args, expected]
  rows:
    - ["io1681001", IOBase.__dict__.__contains__,         ["__call__"], false]
    - ["io1681002", RawIOBase.__dict__.__contains__,      ["__call__"], false]
    - ["io1681003", BufferedIOBase.__dict__.__contains__,  ["__call__"], false]
    - ["io1681004", TextIOBase.__dict__.__contains__,     ["__call__"], false]
    - ["io1681005", StringIO.__dict__.__contains__,       ["__call__"], false]
    - ["io1681006", BytesIO.__dict__.__contains__,        ["__call__"], false]
    - ["io1681007", FileIO.__dict__.__contains__,         ["__call__"], false]
    - ["io1681008", BufferedReader.__dict__.__contains__,  ["__call__"], false]
    - ["io1681009", BufferedWriter.__dict__.__contains__,  ["__call__"], false]
    - ["io1681010", TextIOWrapper.__dict__.__contains__,   ["__call__"], false]

# ---------------------------------------------------------------------------
# Table io_extra1681.context_manager_protocol
# IOBase defines __enter__ and __exit__ in its own __dict__.
# Subclasses inherit these without re-defining them.
# ---------------------------------------------------------------------------

table io_extra1681.context_manager_protocol:
  description: "Context manager protocol (__enter__/__exit__) in io class __dict__ checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1681

  columns: [id, function, args, expected]
  rows:
    - ["io1681011", IOBase.__dict__.__contains__,          ["__enter__"], true]
    - ["io1681012", IOBase.__dict__.__contains__,          ["__exit__"],  true]
    - ["io1681013", RawIOBase.__dict__.__contains__,       ["__enter__"], false]
    - ["io1681014", RawIOBase.__dict__.__contains__,       ["__exit__"],  false]
    - ["io1681015", BufferedIOBase.__dict__.__contains__,   ["__enter__"], false]
    - ["io1681016", BufferedIOBase.__dict__.__contains__,   ["__exit__"],  false]
    - ["io1681017", TextIOBase.__dict__.__contains__,      ["__enter__"], false]
    - ["io1681018", TextIOBase.__dict__.__contains__,      ["__exit__"],  false]
    - ["io1681019", StringIO.__dict__.__contains__,        ["__enter__"], false]
    - ["io1681020", StringIO.__dict__.__contains__,        ["__exit__"],  false]
    - ["io1681021", BytesIO.__dict__.__contains__,         ["__enter__"], false]
    - ["io1681022", BytesIO.__dict__.__contains__,         ["__exit__"],  false]

# ---------------------------------------------------------------------------
# Table io_extra1681.iterator_protocol
# IOBase defines __iter__ and __next__ in its own __dict__.
# Subclasses inherit without re-defining them.
# ---------------------------------------------------------------------------

table io_extra1681.iterator_protocol:
  description: "Iterator protocol (__iter__/__next__) in io class __dict__ checks"
