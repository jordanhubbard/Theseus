spec: uuid_extra191
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.UUID.__doc__.__class__.__name__ == 'str' (len=3) — the UUID class carries a docstring."
    - "uuid.SafeUUID.__doc__.__class__.__name__ == 'str' (len=3) — the SafeUUID enum carries a docstring."
    - "uuid.uuid1.__doc__.__class__.__name__ == 'str' (len=3) — uuid1 function carries a docstring."
    - "uuid.uuid4.__doc__.__class__.__name__ == 'str' (len=3) — uuid4 function carries a docstring."
    - "uuid.uuid5.__doc__.__class__.__name__ == 'str' (len=3) — uuid5 function carries a docstring."
    - "uuid.UUID.__init__.__doc__.__class__.__name__ == 'str' (len=3) — UUID.__init__ carries a docstring."
    - "uuid.UUID.__str__.__doc__.__class__.__name__ == 'NoneType' (len=8) — UUID.__str__ has no docstring; __doc__ is None."
    - "uuid.UUID.__hash__.__doc__.__class__.__name__ == 'NoneType' (len=8) — UUID.__hash__ has no docstring; __doc__ is None."
    - "Identity ordering by doc_class_name len: str(3) for UUID/SafeUUID/uuid1/uuid4/uuid5/UUID.__init__; NoneType(8) for UUID.__str__/UUID.__hash__."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

