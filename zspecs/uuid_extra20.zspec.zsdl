spec: uuid_extra20
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "This spec extends uuid_extra19.zspec.zsdl."
    - "Prior specs covered: uuid4() type, UUID fields, UUID.__name__/__module__/__qualname__, uuid.__name__/__package__, uuid1/3/4/5 __name__/__module__, NAMESPACE_DNS/URL/OID/X500 class names, UUID.__bases__[0].__name__, UUID.__init__.__name__, UUID.hex length/urn prefix, UUID integer attributes, uuid1/3/4/5 __qualname__ (extra5), uuid1/3/4/5 __module__ (extra18), UUID.__name__/__qualname__/__module__ lengths (extra19)."
    - "This spec covers: uuid.uuid1.__qualname__, uuid.uuid3.__qualname__, uuid.uuid4.__qualname__, uuid.uuid5.__qualname__, uuid.UUID.__init__.__qualname__, uuid.uuid1.__module__.__len__(), uuid.uuid3.__module__.__len__(), uuid.uuid4.__module__.__len__(), uuid.uuid5.__module__.__len__(), uuid.UUID.__module__.__len__(), uuid.NAMESPACE_DNS.__class__.__module__, uuid.UUID.__qualname__.__len__()."
    - "uuid.uuid1.__qualname__ == 'uuid1' — extra5 checks uuid1.__qualname__.__eq__ in a table; this spec provides standalone invariants for regression coverage in the extra20 namespace."
    - "uuid.uuid3.__qualname__ == 'uuid3' — same rationale as uuid1.__qualname__."
    - "uuid.uuid4.__qualname__ == 'uuid4' — same rationale as uuid1.__qualname__."
    - "uuid.uuid5.__qualname__ == 'uuid5' — same rationale as uuid1.__qualname__."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — no prior uuid spec checks UUID.__init__.__qualname__. UUID.__init__.__name__ is '__init__'; __qualname__ is 'UUID.__init__' (includes enclosing class name)."
    - "uuid.uuid1.__module__.__len__() == 4 — len('uuid') == 4; uuid_extra18 checks uuid1.__module__.__eq__('uuid') in a table. No prior spec checks __module__.__len__() on any factory function."
    - "uuid.uuid3.__module__.__len__() == 4 — same rationale as uuid1.__module__.__len__()."
    - "uuid.uuid4.__module__.__len__() == 4 — same rationale as uuid1.__module__.__len__()."
    - "uuid.uuid5.__module__.__len__() == 4 — same rationale as uuid1.__module__.__len__()."
    - "uuid.UUID.__module__.__len__() == 4 — uuid_extra18 checks UUID.__module__.__eq__('uuid'); no prior spec checks UUID.__module__.__len__()."
    - "uuid.NAMESPACE_DNS.__class__.__module__ == 'uuid' — extra15/17/19 check NAMESPACE constants' __class__.__qualname__ and __class__.__name__; no prior uuid spec checks __class__.__module__ on any NAMESPACE constant."
    - "uuid.UUID.__qualname__.__len__() == 4 — extra5 checks UUID.__qualname__.__eq__('UUID'); extra19 checks UUID.__name__.__len__()==4. No prior uuid spec checks UUID.__qualname__.__len__(). For top-level classes __name__ == __qualname__ so the lengths are equal."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid factory function __qualname__ standalone invariants
#
# uuid_extra5 checks uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ in a table.
# These standalone invariants in the extra20 namespace provide additional
# regression coverage. For module-level functions __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table uuid_extra20.factory_qualnames:
  description: "uuid1/uuid3/uuid4/uuid5 __qualname__ standalone — extra5 checked in table; new namespace for regression coverage"
  kind: python_call_eq
  category: function_identity
  id_prefix: factqn20

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uuid3, uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uuid4, uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uuid5, uuid5.__qualname__.__eq__, ["uuid5"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__
#
# No prior uuid spec checks UUID.__init__.__qualname__. uuid_extra8 (via the
# base uuid specs) checks UUID.__init__.__name__ == '__init__'. The __qualname__
# of a method includes the enclosing class name, so UUID.__init__.__qualname__
# is 'UUID.__init__' — distinct from __name__ which is simply '__init__'.
# ---------------------------------------------------------------------------

invariant uuid_extra20.UUID_init.qualname:
  description: "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — no prior uuid spec checks UUID.__init__.__qualname__; __qualname__ includes enclosing class"
  category: method_identity
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid factory function __module__ string lengths
#
# uuid_extra18 checks uuid1/3/4/5 __module__.__eq__('uuid') in a table.
# No prior uuid spec checks __module__.__len__() on any factory function.
# All four have __module__ == 'uuid', so len == 4.
# Also checks UUID.__module__.__len__(): extra18 checks UUID.__module__.__eq__;
# no prior spec checks UUID.__module__.__len__().
# ---------------------------------------------------------------------------

table uuid_extra20.function_module_lengths:
  description: "uuid1/uuid3/uuid4/uuid5 and UUID __module__ string lengths — no prior spec checks __module__.__len__() on these"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmodlen20

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__module__.__len__, [], 4]
    - [uuid3, uuid3.__module__.__len__, [], 4]
    - [uuid4, uuid4.__module__.__len__, [], 4]
    - [uuid5, uuid5.__module__.__len__, [], 4]
    - [UUID,  UUID.__module__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__module__
#
# Prior specs (extra15, extra17, extra19) check NAMESPACE constants'
# __class__.__qualname__ and __class__.__name__. No prior uuid spec checks
# __class__.__module__ on any NAMESPACE constant. NAMESPACE_DNS is an instance
# of UUID, which is defined in the 'uuid' module.
# ---------------------------------------------------------------------------

invariant uuid_extra20.NAMESPACE_DNS.class_module:
  description: "uuid.NAMESPACE_DNS.__class__.__module__ == 'uuid' — no prior uuid spec checks __class__.__module__ on any NAMESPACE constant"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__qualname__ string length
#
# uuid_extra5 checks UUID.__qualname__.__eq__('UUID'). uuid_extra19 checks
# UUID.__name__.__len__() == 4. No prior uuid spec checks UUID.__qualname__.__len__().
# For top-level classes __name__ == __qualname__ so the length is also 4.
# ---------------------------------------------------------------------------

invariant uuid_extra20.UUID.qualname_len:
  description: "uuid.UUID.__qualname__.__len__() == 4 — len('UUID') == 4; distinct from __name__.__len__() checked in extra19"
  category: class_identity
  kind: python_call_eq
  function: UUID.__qualname__.__len__
  args: []
  expected: 4
