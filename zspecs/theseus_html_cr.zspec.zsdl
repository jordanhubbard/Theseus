spec: theseus_html_cr
version: ">=3.8"
backend: python_cleanroom(theseus_html_cr)
blocks: html

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/html.html"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py (internal implementation)"
  notes:
    - "Clean-room html module. Do NOT import html."
    - "escape(s): escape HTML special characters."
    - "unescape(s): unescape HTML entities."

error_model: python_exceptions

invariant theseus_html_cr.html2_escape:
  description: "escape('<b>hello & world</b>') escapes < > &"
  category: escape
  kind: python_call_eq
  function: html2_escape
  args: []
  expected: "&lt;b&gt;hello &amp; world&lt;/b&gt;"

invariant theseus_html_cr.html2_unescape:
  description: "unescape reverses escape"
  category: unescape
  kind: python_call_eq
  function: html2_unescape
  args: []
  expected: true

invariant theseus_html_cr.html2_quote_attr:
  description: "escape with quote=True also escapes double quotes"
  category: escape
  kind: python_call_eq
  function: html2_quote_attr
  args: []
  expected: true
