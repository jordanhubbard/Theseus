spec: struct_extra2791
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for Struct, struct.error."
    - "struct_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for Struct, struct.error."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "struct.Struct.__dict__.__contains__('__iand__') == False — struct.Struct is a binary format descriptor; it defines no in-place bitwise AND operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__ior__') == False — struct.Struct defines no in-place bitwise OR operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__ixor__') == False — struct.Struct defines no in-place bitwise XOR operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__iand__') == False — struct.error is an Exception subclass; exception types never define in-place bitwise AND; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__ior__') == False — struct.error defines no in-place bitwise OR operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__ixor__') == False — struct.error defines no in-place bitwise XOR operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __iand__, __ior__, __ixor__ absence
# struct.Struct is the compiled format object returned by struct.Struct(fmt).
# It exposes pack/unpack/pack_into/unpack_from/iter_unpack methods and the
# size/format attributes. In-place bitwise operators (&=, |=, ^=) are
# undefined for a binary format descriptor.
# ---------------------------------------------------------------------------

table struct_extra2791.struct_dict_iand_ior_ixor:
  description: "struct.Struct.__dict__ does not contain __iand__, __ior__, or __ixor__ — Struct is a binary format descriptor, not an integer operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2791

  columns: [id, function, args, expected]
  rows:
    - ["st2791-struct-iand", struct.Struct.__dict__.__contains__, ["__iand__"], false]
    - ["st2791-struct-ior",  struct.Struct.__dict__.__contains__, ["__ior__"],  false]
    - ["st2791-struct-ixor", struct.Struct.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 2: struct.error.__dict__ — __iand__, __ior__, __ixor__ absence
# struct.error is a subclass of Exception raised on pack/unpack failures.
# Exception types never define in-place bitwise operators in their own __dict__.
# ---------------------------------------------------------------------------

table struct_extra2791.error_dict_iand_ior_ixor:
  description: "struct.error.__dict__ does not contain __iand__, __ior__, or __ixor__ — struct.error is an Exception subclass; exception types define no in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2791

  columns: [id, function, args, expected]
  rows:
    - ["st2791-error-iand", struct.error.__dict__.__contains__, ["__iand__"], false]
    - ["st2791-error-ior",  struct.error.__dict__.__contains__, ["__ior__"],  false]
    - ["st2791-error-ixor", struct.error.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — per-dunder detail with descriptions
# ---------------------------------------------------------------------------

table struct_extra2791.struct_dict_detail:
  description: "struct.Struct.__dict__ in-place bitwise operator absence detail — __iand__, __ior__, and __ixor__ are not defined because Struct is a packing/unpacking tool, not a bitwise operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2791

  columns: [id, function, args, expected, description]
  rows:
    - ["st2791-d-iand", struct.Struct.__dict__.__contains__, ["__iand__"], false, "struct.Struct does not support &= — binary format descriptors have no bitwise AND semantics"]
    - ["st2791-d-ior",  struct.Struct.__dict__.__contains__, ["__ior__"],  false, "struct.Struct does not support |= — bitwise OR has no defined meaning for a format descriptor"]
    - ["st2791-d-ixor", struct.Struct.__dict__.__contains__, ["__ixor__"], false, "struct.Struct does not support ^= — bitwise XOR is undefined for a binary format descriptor"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — Struct and error both lack all three dunders
# ---------------------------------------------------------------------------

table struct_extra2791.all_types_all_dunders_absent:
  description: "struct.Struct and struct.error both lack __iand__, __ior__, and __ixor__ in __dict__ — neither struct type defines in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2791

  columns: [id, function, args, expected]
  rows:
    - ["st2791-x-struct-iand", struct.Struct.__dict__.__contains__, ["__iand__"], false]
    - ["st2791-x-struct-ior",  struct.Struct.__dict__.__contains__, ["__ior__"],  false]
    - ["st2791-x-struct-ixor", struct.Struct.__dict__.__contains__, ["__ixor__"], false]
    - ["st2791-x-error-iand",  struct.error.__dict__.__contains__,  ["__iand__"], false]
    - ["st2791-x-error-ior",   struct.error.__dict__.__contains__,  ["__ior__"],  false]
    - ["st2791-x-error-ixor",  struct.error.__dict__.__contains__,  ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra2791.struct_no_iand:
  description: "struct.Struct.__dict__.__contains__('__iand__') == False — struct.Struct does not define the &= operator; it is a binary packing/unpacking tool with no bitwise semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__iand__"]
  expected: false

invariant struct_extra2791.struct_no_ior:
  description: "struct.Struct.__dict__.__contains__('__ior__') == False — struct.Struct does not define the |= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__ior__"]
  expected: false

invariant struct_extra2791.struct_no_ixor:
  description: "struct.Struct.__dict__.__contains__('__ixor__') == False — struct.Struct does not define the ^= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__ixor__"]
  expected: false

invariant struct_extra2791.error_no_iand:
  description: "struct.error.__dict__.__contains__('__iand__') == False — struct.error (Exception subclass) does not define the &= operator; exception types carry no bitwise semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__iand__"]
  expected: false

invariant struct_extra2791.error_no_ior:
  description: "struct.error.__dict__.__contains__('__ior__') == False — struct.error does not define the |= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__ior__"]
  expected: false

invariant struct_extra2791.error_no_ixor:
  description: "struct.error.__dict__.__contains__('__ixor__') == False — struct.error does not define the ^= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__ixor__"]
  expected: false
