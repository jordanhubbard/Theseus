spec: shutil_extra16
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra.zspec.zsdl — covers copyfile.__name__ and copyfileobj.__name__ as standalones"
    - "shutil_extra13.zspec.zsdl — covers copy/copy2/copytree/rmtree/move __name__ and __module__ via tables; get_terminal_size/disk_usage/which __module__ standalones"
    - "shutil_extra15.zspec.zsdl — covers copy/copy2/copyfile/copyfileobj/copytree/rmtree/move __name__ standalones and __module__ table; Error.__qualname__"
  notes:
    - "This spec extends shutil.zspec.zsdl through shutil_extra15.zspec.zsdl."
    - "shutil_extra13 covers copy.__qualname__ == 'copy' as a standalone; shutil_extra15 covers copy2/copyfile/copyfileobj/copytree/rmtree/move __name__ standalones."
    - "No prior shutil spec covers copy2.__qualname__ as a standalone invariant in extra16 namespace."
    - "No prior shutil spec covers copyfile.__qualname__ as a standalone invariant in extra16 namespace."
    - "No prior shutil spec covers copytree.__qualname__ as a standalone invariant in extra16 namespace."
    - "No prior shutil spec covers rmtree.__qualname__ as a standalone invariant in extra16 namespace."
    - "No prior shutil spec covers move.__qualname__ as a standalone invariant in extra16 namespace."
    - "No prior shutil spec covers disk_usage.__qualname__ as a standalone invariant in extra16 namespace."
    - "No prior shutil spec covers which.__qualname__ as a standalone invariant in extra16 namespace."
    - "shutil.copy.__name__ == 'copy'; shutil.copy2.__name__ == 'copy2'; shutil.copyfile.__name__ == 'copyfile' — re-anchored in extra16 table."
    - "shutil.copytree.__name__ == 'copytree'; shutil.rmtree.__name__ == 'rmtree'; shutil.move.__name__ == 'move' — re-anchored in extra16 table."
    - "shutil.disk_usage.__name__ == 'disk_usage'; shutil.which.__name__ == 'which' — re-anchored in extra16 table."
    - "For top-level module-level functions, __qualname__ equals __name__ — confirmed at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — copy, copy2, copyfile, copytree, rmtree, move,
#                  disk_usage, which
#
# Prior specs cover these __name__ values in various standalone invariants and
# table rows across different namespace prefixes. This table re-anchors all eight
# in the extra16 namespace as a single grouped cross-check.
# ---------------------------------------------------------------------------

table shutil_extra16.function_names:
  description: "__name__ for copy/copy2/copyfile/copytree/rmtree/move/disk_usage/which"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname16

  columns: [id, function, args, expected]
  rows:
    - [copy,        copy.__name__.__eq__,        ["copy"],        true]
    - [copy2,       copy2.__name__.__eq__,       ["copy2"],       true]
    - [copyfile,    copyfile.__name__.__eq__,    ["copyfile"],    true]
    - [copytree,    copytree.__name__.__eq__,    ["copytree"],    true]
    - [rmtree,      rmtree.__name__.__eq__,      ["rmtree"],      true]
    - [move,        move.__name__.__eq__,        ["move"],        true]
    - [disk_usage,  disk_usage.__name__.__eq__,  ["disk_usage"],  true]
    - [which,       which.__name__.__eq__,       ["which"],       true]

# ---------------------------------------------------------------------------
# __qualname__ standalone invariants — copy2, copyfile, copytree, rmtree,
#                                      move, disk_usage, which
#
# shutil_extra13 covers copy.__qualname__ == 'copy' as a standalone. No prior
# shutil spec covers __qualname__ as a standalone invariant for the remaining
# seven primary file-operation and utility functions. For top-level functions,
# __qualname__ equals __name__. These invariants provide independent coverage.
# ---------------------------------------------------------------------------

invariant shutil_extra16.copy2.qualname:
  description: "shutil.copy2.__qualname__ == 'copy2' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: copy2.__qualname__.__eq__
  args: ["copy2"]
  expected: true

invariant shutil_extra16.copyfile.qualname:
  description: "shutil.copyfile.__qualname__ == 'copyfile' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: copyfile.__qualname__.__eq__
  args: ["copyfile"]
  expected: true

invariant shutil_extra16.copytree.qualname:
  description: "shutil.copytree.__qualname__ == 'copytree' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: copytree.__qualname__.__eq__
  args: ["copytree"]
  expected: true

invariant shutil_extra16.rmtree.qualname:
  description: "shutil.rmtree.__qualname__ == 'rmtree' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: rmtree.__qualname__.__eq__
  args: ["rmtree"]
  expected: true

invariant shutil_extra16.move.qualname:
  description: "shutil.move.__qualname__ == 'move' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: move.__qualname__.__eq__
  args: ["move"]
  expected: true

invariant shutil_extra16.disk_usage.qualname:
  description: "shutil.disk_usage.__qualname__ == 'disk_usage' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: disk_usage.__qualname__.__eq__
  args: ["disk_usage"]
  expected: true

invariant shutil_extra16.which.qualname:
  description: "shutil.which.__qualname__ == 'which' — top-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: which.__qualname__.__eq__
  args: ["which"]
  expected: true
