error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_alphabetical.isAlphabetical:
  kind: node_module_call_eq
  function: isAlphabetical
  category: predicate
  id_prefix: isalpha

  columns: [id, args, expected]
  rows:
    - [lower_a,   ["a"],  true]
    - [upper_Z,   ["Z"],  true]
    - [digit,     ["1"],  false]
    - [space,     [" "],  false]
    - [symbol,    ["!"],  false]

