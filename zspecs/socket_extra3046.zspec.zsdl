spec: sk3046
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (sk3046): __enter__, __exit__, __aenter__ dict-presence checks for socket types."
    - "socket.socket IS a context manager: it defines both __enter__ and __exit__ in its own __dict__, allowing use in 'with' statements for automatic close() on exit. Verified on Python 3.14.4."
    - "socket.socket does NOT define __aenter__ — it supports synchronous context management only, not async context management."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses — they define neither __enter__, __exit__, nor __aenter__ in their own __dict__."
    - "type(socket.socket()) is identical to socket.socket — verified on Python 3.14.4."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3046.enter:
  description: "socket types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk3046
  columns: [id, function, args, expected]
  rows:
    - ["sk3046001", operator.contains, [socket.socket.__dict__,         "__enter__"], true]
    - ["sk3046002", operator.contains, [socket.AddressFamily.__dict__,  "__enter__"], false]
    - ["sk3046003", operator.contains, [socket.SocketKind.__dict__,     "__enter__"], false]
    - ["sk3046004", operator.contains, [type(socket.socket()).__dict__, "__enter__"], true]

