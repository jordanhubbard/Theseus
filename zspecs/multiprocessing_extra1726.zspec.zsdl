spec: multiprocessing_extra1726
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "Theme: which multiprocessing stdlib types define __lt__, __le__, __gt__, __ge__, __ne__ in their own __dict__."
    - "multiprocessing.Process: pure Python class representing a spawnable process; no ordering operators defined in own __dict__ -> all False."
    - "multiprocessing.process.BaseProcess: root of the process class hierarchy; no comparison operators in own __dict__ -> all False."
    - "multiprocessing.Pool: worker pool manager; no comparison operators in own __dict__ -> all False."
    - "Rationale: process objects represent execution contexts, not values; ordering them has no meaning."
    - "Cross-check: __eq__ is absent from Process and BaseProcess own __dict__ (inherited from object — identity comparison). __hash__ also inherited -> all False."
    - "Cross-check: Pool.__dict__ also does not contain __eq__ or __hash__ -> False."
    - "multiprocessing.pool.Pool.__dict__ is the same class as multiprocessing.Pool; the Pool class defines no comparison dunders."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: comparison operator dict-presence checks (__lt__, __le__, __gt__, __ge__, __ne__)
#
# Wave 562 theme: do multiprocessing types define ordering/comparison dunders
# in their own __dict__? Process objects represent OS-level subprocesses and
# carry no ordering semantics. BaseProcess is the abstract root of all process
# types and likewise defines no comparison operators. Pool manages a pool of
# worker processes and has no meaningful ordering either. All checks return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra1726.comparison_protocol:
  description: "multiprocessing types: __lt__, __le__, __gt__, __ge__, __ne__ dict-presence checks (all False — no ordering semantics)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1726

  columns: [id, function, args, expected]
  rows:
    - ["mp1726001", "multiprocessing.Process.__dict__.__contains__",             ["__lt__"], false]
    - ["mp1726002", "multiprocessing.Process.__dict__.__contains__",             ["__le__"], false]
    - ["mp1726003", "multiprocessing.Process.__dict__.__contains__",             ["__gt__"], false]
    - ["mp1726004", "multiprocessing.Process.__dict__.__contains__",             ["__ge__"], false]
    - ["mp1726005", "multiprocessing.Process.__dict__.__contains__",             ["__ne__"], false]
    - ["mp1726006", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__lt__"], false]
    - ["mp1726007", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__le__"], false]
    - ["mp1726008", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__gt__"], false]
    - ["mp1726009", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__ge__"], false]
    - ["mp1726010", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__ne__"], false]

# ---------------------------------------------------------------------------
# Table 2: __eq__ and __hash__ dict-presence cross-checks
#
# Wave 562 cross-check: multiprocessing types do not override __eq__ or
# __hash__ in their own __dict__. Process identity (are these the same
# process object?) is the only meaningful equality, so the default
# object.__eq__ (identity comparison) is used. Similarly __hash__ is
# inherited from object. Pool also relies on object identity for equality.
# None of these types define __eq__ or __hash__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1726.eq_hash_protocol:
  description: "multiprocessing types: __eq__ and __hash__ dict-presence cross-check (all inherited from object — not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1726

  columns: [id, function, args, expected]
  rows:
    - ["mp1726011", "multiprocessing.Process.__dict__.__contains__",             ["__eq__"],   false]
    - ["mp1726012", "multiprocessing.Process.__dict__.__contains__",             ["__hash__"], false]
    - ["mp1726013", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__eq__"],   false]
    - ["mp1726014", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__hash__"], false]
    - ["mp1726015", "multiprocessing.Pool.__dict__.__contains__",                ["__eq__"],   false]
    - ["mp1726016", "multiprocessing.Pool.__dict__.__contains__",                ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 3: ordering operators for multiprocessing.Pool and extended cross-checks
#
# Wave 562 extension: extend the comparison/ordering protocol checks to
# multiprocessing.Pool and add __ne__ cross-checks for BaseProcess and Pool.
# Pool manages a set of worker processes. It has no meaningful ordering
# relationship with other Pool instances. Cross-checks confirm that __ne__
# is also absent from Pool.__dict__ and BaseProcess.__dict__. The complete
# picture: no multiprocessing type defines any of the six comparison dunders
# (__lt__, __le__, __gt__, __ge__, __ne__, __eq__) in its own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1726.pool_comparison_protocol:
  description: "multiprocessing.Pool and BaseProcess: ordering operator dict-presence and extended cross-checks (all False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1726

  columns: [id, function, args, expected]
  rows:
    - ["mp1726017", "multiprocessing.Pool.__dict__.__contains__", ["__lt__"], false]
    - ["mp1726018", "multiprocessing.Pool.__dict__.__contains__", ["__le__"], false]
    - ["mp1726019", "multiprocessing.Pool.__dict__.__contains__", ["__gt__"], false]
    - ["mp1726020", "multiprocessing.Pool.__dict__.__contains__", ["__ge__"], false]
    - ["mp1726021", "multiprocessing.Pool.__dict__.__contains__", ["__ne__"], false]
    - ["mp1726022", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__lt__"], false]
    - ["mp1726023", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__gt__"], false]
    - ["mp1726024", "multiprocessing.Process.__dict__.__contains__",             ["__lt__"], false]
    - ["mp1726025", "multiprocessing.Process.__dict__.__contains__",             ["__gt__"], false]
