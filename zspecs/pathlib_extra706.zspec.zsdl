spec: pathlib_extra706
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers pathlib.Path stat, glob, iterdir, resolve, expanduser, symlink_to, hardlink_to, touch, rmdir, chmod method identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra706.method_identity:
  description: "Identity checks for pathlib.Path stat/glob/iterdir and related method qualnames"
  kind: python_call_eq
  category: method_identity
  id_prefix: pl706mi
  columns: [id, function, args, expected]
  rows:
    - [pl706mi001, pathlib.Path.stat.__qualname__.__eq__, ["Path.stat"], true]
    - [pl706mi002, pathlib.Path.stat.__module__.__eq__, ["pathlib"], true]
    - [pl706mi003, pathlib.Path.glob.__qualname__.__eq__, ["Path.glob"], true]
    - [pl706mi004, pathlib.Path.rglob.__qualname__.__eq__, ["Path.rglob"], true]
    - [pl706mi005, pathlib.Path.iterdir.__qualname__.__eq__, ["Path.iterdir"], true]
    - [pl706mi006, pathlib.Path.resolve.__qualname__.__eq__, ["Path.resolve"], true]
    - [pl706mi007, pathlib.Path.expanduser.__qualname__.__eq__, ["Path.expanduser"], true]
    - [pl706mi008, pathlib.Path.symlink_to.__qualname__.__eq__, ["Path.symlink_to"], true]
    - [pl706mi009, pathlib.Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"], true]
    - [pl706mi010, pathlib.Path.touch.__qualname__.__eq__, ["Path.touch"], true]
    - [pl706mi011, pathlib.Path.rmdir.__qualname__.__eq__, ["Path.rmdir"], true]
    - [pl706mi012, pathlib.Path.chmod.__qualname__.__eq__, ["Path.chmod"], true]
