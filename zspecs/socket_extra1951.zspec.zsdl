spec: socket_extra1951
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket is a Python class wrapping the C-level socket type; its __dict__ contains no __contains__, __iter__, __next__, __aiter__, or __anext__."
    - "socket.error, socket.timeout, and socket.gaierror are exception subclasses; none define iteration dunders in their own __dict__."
    - "socket.socket objects are not iterable — no __iter__ is defined on the class."
    - "There is no async iteration support in any socket module class — __aiter__ and __anext__ are absent from all class dicts."
    - "socket.herror and socket.timeout are aliases/subclasses of OSError; none add iteration methods."
  created_at: "2026-04-12"
error_model: python_exceptions

table socket_extra1951.contains_protocol:
  description: "socket types __contains__ dict-presence — none define __contains__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1951

  columns: [id, function, args, expected]
  rows:
    - ["sk1951001", "socket.socket.__dict__.__contains__",   ["__contains__"], false]
    - ["sk1951002", "socket.error.__dict__.__contains__",    ["__contains__"], false]
    - ["sk1951003", "socket.timeout.__dict__.__contains__",  ["__contains__"], false]
    - ["sk1951004", "socket.gaierror.__dict__.__contains__", ["__contains__"], false]
    - ["sk1951005", "socket.herror.__dict__.__contains__",   ["__contains__"], false]

