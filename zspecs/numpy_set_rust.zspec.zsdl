spec: numpy_set_rust
version: ">=3.9"
backend: rust_module(numpy_set_rust)

docs: https://numpy.org/doc/stable/reference/routines.set.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/routines.set.html — NumPy set routines documentation"
  not_derived_from:
    - "NumPy source: numpy/lib/arraysetops.py"
  notes:
    - "numpy set operations on 1D arrays, returning sorted lists."
    - "intersect1d(a, b) returns sorted unique elements in both a and b."
    - "intersect1d([1,2,3,4],[2,4,6,8]) == [2, 4]."
    - "union1d(a, b) returns sorted unique elements in either a or b."
    - "union1d([1,2,3],[2,3,4]) == [1, 2, 3, 4]."
    - "setdiff1d(a, b) returns sorted unique elements in a but not in b."
    - "setdiff1d([1,2,3,4],[2,4]) == [1, 3]."
    - "isin(element, test_elements) returns boolean array, same shape as element."
    - "isin([1,2,3,4],[2,4]) == [False, True, False, True]."
    - "All functions return lists for ease of testing."
    - "All test vectors verified against numpy 2.2.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# intersect1d — sorted intersection of two arrays
table numpy_set_rust.intersect1d.vectors:
  kind: python_call_eq
  category: intersect1d
  id_prefix: ns_i1
  function: intersect1d

  columns: [id, args, expected]
  rows:
    - [even_odd,   [[1, 2, 3, 4], [2, 4, 6, 8]], [2, 4]]
    - [no_overlap, [[1, 3, 5], [2, 4, 6]],        []]
    - [identical,  [[1, 2, 3], [1, 2, 3]],         [1, 2, 3]]
    - [subset,     [[1, 2, 3, 4, 5], [2, 4]],      [2, 4]]

# union1d — sorted union of two arrays
table numpy_set_rust.union1d.vectors:
  kind: python_call_eq
  category: union1d
  id_prefix: ns_u1
  function: union1d

  columns: [id, args, expected]
  rows:
    - [disjoint,  [[1, 2, 3], [4, 5, 6]],         [1, 2, 3, 4, 5, 6]]
    - [overlap,   [[1, 2, 3], [2, 3, 4]],          [1, 2, 3, 4]]
    - [identical, [[1, 2, 3], [1, 2, 3]],           [1, 2, 3]]
    - [one_empty, [[1, 3, 5], []],                  [1, 3, 5]]

# setdiff1d — sorted elements in a but not b
table numpy_set_rust.setdiff1d.vectors:
  kind: python_call_eq
  category: setdiff1d
  id_prefix: ns_sd
  function: setdiff1d

  columns: [id, args, expected]
  rows:
    - [partial,   [[1, 2, 3, 4], [2, 4]],          [1, 3]]
    - [no_remove, [[1, 2, 3], [4, 5, 6]],           [1, 2, 3]]
    - [all_remove, [[1, 2, 3], [1, 2, 3]],          []]
    - [single,    [[5, 10, 15], [10]],               [5, 15]]

# isin — membership test returning boolean list
table numpy_set_rust.isin.vectors:
  kind: python_call_eq
  category: isin
  id_prefix: ns_in
  function: isin

  columns: [id, args, expected]
  rows:
    - [mixed,    [[1, 2, 3, 4], [2, 4]],            [false, true, false, true]]
    - [all_in,   [[1, 2, 3], [1, 2, 3, 4]],          [true, true, true]]
    - [none_in,  [[5, 6, 7], [1, 2, 3]],             [false, false, false]]
    - [single,   [[3], [1, 2, 3]],                   [true]]

