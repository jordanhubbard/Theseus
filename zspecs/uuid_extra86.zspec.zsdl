spec: uuid_extra86
version: ">=3.9"
extends: uuid_extra85
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra85.zspec.zsdl — covers uuid.UUID/__dict__ membership for dunder methods (__init__/__setattr__/__repr__/__str__/__hash__/__int__/__eq__/__lt__) and property names (hex/bytes/bytes_le/fields/time_low/urn/variant/version/is_safe) / UUID and SafeUUID __dict__ class names (table + invariants)."
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ / SafeUUID class identity / uuid namespace and reserved constant class names (table + invariants)."
    - "uuid_extra83.zspec.zsdl — covers UUID dunder method __qualname__ lengths / UUID string and numeric property fget __qualname__ lengths / module-level uuid function qualname equality (table + invariants)."
    - "uuid_extra82.zspec.zsdl — covers uuid.SafeUUID enum member class identity / uuid module identity (__name__/__package__/__spec__/__loader__) (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra85; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: uuid.UUID.__init__ code attrs (co_name, co_argcount, __qualname__) + uuid module-level function __qualname__ and __module__ values."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_name == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__qualname__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__qualname__ == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_name.__eq__('__init__')
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7)
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
#
# Wave 257 theme: UUID.__init__ code attributes.
#
# UUID.__init__ is a Python function (not a C slot). Its __code__.co_name is
# '__init__', co_argcount is 7 (self + hex + bytes + bytes_le + fields + int +
# version + is_safe — the UUID constructor has many optional params counted by
# co_argcount as defined positional+keyword args without defaults subtracted).
# Its __qualname__ is 'UUID.__init__'. No prior uuid spec anchors these three
# code attrs together under uuidfnattrs86. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra86.uuid_UUID_init_code_attrs:
  description: "uuid.UUID/__init__/__code__/co_name.__eq__('__init__')==True / co_argcount.__eq__(7)==True / __qualname__.__eq__('UUID.__init__')==True — UUID.__init__ is a Python function; co_name=='__init__', co_argcount==7 (self + hex + bytes + bytes_le + fields + int + version + is_safe), __qualname__=='UUID.__init__'; no prior uuid spec anchors these three code attrs together; first uuidfnattrs86 anchor for UUID.__init__ code attributes"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfnattrs86

  columns: [id, function, args, expected]
  rows:
    - [init_co_name,    "UUID.__init__.__code__.co_name.__eq__",    ["__init__"],    true]
    - [init_co_argcount, "UUID.__init__.__code__.co_argcount.__eq__", [7],           true]
    - [init_qualname,   "UUID.__init__.__qualname__.__eq__",        ["UUID.__init__"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1.__qualname__.__eq__('uuid1')
# uuid.uuid1.__module__.__eq__('uuid')
# uuid.uuid1.__code__.co_argcount.__eq__(2)
# uuid.uuid4.__qualname__.__eq__('uuid4')
# uuid.uuid4.__code__.co_argcount.__eq__(0)
#
# Wave 257 theme: uuid1 and uuid4 function attrs.
#
# uuid1 generates a UUID from a host ID and sequence number; it takes 2
# positional args (node, clock_seq), so co_argcount==2. uuid4 generates a
# random UUID with no required arguments, so co_argcount==0. Both have
# __qualname__ equal to their own function name and __module__=='uuid'.
# No prior uuid spec anchors co_argcount for uuid1/uuid4 under uuidfnattrs86.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra86.uuid1_uuid4_attrs:
  description: "uuid.uuid1/__qualname__.__eq__('uuid1')==True / uuid1/__module__.__eq__('uuid')==True / uuid1/__code__/co_argcount.__eq__(2)==True / uuid4/__qualname__.__eq__('uuid4')==True / uuid4/__code__/co_argcount.__eq__(0)==True — uuid1 takes node+clock_seq (co_argcount==2); uuid4 takes no args (co_argcount==0); both have __qualname__ equal to their name and __module__=='uuid'; no prior uuid spec anchors co_argcount for uuid1/uuid4; first uuidfnattrs86 anchor for uuid1/uuid4 function attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfnattrs86

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname,     uuid1.__qualname__.__eq__,           ["uuid1"], true]
    - [uuid1_module,       uuid1.__module__.__eq__,             ["uuid"],  true]
    - [uuid1_co_argcount,  uuid1.__code__.co_argcount.__eq__,   [2],       true]
    - [uuid4_qualname,     uuid4.__qualname__.__eq__,           ["uuid4"], true]
    - [uuid4_co_argcount,  uuid4.__code__.co_argcount.__eq__,   [0],       true]

# ---------------------------------------------------------------------------
# uuid.uuid3.__qualname__.__eq__('uuid3')
# uuid.uuid3.__module__.__eq__('uuid')
# uuid.uuid3.__code__.co_argcount.__eq__(2)
# uuid.uuid5.__qualname__.__eq__('uuid5')
# uuid.uuid5.__module__.__eq__('uuid')
# uuid.uuid5.__code__.co_argcount.__eq__(2)
# uuid.getnode.__qualname__.__eq__('getnode')
# uuid.getnode.__code__.co_argcount.__eq__(0)
#
# Wave 257 theme: uuid3, uuid5, and getnode function attrs.
#
# uuid3 and uuid5 each generate a UUID from a namespace UUID and a name string;
# both take 2 positional args (namespace, name), so co_argcount==2. getnode
# returns the hardware address as an integer and takes no args (co_argcount==0).
# All have __qualname__ equal to their own function name. No prior uuid spec
# anchors co_argcount for uuid3/uuid5/getnode under uuidfnattrs86.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra86.uuid3_uuid5_getnode_attrs:
  description: "uuid.uuid3/__qualname__.__eq__('uuid3')==True / uuid3/__module__.__eq__('uuid')==True / uuid3/__code__/co_argcount.__eq__(2)==True / uuid5/__qualname__.__eq__('uuid5')==True / uuid5/__module__.__eq__('uuid')==True / uuid5/__code__/co_argcount.__eq__(2)==True / getnode/__qualname__.__eq__('getnode')==True / getnode/__code__/co_argcount.__eq__(0)==True — uuid3/uuid5 take namespace+name (co_argcount==2); getnode takes no args (co_argcount==0); all have __qualname__ equal to their name; first uuidfnattrs86 anchor for uuid3/uuid5/getnode function attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfnattrs86

  columns: [id, function, args, expected]
  rows:
    - [uuid3_qualname,    uuid3.__qualname__.__eq__,          ["uuid3"],   true]
    - [uuid3_module,      uuid3.__module__.__eq__,            ["uuid"],    true]
    - [uuid3_co_argcount, uuid3.__code__.co_argcount.__eq__,  [2],         true]
    - [uuid5_qualname,    uuid5.__qualname__.__eq__,          ["uuid5"],   true]
    - [uuid5_module,      uuid5.__module__.__eq__,            ["uuid"],    true]
    - [uuid5_co_argcount, uuid5.__code__.co_argcount.__eq__,  [2],         true]
    - [getnode_qualname,  getnode.__qualname__.__eq__,        ["getnode"], true]
    - [getnode_co_argcount, getnode.__code__.co_argcount.__eq__, [0],      true]

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid')
# uuid.uuid3.__module__.__eq__('uuid')
# uuid.uuid4.__module__.__eq__('uuid')
# uuid.uuid5.__module__.__eq__('uuid')
#
# Wave 257 theme: all four uuid generation functions __module__ == 'uuid'.
#
# uuid1, uuid3, uuid4, and uuid5 are all defined in Lib/uuid.py and have
# __module__ == 'uuid'. This table groups all four __module__ equality checks
# together as a cross-check under uuidfnattrs86. Prior tables first anchor
# these individually; this table cross-checks them all together.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra86.uuid_fn_module_eq_xchk:
  description: "uuid.uuid1/__module__.__eq__('uuid')==True / uuid3/__module__.__eq__('uuid')==True / uuid4/__module__.__eq__('uuid')==True / uuid5/__module__.__eq__('uuid')==True — all four UUID generation functions are defined in Lib/uuid.py and have __module__=='uuid'; prior tables first anchor these individually; this table cross-checks all four __module__ values together under uuidfnattrs86; first uuidfnattrs86 cross-check for all four uuid function __module__ values"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfnattrs86

  columns: [id, function, args, expected]
  rows:
    - [uuid1_module_xchk, uuid1.__module__.__eq__, ["uuid"], true]
    - [uuid3_module_xchk, uuid3.__module__.__eq__, ["uuid"], true]
    - [uuid4_module_xchk, uuid4.__module__.__eq__, ["uuid"], true]
    - [uuid5_module_xchk, uuid5.__module__.__eq__, ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_name.__eq__('__init__') — standalone
#
# uuid.UUID.__init__.__code__.co_name is '__init__'. UUID.__init__ is a
# pure-Python function; its code object records the function name in co_name.
# No prior uuid spec anchors UUID.__init__.__code__.co_name.__eq__ as a
# standalone under uuidfnattrs86. First standalone for UUID.__init__ co_name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra86.init_co_name:
  description: "uuid.UUID.__init__.__code__.co_name.__eq__('__init__') == True — UUID.__init__ is a pure-Python function; its code object records the function name in co_name as '__init__'; no prior uuid spec anchors this as a standalone; first standalone for UUID.__init__ co_name under uuidfnattrs86"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_name.__eq__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7) — standalone
#
# uuid.UUID.__init__.__code__.co_argcount is 7. The UUID constructor signature
# is __init__(self, hex=None, bytes=None, bytes_le=None, fields=None, int=None,
# version=None, *, is_safe=SafeUUID.unknown): co_argcount counts 7 positional-
# or-keyword parameters (self, hex, bytes, bytes_le, fields, int, version).
# No prior uuid spec anchors this as a standalone under uuidfnattrs86.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra86.init_co_argcount:
  description: "uuid.UUID.__init__.__code__.co_argcount.__eq__(7) == True — UUID.__init__ has co_argcount==7: self + hex + bytes + bytes_le + fields + int + version (is_safe is keyword-only, not counted in co_argcount); no prior uuid spec anchors this as a standalone; first standalone for UUID.__init__ co_argcount under uuidfnattrs86"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_argcount.__eq__"
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_argcount.__eq__(0) — standalone
#
# uuid.uuid4.__code__.co_argcount is 0. uuid4() generates a random UUID and
# takes no arguments — it is a zero-argument function. This distinguishes uuid4
# from uuid1, uuid3, and uuid5 which each accept arguments. No prior uuid spec
# anchors uuid4.__code__.co_argcount.__eq__(0) as a standalone under uuidfnattrs86.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra86.uuid4_co_argcount:
  description: "uuid.uuid4.__code__.co_argcount.__eq__(0) == True — uuid4() takes no arguments (generates a random UUID); co_argcount==0 distinguishes it from uuid1/uuid3/uuid5 which accept parameters; no prior uuid spec anchors this as a standalone; first standalone for uuid4 co_argcount under uuidfnattrs86"
  category: type_identity
  kind: python_call_eq
  function: uuid4.__code__.co_argcount.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3.__code__.co_argcount.__eq__(2) — standalone
#
# uuid.uuid3.__code__.co_argcount is 2. uuid3(namespace, name) generates a
# UUID using MD5 from a namespace UUID and a name string; it takes exactly 2
# positional arguments. No prior uuid spec anchors uuid3.__code__.co_argcount
# as a standalone under uuidfnattrs86. First standalone for uuid3 co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra86.uuid3_co_argcount:
  description: "uuid.uuid3.__code__.co_argcount.__eq__(2) == True — uuid3(namespace, name) generates a UUID using MD5 from a namespace and name; co_argcount==2 (namespace + name); no prior uuid spec anchors this as a standalone; first standalone for uuid3 co_argcount under uuidfnattrs86"
  category: type_identity
  kind: python_call_eq
  function: uuid3.__code__.co_argcount.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# uuid.getnode.__qualname__.__eq__('getnode') — standalone
#
# uuid.getnode.__qualname__ is 'getnode'. getnode() returns the hardware
# address (MAC address) as a 48-bit positive integer. It is a module-level
# function with __qualname__ equal to its own name. No prior uuid spec anchors
# getnode.__qualname__.__eq__ as a standalone under uuidfnattrs86.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra86.getnode_qualname:
  description: "uuid.getnode.__qualname__.__eq__('getnode') == True — getnode() returns the hardware (MAC) address as a 48-bit positive integer; its __qualname__ is 'getnode' (a top-level module function); no prior uuid spec anchors this as a standalone; first standalone for uuid.getnode __qualname__ under uuidfnattrs86"
  category: type_identity
  kind: python_call_eq
  function: getnode.__qualname__.__eq__
  args: ["getnode"]
  expected: true
