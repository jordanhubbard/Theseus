spec: itertools_extra39
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra38.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all; __dict__.__class__.__name__.__len__()==12 for all; chain.from_iterable.__name__.__len__()==13; __doc__ lengths for all major types; list(repeat(7, 3))==[7,7,7]; next(dropwhile(...)) behavioral."
    - "This spec covers: groupby.__name__ == 'groupby'; groupby.__qualname__ == 'groupby'; compress.__name__ == 'compress'; compress.__qualname__ == 'compress'; dropwhile.__name__ == 'dropwhile'; takewhile.__name__ == 'takewhile'; starmap.__name__ == 'starmap'; filterfalse.__name__ == 'filterfalse'; __name__.__len__() for each: groupby(7), compress(8), dropwhile(9), takewhile(9), starmap(7), filterfalse(11)."
    - "Key findings: itertools.groupby.__name__ and __qualname__ are both 'groupby' (7 chars) — for all itertools C-extension types, __qualname__ == __name__ because they are top-level types with no enclosing class. itertools.starmap.__name__ is 'starmap' (7 chars) — same length as groupby, forming a pair at length 7. itertools.compress.__name__ is 'compress' (8 chars). itertools.dropwhile.__name__ and itertools.takewhile.__name__ are both 'dropwhile'/'takewhile' (9 chars each) — same length because these companion filtering types have equally long names. itertools.filterfalse.__name__ is 'filterfalse' (11 chars) — the longest __name__ among all itertools filtering types. No prior itertools spec records these string equality invariants or __name__.__len__() values in the extra39 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.groupby identity metadata — extra39 namespace
#
# itertools.groupby.__name__ is 'groupby' and itertools.groupby.__qualname__ is
# 'groupby' — both 7 chars. For all itertools C-extension types, __qualname__
# equals __name__ because they are top-level type definitions with no enclosing
# class scope. Prior specs recorded groupby.__qualname__.__len__()==7 but not
# the string equality invariants for __name__ and __qualname__. No prior itertools
# spec records these equality invariants for groupby in the extra39 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra39.groupby_name:
  description: "itertools.groupby.__name__ == 'groupby' — C-extension type; unqualified name; 7 chars"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra39.groupby_qualname:
  description: "itertools.groupby.__qualname__ == 'groupby' — top-level C type; __qualname__ == __name__ (no enclosing class scope)"
  category: identity
  kind: python_call_eq
  function: groupby.__qualname__.__eq__
  args: ["groupby"]
  expected: true

# ---------------------------------------------------------------------------
# itertools.compress identity metadata — extra39 namespace
#
# itertools.compress.__name__ is 'compress' and itertools.compress.__qualname__
# is 'compress' — both 8 chars. Prior specs recorded compress.__qualname__.__len__
# ()==8 but not the string equality invariants. No prior itertools spec records
# these equality invariants for compress in the extra39 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra39.compress_name:
  description: "itertools.compress.__name__ == 'compress' — C-extension type; 8-char name; selects elements where selector is true"
  category: identity
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant itertools_extra39.compress_qualname:
  description: "itertools.compress.__qualname__ == 'compress' — top-level C type; __qualname__ == __name__; 8 chars"
  category: identity
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

# ---------------------------------------------------------------------------
# itertools filtering type __name__ string equality — extra39 namespace
#
# itertools.dropwhile.__name__ is 'dropwhile' (9 chars) and itertools.takewhile.
# __name__ is 'takewhile' (9 chars) — the same length because these two
# complementary filtering types have equally long names. itertools.starmap.
# __name__ is 'starmap' (7 chars) — the same length as groupby. itertools.
# filterfalse.__name__ is 'filterfalse' (11 chars) — the longest __name__ among
# all itertools filtering types. No prior itertools spec records these four
# string equality invariants in the extra39 namespace.
# ---------------------------------------------------------------------------

table itertools_extra39.filtering_type_names:
  description: "itertools filtering C-type __name__ string equality: dropwhile('dropwhile'), takewhile('takewhile'), starmap('starmap'), filterfalse('filterfalse')"
  kind: python_call_eq
  category: identity
  id_prefix: filtername39

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_name,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__ == 'dropwhile' — C-extension type; 9-char name; drops elements while predicate is true then yields all remaining"]
    - [takewhile_name,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__ == 'takewhile' — C-extension type; 9-char name; same length as dropwhile; yields elements while predicate is true then stops"]
    - [starmap_name,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__ == 'starmap' — C-extension type; 7-char name; same length as groupby; applies function to argument tuples from iterable"]
    - [filterfalse_name,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__ == 'filterfalse' — C-extension type; 11-char name; longest filtering-type __name__; complement of builtin filter"]

# ---------------------------------------------------------------------------
# itertools type __name__.__len__() values — extra39 namespace
#
# The __name__ lengths for the 6 types covered in this spec are:
# groupby(7), starmap(7), compress(8), dropwhile(9), takewhile(9), filterfalse(11).
# groupby and starmap share length 7; dropwhile and takewhile share length 9.
# These __len__() values are distinct from the __qualname__.__len__() values
# recorded in prior specs — the values happen to be identical because
# __qualname__ == __name__ for all top-level C types, but the prior specs
# recorded __qualname__.__len__(), not __name__.__len__(). No prior itertools
# spec records __name__.__len__() for groupby, compress, dropwhile, takewhile,
# starmap, or filterfalse in the extra39 namespace.
# ---------------------------------------------------------------------------

table itertools_extra39.type_name_lengths:
  description: "itertools C-type __name__.__len__(): groupby(7), starmap(7), compress(8), dropwhile(9), takewhile(9), filterfalse(11)"
  kind: python_call_eq
  category: string_properties
  id_prefix: namelen39

  columns: [id, function, args, expected, description]
  rows:
    - [groupby,
       groupby.__name__.__len__,
       [],
       7,
       "len(itertools.groupby.__name__) == 7 — 'groupby'; same length as starmap"]
    - [starmap,
       starmap.__name__.__len__,
       [],
       7,
       "len(itertools.starmap.__name__) == 7 — 'starmap'; same length as groupby"]
    - [compress,
       compress.__name__.__len__,
       [],
       8,
       "len(itertools.compress.__name__) == 8 — 'compress'"]
    - [dropwhile,
       dropwhile.__name__.__len__,
       [],
       9,
       "len(itertools.dropwhile.__name__) == 9 — 'dropwhile'; same length as takewhile"]
    - [takewhile,
       takewhile.__name__.__len__,
       [],
       9,
       "len(itertools.takewhile.__name__) == 9 — 'takewhile'; same length as dropwhile"]
    - [filterfalse,
       filterfalse.__name__.__len__,
       [],
       11,
       "len(itertools.filterfalse.__name__) == 11 — 'filterfalse'; longest filtering-type __name__"]
