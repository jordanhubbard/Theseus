spec: scipy_special_rust
version: ">=3.9"
backend: rust_module(scipy_special_rust)

docs: https://docs.scipy.org/doc/scipy/reference/special.html

provenance:
  derived_from:
    - "https://docs.scipy.org/doc/scipy/reference/special.html — SciPy special functions"
  not_derived_from:
    - "scipy source: scipy/special/_basic.py"
  notes:
    - "SciPy special functions include factorial, gamma, combinations."
    - "special.factorial(5) == 120.0 (returns float)."
    - "special.factorial(0) == 1.0."
    - "special.comb(5, 2) == 10.0 — combinations."
    - "special.comb(10, 3) == 120.0."
    - "special.gamma(1) == 1.0 — gamma function."
    - "special.gamma(5) == 24.0 — gamma(n) == (n-1)! for integers."
    - "Expose special_factorial(n) -> float: scipy.special.factorial(n)."
    - "Expose special_comb(n, k) -> float: scipy.special.comb(n, k)."
    - "Expose special_gamma(n) -> float: scipy.special.gamma(n)."
    - "All test vectors verified against scipy 1.15.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# special_factorial — factorial function
table scipy_special_rust.factorial.vectors:
  kind: python_call_eq
  category: factorial
  id_prefix: ss_fact
  function: special_factorial

  columns: [id, args, expected]
  rows:
    - [zero,  [0], 1.0]
    - [one,   [1], 1.0]
    - [five,  [5], 120.0]
    - [ten,   [10], 3628800.0]

# special_comb — combinations (n choose k)
table scipy_special_rust.comb.vectors:
  kind: python_call_eq
  category: comb
  id_prefix: ss_comb
  function: special_comb

  columns: [id, args, expected]
  rows:
    - [five_two,  [5, 2],  10.0]
    - [ten_three, [10, 3], 120.0]
    - [any_zero,  [5, 0],  1.0]

# special_gamma — gamma function
invariant scipy_special_rust.gamma.one:
  description: "gamma(1) == 1.0"
  category: gamma
  kind: python_call_eq
  function: special_gamma
  args: [1]
  expected: 1.0

invariant scipy_special_rust.gamma.five:
  description: "gamma(5) == 24.0 (== 4!)"
  category: gamma
  kind: python_call_eq
  function: special_gamma
  args: [5]
  expected: 24.0

