spec: struct_extra98
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra97

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__.__len__() and error.__name__.__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth and entry names / module-level function __qualname__.__len__() for pack/unpack/calcsize (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra97; it does NOT duplicate invariants present in those files."
    - "Wave 265 theme: struct.Struct getset_descriptor attributes (size and format) — class name, qualname, qualname length, name length, and __objclass__.__name__."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__ == 'Struct.size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__ == 'Struct.format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct.size and Struct.format are getset_descriptor objects (C-level get/set descriptor), not method_descriptor or property objects."
    - "Note: getset_descriptor is the C-API descriptor type used when a C extension defines a slot as a PyGetSetDef — it provides per-instance attribute access at the C level."
    - "Note: Struct.size.__qualname__ is 'Struct.size' (11 chars = 'Struct.' 7 + 'size' 4). Struct.format.__qualname__ is 'Struct.format' (13 chars = 'Struct.' 7 + 'format' 6)."
    - "Note: __objclass__ on a descriptor gives the class that owns it (Struct in both cases)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.format.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.size.__qualname__.__eq__('Struct.size')
# struct.Struct.format.__qualname__.__eq__('Struct.format')
#
# Wave 265 theme: Struct.size and Struct.format descriptor class name and qualname.
#
# struct.Struct exposes two getset_descriptor attributes at the class level:
# 'size' (the byte size of the packed struct) and 'format' (the format string).
# These are C-level PyGetSetDef descriptors, not Python property objects. Their
# class is 'getset_descriptor'. Their __qualname__ values include the class
# prefix: 'Struct.size' and 'Struct.format'. struct_extra93 first anchors
# Struct.format.__qualname__.__eq__('Struct.format'); this table extends
# coverage to both descriptor class names and qualname equality under
# structdesc98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra98.Struct_getset_descriptor_class_and_qualname:
  description: "struct.Struct.size/__class__.__name__.__eq__('getset_descriptor')==True / Struct.format/__class__.__name__.__eq__('getset_descriptor')==True / Struct.size/__qualname__.__eq__('Struct.size')==True / Struct.format/__qualname__.__eq__('Struct.format')==True — size and format are C-level PyGetSetDef descriptors (not property); __qualname__ includes 'Struct.' prefix; extra93 anchors Struct.format.__qualname__ equality; first structdesc98 anchor for getset_descriptor class names and both descriptor qualnames"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc98

  columns: [id, function, args, expected, description]
  rows:
    - [size_class,      "Struct.size.__class__.__name__.__eq__",     ["getset_descriptor"],  true, "Struct.size is a C-level PyGetSetDef descriptor, not a Python property"]
    - [format_class,    "Struct.format.__class__.__name__.__eq__",   ["getset_descriptor"],  true, "Struct.format is a C-level PyGetSetDef descriptor, not a Python property"]
    - [size_qualname,   "Struct.size.__qualname__.__eq__",           ["Struct.size"],         true, "Struct.size.__qualname__ is 'Struct.size' (11 chars with 'Struct.' prefix)"]
    - [format_qualname, "Struct.format.__qualname__.__eq__",         ["Struct.format"],       true, "Struct.format.__qualname__ is 'Struct.format' (13 chars with 'Struct.' prefix)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__len__()==11
# struct.Struct.format.__qualname__.__len__()==13
# struct.Struct.size.__name__.__len__()==4
# struct.Struct.format.__name__.__len__()==6
# struct.Struct.size.__objclass__.__name__.__eq__('Struct')
# struct.Struct.format.__objclass__.__name__.__eq__('Struct')
#
# Wave 265 theme: Struct.size and Struct.format descriptor qualname lengths,
# name lengths, and __objclass__.__name__.
#
# Struct.size.__qualname__ is 'Struct.size' (11 = 7 + 4). Struct.format.__qualname__
# is 'Struct.format' (13 = 7 + 6). The __name__ of each descriptor gives just
# the attribute name: 'size' (4) and 'format' (6). The __objclass__ attribute
# of a descriptor gives the class that owns it — both are 'Struct'. No prior
# struct spec anchors these qualname/name lengths or __objclass__ under
# structdesc98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra98.Struct_getset_descriptor_lengths_and_objclass:
  description: "struct.Struct.size/__qualname__/__len__()==11 / Struct.format/__qualname__/__len__()==13 / Struct.size/__name__/__len__()==4 / Struct.format/__name__/__len__()==6 / Struct.size/__objclass__/__name__.__eq__('Struct')==True / Struct.format/__objclass__/__name__.__eq__('Struct')==True — qualname length 11 for 'Struct.size' (7+4) and 13 for 'Struct.format' (7+6); __name__ is just the attribute name; __objclass__ names the owning class; first structdesc98 anchor for these lengths and objclass"
  kind: python_call_eq
  category: name_lengths
  id_prefix: structdesc98

  columns: [id, function, args, expected, description]
  rows:
    - [size_qlen,           Struct.size.__qualname__.__len__,               [], 11,   "'Struct.size' is 11 chars (7 for 'Struct.' + 4 for 'size')"]
    - [format_qlen,         Struct.format.__qualname__.__len__,             [], 13,   "'Struct.format' is 13 chars (7 for 'Struct.' + 6 for 'format')"]
    - [size_nlen,           Struct.size.__name__.__len__,                   [], 4,    "'size' is 4 chars (simple attribute name without class prefix)"]
    - [format_nlen,         Struct.format.__name__.__len__,                 [], 6,    "'format' is 6 chars (simple attribute name without class prefix)"]
    - [size_objclass,       "Struct.size.__objclass__.__name__.__eq__",     ["Struct"], true, "__objclass__ names the class owning the descriptor: Struct"]
    - [format_objclass,     "Struct.format.__objclass__.__name__.__eq__",   ["Struct"], true, "__objclass__ names the class owning the descriptor: Struct"]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__len__()==40
# struct.Struct.__doc__.__eq__('Struct(fmt) --> compiled struct object\n\n')
#
# Wave 265 theme: Struct class __doc__ string identity.
#
# struct.Struct.__doc__ is 'Struct(fmt) --> compiled struct object\n\n' (40 chars).
# This is the C-level docstring set for the Struct type object in _struct.c.
# struct_extra91 anchors Struct.__doc__ as a non-None value; no prior spec
# anchors Struct.__doc__.__len__()==40 or the full equality under structdesc98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra98.Struct_doc_length_and_equality:
  description: "struct.Struct.__doc__/__len__()==40 / Struct.__doc__.__eq__('Struct(fmt) --> compiled struct object\\n\\n')==True — Struct.__doc__ is a 40-char C-level docstring from _struct.c; extra91 anchors Struct.__doc__ as non-None; first structdesc98 anchor for Struct.__doc__ length and equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc98

  columns: [id, function, args, expected, description]
  rows:
    - [doc_len,   Struct.__doc__.__len__,  [], 40, "'Struct(fmt) --> compiled struct object\\n\\n' is 40 chars"]
    - [doc_eq,    "Struct.__doc__.__eq__",  ["Struct(fmt) --> compiled struct object\n\n"], true, "full docstring equality check"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') — standalone
#
# struct.Struct.size.__class__.__name__ is 'getset_descriptor'. The 'size'
# attribute of struct.Struct provides the byte size of the compiled struct
# format. Unlike Python-level property descriptors, it is implemented as a
# C-level PyGetSetDef entry in _struct.c (getset_descriptor). This means the
# getter and setter are C functions, and the attribute is not an ordinary
# Python property. No prior struct spec anchors
# Struct.size.__class__.__name__.__eq__('getset_descriptor') as a standalone
# under structdesc98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra98.Struct_size_getset_descriptor:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — Struct.size is a C-level PyGetSetDef descriptor from _struct.c (not a Python property); provides the byte size of the compiled format; distinguished from method_descriptor (methods) and property (Python-level getter); no prior struct spec anchors this as a standalone; first standalone for Struct.size __class__.__name__ under structdesc98"
  category: type_identity
  kind: python_call_eq
  function: "Struct.size.__class__.__name__.__eq__"
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__len__()==11 — standalone
#
# struct.Struct.size.__qualname__.__len__() is 11. The __qualname__ is
# 'Struct.size': 7 chars for 'Struct.' plus 4 chars for 'size'. This follows
# the standard Python descriptor naming convention: qualname includes the
# owning class name as a prefix. struct_extra93 first anchors
# Struct.format.__qualname__.__eq__('Struct.format') (13 chars); no prior spec
# anchors Struct.size.__qualname__.__len__()==11 as a standalone under
# structdesc98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra98.Struct_size_qualname_len_11:
  description: "struct.Struct.size.__qualname__.__len__() == 11 — __qualname__ is 'Struct.size' (11 chars = 7 for 'Struct.' + 4 for 'size'); standard descriptor naming with owning class prefix; extra93 anchors Struct.format.__qualname__.__eq__ (13 chars); no prior struct spec anchors Struct.size.__qualname__.__len__() as a standalone; first standalone under structdesc98"
  category: name_lengths
  kind: python_call_eq
  function: Struct.size.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__len__()==13 — standalone
#
# struct.Struct.format.__qualname__.__len__() is 13. The __qualname__ is
# 'Struct.format': 7 chars for 'Struct.' plus 6 chars for 'format'. The
# format attribute provides the format string that was used to create the
# Struct instance. struct_extra93 anchors Struct.format.__qualname__.__eq__
# ('Struct.format'); no prior spec anchors
# Struct.format.__qualname__.__len__()==13 as a standalone under structdesc98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra98.Struct_format_qualname_len_13:
  description: "struct.Struct.format.__qualname__.__len__() == 13 — __qualname__ is 'Struct.format' (13 chars = 7 for 'Struct.' + 6 for 'format'); format provides the format string used to create the Struct; extra93 anchors Struct.format.__qualname__.__eq__('Struct.format'); no prior struct spec anchors __len__()==13 as a standalone; first standalone under structdesc98"
  category: name_lengths
  kind: python_call_eq
  function: Struct.format.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') — standalone
#
# struct.Struct.format.__class__.__name__ is 'getset_descriptor'. Like Struct.size,
# the 'format' attribute is a C-level PyGetSetDef descriptor from _struct.c.
# It provides read-only access to the format string that was used to create
# the Struct instance. Because it is a getset_descriptor (not a Python property),
# accessing it invokes a C getter function directly. No prior struct spec anchors
# Struct.format.__class__.__name__.__eq__('getset_descriptor') as a standalone
# under structdesc98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra98.Struct_format_getset_descriptor:
  description: "struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') == True — Struct.format is a C-level PyGetSetDef descriptor from _struct.c (not a Python property); provides read-only access to the format string; accessing it invokes a C getter; no prior struct spec anchors this as a standalone; first standalone for Struct.format __class__.__name__ under structdesc98"
  category: type_identity
  kind: python_call_eq
  function: "Struct.format.__class__.__name__.__eq__"
  args: ["getset_descriptor"]
  expected: true
