spec: io_extra1531
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, BytesIO, StringIO, UnsupportedOperation documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "_io C extension source"
    - "io_extra.zspec.zsdl — covers TextIOWrapper, BufferedRandom, UnsupportedOperation class names, DEFAULT_BUFFER_SIZE, SEEK_* constants"
    - "io_extra1516.zspec.zsdl — covers arithmetic/numeric operator absence for IOBase, BytesIO, StringIO (wave 548)"
  notes:
    - "Wave 549 (_extra1531): comparison operator __dict__ presence checks for io module classes."
    - "io classes are I/O stream types, not ordered value types. None define __lt__, __le__, __gt__, __ge__, __ne__, __eq__, or __hash__ in their own __dict__."
    - "io.IOBase is the abstract base class for all I/O streams; its __dict__ contains module metadata and ABC infrastructure (__abstractmethods__, _abc_impl) but no comparison operators."
    - "io.BytesIO is a concrete in-memory bytes stream; its __dict__ contains stream methods (read, write, seek) and iteration dunders but no comparison operators."
    - "io.StringIO is a concrete in-memory text stream; its __dict__ contains stream methods (read, write, readline) but no comparison operators."
    - "io.UnsupportedOperation is an exception class inheriting from OSError and ValueError; its __dict__ is minimal (__module__, __weakref__, __doc__) with no comparison operators."
    - "Positive anchors confirm that stream-specific dunders ARE present: BytesIO defines read and write; StringIO defines read and write; IOBase defines __abstractmethods__."
    - "Contrast with: pathlib.PurePath (defines __lt__, __le__, __gt__, __ge__, __eq__, __hash__), re.Pattern (defines all seven), decimal.Decimal (defines all seven)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1531.iobase_comparison_ops:
  description: "io.IOBase comparison operator absence — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ are all absent from io.IOBase.__dict__; IOBase is an abstract I/O base class, not an ordered value type; positive anchor shows __abstractmethods__ IS present; wave 549"
  kind: python_call_eq
  category: comparison_ops
  id_prefix: io1531ib
  columns: [id, function, args, expected, description]
  rows:
    - [io1531ib001,
       io.IOBase.__dict__.__contains__,
       ["__lt__"],
       false,
       "io.IOBase.__dict__.__contains__('__lt__') == False — io.IOBase is the abstract base class for all I/O stream classes; it is not an ordered value type and defines no comparison operators; __lt__ is absent from io.IOBase.__dict__; I/O streams cannot be sorted or compared for ordering; verified with Python 3.14.3"]
    - [io1531ib002,
       io.IOBase.__dict__.__contains__,
       ["__le__"],
       false,
       "io.IOBase.__dict__.__contains__('__le__') == False — io.IOBase does not implement __le__; less-than-or-equal comparison is meaningless for abstract I/O base objects; the io class hierarchy defines stream protocol methods (read, write, seek, close) but no ordering operators; verified with Python 3.14.3"]
    - [io1531ib003,
       io.IOBase.__dict__.__contains__,
       ["__gt__"],
       false,
       "io.IOBase.__dict__.__contains__('__gt__') == False — io.IOBase does not implement __gt__; greater-than comparison is not part of the I/O stream protocol; IOBase defines abstract methods for stream interaction, not ordering operations; verified with Python 3.14.3"]
    - [io1531ib004,
       io.IOBase.__dict__.__contains__,
       ["__ge__"],
       false,
       "io.IOBase.__dict__.__contains__('__ge__') == False — io.IOBase does not implement __ge__; greater-than-or-equal comparison is absent from the I/O class hierarchy; contrast with pathlib.PurePath which defines __ge__ for lexicographic path ordering, but IOBase defines no such operator; verified with Python 3.14.3"]
    - [io1531ib005,
       io.IOBase.__dict__.__contains__,
       ["__eq__"],
       false,
       "io.IOBase.__dict__.__contains__('__eq__') == False — io.IOBase does not define __eq__ in its own __dict__; equality comparison falls through to the default object identity semantics inherited from object; IOBase instances are compared by identity, not by stream contents; verified with Python 3.14.3"]
    - [io1531ib006,
       io.IOBase.__dict__.__contains__,
       ["__hash__"],
       false,
       "io.IOBase.__dict__.__contains__('__hash__') == False — io.IOBase does not define __hash__ in its own __dict__; hashing falls through to the default identity-based hash inherited from object; contrast with pathlib.PurePath which defines __hash__ for use in sets and dicts, and decimal.Decimal which defines __hash__ consistent with its __eq__; verified with Python 3.14.3"]
    - [io1531ib007,
       io.IOBase.__dict__.__contains__,
       ["__ne__"],
       false,
       "io.IOBase.__dict__.__contains__('__ne__') == False — io.IOBase does not define __ne__ in its own __dict__; not-equal comparison uses the default inherited from object (negation of __eq__); none of the six io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO) define any comparison operator dunder in their own __dict__; verified with Python 3.14.3"]
    - [io1531ib008,
       io.IOBase.__dict__.__contains__,
       ["__abstractmethods__"],
       true,
       "io.IOBase.__dict__.__contains__('__abstractmethods__') == True — positive anchor: io.IOBase defines __abstractmethods__ in its own __dict__; this marks IOBase as an abstract class with abstract method stubs; the class dict contains abstract-class metadata, not comparison operators; verified with Python 3.14.3"]

table io_extra1531.bytesio_comparison_ops:
  description: "io.BytesIO comparison operator absence — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ are all absent from io.BytesIO.__dict__; BytesIO is an in-memory bytes stream, not an ordered value type; positive anchors show read and write ARE present; wave 549"
  kind: python_call_eq
  category: comparison_ops
  id_prefix: io1531by
  columns: [id, function, args, expected, description]
  rows:
    - [io1531by001,
       io.BytesIO.__dict__.__contains__,
       ["__lt__"],
       false,
       "io.BytesIO.__dict__.__contains__('__lt__') == False — io.BytesIO is an in-memory byte stream backed by a bytes buffer; it is not an ordered value type and defines no __lt__; bytes objects (b'x') support __lt__ for lexicographic comparison, but io.BytesIO stream objects do not expose ordering operators; verified with Python 3.14.3"]
    - [io1531by002,
       io.BytesIO.__dict__.__contains__,
       ["__le__"],
       false,
       "io.BytesIO.__dict__.__contains__('__le__') == False — io.BytesIO does not implement __le__; less-than-or-equal ordering is absent from BytesIO.__dict__; BytesIO wraps a bytes buffer with a stream interface (read/write/seek), not a comparable-value interface; verified with Python 3.14.3"]
    - [io1531by003,
       io.BytesIO.__dict__.__contains__,
       ["__gt__"],
       false,
       "io.BytesIO.__dict__.__contains__('__gt__') == False — io.BytesIO does not implement __gt__; greater-than comparison is undefined for byte stream objects; the stream position and buffer contents are not exposed as a comparable value through the ordering protocol; verified with Python 3.14.3"]
    - [io1531by004,
       io.BytesIO.__dict__.__contains__,
       ["__ge__"],
       false,
       "io.BytesIO.__dict__.__contains__('__ge__') == False — io.BytesIO does not implement __ge__; the complete set of ordering operators (__lt__, __le__, __gt__, __ge__) is absent from BytesIO.__dict__; contrast with pathlib.PurePath and decimal.Decimal which define all four ordering operators; verified with Python 3.14.3"]
    - [io1531by005,
       io.BytesIO.__dict__.__contains__,
       ["__eq__"],
       false,
       "io.BytesIO.__dict__.__contains__('__eq__') == False — io.BytesIO does not define __eq__ in its own __dict__; equality comparison uses the default object identity semantics inherited from object; two BytesIO objects with identical contents are not equal unless they are the same object; verified with Python 3.14.3"]
    - [io1531by006,
       io.BytesIO.__dict__.__contains__,
       ["__hash__"],
       false,
       "io.BytesIO.__dict__.__contains__('__hash__') == False — io.BytesIO does not define __hash__ in its own __dict__; hashing uses the default identity-based hash inherited from object; BytesIO instances cannot be used as dict keys based on their content; verified with Python 3.14.3"]
    - [io1531by007,
       io.BytesIO.__dict__.__contains__,
       ["read"],
       true,
       "io.BytesIO.__dict__.__contains__('read') == True — positive anchor: io.BytesIO defines 'read' in its own __dict__; the read method is the primary stream consumption method returning bytes; stream I/O methods (read, write, seek) are present while all comparison operator dunders are absent; verified with Python 3.14.3"]
    - [io1531by008,
       io.BytesIO.__dict__.__contains__,
       ["write"],
       true,
       "io.BytesIO.__dict__.__contains__('write') == True — positive anchor: io.BytesIO defines 'write' in its own __dict__; write appends bytes to the in-memory buffer; stream write/read methods are defined, comparison operators are not; BytesIO.__dict__ has no __lt__, __le__, __gt__, __ge__, __eq__, __ne__, or __hash__; verified with Python 3.14.3"]

table io_extra1531.stringio_comparison_ops:
  description: "io.StringIO comparison operator absence — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ are all absent from io.StringIO.__dict__; StringIO is an in-memory text stream, not an ordered value type; positive anchors show read and write ARE present; wave 549"
  kind: python_call_eq
  category: comparison_ops
  id_prefix: io1531si
  columns: [id, function, args, expected, description]
  rows:
    - [io1531si001,
       io.StringIO.__dict__.__contains__,
       ["__lt__"],
       false,
       "io.StringIO.__dict__.__contains__('__lt__') == False — io.StringIO is an in-memory text stream; it is not an ordered value type and defines no __lt__; str objects support __lt__ for lexicographic comparison, but io.StringIO stream objects do not expose ordering operators; StringIO wraps a text buffer with a stream interface, not a comparable-value interface; verified with Python 3.14.3"]
    - [io1531si002,
       io.StringIO.__dict__.__contains__,
       ["__le__"],
       false,
       "io.StringIO.__dict__.__contains__('__le__') == False — io.StringIO does not implement __le__; less-than-or-equal ordering is absent from StringIO.__dict__; contrast with pathlib.PurePath which defines __le__ for lexicographic path comparison; io.StringIO has no such operator despite wrapping text; verified with Python 3.14.3"]
    - [io1531si003,
       io.StringIO.__dict__.__contains__,
       ["__gt__"],
       false,
       "io.StringIO.__dict__.__contains__('__gt__') == False — io.StringIO does not implement __gt__; greater-than comparison is undefined for text stream objects; the stream position and text buffer are not exposed as comparable values through the ordering protocol; verified with Python 3.14.3"]
    - [io1531si004,
       io.StringIO.__dict__.__contains__,
       ["__ge__"],
       false,
       "io.StringIO.__dict__.__contains__('__ge__') == False — io.StringIO does not implement __ge__; the complete ordering operator set (__lt__, __le__, __gt__, __ge__) is absent from StringIO.__dict__; io classes are designed for stream I/O, not value ordering; verified with Python 3.14.3"]
    - [io1531si005,
       io.StringIO.__dict__.__contains__,
       ["__eq__"],
       false,
       "io.StringIO.__dict__.__contains__('__eq__') == False — io.StringIO does not define __eq__ in its own __dict__; equality comparison uses the default object identity semantics inherited from object; two StringIO objects with identical text content are not equal unless they are the same object; verified with Python 3.14.3"]
    - [io1531si006,
       io.StringIO.__dict__.__contains__,
       ["__hash__"],
       false,
       "io.StringIO.__dict__.__contains__('__hash__') == False — io.StringIO does not define __hash__ in its own __dict__; hashing uses the default identity-based hash inherited from object; StringIO instances are not hashable by content; contrast with decimal.Decimal which defines __hash__ consistent with numeric equality; verified with Python 3.14.3"]
    - [io1531si007,
       io.StringIO.__dict__.__contains__,
       ["read"],
       true,
       "io.StringIO.__dict__.__contains__('read') == True — positive anchor: io.StringIO defines 'read' in its own __dict__; read is the primary stream consumption method returning a str; stream methods (read, write, readline, seek) are present while comparison operators (__lt__, __le__, __gt__, __ge__, __eq__, __ne__, __hash__) are absent; verified with Python 3.14.3"]
    - [io1531si008,
       io.StringIO.__dict__.__contains__,
       ["write"],
       true,
       "io.StringIO.__dict__.__contains__('write') == True — positive anchor: io.StringIO defines 'write' in its own __dict__; write appends text to the in-memory text buffer; stream write/read operations are defined, but comparison operators are not; verified with Python 3.14.3"]
    - [io1531si009,
       io.StringIO.__dict__.__contains__,
       ["__ne__"],
       false,
       "io.StringIO.__dict__.__contains__('__ne__') == False — io.StringIO does not define __ne__ in its own __dict__; not-equal comparison uses the default inherited from object; the complete comparison operator set (__lt__, __le__, __gt__, __ge__, __eq__, __ne__, __hash__) is absent from io.StringIO.__dict__ just as from io.IOBase.__dict__ and io.BytesIO.__dict__; wave 549 confirms the entire io class hierarchy defines no comparison operators in class __dict__; verified with Python 3.14.3"]
