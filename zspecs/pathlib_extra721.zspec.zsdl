    - [pl721pq005, pathlib.PurePath.suffix.__qualname__.__eq__, ["PurePath.suffix"], true]
    - [pl721pq006, pathlib.PurePath.suffixes.__qualname__.__eq__, ["PurePath.suffixes"], true]
    - [pl721pq007, pathlib.PurePath.parts.__qualname__.__eq__, ["PurePath.parts"], true]
    - [pl721pq008, pathlib.PurePath.root.__qualname__.__eq__, ["PurePath.root"], true]
    - [pl721pq009, pathlib.PurePath.drive.__qualname__.__eq__, ["PurePath.drive"], true]
    - [pl721pq010, pathlib.PurePath.anchor.__qualname__.__eq__, ["PurePath.anchor"], true]
