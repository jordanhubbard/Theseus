  notes: "Qualname identity checks for pathlib.PurePath and pathlib.Path property descriptors"
  created_at: "2026-04-12"

docs:
  summary: "Covers pathlib.PurePath and pathlib.Path property qualnames for parent, name, stem, suffix, suffixes, parts, root, drive, and anchor."

table pathlib_extra721.property_qualnames:
