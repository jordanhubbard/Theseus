spec: titlecase
version: ">=1.1.3"
backend: node(titlecase)

docs: https://www.npmjs.com/package/titlecase

provenance:
  derived_from:
    - "titlecase README — https://www.npmjs.com/package/titlecase"
    - "Test vectors verified with titlecase via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "titlecase source"
  notes:
    - "titlecase is an npm package. Install: npm install titlecase"
    - "Converts a string to title case, following English capitalization rules."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table titlecase.convert:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: tcase

  columns: [id, args, expected]
  rows:
    - [simple,  ["hello world"],          "Hello World"]
    - [phrase,  ["the quick brown fox"],  "The Quick Brown Fox"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:43:29Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
