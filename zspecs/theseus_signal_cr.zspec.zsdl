spec: theseus_signal_cr
version: ">=3.8"
backend: python_cleanroom(theseus_signal_cr)
blocks: signal

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/signal.html"
    - "POSIX signal numbers"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c (internal implementation)"
  notes:
    - "Clean-room signal constants and utilities. Do NOT import signal."
    - "SIGINT=2, SIGTERM=15, SIGHUP=1, SIGKILL=9, SIGUSR1=10, SIGUSR2=12."
    - "SIG_DFL, SIG_IGN: special handler constants."
    - "signal(signum, handler): set signal handler (delegates to os.signal if available)."
    - "getsignal(signum): return current handler."

error_model: python_exceptions

invariant theseus_signal_cr.signal2_constants:
  description: "SIGINT == 2 and SIGTERM == 15"
  category: constants
  kind: python_call_eq
  function: signal2_constants
  args: []
  expected: true

invariant theseus_signal_cr.signal2_sigint_value:
  description: "SIGINT has value 2"
  category: SIGINT
  kind: python_call_eq
  function: signal2_sigint_value
  args: []
  expected: 2

invariant theseus_signal_cr.signal2_sigterm_value:
  description: "SIGTERM has value 15"
  category: SIGTERM
  kind: python_call_eq
  function: signal2_sigterm_value
  args: []
  expected: 15
