spec: uuid_extra59
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra58.zspec.zsdl — covers uuid4/uuid3/uuid5 __defaults__/__class__/__name__=='NoneType' / uuid1/__defaults__/__class__/__name__=='tuple' / uuid1/__defaults__/__len__()==2 / uuid1/__defaults__[0]/__class__/__name__=='NoneType' / UUID.__init__/__defaults__/__class__/__name__=='tuple' / UUID.__init__/__defaults__/__len__()==6 (table + invariants)."
    - "uuid_extra57.zspec.zsdl — covers uuid4/__code__.co_consts/__class__.__name__=='tuple' / uuid1/__code__.co_consts/__class__.__name__=='tuple' / co_nlocals/__class__.__name__=='int' / co_stacksize/__class__.__name__=='int' / UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__qualname__=='UUID' / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 (table + invariants)."
    - "uuid_extra56.zspec.zsdl — covers uuid4/__code__.co_varnames/__class__.__name__=='tuple' / uuid1/__code__.co_varnames/__class__.__name__=='tuple' / uuid1/__code__.co_varnames[0]=='node' / uuid4/__code__.co_filename.__contains__('.py') / NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' (table + invariants)."
    - "uuid_extra55.zspec.zsdl — covers uuid4/__code__.co_name / uuid1/__code__.co_name / uuid4/__code__.co_argcount==0 / uuid1/__code__.co_argcount==2 / UUID.__doc__.__contains__('hex'/'int') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra58; it does NOT duplicate invariants present in those files."
    - "Wave 234 theme: __kwdefaults__ for uuid4/uuid1/uuid3/uuid5 + UUID.__init__.__kwdefaults__ structure + UUID.__repr__/__str__ qualified names."
    - "uuid.uuid4.__kwdefaults__.__class__.__name__ == 'NoneType' — uuid4() takes no arguments and has no keyword-only parameters; __kwdefaults__ is None. No prior uuid spec checks uuid4.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__kwdefaults__.__class__.__name__ == 'NoneType' — uuid1(node=None, clock_seq=None) has no keyword-only parameters; __kwdefaults__ is None. No prior uuid spec checks uuid1.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__kwdefaults__.__class__.__name__ == 'NoneType' — uuid3(namespace, name) has no keyword-only parameters; __kwdefaults__ is None. No prior uuid spec checks uuid3.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__kwdefaults__.__class__.__name__ == 'NoneType' — uuid5(namespace, name) has no keyword-only parameters; __kwdefaults__ is None. No prior uuid spec checks uuid5.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__kwdefaults__.__class__.__name__ == 'dict' — UUID.__init__(self, ..., *, is_safe=SafeUUID.unknown) has one keyword-only parameter (is_safe); __kwdefaults__ is a dict of length 1. No prior uuid spec checks UUID.__init__.__kwdefaults__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__kwdefaults__.__len__() == 1 — the __kwdefaults__ dict has one key ('is_safe'). No prior uuid spec checks UUID.__init__.__kwdefaults__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' — UUID is a pure-Python class; UUID.__repr__ is a Python function with __qualname__ 'UUID.__repr__'. No prior uuid spec checks UUID.__repr__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' — UUID.__str__ is a Python function with __qualname__ 'UUID.__str__'. No prior uuid spec checks UUID.__str__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_name == '__init__' — the code object's co_name reflects the function name. No prior uuid spec checks UUID.__init__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 — def __init__(self, hex=None, bytes=None, bytes_le=None, fields=None, int=None, version=None, ...): self plus six optional positional args = 7. No prior uuid spec checks UUID.__init__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 / uuid1 / uuid3 / uuid5 __kwdefaults__ NoneType
#
# Wave 234 theme: __kwdefaults__ NoneType for uuid generator functions.
#
# uuid4(), uuid1(node=None, clock_seq=None), uuid3(namespace, name), and
# uuid5(namespace, name) are Python functions with no keyword-only parameters.
# __kwdefaults__ is None (NoneType) for all four. No prior uuid spec checks
# __kwdefaults__ for any of these functions in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra59.none_kwdefaults:
  description: "uuid4/__kwdefaults__/__class__/__name__=='NoneType' / uuid1/__kwdefaults__/__class__/__name__=='NoneType' / uuid3/__kwdefaults__/__class__/__name__=='NoneType' / uuid5/__kwdefaults__/__class__/__name__=='NoneType' — uuid4/uuid1/uuid3/uuid5 are Python functions with no keyword-only parameters; __kwdefaults__ is None (NoneType) for all four; no prior uuid spec checks __kwdefaults__ for any uuid generator function; first __kwdefaults__ identity anchor for uuid generator functions"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: uuidkw59

  columns: [id, function, args, expected]
  rows:
    - [uuid4_kwdefaults_class_NoneType, uuid4.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [uuid1_kwdefaults_class_NoneType, uuid1.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [uuid3_kwdefaults_class_NoneType, uuid3.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [uuid5_kwdefaults_class_NoneType, uuid5.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__kwdefaults__ structure — class name and length
#
# Wave 234 theme: UUID.__init__.__kwdefaults__ is a dict of length 1.
#
# uuid.UUID.__init__(self, hex=None, bytes=None, bytes_le=None, fields=None,
# int=None, version=None, *, is_safe=SafeUUID.unknown) has one keyword-only
# parameter (is_safe). __kwdefaults__ is a dict with one entry. No prior uuid
# spec checks UUID.__init__.__kwdefaults__.__class__.__name__ or
# UUID.__init__.__kwdefaults__.__len__(). Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table uuid_extra59.UUID_init_kwdefaults:
  description: "uuid.UUID.__init__/__kwdefaults__/__class__/__name__=='dict' / UUID.__init__/__kwdefaults__/__len__()==1 — UUID.__init__ has one keyword-only parameter (is_safe=SafeUUID.unknown); __kwdefaults__ is a dict of length 1; no prior uuid spec checks UUID.__init__/__kwdefaults__/__class__/__name__ or UUID.__init__/__kwdefaults__/__len__(); first UUID.__init__ kwdefaults structure anchor"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: uuidkw59

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_kwdefaults_class_dict, UUID.__init__.__kwdefaults__.__class__.__name__.__eq__, ["dict"], true]
    - [UUID_init_kwdefaults_len_1,      UUID.__init__.__kwdefaults__.__len__,                   [],       1]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__ chains — co_name and co_argcount
#
# Wave 234 theme: UUID.__init__.__code__ attribute checks.
#
# uuid.UUID.__init__ is a Python function. Its __code__ object has co_name
# '__init__' and co_argcount 7 (self + six optional positional params:
# hex, bytes, bytes_le, fields, int, version). No prior uuid spec checks
# UUID.__init__.__code__.co_name or UUID.__init__.__code__.co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra59.UUID_init_code_chains:
  description: "uuid.UUID.__init__/__code__.co_name=='__init__' / UUID.__init__/__code__.co_argcount==7 — UUID.__init__ is a Python function; co_name is '__init__'; co_argcount is 7 (self plus six optional positional params: hex/bytes/bytes_le/fields/int/version); no prior uuid spec checks UUID.__init__/__code__.co_name or UUID.__init__/__code__.co_argcount; first UUID.__init__ code attribute anchor"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidkw59

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_code_co_name_init,   UUID.__init__.__code__.co_name.__eq__,        ["__init__"], true]
    - [UUID_init_code_co_argcount_7,  UUID.__init__.__code__.co_argcount.__eq__,     [7],          true]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__ and UUID.__str__ __qualname__ equality
#
# Wave 234 theme: UUID method qualified names.
#
# uuid.UUID is a pure-Python class (class UUID: in Lib/uuid.py). Its methods
# __repr__ and __str__ are Python functions with __qualname__ values following
# the pattern 'UUID.<method_name>'. UUID.__repr__.__qualname__ is 'UUID.__repr__'
# and UUID.__str__.__qualname__ is 'UUID.__str__'. No prior uuid spec checks
# UUID.__repr__.__qualname__ or UUID.__str__.__qualname__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra59.UUID_method_qualnames:
  description: "uuid.UUID.__repr__/__qualname__=='UUID.__repr__' / uuid.UUID.__str__/__qualname__=='UUID.__str__' — UUID is a pure-Python class; __repr__ and __str__ are Python functions whose __qualname__ follows the 'UUID.<method>' pattern; no prior uuid spec checks UUID.__repr__.__qualname__ or UUID.__str__.__qualname__; first UUID method qualname anchor for repr/str"
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidkw59

  columns: [id, function, args, expected]
  rows:
    - [UUID_repr_qualname_eq, UUID.__repr__.__qualname__.__eq__, ["UUID.__repr__"], true]
    - [UUID_str_qualname_eq,  UUID.__str__.__qualname__.__eq__,  ["UUID.__str__"],  true]

# ---------------------------------------------------------------------------
# uuid.uuid4.__kwdefaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# uuid4() has no keyword-only parameters; __kwdefaults__ is None (NoneType).
# No prior uuid spec checks uuid4.__kwdefaults__ in any form. First
# __kwdefaults__ NoneType anchor for uuid.uuid4.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra59.uuid4_kwdefaults_NoneType:
  description: "uuid.uuid4.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — uuid4() has no keyword-only parameters; __kwdefaults__ is None (NoneType); no prior uuid spec checks uuid4.__kwdefaults__ in any form; first __kwdefaults__ NoneType anchor for uuid.uuid4"
  category: kwdefaults
  kind: python_call_eq
  function: uuid4.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') — standalone
#
# uuid.UUID.__init__ has one keyword-only parameter (is_safe=SafeUUID.unknown).
# __kwdefaults__ is a dict. No prior uuid spec checks
# UUID.__init__.__kwdefaults__.__class__.__name__. First UUID.__init__
# __kwdefaults__ class identity anchor. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

invariant uuid_extra59.UUID_init_kwdefaults_dict:
  description: "uuid.UUID.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') == True — UUID.__init__ has one keyword-only parameter (is_safe); __kwdefaults__ is a dict; no prior uuid spec checks UUID.__init__.__kwdefaults__.__class__.__name__; first UUID.__init__ kwdefaults class identity anchor"
  category: kwdefaults
  kind: python_call_eq
  function: UUID.__init__.__kwdefaults__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__kwdefaults__.__len__() == 1 — standalone
#
# uuid.UUID.__init__ has exactly one keyword-only parameter (is_safe).
# __kwdefaults__ dict has length 1. No prior uuid spec checks
# UUID.__init__.__kwdefaults__.__len__(). First UUID.__init__ __kwdefaults__
# length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra59.UUID_init_kwdefaults_len_1:
  description: "uuid.UUID.__init__.__kwdefaults__.__len__() == 1 — UUID.__init__ has one keyword-only parameter (is_safe); __kwdefaults__ has length 1; no prior uuid spec checks UUID.__init__.__kwdefaults__.__len__(); first UUID.__init__ kwdefaults length anchor"
  category: kwdefaults
  kind: python_call_eq
  function: UUID.__init__.__kwdefaults__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__') — standalone
#
# uuid.UUID is a pure-Python class. UUID.__repr__ is a Python function with
# __qualname__ 'UUID.__repr__'. No prior uuid spec checks
# UUID.__repr__.__qualname__. First qualname anchor for uuid.UUID.__repr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra59.UUID_repr_qualname:
  description: "uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__') == True — UUID is a pure-Python class; __repr__ is a Python function with __qualname__ 'UUID.__repr__'; no prior uuid spec checks UUID.__repr__.__qualname__; first qualname anchor for uuid.UUID.__repr__"
  category: qualnames
  kind: python_call_eq
  function: UUID.__repr__.__qualname__.__eq__
  args: ["UUID.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') — standalone
#
# uuid.UUID is a pure-Python class. UUID.__str__ is a Python function with
# __qualname__ 'UUID.__str__'. No prior uuid spec checks
# UUID.__str__.__qualname__. First qualname anchor for uuid.UUID.__str__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra59.UUID_str_qualname:
  description: "uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') == True — UUID is a pure-Python class; __str__ is a Python function with __qualname__ 'UUID.__str__'; no prior uuid spec checks UUID.__str__.__qualname__; first qualname anchor for uuid.UUID.__str__"
  category: qualnames
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__eq__
  args: ["UUID.__str__"]
  expected: true
