# ===

table uuid_extra2431.aiter_in_dict_SafeUUID:
  description: "__aiter__ and __anext__ dict-presence for uuid.SafeUUID — enum type, not an async iterable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2431

  columns: [id, function, args, expected]
  rows:
    - ["uu2431003", "uuid.SafeUUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu2431004", "uuid.SafeUUID.__dict__.__contains__", ["__anext__"], false]

# ===
# Table 3: Contrast — sync dunder methods present in uuid.UUID __dict__
# ===

table uuid_extra2431.sync_methods_UUID:
  description: "uuid.UUID defines sync dunder methods (__init__, __hash__, __eq__, __str__) but NOT async protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2431

  columns: [id, function, args, expected]
  rows:
    - ["uu2431005", "uuid.UUID.__dict__.__contains__", ["__init__"],  true]
    - ["uu2431006", "uuid.UUID.__dict__.__contains__", ["__hash__"],  true]
    - ["uu2431007", "uuid.UUID.__dict__.__contains__", ["__eq__"],    true]
    - ["uu2431008", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu2431009", "uuid.UUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu2431010", "uuid.UUID.__dict__.__contains__", ["__anext__"], false]

# ===
# Table 4: Contrast — enum class member map present in uuid.SafeUUID __dict__
# ===

table uuid_extra2431.safeuuid_enum_contrast:
  description: "uuid.SafeUUID has enum infrastructure (_value2member_map_) but not async protocol (__aiter__, __anext__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2431

  columns: [id, function, args, expected]
  rows:
    - ["uu2431011", "uuid.SafeUUID.__dict__.__contains__", ["_value2member_map_"], true]
    - ["uu2431012", "uuid.SafeUUID.__dict__.__contains__", ["__aiter__"],          false]
    - ["uu2431013", "uuid.SafeUUID.__dict__.__contains__", ["__anext__"],          false]
    - ["uu2431014", "uuid.UUID.__dict__.__contains__",     ["__iter__"],           false]
    - ["uu2431015", "uuid.UUID.__dict__.__contains__",     ["__next__"],           false]
    - ["uu2431016", "uuid.SafeUUID.__dict__.__contains__", ["__iter__"],           false]
    - ["uu2431017", "uuid.SafeUUID.__dict__.__contains__", ["__next__"],           false]
