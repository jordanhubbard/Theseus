spec: uuid_extra2431
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID class identity, uuid1/3/4/5 names, NAMESPACE_* instances, UUID int/hex attributes"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 name standalones, NAMESPACE_* class name standalones, RESERVED_* string constants"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for uuid classes."
    - "uuid.UUID is a plain Python class; uuid.SafeUUID is an IntEnum subclass."
    - "Neither uuid.UUID nor uuid.SafeUUID defines __aiter__ or __anext__ in their class __dict__."
    - "UUID is not an iterator at all — it defines __hash__, __eq__, __str__, and __init__ as sync methods."
    - "SafeUUID is an enum; enum members are iterable at the class level but SafeUUID itself does not define __aiter__ or __anext__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ===
# Table 1: __aiter__ in class __dict__ — uuid.UUID
# ===

table uuid_extra2431.aiter_in_dict_UUID:
  description: "__aiter__ and __anext__ dict-presence for uuid.UUID — not an async iterable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2431

  columns: [id, function, args, expected]
  rows:
    - ["uu2431001", "uuid.UUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu2431002", "uuid.UUID.__dict__.__contains__", ["__anext__"], false]

# ===
