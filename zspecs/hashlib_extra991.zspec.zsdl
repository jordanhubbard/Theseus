spec: hashlib_extra991
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib function text signature class names, __module__ attributes, and package identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra991.text_signature_classnames:
  description: "hashlib function __text_signature__ class name identity"
  kind: python_call_eq
  category: text_signature_classnames
  id_prefix: hl991ts
  columns: [id, function, args, expected]
  rows:
    - [hl991ts001, hashlib.md5.__qualname__.__class__.__name__.__eq__,       ["str"], true]
    - [hl991ts002, hashlib.sha256.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [hl991ts003, hashlib.new.__qualname__.__class__.__name__.__eq__,       ["str"], true]
    - [hl991ts004, hashlib.pbkdf2_hmac.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [hl991ts005, hashlib.sha512.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [hl991ts006, hashlib.sha1.__qualname__.__class__.__name__.__eq__,      ["str"], true]

table hashlib_extra991.module_attributes:
  description: "hashlib function __module__ attribute identity"
  kind: python_call_eq
  category: module_attributes
  id_prefix: hl991ma
  columns: [id, function, args, expected]
  rows:
    - [hl991ma001, hashlib.md5.__module__.__eq__,        ["hashlib"], true]
    - [hl991ma002, hashlib.sha256.__module__.__eq__,     ["hashlib"], true]
    - [hl991ma003, hashlib.new.__module__.__eq__,        ["hashlib"], true]
    - [hl991ma004, hashlib.sha512.__module__.__eq__,     ["hashlib"], true]
    - [hl991ma005, hashlib.sha1.__module__.__eq__,       ["hashlib"], true]
    - [hl991ma006, hashlib.pbkdf2_hmac.__module__.__eq__, ["hashlib"], true]

table hashlib_extra991.package_identity:
  description: "hashlib module __package__ and __name__ identity"
  kind: python_call_eq
  category: package_identity
  id_prefix: hl991pi
  columns: [id, function, args, expected]
  rows:
    - [hl991pi001, hashlib.__package__.__eq__,               [""],       true]
    - [hl991pi002, hashlib.__name__.__eq__,                  ["hashlib"], true]
    - [hl991pi003, hashlib.__spec__.name.__eq__,             ["hashlib"], true]
    - [hl991pi004, hashlib.__name__.__class__.__name__.__eq__, ["str"],   true]
