spec: time_stamp
version: ">=2.0.0"
backend: node(time-stamp)

docs: https://github.com/jonschlinkert/time-stamp#readme

provenance:
  derived_from:
    - "time-stamp README — https://github.com/jonschlinkert/time-stamp#readme"
    - "Test vectors verified with time-stamp via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "time-stamp source"
  notes:
    - "Format the current Date using YYYY/MM/DD/HH/mm/ss/ms placeholders."
    - "Install: npm install time-stamp"
    - "v2 CJS; module export IS the formatter (pattern, [date]) → string. Without a Date arg, formats now()."
    - "Spec tests pattern handling (passthrough text + format-token width) without depending on the wall clock value."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure on inputs; never throws on string-pattern input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant time_stamp.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant time_stamp.has_utc_helper:
  description: "ts.utc() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "utc.constructor.name"}
  expected: "Function"

invariant time_stamp.empty_pattern:
  description: "ts('') returns the empty string"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: ""

invariant time_stamp.plain_text_passthrough:
  description: "Plain literal text without format tokens is unchanged"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: ["hello"]
  chain: []
  expected: "hello"

invariant time_stamp.YYYY_length_is_4:
  description: "ts('YYYY') always returns a 4-character year"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: ["YYYY"]
  chain:
    - {get: length}
  expected: 4

invariant time_stamp.MM_length_is_2:
  description: "ts('MM') is a 2-character zero-padded month"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: ["MM"]
  chain:
    - {get: length}
  expected: 2

invariant time_stamp.MM_DD_length_is_5:
  description: "ts('MM-DD') is 5 characters: 2 + dash + 2"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: ["MM-DD"]
  chain:
    - {get: length}
  expected: 5

invariant time_stamp.literal_at_separator_left_alone:
  description: "Non-token characters in the pattern are kept verbatim"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: ["[fixed]"]
  chain: []
  expected: "[fixed]"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:38:28Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
