spec: functools_extra189
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.cmp_to_key and functools.reduce identity — functools.cmp_to_key.__name__=='cmp_to_key' (len=10); functools.cmp_to_key.__module__=='_functools' (C extension); functools.cmp_to_key.__qualname__=='cmp_to_key'; functools.cmp_to_key.__class__.__name__=='builtin_function_or_method'; functools.reduce.__name__=='reduce' (len=6); functools.reduce.__module__=='_functools' (C extension); functools.reduce.__qualname__=='reduce'; functools.reduce.__class__.__name__=='builtin_function_or_method'."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — cmp_to_key is implemented in the C extension _functools (not pure-Python Lib/functools.py); its __name__ is 'cmp_to_key', 10 characters. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is a C builtin exposed through the _functools C extension; its __module__ is '_functools', not 'functools'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — as a module-level C builtin, __qualname__ equals __name__ 'cmp_to_key'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin, so type(cmp_to_key).__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' — reduce is implemented in the C extension _functools; its __name__ is 'reduce', 6 characters. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce is a C builtin exposed through _functools; its __module__ is '_functools', not 'functools'. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' — as a module-level C builtin, __qualname__ equals __name__ 'reduce'. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin, so type(reduce).__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cmp_to_key __name__, __module__, __qualname__
#
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__name__.__len__() == 10
# functools.cmp_to_key.__module__ == '_functools'
# functools.cmp_to_key.__qualname__ == 'cmp_to_key'
#
# cmp_to_key is implemented in the C extension _functools (not pure-Python
# Lib/functools.py). It converts a comparison function (old-style, taking two
# arguments) into a key function suitable for use with sorted(). Its __name__
# is 'cmp_to_key' (10 chars) and __module__ is '_functools'.
# New to extra189.
# ---------------------------------------------------------------------------

table functools_extra189.cmp_to_key_identity:
  description: "functools.cmp_to_key.__name__=='cmp_to_key' len 10; __module__=='_functools' (C extension); __qualname__=='cmp_to_key'; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: functcmpreduce189

  columns: [id, function, args, expected, description]
  rows:
    - [cmptokey_name_eq,
       cmp_to_key.__name__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — cmp_to_key is a C builtin in _functools that converts old-style comparison functions into key functions; its __name__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra189"]
    - [cmptokey_name_len_10,
       cmp_to_key.__name__.__len__,
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — the name 'cmp_to_key' has exactly 10 characters: c-m-p-_-t-o-_-k-e-y; str.__len__() returns 10; new to extra189"]
    - [cmptokey_module_eq,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in the C extension _functools, not the pure-Python Lib/functools.py; its __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra189"]
    - [cmptokey_qualname_eq,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — as a module-level C builtin, __qualname__ equals __name__ 'cmp_to_key' (10 chars); str.__eq__('cmp_to_key') returns True; new to extra189"]

# ---------------------------------------------------------------------------
# Table 2: functools.cmp_to_key __class__ and functools.reduce __name__,
#          __module__
#
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__name__.__len__() == 6
# functools.reduce.__module__ == '_functools'
#
# Both cmp_to_key and reduce are C builtins so their __class__.__name__ is
# 'builtin_function_or_method'. reduce is the classic left-fold function
# ported from Python 2's built-in; its __name__ is 'reduce' (6 chars).
# New to extra189.
# ---------------------------------------------------------------------------

table functools_extra189.cmp_to_key_class_and_reduce_name:
  description: "functools.cmp_to_key.__class__.__name__=='builtin_function_or_method'; functools.reduce.__name__=='reduce' len 6; __module__=='_functools'; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: functcmpreduce189

  columns: [id, function, args, expected, description]
  rows:
    - [cmptokey_class_eq,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C builtin in _functools, so type(cmp_to_key).__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra189"]
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is the classic left-fold C builtin in _functools that applies a function of two arguments cumulatively to a sequence; its __name__ is 'reduce'; str.__eq__('reduce') returns True; new to extra189"]
    - [reduce_name_len_6,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — the name 'reduce' has exactly 6 characters: r-e-d-u-c-e; str.__len__() returns 6; new to extra189"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C builtin in the _functools extension, not the pure-Python functools module; its __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra189"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce __qualname__ and __class__
#
# functools.reduce.__qualname__ == 'reduce'
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
#
# reduce is a module-level C builtin so __qualname__ == __name__ == 'reduce'.
# Its __class__.__name__ is 'builtin_function_or_method', same as cmp_to_key.
# New to extra189.
# ---------------------------------------------------------------------------

table functools_extra189.reduce_qualname_and_class:
  description: "functools.reduce.__qualname__=='reduce' equals __name__; __class__.__name__=='builtin_function_or_method'; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: functcmpreduce189

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — as a module-level C builtin, __qualname__ equals __name__ 'reduce' (6 chars); str.__eq__('reduce') returns True; new to extra189"]
    - [reduce_qualname_len_6,
       reduce.__qualname__.__len__,
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — the qualname 'reduce' has exactly 6 characters, equal to the __name__ length; str.__len__() returns 6; new to extra189"]
    - [reduce_class_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin in _functools, so type(reduce).__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra189"]
    - [cmptokey_qualname_len_10,
       cmp_to_key.__qualname__.__len__,
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — cross-check: 'cmp_to_key' qualname is 10 chars (same as __name__) while 'reduce' qualname is 6 chars; confirmed by str.__len__(); new to extra189"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra189
# ---------------------------------------------------------------------------

invariant functools_extra189.cmp_to_key_name_is_cmp_to_key:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — C builtin in _functools that converts old-style comparison functions into key functions; __name__ is 'cmp_to_key' (10 chars); new to extra189"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra189.cmp_to_key_module_is_functools_c:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the C extension _functools, not pure-Python Lib/functools.py; its __module__ is '_functools'; new to extra189"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra189.cmp_to_key_qualname_equals_name:
  description: "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — module-level C builtin has __qualname__ == __name__ == 'cmp_to_key' (10 chars); new to extra189"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra189.cmp_to_key_class_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin (not a Python function), so type(cmp_to_key).__name__ == 'builtin_function_or_method'; new to extra189"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra189.reduce_name_is_reduce:
  description: "functools.reduce.__name__ == 'reduce' — classic left-fold C builtin in _functools that applies a function cumulatively to a sequence; __name__ is 'reduce' (6 chars); new to extra189"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra189.reduce_module_is_functools_c:
  description: "functools.reduce.__module__ == '_functools' — reduce is a C builtin in the _functools C extension, not the pure-Python functools module; its __module__ is '_functools'; new to extra189"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra189.reduce_qualname_equals_name:
  description: "functools.reduce.__qualname__ == 'reduce' — module-level C builtin has __qualname__ == __name__ == 'reduce' (6 chars); new to extra189"
  category: identity
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra189.reduce_class_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin (not a Python function), so type(reduce).__name__ == 'builtin_function_or_method'; new to extra189"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
