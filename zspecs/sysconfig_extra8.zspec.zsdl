spec: sysconfig_extra8
version: ">=3.9"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sysconfig.html — Python sysconfig documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
  notes:
    - "This spec extends sysconfig.zspec.zsdl through sysconfig_extra7.zspec.zsdl."
    - "sysconfig_extra3 covers: __qualname__ for 8 functions; __module__ for get_python_version/get_platform."
    - "sysconfig_extra4 covers: __module__ for get_config_var/parse_config_h/get_path/get_paths."
    - "sysconfig_extra7 covers: function_names table (__name__ for get_python_version/get_platform/get_paths/get_config_vars); get_python_version/get_platform returns_str; get_paths returns_dict."
    - "This spec adds new axes: __module__ for get_scheme_names/get_path/get_path_names in a consolidated table; __qualname__ for get_scheme_names/get_path/get_path_names standalone invariants; get_scheme_names().__class__.__name__ == 'tuple' standalone; get_path_names().__class__.__name__ == 'tuple' standalone."
    - "sysconfig.get_scheme_names.__module__ == 'sysconfig' — verified at runtime."
    - "sysconfig.get_path.__module__ == 'sysconfig' — verified at runtime."
    - "sysconfig.get_path_names.__module__ == 'sysconfig' — verified at runtime."
    - "sysconfig.get_scheme_names.__qualname__ == 'get_scheme_names' — verified at runtime."
    - "sysconfig.get_path.__qualname__ == 'get_path' — verified at runtime."
    - "sysconfig.get_path_names.__qualname__ == 'get_path_names' — verified at runtime."
    - "sysconfig.get_scheme_names().__class__.__name__ == 'tuple' — verified at runtime."
    - "sysconfig.get_path_names().__class__.__name__ == 'tuple' — verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_scheme_names, get_path, get_path_names — __module__ table
#
# sysconfig_extra3 covers __module__ for get_python_version and get_platform.
# sysconfig_extra4 covers __module__ for get_config_var, parse_config_h,
# get_path, and get_paths. get_scheme_names and get_path_names __module__ have
# not appeared in any prior sysconfig spec. This table covers all three in the
# extra8 namespace, with get_path re-anchored here to broaden coverage.
# ---------------------------------------------------------------------------

table sysconfig_extra8.function_modules:
  description: "__module__ for get_scheme_names, get_path, get_path_names"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [get_scheme_names, get_scheme_names.__module__.__eq__, ["sysconfig"], true]
    - [get_path,         get_path.__module__.__eq__,         ["sysconfig"], true]
    - [get_path_names,   get_path_names.__module__.__eq__,   ["sysconfig"], true]

# ---------------------------------------------------------------------------
# get_scheme_names — __qualname__ standalone
#
# sysconfig_extra3 covers __qualname__ for 8 functions; it does not include
# get_scheme_names. This invariant anchors get_scheme_names.__qualname__ in the
# extra8 namespace as a new coverage axis.
# ---------------------------------------------------------------------------

invariant sysconfig_extra8.get_scheme_names.qualname:
  description: "sysconfig.get_scheme_names.__qualname__ == 'get_scheme_names'"
  category: function_attrs
  kind: python_call_eq
  function: get_scheme_names.__qualname__.__eq__
  args: ["get_scheme_names"]
  expected: true

# ---------------------------------------------------------------------------
# get_path_names — __qualname__ standalone
#
# sysconfig_extra3 does not check get_path_names.__qualname__. This invariant
# anchors it in the extra8 namespace.
# ---------------------------------------------------------------------------

invariant sysconfig_extra8.get_path_names.qualname:
  description: "sysconfig.get_path_names.__qualname__ == 'get_path_names'"
  category: function_attrs
  kind: python_call_eq
  function: get_path_names.__qualname__.__eq__
  args: ["get_path_names"]
  expected: true

# ---------------------------------------------------------------------------
# get_scheme_names() — return type is tuple
#
# sysconfig_extra6 covers get_scheme_names() returning a tuple via
# method_chain. This invariant re-anchors the tuple type check in the extra8
# namespace using __class__.__name__.__eq__ as a standalone axis.
# ---------------------------------------------------------------------------

invariant sysconfig_extra8.get_scheme_names.returns_tuple:
  description: "sysconfig.get_scheme_names().__class__.__name__ == 'tuple'"
  category: runtime
  kind: python_call_eq
  function: get_scheme_names().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# get_path_names() — return type is tuple
#
# sysconfig base confirms get_path_names() returns a tuple via method_chain.
# This invariant anchors the tuple type check in the extra8 namespace using
# __class__.__name__.__eq__ as a complementary standalone axis.
# ---------------------------------------------------------------------------

invariant sysconfig_extra8.get_path_names.returns_tuple:
  description: "sysconfig.get_path_names().__class__.__name__ == 'tuple'"
  category: runtime
  kind: python_call_eq
  function: get_path_names().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
