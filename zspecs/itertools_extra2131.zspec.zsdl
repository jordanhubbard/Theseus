spec: itertools_extra2131
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2131 (_extra2131): exception protocol dict-presence checks — __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__ for itertools types."
    - "Theme: exception protocol dict-presence — checking whether exception-related attributes are defined at the class level in __dict__ for itertools C extension iterator types."
    - "itertools has no exception types. All iterator types are C extension types implementing the iterator protocol."
    - "None of the itertools iterator types define any exception-protocol attributes in their class __dict__."
    - "accumulate, chain, combinations, combinations_with_replacement, compress, count, cycle, dropwhile, filterfalse, groupby, islice, pairwise, permutations, product, repeat, starmap, takewhile, zip_longest are all C extension iterator types."
    - "_tee, _tee_dataobject, _grouper are internal C extension types used by itertools.tee."
    - "Exception protocol attributes are instance-level attributes set on BaseException instances, not class-level entries in any itertools type."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: exception protocol dict-presence for core itertools iterator types
#
# accumulate, chain, compress, count, cycle, dropwhile, filterfalse check.
# All are C extension iterator types. None are exception types.
# All exception-protocol attributes absent from class __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2131.exception_protocol:
  description: "itertools iterator types exception-protocol attribute dict-presence checks — __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2131

  columns: [id, function, args, expected]
  rows:
    - ["it2131001", "itertools.accumulate.__dict__.__contains__",  ["__cause__"],            false]
    - ["it2131002", "itertools.accumulate.__dict__.__contains__",  ["__context__"],          false]
    - ["it2131003", "itertools.accumulate.__dict__.__contains__",  ["__traceback__"],        false]
    - ["it2131004", "itertools.accumulate.__dict__.__contains__",  ["__suppress_context__"], false]
    - ["it2131005", "itertools.accumulate.__dict__.__contains__",  ["__notes__"],            false]
