spec: io_extra143
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.TextIOBase and io.IOBase abstract base class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and method descriptor identity (__qualname__, __class__.__name__) for their C-inherited methods."
    - "io.TextIOBase.__name__ == 'TextIOBase' (length 10) — the ABC for text I/O streams, defined in the pure Python io module."
    - "io.TextIOBase.__module__ == 'io' (length 2) — the ABC wrapper lives in the Python io module."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' (length 11) — the ABC directly wraps the C extension _TextIOBase from _io."
    - "io.TextIOBase.__mro__.__len__() == 5 — MRO is [TextIOBase, _TextIOBase, IOBase, _IOBase, object]."
    - "io.TextIOBase.__class__.__name__ == 'ABCMeta' (length 7) — TextIOBase is an ABC; its metaclass is ABCMeta."
    - "io.IOBase.__name__ == 'IOBase' (length 6) — the root ABC for all I/O streams."
    - "io.IOBase.__module__ == 'io' (length 2) — the ABC wrapper lives in the Python io module."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' (length 7) — the ABC directly wraps the C extension _IOBase."
    - "io.IOBase.__mro__.__len__() == 3 — MRO is [IOBase, _IOBase, object]; only one C layer since IOBase has no Python parent."
    - "io.IOBase.__class__.__name__ == 'ABCMeta' (length 7) — IOBase is an ABC."
    - "TextIOBase method descriptors read/readline/write carry qualnames from the underlying C type _TextIOBase."
    - "IOBase method descriptors close/flush/readline/readlines/writelines/seek/tell/truncate carry qualnames from _IOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOBase class identity
# TextIOBase is an ABC in the pure Python io module.
# __name__ == 'TextIOBase' (10), __module__ == 'io' (2),
# __qualname__ == 'TextIOBase' (10).
# __bases__[0].__name__ == '_TextIOBase' (11). MRO length == 5.
# __class__.__name__ == 'ABCMeta' (7; not 'type').
# ---------------------------------------------------------------------------

table io_extra143.TextIOBase_class_identity:
  description: "io.TextIOBase class identity: __name__='TextIOBase' (10), __module__='io' (2), __qualname__='TextIOBase' (10), __bases__[0].__name__='_TextIOBase' (11), __mro__.__len__()==5, __class__.__name__='ABCMeta'"
  kind: python_call_eq
  category: class_identity
  id_prefix: iotib143

  columns: [id, function, args, expected]
  rows:
    - [tib_name_eq,      TextIOBase.__name__.__eq__,                   ["TextIOBase"],   true]
    - [tib_name_len,     TextIOBase.__name__.__len__,                  [],              10]
    - [tib_module_eq,    TextIOBase.__module__.__eq__,                 ["io"],          true]
    - [tib_module_not,   TextIOBase.__module__.__eq__,                 ["_io"],         false]
    - [tib_module_len,   TextIOBase.__module__.__len__,                [],              2]
    - [tib_qualname_eq,  TextIOBase.__qualname__.__eq__,               ["TextIOBase"],  true]
    - [tib_qualname_len, TextIOBase.__qualname__.__len__,              [],              10]
    - [tib_base_eq,      "TextIOBase.__bases__[0].__name__.__eq__",    ["_TextIOBase"], true]
    - [tib_base_len,     "TextIOBase.__bases__[0].__name__.__len__",   [],              11]
    - [tib_mro_len,      TextIOBase.__mro__.__len__,                   [],              5]
    - [tib_cls_eq,       TextIOBase.__class__.__name__.__eq__,         ["ABCMeta"],     true]
    - [tib_cls_not_type, TextIOBase.__class__.__name__.__eq__,         ["type"],        false]

# ---------------------------------------------------------------------------
# io.TextIOBase method descriptor identity
# read, readline, write inherit from _TextIOBase (C extension type).
# seek and tell inherit from _IOBase (the common C base).
# read: '_TextIOBase.read' (16), readline: '_TextIOBase.readline' (20),
# write: '_TextIOBase.write' (17), seek: '_IOBase.seek' (12), tell: '_IOBase.tell' (12).
# ---------------------------------------------------------------------------

table io_extra143.TextIOBase_method_descriptors:
  description: "io.TextIOBase method descriptor __class__.__name__ and __qualname__: read/readline/write come from _TextIOBase; seek/tell come from _IOBase"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iotib143

  columns: [id, function, args, expected]
  rows:
    - [read_cls_eq,      TextIOBase.read.__class__.__name__.__eq__,       ["method_descriptor"],    true]
    - [readline_cls_eq,  TextIOBase.readline.__class__.__name__.__eq__,   ["method_descriptor"],    true]
    - [write_cls_eq,     TextIOBase.write.__class__.__name__.__eq__,      ["method_descriptor"],    true]
    - [seek_cls_eq,      TextIOBase.seek.__class__.__name__.__eq__,       ["method_descriptor"],    true]
    - [tell_cls_eq,      TextIOBase.tell.__class__.__name__.__eq__,       ["method_descriptor"],    true]
    - [read_qn_eq,       TextIOBase.read.__qualname__.__eq__,             ["_TextIOBase.read"],     true]
    - [read_qn_len,      TextIOBase.read.__qualname__.__len__,            [],                       16]
    - [readline_qn_eq,   TextIOBase.readline.__qualname__.__eq__,         ["_TextIOBase.readline"], true]
    - [readline_qn_len,  TextIOBase.readline.__qualname__.__len__,        [],                       20]
    - [write_qn_eq,      TextIOBase.write.__qualname__.__eq__,            ["_TextIOBase.write"],    true]
    - [write_qn_len,     TextIOBase.write.__qualname__.__len__,           [],                       17]
    - [seek_qn_eq,       TextIOBase.seek.__qualname__.__eq__,             ["_IOBase.seek"],         true]
    - [tell_qn_eq,       TextIOBase.tell.__qualname__.__eq__,             ["_IOBase.tell"],         true]

# ---------------------------------------------------------------------------
# io.IOBase class identity
# IOBase is the root ABC for all I/O streams.
# __name__ == 'IOBase' (6), __module__ == 'io' (2), __qualname__ == 'IOBase' (6).
# __bases__[0].__name__ == '_IOBase' (7). MRO length == 3.
# __class__.__name__ == 'ABCMeta' (7).
# ---------------------------------------------------------------------------

table io_extra143.IOBase_class_identity:
  description: "io.IOBase class identity: __name__='IOBase' (6), __module__='io' (2), __qualname__='IOBase' (6), __bases__[0].__name__='_IOBase' (7), __mro__.__len__()==3, __class__.__name__='ABCMeta'"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioiob143

  columns: [id, function, args, expected]
  rows:
    - [iob_name_eq,      IOBase.__name__.__eq__,                   ["IOBase"],  true]
    - [iob_name_len,     IOBase.__name__.__len__,                  [],          6]
    - [iob_module_eq,    IOBase.__module__.__eq__,                 ["io"],      true]
    - [iob_module_len,   IOBase.__module__.__len__,                [],          2]
    - [iob_qualname_eq,  IOBase.__qualname__.__eq__,               ["IOBase"],  true]
    - [iob_qualname_len, IOBase.__qualname__.__len__,              [],          6]
    - [iob_base_eq,      "IOBase.__bases__[0].__name__.__eq__",    ["_IOBase"], true]
    - [iob_base_len,     "IOBase.__bases__[0].__name__.__len__",   [],          7]
    - [iob_mro_len,      IOBase.__mro__.__len__,                   [],          3]
    - [iob_cls_eq,       IOBase.__class__.__name__.__eq__,         ["ABCMeta"], true]
    - [iob_cls_not_type, IOBase.__class__.__name__.__eq__,         ["type"],    false]

# ---------------------------------------------------------------------------
# io.IOBase method descriptor identity
# All IOBase methods inherit from _IOBase (C extension type).
# close: '_IOBase.close' (13), flush: '_IOBase.flush' (13),
# readline: '_IOBase.readline' (16), readlines: '_IOBase.readlines' (17),
# writelines: '_IOBase.writelines' (18), seek: '_IOBase.seek' (12),
# tell: '_IOBase.tell' (12), truncate: '_IOBase.truncate' (16).
# ---------------------------------------------------------------------------

table io_extra143.IOBase_method_descriptors:
  description: "io.IOBase method descriptor __class__.__name__ and __qualname__: all methods are 'method_descriptor' with qualnames from _IOBase"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: ioiob143

  columns: [id, function, args, expected]
  rows:
    - [close_cls_eq,      IOBase.close.__class__.__name__.__eq__,      ["method_descriptor"],    true]
    - [flush_cls_eq,      IOBase.flush.__class__.__name__.__eq__,      ["method_descriptor"],    true]
    - [readline_cls_eq,   IOBase.readline.__class__.__name__.__eq__,   ["method_descriptor"],    true]
    - [readlines_cls_eq,  IOBase.readlines.__class__.__name__.__eq__,  ["method_descriptor"],    true]
    - [close_qn_eq,       IOBase.close.__qualname__.__eq__,            ["_IOBase.close"],        true]
    - [close_qn_len,      IOBase.close.__qualname__.__len__,           [],                       13]
    - [flush_qn_eq,       IOBase.flush.__qualname__.__eq__,            ["_IOBase.flush"],        true]
    - [flush_qn_len,      IOBase.flush.__qualname__.__len__,           [],                       13]
    - [readline_qn_eq,    IOBase.readline.__qualname__.__eq__,         ["_IOBase.readline"],     true]
    - [readline_qn_len,   IOBase.readline.__qualname__.__len__,        [],                       16]
    - [readlines_qn_len,  IOBase.readlines.__qualname__.__len__,       [],                       17]
    - [writelines_qn_len, IOBase.writelines.__qualname__.__len__,      [],                       18]
    - [seek_qn_len,       IOBase.seek.__qualname__.__len__,            [],                       12]
    - [tell_qn_len,       IOBase.tell.__qualname__.__len__,            [],                       12]
    - [truncate_qn_len,   IOBase.truncate.__qualname__.__len__,        [],                       16]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra143.TextIOBase.name_is_TextIOBase:
  description: "io.TextIOBase.__name__ == 'TextIOBase' (length 10; the abstract base class for text I/O streams, defined in the pure Python io module)"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true

invariant io_extra143.TextIOBase.module_is_io:
  description: "io.TextIOBase.__module__ == 'io' (length 2; TextIOBase is the ABC wrapper in io, not the C-level _TextIOBase from _io)"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra143.TextIOBase.metaclass_is_ABCMeta:
  description: "io.TextIOBase.__class__.__name__ == 'ABCMeta' (length 7; TextIOBase is constructed with ABCMeta, distinguishing it from concrete C types whose metaclass is plain 'type')"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra143.TextIOBase.mro_len_5:
  description: "io.TextIOBase.__mro__.__len__() == 5 (MRO is [TextIOBase, _TextIOBase, IOBase, _IOBase, object]; two ABC layers plus two C layers plus object)"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra143.IOBase.mro_len_3:
  description: "io.IOBase.__mro__.__len__() == 3 (MRO is [IOBase, _IOBase, object]; only one C layer since IOBase is the root with no Python parent above it)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__mro__.__len__
  args: []
  expected: 3
