spec: io3466
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (io3466): __iter__, __next__, __len__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __iter__/__next__/__len__ dict-presence (iterator/sequence protocol)."
    - "No io class defines __iter__ in its own __dict__: io stream classes do not define the iterator protocol in their own __dict__s."
    - "No io class defines __next__ in its own __dict__: io stream classes do not define the iterator advancement method in their own __dict__s."
    - "No io class defines __len__ in its own __dict__: io stream classes are I/O abstractions without a defined length; __len__ is not present in any io class __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all iterator/sequence protocols absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# No io class defines __iter__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions; the iterator protocol
# is not defined in any io class's own __dict__.
# ---------------------------------------------------------------------------

table io3466.iter:
  description: "io types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3466

  columns: [id, function, args, expected]
  rows:
    - ["io3466001", operator.contains, [io.RawIOBase.__dict__,       "__iter__"], false]
    - ["io3466002", operator.contains, [io.BufferedIOBase.__dict__,  "__iter__"], false]
