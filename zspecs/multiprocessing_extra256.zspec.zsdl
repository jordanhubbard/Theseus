spec: multiprocessing_extra256
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Process methods are defined on BaseProcess (in multiprocessing.process)."
    - "All method __qualname__ values carry the 'BaseProcess.' prefix, not 'Process.'."
    - "All method __module__ values are 'multiprocessing.process'."
    - "multiprocessing.Process.pid is a property; its fget.__name__ is 'ident' (internal name), not 'pid'."
    - "multiprocessing.Process.pid.fget.__qualname__ == 'BaseProcess.ident'."
    - "multiprocessing.Process.name.fget.__name__ == 'name'; daemon.fget.__name__ == 'daemon'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Process method __name__ — table
#
# Six methods of multiprocessing.Process: start, join, terminate, kill,
# is_alive, run. All are defined on BaseProcess and inherited.
# ---------------------------------------------------------------------------

table multiprocessing_extra256.process_method_names:
  description: "multiprocessing.Process methods report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mname

  columns: [id, function, args, expected, description]
  rows:
    - [start,    Process.start.__name__.__eq__,    ["start"],    true, "Process.start.__name__ == 'start'"]
    - [join,     Process.join.__name__.__eq__,     ["join"],     true, "Process.join.__name__ == 'join'"]
    - [terminate, Process.terminate.__name__.__eq__, ["terminate"], true, "Process.terminate.__name__ == 'terminate'"]
    - [kill,     Process.kill.__name__.__eq__,     ["kill"],     true, "Process.kill.__name__ == 'kill'"]
    - [is_alive, Process.is_alive.__name__.__eq__, ["is_alive"], true, "Process.is_alive.__name__ == 'is_alive'"]
    - [run,      Process.run.__name__.__eq__,      ["run"],      true, "Process.run.__name__ == 'run'"]

# ---------------------------------------------------------------------------
# Process method __qualname__ — table
#
# All six methods carry the 'BaseProcess.' prefix in their __qualname__
# because they are defined on BaseProcess, not on the context-specific
# Process subclass.
# ---------------------------------------------------------------------------

table multiprocessing_extra256.process_method_qualnames:
  description: "multiprocessing.Process methods report 'BaseProcess.'-prefixed __qualname__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mqualname

  columns: [id, function, args, expected, description]
  rows:
    - [start,    Process.start.__qualname__.__eq__,    ["BaseProcess.start"],    true, "Process.start.__qualname__ == 'BaseProcess.start'"]
    - [join,     Process.join.__qualname__.__eq__,     ["BaseProcess.join"],     true, "Process.join.__qualname__ == 'BaseProcess.join'"]
    - [terminate, Process.terminate.__qualname__.__eq__, ["BaseProcess.terminate"], true, "Process.terminate.__qualname__ == 'BaseProcess.terminate'"]
    - [kill,     Process.kill.__qualname__.__eq__,     ["BaseProcess.kill"],     true, "Process.kill.__qualname__ == 'BaseProcess.kill'"]
    - [is_alive, Process.is_alive.__qualname__.__eq__, ["BaseProcess.is_alive"], true, "Process.is_alive.__qualname__ == 'BaseProcess.is_alive'"]
    - [run,      Process.run.__qualname__.__eq__,      ["BaseProcess.run"],      true, "Process.run.__qualname__ == 'BaseProcess.run'"]

# ---------------------------------------------------------------------------
# Process method __class__.__name__ and __module__ — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra256.start.class_name:
  description: "multiprocessing.Process.start.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Process.start.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra256.start.module:
  description: "multiprocessing.Process.start.__module__ == 'multiprocessing.process'"
  category: identity
  kind: python_call_eq
  function: Process.start.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# Process properties — standalone invariants
#
# name and daemon properties have fget.__name__ matching the property name.
# pid is a special case: its fget.__name__ is 'ident' (internal implementation
# name), not 'pid'. The __qualname__ for all three fgets uses 'BaseProcess.'
# prefix.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra256.name_fget.name:
  description: "multiprocessing.Process.name.fget.__name__ == 'name'"
  category: identity
  kind: python_call_eq
  function: Process.name.fget.__name__.__eq__
  args: ["name"]
  expected: true

invariant multiprocessing_extra256.name_fget.qualname:
  description: "multiprocessing.Process.name.fget.__qualname__ == 'BaseProcess.name'"
  category: identity
  kind: python_call_eq
  function: Process.name.fget.__qualname__.__eq__
  args: ["BaseProcess.name"]
  expected: true

invariant multiprocessing_extra256.daemon_fget.name:
  description: "multiprocessing.Process.daemon.fget.__name__ == 'daemon'"
  category: identity
  kind: python_call_eq
  function: Process.daemon.fget.__name__.__eq__
  args: ["daemon"]
  expected: true

invariant multiprocessing_extra256.daemon_fget.qualname:
  description: "multiprocessing.Process.daemon.fget.__qualname__ == 'BaseProcess.daemon'"
  category: identity
  kind: python_call_eq
  function: Process.daemon.fget.__qualname__.__eq__
  args: ["BaseProcess.daemon"]
  expected: true

invariant multiprocessing_extra256.pid_fget.name:
  description: "multiprocessing.Process.pid.fget.__name__ == 'ident' — internal implementation name"
  category: identity
  kind: python_call_eq
  function: Process.pid.fget.__name__.__eq__
  args: ["ident"]
  expected: true

invariant multiprocessing_extra256.pid_fget.qualname:
  description: "multiprocessing.Process.pid.fget.__qualname__ == 'BaseProcess.ident'"
  category: identity
  kind: python_call_eq
  function: Process.pid.fget.__qualname__.__eq__
  args: ["BaseProcess.ident"]
  expected: true
