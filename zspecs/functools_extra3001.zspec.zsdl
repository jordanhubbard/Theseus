spec: ft3001
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (ft3001): __getitem__, __setitem__, __delitem__ dict-presence checks for functools types."
    - "functools classes are not mappings or sequences — none define item access or mutation operators."
    - "Verified types: functools.partial, functools.partialmethod, functools.cached_property, functools._lru_cache_wrapper, functools._CacheInfo, functools.singledispatch."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by functools.lru_cache()."
    - "functools._CacheInfo is the namedtuple class for lru_cache statistics."
    - "functools.singledispatch is the dispatch decorator function; its __dict__ is that of a plain function."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3001.getitem:
  description: "functools types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3001
  columns: [id, function, args, expected]
  rows:
    - ["ft3001001", operator.contains, [functools.partial.__dict__,              "__getitem__"], false]
    - ["ft3001002", operator.contains, [functools.partialmethod.__dict__,        "__getitem__"], false]
    - ["ft3001003", operator.contains, [functools.cached_property.__dict__,      "__getitem__"], false]
    - ["ft3001004", operator.contains, [functools._lru_cache_wrapper.__dict__,   "__getitem__"], false]
    - ["ft3001005", operator.contains, [functools._CacheInfo.__dict__,           "__getitem__"], false]
    - ["ft3001006", operator.contains, [functools.singledispatch.__dict__,       "__getitem__"], false]

