spec: pathlib_extra1906
version: ">=3.9"
backend: python_module(pathlib)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath, pathlib.WindowsPath are all Python classes defined in pathlib."
    - "None of these pathlib types define __reversed__, __missing__, or __match_args__ in their own __dict__."
    - "None define __abstractmethods__ or __type_params__ in their own __dict__."
    - "pathlib.PurePath.__qualname__ == 'PurePath' — top-level Python class."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' — top-level Python class."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath' — top-level Python class."
    - "pathlib.Path.__qualname__ == 'Path' — top-level Python class."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath' — top-level Python class."
    - "pathlib.WindowsPath.__qualname__ == 'WindowsPath' — top-level Python class."
    - "All pathlib classes have __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table pathlib_extra1906.reversed_protocol:
  description: "pathlib types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: reversed_protocol
  id_prefix: pl1906

  columns: [id, function, args, expected]
  rows:
    - ["pl1906001", "pathlib.PurePath.__dict__.__contains__", ["__reversed__"], false]
    - ["pl1906002", "pathlib.PurePosixPath.__dict__.__contains__", ["__reversed__"], false]
    - ["pl1906003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reversed__"], false]
    - ["pl1906004", "pathlib.Path.__dict__.__contains__", ["__reversed__"], false]
    - ["pl1906005", "pathlib.PosixPath.__dict__.__contains__", ["__reversed__"], false]
    - ["pl1906006", "pathlib.WindowsPath.__dict__.__contains__", ["__reversed__"], false]
    - ["pl1906007", "pathlib.PurePath.__dict__.__contains__", ["__missing__"], false]
    - ["pl1906008", "pathlib.Path.__dict__.__contains__", ["__missing__"], false]

