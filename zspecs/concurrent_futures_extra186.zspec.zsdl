spec: concurrent_futures_extra186
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.cancel.__name__ == 'cancel' (len=6)"
    - "concurrent.futures.Future.cancelled.__name__ == 'cancelled' (len=9)"
    - "concurrent.futures.Future.running.__name__ == 'running' (len=7)"
    - "concurrent.futures.Future.done.__name__ == 'done' (len=4)"
    - "concurrent.futures.Future.result.__name__ == 'result' (len=6)"
    - "concurrent.futures.Future.exception.__name__ == 'exception' (len=9)"
    - "concurrent.futures.Future.add_done_callback.__name__ == 'add_done_callback' (len=17)"
    - "Length ordering: done(4) < cancel(6)==result(6) < running(7) < cancelled(9)==exception(9) < add_done_callback(17)"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

