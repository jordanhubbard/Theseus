table functools_extra1216.reduce_module_qualname_class:
  description: "functools.reduce __module__, __qualname__, and __class__.__name__ identity"
  kind: python_call_eq
  category: reduce_module_qualname_class
  id_prefix: fn1216rm
  columns: [id, function, args, expected]
  rows:
    - [fn1216rm001, functools.reduce.__module__.__eq__,           ["_functools"],                  true]
    - [fn1216rm002, functools.reduce.__qualname__.__eq__,         ["reduce"],                      true]
    - [fn1216rm003, functools.reduce.__class__.__name__.__eq__,   ["builtin_function_or_method"],  true]
    - [fn1216rm004, functools.lru_cache.__module__.__eq__,        ["functools"],                   true]
    - [fn1216rm005, functools.lru_cache.__qualname__.__eq__,      ["lru_cache"],                   true]
    - [fn1216rm006, functools.lru_cache.__class__.__name__.__eq__, ["function"],                   true]
    - [fn1216rm007, functools.cache.__module__.__eq__,            ["functools"],                   true]
    - [fn1216rm008, functools.cache.__qualname__.__eq__,          ["cache"],                       true]

