spec: pathlib_extra469
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.Path method identity checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All methods listed are public API on pathlib.Path and have been stable since Python 3.6+"
    - "Method __name__ attributes reflect the unbound function name on the class"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra469.method_names:
  description: "pathlib.Path method name identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: PLM

  columns: [id, function, args, expected]
  rows:
    - [PLM001, pathlib.Path.joinpath.__name__.__eq__, ["joinpath"], true]
    - [PLM002, pathlib.Path.iterdir.__name__.__eq__, ["iterdir"], true]
    - [PLM003, pathlib.Path.glob.__name__.__eq__, ["glob"], true]
    - [PLM004, pathlib.Path.rglob.__name__.__eq__, ["rglob"], true]
    - [PLM005, pathlib.Path.stat.__name__.__eq__, ["stat"], true]
    - [PLM006, pathlib.Path.exists.__name__.__eq__, ["exists"], true]
    - [PLM007, pathlib.Path.is_file.__name__.__eq__, ["is_file"], true]
    - [PLM008, pathlib.Path.is_dir.__name__.__eq__, ["is_dir"], true]
    - [PLM009, pathlib.Path.is_symlink.__name__.__eq__, ["is_symlink"], true]
    - [PLM010, pathlib.Path.mkdir.__name__.__eq__, ["mkdir"], true]
    - [PLM011, pathlib.Path.rmdir.__name__.__eq__, ["rmdir"], true]
    - [PLM012, pathlib.Path.unlink.__name__.__eq__, ["unlink"], true]
    - [PLM013, pathlib.Path.rename.__name__.__eq__, ["rename"], true]
    - [PLM014, pathlib.Path.resolve.__name__.__eq__, ["resolve"], true]
    - [PLM015, pathlib.Path.read_text.__name__.__eq__, ["read_text"], true]
    - [PLM016, pathlib.Path.write_text.__name__.__eq__, ["write_text"], true]
