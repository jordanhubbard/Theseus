spec: socket_extra1096
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket.__new__ qualname, socket.setdefaulttimeout/getdefaulttimeout qualname/module/class, socket.inet_aton/inet_ntoa/htons qualname and module"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1096.socket_new_qualname:
  description: "socket.socket.__new__ qualname and class name identity"
  kind: python_call_eq
  category: socket_new_qualname
  id_prefix: sk1096nq
  columns: [id, function, args, expected]
  rows:
    - [sk1096nq001, socket.socket.__new__.__qualname__.__eq__,              ["socket.__new__"],  true]
    - [sk1096nq002, socket.socket.__new__.__qualname__.__class__.__name__.__eq__, ["str"],       true]
    - [sk1096nq003, socket.socket.__new__.__class__.__name__.__eq__,        ["slot_wrapper"],    true]
    - [sk1096nq004, socket.socket.__new__.__module__.__eq__,                ["_socket"],         true]
    - [sk1096nq005, socket.socket.__new__.__module__.__class__.__name__.__eq__, ["str"],         true]
    - [sk1096nq006, socket.socket.__str__.__qualname__.__eq__,              ["socket.__str__"],  true]
    - [sk1096nq007, socket.socket.__str__.__qualname__.__class__.__name__.__eq__, ["str"],       true]
    - [sk1096nq008, socket.socket.__str__.__class__.__name__.__eq__,        ["slot_wrapper"],    true]

table socket_extra1096.timeout_functions_qualname_module:
  description: "socket.setdefaulttimeout and socket.getdefaulttimeout qualname, module, class identity"
  kind: python_call_eq
  category: timeout_function_attrs
  id_prefix: sk1096tf
  columns: [id, function, args, expected]
  rows:
    - [sk1096tf001, socket.setdefaulttimeout.__qualname__.__eq__,              ["setdefaulttimeout"],              true]
    - [sk1096tf002, socket.getdefaulttimeout.__qualname__.__eq__,              ["getdefaulttimeout"],              true]
    - [sk1096tf003, socket.setdefaulttimeout.__module__.__eq__,                ["socket"],                        true]
    - [sk1096tf004, socket.getdefaulttimeout.__module__.__eq__,                ["socket"],                        true]
    - [sk1096tf005, socket.setdefaulttimeout.__class__.__name__.__eq__,        ["builtin_function_or_method"],    true]
    - [sk1096tf006, socket.getdefaulttimeout.__class__.__name__.__eq__,        ["builtin_function_or_method"],    true]
    - [sk1096tf007, socket.setdefaulttimeout.__qualname__.__class__.__name__.__eq__, ["str"],                     true]
    - [sk1096tf008, socket.getdefaulttimeout.__qualname__.__class__.__name__.__eq__, ["str"],                     true]
    - [sk1096tf009, socket.setdefaulttimeout.__module__.__class__.__name__.__eq__,   ["str"],                     true]

table socket_extra1096.inet_and_htons_qualname_module:
