    - [sk1096ih002, socket.inet_ntoa.__qualname__.__eq__,              ["inet_ntoa"],                     true]
    - [sk1096ih003, socket.htons.__qualname__.__eq__,                  ["htons"],                         true]
    - [sk1096ih004, socket.inet_aton.__module__.__eq__,                ["socket"],                        true]
    - [sk1096ih005, socket.inet_ntoa.__module__.__eq__,                ["socket"],                        true]
    - [sk1096ih006, socket.htons.__module__.__eq__,                    ["socket"],                        true]
    - [sk1096ih007, socket.inet_aton.__class__.__name__.__eq__,        ["builtin_function_or_method"],    true]
    - [sk1096ih008, socket.inet_ntoa.__class__.__name__.__eq__,        ["builtin_function_or_method"],    true]
