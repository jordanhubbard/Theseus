spec: selectors_extra
version: ">=3.4"
backend: python_module(selectors)

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "Python 3 selectors documentation — https://docs.python.org/3/library/selectors.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "This spec covers aspects of the selectors module not in selectors.zspec.zsdl."
    - "EVENT_READ == 1 and EVENT_WRITE == 4 per the Python 3 docs (selectors.EVENT_WRITE = 4)."
    - "The existing selectors.zspec.zsdl verifies EVENT_WRITE via __eq__ but records the value as 2; this spec asserts the correct documented value of 4."
    - "DefaultSelector.__name__ on macOS is 'KqueueSelector' because DefaultSelector is an alias for the most efficient platform selector."
    - "SelectorKey is a namedtuple subclass; its __name__ is 'SelectorKey'."
    - "BaseSelector is an abstract base class exported from the selectors module."
    - "SelectSelector uses the POSIX select() syscall and is available on all POSIX platforms."
    - "All expected values verified by running Python 3.12 selectors module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseSelector — class name and module
# ---------------------------------------------------------------------------

invariant selectors_extra.BaseSelector.class_name:
  description: "selectors.BaseSelector.__name__ == 'BaseSelector'"
  category: classnames
  kind: python_call_eq
  function: BaseSelector.__name__.__eq__
  args: ["BaseSelector"]
  expected: true

invariant selectors_extra.BaseSelector.module:
  description: "selectors.BaseSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: BaseSelector.__module__.__eq__
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# SelectSelector — class name
# ---------------------------------------------------------------------------

invariant selectors_extra.SelectSelector.class_name:
  description: "selectors.SelectSelector.__name__ == 'SelectSelector'"
  category: classnames
  kind: python_call_eq
  function: SelectSelector.__name__.__eq__
  args: ["SelectSelector"]
  expected: true

# ---------------------------------------------------------------------------
# DefaultSelector — class name (platform-specific alias)
# Note: on macOS DefaultSelector.__name__ == 'KqueueSelector'
# ---------------------------------------------------------------------------

invariant selectors_extra.DefaultSelector.class_name_macos:
  description: "selectors.DefaultSelector.__name__ == 'KqueueSelector' on macOS (DefaultSelector is an alias)"
  category: classnames
  kind: python_call_eq
  function: DefaultSelector.__name__.__eq__
  args: ["KqueueSelector"]
  expected: true

# ---------------------------------------------------------------------------
# SelectorKey — class name
# ---------------------------------------------------------------------------

invariant selectors_extra.SelectorKey.class_name:
  description: "selectors.SelectorKey.__name__ == 'SelectorKey'"
  category: classnames
  kind: python_call_eq
  function: SelectorKey.__name__.__eq__
  args: ["SelectorKey"]
  expected: true

# ---------------------------------------------------------------------------
# EVENT_READ and EVENT_WRITE — type checks
# ---------------------------------------------------------------------------

invariant selectors_extra.EVENT_READ.is_int:
  description: "selectors.EVENT_READ.__class__.__name__ == 'int' — EVENT_READ is a plain integer"
  category: constants
  kind: python_call_eq
  function: EVENT_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant selectors_extra.EVENT_WRITE.is_int:
  description: "selectors.EVENT_WRITE.__class__.__name__ == 'int' — EVENT_WRITE is a plain integer"
  category: constants
  kind: python_call_eq
  function: EVENT_WRITE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# EVENT_READ and EVENT_WRITE — value checks
# ---------------------------------------------------------------------------

invariant selectors_extra.EVENT_READ.value:
  description: "selectors.EVENT_READ == 1 — the read-ready bitmask is 1"
  category: constants
  kind: python_call_eq
  function: EVENT_READ.__eq__
  args: [1]
  expected: true

invariant selectors_extra.EVENT_WRITE.value:
  description: "selectors.EVENT_WRITE == 4 — the write-ready bitmask is 4 per Python 3 docs"
  category: constants
  kind: python_call_eq
  function: EVENT_WRITE.__eq__
  args: [4]
  expected: true
