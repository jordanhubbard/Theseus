       6,
       "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — co_varnames lists all local variable names: wrapper, wrapped, assigned, updated, attr, value; tuple.__len__() returns 6; new to extra136"]
    - [uw_co_varnames_2_eq_assigned,
       "update_wrapper.__code__.co_varnames[2].__eq__",
       ["assigned"],
       true,
       "functools.update_wrapper.__code__.co_varnames[2].__eq__('assigned') == True — co_varnames[2] is 'assigned', the third positional parameter (a tuple of attribute names to copy directly from wrapped to wrapper, defaults to WRAPPER_ASSIGNMENTS); str.__eq__('assigned') returns True; new to extra136"]
    - [uw_co_varnames_3_eq_updated,
       "update_wrapper.__code__.co_varnames[3].__eq__",
       ["updated"],
       true,
       "functools.update_wrapper.__code__.co_varnames[3].__eq__('updated') == True — co_varnames[3] is 'updated', the fourth positional parameter (a tuple of attribute names on wrapper updated from wrapped, defaults to WRAPPER_UPDATES); str.__eq__('updated') returns True; new to extra136"]

