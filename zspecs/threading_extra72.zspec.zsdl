spec: threading_extra72
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra71.zspec.zsdl."
    - "Wave 237 theme: threading function __code__ attributes — first __code__ for threading."
    - "Thread.__init__.__code__.co_name == '__init__' — co_name records the def statement name. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_argcount == 6 — Thread.__init__(self, group=None, target=None, name=None, args=(), kwargs=None) has 6 positional parameters (self, group, target, name, args, kwargs); daemon and context are keyword-only (co_kwonlyargcount==2). Verified with Python 3.14.3."
    - "Semaphore.__init__.__code__.co_name == '__init__' — Semaphore.__init__ is a pure-Python method. Verified with Python 3.14.3."
    - "Semaphore.__init__.__code__.co_argcount == 2 — Semaphore.__init__(self, value=1) has 2 positional parameters (self and value). Verified with Python 3.14.3."
    - "Event.set.__code__.co_name == 'set' — Event.set is a pure-Python method in Lib/threading.py. Verified with Python 3.14.3."
    - "Event.clear.__code__.co_name == 'clear' — Event.clear is a pure-Python method in Lib/threading.py. Verified with Python 3.14.3."
    - "Event.wait.__code__.co_name == 'wait' — Event.wait is a pure-Python method in Lib/threading.py. Verified with Python 3.14.3."
    - "Event.wait.__code__.co_argcount == 2 — Event.wait(self, timeout=None) has 2 positional parameters (self and timeout). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.__init__ __code__ attributes — extra72
#
# Wave 237 theme: Thread.__init__ is a pure-Python method with __code__.
#
# threading.Thread.__init__ is defined in Lib/threading.py as:
#   def __init__(self, group=None, target=None, name=None,
#                args=(), kwargs=None, *, daemon=None):
#
# co_name     == '__init__'
# co_argcount == 6   (self, group, target, name, args, kwargs are all positional;
#                     daemon is keyword-only; in CPython 3.x there is also an
#                     internal 'context' keyword-only parameter giving
#                     co_kwonlyargcount==2 but co_argcount==6)
#
# No prior threading spec checks Thread.__init__.__code__ via thrdcode72. New to extra72.
# ---------------------------------------------------------------------------

table threading_extra72.Thread_init_code:
  description: "Thread.__init__.__code__.co_name=='__init__', co_argcount==6; wave 237 Thread.__init__ __code__; new to extra72"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdcode72

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_init_co_name_eq_init,
       Thread.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "threading.Thread.__init__.__code__.co_name.__eq__('__init__') == True — Thread.__init__ is a pure-Python method defined in Lib/threading.py; the code object's co_name stores the name from the def statement which is '__init__' (8 chars including underscores); str.__eq__('__init__') returns True; no prior threading spec checks Thread.__init__.__code__.co_name via thrdcode72; new to extra72"]
    - [Thread_init_co_argcount_eq_6,
       Thread.__init__.__code__.co_argcount.__eq__,
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__ is defined with positional parameters: self, group=None, target=None, name=None, args=(), kwargs=None (6 positional total); daemon and the internal context parameter are keyword-only (co_kwonlyargcount==2); co_argcount counts only the positional parameters and equals 6; int.__eq__(6) returns True; no prior threading spec checks Thread.__init__.__code__.co_argcount via thrdcode72; new to extra72"]

# ---------------------------------------------------------------------------
# Semaphore.__init__ __code__ attributes — extra72
#
# Wave 237 theme: Semaphore.__init__ is a pure-Python method with __code__.
#
# threading.Semaphore.__init__ is defined in Lib/threading.py as:
#   def __init__(self, value=1):
#
# co_name     == '__init__'
# co_argcount == 2   (self and value are both positional)
#
# No prior threading spec checks Semaphore.__init__.__code__ via thrdcode72. New to extra72.
# ---------------------------------------------------------------------------

table threading_extra72.Semaphore_init_code:
  description: "Semaphore.__init__.__code__.co_name=='__init__', co_argcount==2; wave 237 Semaphore.__init__ __code__; new to extra72"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdcode72

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_init_co_name_eq_init,
       Semaphore.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "threading.Semaphore.__init__.__code__.co_name.__eq__('__init__') == True — Semaphore.__init__ is a pure-Python method defined in Lib/threading.py that initializes the semaphore with a given value (default 1); the code object's co_name is '__init__' (8 chars); str.__eq__('__init__') returns True; no prior threading spec checks Semaphore.__init__.__code__.co_name via thrdcode72; new to extra72"]
    - [Semaphore_init_co_argcount_eq_2,
       Semaphore.__init__.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Semaphore.__init__.__code__.co_argcount.__eq__(2) == True — Semaphore.__init__ is defined as 'def __init__(self, value=1):' with two positional parameters self and value (value has a default of 1 but is positional, not keyword-only); co_argcount equals 2; int.__eq__(2) returns True; no prior threading spec checks Semaphore.__init__.__code__.co_argcount via thrdcode72; new to extra72"]

# ---------------------------------------------------------------------------
# Event.set and Event.clear __code__ names — extra72
#
# Wave 237 theme: Event.set and Event.clear are pure-Python methods with __code__.
#
# threading.Event.set is defined in Lib/threading.py as:
#   def set(self):
# threading.Event.clear is defined in Lib/threading.py as:
#   def clear(self):
#
# Event.set.__code__.co_name   == 'set'
# Event.clear.__code__.co_name == 'clear'
#
# No prior threading spec checks these Event method __code__ names via thrdcode72. New to extra72.
# ---------------------------------------------------------------------------

table threading_extra72.Event_set_clear_code:
  description: "Event.set.__code__.co_name=='set', Event.clear.__code__.co_name=='clear'; wave 237 Event method __code__ names; new to extra72"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdcode72

  columns: [id, function, args, expected, description]
  rows:
    - [Event_set_co_name_eq_set,
       Event.set.__code__.co_name.__eq__,
       ["set"],
       true,
       "threading.Event.set.__code__.co_name.__eq__('set') == True — Event.set is a pure-Python method defined in Lib/threading.py that sets the internal event flag to True and wakes all waiting threads; it is defined as 'def set(self):' so the code object's co_name is 'set' (3 chars); str.__eq__('set') returns True; no prior threading spec checks Event.set.__code__.co_name via thrdcode72; new to extra72"]
    - [Event_clear_co_name_eq_clear,
       Event.clear.__code__.co_name.__eq__,
       ["clear"],
       true,
       "threading.Event.clear.__code__.co_name.__eq__('clear') == True — Event.clear is a pure-Python method defined in Lib/threading.py that resets the internal event flag to False; it is defined as 'def clear(self):' so the code object's co_name is 'clear' (5 chars); str.__eq__('clear') returns True; no prior threading spec checks Event.clear.__code__.co_name via thrdcode72; new to extra72"]

# ---------------------------------------------------------------------------
# Event.wait __code__ attributes — extra72
#
# Wave 237 theme: Event.wait is a pure-Python method with __code__.
#
# threading.Event.wait is defined in Lib/threading.py as:
#   def wait(self, timeout=None):
#
# co_name     == 'wait'
# co_argcount == 2   (self and timeout are both positional; timeout has a default)
#
# No prior threading spec checks Event.wait.__code__ via thrdcode72. New to extra72.
# ---------------------------------------------------------------------------

table threading_extra72.Event_wait_code:
  description: "Event.wait.__code__.co_name=='wait', co_argcount==2; wave 237 Event.wait __code__; new to extra72"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdcode72

  columns: [id, function, args, expected, description]
  rows:
    - [Event_wait_co_name_eq_wait,
       Event.wait.__code__.co_name.__eq__,
       ["wait"],
       true,
       "threading.Event.wait.__code__.co_name.__eq__('wait') == True — Event.wait is a pure-Python method defined in Lib/threading.py that blocks until the internal event flag is True or the optional timeout expires; it is defined as 'def wait(self, timeout=None):' so the code object's co_name is 'wait' (4 chars); str.__eq__('wait') returns True; no prior threading spec checks Event.wait.__code__.co_name via thrdcode72; new to extra72"]
    - [Event_wait_co_argcount_eq_2,
       Event.wait.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Event.wait.__code__.co_argcount.__eq__(2) == True — Event.wait is defined as 'def wait(self, timeout=None):' with two positional parameters self and timeout (timeout has a default of None but is positional, not keyword-only); co_argcount counts positional parameters only and equals 2; int.__eq__(2) returns True; no prior threading spec checks Event.wait.__code__.co_argcount via thrdcode72; new to extra72"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra72
# ---------------------------------------------------------------------------

invariant threading_extra72.Thread_init_co_name:
  description: "threading.Thread.__init__.__code__.co_name.__eq__('__init__') == True — co_name records the def statement name; wave 237 Thread.__init__ __code__; new to extra72"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra72.Thread_init_co_argcount:
  description: "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__(self, group, target, name, args, kwargs) has 6 positional parameters; wave 237 Thread.__init__ __code__; new to extra72"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant threading_extra72.Semaphore_init_co_argcount:
  description: "threading.Semaphore.__init__.__code__.co_argcount.__eq__(2) == True — Semaphore.__init__(self, value=1) has 2 positional parameters; wave 237 Semaphore.__init__ __code__; new to extra72"
  kind: python_call_eq
  function: Semaphore.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra72.Event_set_co_name:
  description: "threading.Event.set.__code__.co_name.__eq__('set') == True — co_name for Event.set is 'set'; wave 237 Event.set __code__; new to extra72"
  kind: python_call_eq
  function: Event.set.__code__.co_name.__eq__
  args: ["set"]
  expected: true

invariant threading_extra72.Event_wait_co_argcount:
  description: "threading.Event.wait.__code__.co_argcount.__eq__(2) == True — Event.wait(self, timeout=None) has 2 positional parameters; wave 237 Event.wait __code__; new to extra72"
  kind: python_call_eq
  function: Event.wait.__code__.co_argcount.__eq__
  args: [2]
  expected: true
