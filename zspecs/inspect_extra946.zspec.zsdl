spec: inspect_extra946
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.Parameter kind sentinels and inspect.Signature.empty class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra946.parameter_kind_class_names:
  description: "inspect.Parameter kind sentinel __class__.__name__ identity"
  kind: python_call_eq
  category: parameter_kind
  id_prefix: ip946pk
  columns: [id, function, args, expected]
  rows:
    - [ip946pk001, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,      ["_ParameterKind"], true]
    - [ip946pk002, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [ip946pk003, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,       ["_ParameterKind"], true]
    - [ip946pk004, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,         ["_ParameterKind"], true]
    - [ip946pk005, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__,          ["_ParameterKind"], true]

table inspect_extra946.parameter_kind_names:
  description: "inspect.Parameter kind sentinel .name attribute identity"
  kind: python_call_eq
  category: parameter_kind_names
  id_prefix: ip946kn
  columns: [id, function, args, expected]
  rows:
    - [ip946kn001, inspect.Parameter.POSITIONAL_ONLY.name.__eq__,                    ["POSITIONAL_ONLY"],      true]
    - [ip946kn002, inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__,              ["POSITIONAL_OR_KEYWORD"], true]
    - [ip946kn003, inspect.Parameter.VAR_POSITIONAL.name.__eq__,                     ["VAR_POSITIONAL"],       true]
    - [ip946kn004, inspect.Parameter.KEYWORD_ONLY.name.__eq__,                       ["KEYWORD_ONLY"],         true]
    - [ip946kn005, inspect.Parameter.VAR_KEYWORD.name.__eq__,                        ["VAR_KEYWORD"],          true]

table inspect_extra946.empty_sentinel_identity:
  description: "inspect.Parameter.empty and inspect.Signature.empty class identity"
  kind: python_call_eq
  category: empty_sentinel
  id_prefix: ip946es
  columns: [id, function, args, expected]
  rows:
    - [ip946es001, inspect.Parameter.empty.__class__.__name__.__eq__,                ["_empty"],     true]
    - [ip946es002, inspect.Signature.empty.__class__.__name__.__eq__,                ["_empty"],     true]
    - [ip946es003, inspect.Parameter.empty.__name__.__eq__,                          ["_empty"],     true]
    - [ip946es004, inspect.Signature.empty.__name__.__eq__,                          ["_empty"],     true]
    - [ip946es005, inspect.Parameter.empty.__module__.__eq__,                        ["inspect"],    true]
    - [ip946es006, inspect.Signature.empty.__module__.__eq__,                        ["inspect"],    true]

table inspect_extra946.parameter_class_identity:
  description: "inspect.Parameter and inspect.Signature top-level class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: ip946ci
  columns: [id, function, args, expected]
  rows:
    - [ip946ci001, inspect.Parameter.__class__.__name__.__eq__,                      ["type"],       true]
    - [ip946ci002, inspect.Signature.__class__.__name__.__eq__,                      ["type"],       true]
    - [ip946ci003, inspect.Parameter.__module__.__eq__,                              ["inspect"],    true]
    - [ip946ci004, inspect.Signature.__module__.__eq__,                              ["inspect"],    true]
