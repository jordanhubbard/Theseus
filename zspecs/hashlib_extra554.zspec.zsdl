spec: hashlib_extra554
backend: python_module(hashlib)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module: blake2b, blake2s, sha3 family and related attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __doc__, __class__, __bases__ identity checks for hashlib blake2 and sha3 types"
  created_at: "2026-04-12T00:00:00Z"

table hashlib_extra554.qualname_checks:
  columns: [id, function, args, expected]
  rows:
    - [hx554_t01, hashlib.blake2b.__qualname__.__eq__, ['blake2b'], true]
    - [hx554_t02, hashlib.blake2s.__qualname__.__eq__, ['blake2s'], true]
    - [hx554_t03, hashlib.sha3_256.__qualname__.__eq__, ['sha3_256'], true]
    - [hx554_t04, hashlib.sha3_512.__qualname__.__eq__, ['sha3_512'], true]

table hashlib_extra554.doc_class_checks:
  columns: [id, function, args, expected]
  rows:
    - [hx554_t05, hashlib.blake2b.__doc__.__class__.__name__.__eq__, ['str'], true]
    - [hx554_t06, hashlib.blake2s.__doc__.__class__.__name__.__eq__, ['str'], true]
    - [hx554_t07, hashlib.new.__doc__.__class__.__name__.__eq__, ['str'], true]
    - [hx554_t08, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ['str'], true]

table hashlib_extra554.algorithms_class_checks:
  columns: [id, function, args, expected]
  rows:
    - [hx554_t09, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ['set'], true]
    - [hx554_t10, hashlib.algorithms_available.__class__.__name__.__eq__, ['set'], true]

invariant hashlib_extra554.blake2b_base_is_object:
  kind: python_call_eq
  function: "hashlib.blake2b.__bases__[0].__name__.__eq__"
  args: ['object']
  expected: true

invariant hashlib_extra554.blake2s_base_is_object:
  kind: python_call_eq
  function: "hashlib.blake2s.__bases__[0].__name__.__eq__"
  args: ['object']
  expected: true
