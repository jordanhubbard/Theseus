spec: heapq_extra18
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
    - "heapq_extra17.zspec.zsdl — covers __qualname__.__eq__ for all 8 callables in a unified table."
    - "heapq_extra16.zspec.zsdl — covers __package__ and __qualname__.__len__() for all 7+1 functions."
    - "heapq_extra15.zspec.zsdl — covers __module__.__eq__ for merge/nlargest/nsmallest; __qualname__ standalone."
  notes:
    - "This spec extends heapq.zspec.zsdl through heapq_extra17.zspec.zsdl."
    - "Prior specs cover: __module__.__eq__ for all 8 callables; __qualname__.__eq__ and __qualname__.__len__() for all 8; __package__."
    - "NOT yet covered: __module__.__len__() for any heapq callable."
    - "Focus: __module__.__len__() table for all 8 heapq callables, distinguishing C builtins (len('_heapq')==6) from pure-Python (len('heapq')==5)."
    - "heappush/heappop/heapify/heapreplace/heappushpop are C builtins with __module__ == '_heapq'; len('_heapq') == 6."
    - "nlargest/nsmallest/merge are pure-Python with __module__ == 'heapq'; len('heapq') == 5."
    - "heapq.__name__.__len__() == 5 — len('heapq') == 5. Verified."
    - "heapq.__package__.__len__() == 0 — __package__ == '' for top-level module. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# heapq module-level __name__.__len__() and __package__.__len__()
#
# heapq_extra4 and heapq_extra16 cover __name__.__eq__ and __package__.__eq__.
# No prior heapq spec checks __name__.__len__() or __package__.__len__() at the
# module level. heapq.__name__ == 'heapq' (len 5); __package__ == '' (len 0).
# ---------------------------------------------------------------------------

invariant heapq_extra18.module.name_len:
  description: "heapq.__name__.__len__() == 5 — len('heapq') == 5"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 5

invariant heapq_extra18.module.package_len:
  description: "heapq.__package__.__len__() == 0 — __package__ is the empty string for a top-level module"
  category: module_identity
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# __module__.__len__() for all 8 heapq callables
#
# No prior heapq spec checks __module__.__len__() for any callable. The C
# builtins (heappush, heappop, heapify, heapreplace, heappushpop) have
# __module__ == '_heapq' (len 6). The pure-Python callables (nlargest,
# nsmallest, merge) have __module__ == 'heapq' (len 5). This table provides
# an independent execution path from the __module__.__eq__ checks in prior
# specs. id_prefix hqmodlen18 does not conflict with any prior heapq spec.
# ---------------------------------------------------------------------------

table heapq_extra18.module_lengths:
  description: "__module__.__len__() for all 8 heapq callables — 6 for C builtins, 5 for pure-Python"
  kind: python_call_eq
  category: function_module
  id_prefix: hqmodlen18

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__module__.__len__,    [], 6]
    - [heappop,     heappop.__module__.__len__,     [], 6]
    - [heapify,     heapify.__module__.__len__,     [], 6]
    - [heapreplace, heapreplace.__module__.__len__, [], 6]
    - [heappushpop, heappushpop.__module__.__len__, [], 6]
    - [nlargest,    nlargest.__module__.__len__,    [], 5]
    - [nsmallest,   nsmallest.__module__.__len__,   [], 5]
    - [merge,       merge.__module__.__len__,       [], 5]
