spec: threading_extra164
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.TIMEOUT_MAX.__class__.__name__ 'float'; threading.TIMEOUT_MAX.__gt__(0) True; threading.active_count.__code__.co_argcount 0; threading.active_count.__code__.co_name 'active_count'; threading.activeCount.__name__ 'activeCount'; threading.activeCount.__module__ 'threading' (Wave 292)."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant giving the maximum value for the timeout parameter of blocking functions; its __class__.__name__ is 'float'. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX > 0 — TIMEOUT_MAX is a large positive float (9223372036.0 on this platform); TIMEOUT_MAX.__gt__(0) is True. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_argcount == 0 — active_count() takes no arguments; it returns the number of Thread objects currently alive; co_argcount is 0. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_name == 'active_count' — active_count is a Python function in Lib/threading.py; its code object co_name is 'active_count'. Verified with Python 3.14.3."
    - "threading.activeCount exists and is a function — activeCount is the deprecated camelCase alias for active_count still present in Python 3.14.3; its __name__ is 'activeCount' and __module__ is 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX constant identity
#
# Wave 292 theme: threading.TIMEOUT_MAX float constant — class name, positivity,
# and related active_count argument count.
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(0) == True
# threading.active_count.__code__.co_argcount == 0
# threading.active_count.__code__.co_name == 'active_count'
#
# threading.TIMEOUT_MAX is a float constant that gives the maximum value
# allowed for the timeout parameter accepted by blocking functions such as
# threading.Thread.join(), threading.Lock.acquire(), threading.Event.wait(),
# etc. Its value on this platform is 9223372036.0. Specifying a timeout greater
# than TIMEOUT_MAX raises OverflowError. It is a plain Python float object;
# its __class__.__name__ is 'float' and it is positive.
# threading.active_count() returns the number of Thread objects currently alive;
# it takes no arguments (co_argcount is 0). New to extra164.
# ---------------------------------------------------------------------------

table threading_extra164.timeout_max_constant_identity:
  description: "threading.TIMEOUT_MAX: __class__.__name__ 'float', __gt__(0) True; active_count co_argcount 0, co_name 'active_count'; wave 292; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtmci164

  columns: [id, function, args, expected, description]
  rows:
    - [tm_class_name_eq_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant giving the maximum allowed timeout value for blocking threading functions such as Thread.join() and Lock.acquire(); its __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra164"]
    - [tm_gt_0,
       "TIMEOUT_MAX.__gt__",
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0 on this platform); it is always greater than zero; float.__gt__(0) returns True; new to extra164"]
    - [ac_argc_eq_0,
       "active_count.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.active_count.__code__.co_argcount.__eq__(0) == True — active_count() takes no positional-or-keyword arguments; it returns the number of Thread objects currently alive including the main thread; co_argcount is 0; int.__eq__(0) returns True; new to extra164"]
    - [ac_co_name_eq_active_count,
       "active_count.__code__.co_name.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__code__.co_name.__eq__('active_count') == True — active_count is a Python function in Lib/threading.py that returns the count of currently alive Thread objects; its code object co_name is 'active_count'; str.__eq__('active_count') returns True; new to extra164"]

# ---------------------------------------------------------------------------
# Table 2: threading.activeCount deprecated alias identity
#
# Wave 292 theme: threading.activeCount deprecated camelCase alias — name,
# module, and class; plus TIMEOUT_MAX class name cross-check.
#
# threading.activeCount.__name__ == 'activeCount'
# threading.activeCount.__module__ == 'threading'
# threading.activeCount.__class__.__name__ == 'function'
# threading.TIMEOUT_MAX.__class__.__name__ == 'float' (cross-check)
#
# threading.activeCount is the deprecated camelCase alias for active_count,
# retained for backwards compatibility. In Python 3.10 it was deprecated
# (DeprecationWarning on call) but remains present in Python 3.14.3.
# It is a Python function in Lib/threading.py; its __name__ is 'activeCount',
# __module__ is 'threading', and __class__.__name__ is 'function'.
# New to extra164.
# ---------------------------------------------------------------------------

table threading_extra164.activecount_deprecated_alias_identity:
  description: "threading.activeCount: __name__ 'activeCount', __module__ 'threading', __class__.__name__ 'function'; TIMEOUT_MAX class 'float' cross-check; wave 292; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: threadingacdai164

  columns: [id, function, args, expected, description]
  rows:
    - [acd_name_eq_activecount,
       "activeCount.__name__.__eq__",
       ["activeCount"],
       true,
       "threading.activeCount.__name__.__eq__('activeCount') == True — activeCount is the deprecated camelCase alias for active_count in Lib/threading.py retained for backwards compatibility; its __name__ is 'activeCount'; str.__eq__('activeCount') returns True; new to extra164"]
    - [acd_module_eq_threading,
       "activeCount.__module__.__eq__",
       ["threading"],
       true,
       "threading.activeCount.__module__.__eq__('threading') == True — activeCount is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra164"]
    - [acd_class_name_eq_function,
       "activeCount.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.activeCount.__class__.__name__.__eq__('function') == True — activeCount is a Python function (not a C built-in); it is the deprecated camelCase alias for active_count in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra164"]
    - [tm_class_name_ne_int,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["int"],
       false,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('int') == False — TIMEOUT_MAX is a float (not an int); its __class__.__name__ is 'float' not 'int'; str.__eq__('int') returns False; new to extra164"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant threading_extra164.timeout_max_class_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant giving the maximum allowed blocking-function timeout; wave 292; new to extra164"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra164.timeout_max_gt_zero:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (e.g. 9223372036.0); always greater than 0; wave 292; new to extra164"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra164.active_count_co_argcount_0:
  description: "threading.active_count.__code__.co_argcount == 0 — active_count() takes no arguments; returns count of alive Thread objects; wave 292; new to extra164"
  kind: python_call_eq
  function: active_count.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant threading_extra164.active_count_co_name:
  description: "threading.active_count.__code__.co_name == 'active_count' — code object name for active_count in Lib/threading.py; wave 292; new to extra164"
  kind: python_call_eq
  function: active_count.__code__.co_name.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra164.activecount_name:
  description: "threading.activeCount.__name__ == 'activeCount' — deprecated camelCase alias for active_count; still present in Python 3.14.3; wave 292; new to extra164"
  kind: python_call_eq
  function: activeCount.__name__.__eq__
  args: ["activeCount"]
  expected: true

invariant threading_extra164.activecount_module_threading:
  description: "threading.activeCount.__module__ == 'threading' — activeCount deprecated alias defined in Lib/threading.py; wave 292; new to extra164"
  kind: python_call_eq
  function: activeCount.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra164.activecount_class_function:
  description: "threading.activeCount.__class__.__name__ == 'function' — activeCount is a Python function, not a C built-in; wave 292; new to extra164"
  kind: python_call_eq
  function: activeCount.__class__.__name__.__eq__
  args: ["function"]
  expected: true

