spec: hashlib_extra2566
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/sha2module.c"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "hashlib HASH (the C extension type returned by hashlib.md5()) defines NONE of __getattr__, __setattr__, __delattr__, or __getattribute__ in its own __dict__."
    - "The HASH type inherits attribute access from the default C-type slot mechanism — no Python-level override is registered."
    - "HASH.__dict__ contains only: __repr__, update, digest, hexdigest, copy, digest_size, block_size, name, __doc__, __module__."
    - "HASH does NOT block attribute setting via __setattr__; it is a C type that is naturally immutable due to its type structure."
    - "hashlib.md5().__class__.__name__ is 'md5' (or the openssl variant name), not 'HASH' — the type name varies by backend."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __getattr__ dict-presence — absent from HASH (no custom lazy attribute lookup)
# ---------------------------------------------------------------------------

table hashlib_extra2566.getattr_protocol:
  description: "__getattr__ is absent from the HASH type __dict__ — no custom lazy attribute lookup is defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2566

  columns: [id, function, args, expected]
  rows:
    - ["hl2566001", "hashlib.md5().__class__.__dict__.__contains__", ["__getattr__"],      false]
    - ["hl2566002", "hashlib.md5().__class__.__dict__.__contains__", ["__setattr__"],      false]
    - ["hl2566003", "hashlib.md5().__class__.__dict__.__contains__", ["__delattr__"],      false]
    - ["hl2566004", "hashlib.md5().__class__.__dict__.__contains__", ["__getattribute__"], false]

# ---------------------------------------------------------------------------
# Positive presence — methods and descriptors that ARE in HASH.__dict__
# ---------------------------------------------------------------------------

table hashlib_extra2566.hash_dict_positive:
  description: "Methods defined directly in the HASH type __dict__ — the actual hashing API"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2566

  columns: [id, function, args, expected]
  rows:
    - ["hl2566005", "hashlib.md5().__class__.__dict__.__contains__", ["update"],      true]
    - ["hl2566006", "hashlib.md5().__class__.__dict__.__contains__", ["digest"],      true]
    - ["hl2566007", "hashlib.md5().__class__.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl2566008", "hashlib.md5().__class__.__dict__.__contains__", ["copy"],        true]
    - ["hl2566009", "hashlib.md5().__class__.__dict__.__contains__", ["digest_size"], true]
    - ["hl2566010", "hashlib.md5().__class__.__dict__.__contains__", ["block_size"],  true]
    - ["hl2566011", "hashlib.md5().__class__.__dict__.__contains__", ["name"],        true]
    - ["hl2566012", "hashlib.md5().__class__.__dict__.__contains__", ["__repr__"],    true]

# ---------------------------------------------------------------------------
# Absent dunders — standard comparison/lifecycle methods not overridden in HASH
# ---------------------------------------------------------------------------

table hashlib_extra2566.hash_absent_dunders:
  description: "Standard dunder methods absent from HASH.__dict__ — inherited from C-type defaults"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2566

  columns: [id, function, args, expected]
  rows:
    - ["hl2566013", "hashlib.md5().__class__.__dict__.__contains__", ["__eq__"],    false]
    - ["hl2566014", "hashlib.md5().__class__.__dict__.__contains__", ["__hash__"],  false]
    - ["hl2566015", "hashlib.md5().__class__.__dict__.__contains__", ["__init__"],  false]
    - ["hl2566016", "hashlib.md5().__class__.__dict__.__contains__", ["__new__"],   false]
    - ["hl2566017", "hashlib.md5().__class__.__dict__.__contains__", ["__slots__"], false]
