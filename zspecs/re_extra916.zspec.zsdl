spec: re_extra916
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module function documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re module function __qualname__ identity for all major public functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra916.compile_and_match_qualnames:
  description: "re compile, match, search, and fullmatch function __qualname__ identity"
  kind: python_call_eq
  category: compile_and_match_qualnames
  id_prefix: re916cm
  columns: [id, function, args, expected]
  rows:
    - [re916cm001, re.compile.__qualname__.__eq__,   ["compile"],   true]
    - [re916cm002, re.match.__qualname__.__eq__,     ["match"],     true]
    - [re916cm003, re.search.__qualname__.__eq__,    ["search"],    true]
    - [re916cm004, re.fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [re916cm005, re.compile.__module__.__eq__,     ["re"],        true]
    - [re916cm006, re.match.__module__.__eq__,       ["re"],        true]
    - [re916cm007, re.search.__module__.__eq__,      ["re"],        true]
    - [re916cm008, re.fullmatch.__module__.__eq__,   ["re"],        true]

table re_extra916.find_and_iter_qualnames:
  description: "re findall and finditer function __qualname__ identity"
  kind: python_call_eq
  category: find_and_iter_qualnames
  id_prefix: re916fi
  columns: [id, function, args, expected]
  rows:
    - [re916fi001, re.findall.__qualname__.__eq__,  ["findall"],  true]
    - [re916fi002, re.finditer.__qualname__.__eq__, ["finditer"], true]
    - [re916fi003, re.findall.__module__.__eq__,    ["re"],       true]
    - [re916fi004, re.finditer.__module__.__eq__,   ["re"],       true]
    - [re916fi005, re.sub.__qualname__.__eq__,      ["sub"],      true]
    - [re916fi006, re.split.__qualname__.__eq__,    ["split"],    true]
    - [re916fi007, re.sub.__module__.__eq__,        ["re"],       true]
    - [re916fi008, re.split.__module__.__eq__,      ["re"],       true]

table re_extra916.utility_func_qualnames:
  description: "re escape and purge utility function __qualname__ identity"
  kind: python_call_eq
  category: utility_func_qualnames
  id_prefix: re916uf
  columns: [id, function, args, expected]
  rows:
    - [re916uf001, re.escape.__qualname__.__eq__, ["escape"], true]
    - [re916uf002, re.purge.__qualname__.__eq__,  ["purge"],  true]
    - [re916uf003, re.escape.__module__.__eq__,   ["re"],     true]
    - [re916uf004, re.purge.__module__.__eq__,    ["re"],     true]
    - [re916uf005, re.escape.__name__.__eq__,     ["escape"], true]
    - [re916uf006, re.purge.__name__.__eq__,      ["purge"],  true]
    - [re916uf007, re.compile.__name__.__eq__,    ["compile"],true]
    - [re916uf008, re.match.__name__.__eq__,      ["match"],  true]
