  expected: true

invariant threading_extra169.active_count_module_threading:
  description: "threading.active_count.__module__ == 'threading' — active_count is defined in Lib/threading.py; wave 297; new to extra169"
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra169.enumerate_name_enumerate:
  description: "threading.enumerate.__name__ == 'enumerate' — Python function returning a list of all alive Thread objects; distinct from built-in enumerate; wave 297; new to extra169"
  kind: python_call_eq
  function: enumerate.__name__.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra169.enumerate_module_threading:
  description: "threading.enumerate.__module__ == 'threading' — threading.enumerate is defined in Lib/threading.py with __module__ 'threading', not 'builtins'; wave 297; new to extra169"
