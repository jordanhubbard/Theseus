spec: threading_extra169
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.current_thread.__name__ 'current_thread'; threading.current_thread.__module__ 'threading'; threading.main_thread.__name__ 'main_thread'; threading.main_thread.__module__ 'threading'; threading.active_count.__name__ 'active_count'; threading.active_count.__module__ 'threading'; threading.enumerate.__name__ 'enumerate'; threading.enumerate.__module__ 'threading' (Wave 297)."
    - "threading.current_thread.__name__ == 'current_thread' — threading.current_thread is a Python function defined in Lib/threading.py that returns the Thread object corresponding to the caller's thread of control; its __name__ is 'current_thread'. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' — current_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'. Verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' — threading.main_thread is a Python function defined in Lib/threading.py that returns the main Thread object (the thread from which the Python interpreter was started); its __name__ is 'main_thread'. Verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' — main_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'. Verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' — threading.active_count is a Python function defined in Lib/threading.py that returns the number of Thread objects currently alive; its __name__ is 'active_count'. Verified with Python 3.14.3."
    - "threading.active_count.__module__ == 'threading' — active_count is defined in Lib/threading.py; its __module__ attribute is 'threading'. Verified with Python 3.14.3."
    - "threading.enumerate.__name__ == 'enumerate' — threading.enumerate is a Python function defined in Lib/threading.py that returns a list of all Thread objects currently alive; its __name__ is 'enumerate'. NOTE: threading.enumerate is a distinct function from the built-in enumerate; it is accessed as threading.enumerate. Verified with Python 3.14.3."
    - "threading.enumerate.__module__ == 'threading' — threading.enumerate is defined in Lib/threading.py; its __module__ attribute is 'threading', not 'builtins'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.current_thread Python function identity
#
# Wave 297 theme: threading.current_thread Python function identity — __name__,
# __module__, and __class__.__name__.
#
# threading.current_thread.__name__ == 'current_thread'
# threading.current_thread.__module__ == 'threading'
# threading.current_thread.__class__.__name__ == 'function'
# threading.current_thread.__name__ != 'main_thread'
#
# threading.current_thread() returns the Thread object corresponding to the
# caller's thread of control. If the caller's thread was not created through
# the threading module, a dummy Thread object with limited functionality is
# returned. It is a Python function defined in Lib/threading.py. New to extra169.
# ---------------------------------------------------------------------------

table threading_extra169.current_thread_identity:
  description: "threading.current_thread: __name__ 'current_thread', __module__ 'threading', __class__.__name__ 'function'; wave 297; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcti169

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_current_thread,
       "current_thread.__name__.__eq__",
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — threading.current_thread is a Python function defined in Lib/threading.py that returns the Thread object for the calling thread; its __name__ attribute is 'current_thread'; str.__eq__('current_thread') returns True; new to extra169"]
    - [ct_module_threading,
       "current_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — threading.current_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra169"]
    - [ct_class_name_function,
       "current_thread.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.current_thread.__class__.__name__.__eq__('function') == True — threading.current_thread is a regular Python function defined in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [ct_name_ne_main_thread,
       "current_thread.__name__.__eq__",
       ["main_thread"],
       false,
       "threading.current_thread.__name__.__eq__('main_thread') == False — current_thread.__name__ is 'current_thread', not 'main_thread'; current_thread returns the Thread for the calling thread while main_thread returns the main thread specifically; they are distinct functions; str.__eq__('main_thread') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 2: threading.main_thread Python function identity
#
# Wave 297 theme: threading.main_thread Python function identity — __name__,
# __module__, and __class__.__name__.
#
# threading.main_thread.__name__ == 'main_thread'
# threading.main_thread.__module__ == 'threading'
# threading.main_thread.__class__.__name__ == 'function'
# threading.main_thread.__name__ != 'current_thread'
#
# threading.main_thread() returns the main Thread object. In normal conditions,
# the main thread is the thread from which the Python interpreter was started.
# The main thread is not a daemon thread and cannot be joined. It is a Python
# function defined in Lib/threading.py. New to extra169.
# ---------------------------------------------------------------------------

table threading_extra169.main_thread_identity:
  description: "threading.main_thread: __name__ 'main_thread', __module__ 'threading', __class__.__name__ 'function'; wave 297; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmti169

  columns: [id, function, args, expected, description]
  rows:
    - [mt_name_main_thread,
       "main_thread.__name__.__eq__",
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — threading.main_thread is a Python function defined in Lib/threading.py that returns the main Thread object (the thread from which the Python interpreter was started); its __name__ attribute is 'main_thread'; str.__eq__('main_thread') returns True; new to extra169"]
    - [mt_module_threading,
       "main_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — threading.main_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra169"]
    - [mt_class_name_function,
       "main_thread.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.main_thread.__class__.__name__.__eq__('function') == True — threading.main_thread is a regular Python function defined in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [mt_name_ne_current_thread,
       "main_thread.__name__.__eq__",
       ["current_thread"],
       false,
       "threading.main_thread.__name__.__eq__('current_thread') == False — main_thread.__name__ is 'main_thread', not 'current_thread'; main_thread always returns the main thread while current_thread returns the caller's thread (which may be any thread); str.__eq__('current_thread') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 3: threading.active_count Python function identity
#
# Wave 297 theme: threading.active_count Python function identity — __name__,
# __module__, and __class__.__name__.
#
# threading.active_count.__name__ == 'active_count'
# threading.active_count.__module__ == 'threading'
# threading.active_count.__class__.__name__ == 'function'
# threading.active_count.__module__ != 'builtins'
#
# threading.active_count() returns the number of Thread objects currently alive.
# The count is equal to the length of the list returned by enumerate(). It is
# a Python function defined in Lib/threading.py, not a C builtin. New to extra169.
# ---------------------------------------------------------------------------

table threading_extra169.active_count_identity:
  description: "threading.active_count: __name__ 'active_count', __module__ 'threading', __class__.__name__ 'function'; wave 297; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: threadingaci169

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_active_count,
       "active_count.__name__.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — threading.active_count is a Python function defined in Lib/threading.py that returns the number of Thread objects currently alive; its __name__ attribute is 'active_count'; str.__eq__('active_count') returns True; new to extra169"]
    - [ac_module_threading,
       "active_count.__module__.__eq__",
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — threading.active_count is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra169"]
    - [ac_class_name_function,
       "active_count.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.active_count.__class__.__name__.__eq__('function') == True — threading.active_count is a regular Python function defined in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [ac_module_not_builtins,
       "active_count.__module__.__eq__",
       ["builtins"],
       false,
       "threading.active_count.__module__.__eq__('builtins') == False — threading.active_count is defined in Lib/threading.py with __module__ 'threading', NOT in builtins; str.__eq__('builtins') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 4: threading.enumerate Python function identity
#
# Wave 297 theme: threading.enumerate Python function identity — __name__,
# __module__, __class__.__name__, and negative checks.
#
# threading.enumerate.__name__ == 'enumerate'
# threading.enumerate.__module__ == 'threading'
# threading.enumerate.__class__.__name__ == 'function'
# threading.enumerate.__module__ != 'builtins'
#
# threading.enumerate() returns a list of all Thread objects currently alive,
# including the main thread and daemon threads but excluding terminated threads.
# Its __name__ is 'enumerate' — the same string as the built-in enumerate function
# name — but it is a completely distinct Python function defined in Lib/threading.py
# with __module__ 'threading', not 'builtins'. New to extra169.
# ---------------------------------------------------------------------------

table threading_extra169.enumerate_identity:
  description: "threading.enumerate: __name__ 'enumerate', __module__ 'threading' (NOT 'builtins'), __class__.__name__ 'function'; wave 297; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: threadingeni169

  columns: [id, function, args, expected, description]
  rows:
    - [en_name_enumerate,
       "enumerate.__name__.__eq__",
       ["enumerate"],
       true,
       "threading.enumerate.__name__.__eq__('enumerate') == True — threading.enumerate is a Python function defined in Lib/threading.py that returns a list of all Thread objects currently alive; its __name__ attribute is 'enumerate'; str.__eq__('enumerate') returns True; new to extra169"]
    - [en_module_threading,
       "enumerate.__module__.__eq__",
       ["threading"],
       true,
       "threading.enumerate.__module__.__eq__('threading') == True — threading.enumerate is defined in Lib/threading.py with __module__ 'threading'; this is distinct from the built-in enumerate function which has __module__ 'builtins'; str.__eq__('threading') returns True; new to extra169"]
    - [en_class_name_function,
       "enumerate.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.enumerate.__class__.__name__.__eq__('function') == True — threading.enumerate is a regular Python function defined in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [en_module_not_builtins,
       "enumerate.__module__.__eq__",
       ["builtins"],
       false,
       "threading.enumerate.__module__.__eq__('builtins') == False — threading.enumerate is defined in Lib/threading.py with __module__ 'threading', NOT 'builtins'; the built-in enumerate (for iterating with indices) lives in builtins but threading.enumerate is a separate function; str.__eq__('builtins') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 5: Cross-checks — current_thread, main_thread, active_count, enumerate
# are all distinct Python functions sharing module 'threading'
#
# Wave 297 theme: cross-checks confirming all four threading module-level
# functions have distinct __name__ values and shared __module__ 'threading'.
#
# threading.current_thread.__name__ != 'active_count'
# threading.main_thread.__name__ != 'enumerate'
# threading.active_count.__name__ != 'current_thread'
# threading.enumerate.__name__ != 'active_count'
#
# All four (current_thread, main_thread, active_count, enumerate) are regular
# Python functions defined in Lib/threading.py. They all have __module__
# 'threading' and __class__.__name__ 'function'. Their __name__ values are
# distinct. New to extra169.
# ---------------------------------------------------------------------------

table threading_extra169.module_functions_cross_checks:
  description: "threading: current_thread, main_thread, active_count, enumerate all distinct __name__ values; wave 297; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmfcc169

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_ne_active_count,
       "current_thread.__name__.__eq__",
       ["active_count"],
       false,
       "threading.current_thread.__name__.__eq__('active_count') == False — current_thread.__name__ is 'current_thread', not 'active_count'; they are distinct threading module functions; str.__eq__('active_count') returns False; new to extra169"]
    - [mt_name_ne_enumerate,
       "main_thread.__name__.__eq__",
       ["enumerate"],
       false,
       "threading.main_thread.__name__.__eq__('enumerate') == False — main_thread.__name__ is 'main_thread', not 'enumerate'; they are distinct threading module functions; str.__eq__('enumerate') returns False; new to extra169"]
    - [ac_name_ne_current_thread,
       "active_count.__name__.__eq__",
       ["current_thread"],
       false,
       "threading.active_count.__name__.__eq__('current_thread') == False — active_count.__name__ is 'active_count', not 'current_thread'; they are distinct threading module functions; str.__eq__('current_thread') returns False; new to extra169"]
    - [en_name_ne_active_count,
       "enumerate.__name__.__eq__",
       ["active_count"],
       false,
       "threading.enumerate.__name__.__eq__('active_count') == False — enumerate.__name__ is 'enumerate', not 'active_count'; they are distinct threading module functions; str.__eq__('active_count') returns False; new to extra169"]

