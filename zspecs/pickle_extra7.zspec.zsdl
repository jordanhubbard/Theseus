spec: pickle_extra7
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl and prior extras through pickle_extra6.zspec.zsdl."
    - "Prior specs cover: function names (dumps/loads/dump/load), class names and modules and qualnames (Pickler/Unpickler/PickleError/PicklingError/UnpicklingError), HIGHEST_PROTOCOL and DEFAULT_PROTOCOL bounds and class names, PickleBuffer name/module/base, exception hierarchy, dumps return type (int/list/None/False/float/empty dict), round-trips (42/None/True/'hello'/float), protocol 0 bytes for int."
    - "NEW in this spec: loads(dumps([1,2,3])) round-trip for list; loads(dumps([])) round-trip for empty list; loads(dumps(False)) round-trip for False; loads(dumps('world')) round-trip for string 'world'; dumps result length > 0 for int and True; Unpickler.__class__.__qualname__=='type'; PicklingError.__class__.__qualname__=='type'."
    - "pickle.loads(pickle.dumps([1,2,3])) == [1,2,3] — list survives pickle round-trip."
    - "pickle.loads(pickle.dumps([])) == [] — empty list survives pickle round-trip."
    - "pickle.loads(pickle.dumps(False)) == False — False survives pickle round-trip."
    - "pickle.dumps(42).__len__() == 5 — default protocol 5 encoding of int 42 is 5 bytes."
    - "pickle.dumps(True).__len__() == 4 — default protocol 5 encoding of True is 4 bytes."
    - "pickle.loads(pickle.dumps('world')) == 'world' — string round-trip for value not in prior specs."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# loads(dumps(x)) round-trips for new value types
#
# Prior round-trip specs cover: int 42, None, True, 'hello', float 3.14.
# This section adds: list [1,2,3], empty list [], bool False, string 'world'.
# ---------------------------------------------------------------------------

invariant pickle_extra7.roundtrip.list_123:
  description: "pickle.loads(pickle.dumps([1,2,3])) == [1,2,3] — list survives a pickle round-trip"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex 8005950b000000000000005d94284b014b024b03652e]
  expected: [1, 2, 3]

invariant pickle_extra7.roundtrip.empty_list:
  description: "pickle.loads(pickle.dumps([])) == [] — empty list survives a pickle round-trip"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex 80059500000000000000005d942e]
  expected: []

invariant pickle_extra7.roundtrip.false:
  description: "pickle.loads(pickle.dumps(False)) == False — False survives a pickle round-trip"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex 8005892e]
  expected: false

invariant pickle_extra7.roundtrip.world_string:
  description: "pickle.loads(pickle.dumps('world')) == 'world' — string 'world' survives a pickle round-trip"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex 80059509000000000000008c05776f726c64942e]
  expected: "world"

# ---------------------------------------------------------------------------
# dumps result length > 0 for specific inputs
#
# Prior specs check that dumps returns bytes (class name check) but do not
# verify the length of the output. The length of dumps(42) is deterministic
# at protocol 5 (5 bytes). dumps(True) is 4 bytes at protocol 5.
# ---------------------------------------------------------------------------

invariant pickle_extra7.dumps_int.length:
  description: "pickle.dumps(42).__len__() == 5 — protocol 5 encodes int 42 in exactly 5 bytes"
  category: dumps_length
  kind: python_call_eq
  function: dumps
  args: [42]
  method: __len__
  method_args: []
  expected: 5

invariant pickle_extra7.dumps_true.length:
  description: "pickle.dumps(True).__len__() == 4 — protocol 5 encodes True in exactly 4 bytes"
  category: dumps_length
  kind: python_call_eq
  function: dumps
  args: [true]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# dumps returns bytes for string 'world' (distinct from 'hello' in prior specs)
#
# pickle_extra6 confirms dumps(float) and dumps(empty dict) return bytes.
# This adds 'world' as a string input distinct from 'hello' (covered in base spec).
# ---------------------------------------------------------------------------

invariant pickle_extra7.dumps_world.returns_bytes:
  description: "pickle.dumps('world').__class__.__name__ == 'bytes' — string 'world' serializes to bytes"
  category: dumps_type
  kind: python_call_eq
  function: dumps
  args: ["world"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# Unpickler and PicklingError __class__.__qualname__ == 'type'
#
# pickle_extra6 adds this check for PickleError and Pickler. This spec extends
# coverage to Unpickler and PicklingError (distinct class objects).
# ---------------------------------------------------------------------------

invariant pickle_extra7.Unpickler.class_qualname:
  description: "pickle.Unpickler.__class__.__qualname__ == 'type' — Unpickler is a type"
  category: class_metadata
  kind: python_call_eq
  function: Unpickler.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant pickle_extra7.PicklingError.class_qualname:
  description: "pickle.PicklingError.__class__.__qualname__ == 'type' — PicklingError is a type"
  category: class_metadata
  kind: python_call_eq
  function: PicklingError.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant pickle_extra7.UnpicklingError.class_qualname:
  description: "pickle.UnpicklingError.__class__.__qualname__ == 'type' — UnpicklingError is a type"
  category: class_metadata
  kind: python_call_eq
  function: UnpicklingError.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true
