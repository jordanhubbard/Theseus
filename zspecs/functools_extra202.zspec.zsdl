spec: functools_extra202
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.wraps and functools.update_wrapper identity — __name__, __module__, __qualname__, __class__.__name__."
    - "functools.wraps.__name__ == 'wraps' — wraps is a pure-Python function defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — wraps is defined at module scope in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — wraps is a top-level function; __qualname__ is the simple name 'wraps'. Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a pure-Python function; its __class__ is <class 'function'>. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' — update_wrapper is a top-level function; __qualname__ is the simple name 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a pure-Python function; its __class__ is <class 'function'>. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps identity — __name__, __module__, __qualname__
#
# functools.wraps.__name__.__eq__('wraps') == True
# functools.wraps.__module__.__eq__('functools') == True
# functools.wraps.__qualname__.__eq__('wraps') == True
#
# wraps is a pure-Python decorator factory defined in Lib/functools.py at module
# scope; it uses WRAPPER_ASSIGNMENTS to copy attributes from the wrapped function.
# New to extra202.
# ---------------------------------------------------------------------------

table functools_extra202.wraps_identity:
  description: "functools.wraps __name__, __module__, __qualname__; pure-Python decorator factory defined in Lib/functools.py; new to extra202"
  kind: python_call_eq
  category: string_identity
  id_prefix: functwraps202

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq_wraps,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — wraps is a pure-Python function in Lib/functools.py; __name__ is the simple name 'wraps'; str.__eq__('wraps') returns True; new to extra202"]
    - [wraps_module_eq_functools,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined at module scope in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra202"]
    - [wraps_qualname_eq_wraps,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a top-level function with no enclosing class or function scope; __qualname__ is 'wraps'; str.__eq__('wraps') returns True; new to extra202"]

# ---------------------------------------------------------------------------
# Table 2: functools.update_wrapper identity — __name__, __module__, __qualname__
#
# functools.update_wrapper.__name__.__eq__('update_wrapper') == True
# functools.update_wrapper.__module__.__eq__('functools') == True
# functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True
#
# update_wrapper is the core pure-Python function that wraps calls to; it
# copies WRAPPER_ASSIGNMENTS attributes and updates WRAPPER_UPDATES attrs.
# New to extra202.
# ---------------------------------------------------------------------------

table functools_extra202.update_wrapper_identity:
  description: "functools.update_wrapper __name__, __module__, __qualname__; pure-Python function; the underlying implementation called by wraps; new to extra202"
  kind: python_call_eq
  category: string_identity
  id_prefix: functwraps202

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_name_eq,
       update_wrapper.__name__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function in Lib/functools.py; __name__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra202"]
    - [update_wrapper_module_eq_functools,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra202"]
    - [update_wrapper_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a top-level function with no enclosing scope prefix; __qualname__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra202"]

# ---------------------------------------------------------------------------
# Table 3: functools.wraps and update_wrapper __class__.__name__ cross-check
#
# functools.wraps.__class__.__name__.__eq__('function') == True
# functools.update_wrapper.__class__.__name__.__eq__('function') == True
#
# Both wraps and update_wrapper are pure-Python functions; their __class__ is
# <class 'function'> (the Python function type); this distinguishes them from
# C built-ins (builtin_function_or_method) and C extension types (type).
# New to extra202.
# ---------------------------------------------------------------------------

table functools_extra202.wraps_update_wrapper_class_names:
  description: "functools.wraps and update_wrapper __class__.__name__=='function'; both are pure-Python functions, not C built-ins; new to extra202"
  kind: python_call_eq
  category: string_identity
  id_prefix: functwraps202

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_name_eq_function,
       wraps.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a pure-Python function; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; this distinguishes it from C built-ins (builtin_function_or_method); new to extra202"]
    - [update_wrapper_class_name_eq_function,
       update_wrapper.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a pure-Python function; __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra202"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra202
# ---------------------------------------------------------------------------

invariant functools_extra202.wraps_name:
  description: "functools.wraps.__name__ == 'wraps' — pure-Python decorator factory in Lib/functools.py; new to extra202"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra202.wraps_module:
  description: "functools.wraps.__module__ == 'functools' — defined in Lib/functools.py at module scope; new to extra202"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra202.wraps_qualname:
  description: "functools.wraps.__qualname__ == 'wraps' — top-level function; no enclosing scope prefix; new to extra202"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra202.wraps_class_name:
  description: "functools.wraps.__class__.__name__ == 'function' — pure-Python function, not a C built-in; new to extra202"
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra202.update_wrapper_name:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' — pure-Python function in Lib/functools.py; new to extra202"
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra202.update_wrapper_module:
  description: "functools.update_wrapper.__module__ == 'functools' — defined in Lib/functools.py; __module__ is 'functools'; new to extra202"
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra202.update_wrapper_qualname:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper' — top-level function; __qualname__ is the simple name; new to extra202"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra202.update_wrapper_class_name:
  description: "functools.update_wrapper.__class__.__name__ == 'function' — pure-Python function, not a C built-in; new to extra202"
  kind: python_call_eq
  function: update_wrapper.__class__.__name__.__eq__
  args: ["function"]
  expected: true
