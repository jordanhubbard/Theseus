spec: struct_extra1681
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol dict-presence checks."
    - "struct.Struct is a C extension type; instances are NOT callable — __call__ not in dict → False."
    - "struct.error is a pure Python exception subclass; it does not define __call__ in its own dict → False."
    - "struct.Struct defines pack, unpack, pack_into, unpack_from, iter_unpack, format, size in its own __dict__."
    - "struct.Struct.__dict__.__contains__('format') == True — the format string attribute."
    - "struct.Struct.__dict__.__contains__('size') == True — the computed packed size attribute."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: callable_protocol
#
# struct.Struct is a C extension type.  It does not define __call__ in its
# own __dict__; Struct instances are binary format descriptors, not callables.
# struct.error is an exception subclass; it also does not define __call__.
# ---------------------------------------------------------------------------

table struct_extra1681.callable_protocol:
  description: "struct types __call__ dict-presence checks (wave 559 _extra1681) — struct.Struct.__dict__.__contains__('__call__')==False (Struct is a C extension type; it does not expose tp_call in its Python-visible __dict__; Struct instances represent compiled binary format strings and are not designed to be called as functions); struct.error.__dict__.__contains__('__call__')==False (struct.error is an exception class, not a callable descriptor); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1681

  columns: [id, function, args, expected]
  rows:
    - ["st1681001", "struct.Struct.__dict__.__contains__", ["__call__"],    false]
    - ["st1681002", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st1681003", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st1681004", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st1681005", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1681006", "struct.error.__dict__.__contains__",  ["__call__"],    false]

# ---------------------------------------------------------------------------
# Table 2: struct_method_and_attr_presence
#
# Verifies core packing/unpacking method and attribute presence in
# struct.Struct.  format (the format string) and size (packed byte count)
# are C-level descriptor attributes.  iter_unpack was added in Python 3.4
# and is present in all Python >= 3.9.
# ---------------------------------------------------------------------------

table struct_extra1681.struct_method_and_attr_presence:
  description: "struct.Struct own-dict method and attribute presence (wave 559 _extra1681) — struct.Struct defines pack, unpack, pack_into, unpack_from, iter_unpack (the full packing API) plus format (the compiled format string descriptor) and size (the packed byte count descriptor) in its own __dict__; __call__ is absent because Struct instances are not callable; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1681

  columns: [id, function, args, expected]
  rows:
    - ["st1681010", "struct.Struct.__dict__.__contains__", ["__call__"],    false]
    - ["st1681011", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st1681012", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st1681013", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st1681014", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1681015", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1681016", "struct.Struct.__dict__.__contains__", ["format"],      true]
    - ["st1681017", "struct.Struct.__dict__.__contains__", ["size"],        true]

# ---------------------------------------------------------------------------
# Table 3: struct_type_identity
#
# Verifies module and metatype identity for struct.Struct and struct.error.
# Struct is defined in the _struct C accelerator; __module__ == 'struct'.
# struct.error is a pure-Python exception defined in Lib/struct.py.
# ---------------------------------------------------------------------------

table struct_extra1681.struct_type_identity:
  description: "struct.Struct and struct.error module and metatype identity checks (wave 559 _extra1681) — struct.Struct.__module__ == 'struct' (exposed via the public struct module regardless of the underlying _struct C accelerator); struct.Struct.__class__.__name__ == 'type'; struct.error.__module__ == 'struct'; struct.error.__class__.__name__ == 'type'; neither defines __call__ in its own dict; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1681

  columns: [id, function, args, expected]
  rows:
    - ["st1681020", "struct.Struct.__dict__.__contains__",          ["__call__"],   false]
    - ["st1681021", "struct.Struct.__name__.__eq__",                ["Struct"],     true]
    - ["st1681022", "struct.Struct.__module__.__eq__",              ["struct"],     true]
    - ["st1681023", "struct.Struct.__class__.__name__.__eq__",      ["type"],       true]
    - ["st1681024", "struct.error.__dict__.__contains__",           ["__call__"],   false]
    - ["st1681025", "struct.error.__name__.__eq__",                 ["error"],      true]
    - ["st1681026", "struct.error.__module__.__eq__",               ["struct"],     true]
    - ["st1681027", "struct.error.__class__.__name__.__eq__",       ["type"],       true]
