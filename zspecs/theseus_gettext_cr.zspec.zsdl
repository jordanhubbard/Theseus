spec: theseus_gettext_cr
version: ">=3.0"
backend: python_cleanroom(theseus_gettext_cr)
blocks: gettext

docs: https://docs.python.org/3/library/gettext.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/gettext.html"
  not_derived_from:
    - "CPython source: Lib/gettext.py"
  notes:
    - "Clean-room gettext module. Do NOT import gettext."

error_model: python_exceptions

invariant theseus_gettext_cr.gettext2_nulltranslations:
  description: "NullTranslations().gettext(msg) returns msg unchanged"
  category: behavior
  kind: python_call_eq
  function: gettext2_nulltranslations
  args: []
  expected: true

invariant theseus_gettext_cr.gettext2_install:
  description: "install function is callable"
  category: behavior
  kind: python_call_eq
  function: gettext2_install
  args: []
  expected: true

invariant theseus_gettext_cr.gettext2_find:
  description: "find() returns None when no .mo file found"
  category: behavior
  kind: python_call_eq
  function: gettext2_find
  args: []
  expected: true
