spec: itertools_extra287
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools classes __name__ and __qualname__ identity including batched (3.12+) and pairwise (3.10+)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools classes are C types; __qualname__ matches __name__ (no nesting)"
    - "batched added in Python 3.12, pairwise added in Python 3.10"
    - "All itertools classes have __module__ == 'itertools'"
    - "All itertools classes inherit directly from object"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra287.class_name_identity:
  description: "__name__ for dropwhile, takewhile, groupby, compress, combinations_with_replacement, pairwise, batched"
  kind: python_call_eq
  category: identity
  id_prefix: itex287

  columns: [id, function, args, expected, description]
  rows:
    - [itex287_001, itertools.dropwhile.__name__.__eq__, ["dropwhile"], true, "dropwhile __name__"]
    - [itex287_002, itertools.takewhile.__name__.__eq__, ["takewhile"], true, "takewhile __name__"]
    - [itex287_003, itertools.groupby.__name__.__eq__, ["groupby"], true, "groupby __name__"]
    - [itex287_004, itertools.compress.__name__.__eq__, ["compress"], true, "compress __name__"]
    - [itex287_005, itertools.combinations_with_replacement.__name__.__eq__, ["combinations_with_replacement"], true, "combinations_with_replacement __name__"]
    - [itex287_006, itertools.pairwise.__name__.__eq__, ["pairwise"], true, "pairwise __name__"]
    - [itex287_007, itertools.batched.__name__.__eq__, ["batched"], true, "batched __name__"]

table itertools_extra287.class_qualname_identity:
  description: "__qualname__ matches __name__ for itertools C types"
  kind: python_call_eq
  category: identity
  id_prefix: itex287q

  columns: [id, function, args, expected, description]
  rows:
    - [itex287q_001, itertools.dropwhile.__qualname__.__eq__, ["dropwhile"], true, "dropwhile __qualname__"]
    - [itex287q_002, itertools.takewhile.__qualname__.__eq__, ["takewhile"], true, "takewhile __qualname__"]
    - [itex287q_003, itertools.groupby.__qualname__.__eq__, ["groupby"], true, "groupby __qualname__"]
    - [itex287q_004, itertools.compress.__qualname__.__eq__, ["compress"], true, "compress __qualname__"]
    - [itex287q_005, itertools.combinations_with_replacement.__qualname__.__eq__, ["combinations_with_replacement"], true, "combinations_with_replacement __qualname__"]
    - [itex287q_006, itertools.pairwise.__qualname__.__eq__, ["pairwise"], true, "pairwise __qualname__"]
    - [itex287q_007, itertools.batched.__qualname__.__eq__, ["batched"], true, "batched __qualname__"]

invariant itertools_extra287.dropwhile_module:
  description: "dropwhile __module__ is itertools"
  category: identity
  kind: python_call_eq
  function: itertools.dropwhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra287.takewhile_module:
  description: "takewhile __module__ is itertools"
  category: identity
  kind: python_call_eq
  function: itertools.takewhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra287.combinations_with_replacement_base_class:
  description: "combinations_with_replacement base class is object"
  category: identity
  kind: python_call_eq
  function: itertools.combinations_with_replacement.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra287.batched_base_class:
  description: "batched base class is object"
  category: identity
  kind: python_call_eq
  function: itertools.batched.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
