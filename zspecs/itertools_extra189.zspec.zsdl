spec: itertools_extra189
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/itertools.py"
  notes:
    - "itertools.combinations.__qualname__ == 'combinations' (len=12); verified with Python 3.14.3."
    - "itertools.combinations.__bases__[0].__name__ == 'object' — combinations is a C-extension type whose only base is object; verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' (len=12); verified with Python 3.14.3."
    - "itertools.permutations.__bases__[0].__name__ == 'object' — permutations is a C-extension type whose only base is object; verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'; verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress' (len=8); verified with Python 3.14.3."
    - "itertools.compress.__bases__[0].__name__ == 'object'; verified with Python 3.14.3."
    - "itertools.dropwhile.__bases__[0].__name__ == 'object'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations and itertools.permutations qualname and bases
#
# itertools.combinations.__qualname__      == 'combinations'  (len=12)
# itertools.combinations.__bases__[0].__name__ == 'object'
# itertools.permutations.__qualname__      == 'permutations'  (len=12)
# itertools.permutations.__bases__[0].__name__ == 'object'
#
# Both are C-extension types that inherit directly from object.
# New to extra189.
# ---------------------------------------------------------------------------

table itertools_extra189.combinations_permutations_identity:
  description: "combinations.__qualname__=='combinations' (len=12); combinations.__bases__[0].__name__=='object'; permutations.__qualname__=='permutations' (len=12); permutations.__bases__[0].__name__=='object'; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: iterbases189

  columns: [id, function, args, expected, description]
  rows:
    - [comb_qual_eq,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — C-extension type's __qualname__ is 'combinations' (len=12); str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [comb_qual_len,
       combinations.__qualname__.__len__,
       [],
       12,
       "itertools.combinations.__qualname__.__len__() == 12 — 'combinations' has 12 characters: c-o-m-b-i-n-a-t-i-o-n-s; str.__len__() returns 12; verified with Python 3.14.3; new to extra189"]
    - [perm_qual_eq,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — C-extension type's __qualname__ is 'permutations' (len=12); str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [perm_qual_len,
       permutations.__qualname__.__len__,
       [],
       12,
       "itertools.permutations.__qualname__.__len__() == 12 — 'permutations' has 12 characters: p-e-r-m-u-t-a-t-i-o-n-s; str.__len__() returns 12; verified with Python 3.14.3; new to extra189"]

# ---------------------------------------------------------------------------
# Table 2: __bases__[0].__name__ == 'object' for four itertools types
#
# itertools.combinations.__bases__[0].__name__             == 'object'
# itertools.permutations.__bases__[0].__name__             == 'object'
# itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'
# itertools.compress.__bases__[0].__name__                 == 'object'
#
# All itertools C-extension types inherit directly from object.
# New to extra189.
# ---------------------------------------------------------------------------

table itertools_extra189.bases_object_identity:
  description: "combinations/permutations/combinations_with_replacement/compress __bases__[0].__name__=='object'; all C-extension itertools types inherit directly from object; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: iterbases189

  columns: [id, function, args, expected, description]
  rows:
    - [comb_base_eq,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations is a C-extension type; __bases__[0] is object; verified with Python 3.14.3; new to extra189"]
    - [perm_base_eq,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations is a C-extension type; __bases__[0] is object; verified with Python 3.14.3; new to extra189"]
    - [cwr_base_eq,
       "combinations_with_replacement.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations_with_replacement.__bases__[0].__name__.__eq__('object') == True — combinations_with_replacement is a C-extension type; __bases__[0] is object; verified with Python 3.14.3; new to extra189"]
    - [compress_base_eq,
       "compress.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.compress.__bases__[0].__name__.__eq__('object') == True — compress is a C-extension type; __bases__[0] is object; verified with Python 3.14.3; new to extra189"]

