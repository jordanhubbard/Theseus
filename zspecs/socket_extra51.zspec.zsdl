spec: socket_extra51
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra50.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values; gethostname/getaddrinfo/getfqdn __module__.__eq__('socket') and __module__.__class__.__name__.__eq__('str')."
    - "socket_extra49.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/__doc__.__class__.__name__.__eq__('str'), module __doc__.__class__.__name__/__qualname__/__module__, and socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__len__()."
    - "socket_extra48.zspec.zsdl — covers herror/gaierror/timeout __bases__[0].__qualname__.__eq__('OSError') and herror/gaierror/timeout/socket.__doc__.__class__.__name__.__eq__('str')."
    - "socket_extra47.zspec.zsdl — covers socket/herror/gaierror/timeout __class__.__qualname__.__eq__('type'), gethostname/gethostbyname __class__.__qualname__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn __class__.__qualname__.__eq__('function'), socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins')."
    - "socket_extra38.zspec.zsdl — covers socket.AF_INET==2, SOCK_STREAM==1, SOCK_DGRAM==2 integer values (already covered as __eq__ checks)."
    - "socket_extra35.zspec.zsdl — covers AF_INET/__class__/__qualname__.__len__()==13 and SOCK_STREAM/__class__/__qualname__.__len__()==10."
    - "socket_extra24.zspec.zsdl — covers AF_INET/__class__/__qualname__.__eq__('AddressFamily') and SOCK_STREAM/__class__/__qualname__.__eq__('SocketKind') (only these two, not SOCK_DGRAM)."
    - "socket_extra18.zspec.zsdl — covers AF_INET/__class__/__name__.__len__()==13 and SOCK_STREAM/__class__/__name__.__len__()==10."
    - "socket_extra2.zspec.zsdl — covers AF_INET/__class__/__name__.__eq__('AddressFamily'), SOCK_STREAM/__class__/__name__.__eq__('SocketKind'), SOCK_DGRAM/__class__/__name__.__eq__('SocketKind'), AF_INET==2, SOCK_STREAM==1, SOCK_DGRAM==2."
  notes:
    - "This spec extends socket through socket_extra50; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior socket spec checks __class__.__module__.__eq__('socket') for AF_INET, SOCK_STREAM, or SOCK_DGRAM. socket_extra2 covers __class__.__name__.__eq__('AddressFamily'/'SocketKind') for these enum members. socket_extra24 covers AF_INET/__class__/__qualname__.__eq__ and SOCK_STREAM/__class__/__qualname__.__eq__. But __class__.__module__ — confirming which module defines the AddressFamily and SocketKind enum classes — has never been checked for any of these enum members. AddressFamily and SocketKind are both defined in the socket module; any instance's __class__.__module__ == 'socket'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__module__ == 'socket'. AF_INET is an AddressFamily enum member; AddressFamily is defined in the socket module. No prior spec checks AF_INET.__class__.__module__.__eq__('socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__module__ == 'socket'. SOCK_STREAM is a SocketKind enum member; SocketKind is defined in the socket module. No prior spec checks SOCK_STREAM.__class__.__module__.__eq__('socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__module__ == 'socket'. SOCK_DGRAM is a SocketKind enum member. No prior spec checks SOCK_DGRAM.__class__.__module__.__eq__('socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks __class__.__module__.__len__() for AF_INET, SOCK_STREAM, or SOCK_DGRAM. The length of the __class__.__module__ string ('socket' = 6 chars) is an independent regression vector from the string equality check. If the enum classes were moved to a differently-named module, the length would change. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__module__.__len__() == 6. len('socket') == 6. No prior spec checks AF_INET.__class__.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__module__.__len__() == 6. len('socket') == 6. No prior spec checks SOCK_STREAM.__class__.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior socket spec checks __class__.__qualname__.__eq__('SocketKind') for SOCK_DGRAM. socket_extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind') (only SOCK_STREAM, not SOCK_DGRAM). socket_extra35 covers __class__.__qualname__.__len__() for SOCK_STREAM but not SOCK_DGRAM. SOCK_DGRAM is also a SocketKind member, so SOCK_DGRAM.__class__.__qualname__ == 'SocketKind'. This single-row novel check completes the coverage gap for SOCK_DGRAM on the __qualname__ axis. Additionally, SOCK_DGRAM.__class__.__qualname__.__len__() == 10 is novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__qualname__ == 'SocketKind'. socket_extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind') only. SOCK_DGRAM is a SocketKind member; its __class__.__qualname__ is also 'SocketKind'. No prior spec checks SOCK_DGRAM.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__qualname__.__len__() == 10. len('SocketKind') == 10. socket_extra35 covers SOCK_STREAM.__class__.__qualname__.__len__()==10 but NOT SOCK_DGRAM. No prior spec checks SOCK_DGRAM.__class__.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET / SOCK_STREAM / SOCK_DGRAM __class__.__module__.__eq__('socket')
#
# socket_extra2 covers __class__.__name__.__eq__ for these enum members.
# socket_extra24 covers AF_INET/__class__/__qualname__.__eq__ and
#   SOCK_STREAM/__class__/__qualname__.__eq__ (__qualname__ axis).
# No prior socket spec checks __class__.__module__.__eq__ for any of these
# enum members. AddressFamily and SocketKind are both defined in the socket
# module, so any instance's __class__.__module__ == 'socket'. This provides
# an independent regression vector confirming enum class provenance.
# ---------------------------------------------------------------------------

table socket_extra51.enum_class_modules:
  description: "socket.AF_INET/SOCK_STREAM/SOCK_DGRAM __class__.__module__.__eq__('socket') — AddressFamily and SocketKind are defined in the socket module; novel __class__.__module__ axis for enum members; socket_extra2 covers __class__.__name__; socket_extra24 covers AF_INET/SOCK_STREAM __class__.__qualname__; no prior spec checks __class__.__module__ for any socket enum member"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketaf51

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_class_module_eq,    AF_INET.__class__.__module__.__eq__,    ["socket"], true]
    - [SOCK_STREAM_class_module_eq, SOCK_STREAM.__class__.__module__.__eq__, ["socket"], true]
    - [SOCK_DGRAM_class_module_eq, SOCK_DGRAM.__class__.__module__.__eq__, ["socket"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET / SOCK_STREAM __class__.__module__.__len__()
#
# The __class__.__module__ string for AddressFamily and SocketKind is 'socket'
# (6 chars). No prior socket spec checks __class__.__module__.__len__() for
# any enum member. This provides an independent length regression vector
# complementing the __eq__ check above: if the module is renamed, the length
# changes.
# ---------------------------------------------------------------------------

table socket_extra51.enum_class_module_lengths:
  description: "socket.AF_INET/SOCK_STREAM __class__.__module__.__len__()==6 — len('socket')==6; novel __class__.__module__.__len__() axis for enum members; no prior socket spec checks __class__.__module__.__len__() for AF_INET or SOCK_STREAM"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketaf51

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_class_module_len,    AF_INET.__class__.__module__.__len__,    [], 6]
    - [SOCK_STREAM_class_module_len, SOCK_STREAM.__class__.__module__.__len__, [], 6]

# ---------------------------------------------------------------------------
# socket.SOCK_DGRAM __class__.__qualname__.__eq__('SocketKind')
# and __class__.__qualname__.__len__()==10
#
# socket_extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind')
#   and socket_extra35 covers SOCK_STREAM.__class__.__qualname__.__len__()==10.
# But no prior spec checks __class__.__qualname__.__eq__ or __qualname__.__len__()
# for SOCK_DGRAM. SOCK_DGRAM is also a SocketKind member, so these invariants
# parallel the already-covered SOCK_STREAM checks and complete the SOCK_DGRAM
# coverage gap on the __qualname__ axis.
# ---------------------------------------------------------------------------

table socket_extra51.SOCK_DGRAM_class_qualname:
  description: "socket.SOCK_DGRAM/__class__/__qualname__.__eq__('SocketKind') and __class__/__qualname__.__len__()==10 — SOCK_DGRAM is a SocketKind enum member; socket_extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__ but NOT SOCK_DGRAM; socket_extra35 covers SOCK_STREAM.__class__.__qualname__.__len__ but NOT SOCK_DGRAM; no prior spec checks either axis for SOCK_DGRAM"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketaf51

  columns: [id, function, args, expected]
  rows:
    - [SOCK_DGRAM_class_qualname_eq,  SOCK_DGRAM.__class__.__qualname__.__eq__,  ["SocketKind"], true]
    - [SOCK_DGRAM_class_qualname_len, SOCK_DGRAM.__class__.__qualname__.__len__, [],             10]
