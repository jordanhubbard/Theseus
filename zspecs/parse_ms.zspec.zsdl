spec: parse_ms
version: ">=4.0.0"
backend: node(parse-ms)

docs: https://www.npmjs.com/package/parse-ms

provenance:
  derived_from:
    - "parse-ms README — https://www.npmjs.com/package/parse-ms"
    - "Test vectors verified with parse-ms via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "parse-ms source"
  notes:
    - "parse-ms is an npm package. Install: npm install parse-ms"
    - "Parses milliseconds into a detailed time object with days, hours, minutes, seconds, milliseconds, microseconds, and nanoseconds."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object with time components."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table parse_ms.parseMs:
  kind: node_module_call_eq
  function: "default"
  category: time
  id_prefix: pms

  columns: [id, args, expected]
  rows:
    - [one_sec,  [1000],    {"days": 0, "hours": 0, "minutes": 0, "seconds": 1, "milliseconds": 0, "microseconds": 0, "nanoseconds": 0}]
    - [one_min,  [60000],   {"days": 0, "hours": 0, "minutes": 1, "seconds": 0, "milliseconds": 0, "microseconds": 0, "nanoseconds": 0}]
    - [mixed,    [3661000], {"days": 0, "hours": 1, "minutes": 1, "seconds": 1, "milliseconds": 0, "microseconds": 0, "nanoseconds": 0}]
