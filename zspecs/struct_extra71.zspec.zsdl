spec: struct_extra71
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra70.zspec.zsdl — covers Struct/__dict__/__contains__ __init__/__new__/__repr__/__module__ / pack/unpack/calcsize/__doc__.__contains__('format') / Struct/__doc__.__contains__('fmt'/'Struct') (table + invariants)."
    - "struct_extra69.zspec.zsdl — covers Struct/__dict__/__contains__('__sizeof__') / Struct.size/__qualname__=='Struct.size' / error/__qualname__=='error' (table + invariants)."
    - "struct_extra68.zspec.zsdl — covers Struct.size/format/__class__/__name__=='getset_descriptor' / Struct/__doc__/__class__/__name__=='str' / Struct/__name__/__module__/__qualname__ / pack/unpack/calcsize/__qualname__ (table + invariants)."
    - "struct_extra67.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__class__/__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct/__dict__/__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra70; it does NOT duplicate invariants present in those files."
    - "Wave 242 theme: struct.Struct __dict__ remaining attributes + module-level function __module__."
    - "struct.Struct.__dict__.__contains__('__doc__') == True — Struct defines __doc__ in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct' — pack is a C builtin from the _struct extension (not the struct wrapper module). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct' — unpack is a C builtin from the _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct' — calcsize is a C builtin from the _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == '_struct' — pack_into is a C builtin from the _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct' — iter_unpack is a C builtin from the _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__module__ == '_struct' — unpack_from is a C builtin from the _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ for __doc__
#
# Wave 242 theme: struct.Struct __dict__ remaining attributes.
#
# struct.Struct defines __doc__ in its class __dict__. struct_extra65 covers
# Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/
# size/format. struct_extra69 covers __sizeof__. struct_extra70 covers
# __init__/__new__/__repr__/__module__. No prior struct spec checks
# Struct.__dict__.__contains__ for __doc__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra71.Struct_dict_contains_doc:
  description: "struct.Struct/__dict__.__contains__('__doc__')==True — Struct defines __doc__ in its class __dict__; struct_extra65 covers pack/unpack/size/format; struct_extra69 covers __sizeof__; struct_extra70 covers __init__/__new__/__repr__/__module__; no prior struct spec checks __doc__ in Struct.__dict__; first __doc__ dict contains anchor for Struct"
  kind: python_call_eq
  category: class_dict
  id_prefix: structmore71

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_contains_doc, Struct.__dict__.__contains__, ["__doc__"], true]

# ---------------------------------------------------------------------------
# struct.pack and unpack __module__ identity
#
# Wave 242 theme: struct module-level function __module__.
#
# struct.pack and struct.unpack are C builtins from the _struct extension.
# Their __module__ is '_struct'. No prior struct spec checks pack.__module__
# or unpack.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra71.pack_unpack_module:
  description: "struct.pack/__module__.__eq__('_struct')==True / struct.unpack/__module__.__eq__('_struct')==True — pack and unpack are C builtins from the _struct C extension (not the struct wrapper module); no prior struct spec checks pack.__module__ or unpack.__module__; first __module__ anchor for struct.pack and struct.unpack"
  kind: python_call_eq
  category: module_attrs
  id_prefix: structmore71

  columns: [id, function, args, expected]
  rows:
    - [pack_module_struct,   pack.__module__.__eq__,   ["_struct"], true]
    - [unpack_module_struct, unpack.__module__.__eq__, ["_struct"], true]

# ---------------------------------------------------------------------------
# struct.calcsize / pack_into / unpack_from __module__ identity
#
# Wave 242 theme: struct module-level function __module__.
#
# struct.calcsize, pack_into, and unpack_from are C builtins from _struct.
# Their __module__ is '_struct'. No prior struct spec checks calcsize.__module__,
# pack_into.__module__, or unpack_from.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra71.calcsize_packinto_unpackfrom_module:
  description: "struct.calcsize/__module__.__eq__('_struct')==True / pack_into/__module__.__eq__('_struct')==True / unpack_from/__module__.__eq__('_struct')==True — calcsize, pack_into, and unpack_from are C builtins from the _struct extension; no prior struct spec checks calcsize/__module__, pack_into/__module__, or unpack_from/__module__; first __module__ anchor for calcsize/pack_into/unpack_from"
  kind: python_call_eq
  category: module_attrs
  id_prefix: structmore71

  columns: [id, function, args, expected]
  rows:
    - [calcsize_module_struct,    calcsize.__module__.__eq__,    ["_struct"], true]
    - [pack_into_module_struct,   pack_into.__module__.__eq__,   ["_struct"], true]
    - [unpack_from_module_struct, unpack_from.__module__.__eq__, ["_struct"], true]

# ---------------------------------------------------------------------------
# struct.iter_unpack __module__ identity
#
# Wave 242 theme: struct iter_unpack __module__.
#
# struct.iter_unpack is a C builtin from the _struct extension.
# Its __module__ is '_struct'. No prior struct spec checks iter_unpack.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra71.iter_unpack_module:
  description: "struct.iter_unpack/__module__.__eq__('_struct')==True — iter_unpack is a C builtin from the _struct extension; no prior struct spec checks iter_unpack.__module__; first __module__ anchor for struct.iter_unpack"
  kind: python_call_eq
  category: module_attrs
  id_prefix: structmore71

  columns: [id, function, args, expected]
  rows:
    - [iter_unpack_module_struct, iter_unpack.__module__.__eq__, ["_struct"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__doc__') — standalone
#
# struct.Struct defines __doc__ in its class __dict__. No prior struct spec
# checks Struct.__dict__.__contains__('__doc__'). First __doc__ dict contains
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra71.Struct_dict_contains_doc:
  description: "struct.Struct.__dict__.__contains__('__doc__') == True — Struct defines __doc__ in its class __dict__; no prior struct spec checks __doc__ in Struct.__dict__; first __doc__ dict contains standalone for Struct"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__doc__"]
  expected: true

