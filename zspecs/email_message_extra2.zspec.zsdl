spec: email_message_extra2
version: ">=3.6"
backend: python_module(email.message)

docs: https://docs.python.org/3/library/email.message.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.message.html — Python email.message documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/message.py"
    - "email_message.zspec.zsdl — covers Message.__name__, MIMEPart.__name__, EmailMessage.__name__; Message behavior (missing header, keys, len, content_type, is_multipart, charset, defects); EmailMessage content_type; issubclass check"
    - "email_message_extra.zspec.zsdl — covers Message/MIMEPart/EmailMessage __qualname__ and __module__; Message.__bases__[0].__name__; Message().__class__.__name__; EmailMessage().__class__.__name__; Message is_type; EmailMessage.__bases__[0].__name__"
    - "email_extra.zspec.zsdl — covers email top-level function __name__ checks; message_from_string/bytes behavior"
    - "email_mime.zspec.zsdl — covers MIMEText/MIMEMultipart/MIMEBase; get_payload for MIMEText instances"
  notes:
    - "This spec extends email_message.zspec.zsdl and email_message_extra.zspec.zsdl."
    - "Focus: Message instance method __name__ checks (not covered in any prior email.message spec)."
    - "Message.get.__name__ == 'get' — dict-like header access with default."
    - "Message.__getitem__.__name__ == '__getitem__' — bracket header access."
    - "Message.__setitem__.__name__ == '__setitem__' — bracket header assignment."
    - "Message.__contains__.__name__ == '__contains__' — 'in' operator for header names."
    - "Message.__len__.__name__ == '__len__' — number of headers."
    - "Message.keys.__name__ == 'keys' — list of header names."
    - "Message.values.__name__ == 'values' — list of header values."
    - "Message.items.__name__ == 'items' — list of (name, value) pairs."
    - "Message.get_content_type.__name__ == 'get_content_type'."
    - "Message.get_payload.__name__ == 'get_payload' — returns the payload."
    - "Message.set_payload.__name__ == 'set_payload' — sets the payload."
    - "Message.is_multipart.__name__ == 'is_multipart'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Message instance method __name__ checks
#
# email_message.zspec.zsdl tests behavior of Message methods (calling them
# on Message() instances), but not the method __name__ attributes themselves.
# email_message_extra.zspec.zsdl checks __qualname__ and __module__ for the
# classes but not for any individual methods.
# No prior spec checks __name__ for any email.message.Message method.
# ---------------------------------------------------------------------------

table email_message_extra2.message_method_names:
  kind: python_call_eq
  category: function_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [get,              Message.get.__name__.__eq__,              ["get"],              true]
    - [__getitem__,      Message.__getitem__.__name__.__eq__,      ["__getitem__"],      true]
    - [__setitem__,      Message.__setitem__.__name__.__eq__,      ["__setitem__"],      true]
    - [__contains__,     Message.__contains__.__name__.__eq__,     ["__contains__"],     true]
    - [__len__,          Message.__len__.__name__.__eq__,          ["__len__"],          true]
    - [keys,             Message.keys.__name__.__eq__,             ["keys"],             true]
    - [values,           Message.values.__name__.__eq__,           ["values"],           true]
    - [items,            Message.items.__name__.__eq__,            ["items"],            true]
    - [get_payload,      Message.get_payload.__name__.__eq__,      ["get_payload"],      true]
    - [set_payload,      Message.set_payload.__name__.__eq__,      ["set_payload"],      true]
    - [get_content_type, Message.get_content_type.__name__.__eq__, ["get_content_type"], true]
    - [is_multipart,     Message.is_multipart.__name__.__eq__,     ["is_multipart"],     true]

# ---------------------------------------------------------------------------
# Message instance method __qualname__ checks
#
# Consistent with the pattern in xml_etree_extra4 and html_parser_extra3:
# instance methods have __qualname__ == 'ClassName.method_name'.
# No prior email.message spec checks method-level __qualname__.
# ---------------------------------------------------------------------------

table email_message_extra2.message_method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [get,              Message.get.__qualname__.__eq__,              ["Message.get"],              true]
    - [keys,             Message.keys.__qualname__.__eq__,             ["Message.keys"],             true]
    - [values,           Message.values.__qualname__.__eq__,           ["Message.values"],           true]
    - [items,            Message.items.__qualname__.__eq__,            ["Message.items"],            true]
    - [get_payload,      Message.get_payload.__qualname__.__eq__,      ["Message.get_payload"],      true]
    - [set_payload,      Message.set_payload.__qualname__.__eq__,      ["Message.set_payload"],      true]
    - [get_content_type, Message.get_content_type.__qualname__.__eq__, ["Message.get_content_type"], true]
    - [is_multipart,     Message.is_multipart.__qualname__.__eq__,     ["Message.is_multipart"],     true]

# ---------------------------------------------------------------------------
# MIMEPart is_type check
#
# email_message_extra checks Message.__class__.__name__ == 'type' and
# EmailMessage.__bases__[0].__name__ == 'MIMEPart'. The is_type check for
# MIMEPart itself has not been tested.
# ---------------------------------------------------------------------------

invariant email_message_extra2.MIMEPart.is_type:
  description: "email.message.MIMEPart.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: MIMEPart.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# EmailMessage is_type check
#
# email_message_extra checks Message is_type only.
# EmailMessage is_type has not been verified.
# ---------------------------------------------------------------------------

invariant email_message_extra2.EmailMessage.is_type:
  description: "email.message.EmailMessage.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: EmailMessage.__class__.__name__.__eq__
  args: ["type"]
  expected: true
