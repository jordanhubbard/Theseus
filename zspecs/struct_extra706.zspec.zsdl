spec: struct_extra706
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers struct module-level function qualnames and Struct class attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra706.qualnames:
  description: "struct module-level function and Struct class qualname and module attribute checks"
  kind: python_call_eq
  category: qualnames
  id_prefix: st706qn
  columns: [id, function, args, expected]
  rows:
    - [st706qn001, struct.pack.__qualname__.__eq__, ["pack"], true]
    - [st706qn002, struct.pack.__module__.__eq__, ["struct"], true]
    - [st706qn003, struct.unpack.__qualname__.__eq__, ["unpack"], true]
    - [st706qn004, struct.unpack.__module__.__eq__, ["struct"], true]
    - [st706qn005, struct.pack_into.__qualname__.__eq__, ["pack_into"], true]
    - [st706qn006, struct.unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [st706qn007, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [st706qn008, struct.calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [st706qn009, struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - [st706qn010, struct.Struct.__module__.__eq__, ["struct"], true]
    - [st706qn011, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st706qn012, struct.error.__module__.__eq__, ["struct"], true]
