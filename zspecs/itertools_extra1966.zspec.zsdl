spec: itertools_extra1966
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "All itertools C-types (count, cycle, chain, islice, zip_longest, product, combinations, permutations) do NOT define context manager protocol."
    - "None of the itertools types define __aenter__ or __aexit__ — itertools has no async context manager types."
    - "None of the itertools types define __del__ — no finalizer protocol in itertools."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra1966.context_manager_enter:
  description: "itertools C-types __enter__ dict-presence checks — none define context manager protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1966
  columns: [id, function, args, expected]
  rows:
    - ["it1966001", "itertools.count.__dict__.__contains__",        ["__enter__"], false]
    - ["it1966002", "itertools.cycle.__dict__.__contains__",        ["__enter__"], false]
    - ["it1966003", "itertools.chain.__dict__.__contains__",        ["__enter__"], false]
    - ["it1966004", "itertools.islice.__dict__.__contains__",       ["__enter__"], false]
    - ["it1966005", "itertools.zip_longest.__dict__.__contains__",  ["__enter__"], false]
    - ["it1966006", "itertools.product.__dict__.__contains__",      ["__enter__"], false]
    - ["it1966007", "itertools.combinations.__dict__.__contains__", ["__enter__"], false]
    - ["it1966008", "itertools.permutations.__dict__.__contains__", ["__enter__"], false]

