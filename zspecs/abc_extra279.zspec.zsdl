spec: abc_extra279
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.update_abstractmethods — update_abstractmethods (added 3.10)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra278.zspec.zsdl — covers collections.abc.Sequence __abstractmethods__ membership; Sequence concrete mixin method __qualname__ lengths; MutableSequence __abstractmethods__.__len__()"
    - "abc_extra28.zspec.zsdl — covers ABCMeta.__subclasshook__ name lengths, deprecated decorator lengths, module membership lengths"
    - "abc_extra.zspec.zsdl — covers abc.abstractmethod, abc.ABC, abc.ABCMeta identity checks"
  notes:
    - "This spec uses the abc module (NOT collections.abc). It covers: abc module identity (__name__, __spec__.name, __package__, __spec__.origin, __loader__.__name__); ABC class identity (__module__, __name__.__len__, __qualname__.__len__, __bases__[0].__name__, __mro__.__len__()); ABCMeta class identity (__module__, __name__.__len__, __bases__[0].__name__, __mro__.__len__()); update_abstractmethods function identity (__qualname__, __module__, __qualname__.__len__()); get_cache_token function identity (__qualname__, __module__); ABCMeta.register and ABCMeta.__subclasscheck__ __qualname__ lengths."
    - "abc.__name__ == 'abc' (len=3); abc.__package__ == '' (empty string, len=0); abc.__spec__.name == 'abc'; abc.__spec__.origin == 'frozen'; abc.__loader__.__name__ == 'FrozenImporter'. The abc module is loaded from frozen bytecode embedded in CPython, not from a .py file at runtime (even though abc.__file__ points to abc.py). NOTE: abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, not an instance) — use abc.__loader__.__name__ == 'FrozenImporter' to identify the loader. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ABC.__module__ == 'abc'; ABC.__name__.__len__() == 3; ABC.__qualname__.__len__() == 3; ABC.__bases__[0].__name__ == 'object'; ABC.__mro__.__len__() == 2 ([ABC, object]). ABC is a minimal helper class with no abstract methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ABCMeta.__module__ == 'abc'; ABCMeta.__name__.__len__() == 7; ABCMeta.__bases__[0].__name__ == 'type'; ABCMeta.__mro__.__len__() == 3 ([ABCMeta, type, object]). ABCMeta is a metaclass, so it subclasses 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.update_abstractmethods (added in Python 3.10) has __qualname__ == 'update_abstractmethods' (len=22) and __module__ == 'abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.get_cache_token.__module__ == '_abc' (from the C extension), __qualname__ == 'get_cache_token' (len=15). Note the module is '_abc', not 'abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25); __subclasscheck__ is the longer of the two. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module identity — extra279
#
# abc.__name__             == 'abc'            (len=3)
# abc.__package__          == ''               (len=0, empty string — abc is a top-level module)
# abc.__spec__.name        == 'abc'
# abc.__spec__.origin      == 'frozen'         (loaded from frozen bytecode)
# abc.__loader__.__name__  == 'FrozenImporter' (abc.__loader__ is the FrozenImporter *class* itself)
# ---------------------------------------------------------------------------

table abc_extra279.abc_module_identity:
  description: "abc module identity checks in extra279 namespace — __name__=='abc' (len=3); __package__=='' (empty, top-level module); __spec__.origin=='frozen'; __loader__.__name__=='FrozenImporter'; abc is loaded from frozen bytecode embedded in CPython; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmod279

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,         abc.__name__.__eq__,              ["abc"],            true,  "abc.__name__ == 'abc'; verified with Python 3.14.3"]
    - [name_len,        abc.__name__.__len__,             [],                 3,     "abc.__name__.__len__() == 3 — 'abc' is 3 characters; verified with Python 3.14.3"]
    - [pkg_len,         abc.__package__.__len__,          [],                 0,     "abc.__package__.__len__() == 0 — __package__ is empty string for top-level abc module; verified with Python 3.14.3"]
    - [spec_name_eq,    abc.__spec__.name.__eq__,         ["abc"],            true,  "abc.__spec__.name == 'abc'; verified with Python 3.14.3"]
    - [spec_origin_eq,  abc.__spec__.origin.__eq__,       ["frozen"],         true,  "abc.__spec__.origin == 'frozen' — abc is loaded from CPython frozen bytecode; verified with Python 3.14.3"]
    - [loader_name_eq,  abc.__loader__.__name__.__eq__,   ["FrozenImporter"], true,  "abc.__loader__.__name__ == 'FrozenImporter' — abc.__loader__ is the FrozenImporter class itself; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC and ABCMeta class identity — extra279
#
# ABC.__module__             == 'abc'
# ABC.__name__.__len__()     == 3
# ABC.__qualname__.__len__() == 3
# ABC.__bases__[0].__name__  == 'object'
# ABC.__mro__.__len__()      == 2  ([ABC, object])
#
# ABCMeta.__module__             == 'abc'
# ABCMeta.__name__.__len__()     == 7
# ABCMeta.__bases__[0].__name__  == 'type'  (ABCMeta is a metaclass)
# ABCMeta.__mro__.__len__()      == 3  ([ABCMeta, type, object])
# ---------------------------------------------------------------------------

table abc_extra279.abc_abcmeta_class_identity:
  description: "abc.ABC and abc.ABCMeta class identity checks in extra279 namespace — ABC is a flat object subclass (mro len=2); ABCMeta subclasses type (mro len=3); both have __module__=='abc'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcclass279

  columns: [id, function, args, expected, description]
  rows:
    - [abc_module_eq,     ABC.__module__.__eq__,                   ["abc"],    true,  "ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abc_name_len,      ABC.__name__.__len__,                    [],         3,     "ABC.__name__.__len__() == 3 — 'ABC' is 3 characters; verified with Python 3.14.3"]
    - [abc_qualname_len,  ABC.__qualname__.__len__,                [],         3,     "ABC.__qualname__.__len__() == 3 — top-level class, __qualname__ == __name__; verified with Python 3.14.3"]
    - [abc_base_eq,       "ABC.__bases__[0].__name__.__eq__",      ["object"], true,  "ABC.__bases__[0].__name__ == 'object' — ABC is a direct object subclass; verified with Python 3.14.3"]
    - [abc_mro_len,       ABC.__mro__.__len__,                     [],         2,     "ABC.__mro__.__len__() == 2 — [ABC, object]; verified with Python 3.14.3"]
    - [meta_module_eq,    ABCMeta.__module__.__eq__,               ["abc"],    true,  "ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [meta_name_len,     ABCMeta.__name__.__len__,                [],         7,     "ABCMeta.__name__.__len__() == 7 — 'ABCMeta' is 7 characters; verified with Python 3.14.3"]
    - [meta_base_eq,      "ABCMeta.__bases__[0].__name__.__eq__",  ["type"],   true,  "ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass (subclasses type); verified with Python 3.14.3"]
    - [meta_mro_len,      ABCMeta.__mro__.__len__,                 [],         3,     "ABCMeta.__mro__.__len__() == 3 — [ABCMeta, type, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# update_abstractmethods and get_cache_token function identity — extra279
#
# abc.update_abstractmethods (added in Python 3.10):
#   __qualname__ == 'update_abstractmethods'  (len=22)
#   __module__   == 'abc'
#
# abc.get_cache_token (from C extension _abc):
#   __qualname__ == 'get_cache_token'  (len=15)
#   __module__   == '_abc'  (NOT 'abc' — implemented in C)
# ---------------------------------------------------------------------------

invariant abc_extra279.update_abstractmethods.qualname_eq:
  description: "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — module-level function added in Python 3.10 (len=22)"
  category: functions
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra279.update_abstractmethods.qualname_len:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — 'update_abstractmethods' is 22 characters"
  category: functions
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22

invariant abc_extra279.update_abstractmethods.module_eq:
  description: "abc.update_abstractmethods.__module__ == 'abc' — pure-Python function defined in abc module"
  category: functions
  kind: python_call_eq
  function: update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra279.get_cache_token.module_eq:
  description: "abc.get_cache_token.__module__ == '_abc' — implemented in the _abc C extension, not in abc.py"
  category: functions
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra279.get_cache_token.qualname_len:
  description: "abc.get_cache_token.__qualname__.__len__() == 15 — 'get_cache_token' is 15 characters"
  category: functions
  kind: python_call_eq
  function: get_cache_token.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# ABCMeta.register and ABCMeta.__subclasscheck__ qualname lengths — extra279
#
# ABCMeta.register.__qualname__          == 'ABCMeta.register'         (len=16)
# ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25)
# __subclasscheck__ has the longer qualname (25 > 16).
# ---------------------------------------------------------------------------

invariant abc_extra279.ABCMeta.register_qualname_len:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' is 16 characters"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra279.ABCMeta.subclasscheck_qualname_len:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — 'ABCMeta.__subclasscheck__' is 25 characters; the longest of the surveyed ABCMeta method qualnames"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra279.ABCMeta.subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — the hook that ABCMeta registers to intercept issubclass() calls (len=25)"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true
