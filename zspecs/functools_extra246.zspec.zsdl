invariant functools_extra246.updwrap_doc_contains_wrapper:
  description: "functools.update_wrapper.__doc__.__contains__('wrapper') == True; new to extra246"
  kind: python_call_eq
  function: update_wrapper.__doc__.__contains__
  args: ["wrapper"]
