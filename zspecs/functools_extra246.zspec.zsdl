spec: functools_extra246
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra245.zspec.zsdl — covers cached_property and total_ordering identity"
    - "functools_extra.zspec.zsdl — covers reduce/partial/cached_property/cmp_to_key/total_ordering/singledispatch names and modules"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
  notes:
    - "This spec covers functools.wraps and functools.update_wrapper function identity contracts."
    - "functools.wraps.__name__ == 'wraps' (len=5) — wraps is a Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' (len=9) — wraps is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' (len=5) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a plain Python function. Verified with Python 3.14.3."
    - "functools.wraps.__doc__ contains 'wrapper' == True — docstring says 'Decorator factory to apply update_wrapper() to a wrapper function'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' (len=14) — update_wrapper is a Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' (len=9) — update_wrapper is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' (len=14) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a plain Python function. Verified with Python 3.14.3."
    - "functools.update_wrapper.__doc__ contains 'wrapper' == True — docstring says 'Update a wrapper function to look like the wrapped function'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps identity contracts
#
# functools.wraps.__name__ == 'wraps' (len=5)
# functools.wraps.__module__ == 'functools' (len=9)
# functools.wraps.__qualname__ == 'wraps' (len=5)
# functools.wraps.__class__.__name__ == 'function'
# functools.wraps.__doc__.__contains__('wrapper') == True
#
# wraps is a Python function in Lib/functools.py. New to extra246.
# ---------------------------------------------------------------------------

table functools_extra246.wraps246_identity:
  description: "functools.wraps identity: name, module, qualname, class, doc; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: wraps246

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — wraps is a Python function in Lib/functools.py; __name__ is 'wraps' (len=5); new to extra246"]
    - [wraps_name_len_5,
       wraps.__name__.__len__,
       [],
       5,
       "functools.wraps.__name__.__len__() == 5 — 'wraps' has exactly 5 characters (w-r-a-p-s); str.__len__() returns 5; new to extra246"]
    - [wraps_module_eq,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra246"]
    - [wraps_module_len_9,
       wraps.__module__.__len__,
       [],
       9,
       "functools.wraps.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra246"]
    - [wraps_qualname_eq,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — __qualname__ is 'wraps' (len=5); same as __name__ for top-level function; new to extra246"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps class and doc contracts
#
# functools.wraps.__class__.__name__ == 'function'
# functools.wraps.__qualname__.__len__() == 5
# functools.wraps.__doc__.__contains__('wrapper') == True
# functools.wraps.__doc__.__contains__('update_wrapper') == True
# functools.wraps.__doc__.__class__.__name__ == 'str'
#
# New to extra246.
# ---------------------------------------------------------------------------

table functools_extra246.wraps246_class_doc:
  description: "functools.wraps class, qualname len, doc checks; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: wraps246doc

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_is_function,
       wraps.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a plain Python function; its __class__ is the built-in function type; new to extra246"]
    - [wraps_qualname_len_5,
       wraps.__qualname__.__len__,
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — 'wraps' has exactly 5 characters; str.__len__() returns 5; new to extra246"]
    - [wraps_doc_contains_wrapper,
       wraps.__doc__.__contains__,
       ["wrapper"],
       true,
       "functools.wraps.__doc__.__contains__('wrapper') == True — docstring says 'Decorator factory to apply update_wrapper() to a wrapper function'; new to extra246"]
    - [wraps_doc_contains_update_wrapper,
       wraps.__doc__.__contains__,
       ["update_wrapper"],
       true,
       "functools.wraps.__doc__.__contains__('update_wrapper') == True — docstring references update_wrapper() in the description; new to extra246"]
    - [wraps_doc_class_is_str,
       wraps.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.wraps.__doc__.__class__.__name__.__eq__('str') == True — the wraps docstring is a plain Python str object; new to extra246"]

# ---------------------------------------------------------------------------
# Table 3: functools.update_wrapper identity contracts
#
# functools.update_wrapper.__name__ == 'update_wrapper' (len=14)
# functools.update_wrapper.__module__ == 'functools' (len=9)
# functools.update_wrapper.__qualname__ == 'update_wrapper' (len=14)
# functools.update_wrapper.__class__.__name__ == 'function'
# functools.update_wrapper.__doc__.__contains__('wrapper') == True
#
# update_wrapper is a Python function in Lib/functools.py. New to extra246.
# ---------------------------------------------------------------------------

table functools_extra246.updwrap246_identity:
  description: "functools.update_wrapper identity: name, module, qualname, class, doc; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: updwrap246

  columns: [id, function, args, expected, description]
  rows:
    - [updwrap_name_eq,
       update_wrapper.__name__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper is a Python function in Lib/functools.py; __name__ is 'update_wrapper' (len=14); new to extra246"]
    - [updwrap_name_len_14,
       update_wrapper.__name__.__len__,
       [],
       14,
       "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' has exactly 14 characters; str.__len__() returns 14; new to extra246"]
    - [updwrap_module_eq,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra246"]
    - [updwrap_module_len_9,
       update_wrapper.__module__.__len__,
       [],
       9,
       "functools.update_wrapper.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra246"]
    - [updwrap_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — __qualname__ is 'update_wrapper' (len=14); same as __name__ for top-level function; new to extra246"]

# ---------------------------------------------------------------------------
# Table 4: functools.update_wrapper class and doc contracts
#
# functools.update_wrapper.__class__.__name__ == 'function'
# functools.update_wrapper.__qualname__.__len__() == 14
# functools.update_wrapper.__doc__.__contains__('wrapper') == True
# functools.update_wrapper.__doc__.__contains__('wrapped') == True
# functools.update_wrapper.__doc__.__class__.__name__ == 'str'
#
# New to extra246.
# ---------------------------------------------------------------------------

table functools_extra246.updwrap246_class_doc:
  description: "functools.update_wrapper class, qualname len, doc checks; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: updwrap246doc

  columns: [id, function, args, expected, description]
  rows:
    - [updwrap_class_is_function,
       update_wrapper.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a plain Python function; its __class__ is the built-in function type; new to extra246"]
    - [updwrap_qualname_len_14,
       update_wrapper.__qualname__.__len__,
       [],
       14,
       "functools.update_wrapper.__qualname__.__len__() == 14 — 'update_wrapper' has exactly 14 characters; str.__len__() returns 14; new to extra246"]
    - [updwrap_doc_contains_wrapper,
       update_wrapper.__doc__.__contains__,
       ["wrapper"],
       true,
       "functools.update_wrapper.__doc__.__contains__('wrapper') == True — docstring says 'Update a wrapper function to look like the wrapped function'; new to extra246"]
    - [updwrap_doc_contains_wrapped,
       update_wrapper.__doc__.__contains__,
       ["wrapped"],
       true,
       "functools.update_wrapper.__doc__.__contains__('wrapped') == True — docstring references 'wrapped' as the original function argument; new to extra246"]
    - [updwrap_doc_class_is_str,
       update_wrapper.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.update_wrapper.__doc__.__class__.__name__.__eq__('str') == True — the update_wrapper docstring is a plain Python str object; new to extra246"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra246
# ---------------------------------------------------------------------------

invariant functools_extra246.wraps_name_eq:
  description: "functools.wraps.__name__ == 'wraps' (len=5); new to extra246"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra246.wraps_name_len_5:
  description: "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters; new to extra246"
  kind: python_call_eq
  function: wraps.__name__.__len__
  args: []
  expected: 5

invariant functools_extra246.wraps_module_eq:
  description: "functools.wraps.__module__ == 'functools' — defined in Lib/functools.py; new to extra246"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra246.wraps_module_len_9:
  description: "functools.wraps.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra246"
  kind: python_call_eq
  function: wraps.__module__.__len__
  args: []
  expected: 9

invariant functools_extra246.wraps_qualname_eq:
  description: "functools.wraps.__qualname__ == 'wraps' (len=5); new to extra246"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra246.wraps_class_is_function:
  description: "functools.wraps.__class__.__name__ == 'function' — plain Python function; new to extra246"
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra246.wraps_doc_contains_wrapper:
  description: "functools.wraps.__doc__.__contains__('wrapper') == True; new to extra246"
  kind: python_call_eq
  function: wraps.__doc__.__contains__
  args: ["wrapper"]
  expected: true

invariant functools_extra246.updwrap_name_eq:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' (len=14); new to extra246"
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra246.updwrap_name_len_14:
  description: "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' has 14 characters; new to extra246"
  kind: python_call_eq
  function: update_wrapper.__name__.__len__
  args: []
  expected: 14

invariant functools_extra246.updwrap_module_eq:
  description: "functools.update_wrapper.__module__ == 'functools' — defined in Lib/functools.py; new to extra246"
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra246.updwrap_module_len_9:
  description: "functools.update_wrapper.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra246"
  kind: python_call_eq
  function: update_wrapper.__module__.__len__
  args: []
  expected: 9

invariant functools_extra246.updwrap_qualname_eq:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper' (len=14); new to extra246"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra246.updwrap_class_is_function:
  description: "functools.update_wrapper.__class__.__name__ == 'function' — plain Python function; new to extra246"
  kind: python_call_eq
  function: update_wrapper.__class__.__name__.__eq__
  args: ["function"]
