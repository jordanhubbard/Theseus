spec: re_extra134
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Lib/re/_constants.py"
  notes:
    - "This spec covers: re.RegexFlag enum member integer values and name string lengths."
    - "re.IGNORECASE.value == 2 — case-insensitive matching flag (bit 1)."
    - "re.LOCALE.value == 4 — locale-dependent matching flag (bit 2)."
    - "re.MULTILINE.value == 8 — multiline mode flag (bit 3)."
    - "re.DOTALL.value == 16 — dot-all mode flag (bit 4)."
    - "re.UNICODE.value == 32 — Unicode matching flag (bit 5)."
    - "re.VERBOSE.value == 64 — verbose/free-spacing flag (bit 6)."
    - "re.ASCII.value == 256 — ASCII-only matching flag (bit 8)."
    - "re.NOFLAG.value == 0 — no flags set (identity element for bitwise OR of flags)."
    - "re.IGNORECASE.name == 'IGNORECASE' (length 10)."
    - "re.MULTILINE.name == 'MULTILINE' (length 9)."
    - "re.DOTALL.name == 'DOTALL' (length 6)."
    - "re.VERBOSE.name == 'VERBOSE' (length 7)."
    - "re.UNICODE.name == 'UNICODE' (length 7)."
    - "re.LOCALE.name == 'LOCALE' (length 6)."
    - "re.ASCII.name == 'ASCII' (length 5)."
    - "re.NOFLAG.name == 'NOFLAG' (length 6)."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (each member is a RegexFlag instance)."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag enum member integer values (powers of 2 plus 0 for NOFLAG)
# IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64,
# ASCII=256, NOFLAG=0.
# ---------------------------------------------------------------------------

table re_extra134.RegexFlag_values:
  description: "re.RegexFlag enum member .value integer equality: IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64, ASCII=256, NOFLAG=0"
  kind: python_call_eq
  category: enum_values
  id_prefix: reregexflag134

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_val,  IGNORECASE.value.__eq__,  [2],   true]
    - [locale_val,      LOCALE.value.__eq__,      [4],   true]
    - [multiline_val,   MULTILINE.value.__eq__,   [8],   true]
    - [dotall_val,      DOTALL.value.__eq__,      [16],  true]
    - [unicode_val,     UNICODE.value.__eq__,     [32],  true]
    - [verbose_val,     VERBOSE.value.__eq__,     [64],  true]
    - [ascii_val,       ASCII.value.__eq__,       [256], true]
    - [noflag_val,      NOFLAG.value.__eq__,      [0],   true]
    - [ignorecase_not,  IGNORECASE.value.__eq__,  [1],   false]
    - [multiline_not,   MULTILINE.value.__eq__,   [2],   false]

# ---------------------------------------------------------------------------
# re.RegexFlag enum member name string lengths
# IGNORECASE (10), MULTILINE (9), DOTALL (6), VERBOSE (7),
# UNICODE (7), LOCALE (6), ASCII (5), NOFLAG (6).
# ---------------------------------------------------------------------------

table re_extra134.RegexFlag_name_lengths:
  description: "re.RegexFlag enum member .name string lengths: IGNORECASE=10, MULTILINE=9, DOTALL=6, VERBOSE=7, UNICODE=7, LOCALE=6, ASCII=5, NOFLAG=6"
  kind: python_call_eq
  category: enum_values
  id_prefix: reregexflag134

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_nlen, IGNORECASE.name.__len__, [], 10]
    - [multiline_nlen,  MULTILINE.name.__len__,  [], 9]
    - [dotall_nlen,     DOTALL.name.__len__,     [], 6]
    - [verbose_nlen,    VERBOSE.name.__len__,    [], 7]
    - [unicode_nlen,    UNICODE.name.__len__,    [], 7]
    - [locale_nlen,     LOCALE.name.__len__,     [], 6]
    - [ascii_nlen,      ASCII.name.__len__,      [], 5]
    - [noflag_nlen,     NOFLAG.name.__len__,     [], 6]

# ---------------------------------------------------------------------------
# re.RegexFlag enum member name string equality and class membership
# Each member name equals its own string name, and __class__.__name__ == 'RegexFlag'.
# RegexFlag.__bases__[0].__name__ == 'IntFlag'.
# ---------------------------------------------------------------------------

table re_extra134.RegexFlag_name_eq_and_class:
  description: "re.RegexFlag enum member .name string equality and __class__.__name__ == 'RegexFlag'; RegexFlag.__bases__[0].__name__ == 'IntFlag'"
  kind: python_call_eq
  category: enum_values
  id_prefix: reregexflag134

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_name,   IGNORECASE.name.__eq__,                    ["IGNORECASE"],  true]
    - [multiline_name,    MULTILINE.name.__eq__,                     ["MULTILINE"],   true]
    - [dotall_name,       DOTALL.name.__eq__,                        ["DOTALL"],      true]
    - [verbose_name,      VERBOSE.name.__eq__,                       ["VERBOSE"],     true]
    - [noflag_name,       NOFLAG.name.__eq__,                        ["NOFLAG"],      true]
    - [ign_cls_name,      IGNORECASE.__class__.__name__.__eq__,      ["RegexFlag"],   true]
    - [rflag_base_name,   "RegexFlag.__bases__[0].__name__.__eq__",  ["IntFlag"],     true]
    - [rflag_base_not_en, "RegexFlag.__bases__[0].__name__.__eq__",  ["Enum"],        false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra134.IGNORECASE.value_is_2:
  description: "re.IGNORECASE.value == 2 (IGNORECASE is bit 1 in the RegexFlag bitmask; using re.I or re.IGNORECASE enables case-insensitive matching)"
  category: enum_values
  kind: python_call_eq
  function: IGNORECASE.value.__eq__
  args: [2]
  expected: true

invariant re_extra134.MULTILINE.value_is_8:
  description: "re.MULTILINE.value == 8 (MULTILINE is bit 3 in the RegexFlag bitmask; makes ^ and $ match at line boundaries, not just string boundaries)"
  category: enum_values
  kind: python_call_eq
  function: MULTILINE.value.__eq__
  args: [8]
  expected: true

invariant re_extra134.NOFLAG.value_is_0:
  description: "re.NOFLAG.value == 0 (NOFLAG is the identity element for bitwise OR of RegexFlag values; using re.NOFLAG means no flags are set)"
  category: enum_values
  kind: python_call_eq
  function: NOFLAG.value.__eq__
  args: [0]
  expected: true

invariant re_extra134.ASCII.value_is_256:
  description: "re.ASCII.value == 256 (ASCII is bit 8 in the RegexFlag bitmask; restricts \\w, \\d, \\s, etc. to ASCII character class equivalents)"
  category: enum_values
  kind: python_call_eq
  function: ASCII.value.__eq__
  args: [256]
  expected: true

invariant re_extra134.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag, so its members are both enum members and integers)"
  category: enum_values
  kind: python_call_eq
  function: RegexFlag.__bases__[0].__name__.__eq__
  args: ["IntFlag"]
  expected: true
