spec: constant_case
version: ">=3.0.0"
backend: node(constant-case)

docs: https://www.npmjs.com/package/constant-case

provenance:
  derived_from:
    - "constant-case README — https://www.npmjs.com/package/constant-case"
    - "Test vectors verified with constant-case@3.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "constant-case source"
  notes:
    - "constant-case exports {constantCase} named function."
    - "constantCase converts string to CONSTANT_CASE (upper snake case)."
    - "Handles camelCase, PascalCase, kebab-case, and space-separated inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns CONSTANT_CASED string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table constant_case.constant_case:
  kind: node_module_call_eq
  function: constantCase
  category: constantCase
  id_prefix: cconst

  columns: [id, args, expected]
  rows:
    - [camel,  ["fooBar"],      "FOO_BAR"]
    - [space,  ["foo bar"],     "FOO_BAR"]
    - [dash,   ["foo-bar-baz"], "FOO_BAR_BAZ"]
    - [lower,  ["hello world"], "HELLO_WORLD"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T08:25:43Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
