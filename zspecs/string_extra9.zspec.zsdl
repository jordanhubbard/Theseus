spec: string_extra9
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra8.zspec.zsdl."
    - "string_extra: Formatter/__name__/__module__, Template/__name__/__module__, capwords/__name__, constants type-is-str table."
    - "string_extra2: Formatter/__bases__[0].__name__=='object', Template/__bases__[0].__name__=='object', capwords.__module__, ascii_letters len==52, whitespace contains newline, printable len==100, punctuation len==32, octdigits/hexdigits exact values."
    - "string_extra4: Formatter/__name__/__module__ (table), Template/__name__/__module__ (table), digits/hexdigits/octdigits values, ascii_lowercase/uppercase/letters/digits/punctuation lengths, Formatter().format method name."
    - "string_extra5: Template/__qualname__, Formatter/__qualname__, capwords/__qualname__, ascii_uppercase/lowercase exact values, digits/ascii_uppercase membership checks, capwords double-internal-space and uppercase single word."
    - "string_extra6: whitespace len/membership (CR/tab/not-a); punctuation membership (!/@/not-a); ascii_letters membership (z/Z/not-0); capwords with sep ('hello-world'/multi); digits membership (not-a/9)."
    - "string_extra7: printable membership (5/a/Z/!/space/null); ascii_letters exact value; hexdigits membership (A/f/G); whitespace vtab/ff membership; Formatter instance class name; Formatter/Template base class name; capwords already-title-case/empty-string; digits first/last char."
    - "string_extra8: __len__ standalone invariants for all constants; Formatter/__name__ and Template/__name__ via __eq__ chain; Formatter/__module__ and Template/__module__ via __eq__ chain."
    - "This spec (extra9) adds: extra9-namespace anchors for Template.__name__, Formatter.__name__, capwords.__name__, ascii_letters type check; fresh behavioral vectors for capwords, Template.substitute, Formatter.format, and ascii_letters indexing."
    - "string.Template.__name__ == 'Template' — extra9-namespace anchor; covered in extra, extra2, extra4, extra8 namespaces."
    - "string.Formatter.__name__ == 'Formatter' — extra9-namespace anchor; covered in extra, extra2, extra4, extra8 namespaces."
    - "string.capwords.__name__ == 'capwords' — extra9-namespace anchor; covered in extra namespace."
    - "string.ascii_letters.__class__.__name__ == 'str' — extra9-namespace anchor for type check; type-is-str covered in extra namespace."
    - "string.capwords('hello world') == 'Hello World' — two-word input; not covered as a standalone invariant before."
    - "string.ascii_letters[0] == 'a' — first character is lowercase a; no prior spec checks direct indexing."
    - "string.ascii_letters[-1] == 'Z' — last character is uppercase Z; no prior spec checks this index."
    - "string.ascii_letters.endswith('Z') — no prior spec checks endswith on ascii_letters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class and function __name__ — extra9-namespace grouped table
#
# string_extra, string_extra2, string_extra4, and string_extra8 cover these
# in their respective namespaces. This table provides extra9-namespace anchors
# for the four assigned axes: Template.__name__, Formatter.__name__,
# capwords.__name__, and the ascii_letters type identity.
# ---------------------------------------------------------------------------

table string_extra9.name_attrs:
  kind: python_call_eq
  category: class_identity
  id_prefix: sname

  columns: [id, function, args, expected]
  rows:
    - [Template,      Template.__name__.__eq__,      ["Template"],  true]
    - [Formatter,     Formatter.__name__.__eq__,     ["Formatter"], true]
    - [capwords,      capwords.__name__.__eq__,      ["capwords"],  true]
    - [ascii_letters, ascii_letters.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# capwords — two-word behavioral vector
#
# string_extra5 covers capwords with double internal spaces and a single
# already-uppercased word. No prior spec checks capwords('hello world') as
# a standalone invariant. Each word is title-cased: 'Hello World'.
# ---------------------------------------------------------------------------

invariant string_extra9.capwords.two_words:
  description: "string.capwords('hello world') == 'Hello World' — each word title-cased"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["hello world"]
  expected: "Hello World"

# ---------------------------------------------------------------------------
# capwords — three-word behavioral vector
#
# No prior spec covers capwords('foo bar baz') as a standalone invariant.
# All three words are title-cased: 'Foo Bar Baz'.
# ---------------------------------------------------------------------------

invariant string_extra9.capwords.three_words:
  description: "string.capwords('foo bar baz') == 'Foo Bar Baz' — three words all title-cased"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["foo bar baz"]
  expected: "Foo Bar Baz"

# ---------------------------------------------------------------------------
# ascii_letters — indexing: first and last character
#
# Prior specs cover ascii_letters exact value (extra7), length (extra2/extra4/extra8),
# and membership (extra6/extra7). No prior spec checks direct index access.
# ascii_letters is the concatenation of ascii_lowercase + ascii_uppercase,
# so [0] == 'a' and [-1] == 'Z'.
# ---------------------------------------------------------------------------

invariant string_extra9.ascii_letters.first_char:
  description: "string.ascii_letters[0] == 'a' — first character is lowercase a"
  category: constants
  kind: python_call_eq
  function: ascii_letters.__getitem__
  args: [0]
  expected: "a"

invariant string_extra9.ascii_letters.last_char:
  description: "string.ascii_letters[-1] == 'Z' — last character is uppercase Z"
  category: constants
  kind: python_call_eq
  function: ascii_letters.__getitem__
  args: [-1]
  expected: "Z"

# ---------------------------------------------------------------------------
# ascii_letters — endswith check
#
# No prior spec checks ascii_letters.endswith('Z').
# Since ascii_letters == ascii_lowercase + ascii_uppercase, the last char is 'Z'.
# ---------------------------------------------------------------------------

invariant string_extra9.ascii_letters.endswith_Z:
  description: "string.ascii_letters.endswith('Z') == True — string ends with uppercase Z"
  category: constants
  kind: python_call_eq
  function: ascii_letters.endswith
  args: ["Z"]
  expected: true
