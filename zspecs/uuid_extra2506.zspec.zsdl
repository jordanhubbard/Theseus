spec: uuid_extra2506
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
    - "CPython source: Lib/uuid.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2506): __add__, __sub__, __mul__ dict-presence checks."
    - "uuid.UUID is not an arithmetic type; it defines none of these additive, subtractive, or multiplicative protocols in its own __dict__."
    - "uuid.SafeUUID is an IntEnum subclass; it inherits arithmetic methods from int but defines none of them in its own __dict__."
    - "All __add__/__sub__/__mul__ dunder methods (including r/i variants) are absent from both uuid.UUID.__dict__ and uuid.SafeUUID.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table uuid_extra2506.uuid_add_protocol:
  description: "uuid.UUID __add__/__radd__/__iadd__ dict-presence checks (UUID is not arithmetic)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2506

  columns: [id, function, args, expected]
  rows:
    - ["uu2506001", "uuid.UUID.__dict__.__contains__", ["__add__"], false]
    - ["uu2506002", "uuid.UUID.__dict__.__contains__", ["__radd__"], false]
    - ["uu2506003", "uuid.UUID.__dict__.__contains__", ["__iadd__"], false]

