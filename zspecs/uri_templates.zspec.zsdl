spec: uri_templates
version: ">=0.2.0"
backend: node(uri-templates)

docs: https://github.com/geraintluff/uri-templates#readme

provenance:
  derived_from:
    - "uri-templates README — https://github.com/geraintluff/uri-templates#readme"
    - "RFC 6570 — URI Template"
    - "Test vectors verified with uri-templates via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "uri-templates source"
  notes:
    - "RFC 6570 URI Template implementation, alternative to url-template — module export IS the parser, plus inverse fromUri()."
    - "Install: npm install uri-templates"
    - "Pattern: const ut = require('uri-templates'); const t = ut(spec); t.fill(vars); t.fromUri(uri)"
  rfcs:
    - "RFC 6570 — URI Template — https://www.rfc-editor.org/rfc/rfc6570"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on valid template strings."
  stderr: "null"
  stickiness: "N/A — Template instances are stateless."
  codes: {}

# fill() — forward expansion
table uri_templates.fill:
  kind: node_chain_eq
  category: fill
  entry: module
  id_prefix: fill

  columns: [id, entry_args, chain, expected]
  rows:
    - [simple_substitution,
       ["/users/{id}"],
       [{method: fill, args: [{id: 42}]}],
       "/users/42"]

    - [reserved_path_expansion,
       ["{+path}/here"],
       [{method: fill, args: [{path: "/a/b"}]}],
       "/a/b/here"]

    - [fragment_expansion,
       ["X{#frag}"],
       [{method: fill, args: [{frag: "fragval"}]}],
       "X#fragval"]

    - [missing_var_expanded_empty,
       ["{?missing}"],
       [{method: fill, args: [{}]}],
       ""]

    - [empty_template,
       [""],
       [{method: fill, args: [{}]}],
       ""]

# fromUri() — reverse parsing
table uri_templates.fromUri:
  kind: node_chain_eq
  category: fromUri
  entry: module
  id_prefix: fromUri

  columns: [id, entry_args, chain, expected]
  rows:
    - [extract_id,
       ["/users/{id}"],
       [{method: fromUri, args: ["/users/42"]}],
       {id: "42"}]

    - [extract_two_vars,
       ["/{type}/{id}"],
       [{method: fromUri, args: ["/users/42"]}],
       {type: "users", id: "42"}]

    - [no_match_returns_undefined,
       ["/users/{id}"],
       [{method: fromUri, args: ["/totally-different"]}],
       ~]
