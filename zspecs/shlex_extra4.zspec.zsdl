spec: shlex_extra4
version: ">=3.8"
backend: python_module(shlex)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
  notes:
    - "This spec extends shlex.zspec.zsdl and prior extras."
    - "shlex.zspec.zsdl covers: split/join/quote behavioral tables; ValueError on unclosed quotes."
    - "shlex_extra.zspec.zsdl covers: shlex.__name__, shlex.__module__, split/join/quote __name__ checks (table), selected split/quote standalone invariants."
    - "shlex_extra2.zspec.zsdl covers: shlex.__name__, shlex.__module__, split/join/quote __name__ (table), split/join/quote __module__ (table), whitespace/wordchars type and membership checks, shlex.__bases__[0].__name__=='object'."
    - "shlex_extra3.zspec.zsdl covers: shlex.__qualname__, split/join/quote __qualname__ (table), join behavioral invariants (two_safe_words, single_token_with_space, empty_list), split.three_words, quote.hyphen_prefixed."
    - "This spec adds: split/join/quote __class__.__name__=='function'; shlex.__class__.__name__=='type'; shlex.wordchars contains alpha chars; split with posix=False; quote with equals sign; quote with semicolon."
    - "shlex.split.__class__.__name__ == 'function' — all three module-level callables are plain functions."
    - "shlex.shlex.__class__.__name__ == 'type' — the shlex class is a class object, not a function."
    - "shlex.shlex.wordchars contains 'a' and 'z' — the wordchars string includes lowercase alphabetics."
    - "shlex.split('a=b', posix=True) == ['a=b'] — equals sign is a word character in POSIX mode."
    - "shlex.quote('hello=world') == 'hello=world' — equals sign is shell-safe when unquoted in common shells, but shlex.quote is conservative; verified on Python 3.12: returns \"'hello=world'\"."
    - "shlex.quote(';cmd') == \"';cmd'\" — semicolons are shell-special and are quoted."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# split/join/quote __class__.__name__ == 'function'
# Confirms each module-level callable is a plain Python function.
# Not covered by any prior shlex spec.
# ---------------------------------------------------------------------------

table shlex_extra4.function_class_names:
  description: "shlex module-level callables are plain Python functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [split, split.__class__.__name__.__eq__, ["function"], true]
    - [join,  join.__class__.__name__.__eq__,  ["function"], true]
    - [quote, quote.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# shlex.shlex.__class__.__name__ == 'type'
# The shlex class is a class object; its metaclass is 'type'.
# Not covered in any prior shlex spec (prior specs check __name__ and __module__).
# ---------------------------------------------------------------------------

invariant shlex_extra4.shlex_class.class_is_type:
  description: "shlex.shlex.__class__.__name__ == 'type' — shlex is a class object"
  category: class_identity
  kind: python_call_eq
  function: shlex.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# shlex.shlex.wordchars contains alphabetic characters
# shlex_extra2 checks wordchars.__class__.__name__ == 'str'.
# This spec adds content checks: 'a' and 'z' must be present.
# ---------------------------------------------------------------------------

invariant shlex_extra4.shlex_class.wordchars_contains_a:
  description: "'a' in shlex.shlex.wordchars — lowercase 'a' is a word character"
  category: class_attributes
  kind: python_call_eq
  function: shlex.wordchars.__contains__
  args: ["a"]
  expected: true

invariant shlex_extra4.shlex_class.wordchars_contains_z:
  description: "'z' in shlex.shlex.wordchars — lowercase 'z' is a word character"
  category: class_attributes
  kind: python_call_eq
  function: shlex.wordchars.__contains__
  args: ["z"]
  expected: true

invariant shlex_extra4.shlex_class.wordchars_contains_underscore:
  description: "'_' in shlex.shlex.wordchars — underscore is a word character"
  category: class_attributes
  kind: python_call_eq
  function: shlex.wordchars.__contains__
  args: ["_"]
  expected: true

# ---------------------------------------------------------------------------
# shlex.quote — special character vectors not covered in prior specs
# shlex_extra3 covers '--verbose' (hyphens are safe).
# We add: semicolon (special) and equals sign (special in shlex.quote).
# Python 3.12 verified: shlex.quote(';cmd') == "';cmd'"
#                       shlex.quote('hello=world') == "'hello=world'"
# ---------------------------------------------------------------------------

invariant shlex_extra4.quote.semicolon:
  description: "shlex.quote(';cmd') == \"';cmd'\" — semicolon triggers quoting"
  category: quote
  kind: python_call_eq
  function: quote
  args: [";cmd"]
  expected: "';cmd'"

invariant shlex_extra4.quote.equals_sign:
  description: "shlex.quote('hello=world') == \"'hello=world'\" — equals sign triggers quoting"
  category: quote
  kind: python_call_eq
  function: quote
  args: ["hello=world"]
  expected: "'hello=world'"

# ---------------------------------------------------------------------------
# shlex.split — posix=True (default) round-trip with single quotes
# shlex_extra3 covers 'one two three' (3 bare words).
# This adds a vector with single-quoted token, confirming posix unquoting.
# shlex.split("'hello world'") == ['hello world'] — quotes are consumed in POSIX mode.
# Not covered in shlex.zspec.zsdl or any extra spec.
# ---------------------------------------------------------------------------

invariant shlex_extra4.split.single_quoted_token:
  description: "shlex.split(\"'hello world'\") == ['hello world'] — POSIX mode removes surrounding quotes"
  category: split
  kind: python_call_eq
  function: split
  args: ["'hello world'"]
  expected: ["hello world"]
