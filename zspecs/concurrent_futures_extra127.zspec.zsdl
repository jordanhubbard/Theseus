spec: concurrent_futures_extra127
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: wave 255 theme — concurrent.futures.__all__ list identity and membership. NEW in extra127: concurrent.futures.__all__.__class__.__name__=='list' (a list, unlike asyncio.__all__ which is a tuple); concurrent.futures.__all__.__len__()==14; concurrent.futures.__all__.__contains__('Future')==True; concurrent.futures.__all__.__contains__('Executor')==True; concurrent.futures.__all__.__contains__('ThreadPoolExecutor')==True; concurrent.futures.__all__.__contains__('ProcessPoolExecutor')==True; concurrent.futures.__all__.__contains__('wait')==True; concurrent.futures.__all__.__contains__('as_completed')==True; concurrent.futures.__all__.__contains__('FIRST_COMPLETED')==True; concurrent.futures.__all__.__contains__('ALL_COMPLETED')==True; concurrent.futures.__all__.__contains__('CancelledError')==True; concurrent.futures.__all__.__contains__('BrokenExecutor')==True; concurrent.futures.__all__.__contains__('InterpreterPoolExecutor')==True; concurrent.futures.__all__[0]=='FIRST_COMPLETED'; concurrent.futures.__all__[-1]=='InterpreterPoolExecutor'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__all__.__class__.__name__ == 'list'. concurrent.futures uses a plain Python list for __all__ (defined in Lib/concurrent/futures/__init__.py). This contrasts with asyncio.__all__ (class='tuple'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__all__.__len__() == 14. The 14-element list covers executor classes, Future, wait utilities, constants, and exceptions. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__all__[0] == 'FIRST_COMPLETED'. The first element is the FIRST_COMPLETED constant, and the last element is 'InterpreterPoolExecutor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ list class identity — extra127
#
# Wave 255 theme: concurrent.futures.__all__ is a list and membership tests.
#
# concurrent.futures.__all__.__class__.__name__ == 'list'
# concurrent.futures.__all__.__len__() == 14
# concurrent.futures.__all__.__contains__('Future') == True
# concurrent.futures.__all__.__contains__('Executor') == True
# concurrent.futures.__all__.__contains__('ThreadPoolExecutor') == True
# concurrent.futures.__all__.__contains__('ProcessPoolExecutor') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra127.cf_all_class_identity:
  description: "concurrent.futures.__all__ class identity and executor membership checks in cfall127 namespace — wave 255 theme: concurrent.futures.__all__ is a list (unlike asyncio.__all__ which is a tuple); concurrent.futures.__all__.__class__.__name__.__eq__('list')==True (defined as a plain Python list in Lib/concurrent/futures/__init__.py); concurrent.futures.__all__.__len__()==14 (covers 14 public names: constants, exceptions, Future, Executor subclasses, and wait helpers); concurrent.futures.__all__.__contains__('Future')==True (the core result-holder class); concurrent.futures.__all__.__contains__('Executor')==True (the abstract base for thread/process pools); concurrent.futures.__all__.__contains__('ThreadPoolExecutor')==True (thread-based executor); concurrent.futures.__all__.__contains__('ProcessPoolExecutor')==True (process-based executor); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfall127

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls,      "concurrent.futures.__all__.__class__.__name__.__eq__", ["list"],                 true, "concurrent.futures.__all__.__class__.__name__ == 'list' — a list unlike asyncio's tuple; verified with Python 3.14.3"]
    - [all_len,      "concurrent.futures.__all__.__len__",                   [],                       14,   "concurrent.futures.__all__.__len__() == 14; verified with Python 3.14.3"]
    - [has_future,   "concurrent.futures.__all__.__contains__",              ["Future"],               true, "concurrent.futures.__all__.__contains__('Future') == True; verified with Python 3.14.3"]
    - [has_executor, "concurrent.futures.__all__.__contains__",              ["Executor"],             true, "concurrent.futures.__all__.__contains__('Executor') == True — abstract base executor; verified with Python 3.14.3"]
    - [has_tpe,      "concurrent.futures.__all__.__contains__",              ["ThreadPoolExecutor"],   true, "concurrent.futures.__all__.__contains__('ThreadPoolExecutor') == True; verified with Python 3.14.3"]
    - [has_ppe,      "concurrent.futures.__all__.__contains__",              ["ProcessPoolExecutor"],  true, "concurrent.futures.__all__.__contains__('ProcessPoolExecutor') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ wait/completion helper membership — extra127
#
# concurrent.futures.__all__.__contains__('wait') == True
# concurrent.futures.__all__.__contains__('as_completed') == True
# concurrent.futures.__all__.__contains__('FIRST_COMPLETED') == True
# concurrent.futures.__all__.__contains__('ALL_COMPLETED') == True
# concurrent.futures.__all__.__contains__('CancelledError') == True
# concurrent.futures.__all__.__contains__('BrokenExecutor') == True
# concurrent.futures.__all__.__contains__('InterpreterPoolExecutor') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra127.cf_all_helper_membership:
  description: "concurrent.futures.__all__ wait utility and constant membership checks in cfall127 namespace — wave 255 theme: wait helpers, constants, and exceptions in concurrent.futures.__all__; concurrent.futures.__all__.__contains__('wait')==True (wait() blocks until futures are done); concurrent.futures.__all__.__contains__('as_completed')==True (yields futures in completion order); concurrent.futures.__all__.__contains__('FIRST_COMPLETED')==True (constant for wait(return_when=)); concurrent.futures.__all__.__contains__('ALL_COMPLETED')==True (wait constant: wait for all); concurrent.futures.__all__.__contains__('CancelledError')==True (exception re-exported from concurrent.futures); concurrent.futures.__all__.__contains__('BrokenExecutor')==True (raised when executor is broken); concurrent.futures.__all__.__contains__('InterpreterPoolExecutor')==True (per-interpreter GIL executor added in Python 3.13+); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfall127a

  columns: [id, function, args, expected, description]
  rows:
    - [has_wait,     "concurrent.futures.__all__.__contains__", ["wait"],                    true, "concurrent.futures.__all__.__contains__('wait') == True; verified with Python 3.14.3"]
    - [has_ascmpl,   "concurrent.futures.__all__.__contains__", ["as_completed"],            true, "concurrent.futures.__all__.__contains__('as_completed') == True; verified with Python 3.14.3"]
    - [has_fc,       "concurrent.futures.__all__.__contains__", ["FIRST_COMPLETED"],         true, "concurrent.futures.__all__.__contains__('FIRST_COMPLETED') == True — wait() constant; verified with Python 3.14.3"]
    - [has_ac,       "concurrent.futures.__all__.__contains__", ["ALL_COMPLETED"],           true, "concurrent.futures.__all__.__contains__('ALL_COMPLETED') == True — wait() constant; verified with Python 3.14.3"]
    - [has_cerr,     "concurrent.futures.__all__.__contains__", ["CancelledError"],          true, "concurrent.futures.__all__.__contains__('CancelledError') == True — exception re-exported; verified with Python 3.14.3"]
    - [has_bexec,    "concurrent.futures.__all__.__contains__", ["BrokenExecutor"],          true, "concurrent.futures.__all__.__contains__('BrokenExecutor') == True; verified with Python 3.14.3"]
    - [has_ipe,      "concurrent.futures.__all__.__contains__", ["InterpreterPoolExecutor"], true, "concurrent.futures.__all__.__contains__('InterpreterPoolExecutor') == True — added Python 3.13+; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ index access — extra127
#
# concurrent.futures.__all__[0] == 'FIRST_COMPLETED'
# concurrent.futures.__all__[-1] == 'InterpreterPoolExecutor'
# concurrent.futures.__all__.__contains__('FIRST_EXCEPTION') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra127.cf_all_index_access:
  description: "concurrent.futures.__all__ index access and remaining membership checks in cfall127 namespace — wave 255 theme: first and last elements of the __all__ list; since concurrent.futures.__all__ is a list (not a tuple), it supports index access; concurrent.futures.__all__.__getitem__(0).__eq__('FIRST_COMPLETED')==True (first element is the FIRST_COMPLETED constant); concurrent.futures.__all__.__getitem__(-1).__eq__('InterpreterPoolExecutor')==True (last element is InterpreterPoolExecutor, the newest addition); concurrent.futures.__all__.__contains__('FIRST_EXCEPTION')==True (the third wait constant: FIRST_EXCEPTION triggers when any future raises); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfall127b

  columns: [id, function, args, expected, description]
  rows:
    - [first_elem,  "concurrent.futures.__all__.__getitem__", [0],                 "FIRST_COMPLETED",         "concurrent.futures.__all__[0] == 'FIRST_COMPLETED' (first element); verified with Python 3.14.3"]
    - [last_elem,   "concurrent.futures.__all__.__getitem__", [-1],                "InterpreterPoolExecutor", "concurrent.futures.__all__[-1] == 'InterpreterPoolExecutor' (last element); verified with Python 3.14.3"]
    - [has_fexc,    "concurrent.futures.__all__.__contains__", ["FIRST_EXCEPTION"], true,                     "concurrent.futures.__all__.__contains__('FIRST_EXCEPTION') == True — third wait constant; verified with Python 3.14.3"]
    - [all_cls2,    "concurrent.futures.__all__.__class__.__name__.__eq__", ["list"], true,                   "concurrent.futures.__all__.__class__.__name__ == 'list' — confirmed list type; verified with Python 3.14.3"]
    - [has_ise,     "concurrent.futures.__all__.__contains__", ["InvalidStateError"], true,                   "concurrent.futures.__all__.__contains__('InvalidStateError') == True — exception re-exported; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra127
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra127.cf_all_is_list:
  description: "concurrent.futures.__all__.__class__.__name__.__eq__('list') returns True — concurrent.futures.__all__ is a plain Python list defined in Lib/concurrent/futures/__init__.py; this contrasts with asyncio.__all__ (class='tuple', len=95) and mirrors multiprocessing.__all__ (class='list', len=37); using a list for __all__ means the public API namespace is defined by a mutable sequence; concurrent.futures.__all__.__len__()==14; the 14 entries cover all public executor classes, Future, wait utilities, completion constants, and exceptions; NEW in extra127: first standalone concurrent.futures.__all__ class name invariant in cfall127 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

invariant concurrent_futures_extra127.cf_all_len_is_14:
  description: "concurrent.futures.__all__.__len__() == 14 — concurrent.futures.__all__ contains 14 entries: ['FIRST_COMPLETED', 'FIRST_EXCEPTION', 'ALL_COMPLETED', 'CancelledError', 'TimeoutError', 'InvalidStateError', 'BrokenExecutor', 'Future', 'Executor', 'wait', 'as_completed', 'ProcessPoolExecutor', 'ThreadPoolExecutor', 'InterpreterPoolExecutor']; this is substantially smaller than asyncio.__all__ (len=95) and multiprocessing.__all__ (len=37), reflecting the focused scope of concurrent.futures; the 14 names cover 3 constants, 3 exceptions, 1 abstract base class, 3 executor implementations, 1 future class, and 2 wait helpers; NEW in extra127: first standalone concurrent.futures.__all__ length invariant in cfall127 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__len__"
  args: []
  expected: 14

invariant concurrent_futures_extra127.cf_all_contains_Future:
  description: "concurrent.futures.__all__.__contains__('Future') returns True — concurrent.futures.Future is the core result-holder class in concurrent.futures; it represents the eventual result of an asynchronous computation; Future is in __all__ as a public class; concurrent.futures.Future.__module__ is 'concurrent.futures._base'; Future.__mro__.__len__()==2 ([Future, object]); concurrent.futures.__all__.__class__.__name__ is 'list'; concurrent.futures.__all__.__len__()==14; also notable: concurrent.futures.__all__ contains 'Executor' (the abstract base) alongside the three concrete executor types (ThreadPoolExecutor, ProcessPoolExecutor, InterpreterPoolExecutor); NEW in extra127: first standalone Future membership invariant in cfall127 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__contains__"
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra127.cf_all_contains_ThreadPoolExecutor:
  description: "concurrent.futures.__all__.__contains__('ThreadPoolExecutor') returns True — ThreadPoolExecutor is in concurrent.futures.__all__; it is a concrete Executor subclass that manages a pool of threads; concurrent.futures.__all__ contains all three concrete executor types: ThreadPoolExecutor (thread-based), ProcessPoolExecutor (process-based), and InterpreterPoolExecutor (per-interpreter GIL, Python 3.13+); concurrent.futures.__all__.__len__()==14; concurrent.futures.__all__.__class__.__name__ is 'list'; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread'; compare: asyncio.__all__.__contains__('ThreadPoolExecutor') would return False since ThreadPoolExecutor is not part of asyncio's public API; NEW in extra127: first standalone ThreadPoolExecutor membership invariant in cfall127 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__contains__"
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra127.cf_all_first_is_FIRST_COMPLETED:
  description: "concurrent.futures.__all__.__getitem__(0).__eq__('FIRST_COMPLETED') returns True — the first element of concurrent.futures.__all__ is 'FIRST_COMPLETED'; since __all__ is a list (not a tuple), index access is well-defined; FIRST_COMPLETED is one of three wait() return_when constants in concurrent.futures (alongside FIRST_EXCEPTION and ALL_COMPLETED); FIRST_COMPLETED causes wait() to return when the first future completes or is cancelled; concurrent.futures.__all__[-1] is 'InterpreterPoolExecutor' (the last element); concurrent.futures.__all__.__len__()==14; NEW in extra127: first standalone __all__[0] element invariant in cfall127 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__getitem__"
  args: [0]
  expected: "FIRST_COMPLETED"

