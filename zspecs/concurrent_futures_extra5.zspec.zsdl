spec: concurrent_futures_extra5
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec extends prior concurrent_futures specs."
    - "Focus: class names and function names not yet covered."
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'."
    - "concurrent.futures.Future.__name__ == 'Future'."
    - "concurrent.futures.Executor.__name__ == 'Executor'."
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError'."
    - "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'."
    - "concurrent.futures.wait.__name__ == 'wait'."
    - "concurrent.futures.as_completed.__name__ == 'as_completed'."
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'."
    - "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'."
    - "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor, ThreadPoolExecutor.__name__.__eq__, ["ThreadPoolExecutor"], true]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true]
    - [Future,             Future.__name__.__eq__,             ["Future"],             true]
    - [Executor,           Executor.__name__.__eq__,           ["Executor"],           true]
    - [CancelledError,     CancelledError.__name__.__eq__,     ["CancelledError"],     true]
    - [TimeoutError,       TimeoutError.__name__.__eq__,       ["TimeoutError"],       true]
    - [BrokenExecutor,     BrokenExecutor.__name__.__eq__,     ["BrokenExecutor"],     true]

table concurrent_futures_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [wait,         wait.__name__.__eq__,         ["wait"],         true]
    - [as_completed, as_completed.__name__.__eq__, ["as_completed"], true]

table concurrent_futures_extra5.wait_constants:
  kind: python_call_eq
  category: constants
  id_prefix: wait_c

  columns: [id, function, args, expected]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__eq__, ["FIRST_COMPLETED"], true]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__eq__, ["FIRST_EXCEPTION"], true]
    - [ALL_COMPLETED,   ALL_COMPLETED.__eq__,   ["ALL_COMPLETED"],   true]

invariant concurrent_futures_extra5.ThreadPoolExecutor.module:
  description: "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: module
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra5.Future.module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"
  category: module
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra5.BrokenExecutor.base:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: exceptions
  kind: python_call_eq
  function: BrokenExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RuntimeError"

invariant concurrent_futures_extra5.Executor.module:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'"
  category: module
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
