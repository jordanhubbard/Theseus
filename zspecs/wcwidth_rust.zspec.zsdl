spec: wcwidth_rust
version: ">=3.9"
backend: rust_module(wcwidth_rust)

docs: https://wcwidth.readthedocs.io/

provenance:
  derived_from:
    - "https://wcwidth.readthedocs.io/ — wcwidth library documentation"
    - "Unicode Standard Annex #11: East Asian Width"
  not_derived_from:
    - "wcwidth source: wcwidth/wcwidth.py"
  notes:
    - "wcwidth measures the number of terminal columns needed to display a character."
    - "wcwidth.wcwidth(c) -> int: width of single character (0, 1, or 2; -1 for non-printable)."
    - "wcwidth.wcswidth(s) -> int: total width of string (-1 if any non-printable)."
    - "wcwidth('A') == 1 — ASCII characters take 1 column."
    - "wcwidth('中') == 2 — CJK characters take 2 columns."
    - "wcwidth(' ') == 1 — space takes 1 column."
    - "wcswidth('hello') == 5 — 5 ASCII chars."
    - "wcswidth('中文') == 4 — 2 CJK chars × 2 columns each."
    - "wcswidth('Aあ') == 3 — 1 + 2."
    - "All test vectors verified against wcwidth 0.2.13."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# wcwidth — single character width
table wcwidth_rust.wcwidth.vectors:
  kind: python_call_eq
  category: wcwidth
  id_prefix: wcw_ch
  function: wcwidth

  columns: [id, args, expected]
  rows:
    - [ascii_A, ["A"],  1]
    - [ascii_z, ["z"],  1]
    - [space,   [" "],  1]
    - [cjk,     ["中"], 2]
    - [hiragana,["あ"], 2]

# wcswidth — string total width
table wcwidth_rust.wcswidth.vectors:
  kind: python_call_eq
  category: wcswidth
  id_prefix: wcw_str
  function: wcswidth

  columns: [id, args, expected]
  rows:
    - [hello,    ["hello"],  5]
    - [cjk_two,  ["中文"],   4]
    - [mixed,    ["Aあ"],    3]
    - [empty,    [""],       0]
    - [ascii_3,  ["abc"],    3]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:09:42Z
