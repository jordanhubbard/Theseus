spec: dis_extra21
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra20.zspec.zsdl — covers __qualname__.__len__() for dis/disassemble/findlinestarts/findlabels/stack_effect/pretty_flags/print_instructions"
    - "dis_extra19.zspec.zsdl — covers stack_effect/__qualname__.__eq__, pretty_flags/__qualname__.__eq__, print_instructions/__qualname__.__eq__; Positions/ArgResolver/Formatter __qualname__ and __bases__"
    - "dis_extra17.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __name__ and __module__; Instruction/__name__; opname/opmap class (via __class__.__name__)"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__qualname__ and Instruction/__qualname__ in a class_qualnames table"
    - "dis_extra15.zspec.zsdl — covers opmap/__class__/__name__=='dict' and opname item0 type"
  notes:
    - "This spec extends dis_extra20.zspec.zsdl."
    - "Focus: standalone __qualname__.__eq__ invariants for dis/disassemble/get_instructions/findlinestarts/findlabels (these have __len__() in dis_extra20 but __eq__ forms only in table in dis_extra17/__name__, not __qualname__); Instruction/__qualname__.__eq__; opname and opmap __class__.__name__ standalone."
    - "dis.dis.__qualname__ == 'dis' — dis_extra20 covers __len__() == 3; no prior dis spec covers dis.__qualname__.__eq__ as a standalone invariant."
    - "dis.disassemble.__qualname__ == 'disassemble' — dis_extra20 covers __len__(); no prior dis spec covers standalone __qualname__.__eq__."
    - "dis.get_instructions.__qualname__ == 'get_instructions' — dis_extra19 covers __len__(); no prior dis spec covers standalone __qualname__.__eq__."
    - "dis.findlinestarts.__qualname__ == 'findlinestarts' — dis_extra20 covers __len__(); no prior standalone __qualname__.__eq__."
    - "dis.findlabels.__qualname__ == 'findlabels' — dis_extra20 covers __len__(); no prior standalone __qualname__.__eq__."
    - "dis.Instruction.__qualname__ == 'Instruction' — dis_extra16 covers Instruction/__qualname__ in a table; distinct standalone invariant in dis_extra21 namespace."
    - "dis.opname.__class__.__name__ == 'list' — dis_extra17 covers opname class via __class__.__name__ in a table; distinct standalone invariant in dis_extra21 namespace."
    - "dis.opmap.__class__.__name__ == 'dict' — dis_extra15 covers opmap class; distinct standalone invariant in dis_extra21 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Core function __qualname__.__eq__ — dis, disassemble, get_instructions,
# findlinestarts, findlabels
# (dis_extra21 namespace)
#
# dis_extra20 covers __qualname__.__len__() for dis/disassemble/findlinestarts/
# findlabels. dis_extra19 covers get_instructions.__qualname__.__len__().
# The __qualname__.__eq__ form for these five functions as standalone invariants
# in the dis_extra21 namespace is new.
# ---------------------------------------------------------------------------

table dis_extra21.core_function_qualnames:
  description: "__qualname__ for core dis module functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: corefqualname

  columns: [id, function, args, expected]
  rows:
    - [dis,             dis.__qualname__.__eq__,             ["dis"],             true]
    - [disassemble,     disassemble.__qualname__.__eq__,     ["disassemble"],     true]
    - [get_instructions, get_instructions.__qualname__.__eq__, ["get_instructions"], true]
    - [findlinestarts,  findlinestarts.__qualname__.__eq__,  ["findlinestarts"],  true]
    - [findlabels,      findlabels.__qualname__.__eq__,      ["findlabels"],      true]

# ---------------------------------------------------------------------------
# Instruction __qualname__ — standalone invariant
# (dis_extra21 namespace)
#
# dis_extra16 covers Instruction/__qualname__ in a table (class_qualnames).
# This standalone invariant in the dis_extra21 namespace is distinct.
# ---------------------------------------------------------------------------

invariant dis_extra21.Instruction.qualname:
  description: "dis.Instruction.__qualname__ == 'Instruction'"
  category: class_qualnames
  kind: python_call_eq
  function: Instruction.__qualname__.__eq__
  args: ["Instruction"]
  expected: true

# ---------------------------------------------------------------------------
# opname and opmap __class__.__name__ — standalone invariants
# (dis_extra21 namespace)
#
# dis_extra17 covers opname/__class__/__name__ in a table; dis_extra15 covers
# opmap class. These are distinct standalone invariants in the dis_extra21 namespace.
# opname is a list of opcode name strings; opmap maps name strings to opcode ints.
# ---------------------------------------------------------------------------

invariant dis_extra21.opname.class_is_list:
  description: "dis.opname.__class__.__name__ == 'list' — opname is a list of opcode name strings"
  category: class_names
  kind: python_call_eq
  function: opname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra21.opmap.class_is_dict:
  description: "dis.opmap.__class__.__name__ == 'dict' — opmap maps opcode names to integer codes"
  category: class_names
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
