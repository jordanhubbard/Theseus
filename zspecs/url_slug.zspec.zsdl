spec: url_slug
version: ">=5.0.0"
backend: node(url-slug)

docs: https://www.npmjs.com/package/url-slug

provenance:
  derived_from:
    - "url-slug README — https://www.npmjs.com/package/url-slug"
    - "Test vectors verified with url-slug via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "url-slug source"
  notes:
    - "url-slug is an npm package. Install: npm install url-slug"
    - "Converts a string to a URL-safe slug. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table url_slug.urlSlug:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: urlslug

  columns: [id, args, expected]
  rows:
    - [spaces,     ["Hello World"],     "hello-world"]
    - [multi,      ["foo bar baz"],     "foo-bar-baz"]
    - [no_change,  ["hello"],           "hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:13:58Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
