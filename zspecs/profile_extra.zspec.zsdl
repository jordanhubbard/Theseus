spec: profile_extra
version: ">=3.3"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "profile source: sys.setprofile internals"
  notes:
    - "This spec extends profile.zspec.zsdl with additional identity invariants."
    - "Profile.__name__ == 'Profile' and Profile.__module__ == 'profile'."
    - "run and runctx are module-level convenience functions in the profile namespace."
    - "profile.run(statement) profiles statement in __main__.__dict__."
    - "profile.runctx(statement, globals, locals) profiles statement with explicit namespaces."
    - "All expected values verified by running Python 3.12 profile module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name and module identity
# ---------------------------------------------------------------------------

invariant profile_extra.classes.Profile_name:
  description: "profile.Profile.__name__ == 'Profile'"
  category: classes
  kind: python_call_eq
  function: Profile.__name__.__eq__
  args: ["Profile"]
  expected: true

invariant profile_extra.classes.Profile_module:
  description: "profile.Profile.__module__ == 'profile'"
  category: classes
  kind: python_call_eq
  function: Profile.__module__.__eq__
  args: ["profile"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function name identity
# ---------------------------------------------------------------------------

invariant profile_extra.functions.run_name:
  description: "profile.run.__name__ == 'run'"
  category: functions
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant profile_extra.functions.runctx_name:
  description: "profile.runctx.__name__ == 'runctx'"
  category: functions
  kind: python_call_eq
  function: runctx.__name__.__eq__
  args: ["runctx"]
  expected: true
