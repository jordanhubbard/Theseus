spec: pathlib_extra153
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.__all__ module-level public API list — its class (__name__=='list'), length (7), and membership tests for all 7 names. Also covers pathlib.__spec__.name, pathlib.__doc__ class and length."
    - "pathlib.__all__ is a list of 7 strings: ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']."
    - "All 7 names are present: UnsupportedOperation (len=20, the longest), Path (len=4, the shortest), PurePath (len=8), PurePosixPath (len=13), PureWindowsPath (len=15), PosixPath (len=9), WindowsPath (len=11)."
    - "pathlib.__spec__.name == 'pathlib' (len=7); pathlib.__doc__.__class__.__name__ == 'str'; pathlib.__doc__.__len__() == 192."
    - "pathlib.__all__.__len__() == 7 (exactly 7 public names; the entire public API of pathlib fits in a single-digit count)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__all__ list identity
# pathlib.__all__.__class__.__name__ == 'list'; pathlib.__all__.__len__() == 7.
# ---------------------------------------------------------------------------

table pathlib_extra153.all_list_identity:
  description: "pathlib.__all__ list identity: __class__.__name__=='list', __len__()==7"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibll153

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls_eq,  __all__.__class__.__name__.__eq__, ["list"], true, "pathlib.__all__.__class__.__name__ == 'list' (pathlib.__all__ is a plain Python list)"]
    - [all_len_eq,  __all__.__len__,                   [],       7,    "pathlib.__all__.__len__() == 7 (pathlib exports exactly 7 public names: 1 exception + 3 PurePath variants + 3 concrete Path variants)"]

# ---------------------------------------------------------------------------
# pathlib.__all__ membership tests — all 7 public names
# Order in __all__: UnsupportedOperation (0), PurePath (1), PurePosixPath (2),
# PureWindowsPath (3), Path (4), PosixPath (5), WindowsPath (6).
# Shortest: 'Path' (4 chars); Longest: 'UnsupportedOperation' (20 chars).
# ---------------------------------------------------------------------------

table pathlib_extra153.all_membership:
  description: "pathlib.__all__ membership: all 7 names present — UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibll153

  columns: [id, function, args, expected, description]
  rows:
    - [has_unsupop,      __all__.__contains__, ["UnsupportedOperation"], true, "pathlib.__all__ contains 'UnsupportedOperation' (len=20; first item in __all__; raised when an operation is unsupported on the current OS, e.g. Path.owner() on Windows)"]
    - [has_purepath,     __all__.__contains__, ["PurePath"],             true, "pathlib.__all__ contains 'PurePath' (len=8; abstract pure path base class with no filesystem access)"]
    - [has_pureposix,    __all__.__contains__, ["PurePosixPath"],        true, "pathlib.__all__ contains 'PurePosixPath' (len=13; pure POSIX-flavored path without filesystem access; always uses forward slashes)"]
    - [has_purewindows,  __all__.__contains__, ["PureWindowsPath"],      true, "pathlib.__all__ contains 'PureWindowsPath' (len=15; pure Windows-flavored path without filesystem access; uses backslashes and drive letters)"]
    - [has_path,         __all__.__contains__, ["Path"],                 true, "pathlib.__all__ contains 'Path' (len=4; the main concrete path class with filesystem access; instantiates PosixPath or WindowsPath based on the OS)"]
    - [has_posixpath,    __all__.__contains__, ["PosixPath"],            true, "pathlib.__all__ contains 'PosixPath' (len=9; concrete path for POSIX systems; cannot be instantiated on Windows)"]
    - [has_windowspath,  __all__.__contains__, ["WindowsPath"],          true, "pathlib.__all__ contains 'WindowsPath' (len=11; concrete path for Windows systems; cannot be instantiated on POSIX)"]

# ---------------------------------------------------------------------------
# pathlib module-level attributes: __spec__.name, __doc__, __name__
# pathlib.__spec__.name == 'pathlib' (len=7); pathlib.__doc__ is a str of length 192.
# ---------------------------------------------------------------------------

table pathlib_extra153.module_level_attrs:
  description: "pathlib module-level attributes: __spec__.name=='pathlib' (7), __doc__ is str (len=192)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibll153

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,   __spec__.name.__eq__,               ["pathlib"], true, "pathlib.__spec__.name == 'pathlib' (the module spec name matches the module name)"]
    - [spec_name_len,  __spec__.name.__len__,              [],          7,    "pathlib.__spec__.name.__len__() == 7 ('pathlib' has 7 characters)"]
    - [doc_cls_eq,     __doc__.__class__.__name__.__eq__,  ["str"],     true, "pathlib.__doc__.__class__.__name__ == 'str' (the pathlib module has a non-None docstring of type str)"]
    - [doc_len_eq,     __doc__.__len__,                    [],          192,  "pathlib.__doc__.__len__() == 192 (the pathlib module docstring is 192 characters long)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra153.all.class_is_list:
  description: "pathlib.__all__.__class__.__name__ == 'list' — pathlib.__all__ is a plain Python list; it contains exactly 7 entries covering one exception class (UnsupportedOperation), three pure path classes (PurePath, PurePosixPath, PureWindowsPath), and three concrete path classes (Path, PosixPath, WindowsPath)"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra153.all.len_7:
  description: "pathlib.__all__.__len__() == 7 — pathlib exports exactly 7 public names; this is a small, focused public API; by contrast, io.__all__ has 24 entries (io_extra153) and re.__all__ has 31 entries (re_extra149)"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

invariant pathlib_extra153.all.contains_Path:
  description: "pathlib.__all__.__contains__('Path') == True — Path is the central class of the pathlib module; it is the shortest name in __all__ at 4 characters; Path selects PosixPath or WindowsPath at instantiation time based on os.name"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra153.all.contains_PurePath:
  description: "pathlib.__all__.__contains__('PurePath') == True — PurePath is the abstract base class for all pathlib path objects; it provides path manipulation operations (joining, splitting, comparison) without touching the filesystem; Path inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra153.all.contains_UnsupportedOperation:
  description: "pathlib.__all__.__contains__('UnsupportedOperation') == True — UnsupportedOperation (len=20) is the longest name in pathlib.__all__; it is also in io.__all__ (as confirmed in io_extra153); the pathlib version is raised when path operations are unsupported on the current platform, e.g. creating a PosixPath on Windows"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["UnsupportedOperation"]
  expected: true

invariant pathlib_extra153.spec_name_eq_pathlib:
  description: "pathlib.__spec__.name == 'pathlib' (len=7) — the pathlib module spec name is 'pathlib'; __spec__.name has the same length (7) as pathlib.__all__.__len__() (also 7) — a coincidence that the module name character count matches the public API item count"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra153.doc.len_192:
  description: "pathlib.__doc__.__len__() == 192 — the pathlib module-level docstring is 192 characters long; it briefly describes the pathlib module as providing object-oriented filesystem paths"
  category: identity
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 192

invariant pathlib_extra153.all.contains_PureWindowsPath:
  description: "pathlib.__all__.__contains__('PureWindowsPath') == True — PureWindowsPath (len=15) is a pure path implementation that uses Windows path conventions (backslash separator, drive letters like 'C:'); it can be used on any OS for Windows path manipulation without filesystem access"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["PureWindowsPath"]
  expected: true
