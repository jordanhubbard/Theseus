spec: struct_extra206
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct.Struct.__dict__.__len__() == 16 — 16 entries in the Struct class dict as of Python 3.14.3."
    - "struct.Struct.__dict__ keys (sorted): __delattr__, __doc__, __getattribute__, __init__, __module__, __new__, __repr__, __setattr__, __sizeof__, format, iter_unpack, pack, pack_into, size, unpack, unpack_from."
    - "struct.Struct.__dict__.__contains__('__reduce_ex__') == False — __reduce_ex__ is NOT in Struct's own dict; it is inherited from object."
    - "struct.Struct.__dict__.__contains__('__init__') == True — Struct has its own __init__ (C-level slot)."
    - "struct.Struct.__dict__.__contains__('__getattribute__') == True — Struct overrides __getattribute__ (C-level)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. Class dict access never raises."
  stderr: "null"
  stickiness: "N/A — Struct class dict is read-only; format and size are instance attributes set at construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — method presence checks
#
# struct.Struct.__dict__ keys (16 total):
#   __delattr__, __doc__, __getattribute__, __init__, __module__,
#   __new__, __repr__, __setattr__, __sizeof__, format, iter_unpack,
#   pack, pack_into, size, unpack, unpack_from
#
# NOTE: __reduce_ex__ is NOT in Struct.__dict__ (inherited from object).
# ---------------------------------------------------------------------------

table struct_extra206.Struct_dict_method_presence:
  description: "struct.Struct.__dict__ method presence checks in structpack206 namespace — wave 257 theme: Struct.__dict__ has 16 entries; __init__==True (C-level slot); __getattribute__==True (C-level override); __reduce_ex__==False (NOT in Struct dict, inherited from object); pack_into==True; unpack_from==True; iter_unpack==True; all verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: structpack206

  columns: [id, function, args, expected, description]
  rows:
    - [has_init,           struct.Struct.__dict__.__contains__, ["__init__"],          true,  "struct.Struct.__dict__.__contains__('__init__') == True — Struct has its own __init__ slot; verified with Python 3.14.3"]
    - [has_getattr,        struct.Struct.__dict__.__contains__, ["__getattribute__"],  true,  "struct.Struct.__dict__.__contains__('__getattribute__') == True — Struct overrides __getattribute__; verified with Python 3.14.3"]
    - [no_reduce_ex,       struct.Struct.__dict__.__contains__, ["__reduce_ex__"],     false, "struct.Struct.__dict__.__contains__('__reduce_ex__') == False — __reduce_ex__ is NOT in Struct's own dict (inherited from object); verified with Python 3.14.3"]
    - [has_pack_into,      struct.Struct.__dict__.__contains__, ["pack_into"],         true,  "struct.Struct.__dict__.__contains__('pack_into') == True — pack_into method is in Struct dict; verified with Python 3.14.3"]
    - [has_unpack_from,    struct.Struct.__dict__.__contains__, ["unpack_from"],       true,  "struct.Struct.__dict__.__contains__('unpack_from') == True — unpack_from method is in Struct dict; verified with Python 3.14.3"]
    - [has_iter_unpack,    struct.Struct.__dict__.__contains__, ["iter_unpack"],       true,  "struct.Struct.__dict__.__contains__('iter_unpack') == True — iter_unpack method is in Struct dict; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — core attributes and dict length
# ---------------------------------------------------------------------------

table struct_extra206.Struct_dict_core_attrs:
  description: "struct.Struct.__dict__ core attribute presence and dict length checks in structpack206 namespace — wave 257 theme: Struct.__dict__.__contains__('format')==True; Struct.__dict__.__contains__('size')==True; Struct.__dict__.__contains__('pack')==True; Struct.__dict__.__contains__('unpack')==True; Struct.__dict__.__len__()==16; all verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: structpack206a

  columns: [id, function, args, expected, description]
  rows:
    - [has_format,   struct.Struct.__dict__.__contains__, ["format"],  true, "struct.Struct.__dict__.__contains__('format') == True — format attribute descriptor is in Struct dict; verified with Python 3.14.3"]
    - [has_size,     struct.Struct.__dict__.__contains__, ["size"],    true, "struct.Struct.__dict__.__contains__('size') == True — size attribute descriptor is in Struct dict; verified with Python 3.14.3"]
    - [has_pack,     struct.Struct.__dict__.__contains__, ["pack"],    true, "struct.Struct.__dict__.__contains__('pack') == True — pack method is in Struct dict; verified with Python 3.14.3"]
    - [has_unpack,   struct.Struct.__dict__.__contains__, ["unpack"],  true, "struct.Struct.__dict__.__contains__('unpack') == True — unpack method is in Struct dict; verified with Python 3.14.3"]
    - [dict_len,     struct.Struct.__dict__.__len__,      [],          16,   "struct.Struct.__dict__.__len__() == 16 — exactly 16 entries in Struct class dict; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — dunder slot checks (__new__, __repr__, __sizeof__)
# ---------------------------------------------------------------------------

table struct_extra206.Struct_dict_dunder_slots:
  description: "struct.Struct.__dict__ dunder slot presence checks in structpack206 namespace — wave 257 theme: __new__==True; __repr__==True; __sizeof__==True; __delattr__==True; __setattr__==True; __doc__==True; all are present in Struct's own dict (not inherited from object) except __reduce_ex__; all verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: structpack206b

  columns: [id, function, args, expected, description]
  rows:
    - [has_new,       struct.Struct.__dict__.__contains__, ["__new__"],      true, "struct.Struct.__dict__.__contains__('__new__') == True — Struct has its own __new__ slot; verified with Python 3.14.3"]
    - [has_repr,      struct.Struct.__dict__.__contains__, ["__repr__"],     true, "struct.Struct.__dict__.__contains__('__repr__') == True — Struct has its own __repr__; verified with Python 3.14.3"]
    - [has_sizeof,    struct.Struct.__dict__.__contains__, ["__sizeof__"],   true, "struct.Struct.__dict__.__contains__('__sizeof__') == True — Struct has its own __sizeof__; verified with Python 3.14.3"]
    - [has_delattr,   struct.Struct.__dict__.__contains__, ["__delattr__"],  true, "struct.Struct.__dict__.__contains__('__delattr__') == True — Struct overrides __delattr__ (immutable after init); verified with Python 3.14.3"]
    - [has_setattr,   struct.Struct.__dict__.__contains__, ["__setattr__"],  true, "struct.Struct.__dict__.__contains__('__setattr__') == True — Struct overrides __setattr__ (immutable after init); verified with Python 3.14.3"]
    - [has_doc,       struct.Struct.__dict__.__contains__, ["__doc__"],      true, "struct.Struct.__dict__.__contains__('__doc__') == True — Struct has a docstring in its class dict; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct_extra206
# ---------------------------------------------------------------------------

invariant struct_extra206.Struct_dict_contains_init:
  description: "struct.Struct.__dict__.__contains__('__init__') returns True — struct.Struct is a C extension type (defined in Modules/_struct.c); it defines its own __init__ slot which is invoked when constructing Struct(fmt); the __init__ validates the format string and caches the compiled pattern; __init__ is distinct from __new__ which allocates the object; Struct.__dict__ contains 16 entries total; compare: __reduce_ex__ is NOT in Struct.__dict__ (inherited from object); NEW in struct_extra206: first standalone Struct dict __init__ invariant in structpack206 namespace; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__init__"]
  expected: true

invariant struct_extra206.Struct_dict_contains_getattribute:
  description: "struct.Struct.__dict__.__contains__('__getattribute__') returns True — struct.Struct overrides __getattribute__ at the C level (Modules/_struct.c) to provide efficient attribute access for 'format' and 'size' without going through the full MRO lookup; this is a performance optimization for the two most commonly accessed Struct attributes; compare: __reduce_ex__ is NOT in Struct's own dict (inherited from object via the standard MRO); Struct.__dict__.__len__()==16; NEW in struct_extra206: first standalone Struct dict __getattribute__ invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__getattribute__"]
  expected: true

invariant struct_extra206.Struct_dict_NOT_contains_reduce_ex:
  description: "struct.Struct.__dict__.__contains__('__reduce_ex__') returns False — __reduce_ex__ is NOT defined in struct.Struct's own class dict; it is inherited from object via the normal MRO (struct.Struct -> object); struct.Struct does NOT override pickling behavior; this means Struct instances can still be pickled via the inherited object.__reduce_ex__ mechanism; compare: __init__, __new__, __repr__, __sizeof__, __delattr__, __setattr__, __getattribute__ are all present in Struct.__dict__ (defined at C level); NEW in struct_extra206: first standalone Struct dict __reduce_ex__ absent invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__reduce_ex__"]
  expected: false

invariant struct_extra206.Struct_dict_contains_pack_into:
  description: "struct.Struct.__dict__.__contains__('pack_into') returns True — pack_into is an instance method on struct.Struct that writes packed bytes into a writable buffer (bytearray or memoryview) at a given offset; signature: pack_into(buffer, offset, v1, v2, ...); unlike pack() which returns a new bytes object, pack_into writes in-place making it suitable for building binary frames without allocation; pack_into is present in Struct.__dict__ (C-level method descriptor); NEW in struct_extra206: first standalone Struct dict pack_into invariant in structpack206 namespace; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["pack_into"]
  expected: true

invariant struct_extra206.Struct_dict_contains_unpack_from:
  description: "struct.Struct.__dict__.__contains__('unpack_from') returns True — unpack_from is an instance method on struct.Struct that reads from a buffer at a given offset without requiring the buffer to be exactly Struct.size bytes; signature: unpack_from(buffer, offset=0); unlike unpack() which requires exactly calcsize bytes, unpack_from can read from a slice of a larger buffer; useful when multiple fields are packed into a single buffer; present in Struct.__dict__ (C-level method descriptor); NEW in struct_extra206: first standalone Struct dict unpack_from invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["unpack_from"]
  expected: true

invariant struct_extra206.Struct_dict_contains_iter_unpack:
  description: "struct.Struct.__dict__.__contains__('iter_unpack') returns True — iter_unpack is an instance method on struct.Struct that returns an iterator yielding successive tuples unpacked from a buffer; the buffer must be a multiple of Struct.size bytes in length; signature: iter_unpack(buffer); equivalent to calling unpack_from repeatedly at offsets 0, size, 2*size, etc.; present in Struct.__dict__ (C-level method descriptor); compare: struct module-level iter_unpack is also available but Struct.iter_unpack is accessed from the instance; NEW in struct_extra206: first standalone Struct dict iter_unpack invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra206.Struct_dict_len_16:
  description: "struct.Struct.__dict__.__len__() == 16 — the Struct class dict has exactly 16 entries as of Python 3.14.3: __delattr__, __doc__, __getattribute__, __init__, __module__, __new__, __repr__, __setattr__, __sizeof__, format, iter_unpack, pack, pack_into, size, unpack, unpack_from; note that __reduce_ex__, __reduce__, __hash__, __eq__ are NOT present (inherited from object); the absence of these from Struct.__dict__ confirms Struct relies on the default object equality (identity) and pickling behavior; NEW in struct_extra206: first standalone Struct dict length invariant in structpack206 namespace; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__len__
  args: []
  expected: 16

invariant struct_extra206.Struct_dict_contains_sizeof:
  description: "struct.Struct.__dict__.__contains__('__sizeof__') returns True — __sizeof__ is present in struct.Struct's own class dict; it is overridden at the C level to report the actual memory footprint of a Struct instance including the compiled format cache; sys.getsizeof(Struct(fmt)) calls __sizeof__ internally; the presence of __sizeof__ in Struct.__dict__ confirms the C implementation provides a custom memory size calculation distinct from object.__sizeof__; all 16 dict entries are C-level slots; NEW in struct_extra206: first standalone Struct dict __sizeof__ invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__sizeof__"]
  expected: true

