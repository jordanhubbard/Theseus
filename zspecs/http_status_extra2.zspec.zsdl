spec: http_status_extra2
version: ">=3.9"
backend: python_module(http)

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.html — Python http module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
    - "http_status.zspec.zsdl — covers HTTPStatus class identity (__name__, __module__, base IntEnum via method chain), success/redirect/client/server error values, IntEnum int equality, OK/NOT_FOUND phrase strings"
    - "http_status_extra.zspec.zsdl — covers OK/NOT_FOUND/INTERNAL_SERVER_ERROR .value, OK/NOT_FOUND .name, OK.__class__.__name__, and a table of OK/CREATED/NO_CONTENT/BAD_REQUEST/UNAUTHORIZED/FORBIDDEN/NOT_FOUND values"
  notes:
    - "This spec extends http_status.zspec.zsdl and http_status_extra.zspec.zsdl."
    - "http.HTTPStatus.__bases__[0].__name__ == 'IntEnum' — HTTPStatus inherits from IntEnum; verified at runtime."
    - "http.HTTPStatus.ACCEPTED.value == 202 — 202 Accepted; no prior http spec covers ACCEPTED.value as a standalone invariant; verified at runtime."
    - "http.HTTPStatus.MOVED_PERMANENTLY.value == 301 — 301 Moved Permanently; no prior http spec covers this value; verified at runtime."
    - "http.HTTPStatus.CREATED.phrase == 'Created' — phrase for 201 Created; no prior http spec checks CREATED.phrase; verified at runtime."
    - "http.HTTPStatus.NO_CONTENT.phrase == 'No Content' — phrase for 204 No Content; no prior http spec checks NO_CONTENT.phrase; verified at runtime."
    - "http.HTTPStatus.BAD_REQUEST.phrase == 'Bad Request' — phrase for 400; no prior http spec checks BAD_REQUEST.phrase; verified at runtime."
    - "http.HTTPStatus.INTERNAL_SERVER_ERROR.phrase == 'Internal Server Error' — phrase for 500; no prior http spec checks INTERNAL_SERVER_ERROR.phrase; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPStatus.__bases__[0].__name__ — __eq__ chain style
#
# http_status.zspec.zsdl covers this via method chain (HTTPStatus.__bases__.__getitem__).
# This invariant uses the dotted __eq__ chain style for independent cross-checking
# in the extra2 namespace.
# ---------------------------------------------------------------------------

invariant http_status_extra2.HTTPStatus.base_name:
  description: "http.HTTPStatus.__bases__[0].__name__ == 'IntEnum'"
  category: class_hierarchy
  kind: python_call_eq
  function: "HTTPStatus.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus .value — ACCEPTED and MOVED_PERMANENTLY
#
# http_status_extra covers OK/NOT_FOUND/INTERNAL_SERVER_ERROR as standalone
# invariants and a broader value table. ACCEPTED (202) and MOVED_PERMANENTLY
# (301) are new standalone coverage axes not in any prior http spec.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant http_status_extra2.ACCEPTED.value:
  description: "http.HTTPStatus.ACCEPTED.value == 202"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.ACCEPTED.value.__eq__
  args: [202]
  expected: true

invariant http_status_extra2.MOVED_PERMANENTLY.value:
  description: "http.HTTPStatus.MOVED_PERMANENTLY.value == 301"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.MOVED_PERMANENTLY.value.__eq__
  args: [301]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus .phrase — CREATED, NO_CONTENT, BAD_REQUEST, INTERNAL_SERVER_ERROR
#
# http_status.zspec.zsdl covers OK.phrase and NOT_FOUND.phrase only.
# No prior http spec checks phrase for CREATED, NO_CONTENT, BAD_REQUEST,
# or INTERNAL_SERVER_ERROR. All verified at runtime.
# ---------------------------------------------------------------------------

invariant http_status_extra2.CREATED.phrase:
  description: "http.HTTPStatus.CREATED.phrase == 'Created'"
  category: phrase
  kind: python_call_eq
  function: HTTPStatus.CREATED.phrase.__eq__
  args: ["Created"]
  expected: true

invariant http_status_extra2.NO_CONTENT.phrase:
  description: "http.HTTPStatus.NO_CONTENT.phrase == 'No Content'"
  category: phrase
  kind: python_call_eq
  function: HTTPStatus.NO_CONTENT.phrase.__eq__
  args: ["No Content"]
  expected: true

invariant http_status_extra2.BAD_REQUEST.phrase:
  description: "http.HTTPStatus.BAD_REQUEST.phrase == 'Bad Request'"
  category: phrase
  kind: python_call_eq
  function: HTTPStatus.BAD_REQUEST.phrase.__eq__
  args: ["Bad Request"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus phrase table — six representative status codes
#
# Consolidates phrase checks for a set of well-known codes that span the
# 2xx, 3xx, 4xx, and 5xx ranges. http_status_extra covers a .value table;
# this table focuses on .phrase as a distinct attribute axis with a new
# id_prefix to avoid ID collision with all prior http specs.
# Verified at runtime.
# ---------------------------------------------------------------------------

table http_status_extra2.phrase_values:
  description: ".phrase for representative HTTPStatus members across 2xx–5xx"
  kind: python_call_eq
  category: phrase
  id_prefix: hse2p

  columns: [id, function, args, expected]
  rows:
    - [ok,                       HTTPStatus.OK.phrase.__eq__,                       ["OK"],                       true]
    - [created,                  HTTPStatus.CREATED.phrase.__eq__,                  ["Created"],                  true]
    - [accepted,                 HTTPStatus.ACCEPTED.phrase.__eq__,                 ["Accepted"],                 true]
    - [moved_permanently,        HTTPStatus.MOVED_PERMANENTLY.phrase.__eq__,        ["Moved Permanently"],        true]
    - [bad_request,              HTTPStatus.BAD_REQUEST.phrase.__eq__,              ["Bad Request"],              true]
    - [internal_server_error,    HTTPStatus.INTERNAL_SERVER_ERROR.phrase.__eq__,    ["Internal Server Error"],    true]
