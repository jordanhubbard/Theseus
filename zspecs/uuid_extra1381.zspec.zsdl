spec: uuid_extra1381
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks."
    - "uuid.UUID is a concrete pure-Python class; it defines no abstract methods, so uuid.UUID.__dict__.__contains__('__abstractmethods__') returns False."
    - "uuid.SafeUUID is an IntEnum subclass; it also defines no abstract methods, so uuid.SafeUUID.__dict__.__contains__('__abstractmethods__') returns False."
    - "frozenset is the type that __abstractmethods__ would be set to on abstract classes; frozenset.__class__.__name__ == 'type' (frozenset is a class, metaclass is type)."
    - "frozenset.__bases__.__class__.__name__ == 'tuple' — the bases of frozenset are stored as a tuple."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' — all Python class __dict__ attributes are mappingproxy instances."
    - "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy' — same property holds for enum classes."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1381.uuid_class_abstractmethods_absent:
  description: "uuid.UUID class dict does not contain __abstractmethods__ — UUID is a concrete class with no abstract methods; __dict__.__contains__ returns False"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: uu1381ua
  columns: [id, function, args, expected]
  rows:
    - [uu1381ua001, uuid.UUID.__dict__.__contains__,     ["__abstractmethods__"], false]
    - [uu1381ua002, uuid.SafeUUID.__dict__.__contains__,  ["__abstractmethods__"], false]
    - [uu1381ua003, uuid.UUID.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [uu1381ua004, uuid.SafeUUID.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [uu1381ua005, uuid.UUID.__mro__.__class__.__name__.__eq__,       ["tuple"], true]
    - [uu1381ua006, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,   ["tuple"], true]

table uuid_extra1381.frozenset_abstractmethods_type_checks:
  description: "frozenset (the type __abstractmethods__ would be set to on abstract classes) class-level checks; frozenset.__class__.__name__ == 'type' and frozenset.__bases__.__class__.__name__ == 'tuple'"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: uu1381fa
  columns: [id, function, args, expected]
  rows:
    - [uu1381fa001, frozenset.__class__.__name__.__eq__,            ["type"],         true]
    - [uu1381fa002, frozenset.__bases__.__class__.__name__.__eq__,  ["tuple"],        true]
    - [uu1381fa003, frozenset.__name__.__class__.__name__.__eq__,   ["str"],          true]
    - [uu1381fa004, frozenset.__dict__.__contains__,                 ["__abstractmethods__"], false]
    - [uu1381fa005, frozenset.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [uu1381fa006, frozenset.__mro__.__class__.__name__.__eq__,    ["tuple"],        true]

table uuid_extra1381.uuid_bases_and_class_name_checks:
  description: "uuid.UUID and uuid.SafeUUID __bases__ and __class__.__name__ cross-checks; verifies the inheritance structure attributes are consistent with the abstractmethods theme"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: uu1381bc
  columns: [id, function, args, expected]
  rows:
    - [uu1381bc001, uuid.UUID.__bases__.__class__.__name__.__eq__,        ["tuple"],  true]
    - [uu1381bc002, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,    ["tuple"],  true]
    - [uu1381bc003, uuid.UUID.__class__.__name__.__eq__,                  ["type"],   true]
    - [uu1381bc004, uuid.SafeUUID.__class__.__name__.__eq__,              ["EnumType"], true]
    - [uu1381bc005, uuid.UUID.__name__.__class__.__name__.__eq__,         ["str"],    true]
    - [uu1381bc006, uuid.SafeUUID.__name__.__class__.__name__.__eq__,     ["str"],    true]
