spec: ft3526
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 682 (ft3526): __set_name__, __init_subclass__, __class_getitem__ dict-presence checks for functools types."
    - "functools.cached_property defines __set_name__ (true): __set_name__ is called when the descriptor is assigned to a class variable; cached_property uses it to capture the attribute name for cache storage."
    - "functools.partial does NOT define __set_name__, __init_subclass__, or __class_getitem__ (all false)."
    - "functools.partialmethod does NOT define __set_name__, __init_subclass__, or __class_getitem__ (all false)."
    - "type(functools.lru_cache(lambda: None)) does NOT define __set_name__, __init_subclass__, or __class_getitem__ (all false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __set_name__ dict-presence — operator.contains(Cls.__dict__, '__set_name__')
# ---------------------------------------------------------------------------

table ft3526.set_name:
  description: "functools types __set_name__ dict-presence checks; wave 682"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3526
  columns: [id, function, args, expected]
  rows:
    - ["ft3526001", operator.contains, [functools.partial.__dict__,                       "__set_name__"], false]
    - ["ft3526002", operator.contains, [functools.partialmethod.__dict__,                 "__set_name__"], false]
    - ["ft3526003", operator.contains, [functools.cached_property.__dict__,               "__set_name__"], true]
    - ["ft3526004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__, "__set_name__"], false]

