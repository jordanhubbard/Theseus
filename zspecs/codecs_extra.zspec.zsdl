spec: codecs_extra
version: ">=3.2"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "Python codecs documentation — https://docs.python.org/3/library/codecs.html"
    - "Test vectors verified by running Python 3.14.3 codecs module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "CPython source: internal codec state machines"
  notes:
    - "This spec covers aspects of codecs not in codecs.zspec.zsdl."
    - "CodecInfo.__name__ == 'CodecInfo' and CodecInfo.__module__ == 'codecs'."
    - "codecs.lookup('utf-8') returns a CodecInfo instance."
    - "codecs.encode('hello', 'utf-8') returns b'hello' (bytes, not a tuple)."
    - "codecs.decode(b'hello', 'utf-8') returns 'hello' (str, not a tuple)."
    - "codecs.open.__name__ == 'open' — module-level open for codec-aware file I/O."
    - "codecs.register.__name__ == 'register' — registers a codec search function."
    - "codecs.getincrementalencoder('utf-8') returns the IncrementalEncoder class."
    - "codecs.getincrementaldecoder('utf-8') returns the IncrementalDecoder class."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CodecInfo class identity
# ---------------------------------------------------------------------------

invariant codecs_extra.CodecInfo.name:
  description: "codecs.CodecInfo.__name__ == 'CodecInfo'"
  category: classes
  kind: python_call_eq
  function: CodecInfo.__name__.__eq__
  args: ["CodecInfo"]
  expected: true

invariant codecs_extra.CodecInfo.module:
  description: "codecs.CodecInfo.__module__ == 'codecs'"
  category: classes
  kind: python_call_eq
  function: CodecInfo.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# lookup — returns CodecInfo instance (class name check)
# ---------------------------------------------------------------------------

invariant codecs_extra.lookup.utf8_class_name:
  description: "codecs.lookup('utf-8').__class__.__name__ == 'CodecInfo'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-8"]
  method: __class__.__name__.__eq__
  method_args: ["CodecInfo"]
  expected: true

# ---------------------------------------------------------------------------
# encode / decode — UTF-8 string↔bytes
# ---------------------------------------------------------------------------

invariant codecs_extra.encode.utf8:
  description: "codecs.encode('hello', 'utf-8') == b'hello'"
  category: encode_decode
  kind: python_call_eq
  function: encode
  args: ["hello", "utf-8"]
  expected: !ascii "hello"

invariant codecs_extra.decode.utf8:
  description: "codecs.decode(b'hello', 'utf-8') == 'hello'"
  category: encode_decode
  kind: python_call_eq
  function: decode
  args: [!ascii "hello", "utf-8"]
  expected: "hello"

# ---------------------------------------------------------------------------
# function __name__ checks
# ---------------------------------------------------------------------------

invariant codecs_extra.open.name:
  description: "codecs.open.__name__ == 'open'"
  category: identity
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant codecs_extra.register.name:
  description: "codecs.register.__name__ == 'register'"
  category: identity
  kind: python_call_eq
  function: register.__name__.__eq__
  args: ["register"]
  expected: true

# ---------------------------------------------------------------------------
# getincrementalencoder / getincrementaldecoder — return class name
# ---------------------------------------------------------------------------

invariant codecs_extra.getincrementalencoder.utf8_class_name:
  description: "codecs.getincrementalencoder('utf-8').__name__ == 'IncrementalEncoder'"
  category: incremental
  kind: python_call_eq
  function: getincrementalencoder
  args: ["utf-8"]
  method: __name__.__eq__
  method_args: ["IncrementalEncoder"]
  expected: true

invariant codecs_extra.getincrementaldecoder.utf8_class_name:
  description: "codecs.getincrementaldecoder('utf-8').__name__ == 'IncrementalDecoder'"
  category: incremental
  kind: python_call_eq
  function: getincrementaldecoder
  args: ["utf-8"]
  method: __name__.__eq__
  method_args: ["IncrementalDecoder"]
  expected: true
