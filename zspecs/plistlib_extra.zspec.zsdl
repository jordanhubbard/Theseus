spec: plistlib_extra
version: ">=3.9"
backend: python_module(plistlib)

docs: https://docs.python.org/3/library/plistlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/plistlib.html — Python plistlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/plistlib.py"
  notes:
    - "plistlib is a Python stdlib module for reading and writing Apple property list (plist) files."
    - "plistlib.load and plistlib.loads read plist data from file objects and bytes respectively."
    - "plistlib.dump and plistlib.dumps write plist data to file objects and return bytes respectively."
    - "plistlib.FMT_XML and plistlib.FMT_BINARY are IntEnum members of plistlib.PlistFormat."
    - "FMT_XML == 1 and FMT_BINARY == 2 — the integer values of the PlistFormat enum members."
    - "FMT_XML.__class__.__name__ == 'PlistFormat' — both constants are instances of PlistFormat."
    - "plistlib.InvalidFileException is raised for malformed plist data; it inherits from ValueError."
    - "plistlib.UID is a helper class for representing UID values in plist files."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — load, loads, dump, dumps
# ---------------------------------------------------------------------------

table plistlib_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [load,  load.__name__.__eq__,  ["load"],  true]
    - [loads, loads.__name__.__eq__, ["loads"], true]
    - [dump,  dump.__name__.__eq__,  ["dump"],  true]
    - [dumps, dumps.__name__.__eq__, ["dumps"], true]

# ---------------------------------------------------------------------------
# FMT_XML — PlistFormat IntEnum member, value == 1
# ---------------------------------------------------------------------------

invariant plistlib_extra.FMT_XML.class_name:
  description: "plistlib.FMT_XML.__class__.__name__ == 'PlistFormat'"
  category: constants
  kind: python_call_eq
  function: FMT_XML.__class__.__name__.__eq__
  args: ["PlistFormat"]
  expected: true

invariant plistlib_extra.FMT_XML.value:
  description: "plistlib.FMT_XML == 1 — FMT_XML has integer value 1"
  category: constants
  kind: python_call_eq
  function: FMT_XML.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# FMT_BINARY — PlistFormat IntEnum member, value == 2
# ---------------------------------------------------------------------------

invariant plistlib_extra.FMT_BINARY.class_name:
  description: "plistlib.FMT_BINARY.__class__.__name__ == 'PlistFormat'"
  category: constants
  kind: python_call_eq
  function: FMT_BINARY.__class__.__name__.__eq__
  args: ["PlistFormat"]
  expected: true

invariant plistlib_extra.FMT_BINARY.value:
  description: "plistlib.FMT_BINARY == 2 — FMT_BINARY has integer value 2"
  category: constants
  kind: python_call_eq
  function: FMT_BINARY.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# PlistFormat — the enum class itself
# ---------------------------------------------------------------------------

invariant plistlib_extra.PlistFormat.class_name:
  description: "plistlib.PlistFormat.__name__ == 'PlistFormat'"
  category: class_names
  kind: python_call_eq
  function: PlistFormat.__name__.__eq__
  args: ["PlistFormat"]
  expected: true

# ---------------------------------------------------------------------------
# InvalidFileException — class name and hierarchy
# ---------------------------------------------------------------------------

invariant plistlib_extra.InvalidFileException.class_name:
  description: "plistlib.InvalidFileException.__name__ == 'InvalidFileException'"
  category: class_names
  kind: python_call_eq
  function: InvalidFileException.__name__.__eq__
  args: ["InvalidFileException"]
  expected: true

invariant plistlib_extra.InvalidFileException.base_is_ValueError:
  description: "plistlib.InvalidFileException.__bases__[0].__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: InvalidFileException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# UID — helper class for plist UID values
# ---------------------------------------------------------------------------

invariant plistlib_extra.UID.class_name:
  description: "plistlib.UID.__name__ == 'UID'"
  category: class_names
  kind: python_call_eq
  function: UID.__name__.__eq__
  args: ["UID"]
  expected: true

invariant plistlib_extra.UID.module:
  description: "plistlib.UID.__module__ == 'plistlib'"
  category: class_modules
  kind: python_call_eq
  function: UID.__module__.__eq__
  args: ["plistlib"]
  expected: true

# ---------------------------------------------------------------------------
# FMT_XML and FMT_BINARY are distinct — their integer values differ
# ---------------------------------------------------------------------------

invariant plistlib_extra.FMT_XML.not_equal_FMT_BINARY:
  description: "plistlib.FMT_XML != plistlib.FMT_BINARY — the two format constants are distinct"
  category: constants
  kind: python_call_eq
  function: FMT_XML.__eq__
  args: [2]
  expected: false

# ---------------------------------------------------------------------------
# FMT_XML is an int subclass (IntEnum inherits from int)
# ---------------------------------------------------------------------------

invariant plistlib_extra.FMT_XML.is_int_subclass:
  description: "isinstance(plistlib.FMT_XML, int) — PlistFormat is an IntEnum so members are ints"
  category: constants
  kind: python_call_eq
  function: FMT_XML.__class__.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "int"
