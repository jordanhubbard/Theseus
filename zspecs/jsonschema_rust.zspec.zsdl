invariant jsonschema_rust.has_error_class:
  description: "jsonschema.ValidationError is a class"
  category: presence
  kind: python_call_eq
  function: jsonschema_has_error_class
  args: []
  expected: true

invariant jsonschema_rust.schema_version:
  description: "jsonschema.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: jsonschema_schema_version
  args: []
  expected: true


