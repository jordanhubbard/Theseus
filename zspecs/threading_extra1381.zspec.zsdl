spec: threading_extra1381
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ and __isabstractmethod__ checks for threading classes."
    - "threading.Thread, Event, Semaphore, Barrier, and Condition are pure Python classes; threading.Lock is _thread.lock, a C extension type."
    - "None of these threading classes define abstract methods; none have __abstractmethods__ or __isabstractmethod__ in their __dict__."
    - "All class __dict__ attributes are mappingproxy instances regardless of whether the class is defined in C or Python."
    - "threading.Thread.__dict__ contains 'start' and 'run' — the primary threading API methods."
    - "threading.Event.__dict__ contains 'is_set'; threading.Semaphore.__dict__ contains 'acquire'; threading.Barrier.__dict__ contains 'wait'."
    - "threading.Lock.__dict__ contains both 'acquire' and 'release' as C-level method descriptors."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1381.abstractmethods_not_in_dict_thread_lock:
  description: "threading.Thread and Lock have no __abstractmethods__ or __isabstractmethod__ in their __dict__; Thread is pure Python, Lock is a C type, neither defines abstract methods"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: th1381tl
  columns: [id, function, args, expected]
  rows:
    - [th1381tl001, threading.Thread.__dict__.__contains__, ["__abstractmethods__"],  false]
    - [th1381tl002, threading.Thread.__dict__.__contains__, ["__isabstractmethod__"], false]
    - [th1381tl003, threading.Lock.__dict__.__contains__,   ["__abstractmethods__"],  false]
    - [th1381tl004, threading.Lock.__dict__.__contains__,   ["__isabstractmethod__"], false]
    - [th1381tl005, threading.Thread.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true]
    - [th1381tl006, threading.Lock.__dict__.__class__.__name__.__eq__,   ["mappingproxy"],  true]

table threading_extra1381.abstractmethods_not_in_dict_event_semaphore_barrier:
  description: "threading.Event, Semaphore, and Barrier have no __abstractmethods__ or __isabstractmethod__ in their __dict__; all are concrete pure Python classes"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: th1381es
  columns: [id, function, args, expected]
  rows:
    - [th1381es001, threading.Event.__dict__.__contains__,     ["__abstractmethods__"],  false]
    - [th1381es002, threading.Event.__dict__.__contains__,     ["__isabstractmethod__"], false]
    - [th1381es003, threading.Semaphore.__dict__.__contains__,  ["__abstractmethods__"],  false]
    - [th1381es004, threading.Semaphore.__dict__.__contains__,  ["__isabstractmethod__"], false]
    - [th1381es005, threading.Barrier.__dict__.__contains__,    ["__abstractmethods__"],  false]
    - [th1381es006, threading.Barrier.__dict__.__contains__,    ["__isabstractmethod__"], false]
    - [th1381es007, threading.Event.__dict__.__class__.__name__.__eq__,    ["mappingproxy"],  true]
    - [th1381es008, threading.Semaphore.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true]

table threading_extra1381.api_methods_in_dict_cross_check:
  description: "Cross-check: threading classes expose their primary API methods in __dict__; Condition has no abstract-method entries; Thread has both start and run"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: th1381ax
  columns: [id, function, args, expected]
  rows:
    - [th1381ax001, threading.Thread.__dict__.__contains__,    ["start"],               true]
    - [th1381ax002, threading.Thread.__dict__.__contains__,    ["run"],                 true]
    - [th1381ax003, threading.Event.__dict__.__contains__,     ["is_set"],              true]
    - [th1381ax004, threading.Semaphore.__dict__.__contains__,  ["acquire"],             true]
    - [th1381ax005, threading.Barrier.__dict__.__contains__,    ["wait"],                true]
    - [th1381ax006, threading.Condition.__dict__.__contains__,  ["notify"],              true]
    - [th1381ax007, threading.Lock.__dict__.__contains__,       ["acquire"],             true]
    - [th1381ax008, threading.Condition.__dict__.__contains__,  ["__abstractmethods__"], false]
