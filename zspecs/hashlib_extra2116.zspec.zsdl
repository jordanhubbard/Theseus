  columns: [id, function, args, expected]
  rows:
    - ["hl2116010", "hashlib.blake2b.__dict__.__contains__",              ["__and__"],   false]
    - ["hl2116011", "hashlib.blake2b.__dict__.__contains__",              ["__rand__"],  false]
    - ["hl2116012", "hashlib.blake2b.__dict__.__contains__",              ["__iand__"],  false]
    - ["hl2116013", "hashlib.blake2s.__dict__.__contains__",              ["__and__"],   false]
    - ["hl2116014", "hashlib.blake2s.__dict__.__contains__",              ["__rand__"],  false]
    - ["hl2116015", "hashlib.blake2s.__dict__.__contains__",              ["__iand__"],  false]
    - ["hl2116016", "hashlib.md5().__class__.__dict__.__contains__",      ["__and__"],   false]
    - ["hl2116017", "hashlib.md5().__class__.__dict__.__contains__",      ["__rand__"],  false]
    - ["hl2116018", "hashlib.md5().__class__.__dict__.__contains__",      ["__iand__"],  false]

