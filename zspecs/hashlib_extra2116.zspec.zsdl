spec: hashlib_extra2116
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Lib/hashlib.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "hashlib.blake2b and hashlib.blake2s are C-implemented hash constructors; they do not define set/dict merge operators."
    - "_hashlib.HASH is the C type returned by hashlib.md5(), hashlib.sha256(), etc.; it has no set/dict operators."
    - "_hashlib.HASHXOF is the C type returned by hashlib.shake_128(), hashlib.shake_256(); it has no set/dict operators."
    - "None of the hashlib classes define __or__, __ror__, __ior__ in their own __dict__."
    - "None of the hashlib classes define __and__, __rand__, __iand__ in their own __dict__."
    - "None of the hashlib classes define __xor__, __rxor__, __ixor__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# hashlib hash classes do not define these operators
# ---------------------------------------------------------------------------

table hashlib_extra2116.or_protocol:
  description: "hashlib types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2116

  columns: [id, function, args, expected]
  rows:
    - ["hl2116001", "hashlib.blake2b.__dict__.__contains__",           ["__or__"],  false]
    - ["hl2116002", "hashlib.blake2b.__dict__.__contains__",           ["__ror__"], false]
    - ["hl2116003", "hashlib.blake2b.__dict__.__contains__",           ["__ior__"], false]
    - ["hl2116004", "hashlib.blake2s.__dict__.__contains__",           ["__or__"],  false]
    - ["hl2116005", "hashlib.blake2s.__dict__.__contains__",           ["__ror__"], false]
    - ["hl2116006", "hashlib.blake2s.__dict__.__contains__",           ["__ior__"], false]
    - ["hl2116007", "hashlib.md5().__class__.__dict__.__contains__",   ["__or__"],  false]
    - ["hl2116008", "hashlib.md5().__class__.__dict__.__contains__",   ["__ror__"], false]
    - ["hl2116009", "hashlib.md5().__class__.__dict__.__contains__",   ["__ior__"], false]

# ---------------------------------------------------------------------------
