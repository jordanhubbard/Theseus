  columns: [id, function, args, expected]
  rows:
    - ["hl2116019", "hashlib.blake2b.__dict__.__contains__",              ["__xor__"],  false]
    - ["hl2116020", "hashlib.blake2b.__dict__.__contains__",              ["__rxor__"], false]
    - ["hl2116021", "hashlib.blake2b.__dict__.__contains__",              ["__ixor__"], false]
    - ["hl2116022", "hashlib.blake2s.__dict__.__contains__",              ["__xor__"],  false]
    - ["hl2116023", "hashlib.blake2s.__dict__.__contains__",              ["__rxor__"], false]
    - ["hl2116024", "hashlib.blake2s.__dict__.__contains__",              ["__ixor__"], false]
