spec: ab3226
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (ab3226): __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic) for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__radd__): all 3 abc subjects return false for __radd__. abc.ABC is a plain abstract base class convenience wrapper with no arithmetic semantics — n + ABC is not a defined operation and ABC has no __radd__ to provide a fallback. abc.ABCMeta is a metaclass responsible for abstract method tracking and virtual subclass registration (__subclasshook__, register(), __abstractmethods__); none of these capabilities involve reflected addition. The function type (type(abc.abstractmethod(lambda: None)) is <class 'function'>) does not define __radd__ — functions are callables and descriptors, not numeric or sequence types. n + f is not a valid Python expression for function objects."
    - "Key finding (__rsub__): all 3 abc subjects return false for __rsub__. Reflected subtraction (__rsub__) is the complement of __sub__. abc.ABC defines no arithmetic operators — neither __sub__ nor __rsub__ appear in its __dict__. abc.ABCMeta's entire capability is in class-hierarchy machinery; arithmetic is entirely absent. The function type does not define __rsub__; n - f is not a valid Python expression for callable objects."
    - "Key finding (__rmul__): all 3 abc subjects return false for __rmul__. Reflected multiplication (__rmul__) is invoked when n * obj is attempted and the left operand does not handle the right operand. abc.ABC has no numeric or sequence data model. abc.ABCMeta handles abstract method tracking and class hierarchy; none of its responsibilities map to reflected multiplication. The function type does not define __rmul__; n * f is not a valid Python expression for callable objects."
    - "All 9 values in this wave are false — continuing the all-false pattern from wave 661 (__and__/__or__/__xor__)."
    - "The function type profile across all waves: true only for __get__ (wave 652), __repr__ (wave 655), and __call__ (wave 656). All other dunders tested — including this wave's __radd__/__rsub__/__rmul__ — are false."
    - "abc.ABCMeta has now returned false for every arithmetic and reflected arithmetic dunder tested across 11 consecutive waves (652–662). Its entire capability is expressed through class-hierarchy machinery, not operator overloading."
    - "Cross-wave summary for abc subjects:"
    - "  Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false."
    - "  Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3."
    - "  Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3."
    - "  Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false."
    - "  Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false."
    - "  Wave 657 (ab3151): __setitem__/__delitem__/__contains__ — all false for all 3."
    - "  Wave 658 (ab3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (ab3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (ab3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (ab3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (ab3226): __radd__/__rsub__/__rmul__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __radd__ dict-presence — operator.contains(Cls.__dict__, '__radd__')
#
# All 3 abc subjects return false for __radd__.
# abc.ABC: a plain abstract base class convenience wrapper with no
#   arithmetic or reflected-arithmetic semantics. n + ABC is not a defined
#   Python operation; ABC has no __radd__ to serve as a fallback.
# abc.ABCMeta: a metaclass for abstract method tracking and virtual subclass
#   registration. Reflected addition has no role in ABCMeta's responsibilities
#   (__subclasshook__, register(), __abstractmethods__).
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __radd__. n + f is not a valid Python expression
#   for callable objects. Functions are callables and descriptors with no
#   numeric or sequence data model.
# ---------------------------------------------------------------------------

table ab3226.radd:
  description: "abc types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3226

  columns: [id, function, args, expected]
  rows:
    - ["ab3226001", operator.contains, [abc.ABC.__dict__,                                 "__radd__"], false]
    - ["ab3226002", operator.contains, [abc.ABCMeta.__dict__,                             "__radd__"], false]
    - ["ab3226003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__radd__"], false]

# ---------------------------------------------------------------------------
# __rsub__ dict-presence — operator.contains(Cls.__dict__, '__rsub__')
#
# All 3 abc subjects return false for __rsub__.
# abc.ABC: no arithmetic data model; neither __sub__ nor __rsub__ appear in
#   abc.ABC's __dict__. ABC is a pure abstract base class helper with no
#   state of its own beyond what ABCMeta provides.
# abc.ABCMeta: does not define __rsub__ for metaclass reflected subtraction.
#   ABCMeta's API surface (__subclasshook__, register(), __abstractmethods__)
#   has no arithmetic or reflected arithmetic component.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __rsub__. n - f is not a valid Python expression
#   for callable objects. The function type is tightly scoped to its role as
#   a callable descriptor with a display representation.
# ---------------------------------------------------------------------------

table ab3226.rsub:
  description: "abc types __rsub__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3226

  columns: [id, function, args, expected]
  rows:
    - ["ab3226004", operator.contains, [abc.ABC.__dict__,                                 "__rsub__"], false]
    - ["ab3226005", operator.contains, [abc.ABCMeta.__dict__,                             "__rsub__"], false]
    - ["ab3226006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__rsub__"], false]

# ---------------------------------------------------------------------------
# __rmul__ dict-presence — operator.contains(Cls.__dict__, '__rmul__')
#
# All 3 abc subjects return false for __rmul__.
# abc.ABC: no numeric or sequence data model; n * ABC is not a defined
#   Python expression. abc.ABC is a bare metaclass convenience wrapper with
#   no state of its own beyond what ABCMeta provides.
# abc.ABCMeta: does not define __rmul__ for reflected multiplication.
#   ABCMeta is a powerful metaclass, but its entire power lies in
#   class-hierarchy machinery — not in operator overloading.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __rmul__. n * f is not a valid Python expression.
#   The function type is tightly scoped to its role as a callable descriptor
#   with a display representation — no arithmetic operators are defined.
# ---------------------------------------------------------------------------

table ab3226.rmul:
  description: "abc types __rmul__ dict-presence checks; wave 662"
