spec: asyncio_extra11
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra10.zspec.zsdl."
    - "asyncio_extra10 covers: __qualname__ for Semaphore/BoundedSemaphore/Lock/Event/Condition/Queue/QueueEmpty/QueueFull/CancelledError/TimeoutError; run/wait/shield/wait_for __name__ and __module__; QueueEmpty/QueueFull __mro__[2].__name__."
    - "asyncio_extra9 covers: CancelledError/TimeoutError/InvalidStateError/IncompleteReadError __bases__[0].__name__; AbstractEventLoop/BaseEventLoop __bases__[0].__name__; PriorityQueue/LifoQueue __bases__[0].__name__; __module__ for Condition/BoundedSemaphore/PriorityQueue/LifoQueue; gather/sleep/create_task __class__.__name__."
    - "asyncio_extra8 covers: Task/Future __bases__[0].__name__; QueueEmpty/QueueFull __bases__[0].__name__."
    - "NOT yet covered in any prior asyncio spec: asyncio.Lock.__bases__[0].__name__."
    - "NOT yet covered: asyncio.Semaphore.__bases__[0].__name__."
    - "NOT yet covered: asyncio.Event.__bases__[0].__name__."
    - "NOT yet covered: asyncio.BoundedSemaphore.__bases__[0].__name__."
    - "NOT yet covered: asyncio.Condition.__bases__[0].__name__."
    - "NOT yet covered: asyncio.Queue.__bases__[0].__name__."
    - "NOT yet covered: method __qualname__ for Queue.put_nowait, Queue.get_nowait, Queue.empty, Queue.full, Queue.qsize."
    - "NOT yet covered: method __qualname__ for Lock.acquire, Lock.release."
    - "NOT yet covered: method __qualname__ for Semaphore.acquire, Semaphore.release."
    - "asyncio.Lock.__bases__[0].__name__ == 'object' — Lock is a root Python class (no parent sync primitive)."
    - "asyncio.Semaphore.__bases__[0].__name__ == 'object' — Semaphore is a root Python class."
    - "asyncio.Event.__bases__[0].__name__ == 'object' — Event is a root Python class."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore."
    - "asyncio.Condition.__bases__[0].__name__ == 'object' — Condition is a root Python class."
    - "asyncio.Queue.__bases__[0].__name__ == 'object' — Queue is a root Python class."
    - "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait' — method qualname includes class prefix."
    - "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait' — method qualname includes class prefix."
    - "asyncio.Queue.empty.__qualname__ == 'Queue.empty' — method qualname includes class prefix."
    - "asyncio.Queue.full.__qualname__ == 'Queue.full' — method qualname includes class prefix."
    - "asyncio.Queue.qsize.__qualname__ == 'Queue.qsize' — method qualname includes class prefix."
    - "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' — method qualname includes class prefix."
    - "asyncio.Lock.release.__qualname__ == 'Lock.release' — method qualname includes class prefix."
    - "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — method qualname includes class prefix."
    - "asyncio.Semaphore.release.__qualname__ == 'Semaphore.release' — method qualname includes class prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for asyncio sync primitives
#
# asyncio_extra9 covers CancelledError/TimeoutError/InvalidStateError/__bases__[0]
# and event loop / queue variant bases.
# asyncio_extra8 covers Task/Future/QueueEmpty/QueueFull __bases__[0].__name__.
# No prior spec checks __bases__[0].__name__ for Lock, Semaphore, Event,
# BoundedSemaphore, Condition, or Queue. All are pure-Python classes in
# asyncio/locks.py and asyncio/queues.py.
# ---------------------------------------------------------------------------

invariant asyncio_extra11.Lock.base_name:
  description: "asyncio.Lock.__bases__[0].__name__ == 'object' — Lock is a root Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: Lock.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra11.Semaphore.base_name:
  description: "asyncio.Semaphore.__bases__[0].__name__ == 'object' — Semaphore is a root Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: Semaphore.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra11.Event.base_name:
  description: "asyncio.Event.__bases__[0].__name__ == 'object' — Event is a root Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: Event.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra11.BoundedSemaphore.base_name:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundedSemaphore.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Semaphore"

invariant asyncio_extra11.Condition.base_name:
  description: "asyncio.Condition.__bases__[0].__name__ == 'object' — Condition is a root Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: Condition.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra11.Queue.base_name:
  description: "asyncio.Queue.__bases__[0].__name__ == 'object' — Queue is a root Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: Queue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Queue method __qualname__ checks
#
# asyncio_extra10 covers class-level __qualname__ for Queue, but no prior spec
# checks method-level __qualname__ for Queue's interface methods. The __qualname__
# of an unbound method is 'ClassName.method_name'.
# ---------------------------------------------------------------------------

table asyncio_extra11.Queue_method_qualnames:
  description: "asyncio.Queue methods have __qualname__ == 'Queue.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qmq

  columns: [id, function, args, expected]
  rows:
    - [put_nowait, Queue.put_nowait.__qualname__.__eq__, ["Queue.put_nowait"], true]
    - [get_nowait, Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true]
    - [empty,      Queue.empty.__qualname__.__eq__,      ["Queue.empty"],      true]
    - [full,       Queue.full.__qualname__.__eq__,       ["Queue.full"],       true]
    - [qsize,      Queue.qsize.__qualname__.__eq__,      ["Queue.qsize"],      true]

# ---------------------------------------------------------------------------
# Lock method __qualname__ checks
#
# No prior asyncio spec checks method-level __qualname__ for Lock.acquire
# or Lock.release.
# ---------------------------------------------------------------------------

invariant asyncio_extra11.Lock_acquire.qualname:
  description: "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire'"
  category: method_qualnames
  kind: python_call_eq
  function: Lock.acquire.__qualname__.__eq__
  args: ["Lock.acquire"]
  expected: true

invariant asyncio_extra11.Lock_release.qualname:
  description: "asyncio.Lock.release.__qualname__ == 'Lock.release'"
  category: method_qualnames
  kind: python_call_eq
  function: Lock.release.__qualname__.__eq__
  args: ["Lock.release"]
  expected: true

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ checks
#
# No prior asyncio spec checks method-level __qualname__ for Semaphore.acquire
# or Semaphore.release.
# ---------------------------------------------------------------------------

invariant asyncio_extra11.Semaphore_acquire.qualname:
  description: "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'"
  category: method_qualnames
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant asyncio_extra11.Semaphore_release.qualname:
  description: "asyncio.Semaphore.release.__qualname__ == 'Semaphore.release'"
  category: method_qualnames
  kind: python_call_eq
  function: Semaphore.release.__qualname__.__eq__
  args: ["Semaphore.release"]
  expected: true
