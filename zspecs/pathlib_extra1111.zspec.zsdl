spec: pathlib_extra1111
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module Path read/write method qualnames, PurePath property fget qualnames, and Path __new__/__init__ qualname documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Path read_text/read_bytes/write_text/write_bytes/resolve/expanduser qualnames, PurePath property fget qualnames (parent/name/suffix/stem/parts), and Path/PurePath __new__/__init__ qualnames; none covered in _extra1081 or _extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1111.path_io_method_qualnames:
  description: "pathlib.Path read/write and resolution method __qualname__ checks"
  kind: python_call_eq
  category: path_io_method_qualnames
  id_prefix: pl1111io
  columns: [id, function, args, expected]
  rows:
    - [pl1111io001, pathlib.Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true]
    - [pl1111io002, pathlib.Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true]
    - [pl1111io003, pathlib.Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true]
    - [pl1111io004, pathlib.Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true]
    - [pl1111io005, pathlib.Path.resolve.__qualname__.__eq__,     ["Path.resolve"],     true]
    - [pl1111io006, pathlib.Path.expanduser.__qualname__.__eq__,  ["Path.expanduser"],  true]
    - [pl1111io007, pathlib.Path.open.__qualname__.__eq__,        ["Path.open"],        true]
    - [pl1111io008, pathlib.Path.stat.__qualname__.__eq__,        ["Path.stat"],        true]
    - [pl1111io009, pathlib.Path.open.__module__.__eq__,          ["pathlib"],          true]
    - [pl1111io010, pathlib.Path.stat.__module__.__eq__,          ["pathlib"],          true]
    - [pl1111io011, pathlib.Path.open.__class__.__name__.__eq__,  ["function"],         true]

table pathlib_extra1111.purepath_property_fget_qualnames:
  description: "pathlib.PurePath property fget __qualname__ checks for parent, name, suffix, stem, parts"
  kind: python_call_eq
  category: purepath_property_fget_qualnames
  id_prefix: pl1111pr
  columns: [id, function, args, expected]
  rows:
    - [pl1111pr001, pathlib.PurePath.parent.fget.__qualname__.__eq__, ["PurePath.parent"], true]
    - [pl1111pr002, pathlib.PurePath.name.fget.__qualname__.__eq__,   ["PurePath.name"],   true]
    - [pl1111pr003, pathlib.PurePath.suffix.fget.__qualname__.__eq__, ["PurePath.suffix"], true]
    - [pl1111pr004, pathlib.PurePath.stem.fget.__qualname__.__eq__,   ["PurePath.stem"],   true]
    - [pl1111pr005, pathlib.PurePath.parts.fget.__qualname__.__eq__,  ["PurePath.parts"],  true]
    - [pl1111pr006, pathlib.PurePath.parent.fget.__class__.__name__.__eq__, ["function"],  true]
    - [pl1111pr007, pathlib.PurePath.name.fget.__module__.__eq__,     ["pathlib"],         true]
    - [pl1111pr008, pathlib.PurePath.with_name.__qualname__.__eq__,   ["PurePath.with_name"],   true]
    - [pl1111pr009, pathlib.PurePath.with_stem.__qualname__.__eq__,   ["PurePath.with_stem"],   true]
    - [pl1111pr010, pathlib.PurePath.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"], true]
    - [pl1111pr011, pathlib.PurePath.joinpath.__qualname__.__eq__,    ["PurePath.joinpath"],    true]

table pathlib_extra1111.path_construction_qualnames:
  description: "pathlib.Path and PurePath __new__ and __init__ __qualname__ checks"
  kind: python_call_eq
  category: path_construction_qualnames
  id_prefix: pl1111cn
  columns: [id, function, args, expected]
  rows:
    - [pl1111cn001, pathlib.PurePath.__new__.__qualname__.__eq__, ["PurePath.__new__"],   true]
    - [pl1111cn002, pathlib.Path.__new__.__qualname__.__eq__,     ["Path.__new__"],       true]
    - [pl1111cn003, pathlib.Path.__init__.__qualname__.__eq__,    ["PurePath.__init__"],  true]
    - [pl1111cn004, pathlib.PurePath.__init__.__qualname__.__eq__, ["PurePath.__init__"], true]
    - [pl1111cn005, pathlib.Path.__new__.__class__.__name__.__eq__, ["function"],         true]
    - [pl1111cn006, pathlib.__name__.__eq__,              ["pathlib"],            true]
    - [pl1111cn007, pathlib.__spec__.name.__eq__,         ["pathlib"],            true]
    - [pl1111cn008, pathlib.Path.symlink_to.__qualname__.__eq__,  ["Path.symlink_to"],    true]
    - [pl1111cn009, pathlib.Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"],   true]
