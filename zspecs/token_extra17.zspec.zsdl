spec: token_extra17
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra16.zspec.zsdl — covers token.__name__.__len__()==5; token.__package__.__len__()==0; tok_name.__len__()==71; NAME/NUMBER/ENDMARKER __class__.__module__.__len__()==8; NAME=1/NUMBER=2/STRING=3/OP=55/ERRORTOKEN=67/COMMENT=65 values."
    - "token_extra15.zspec.zsdl — covers tok_name/__class__.__module__=='builtins'; NAME/NUMBER/__class__.__module__=='builtins'; tok_name.__len__()==71 standalone; tok_name[1/2/3] values; ENDMARKER class_is_int/value_is_0; NEWLINE/INDENT/DEDENT values."
    - "token_extra12.zspec.zsdl — covers ENCODING/NL/ERRORTOKEN/INDENT/DEDENT __class__.__name__=='int' standalone; COMMENT/INDENT/DEDENT exact values."
    - "token_extra11.zspec.zsdl — covers tok_name.__len__()==71; EXACT_TOKEN_TYPES.__len__()==48; exact values for ENDMARKER/NAME/NUMBER/STRING/NEWLINE/OP (table)."
  notes:
    - "This spec extends token_extra16.zspec.zsdl."
    - "Prior specs covered: token.__name__/__package__, various token constant class names and values, tok_name type/length/values, ENDMARKER/NEWLINE/INDENT/DEDENT/COMMENT/OP/ERRORTOKEN/ENCODING values, __class__.__module__.__len__() for NAME/NUMBER/ENDMARKER."
    - "This spec covers: tok_name[k].__len__() for keys 4–6 (NEWLINE/INDENT/DEDENT); NL/NEWLINE/ENCODING/INDENT/DEDENT exact values in token_extra17 namespace; tok_name.__class__.__name__.__len__(); tok_name.__class__.__module__.__len__(); STRING/OP/COMMENT __class__.__module__.__len__() (extending the builtins coverage to three more constants)."
    - "token.tok_name[4] == 'NEWLINE', len=7. Verified."
    - "token.tok_name[5] == 'INDENT', len=6. Verified."
    - "token.tok_name[6] == 'DEDENT', len=6. Verified."
    - "token.NL == 66. Verified."
    - "token.NEWLINE == 4. Verified."
    - "token.ENCODING == 68. Verified."
    - "token.INDENT == 5. Verified."
    - "token.DEDENT == 6. Verified."
    - "token.tok_name.__class__.__name__ == 'dict', len=4. Verified."
    - "token.tok_name.__class__.__module__ == 'builtins', len=8. Verified."
    - "token.STRING.__class__.__module__.__len__() == 8. Verified."
    - "token.OP.__class__.__module__.__len__() == 8. Verified."
    - "token.COMMENT.__class__.__module__.__len__() == 8. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: tok_name[k].__len__() for keys 4, 5, 6 (NEWLINE, INDENT, DEDENT)
#
# token_extra15 covers tok_name[1/2/3] values. No prior token spec covers
# tok_name[k].__len__() for keys 4–6.
# Verified: tok_name[4]='NEWLINE' (7), tok_name[5]='INDENT' (6),
# tok_name[6]='DEDENT' (6).
# ---------------------------------------------------------------------------

table token_extra17.tok_name_value_lengths:
  description: "tok_name[k].__len__() for NEWLINE/INDENT/DEDENT keys — lengths 7/6/6"
  kind: python_call_eq
  category: string_lengths
  id_prefix: tnvlen17

  columns: [id, function, args, expected]
  rows:
    - [key4_NEWLINE, "tok_name[4].__len__", [], 7]
    - [key5_INDENT,  "tok_name[5].__len__", [], 6]
    - [key6_DEDENT,  "tok_name[6].__len__", [], 6]

# ---------------------------------------------------------------------------
# Table: NL/NEWLINE/ENCODING/INDENT/DEDENT exact values
#
# token_extra15 covers NEWLINE/INDENT/DEDENT values. token_extra16 covers these
# in the extra16 namespace for INDENT/DEDENT only via token_extra12 cross-ref.
# These are distinct standalone checks in the token_extra17 namespace for all
# five constants together.
# Verified: NL=66, NEWLINE=4, ENCODING=68, INDENT=5, DEDENT=6.
# ---------------------------------------------------------------------------

table token_extra17.token_constant_values:
  description: "Exact integer values for NL, NEWLINE, ENCODING, INDENT, DEDENT"
  kind: python_call_eq
  category: constant_values
  id_prefix: tokval17

  columns: [id, function, args, expected]
  rows:
    - [NL,       NL.__eq__,       [66], true]
    - [NEWLINE,  NEWLINE.__eq__,  [4],  true]
    - [ENCODING, ENCODING.__eq__, [68], true]
    - [INDENT,   INDENT.__eq__,   [5],  true]
    - [DEDENT,   DEDENT.__eq__,   [6],  true]

# ---------------------------------------------------------------------------
# Standalone: tok_name.__class__.__name__.__len__() == 4
#
# token_extra13 covers tok_name/__class__.__name__=='dict' as a standalone __eq__.
# No prior token spec covers __class__.__name__.__len__() for tok_name.
# 'dict' has 4 characters. Verified.
# ---------------------------------------------------------------------------

invariant token_extra17.tok_name.class_name_len:
  description: "token.tok_name.__class__.__name__.__len__() == 4 — class name 'dict' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: tok_name.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: tok_name.__class__.__module__.__len__() == 8
#
# token_extra15 covers tok_name/__class__.__module__=='builtins' as a standalone
# __eq__. No prior token spec covers __class__.__module__.__len__() for tok_name.
# 'builtins' has 8 characters. Verified.
# ---------------------------------------------------------------------------

invariant token_extra17.tok_name.class_module_len:
  description: "token.tok_name.__class__.__module__.__len__() == 8 — module name 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: tok_name.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Standalone: STRING/OP/COMMENT __class__.__module__.__len__() == 8
#
# token_extra16 covers NAME/NUMBER/ENDMARKER __class__.__module__.__len__()==8.
# No prior token spec covers __class__.__module__.__len__() for STRING, OP,
# or COMMENT. All integer token constants are int (builtins), so length is 8.
# Verified: STRING=8, OP=8, COMMENT=8.
# ---------------------------------------------------------------------------

invariant token_extra17.STRING.class_module_len:
  description: "token.STRING.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: STRING.__class__.__module__.__len__
  args: []
  expected: 8

invariant token_extra17.OP.class_module_len:
  description: "token.OP.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: OP.__class__.__module__.__len__
  args: []
  expected: 8

invariant token_extra17.COMMENT.class_module_len:
  description: "token.COMMENT.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: COMMENT.__class__.__module__.__len__
  args: []
  expected: 8
