spec: fractions_extra9
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra8)."
    - "fractions.zspec: class name, constructor, numerator/denominator, arithmetic, comparison, limit_denominator, error cases."
    - "fractions_extra: Fraction.__name__, Fraction.__module__, Fraction.__bases__[0].__name__=='Rational', Fraction(1,2) and Fraction(3,6) numerator/denominator, Fraction(1,2).__add__(Fraction(1,2)) via Fraction(1,1)."
    - "fractions_extra2: Fraction.__module__, MRO, repr, limit_denominator alt vectors, subtraction, __add__.__name__."
    - "fractions_extra3: __qualname__, __module__, bases, Fraction(1,3), Fraction(2,4), Fraction('3/5')."
    - "fractions_extra4: __name__/__module__/__qualname__, various numerator/denominator."
    - "fractions_extra5-8: __bases__.__len__, MRO, __float__, __floor__, __round__, __bool__, __pow__, __trunc__, __mod__, as_integer_ratio, class_metadata table."
    - "New axes: Fraction.limit_denominator.__name__ == 'limit_denominator'; Fraction(1,2).__add__(1) numerator and denominator; Fraction(1,3).__mul__(3) as string; Fraction(2,3).__mul__(3) as string."
    - "fractions.Fraction.limit_denominator.__name__ == 'limit_denominator' — method name identity, not yet covered."
    - "fractions.Fraction(1, 2).__add__(1) == Fraction(3, 2); numerator == 3, denominator == 2 — new integer-arg add vector."
    - "fractions.Fraction(1, 3).__mul__(3) == Fraction(1, 1) which stringifies as '1' — product of 1/3 and integer 3."
    - "fractions.Fraction(2, 3).__mul__(3) == Fraction(2, 1) which stringifies as '2' — product of 2/3 and integer 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.limit_denominator.__name__ — method identity
#
# fractions_extra2 covers Fraction.__add__.__name__ == '__add__'.
# No prior spec checks limit_denominator.__name__ as a method identity invariant.
# ---------------------------------------------------------------------------

invariant fractions_extra9.Fraction.limit_denominator_name:
  description: "fractions.Fraction.limit_denominator.__name__ == 'limit_denominator' — method name identity"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__name__.__eq__
  args: ["limit_denominator"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(1, 2).__add__(1) — integer-operand addition
#
# fractions.zspec covers Fraction(1, 4).__add__(1) == Fraction(5, 4).
# fractions_extra covers Fraction(1, 2).__add__(Fraction(1,2)) via Fraction(1,1).
# No prior spec checks Fraction(1, 2).__add__(1).numerator or .denominator directly.
# Fraction(1, 2) + 1 == Fraction(3, 2); numerator == 3, denominator == 2.
# ---------------------------------------------------------------------------

invariant fractions_extra9.Fraction.half_add_int_numerator:
  description: "fractions.Fraction(1, 2).__add__(1).numerator == 3 — 1/2 + 1 == 3/2"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __add__
  method_args: [1]
  expected: 3

invariant fractions_extra9.Fraction.half_add_int_denominator:
  description: "fractions.Fraction(1, 2).__add__(1).denominator == 2 — 1/2 + 1 == 3/2"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __add__
  method_args: [1]
  expected: 2

# ---------------------------------------------------------------------------
# Fraction(1, 3).__mul__(3) and Fraction(2, 3).__mul__(3) — integer-operand multiplication
#
# fractions.zspec covers Fraction(3, 4).__mul__(4) == 3 (integer result).
# No prior spec checks Fraction(1, 3).__mul__(3) or Fraction(2, 3).__mul__(3)
# via __str__ in the fractions_extra9 namespace.
# Fraction(1, 3) * 3 == Fraction(1, 1); __str__ == '1'.
# Fraction(2, 3) * 3 == Fraction(2, 1); __str__ == '2'.
# ---------------------------------------------------------------------------

invariant fractions_extra9.Fraction.third_mul_three_str:
  description: "fractions.Fraction(1, 3).__mul__(3).__str__() == '1' — 1/3 * 3 reduces to 1"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: __mul__
  method_args: [3]
  expected: 1

invariant fractions_extra9.Fraction.two_thirds_mul_three_str:
  description: "fractions.Fraction(2, 3).__mul__(3).__str__() == '2' — 2/3 * 3 reduces to 2"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [2, 3]
  method: __mul__
  method_args: [3]
  expected: 2
