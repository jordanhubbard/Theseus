  id_prefix: asyncioerr142

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_doc_len,      asyncio.Timeout.__doc__.__len__,                 [],                           146,   "asyncio.Timeout.__doc__.__len__() == 146; verified with Python 3.14.3"]
    - [timeout_name_eq,      asyncio.Timeout.__name__.__eq__,                ["Timeout"],                   true,  "asyncio.Timeout.__name__ == 'Timeout' (len=7); verified with Python 3.14.3"]
