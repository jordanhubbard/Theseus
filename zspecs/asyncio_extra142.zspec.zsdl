invariant asyncio_extra142.abstract_event_loop_doc_len_20:
  description: "asyncio.AbstractEventLoop.__doc__.__len__() == 20 — asyncio.AbstractEventLoop.__doc__ is 'Abstract event loop.' (20 chars: a terse one-sentence description); __name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17, the longest __name__ among classes in this spec); __module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); NEW in extra142: first standalone AbstractEventLoop doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__doc__.__len__
  args: []
  expected: 20

invariant asyncio_extra142.abstract_event_loop_name_len_17:
  description: "asyncio.AbstractEventLoop.__name__.__len__() == 17 — asyncio.AbstractEventLoop.__name__ is 'AbstractEventLoop' (17 chars: 'Abstract'=8+'Event'=5+'Loop'=4=17); __module__=='asyncio.events' (len=14); __doc__=='Abstract event loop.' (len=20); NEW in extra142: first standalone AbstractEventLoop name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
