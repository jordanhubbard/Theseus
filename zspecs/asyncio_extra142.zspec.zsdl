table asyncio_extra142.error_classes_doc:
  description: "asyncio.Timeout, CancelledError, TimeoutError __doc__ and identity checks — Timeout.__doc__.__len__()==146 (doc describes usage via timeout() or timeout_at() factory functions); Timeout.__name__.__eq__('Timeout')==True (len=7); Timeout.__module__.__eq__('asyncio.timeouts')==True (len=16); CancelledError.__doc__.__eq__('The Future or Task was cancelled.')==True (len=33); CancelledError.__name__.__eq__('CancelledError')==True (len=14); CancelledError.__module__.__eq__('asyncio.exceptions')==True (len=18); TimeoutError.__doc__.__eq__('Timeout expired.')==True (len=16); TimeoutError.__name__.__eq__('TimeoutError')==True (len=12); TimeoutError.__module__.__eq__('builtins')==True (len=8: re-exported from builtins); verified with Python 3.14.3"
  kind: python_call_eq
