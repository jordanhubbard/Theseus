    - [cancelled_mod_len,    asyncio.CancelledError.__module__.__len__,        [],                           18,    "asyncio.CancelledError.__module__.__len__() == 18 ('asyncio.exceptions'); verified with Python 3.14.3"]
    - [te_doc_eq,            asyncio.TimeoutError.__doc__.__eq__,            ["Timeout expired."],           true,  "asyncio.TimeoutError.__doc__ == 'Timeout expired.' (len=16); verified with Python 3.14.3"]
