spec: asyncio_extra142
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task and future documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "https://docs.python.org/3/library/asyncio-protocol.html — Python asyncio protocol documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/futures.py, Lib/asyncio/taskgroups.py, Lib/asyncio/timeouts.py, Lib/asyncio/exceptions.py, Lib/asyncio/events.py, Lib/asyncio/streams.py, Lib/asyncio/protocols.py"
  notes:
    - "This spec covers: asyncio.Task — __doc__.__len__()==32; __doc__=='A coroutine wrapped in a Future.'; __name__=='Task' (len=4); __module__=='_asyncio' (len=8). asyncio.Future — __doc__.__len__()==449; __name__=='Future' (len=6); __module__=='_asyncio' (len=8). asyncio.TaskGroup — __doc__.__len__()==529; __name__=='TaskGroup' (len=9); __module__=='asyncio.taskgroups' (len=18). asyncio.Timeout — __doc__.__len__()==146; __name__=='Timeout' (len=7); __module__=='asyncio.timeouts' (len=16). asyncio.CancelledError — __doc__.__len__()==33; __doc__=='The Future or Task was cancelled.'; __name__=='CancelledError' (len=14); __module__=='asyncio.exceptions' (len=18). asyncio.TimeoutError — __doc__.__len__()==16; __doc__=='Timeout expired.'; __name__=='TimeoutError' (len=12); __module__=='builtins' (len=8). asyncio.AbstractEventLoop — __doc__.__len__()==20; __doc__=='Abstract event loop.'; __name__=='AbstractEventLoop' (len=17); __module__=='asyncio.events' (len=14). asyncio.StreamWriter — __doc__.__len__()==271; __name__=='StreamWriter' (len=12); __module__=='asyncio.streams' (len=15). asyncio.Protocol — __doc__.__len__()==810; __name__=='Protocol' (len=8); __module__=='asyncio.protocols' (len=17). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.__module__=='_asyncio' and asyncio.Future.__module__=='_asyncio' (both len=8) because Task and Future are implemented in the C extension module _asyncio; the leading underscore is conventional for C-level implementation modules. asyncio.TaskGroup.__module__=='asyncio.taskgroups' (len=18); asyncio.Timeout.__module__=='asyncio.timeouts' (len=16); asyncio.CancelledError.__module__=='asyncio.exceptions' (len=18); asyncio.TimeoutError.__module__=='builtins' (len=8) because TimeoutError is a built-in Python exception that asyncio re-exports. asyncio.AbstractEventLoop.__doc__=='Abstract event loop.' (len=20: 'Abstract event loop.'=20). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task __doc__ and identity — extra142
#
# asyncio.Task.__doc__     == 'A coroutine wrapped in a Future.' (len=32)
# asyncio.Task.__name__    == 'Task'     (len=4)
# asyncio.Task.__module__  == '_asyncio' (len=8)
# ---------------------------------------------------------------------------

table asyncio_extra142.task_doc:
  description: "asyncio.Task __doc__ and identity checks — Task.__doc__.__eq__('A coroutine wrapped in a Future.')==True (len=32: complete single-sentence description of asyncio.Task); Task.__doc__.__len__()==32; Task.__name__.__eq__('Task')==True (len=4); Task.__module__.__eq__('_asyncio')==True (len=8: the C extension module, leading underscore is conventional for C-level implementations); Task.__qualname__.__eq__('Task')==True (len=4: no nesting, top-level class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask142

  columns: [id, function, args, expected, description]
  rows:
    - [doc_eq,      asyncio.Task.__doc__.__eq__,       ["A coroutine wrapped in a Future."],  true,  "asyncio.Task.__doc__ == 'A coroutine wrapped in a Future.' (len=32); verified with Python 3.14.3"]
    - [doc_len,     asyncio.Task.__doc__.__len__,       [],                                   32,    "asyncio.Task.__doc__.__len__() == 32; verified with Python 3.14.3"]
    - [name_eq,     asyncio.Task.__name__.__eq__,      ["Task"],                              true,  "asyncio.Task.__name__ == 'Task' (len=4); verified with Python 3.14.3"]
    - [name_len,    asyncio.Task.__name__.__len__,      [],                                   4,     "asyncio.Task.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [mod_eq,      asyncio.Task.__module__.__eq__,    ["_asyncio"],                          true,  "asyncio.Task.__module__ == '_asyncio' (len=8); verified with Python 3.14.3"]
    - [mod_len,     asyncio.Task.__module__.__len__,    [],                                   8,     "asyncio.Task.__module__.__len__() == 8; verified with Python 3.14.3"]

