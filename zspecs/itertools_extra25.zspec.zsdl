spec: itertools_extra25
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra24.zspec.zsdl."
    - "itertools_extra24 covers: dropwhile/takewhile/filterfalse/accumulate class qualnames; pairwise qualname (Python >= 3.10)."
    - "itertools_extra23 covers: chain.from_iterable/count.__next__/count.__iter__/product.__next__ method qualnames; combinations/permutations/combinations_with_replacement class qualnames."
    - "itertools_extra22 covers: __qualname__.__eq__ for chain/islice/starmap/groupby/count/cycle/repeat/product."
    - "No prior itertools spec records __module__ for chain/islice/starmap/zip_longest/product together in the extra25 namespace."
    - "Focus: __module__ attributes for the core itertools C-level types; these confirm the public 'itertools' module name, not any internal C module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ table — core itertools class module membership
#
# chain, islice, starmap, takewhile, and dropwhile are C-level types defined
# in Modules/itertoolsmodule.c. Their __module__ attribute is 'itertools',
# the public module name, not a private C extension module.
# No prior itertools spec records all five __module__ values together in
# the extra25 namespace.
# ---------------------------------------------------------------------------

table itertools_extra25.core_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra25.core_modules.chain,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__ == 'itertools'"]
    - [itertools_extra25.core_modules.islice,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__ == 'itertools'"]
    - [itertools_extra25.core_modules.starmap,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__ == 'itertools'"]
    - [itertools_extra25.core_modules.takewhile,
       takewhile.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.takewhile.__module__ == 'itertools'"]
    - [itertools_extra25.core_modules.dropwhile,
       dropwhile.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.dropwhile.__module__ == 'itertools'"]

# ---------------------------------------------------------------------------
# __module__.__eq__ table — sequence itertools class module membership
#
# zip_longest, product, groupby, cycle, and repeat are C-level types.
# Their __module__ is 'itertools', confirming public module attribution.
# No prior itertools spec records all five of these __module__ values together
# in the extra25 namespace.
# ---------------------------------------------------------------------------

table itertools_extra25.sequence_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra25.sequence_modules.zip_longest,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__ == 'itertools'"]
    - [itertools_extra25.sequence_modules.product,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__ == 'itertools'"]
    - [itertools_extra25.sequence_modules.groupby,
       groupby.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.groupby.__module__ == 'itertools'"]
    - [itertools_extra25.sequence_modules.cycle,
       cycle.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.cycle.__module__ == 'itertools'"]
    - [itertools_extra25.sequence_modules.repeat,
       repeat.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.repeat.__module__ == 'itertools'"]

# ---------------------------------------------------------------------------
# chain.from_iterable.__qualname__.__eq__ — classmethod qualname
#
# itertools.chain.from_iterable is a C-level classmethod on the chain type.
# Its qualname is 'chain.from_iterable', reflecting the enclosing type name.
# itertools_extra23 covers this in the extra23 namespace; this invariant
# records the same fact in the extra25 namespace for cross-namespace coverage.
# No prior itertools spec records this standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra25.chain.from_iterable.qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'"
  category: qualnames
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

# ---------------------------------------------------------------------------
# chain.__module__.__eq__ — standalone module membership
#
# itertools.chain is a C-level type. Its __module__ is 'itertools', the
# public module name. This confirms the type is attributed to the public
# itertools namespace.
# No prior itertools spec records this standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra25.chain.module:
  description: "itertools.chain.__module__ == 'itertools'"
  category: module_membership
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

# ---------------------------------------------------------------------------
# islice.__module__.__eq__ — standalone module membership
#
# itertools.islice is a C-level type that slices an iterator without
# materializing it into a list. Its __module__ is 'itertools'.
# No prior itertools spec records this standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra25.islice.module:
  description: "itertools.islice.__module__ == 'itertools'"
  category: module_membership
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true

# ---------------------------------------------------------------------------
# zip_longest.__module__.__eq__ — standalone module membership
#
# itertools.zip_longest zips iterables filling shorter ones with a fillvalue.
# Its __module__ is 'itertools'. No prior itertools spec records this
# standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra25.zip_longest.module:
  description: "itertools.zip_longest.__module__ == 'itertools'"
  category: module_membership
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true
