table hashlib_extra228.dict_membership_sha3_xof:
  description: "hashlib module __dict__ membership checks for SHA-3 family and XOFs in hashlib228a namespace — wave 228 theme: sha3_256, sha3_512, sha3_224, sha3_384, shake_128, shake_256 are all top-level names exported by hashlib; SHA-3 and XOF variants defined in FIPS 202; confirmed present in hashlib.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib228a

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_sha3_256,  hashlib.__dict__.__contains__, ["sha3_256"],  true, "hashlib.__dict__.__contains__('sha3_256') == True — sha3_256 is exported as a top-level name in hashlib.__dict__; SHA-3 256-bit variant; verified with Python 3.14.3"]
    - [dict_has_sha3_512,  hashlib.__dict__.__contains__, ["sha3_512"],  true, "hashlib.__dict__.__contains__('sha3_512') == True — sha3_512 is exported as a top-level name in hashlib.__dict__; SHA-3 512-bit variant; verified with Python 3.14.3"]
    - [dict_has_sha3_224,  hashlib.__dict__.__contains__, ["sha3_224"],  true, "hashlib.__dict__.__contains__('sha3_224') == True — sha3_224 is exported as a top-level name in hashlib.__dict__; SHA-3 224-bit variant; verified with Python 3.14.3"]
    - [dict_has_sha3_384,  hashlib.__dict__.__contains__, ["sha3_384"],  true, "hashlib.__dict__.__contains__('sha3_384') == True — sha3_384 is exported as a top-level name in hashlib.__dict__; SHA-3 384-bit variant; verified with Python 3.14.3"]
    - [dict_has_shake_128, hashlib.__dict__.__contains__, ["shake_128"], true, "hashlib.__dict__.__contains__('shake_128') == True — shake_128 is exported as a top-level name in hashlib.__dict__; XOF (extendable output function) 128-bit variant; verified with Python 3.14.3"]
    - [dict_has_shake_256, hashlib.__dict__.__contains__, ["shake_256"], true, "hashlib.__dict__.__contains__('shake_256') == True — shake_256 is exported as a top-level name in hashlib.__dict__; XOF (extendable output function) 256-bit variant; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib module __dict__ membership checks — utility names
#
# hashlib.__dict__.__contains__('new')                   == True
# hashlib.__dict__.__contains__('algorithms_guaranteed') == True
