spec: hashlib_extra228
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('md5') == True — md5 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha1') == True — sha1 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha256') == True — sha256 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha512') == True — sha512 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha224') == True — sha224 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha384') == True — sha384 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha3_256') == True — sha3_256 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha3_512') == True — sha3_512 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha3_224') == True — sha3_224 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('sha3_384') == True — sha3_384 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('shake_128') == True — shake_128 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('shake_256') == True — shake_256 is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('new') == True — new is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('algorithms_guaranteed') == True — algorithms_guaranteed is a top-level name in hashlib.__dict__."
    - "hashlib.__dict__.__contains__('algorithms_available') == True — algorithms_available is a top-level name in hashlib.__dict__."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module __dict__ membership checks — SHA-1/SHA-2 family
#
# hashlib.__dict__.__contains__('md5')    == True
# hashlib.__dict__.__contains__('sha1')   == True
# hashlib.__dict__.__contains__('sha256') == True
# hashlib.__dict__.__contains__('sha512') == True
# hashlib.__dict__.__contains__('sha224') == True
# hashlib.__dict__.__contains__('sha384') == True
# ---------------------------------------------------------------------------

table hashlib_extra228.dict_membership_sha12:
  description: "hashlib module __dict__ membership checks for SHA-1/SHA-2 family in hashlib228 namespace — wave 228 theme: md5, sha1, sha256, sha512, sha224, sha384 are all top-level names exported by hashlib; confirmed present in hashlib.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib228

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_md5,    hashlib.__dict__.__contains__, ["md5"],    true, "hashlib.__dict__.__contains__('md5') == True — md5 is exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]
    - [dict_has_sha1,   hashlib.__dict__.__contains__, ["sha1"],   true, "hashlib.__dict__.__contains__('sha1') == True — sha1 is exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]
    - [dict_has_sha256, hashlib.__dict__.__contains__, ["sha256"], true, "hashlib.__dict__.__contains__('sha256') == True — sha256 is exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]
    - [dict_has_sha512, hashlib.__dict__.__contains__, ["sha512"], true, "hashlib.__dict__.__contains__('sha512') == True — sha512 is exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]
    - [dict_has_sha224, hashlib.__dict__.__contains__, ["sha224"], true, "hashlib.__dict__.__contains__('sha224') == True — sha224 is exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]
    - [dict_has_sha384, hashlib.__dict__.__contains__, ["sha384"], true, "hashlib.__dict__.__contains__('sha384') == True — sha384 is exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]

