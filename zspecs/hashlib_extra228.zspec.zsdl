# ---------------------------------------------------------------------------

table hashlib_extra228.dict_membership_utilities:
  description: "hashlib module __dict__ membership checks for utility names in hashlib228b namespace — wave 228 theme: new, algorithms_guaranteed, algorithms_available are top-level names exported by hashlib; new() is the generic constructor; algorithms_guaranteed and algorithms_available are sets of supported algorithm names; confirmed present in hashlib.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib228b

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_new,                    hashlib.__dict__.__contains__, ["new"],                    true, "hashlib.__dict__.__contains__('new') == True — new is the generic hash constructor exported as a top-level name in hashlib.__dict__; verified with Python 3.14.3"]
    - [dict_has_algorithms_guaranteed,  hashlib.__dict__.__contains__, ["algorithms_guaranteed"],  true, "hashlib.__dict__.__contains__('algorithms_guaranteed') == True — algorithms_guaranteed is a frozenset of hash names guaranteed on all platforms; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_algorithms_available,   hashlib.__dict__.__contains__, ["algorithms_available"],   true, "hashlib.__dict__.__contains__('algorithms_available') == True — algorithms_available is a set of hash names available on the current platform; exported as top-level name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants for hashlib __dict__ membership checks
# ---------------------------------------------------------------------------

invariant hashlib_extra228.dict_contains_md5:
  description: "hashlib.__dict__.__contains__('md5') == True — md5 is exported as a top-level callable in the hashlib module; 'md5' appears as a key in hashlib.__dict__; MD5 produces a 128-bit digest; despite being cryptographically broken for security purposes, it remains available for legacy compatibility; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: hashlib.__dict__.__contains__
  args: ["md5"]
  expected: true

invariant hashlib_extra228.dict_contains_sha256:
  description: "hashlib.__dict__.__contains__('sha256') == True — sha256 is exported as a top-level callable in the hashlib module; 'sha256' appears as a key in hashlib.__dict__; SHA-256 is a widely used cryptographic hash producing a 256-bit digest; it is part of algorithms_guaranteed on all Python platforms; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: hashlib.__dict__.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra228.dict_contains_algorithms_guaranteed:
  description: "hashlib.__dict__.__contains__('algorithms_guaranteed') == True — algorithms_guaranteed is a frozenset of hash algorithm names guaranteed to be supported on all Python platforms; 'algorithms_guaranteed' appears as a key in hashlib.__dict__; includes at minimum md5, sha1, sha224, sha256, sha384, sha512; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: hashlib.__dict__.__contains__
  args: ["algorithms_guaranteed"]
  expected: true
