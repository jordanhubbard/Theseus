spec: multiprocessing_extra1771
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "Wave 565, suffix _extra1771. Theme: async protocol — which stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "multiprocessing is a synchronous library; none of its types define any async protocol methods."
    - "multiprocessing.Queue is a factory function (not a class); it does not define __aenter__ or any async protocol methods."
    - "multiprocessing.Lock is a factory function; the underlying lock type uses sync __enter__/__exit__ only."
    - "multiprocessing.Process is a genuine class with __module__ == 'multiprocessing.process'; it has no async protocol methods."
    - "multiprocessing.Pool is a class; it uses sync __enter__/__exit__ for use as a sync context manager."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: async protocol methods absent from multiprocessing types
#
# All multiprocessing types are synchronous; none define __aenter__,
# __aexit__, __aiter__, __anext__, or __await__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1771.async_protocol_absent:
  kind: python_call_eq
  category: async_protocol
  id_prefix: mp1771

  columns: [id, function, args, expected]
  rows:
    - ["mp1771001", multiprocessing.Process.__dict__.__contains__,  ["__aenter__"], false]
    - ["mp1771002", multiprocessing.Process.__dict__.__contains__,  ["__aexit__"],  false]
    - ["mp1771003", multiprocessing.Process.__dict__.__contains__,  ["__await__"],  false]
    - ["mp1771004", multiprocessing.Process.__dict__.__contains__,  ["__aiter__"],  false]
    - ["mp1771005", multiprocessing.Process.__dict__.__contains__,  ["__anext__"],  false]
    - ["mp1771006", multiprocessing.Pool.__dict__.__contains__,     ["__aenter__"], false]
    - ["mp1771007", multiprocessing.Pool.__dict__.__contains__,     ["__aexit__"],  false]
    - ["mp1771008", multiprocessing.Pool.__dict__.__contains__,     ["__await__"],  false]
    - ["mp1771009", multiprocessing.Pool.__dict__.__contains__,     ["__aiter__"],  false]
    - ["mp1771010", multiprocessing.Pool.__dict__.__contains__,     ["__anext__"],  false]
    - ["mp1771011", multiprocessing.Queue.__dict__.__contains__,    ["__aenter__"], false]
    - ["mp1771012", multiprocessing.Queue.__dict__.__contains__,    ["__aexit__"],  false]
    - ["mp1771013", multiprocessing.Queue.__dict__.__contains__,    ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary sync-protocol and identity checks
#
# multiprocessing.Pool uses sync __enter__/__exit__ (sync context manager).
# multiprocessing.Process.__module__ == 'multiprocessing.process'.
# multiprocessing.Queue and Lock are factory functions.
# ---------------------------------------------------------------------------

table multiprocessing_extra1771.sync_identity_checks:
  kind: python_call_eq
  category: sync_protocol
  id_prefix: mp1771

  columns: [id, function, args, expected]
  rows:
    - ["mp1771014", multiprocessing.Pool.__dict__.__contains__,         ["__enter__"],            true]
    - ["mp1771015", multiprocessing.Pool.__dict__.__contains__,         ["__exit__"],             true]
    - ["mp1771016", multiprocessing.Process.__module__.__eq__,          ["multiprocessing.process"], true]
    - ["mp1771017", multiprocessing.Process.__name__.__eq__,            ["Process"],              true]
    - ["mp1771018", multiprocessing.Queue.__name__.__eq__,              ["Queue"],                true]
    - ["mp1771019", multiprocessing.Lock.__name__.__eq__,               ["Lock"],                 true]
    - ["mp1771020", multiprocessing.Pool.__name__.__eq__,               ["Pool"],                  true]
    - ["mp1771021", multiprocessing.Process.__class__.__name__.__eq__,  ["type"],                 true]
    - ["mp1771022", multiprocessing.Lock.__dict__.__contains__,         ["__aiter__"],            false]
    - ["mp1771023", multiprocessing.Lock.__dict__.__contains__,         ["__anext__"],            false]
