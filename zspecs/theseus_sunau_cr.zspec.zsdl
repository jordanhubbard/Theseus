spec: theseus_sunau_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sunau_cr)
blocks: sunau

docs: https://docs.python.org/3/library/sunau.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sunau.html"
  not_derived_from:
    - "CPython source: Lib/sunau.py"
  notes:
    - "Clean-room sunau module. Do NOT import sunau."

error_model: python_exceptions

invariant theseus_sunau_cr.sunau2_error:
  description: "Error class exists as exception"
  category: behavior
  kind: python_call_eq
  function: sunau2_error
  args: []
  expected: true

invariant theseus_sunau_cr.sunau2_open:
  description: "open() function exists"
  category: behavior
  kind: python_call_eq
  function: sunau2_open
  args: []
  expected: true

invariant theseus_sunau_cr.sunau2_constants:
  description: "AU_HEADER_SIZE and AUDIO_FILE_MAGIC constants exist"
  category: behavior
  kind: python_call_eq
  function: sunau2_constants
  args: []
  expected: true
