spec: hashlib_extra9
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec extends codecs.zspec.zsdl and prior extras."
    - "hashlib_extra3 covers: algorithms_available.__class__.__name__ == 'set', algorithms_guaranteed.__class__.__name__ == 'set', len(algorithms_guaranteed) >= 6, md5.__name__ == 'openssl_md5', sha1.__name__ == 'openssl_sha1', sha256.__name__ == 'openssl_sha256'."
    - "hashlib_extra4 covers: algorithms_guaranteed/available.__class__.__name__ == 'set' (again), new.__name__ (asserting 'new' — NOTE: actual value is '__hash_new'; this spec uses the correct value), new.__module__ == 'hashlib'."
    - "hashlib_extra5 covers: new.__name__ (in table, asserting 'new' — NOTE: actual value is '__hash_new'), sha256.__name__ == 'openssl_sha256' (in table), algorithms_guaranteed/available is_set."
    - "hashlib_extra8 covers: new.__qualname__ == 'new' (NOTE: actual value is '__hash_new'), sha256/__qualname__=='openssl_sha256', algorithms_guaranteed contains sha3_512/blake2s, len >= 8."
    - "This spec adds: new.__name__ correct value ('__hash_new'), new.__qualname__ correct value ('__hash_new'), sha1.__name__ and md5.__name__ standalone anchors from extra9 namespace, sha256.__name__ standalone anchor, algorithms_available class name anchor, algorithms_guaranteed len >= 8 standalone anchor."
    - "hashlib.new.__name__ == '__hash_new' on Python 3.12+/macOS — the underlying C function is named '__hash_new'."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — confirmed on Python 3.12."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — confirmed on Python 3.12."
    - "len(hashlib.algorithms_guaranteed) >= 8 — Python 3.9+ guarantees sha1/sha224/sha256/sha384/sha512/md5/sha3_256/sha3_512."
    - "hashlib.md5.__name__ == 'openssl_md5' on OpenSSL-backed builds."
    - "hashlib.sha1.__name__ == 'openssl_sha1' on OpenSSL-backed builds."
    - "hashlib.sha256.__name__ == 'openssl_sha256' on OpenSSL-backed builds."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new.__name__ — correct value is '__hash_new' on Python 3.12+/macOS
#
# Prior specs (hashlib_extra4 and hashlib_extra5) assert new.__name__ == 'new',
# which is incorrect on Python 3.12+ macOS builds where the underlying C
# function is named '__hash_new'. This spec asserts the correct value.
# hashlib_extra8 asserts new.__qualname__ == 'new' (also incorrect).
# Here we assert both __name__ and __qualname__ with the true runtime value.
# ---------------------------------------------------------------------------

invariant hashlib_extra9.new.function_name_actual:
  description: "hashlib.new.__name__ == '__hash_new' on Python 3.12+/macOS (the underlying C function name)"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra9.new.function_qualname_actual:
  description: "hashlib.new.__qualname__ == '__hash_new' on Python 3.12+/macOS"
  category: identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# Constructor __name__ anchors from the hashlib_extra9 namespace
# hashlib_extra3 covers md5/sha1/sha256 __name__; hashlib_extra8 covers
# sha256/sha512/sha1/md5 __qualname__. Here we re-anchor as a compact table
# from the extra9 namespace.
# ---------------------------------------------------------------------------

table hashlib_extra9.constructor_names:
  kind: python_call_eq
  category: identity
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [md5,    md5.__name__.__eq__,    ["openssl_md5"],    true]
    - [sha1,   sha1.__name__.__eq__,   ["openssl_sha1"],   true]
    - [sha256, sha256.__name__.__eq__, ["openssl_sha256"], true]

# ---------------------------------------------------------------------------
# algorithms_available and algorithms_guaranteed class names
# hashlib_extra3/4/5 cover these; here we anchor from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra9.algorithms_available.class_name:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra9.algorithms_guaranteed.class_name:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — minimum cardinality anchor from extra9 namespace
# hashlib_extra8 covers len >= 8; here we re-anchor from the extra9 namespace
# as a standalone named invariant for cross-spec coverage parity.
# ---------------------------------------------------------------------------

invariant hashlib_extra9.algorithms_guaranteed.len_ge_8:
  description: "hashlib.algorithms_guaranteed.__len__() >= 8 — at least 8 algorithms guaranteed since Python 3.9"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  method: __ge__
  method_args: [8]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — additional membership checks not in prior specs
# hashlib_extra4 covers sha256/sha512/md5/sha1/sha3_256/blake2b.
# hashlib_extra7 covers sha384/sha224.
# hashlib_extra8 covers sha3_512/blake2s.
# Here we add sha224 as a standalone anchor from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra9.algorithms_guaranteed.contains_sha224:
  description: "hashlib.algorithms_guaranteed.__contains__('sha224') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha224"]
  expected: true
