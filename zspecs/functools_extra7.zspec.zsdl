spec: functools_extra7
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl through functools_extra6.zspec.zsdl."
    - "Previous specs cover: __name__/__module__ for partial, reduce, lru_cache, cache, cached_property, total_ordering, singledispatch, cmp_to_key, update_wrapper, wraps, singledispatchmethod; __qualname__ for singledispatch, singledispatchmethod; partial.__bases__[0]/cached_property.__bases__[0] == 'object'; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES tuple class names and lengths; WRAPPER_ASSIGNMENTS.__contains__ for __name__/__qualname__/__module__/__doc__/__annotate__/__type_params__/__dict__."
    - "This spec adds: cached_property.__qualname__ (noted but not yet an invariant); TopologicalSorter (Python 3.9+) __name__/__module__/__qualname__/__bases__[0].__name__; table of class __qualname__ checks for cached_property/singledispatchmethod/TopologicalSorter; WRAPPER_UPDATES.__contains__('__dict__') is already in functools.zspec so we use WRAPPER_ASSIGNMENTS length value == 5 (verified Python 3.12)."
    - "functools.cached_property.__qualname__ == 'cached_property' — top-level class in functools."
    - "functools.TopologicalSorter.__name__ == 'TopologicalSorter' (Python 3.9+)."
    - "functools.TopologicalSorter.__module__ == 'functools'."
    - "functools.TopologicalSorter.__qualname__ == 'TopologicalSorter'."
    - "functools.TopologicalSorter.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 5 on Python 3.12 (tuple of 5 attribute names)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cached_property.__qualname__ — top-level class
#
# functools.cached_property is a top-level class; its __qualname__ equals
# its __name__. Prior specs (extra3 notes, extra4/extra5/extra6) covered
# __name__ and __module__ but no actual invariant for __qualname__ was written.
# ---------------------------------------------------------------------------

invariant functools_extra7.cached_property.qualname:
  description: "functools.cached_property.__qualname__ == 'cached_property'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

# ---------------------------------------------------------------------------
# TopologicalSorter — class identity (Python 3.9+)
#
# functools.TopologicalSorter is a class for dependency ordering introduced
# in Python 3.9. It is a top-level class with object as its sole base.
# ---------------------------------------------------------------------------

invariant functools_extra7.TopologicalSorter.name:
  description: "functools.TopologicalSorter.__name__ == 'TopologicalSorter' (Python 3.9+)"
  category: TopologicalSorter
  kind: python_call_eq
  function: TopologicalSorter.__name__.__eq__
  args: ["TopologicalSorter"]
  expected: true

invariant functools_extra7.TopologicalSorter.module:
  description: "functools.TopologicalSorter.__module__ == 'functools' (Python 3.9+)"
  category: TopologicalSorter
  kind: python_call_eq
  function: TopologicalSorter.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra7.TopologicalSorter.qualname:
  description: "functools.TopologicalSorter.__qualname__ == 'TopologicalSorter' (Python 3.9+)"
  category: TopologicalSorter
  kind: python_call_eq
  function: TopologicalSorter.__qualname__.__eq__
  args: ["TopologicalSorter"]
  expected: true

invariant functools_extra7.TopologicalSorter.base_is_object:
  description: "functools.TopologicalSorter.__bases__[0].__name__ == 'object' (Python 3.9+)"
  category: TopologicalSorter
  kind: python_call_eq
  function: TopologicalSorter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Table: __qualname__ checks for cached_property, singledispatchmethod,
# TopologicalSorter
#
# All three are top-level classes in the functools module, so __qualname__
# equals __name__ in each case. Prior specs covered __name__ and __module__
# but not __qualname__ for cached_property (it was only noted, not tested).
# singledispatchmethod.__qualname__ was covered in extra3; we include it here
# only for TopologicalSorter and cached_property; singledispatchmethod is
# included in the table to document the full set of new-style class checks.
# ---------------------------------------------------------------------------

table functools_extra7.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [cached_property,       cached_property.__qualname__.__eq__,       ["cached_property"],       true]
    - [TopologicalSorter,     TopologicalSorter.__qualname__.__eq__,     ["TopologicalSorter"],     true]

# ---------------------------------------------------------------------------
# TopologicalSorter — class instance method name check
#
# TopologicalSorter instances expose .add(), .prepare(), .is_active(),
# .get_ready(), and .done() methods. We verify .add.__name__ == 'add' to
# confirm the method is present and named correctly.
# ---------------------------------------------------------------------------

invariant functools_extra7.TopologicalSorter.add_method_name:
  description: "functools.TopologicalSorter().add.__name__ == 'add' (Python 3.9+)"
  category: TopologicalSorter
  kind: python_call_eq
  function: TopologicalSorter
  args: []
  method: add.__func__.__name__.__eq__
  method_args: ["add"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — length is 5 on Python 3.12
#
# In Python 3.12 WRAPPER_ASSIGNMENTS == ('__module__', '__name__',
# '__qualname__', '__annotations__', '__doc__'). Its length is 5.
# Prior specs verified __class__.__name__ == 'tuple', __len__ >= 1,
# and __contains__ for individual members; this spec pins the exact length.
# ---------------------------------------------------------------------------

invariant functools_extra7.WRAPPER_ASSIGNMENTS.length_5:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 5 on Python 3.12"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — length is 1 on all CPython versions
#
# functools.WRAPPER_UPDATES == ('__dict__',) — a single-element tuple.
# Prior specs verified non-emptiness (__len__ >= 1); this spec pins the value.
# ---------------------------------------------------------------------------

invariant functools_extra7.WRAPPER_UPDATES.length_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — single element ('__dict__',)"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1
