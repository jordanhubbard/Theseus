spec: http_client_extra4
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "This spec extends http_client.zspec.zsdl through http_client_extra3.zspec.zsdl."
    - "http_client.zspec.zsdl covers: status code integer equality, HTTP_PORT/HTTPS_PORT, class __name__ table, responses dict."
    - "http_client_extra.zspec.zsdl covers: most class __name__/__module__ checks; HTTPException base == 'Exception'; NotConnected/InvalidURL base == 'HTTPException'; type identity checks."
    - "http_client_extra2.zspec.zsdl covers: __qualname__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__ for HTTPException/HTTPResponse/NotConnected/InvalidURL; HTTP_PORT/HTTPS_PORT type and value."
    - "http_client_extra3.zspec.zsdl covers: BadStatusLine/RemoteDisconnected __qualname__, __module__, and bases; OK/NOT_FOUND __class__.__name__ == 'HTTPStatus'; OK/NOT_FOUND/INTERNAL_SERVER_ERROR .value."
    - "Focus: additional HTTPStatus enum member .value checks (CREATED, NO_CONTENT, etc.) not in extra3; HTTPStatus enum member .name attribute checks (OK.name == 'OK', etc.); ImproperConnectionState name/module/base/qualname; IncompleteRead name/module/base/qualname; CannotSendRequest/CannotSendHeader name/module/base/qualname."
    - "http.client.ImproperConnectionState is the common base of CannotSendRequest and CannotSendHeader; its base is HTTPException."
    - "http.client.IncompleteRead inherits from HTTPException — useful when a chunked response is truncated."
    - "http.client.CannotSendRequest and CannotSendHeader both inherit from ImproperConnectionState."
    - "HTTPStatus member .name returns the symbolic name string (e.g., OK.name == 'OK')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPStatus enum member .value checks — additional codes not in extra3
# http_client_extra3 covers OK.value==200, NOT_FOUND.value==404,
# INTERNAL_SERVER_ERROR.value==500. This spec adds the remaining standard codes
# already present in the http_client.zspec.zsdl integer-equality table.
# ---------------------------------------------------------------------------

table http_client_extra4.status_values:
  kind: python_call_eq
  category: status_values
  id_prefix: val

  columns: [id, function, args, expected]
  rows:
    - [CREATED,            CREATED.value.__eq__,            [201], true]
    - [NO_CONTENT,         NO_CONTENT.value.__eq__,         [204], true]
    - [MOVED_PERMANENTLY,  MOVED_PERMANENTLY.value.__eq__,  [301], true]
    - [BAD_REQUEST,        BAD_REQUEST.value.__eq__,        [400], true]
    - [UNAUTHORIZED,       UNAUTHORIZED.value.__eq__,       [401], true]
    - [FORBIDDEN,          FORBIDDEN.value.__eq__,          [403], true]
    - [METHOD_NOT_ALLOWED, METHOD_NOT_ALLOWED.value.__eq__, [405], true]
    - [BAD_GATEWAY,        BAD_GATEWAY.value.__eq__,        [502], true]
    - [SERVICE_UNAVAILABLE,SERVICE_UNAVAILABLE.value.__eq__,[503], true]

# ---------------------------------------------------------------------------
# HTTPStatus enum member .name checks
# http_client_extra3 checks .value; the .name accessor (string member name)
# is a distinct axis not yet covered by any prior spec.
# ---------------------------------------------------------------------------

table http_client_extra4.status_names:
  kind: python_call_eq
  category: status_names
  id_prefix: sname

  columns: [id, function, args, expected]
  rows:
    - [OK,                    OK.name.__eq__,                    ["OK"],                    true]
    - [NOT_FOUND,             NOT_FOUND.name.__eq__,             ["NOT_FOUND"],             true]
    - [CREATED,               CREATED.name.__eq__,               ["CREATED"],               true]
    - [INTERNAL_SERVER_ERROR, INTERNAL_SERVER_ERROR.name.__eq__, ["INTERNAL_SERVER_ERROR"], true]

# ---------------------------------------------------------------------------
# ImproperConnectionState — name, module, base, qualname
# This class is the common parent of CannotSendRequest and CannotSendHeader.
# It has not been covered by any prior spec.
# ---------------------------------------------------------------------------

invariant http_client_extra4.ImproperConnectionState.name:
  description: "http.client.ImproperConnectionState.__name__ == 'ImproperConnectionState'"
  category: class_names
  kind: python_call_eq
  function: ImproperConnectionState.__name__.__eq__
  args: ["ImproperConnectionState"]
  expected: true

invariant http_client_extra4.ImproperConnectionState.qualname:
  description: "http.client.ImproperConnectionState.__qualname__ == 'ImproperConnectionState'"
  category: qualnames
  kind: python_call_eq
  function: ImproperConnectionState.__qualname__.__eq__
  args: ["ImproperConnectionState"]
  expected: true

invariant http_client_extra4.ImproperConnectionState.module:
  description: "http.client.ImproperConnectionState.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: ImproperConnectionState.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra4.ImproperConnectionState.base:
  description: "http.client.ImproperConnectionState.__bases__[0].__name__ == 'HTTPException'"
  category: hierarchy
  kind: python_call_eq
  function: ImproperConnectionState.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HTTPException"

# ---------------------------------------------------------------------------
# IncompleteRead — name, module, base, qualname
# IncompleteRead is raised when a response body is truncated.
# It has not been covered by any prior spec.
# ---------------------------------------------------------------------------

invariant http_client_extra4.IncompleteRead.name:
  description: "http.client.IncompleteRead.__name__ == 'IncompleteRead'"
  category: class_names
  kind: python_call_eq
  function: IncompleteRead.__name__.__eq__
  args: ["IncompleteRead"]
  expected: true

invariant http_client_extra4.IncompleteRead.qualname:
  description: "http.client.IncompleteRead.__qualname__ == 'IncompleteRead'"
  category: qualnames
  kind: python_call_eq
  function: IncompleteRead.__qualname__.__eq__
  args: ["IncompleteRead"]
  expected: true

invariant http_client_extra4.IncompleteRead.module:
  description: "http.client.IncompleteRead.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: IncompleteRead.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra4.IncompleteRead.base:
  description: "http.client.IncompleteRead.__bases__[0].__name__ == 'HTTPException'"
  category: hierarchy
  kind: python_call_eq
  function: IncompleteRead.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HTTPException"

# ---------------------------------------------------------------------------
# CannotSendRequest and CannotSendHeader — name, module, base, qualname
# Both inherit from ImproperConnectionState. Not covered in prior specs.
# ---------------------------------------------------------------------------

table http_client_extra4.cannot_send_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [CannotSendRequest, CannotSendRequest.__name__.__eq__, ["CannotSendRequest"], true]
    - [CannotSendHeader,  CannotSendHeader.__name__.__eq__,  ["CannotSendHeader"],  true]

table http_client_extra4.cannot_send_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [CannotSendRequest, CannotSendRequest.__qualname__.__eq__, ["CannotSendRequest"], true]
    - [CannotSendHeader,  CannotSendHeader.__qualname__.__eq__,  ["CannotSendHeader"],  true]

table http_client_extra4.cannot_send_modules:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [CannotSendRequest, CannotSendRequest.__module__.__eq__, ["http.client"], true]
    - [CannotSendHeader,  CannotSendHeader.__module__.__eq__,  ["http.client"], true]
