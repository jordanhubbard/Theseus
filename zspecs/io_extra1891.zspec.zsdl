spec: io_extra1891
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and IOBase close protocol membership in io types"
    - "None of the io types implement unary arithmetic dunder methods"
    - "TextIOWrapper defines __aiter__ (making it async-iterable) but not __anext__ (uses __iter__/__next__)"
    - "IOBase defines close, closed (property), fileno, isatty, readline, readlines, writelines but not truncate or seek"
    - "__closed is a private instance attribute, not in the class dict"
  created_at: "2026-04-12"

table io_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["io1891-ua-001", "io.BytesIO.__dict__.__contains__", ["__abs__"], false]
    - ["io1891-ua-002", "io.BytesIO.__dict__.__contains__", ["__neg__"], false]
    - ["io1891-ua-003", "io.StringIO.__dict__.__contains__", ["__abs__"], false]
    - ["io1891-ua-004", "io.FileIO.__dict__.__contains__", ["__abs__"], false]
    - ["io1891-ua-005", "io.IOBase.__dict__.__contains__", ["__abs__"], false]
    - ["io1891-ua-006", "io.TextIOWrapper.__dict__.__contains__", ["__abs__"], false]
    - ["io1891-ua-007", "io.BufferedReader.__dict__.__contains__", ["__abs__"], false]
    - ["io1891-ua-008", "io.BufferedWriter.__dict__.__contains__", ["__abs__"], false]

table io_extra1891.async_fspath_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io1891-af-001", "io.BytesIO.__dict__.__contains__", ["__aiter__"], false]
    - ["io1891-af-002", "io.BytesIO.__dict__.__contains__", ["__anext__"], false]
    - ["io1891-af-003", "io.StringIO.__dict__.__contains__", ["__aiter__"], false]
    - ["io1891-af-004", "io.StringIO.__dict__.__contains__", ["__anext__"], false]
    - ["io1891-af-005", "io.TextIOWrapper.__dict__.__contains__", ["__aiter__"], true]
    - ["io1891-af-006", "io.TextIOWrapper.__dict__.__contains__", ["__anext__"], false]
    - ["io1891-af-007", "io.IOBase.__dict__.__contains__", ["__aiter__"], false]
    - ["io1891-af-008", "io.FileIO.__dict__.__contains__", ["__fspath__"], false]

table io_extra1891.iobase_close_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io1891-cp-001", "io.IOBase.__dict__.__contains__", ["close"], true]
    - ["io1891-cp-002", "io.IOBase.__dict__.__contains__", ["closed"], true]
    - ["io1891-cp-003", "io.IOBase.__dict__.__contains__", ["__closed"], false]
    - ["io1891-cp-004", "io.IOBase.__dict__.__contains__", ["fileno"], true]
    - ["io1891-cp-005", "io.IOBase.__dict__.__contains__", ["isatty"], true]
    - ["io1891-cp-006", "io.IOBase.__dict__.__contains__", ["readline"], true]
    - ["io1891-cp-007", "io.IOBase.__dict__.__contains__", ["readlines"], true]
    - ["io1891-cp-008", "io.IOBase.__dict__.__contains__", ["writelines"], true]
    - ["io1891-cp-009", "io.IOBase.__dict__.__contains__", ["truncate"], false]
    - ["io1891-cp-010", "io.IOBase.__dict__.__contains__", ["seek"], false]
