spec: hashlib_extra1891
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and hashlib public API membership"
    - "hashlib hash constructors (sha256, md5) are C builtins and do not implement numeric protocols"
    - "hashlib module dict does not implement numeric or async iteration protocols"
    - "hashlib module dict contains sha256, md5, sha1, sha512, sha224, sha384, new, algorithms_guaranteed, algorithms_available, compare_digest"
  created_at: "2026-04-12"

table hashlib_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["hl1891-ua-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__abs__"], false]
    - ["hl1891-ua-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__neg__"], false]
    - ["hl1891-ua-003", "hashlib.md5.__class__.__dict__.__contains__", ["__abs__"], false]
    - ["hl1891-ua-004", "hashlib.__dict__.__contains__", ["__abs__"], false]
    - ["hl1891-ua-005", "hashlib.__dict__.__contains__", ["__neg__"], false]
    - ["hl1891-ua-006", "hashlib.__dict__.__contains__", ["__pos__"], false]
    - ["hl1891-ua-007", "hashlib.__dict__.__contains__", ["__round__"], false]
    - ["hl1891-ua-008", "hashlib.__dict__.__contains__", ["__floor__"], false]

table hashlib_extra1891.fspath_aiter_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl1891-fa-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__fspath__"], false]
    - ["hl1891-fa-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__aiter__"], false]
    - ["hl1891-fa-003", "hashlib.sha256.__class__.__dict__.__contains__", ["__anext__"], false]
    - ["hl1891-fa-004", "hashlib.md5.__class__.__dict__.__contains__", ["__fspath__"], false]
    - ["hl1891-fa-005", "hashlib.__dict__.__contains__", ["__fspath__"], false]
    - ["hl1891-fa-006", "hashlib.__dict__.__contains__", ["__aiter__"], false]
    - ["hl1891-fa-007", "hashlib.__dict__.__contains__", ["__anext__"], false]
    - ["hl1891-fa-008", "hashlib.__dict__.__contains__", ["__length_hint__"], false]

