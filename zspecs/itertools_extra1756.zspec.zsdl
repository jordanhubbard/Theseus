spec: itertools_extra1756
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "All itertools types are C extension types (itertoolsmodule.c) — none define arithmetic operators in their own __dict__."
    - "itertools.chain, count, cycle, repeat, islice, accumulate, compress, starmap, product, combinations: all False for all eight arithmetic dunders."
    - "Complementary checks: __length_hint__ presence varies by type — islice and repeat define it (finite/bounded), chain and cycle do not (variable/infinite)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for itertools types
#
# Wave 564 theme: which itertools types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# All itertools types are C extension iterator objects — they implement the
# iterator protocol (__iter__, __next__) but are not numeric types. None
# define any arithmetic operator dunder in their own __dict__.
#
# chain: lazily concatenates iterables — no arithmetic.
# count: infinite counter — increments internally but exposes no arithmetic ops.
# cycle: infinite repeating iterator — no arithmetic.
# repeat: repeats a value n times or infinitely — no arithmetic.
# islice: slices an iterator — no arithmetic.
# ---------------------------------------------------------------------------

table itertools_extra1756.arithmetic_operators:
  description: "itertools types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1756

  columns: [id, function, args, expected]
  rows:
    - ["it1756001", "itertools.chain.__dict__.__contains__", ["__add__"], false]
    - ["it1756002", "itertools.chain.__dict__.__contains__", ["__sub__"], false]
    - ["it1756003", "itertools.chain.__dict__.__contains__", ["__mul__"], false]
    - ["it1756004", "itertools.chain.__dict__.__contains__", ["__truediv__"], false]
    - ["it1756005", "itertools.chain.__dict__.__contains__", ["__floordiv__"], false]
    - ["it1756006", "itertools.chain.__dict__.__contains__", ["__pow__"], false]
    - ["it1756007", "itertools.chain.__dict__.__contains__", ["__neg__"], false]
    - ["it1756008", "itertools.chain.__dict__.__contains__", ["__pos__"], false]
    - ["it1756009", "itertools.count.__dict__.__contains__", ["__add__"], false]
    - ["it1756010", "itertools.count.__dict__.__contains__", ["__sub__"], false]
    - ["it1756011", "itertools.count.__dict__.__contains__", ["__neg__"], false]
    - ["it1756012", "itertools.repeat.__dict__.__contains__", ["__add__"], false]
    - ["it1756013", "itertools.repeat.__dict__.__contains__", ["__mul__"], false]
    - ["it1756014", "itertools.islice.__dict__.__contains__", ["__add__"], false]
    - ["it1756015", "itertools.islice.__dict__.__contains__", ["__truediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ presence — unique checks not covered in earlier waves
#
# __length_hint__ is an optional optimization hint (PEP 424) that lets iterators
# report an estimated remaining length. itertools.islice and itertools.repeat
# define __length_hint__ because they have a bounded or known count. itertools.chain
# does not (length depends on exhausting sub-iterators at runtime). itertools.cycle
# does not (infinite). This table provides unique complementary checks on
# __length_hint__ membership alongside continued arithmetic absence confirmation.
# ---------------------------------------------------------------------------

table itertools_extra1756.length_hint_and_arithmetic_contrast:
  description: "itertools __length_hint__ presence: islice/repeat True, chain/cycle False; arithmetic all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1756

  columns: [id, function, args, expected]
  rows:
    - ["it1756016", "itertools.islice.__dict__.__contains__", ["__length_hint__"], true]
    - ["it1756017", "itertools.repeat.__dict__.__contains__", ["__length_hint__"], true]
    - ["it1756018", "itertools.chain.__dict__.__contains__", ["__length_hint__"], false]
    - ["it1756019", "itertools.cycle.__dict__.__contains__", ["__length_hint__"], false]
    - ["it1756020", "itertools.accumulate.__dict__.__contains__", ["__add__"], false]
    - ["it1756021", "itertools.accumulate.__dict__.__contains__", ["__mul__"], false]
    - ["it1756022", "itertools.compress.__dict__.__contains__", ["__add__"], false]
    - ["it1756023", "itertools.starmap.__dict__.__contains__", ["__add__"], false]
    - ["it1756024", "itertools.product.__dict__.__contains__", ["__add__"], false]
    - ["it1756025", "itertools.combinations.__dict__.__contains__", ["__add__"], false]
