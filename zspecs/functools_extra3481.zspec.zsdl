spec: ft3481
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (ft3481): __enter__, __exit__, __call__ dict-presence checks for functools types."
    - "functools.partial defines __call__ (true): partial objects are callable — calling a partial invokes the wrapped function with bound arguments."
    - "functools.partial does NOT define __enter__ or __exit__ (false): partial objects are not context managers."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3481.enter:
  description: "functools types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3481
  columns: [id, function, args, expected]
  rows:
    - ["ft3481001", operator.contains, [functools.partial.__dict__,                          "__enter__"], false]
    - ["ft3481002", operator.contains, [functools.partialmethod.__dict__,                    "__enter__"], false]
    - ["ft3481003", operator.contains, [functools.cached_property.__dict__,                  "__enter__"], false]
    - ["ft3481004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__enter__"], false]

