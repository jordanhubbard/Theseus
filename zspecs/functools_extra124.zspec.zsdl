spec: functools_extra124
version: ">=3.12"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra123.zspec.zsdl."
    - "This spec covers: functools.WRAPPER_ASSIGNMENTS element string lengths not yet covered — WRAPPER_ASSIGNMENTS[2].__len__ (12, '__qualname__'), WRAPPER_ASSIGNMENTS[3].__len__ (7, '__doc__'), WRAPPER_ASSIGNMENTS[4].__len__ (12, '__annotate__'); __annotate__ and __qualname__ share the same length (12); WRAPPER_ASSIGNMENTS __contains__ and __index__ operations; WRAPPER_UPDATES string identity; wave 270."
    - "functools.WRAPPER_ASSIGNMENTS[2].__len__() == 12 ('__qualname__'). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 ('__doc__'). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS[4].__len__() == 12 ('__annotate__'). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.index('__qualname__') == 2. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.index('__doc__') == 3. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.count('__qualname__') == 1. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES[0].__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "Prior specs (extra117) covered element lengths [0]=10, [1]=8, [5]=15. New here: [2]=12, [3]=7, [4]=12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.WRAPPER_ASSIGNMENTS element string lengths [2], [3], [4]
#
# Wave 270 theme: Prior spec extra117 covered element string lengths for
# WRAPPER_ASSIGNMENTS indices [0] (10, '__module__'), [1] (8, '__name__'),
# and [5] (15, '__type_params__'). New here: indices [2], [3], and [4].
# '__qualname__' (index 2) has length 12. '__doc__' (index 3) has length 7.
# '__annotate__' (index 4) also has length 12 — the same as '__qualname__'.
# This coincidence (two WRAPPER_ASSIGNMENTS elements sharing length 12) is
# notable: qualname and annotate both use 12 chars despite conveying very
# different roles (naming vs. annotation access). Python 3.14 added
# __annotate__ as part of PEP 749 (lazy annotation evaluation).
#
# WRAPPER_ASSIGNMENTS[2].__len__() == 12  ('__qualname__')
# WRAPPER_ASSIGNMENTS[3].__len__() == 7   ('__doc__')
# WRAPPER_ASSIGNMENTS[4].__len__() == 12  ('__annotate__')
#
# New to extra124.
# ---------------------------------------------------------------------------

table functools_extra124.wrapper_assignments_element_lens:
  description: "functools.WRAPPER_ASSIGNMENTS element lens: [2]='__qualname__'(12), [3]='__doc__'(7), [4]='__annotate__'(12); [2] and [4] share len=12; prior extra117 covered [0]=10,[1]=8,[5]=15; wave 270; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswaelen124

  columns: [id, function, args, expected, description]
  rows:
    - [wa_elem2_len,
       "WRAPPER_ASSIGNMENTS.__getitem__(2).__len__",
       [],
       12,
       "functools.WRAPPER_ASSIGNMENTS[2].__len__() == 12 — '__qualname__' has 12 chars: _-_-q-u-a-l-n-a-m-e-_-_; same length as '__annotate__' (12); str.__len__() returns 12; not covered in extra117; new to extra124"]
    - [wa_elem3_len,
       "WRAPPER_ASSIGNMENTS.__getitem__(3).__len__",
       [],
       7,
       "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 — '__doc__' has 7 chars: _-_-d-o-c-_-_; the shortest WRAPPER_ASSIGNMENTS element string; str.__len__() returns 7; not covered in extra117; new to extra124"]
    - [wa_elem4_len,
       "WRAPPER_ASSIGNMENTS.__getitem__(4).__len__",
       [],
       12,
       "functools.WRAPPER_ASSIGNMENTS[4].__len__() == 12 — '__annotate__' has 12 chars: _-_-a-n-n-o-t-a-t-e-_-_; same length as '__qualname__' (12); added in Python 3.14 (PEP 749 lazy annotation evaluation); str.__len__() returns 12; not covered in extra117; new to extra124"]
    - [wa_elem2_eq4_len,
       "WRAPPER_ASSIGNMENTS.__getitem__(2).__len__",
       [],
       12,
       "functools.WRAPPER_ASSIGNMENTS[2].__len__() == 12 — confirming __qualname__ and __annotate__ share length 12; both WRAPPER_ASSIGNMENTS elements at indices 2 and 4 have identical length; str.__len__() returns 12; new to extra124"]
    - [wa_elem3_shortest,
       "WRAPPER_ASSIGNMENTS.__getitem__(3).__len__",
       [],
       7,
       "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 — '__doc__' is the shortest element (7 < 8 < 10 < 12 < 15); for comparison: __name__(8), __module__(10), __qualname__(12), __type_params__(15); str.__len__() returns 7; new to extra124"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_ASSIGNMENTS __contains__ and index operations
#
# Wave 270 theme: WRAPPER_ASSIGNMENTS is a plain tuple, so it supports
# __contains__ (membership test), index() (first index of a value), and
# count() (number of occurrences). __contains__('__annotate__') is True
# because __annotate__ is at index 4. __contains__('__wrapped__') is False
# because __wrapped__ is not in WRAPPER_ASSIGNMENTS — it is added as an
# attribute directly by update_wrapper, not listed in WRAPPER_ASSIGNMENTS.
# index('__qualname__') returns 2. index('__doc__') returns 3.
# count('__qualname__') returns 1 (each element appears exactly once).
# None of these operations have been tested in prior specs.
#
# WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False
# WRAPPER_ASSIGNMENTS.index('__qualname__') == 2
# WRAPPER_ASSIGNMENTS.index('__doc__') == 3
# WRAPPER_ASSIGNMENTS.count('__qualname__') == 1
#
# New to extra124.
# ---------------------------------------------------------------------------

table functools_extra124.wrapper_assignments_membership:
  description: "functools.WRAPPER_ASSIGNMENTS membership and index: __contains__('__annotate__')=True, __contains__('__wrapped__')=False (not in tuple), index('__qualname__')=2, index('__doc__')=3, count('__qualname__')=1; wave 270; new to extra124"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolswamem124

  columns: [id, function, args, expected, description]
  rows:
    - [wa_contains_annotate,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__annotate__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — __annotate__ is WRAPPER_ASSIGNMENTS element at index 4 (Python 3.14+); tuple.__contains__('__annotate__') returns True; new to extra124"]
    - [wa_contains_wrapped_false,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__wrapped__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False — __wrapped__ is NOT in WRAPPER_ASSIGNMENTS; it is set directly by update_wrapper as a back-reference to the original function, not listed in the assignment tuple; tuple.__contains__('__wrapped__') returns False; new to extra124"]
    - [wa_contains_dict_false,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__dict__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — __dict__ is in WRAPPER_UPDATES (not WRAPPER_ASSIGNMENTS); WRAPPER_UPDATES handles merged updates while WRAPPER_ASSIGNMENTS handles direct attribute copies; tuple.__contains__('__dict__') returns False; new to extra124"]
    - [wa_index_qualname,
       "WRAPPER_ASSIGNMENTS.index",
       ["__qualname__"],
       2,
       "functools.WRAPPER_ASSIGNMENTS.index('__qualname__') == 2 — '__qualname__' is the third element (index 2) of WRAPPER_ASSIGNMENTS; after '__module__'(0) and '__name__'(1); tuple.index() returns 2; new to extra124"]
    - [wa_count_qualname,
       "WRAPPER_ASSIGNMENTS.count",
       ["__qualname__"],
       1,
       "functools.WRAPPER_ASSIGNMENTS.count('__qualname__') == 1 — each element appears exactly once in WRAPPER_ASSIGNMENTS; all 6 elements are distinct attribute names; tuple.count() returns 1; new to extra124"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_UPDATES and WRAPPER_ASSIGNMENTS class name depths
#
# Wave 270 theme: WRAPPER_UPDATES[0] is the string '__dict__' (already
# verified by value in prior specs). Its __class__.__name__ is 'str' — the
# element is a plain Python string. WRAPPER_UPDATES[0].__class__.__name__.__len__()
# is 3 ('str' has 3 chars). WRAPPER_ASSIGNMENTS[4].__class__.__name__ is also
# 'str' — every element in both tuples is a plain Python str. Cross-checking:
# WRAPPER_ASSIGNMENTS[3].__class__.__name__ == 'str'. These string-type
# confirmations are new to extra124.
#
# WRAPPER_UPDATES[0].__class__.__name__ == 'str'
# WRAPPER_UPDATES[0].__class__.__name__.__len__() == 3
# WRAPPER_ASSIGNMENTS[4].__class__.__name__ == 'str'
# WRAPPER_ASSIGNMENTS[3].__class__.__name__ == 'str'
#
# New to extra124.
# ---------------------------------------------------------------------------

table functools_extra124.wrapper_element_str_types:
  description: "functools WRAPPER tuple elements are plain Python str: WRAPPER_UPDATES[0].__class__.__name__='str'(len=3), WRAPPER_ASSIGNMENTS[3].__class__.__name__='str', WRAPPER_ASSIGNMENTS[4].__class__.__name__='str'; all elements are str; wave 270; new to extra124"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolswes124

  columns: [id, function, args, expected, description]
  rows:
    - [wu_elem0_class_name,
       "WRAPPER_UPDATES.__getitem__(0).__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.WRAPPER_UPDATES[0].__class__.__name__.__eq__('str') == True — the single WRAPPER_UPDATES element '__dict__' is a plain Python str; str.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra124"]
    - [wu_elem0_class_name_len,
       "WRAPPER_UPDATES.__getitem__(0).__class__.__name__.__len__",
       [],
       3,
       "functools.WRAPPER_UPDATES[0].__class__.__name__.__len__() == 3 — 'str' has 3 chars: s-t-r; the type name for Python string objects; str.__len__() returns 3; new to extra124"]
    - [wa_elem4_class_name,
       "WRAPPER_ASSIGNMENTS.__getitem__(4).__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.WRAPPER_ASSIGNMENTS[4].__class__.__name__.__eq__('str') == True — '__annotate__' (element at index 4) is a plain Python str; all WRAPPER_ASSIGNMENTS elements are str; str.__eq__('str') returns True; new to extra124"]
    - [wa_elem3_class_name,
       "WRAPPER_ASSIGNMENTS.__getitem__(3).__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.WRAPPER_ASSIGNMENTS[3].__class__.__name__.__eq__('str') == True — '__doc__' (element at index 3) is a plain Python str; confirming every WRAPPER_ASSIGNMENTS element has type str; str.__eq__('str') returns True; new to extra124"]
    - [wa_elem2_class_name,
       "WRAPPER_ASSIGNMENTS.__getitem__(2).__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.WRAPPER_ASSIGNMENTS[2].__class__.__name__.__eq__('str') == True — '__qualname__' (element at index 2) is a plain Python str; all 6 WRAPPER_ASSIGNMENTS elements and both tuple constants themselves are Python objects but each string element has type str; str.__eq__('str') returns True; new to extra124"]
    - [wa_elem2_index_eq,
       "WRAPPER_ASSIGNMENTS.index",
       ["__doc__"],
       3,
       "functools.WRAPPER_ASSIGNMENTS.index('__doc__') == 3 — '__doc__' is the fourth element (index 3); after '__qualname__'(2) and before '__annotate__'(4); tuple.index() returns 3; new to extra124"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra124
# ---------------------------------------------------------------------------

invariant functools_extra124.wa_elem2_len:
  description: "functools.WRAPPER_ASSIGNMENTS[2].__len__() == 12 — '__qualname__' has 12 chars; same length as WRAPPER_ASSIGNMENTS[4] ('__annotate__'); wave 270; new to extra124"
  kind: python_call_eq
  function: "WRAPPER_ASSIGNMENTS.__getitem__(2).__len__"
  args: []
  expected: 12

invariant functools_extra124.wa_elem3_len:
  description: "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 — '__doc__' has 7 chars; the shortest WRAPPER_ASSIGNMENTS element string; wave 270; new to extra124"
  kind: python_call_eq
  function: "WRAPPER_ASSIGNMENTS.__getitem__(3).__len__"
  args: []
  expected: 7

invariant functools_extra124.wa_elem4_len:
  description: "functools.WRAPPER_ASSIGNMENTS[4].__len__() == 12 — '__annotate__' has 12 chars; Python 3.14+ PEP 749 addition; same length as '__qualname__'; wave 270; new to extra124"
  kind: python_call_eq
  function: "WRAPPER_ASSIGNMENTS.__getitem__(4).__len__"
  args: []
  expected: 12

invariant functools_extra124.wa_contains_annotate:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — __annotate__ is at index 4; Python 3.14 PEP 749 addition; wave 270; new to extra124"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotate__"]
  expected: true

invariant functools_extra124.wa_contains_wrapped_false:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False — __wrapped__ is set directly by update_wrapper, not listed in WRAPPER_ASSIGNMENTS; wave 270; new to extra124"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__wrapped__"]
  expected: false

