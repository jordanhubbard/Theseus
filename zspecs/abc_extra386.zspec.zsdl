spec: abc_extra386
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.ABCMeta.register.__name__ == 'register'"
    - "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'"
    - "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'"
    - "abc.ABCMeta._dump_registry.__name__ == '_dump_registry' and lives in module abc"
    - "__abstractmethods__ is a getset_descriptor defined on 'type', not on ABCMeta itself; type.__dict__['__abstractmethods__'].__class__.__name__ == 'getset_descriptor'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra386.method_names:
  description: "Verify __name__ attribute of abc.ABCMeta methods"
  kind: python_call_eq
  category: identity
  id_prefix: abc386mn

  columns: [id, function, args, expected]
  rows:
    - [abc386mn001, abc.ABCMeta.register.__name__.__eq__, ["register"], true]
    - [abc386mn002, abc.ABCMeta.__instancecheck__.__name__.__eq__, ["__instancecheck__"], true]
    - [abc386mn003, abc.ABCMeta.__subclasscheck__.__name__.__eq__, ["__subclasscheck__"], true]
    - [abc386mn004, abc.ABCMeta._dump_registry.__name__.__eq__, ["_dump_registry"], true]

table abc_extra386.method_modules:
  description: "Verify __module__ attribute of abc.ABCMeta._dump_registry"
  kind: python_call_eq
  category: identity
  id_prefix: abc386mm

  columns: [id, function, args, expected]
  rows:
    - [abc386mm001, abc.ABCMeta._dump_registry.__module__.__eq__, ["abc"], true]

table abc_extra386.abstractmethods_descriptor:
  description: "Verify the __abstractmethods__ descriptor class name as seen through type.__dict__"
  kind: python_call_eq
  category: identity
  id_prefix: abc386ad

  columns: [id, function, args, expected]
  rows:
    - ["abc386ad001", "type.__dict__['__abstractmethods__'].__class__.__name__.__eq__", ["getset_descriptor"], true]
