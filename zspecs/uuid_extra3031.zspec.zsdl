spec: uu3031
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (uu3031): __missing__, __init_subclass__, __class_getitem__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable value object representing a UUID — not a mapping or generic alias; it does not define __missing__, __init_subclass__, or __class_getitem__ in its own __dict__."
    - "type(uuid.UUID(int=0)) is identical to uuid.UUID — verified on Python 3.14.4."
    - "None of the uuid types define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu3031.missing:
  description: "uuid types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu3031
  columns: [id, function, args, expected]
  rows:
    - ["uu3031001", operator.contains, [uuid.UUID.__dict__,              "__missing__"], false]
    - ["uu3031002", operator.contains, [type(uuid.UUID(int=0)).__dict__, "__missing__"], false]

