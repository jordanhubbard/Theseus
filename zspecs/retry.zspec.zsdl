spec: retry
version: ">=0.13.0"
backend: node(retry)

docs: https://github.com/tim-kos/node-retry#readme

provenance:
  derived_from:
    - "node-retry README — https://github.com/tim-kos/node-retry#readme"
    - "Test vectors verified with retry via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "retry source"
  notes:
    - "Configurable retry helper — used by AWS SDK, npm, and many transient-error wrappers."
    - "Install: npm install retry"
    - "v0.13 CJS; named exports operation / timeouts / createTimeout / wrap."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "Operation objects are stateful (track attempts)."
  codes: {}

invariant retry.timeouts_default_length:
  description: "timeouts() with no opts returns 10 entries (10 retries default)"
  category: timeouts
  kind: node_chain_eq
  entry: named
  function: timeouts
  entry_args: []
  chain:
    - {get: length}
  expected: 10

invariant retry.timeouts_default_first:
  description: "First default timeout is 1000ms"
  category: timeouts
  kind: node_chain_eq
  entry: named
  function: timeouts
  entry_args: []
  chain:
    - {method: at, args: [0]}
  expected: 1000

invariant retry.timeouts_explicit_factor:
  description: "timeouts({retries:3, factor:2, minTimeout:100}) is [100, 200, 400]"
  category: timeouts
  kind: node_chain_eq
  entry: named
  function: timeouts
  entry_args: [{retries: 3, factor: 2, minTimeout: 100}]
  chain: []
  expected: [100, 200, 400]

invariant retry.timeouts_factor_three:
  description: "factor:3 grows by 3x"
  category: timeouts
  kind: node_chain_eq
  entry: named
  function: timeouts
  entry_args: [{retries: 4, factor: 3, minTimeout: 10}]
  chain: []
  expected: [10, 30, 90, 270]

invariant retry.has_operation_function:
  description: "operation() factory exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "operation.constructor.name"}
  expected: "Function"

invariant retry.has_wrap_function:
  description: "wrap() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "wrap.constructor.name"}
  expected: "Function"

invariant retry.fresh_operation_attempts_is_one:
  description: "Fresh operation()'s attempts() returns 1 (initial attempt counter)"
  category: operation
  kind: node_chain_eq
  entry: named
  function: operation
  entry_args: []
  chain:
    - {method: attempts, args: []}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:21:27Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
