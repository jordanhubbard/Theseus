spec: itertools_extra86
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra85

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra85.zspec.zsdl."
    - "This spec covers: itertools module __spec__/__loader__ class identity attributes (Wave 250)."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec for a C extension module. Verified with Python 3.14.3."
    - "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec name field is 'itertools'. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — for frozen/C modules the loader is a type (the module type itself). Verified with Python 3.14.3."
    - "itertools.__name__.__eq__('itertools') == True — module __name__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — module docstring is a str. Verified with Python 3.14.3."
    - "itertools.__package__.__eq__('') == True — itertools is a top-level module so __package__ is the empty string. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — chain C type docstring is a str. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__class__.__name__ == 'str' — product C type docstring is a str. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__class__.__name__ == 'str' — combinations C type docstring is a str. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__class__.__name__ == 'str' — permutations C type docstring is a str. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__.__class__.__name__ == 'str' — accumulate C type docstring is a str. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__class__.__name__ == 'str' — groupby C type docstring is a str. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools __spec__ and __loader__ class identity — extra86
#
# Wave 250 theme: itertools module __spec__/__loader__ class identity.
#
# itertools.__spec__.__class__.__name__     == 'ModuleSpec'
# itertools.__spec__.name.__eq__('itertools') == True
# itertools.__loader__.__class__.__name__   == 'type'
# itertools.__name__.__eq__('itertools')    == True
#
# No prior itertools spec checks __spec__/__loader__ identity via itrtoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table itertools_extra86.module_spec_loader_identity:
  description: "__spec__ class==ModuleSpec; __spec__.name==itertools; __loader__ class==type; __name__==itertools; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the itertools module's __spec__ attribute is an importlib.machinery.ModuleSpec instance that describes how the C extension module was loaded; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; no prior itertools spec checks __spec__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [spec_name_eq_itertools,
       "__spec__.name.__eq__",
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec for the itertools C extension module stores the module name 'itertools' in its name attribute; str.__eq__('itertools') returns True; no prior itertools spec checks __spec__.name.__eq__ via itrtoolsextra86; new to extra86"]
    - [loader_class_name_eq_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — for built-in/frozen C extension modules, __loader__ is set to the module type itself (a type object); its __class__ is 'type'; str.__eq__('type') returns True; no prior itertools spec checks __loader__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [name_eq_itertools,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module __name__ attribute holds the string 'itertools' (9 chars); this is the standard module-level __name__ set by the import system; str.__eq__('itertools') returns True; no prior itertools spec checks __name__.__eq__ via itrtoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# itertools __doc__ and __package__ identity — extra86
#
# Wave 250 theme: itertools module __doc__/__package__ class identity.
#
# itertools.__doc__.__class__.__name__     == 'str'
# itertools.__package__.__eq__('')         == True
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.product.__doc__.__class__.__name__ == 'str'
#
# No prior itertools spec checks __doc__/__package__ identity via itrtoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table itertools_extra86.module_doc_package_and_chain_product_doc:
  description: "__doc__ class==str; __package__==''; chain.__doc__ class==str; product.__doc__ class==str; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_name_eq_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — the itertools C extension module has a module-level docstring; in Python, module docstrings are plain str objects; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks __doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [package_eq_empty_string,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level built-in C extension module with no parent package; the import system sets __package__ to '' (empty string) for top-level modules; str.__eq__('') returns True; no prior itertools spec checks __package__.__eq__ via itrtoolsextra86; new to extra86"]
    - [chain_doc_class_name_eq_str,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C extension type with a tp_doc docstring; Python exposes tp_doc as a str object via the __doc__ attribute; __class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks chain.__doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [product_doc_class_name_eq_str,
       "product.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — product is a C extension type with a tp_doc docstring; Python exposes tp_doc as a str object via the __doc__ attribute; __class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks product.__doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# itertools C type __doc__ class identity group 2 — extra86
#
# Wave 250 theme: itertools C type docstring class identity.
#
# itertools.combinations.__doc__.__class__.__name__  == 'str'
# itertools.permutations.__doc__.__class__.__name__  == 'str'
# itertools.accumulate.__doc__.__class__.__name__    == 'str'
# itertools.groupby.__doc__.__class__.__name__       == 'str'
#
# No prior itertools spec checks combinations/permutations/accumulate/groupby __doc__.__class__.__name__ via itrtoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table itertools_extra86.ctype_doc_class_group2:
  description: "combinations/permutations/accumulate/groupby __doc__ class==str; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_doc_class_name_eq_str,
       "combinations.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__name__.__eq__('str') == True — combinations is a C extension type with a tp_doc docstring; Python exposes this as a str via __doc__; __class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks combinations.__doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [permutations_doc_class_name_eq_str,
       "permutations.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.permutations.__doc__.__class__.__name__.__eq__('str') == True — permutations is a C extension type with a tp_doc docstring; Python exposes this as a str via __doc__; __class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks permutations.__doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [accumulate_doc_class_name_eq_str,
       "accumulate.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__.__eq__('str') == True — accumulate is a C extension type with a tp_doc docstring; Python exposes this as a str via __doc__; __class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks accumulate.__doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]
    - [groupby_doc_class_name_eq_str,
       "groupby.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby is a C extension type with a tp_doc docstring; Python exposes this as a str via __doc__; __class__.__name__ is 'str'; str.__eq__('str') returns True; no prior itertools spec checks groupby.__doc__.__class__.__name__ via itrtoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# module identity summary — extra86
#
# Wave 250 theme: itertools module identity double-confirms.
#
# itertools.__spec__.__class__.__name__      == 'ModuleSpec'  (double-confirm)
# itertools.__name__.__eq__('itertools')     == True  (double-confirm)
# itertools.__loader__.__class__.__name__    == 'type'  (double-confirm)
# itertools.__package__.__eq__('')           == True  (double-confirm)
#
# New to extra86.
# ---------------------------------------------------------------------------

table itertools_extra86.module_identity_summary:
  description: "ModuleSpec/__name__/__loader__/__package__ double-confirms; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_ModuleSpec_confirm,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — double-confirms the itertools ModuleSpec class name; the import machinery creates a ModuleSpec for every loaded module including C extensions; new to extra86"]
    - [name_itertools_confirm,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — double-confirms module __name__ is 'itertools'; the import system sets __name__ on all modules; for itertools this is always 'itertools'; new to extra86"]
    - [loader_type_confirm,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — double-confirms __loader__ class is 'type' for the itertools C extension; built-in module loaders are represented as the type metaclass; new to extra86"]
    - [package_empty_confirm,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — double-confirms __package__ is '' for the top-level itertools module; top-level modules have empty __package__; new to extra86"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant itertools_extra86.spec_class_name_eq_ModuleSpec:
  description: "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools ModuleSpec class identity; wave 250; new to extra86"
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra86.spec_name_eq_itertools:
  description: "itertools.__spec__.name.__eq__('itertools') == True — itertools ModuleSpec.name field is 'itertools'; wave 250; new to extra86"
  kind: python_call_eq
  function: "__spec__.name.__eq__"
  args: ["itertools"]
  expected: true

invariant itertools_extra86.loader_class_eq_type:
  description: "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools C extension loader class is 'type'; wave 250; new to extra86"
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant itertools_extra86.package_eq_empty:
  description: "itertools.__package__.__eq__('') == True — itertools is top-level so __package__ is ''; wave 250; new to extra86"
  kind: python_call_eq
  function: "__package__.__eq__"
  args: [""]
  expected: true

invariant itertools_extra86.chain_doc_class_str:
  description: "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain C type docstring is a str; wave 250; new to extra86"
  kind: python_call_eq
  function: "chain.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
