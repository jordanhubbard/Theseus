spec: strip_comments
version: ">=2.0.1"
backend: node(strip-comments)

docs: https://www.npmjs.com/package/strip-comments

provenance:
  derived_from:
    - "strip-comments README — https://www.npmjs.com/package/strip-comments"
    - "Test vectors verified with strip-comments via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "strip-comments source"
  notes:
    - "strip-comments is an npm package. Install: npm install strip-comments"
    - "Removes line comments (//) and block comments (/* */) from a JavaScript string."
    - "The space previously occupied by the comment is preserved."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table strip_comments.strip:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: strpcmt

  columns: [id, args, expected]
  rows:
    - [line_comment,  ["var x = 1; // comment"],  "var x = 1; "]
    - [block_comment, ["/* block */ var x = 1;"], " var x = 1;"]
    - [no_comment,    ["no comments here"],        "no comments here"]
    - [full_line,     ["// full line comment"],    ""]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:25:11Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
