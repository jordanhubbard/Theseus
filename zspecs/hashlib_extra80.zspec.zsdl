spec: hashlib_extra80
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra79.zspec.zsdl — covers blake2b/__dict__.__contains__('copy'/'update'/'digest'/'hexdigest'/'SALT_SIZE') / blake2s/__dict__.__contains__('copy'/'update'/'digest') / blake2b.copy/update/digest/__class__/__name__=='method_descriptor' (table + invariants)."
    - "hashlib_extra77.zspec.zsdl — covers blake2b/__name__/__module__/__bases__[0]/__mro__.__len__() / blake2b/__doc__.__class__.__name__ / blake2s/__name__/__module__/__bases__[0]/__mro__.__len__() (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra79; it does NOT duplicate invariants present in those files."
    - "Wave 244 theme: hashlib blake2b/blake2s remaining class-level constants + hexdigest method class identity."
    - "hashlib.blake2b.__dict__.__contains__('MAX_DIGEST_SIZE') == True — blake2b defines MAX_DIGEST_SIZE as a class-level int constant (value 64) in its class __dict__. No prior hashlib spec checks blake2b.__dict__.__contains__('MAX_DIGEST_SIZE'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('MAX_KEY_SIZE') == True — blake2b defines MAX_KEY_SIZE as a class-level int constant (value 64). No prior hashlib spec checks blake2b.__dict__.__contains__('MAX_KEY_SIZE'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('PERSON_SIZE') == True — blake2b defines PERSON_SIZE as a class-level int constant (value 16). No prior hashlib spec checks blake2b.__dict__.__contains__('PERSON_SIZE'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('MAX_DIGEST_SIZE') == True — blake2s defines MAX_DIGEST_SIZE as a class-level int constant (value 32). No prior hashlib spec checks blake2s.__dict__.__contains__('MAX_DIGEST_SIZE'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('MAX_KEY_SIZE') == True — blake2s defines MAX_KEY_SIZE as a class-level int constant (value 32). No prior hashlib spec checks blake2s.__dict__.__contains__('MAX_KEY_SIZE'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__ == 'int' — the class-level constant is a plain int. No prior hashlib spec checks MAX_DIGEST_SIZE.__class__.__name__ for blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_KEY_SIZE.__class__.__name__ == 'int' — the class-level constant is a plain int. No prior hashlib spec checks MAX_KEY_SIZE.__class__.__name__ for blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_DIGEST_SIZE.__class__.__name__ == 'int' — the class-level constant is a plain int. No prior hashlib spec checks MAX_DIGEST_SIZE.__class__.__name__ for blake2s. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.hexdigest.__class__.__name__ == 'method_descriptor' — hashlib_extra79 covers copy/update/digest class names; hexdigest was listed in extra79 as a __dict__ key but its __class__.__name__ was NOT checked as a standalone invariant. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.hexdigest.__class__.__name__ == 'method_descriptor' — blake2s.hexdigest is a C method_descriptor. No prior hashlib spec checks blake2s.hexdigest.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__ for MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE
#
# Wave 244 theme: blake2b class-level size constants in __dict__.
#
# hashlib.blake2b is a C extension type defining MAX_DIGEST_SIZE (64),
# MAX_KEY_SIZE (64), and PERSON_SIZE (16) as class-level int constants in its
# class __dict__. hashlib_extra79 covers SALT_SIZE in blake2b.__dict__ but NOT
# MAX_DIGEST_SIZE, MAX_KEY_SIZE, or PERSON_SIZE. No prior hashlib spec checks
# blake2b.__dict__.__contains__ for any of these three. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra80.blake2b_dict_size_constants:
  description: "hashlib.blake2b/__dict__.__contains__('MAX_DIGEST_SIZE')==True / __contains__('MAX_KEY_SIZE')==True / __contains__('PERSON_SIZE')==True — blake2b defines MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE as class-level int constants in its __dict__; hashlib_extra79 covers SALT_SIZE but NOT these three; no prior hashlib spec checks blake2b.__dict__.__contains__ for MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE; first size-constant dict contains anchor for blake2b"
  kind: python_call_eq
  category: class_dict
  id_prefix: hashlibmore80

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_has_MAX_DIGEST_SIZE, blake2b.__dict__.__contains__, ["MAX_DIGEST_SIZE"], true]
    - [blake2b_dict_has_MAX_KEY_SIZE,    blake2b.__dict__.__contains__, ["MAX_KEY_SIZE"],    true]
    - [blake2b_dict_has_PERSON_SIZE,     blake2b.__dict__.__contains__, ["PERSON_SIZE"],     true]

# ---------------------------------------------------------------------------
# hashlib.blake2s.__dict__.__contains__ for MAX_DIGEST_SIZE and MAX_KEY_SIZE
#
# Wave 244 theme: blake2s class-level size constants in __dict__.
#
# hashlib.blake2s is a C extension type defining MAX_DIGEST_SIZE (32) and
# MAX_KEY_SIZE (32) as class-level int constants in its class __dict__.
# No prior hashlib spec checks blake2s.__dict__.__contains__ for either of
# these constants. hashlib_extra79 covers copy/update/digest in blake2s.__dict__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra80.blake2s_dict_size_constants:
  description: "hashlib.blake2s/__dict__.__contains__('MAX_DIGEST_SIZE')==True / __contains__('MAX_KEY_SIZE')==True — blake2s defines MAX_DIGEST_SIZE/MAX_KEY_SIZE as class-level int constants in its __dict__; hashlib_extra79 covers copy/update/digest in blake2s.__dict__ but NOT MAX_DIGEST_SIZE or MAX_KEY_SIZE; no prior hashlib spec checks blake2s.__dict__.__contains__ for MAX_DIGEST_SIZE or MAX_KEY_SIZE; first size-constant dict contains anchor for blake2s"
  kind: python_call_eq
  category: class_dict
  id_prefix: hashlibmore80

  columns: [id, function, args, expected]
  rows:
    - [blake2s_dict_has_MAX_DIGEST_SIZE, blake2s.__dict__.__contains__, ["MAX_DIGEST_SIZE"], true]
    - [blake2s_dict_has_MAX_KEY_SIZE,    blake2s.__dict__.__contains__, ["MAX_KEY_SIZE"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2b size constant __class__.__name__ == 'int'
#
# Wave 244 theme: blake2b class-level constant type identity.
#
# hashlib.blake2b.MAX_DIGEST_SIZE and MAX_KEY_SIZE are plain Python ints.
# Their __class__.__name__ is 'int'. No prior hashlib spec checks
# blake2b.MAX_DIGEST_SIZE.__class__.__name__ or blake2b.MAX_KEY_SIZE.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra80.blake2b_constant_class_name:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE/__class__/__name__.__eq__('int')==True / blake2b.MAX_KEY_SIZE/__class__/__name__.__eq__('int')==True / blake2s.MAX_DIGEST_SIZE/__class__/__name__.__eq__('int')==True — class-level size constants are plain ints; no prior hashlib spec checks __class__.__name__ for blake2b.MAX_DIGEST_SIZE/MAX_KEY_SIZE or blake2s.MAX_DIGEST_SIZE; first type identity anchor for blake2b/blake2s size constants"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore80

  columns: [id, function, args, expected]
  rows:
    - [blake2b_MAX_DIGEST_SIZE_class_int, blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__, ["int"], true]
    - [blake2b_MAX_KEY_SIZE_class_int,    blake2b.MAX_KEY_SIZE.__class__.__name__.__eq__,    ["int"], true]
    - [blake2s_MAX_DIGEST_SIZE_class_int, blake2s.MAX_DIGEST_SIZE.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.hexdigest and blake2s.hexdigest __class__.__name__
#
# Wave 244 theme: blake2b/blake2s hexdigest method class identity.
#
# hashlib.blake2b.hexdigest and hashlib.blake2s.hexdigest are C method_descriptors.
# hashlib_extra79 covers blake2b.copy/update/digest __class__.__name__ but NOT
# blake2b.hexdigest.__class__.__name__. No prior hashlib spec checks
# blake2s.hexdigest.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra80.blake2_hexdigest_class_name:
  description: "hashlib.blake2b.hexdigest/__class__/__name__.__eq__('method_descriptor')==True / blake2s.hexdigest/__class__/__name__.__eq__('method_descriptor')==True — hexdigest is a C method_descriptor on both blake2b and blake2s; hashlib_extra79 covers copy/update/digest __class__.__name__ for blake2b but NOT hexdigest; no prior hashlib spec checks blake2s.hexdigest.__class__.__name__; first hexdigest class identity anchor for blake2b and blake2s"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore80

  columns: [id, function, args, expected]
  rows:
    - [blake2b_hexdigest_class_method_descriptor, blake2b.hexdigest.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [blake2s_hexdigest_class_method_descriptor, blake2s.hexdigest.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__('MAX_DIGEST_SIZE') — standalone
#
# blake2b defines MAX_DIGEST_SIZE (value 64) in its class __dict__. No prior
# hashlib spec checks blake2b.__dict__.__contains__('MAX_DIGEST_SIZE'). First
# MAX_DIGEST_SIZE dict contains standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra80.blake2b_dict_has_MAX_DIGEST_SIZE:
  description: "hashlib.blake2b.__dict__.__contains__('MAX_DIGEST_SIZE') == True — blake2b defines MAX_DIGEST_SIZE (value 64) as a class-level int constant; no prior hashlib spec checks blake2b.__dict__.__contains__('MAX_DIGEST_SIZE'); first MAX_DIGEST_SIZE dict contains standalone for blake2b"
  category: class_dict
  kind: python_call_eq
  function: blake2b.__dict__.__contains__
  args: ["MAX_DIGEST_SIZE"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__('PERSON_SIZE') — standalone
#
# blake2b defines PERSON_SIZE (value 16) in its class __dict__. No prior
# hashlib spec checks blake2b.__dict__.__contains__('PERSON_SIZE'). First
# PERSON_SIZE dict contains standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra80.blake2b_dict_has_PERSON_SIZE:
  description: "hashlib.blake2b.__dict__.__contains__('PERSON_SIZE') == True — blake2b defines PERSON_SIZE (value 16) as a class-level int constant; no prior hashlib spec checks blake2b.__dict__.__contains__('PERSON_SIZE'); first PERSON_SIZE dict contains standalone for blake2b"
  category: class_dict
  kind: python_call_eq
  function: blake2b.__dict__.__contains__
  args: ["PERSON_SIZE"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__('int') — standalone
#
# blake2b.MAX_DIGEST_SIZE is a plain int (value 64). No prior hashlib spec
# checks blake2b.MAX_DIGEST_SIZE.__class__.__name__. First type identity
# standalone for blake2b.MAX_DIGEST_SIZE.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra80.blake2b_MAX_DIGEST_SIZE_class_int:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__('int') == True — MAX_DIGEST_SIZE is a plain int (value 64); no prior hashlib spec checks blake2b.MAX_DIGEST_SIZE.__class__.__name__; first type identity standalone for blake2b.MAX_DIGEST_SIZE"
  category: class_identity
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.hexdigest.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2b.hexdigest is a C method_descriptor. hashlib_extra79 covers
# blake2b.copy/update/digest __class__.__name__ as standalones but NOT hexdigest.
# First hexdigest class identity standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra80.blake2b_hexdigest_class_method_descriptor:
  description: "hashlib.blake2b.hexdigest.__class__.__name__.__eq__('method_descriptor') == True — blake2b.hexdigest is a C method_descriptor; hashlib_extra79 covers blake2b.copy/update/digest __class__.__name__ but NOT hexdigest; first hexdigest class identity standalone for blake2b"
  category: class_identity
  kind: python_call_eq
  function: blake2b.hexdigest.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.hexdigest.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2s.hexdigest is a C method_descriptor. No prior hashlib spec checks
# blake2s.hexdigest.__class__.__name__. First hexdigest class identity
# standalone for blake2s. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra80.blake2s_hexdigest_class_method_descriptor:
  description: "hashlib.blake2s.hexdigest.__class__.__name__.__eq__('method_descriptor') == True — blake2s.hexdigest is a C method_descriptor; no prior hashlib spec checks blake2s.hexdigest.__class__.__name__; first hexdigest class identity standalone for blake2s"
  category: class_identity
  kind: python_call_eq
  function: blake2s.hexdigest.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
