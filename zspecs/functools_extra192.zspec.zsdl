spec: functools_extra192
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.__name__ == 'functools' (len=9); verified with Python 3.14.3."
    - "functools.__package__ == '' (empty string, not 'functools'); verified with Python 3.14.3 — the top-level functools module reports an empty __package__."
    - "functools.__doc__.__class__.__name__ == 'str' — the module docstring is a plain Python str (not None); verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' (len=6); functools.reduce.__module__ == '_functools' — reduce is implemented in C and reports '_functools' as its module; verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' (len=7); verified with Python 3.14.3."
    - "functools.lru_cache.__name__ == 'lru_cache' (len=9); verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' (len=5); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools module-level __name__ and __package__ identity
#
# functools.__name__ == 'functools' (len=9)
# functools.__package__ == '' (empty string — top-level module)
#
# The __name__ attribute identifies the module; __package__ is '' for top-level
# modules (not inside a package). New to extra192.
# ---------------------------------------------------------------------------

table functools_extra192.module_name_and_package:
  description: "functools.__name__=='functools' (len=9) and functools.__package__=='' (empty string for top-level module); new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: functmodule192

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the module name is 'functools'; str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra192"]
    - [module_name_len,
       __name__.__len__,
       [],
       9,
       "functools.__name__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra192"]
    - [module_package_eq,
       __package__.__eq__,
       [""],
       true,
       "functools.__package__.__eq__('') == True — top-level modules report __package__ as empty string ''; str.__eq__('') returns True; verified with Python 3.14.3; new to extra192"]
    - [module_package_len,
       __package__.__len__,
       [],
       0,
       "functools.__package__.__len__() == 0 — the empty string has length 0; str.__len__() returns 0; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 2: functools.__doc__ class identity and reduce module identity
#
# functools.__doc__.__class__.__name__ == 'str'
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__module__ == '_functools'
#
# The module-level docstring is a plain str. reduce is implemented in C and
# reports '_functools' (with underscore) as its __module__. New to extra192.
# ---------------------------------------------------------------------------

table functools_extra192.doc_and_reduce_identity:
  description: "functools.__doc__.__class__.__name__=='str'; reduce.__name__=='reduce' (len=6); reduce.__module__=='_functools'; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: functmodule192

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_name_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.__doc__.__class__.__name__.__eq__('str') == True — the module docstring is a plain Python str (not None); __class__.__name__ is 'str'; str.__eq__('str') returns True; verified with Python 3.14.3; new to extra192"]
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — the reduce function's __name__ attribute is 'reduce'; str.__eq__('reduce') returns True; verified with Python 3.14.3; new to extra192"]
    - [reduce_name_len,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters: r-e-d-u-c-e; str.__len__() returns 6; verified with Python 3.14.3; new to extra192"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in C and reports '_functools' (with leading underscore) as __module__; str.__eq__('_functools') returns True; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 3: functools top-level callable __name__ identity
#
# functools.partial.__name__ == 'partial' (len=7)
# functools.lru_cache.__name__ == 'lru_cache' (len=9)
# functools.cache.__name__ == 'cache' (len=5)
#
# These are core functools public API items. Their __name__ attributes confirm
# the callable identity as registered in the functools namespace. New to extra192.
# ---------------------------------------------------------------------------

table functools_extra192.callable_name_identity:
  description: "functools.partial.__name__=='partial' (len=7); lru_cache.__name__=='lru_cache' (len=9); cache.__name__=='cache' (len=5); new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: functmodule192

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial's __name__ is 'partial'; str.__eq__('partial') returns True; verified with Python 3.14.3; new to extra192"]
    - [partial_name_len,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; verified with Python 3.14.3; new to extra192"]
    - [lru_cache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache's __name__ is 'lru_cache'; str.__eq__('lru_cache') returns True; verified with Python 3.14.3; new to extra192"]
    - [lru_cache_name_len,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra192"]
    - [cache_name_eq,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — cache's __name__ is 'cache'; str.__eq__('cache') returns True; verified with Python 3.14.3; new to extra192"]
    - [cache_name_len,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters: c-a-c-h-e; str.__len__() returns 5; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra192
# ---------------------------------------------------------------------------

invariant functools_extra192.module_name_is_functools:
  description: "functools.__name__.__eq__('functools') == True — the module name is 'functools' (len=9); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra192.module_package_is_empty:
  description: "functools.__package__.__eq__('') == True — top-level modules report __package__ as empty string; __package__ is '' not 'functools'; verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant functools_extra192.module_doc_is_str:
  description: "functools.__doc__.__class__.__name__.__eq__('str') == True — the module docstring is a plain Python str, not None; verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra192.reduce_name_is_reduce:
  description: "functools.reduce.__name__.__eq__('reduce') == True — the reduce callable's __name__ is 'reduce' (len=6); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra192.reduce_module_is_underscore_functools:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C built-in and reports '_functools' (with leading underscore) as its module; distinct from 'functools'; verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra192.partial_name_is_partial:
  description: "functools.partial.__name__.__eq__('partial') == True — partial's __name__ is 'partial' (len=7); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra192.lru_cache_name_is_lru_cache:
  description: "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache's __name__ is 'lru_cache' (len=9); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra192.cache_name_is_cache:
  description: "functools.cache.__name__.__eq__('cache') == True — cache's __name__ is 'cache' (len=5); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true
