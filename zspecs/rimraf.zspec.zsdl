spec: rimraf
version: ">=5.0.0"
backend: node(rimraf)

docs: https://github.com/isaacs/rimraf#readme

provenance:
  derived_from:
    - "rimraf README — https://github.com/isaacs/rimraf#readme"
    - "Test vectors verified with rimraf via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "rimraf source"
  notes:
    - "rimraf is the canonical recursive-rm utility — #37 most-depended-upon npm package."
    - "Install: npm install rimraf"
    - "rimraf.sync(path) recursively removes path; returns true on success."
    - "When called on a non-existent path, rimraf.sync returns true (idempotent — 'rm -rf' semantics)."
    - "Tests run inside a per-invariant tempdir sandbox; existence verification of the post-state is done via a fs.existsSync chain step in the same invariant."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "rimraf.sync returns true on success or no-op; throws only on permission errors not exercised here."
  stderr: "null"
  stickiness: "Each invariant runs in a fresh sandbox."
  codes: {}

# ── rimraf.sync return value ────────────────────────────────────────────────

table rimraf.sync_return:
  kind: node_sandbox_chain_eq
  category: sync_return
  entry: named
  function: sync
  id_prefix: ret

  columns: [id, entry_args, chain, setup, expected]
  rows:
    - [removes_file_returns_true,
       ["doomed.txt"], [],
       [{path: "doomed.txt", content: "x"}],
       true]

    - [removes_directory_returns_true,
       ["doomed_dir"], [],
       [{path: "doomed_dir/inner.txt", content: "x"}],
       true]

    - [removes_deep_tree_returns_true,
       ["a"], [],
       [{path: "a/b/c/d/e.txt", content: "deep"}],
       true]

    - [no_op_on_missing_returns_true,
       ["never_existed"], [],
       [],
       true]

    - [removes_only_target,
       ["target"], [],
       [{path: "target", dir: true},
        {path: "keeper.txt", content: "stay"}],
       true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:22:56Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
