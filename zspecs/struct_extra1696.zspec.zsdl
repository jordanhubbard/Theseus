spec: struct_extra1696
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "struct.Struct is a C extension type that wraps a compiled format string.  It defines none of __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, or __deepcopy__ in its own __dict__ — struct.Struct objects are NOT picklable."
    - "struct.error inherits from Exception and defines no custom pickling or copy dunders in its own __dict__."
    - "struct.Struct does define the standard packing/unpacking API in its own __dict__: pack, unpack, pack_into, unpack_from, iter_unpack, and the properties size and format."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods absent from struct.Struct.__dict__
#
# struct.Struct is a compiled C type.  It exposes no pickle protocol hooks
# in its own __dict__ — attempting to pickle a struct.Struct instance raises
# TypeError: cannot pickle '_struct.Struct' object.
# ---------------------------------------------------------------------------

table struct_extra1696.pickling_protocol:
  description: "struct.Struct pickling protocol dict-presence checks — no pickle dunders defined in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1696

  columns: [id, function, args, expected]
  rows:
    - ["st1696001", "struct.Struct.__dict__.__contains__", ["__reduce__"],        false]
    - ["st1696002", "struct.Struct.__dict__.__contains__", ["__getstate__"],      false]
    - ["st1696003", "struct.Struct.__dict__.__contains__", ["__setstate__"],      false]
    - ["st1696004", "struct.Struct.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["st1696005", "struct.Struct.__dict__.__contains__", ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol methods absent from struct.Struct.__dict__
#
# struct.Struct also defines neither __copy__ nor __deepcopy__ in its own
# __dict__.  struct.error likewise defines no pickling or copy dunders.
# ---------------------------------------------------------------------------

table struct_extra1696.copy_protocol:
  description: "struct.Struct and struct.error copy and pickling protocol dict-presence checks — no copy or pickle dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1696

  columns: [id, function, args, expected]
  rows:
    - ["st1696006",  "struct.Struct.__dict__.__contains__", ["__copy__"],          false]
    - ["st1696007",  "struct.Struct.__dict__.__contains__", ["__deepcopy__"],      false]
    - ["st1696008",  "struct.error.__dict__.__contains__",  ["__reduce__"],        false]
    - ["st1696009",  "struct.error.__dict__.__contains__",  ["__getstate__"],      false]
    - ["st1696010",  "struct.error.__dict__.__contains__",  ["__setstate__"],      false]
    - ["st1696011",  "struct.error.__dict__.__contains__",  ["__getnewargs__"],    false]
    - ["st1696012",  "struct.error.__dict__.__contains__",  ["__getnewargs_ex__"], false]
    - ["st1696013",  "struct.error.__dict__.__contains__",  ["__copy__"],          false]
    - ["st1696014",  "struct.error.__dict__.__contains__",  ["__deepcopy__"],      false]

# ---------------------------------------------------------------------------
# Table 3: Standard packing API present in struct.Struct.__dict__
#
# Although struct.Struct is not picklable, it does define its full packing
# and unpacking API in its own __dict__: pack, unpack, pack_into, unpack_from,
# iter_unpack, and the read-only properties size and format.
# ---------------------------------------------------------------------------

table struct_extra1696.packing_api_dict_presence:
  description: "struct.Struct standard packing API dict-presence checks — pack, unpack, pack_into, unpack_from, iter_unpack, size, format all present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1696

  columns: [id, function, args, expected]
  rows:
    - ["st1696015", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st1696016", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st1696017", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st1696018", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1696019", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1696020", "struct.Struct.__dict__.__contains__", ["size"],        true]
    - ["st1696021", "struct.Struct.__dict__.__contains__", ["format"],      true]
