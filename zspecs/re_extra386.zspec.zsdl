spec: re_extra386
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.escape.__name__ == 'escape' and re.escape.__module__ == 're'"
    - "re.purge.__name__ == 'purge' and re.purge.__module__ == 're'"
    - "re.template was deprecated in Python 3.11 and removed in Python 3.13; not covered here"
    - "re.Match methods group, groups, groupdict, start, end, span each report __name__ matching their Python-level name"
    - "re.Match is the public type for match objects returned by re.compile().match() and related methods"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function identity — escape and purge
# ---------------------------------------------------------------------------

table re_extra386.module_function_identity:
  description: "re module-level function identity — escape and purge; each function's __name__ and __module__ match expected values; re.template was removed in Python 3.13 and is not covered; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: remod386

  columns: [id, function, args, expected]
  rows:
    - [escape_name,   re.escape.__name__.__eq__,   ["escape"], true]
    - [escape_module, re.escape.__module__.__eq__, ["re"],     true]
    - [purge_name,    re.purge.__name__.__eq__,    ["purge"],  true]
    - [purge_module,  re.purge.__module__.__eq__,  ["re"],     true]

# ---------------------------------------------------------------------------
# re.Match method __name__ identity
# ---------------------------------------------------------------------------

table re_extra386.match_method_names:
  description: "re.Match method __name__ identity — group, groups, groupdict, start, end, span; each method's __name__ matches its Python-level name; re.Match is the type of match objects returned by pattern.match() and related methods; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: rematch386

  columns: [id, function, args, expected]
  rows:
    - [group_name,     re.Match.group.__name__.__eq__,     ["group"],     true]
    - [groups_name,    re.Match.groups.__name__.__eq__,    ["groups"],    true]
    - [groupdict_name, re.Match.groupdict.__name__.__eq__, ["groupdict"], true]
    - [start_name,     re.Match.start.__name__.__eq__,     ["start"],     true]
    - [end_name,       re.Match.end.__name__.__eq__,       ["end"],       true]
    - [span_name,      re.Match.span.__name__.__eq__,      ["span"],      true]
