spec: just_entries
version: ">=2.3.0"
backend: node(just-entries)

docs: https://www.npmjs.com/package/just-entries

provenance:
  derived_from:
    - "just-entries README — https://www.npmjs.com/package/just-entries"
    - "Test vectors verified with just-entries via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-entries source"
  notes:
    - "just-entries is an npm package. Install: npm install just-entries"
    - "The module exports a single function that returns [key, value] pairs for an object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of [key, value] pairs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_entries.entries:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jents

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"a": 1, "b": 2}], [["a", 1], ["b", 2]]]
    - [single,   [{"x": 42}],        [["x", 42]]]
