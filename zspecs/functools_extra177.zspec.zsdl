spec: functools_extra177
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce.__qualname__ 'reduce'; functools.cmp_to_key.__qualname__ 'cmp_to_key'; functools.lru_cache.__qualname__ 'lru_cache'; functools.cache.__qualname__ 'cache'; functools.WRAPPER_UPDATES.__class__.__name__ 'tuple'; functools.WRAPPER_UPDATES.__contains__('__dict__') True; functools.WRAPPER_UPDATES.__len__() 1 (Wave 301)."
    - "functools.reduce.__qualname__ == 'reduce' — functools.reduce is a C builtin function defined in Modules/_functoolsmodule.c (exposed via the _functools module); like all C builtins, its __qualname__ equals its __name__ ('reduce') since it has no enclosing class scope. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — functools.cmp_to_key is a C builtin function defined in Modules/_functoolsmodule.c; its __qualname__ equals its __name__ ('cmp_to_key'). Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — functools.lru_cache is a module-level Python function; its __qualname__ equals its __name__ ('lru_cache'); already confirmed in extra175 for __name__, now confirming __qualname__ grouping. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' — functools.cache is a module-level Python function; its __qualname__ equals its __name__ ('cache'); already confirmed in extra175 for __name__, now confirming __qualname__ grouping. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — functools.WRAPPER_UPDATES is a module-level tuple constant ('__dict__',) listing attributes to update (not just copy) when using functools.update_wrapper or functools.wraps; its __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — WRAPPER_UPDATES is ('__dict__',); it contains exactly one element, '__dict__'; __contains__('__dict__') returns True. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is the single-element tuple ('__dict__',); its length is exactly 1. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce is defined in the C extension _functools module (Modules/_functoolsmodule.c); its __module__ attribute is '_functools', not 'functools'. functools re-exports it. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is defined in the C extension _functools module (Modules/_functoolsmodule.c); its __module__ attribute is '_functools', not 'functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce and functools.cmp_to_key __qualname__ checks
#
# Wave 301 theme: functools.reduce and functools.cmp_to_key are C builtins
# whose __qualname__ equals their __name__.
#
# functools.reduce.__qualname__ == 'reduce'
# functools.cmp_to_key.__qualname__ == 'cmp_to_key'
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
#
# functools.reduce and functools.cmp_to_key are both C builtin functions
# defined in Modules/_functoolsmodule.c and exposed via _functools. For C
# builtins, __qualname__ equals __name__ since there is no enclosing class
# or closure scope. New to extra177.
# ---------------------------------------------------------------------------

table functools_extra177.reduce_cmp_to_key_qualname:
  description: "functools.reduce and cmp_to_key: __qualname__ equals __name__; both builtin_function_or_method; wave 301; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrckq177

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_reduce,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — functools.reduce is a C builtin function defined in Modules/_functoolsmodule.c; like all C builtins, its __qualname__ equals its __name__ ('reduce') since there is no enclosing class or closure scope; str.__eq__('reduce') returns True; new to extra177"]
    - [cmp_to_key_qualname_cmp_to_key,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — functools.cmp_to_key is a C builtin function defined in Modules/_functoolsmodule.c; its __qualname__ equals its __name__ ('cmp_to_key'); str.__eq__('cmp_to_key') returns True; new to extra177"]
    - [reduce_class_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.reduce is a C builtin function (not a Python function and not a C extension type); its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra177"]
    - [cmp_to_key_class_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.cmp_to_key is a C builtin function defined in Modules/_functoolsmodule.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache and functools.cache __qualname__ checks
#
# Wave 301 theme: functools.lru_cache and functools.cache are module-level
# Python functions whose __qualname__ equals their __name__.
#
# functools.lru_cache.__qualname__ == 'lru_cache'
# functools.cache.__qualname__ == 'cache'
# functools.lru_cache.__qualname__ != 'cache'
# functools.cache.__qualname__ != 'lru_cache'
#
# Unlike reduce and cmp_to_key (which are C builtins with __module__
# '_functools'), lru_cache and cache are Python functions defined in
# Lib/functools.py with __module__ 'functools'. Both have __qualname__
# equal to __name__ since they are module-level (no enclosing scope). New
# to extra177.
# ---------------------------------------------------------------------------

table functools_extra177.lru_cache_cache_qualname:
  description: "functools.lru_cache and cache: __qualname__ == __name__; cross-checks confirm they are distinct; wave 301; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: functoolslccq177

  columns: [id, function, args, expected, description]
  rows:
    - [lru_qualname_lru_cache,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — functools.lru_cache is a module-level Python function in Lib/functools.py; its __qualname__ equals its __name__ ('lru_cache') since it has no enclosing class or closure; str.__eq__('lru_cache') returns True; new to extra177"]
    - [cache_qualname_cache,
       "cache.__qualname__.__eq__",
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — functools.cache is a module-level Python function in Lib/functools.py (added in Python 3.9); its __qualname__ equals its __name__ ('cache'); str.__eq__('cache') returns True; new to extra177"]
    - [lru_qualname_ne_cache,
       "lru_cache.__qualname__.__eq__",
       ["cache"],
       false,
       "functools.lru_cache.__qualname__.__eq__('cache') == False — lru_cache.__qualname__ is 'lru_cache', not 'cache'; lru_cache and cache are distinct decorator functions in functools; str.__eq__('cache') returns False; new to extra177"]
    - [cache_qualname_ne_lru_cache,
       "cache.__qualname__.__eq__",
       ["lru_cache"],
       false,
       "functools.cache.__qualname__.__eq__('lru_cache') == False — cache.__qualname__ is 'cache', not 'lru_cache'; cache is the simpler unbounded variant while lru_cache has a configurable maxsize; str.__eq__('lru_cache') returns False; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_UPDATES is a tuple with one element
#
# Wave 301 theme: functools.WRAPPER_UPDATES is a 1-element tuple containing
# '__dict__'; it differs from WRAPPER_ASSIGNMENTS (a 6-element tuple).
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__len__() == 1
# functools.WRAPPER_UPDATES.__contains__('__dict__') == True
# functools.WRAPPER_UPDATES.__class__.__name__ != 'list'
#
# functools.WRAPPER_UPDATES is the tuple of attributes that update_wrapper
# UPDATES (i.e., merges into) on the wrapper function — specifically it
# updates '__dict__' so that the wrapper's instance dict receives the
# wrapped function's instance dict entries. This is distinct from
# WRAPPER_ASSIGNMENTS (which lists attributes that are COPIED, not merged).
# New to extra177.
# ---------------------------------------------------------------------------

table functools_extra177.wrapper_updates_type_and_len:
  description: "functools.WRAPPER_UPDATES: __class__.__name__ 'tuple', __len__() 1, contains '__dict__', not 'list'; wave 301; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswutl177

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_class_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — functools.WRAPPER_UPDATES is a module-level tuple constant ('__dict__',) listing attributes that update_wrapper updates (merges) onto the wrapper function; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra177"]
    - [wrapper_updates_len_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is the single-element tuple ('__dict__',); it contains exactly one attribute name; tuple.__len__() returns 1; new to extra177"]
    - [wrapper_updates_has_dict,
       "WRAPPER_UPDATES.__contains__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — WRAPPER_UPDATES is ('__dict__',); its sole element is '__dict__', the instance namespace dict; tuple.__contains__('__dict__') returns True; new to extra177"]
    - [wrapper_updates_not_list,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["list"],
       false,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('list') == False — WRAPPER_UPDATES is a tuple, NOT a list; Python uses immutable tuples for these module-level attribute constants; str.__eq__('list') returns False; new to extra177"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_UPDATES does NOT contain 'func', '__name__',
# '__wrapped__'; contrasted with WRAPPER_ASSIGNMENTS length
#
# Wave 301 theme: WRAPPER_UPDATES negative contains checks — it contains only
# '__dict__', not the assignment attributes from WRAPPER_ASSIGNMENTS.
#
# functools.WRAPPER_UPDATES.__contains__('__name__') == False
# functools.WRAPPER_UPDATES.__contains__('__wrapped__') == False
# functools.WRAPPER_UPDATES.__contains__('func') == False
# functools.WRAPPER_UPDATES.__contains__('__dict__') == True  (cross-check)
#
# WRAPPER_ASSIGNMENTS contains '__module__', '__name__', '__qualname__',
# '__doc__', '__annotate__', '__type_params__' — none of which are in
# WRAPPER_UPDATES. '__wrapped__' is set by update_wrapper but is not part of
# WRAPPER_UPDATES either. WRAPPER_UPDATES is exclusively ('__dict__',). New
# to extra177.
# ---------------------------------------------------------------------------

table functools_extra177.wrapper_updates_negative_contains:
  description: "functools.WRAPPER_UPDATES: does not contain '__name__', '__wrapped__', 'func'; '__dict__' cross-check; wave 301; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswunc177

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_no_name,
       "WRAPPER_UPDATES.__contains__",
       ["__name__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__name__') == False — '__name__' is in WRAPPER_ASSIGNMENTS (the attributes that are copied), NOT in WRAPPER_UPDATES (the attributes that are merged); WRAPPER_UPDATES is ('__dict__',) only; __contains__('__name__') returns False; new to extra177"]
    - [wrapper_updates_no_wrapped,
       "WRAPPER_UPDATES.__contains__",
       ["__wrapped__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__wrapped__') == False — '__wrapped__' is set directly by update_wrapper (not via WRAPPER_UPDATES); it is not an element of the WRAPPER_UPDATES tuple; __contains__('__wrapped__') returns False; new to extra177"]
    - [wrapper_updates_no_func,
       "WRAPPER_UPDATES.__contains__",
       ["func"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('func') == False — 'func' is an attribute on functools.partial instances (not related to WRAPPER_UPDATES); WRAPPER_UPDATES contains only '__dict__'; __contains__('func') returns False; new to extra177"]
    - [wrapper_updates_has_dict_xcheck,
       "WRAPPER_UPDATES.__contains__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — cross-check confirming '__dict__' is the sole element in WRAPPER_UPDATES; update_wrapper merges the wrapped function's __dict__ into the wrapper's __dict__; __contains__('__dict__') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 5: functools.reduce and cmp_to_key __module__ == '_functools'; and
# WRAPPER_UPDATES vs WRAPPER_ASSIGNMENTS length comparison
#
# Wave 301 theme: reduce and cmp_to_key have __module__ '_functools' (the C
# extension module), NOT 'functools'; and WRAPPER_UPDATES (len 1) is much
# shorter than WRAPPER_ASSIGNMENTS (len 6).
#
# functools.reduce.__module__ == '_functools'
# functools.cmp_to_key.__module__ == '_functools'
# functools.reduce.__module__ != 'functools'
# functools.WRAPPER_UPDATES.__len__() != 6
#
# reduce and cmp_to_key are C builtins from _functools (Modules/_functoolsmodule.c).
# functools.py re-exports them with 'from _functools import reduce, cmp_to_key'.
# Their __module__ reflects the C module that defines them, not the functools
# re-exporting module. WRAPPER_ASSIGNMENTS has 6 elements (not 1). New to extra177.
# ---------------------------------------------------------------------------

table functools_extra177.reduce_cmp_to_key_module:
  description: "functools.reduce and cmp_to_key: __module__ '_functools'; WRAPPER_UPDATES len 1 != WRAPPER_ASSIGNMENTS len 6; wave 301; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrckm177

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — functools.reduce is a C builtin defined in Modules/_functoolsmodule.c and exposed by the _functools C extension module; functools.py re-exports it with 'from _functools import reduce'; its __module__ is '_functools', not 'functools'; str.__eq__('_functools') returns True; new to extra177"]
    - [cmp_to_key_module_functools_c,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — functools.cmp_to_key is a C builtin defined in Modules/_functoolsmodule.c; functools.py re-exports it from the _functools C extension; its __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra177"]
    - [reduce_module_not_functools,
       "reduce.__module__.__eq__",
       ["functools"],
       false,
       "functools.reduce.__module__.__eq__('functools') == False — despite being accessible as functools.reduce, the __module__ is '_functools' (the C extension), not 'functools' (the Python re-exporting module); str.__eq__('functools') returns False; new to extra177"]
    - [wrapper_updates_len_not_6,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 (not 6) — WRAPPER_UPDATES contains only 1 element ('__dict__'), while WRAPPER_ASSIGNMENTS contains 6 elements; these two constants serve different roles in update_wrapper; tuple.__len__() returns 1; new to extra177"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra177
# ---------------------------------------------------------------------------

invariant functools_extra177.reduce_qualname_eq:
  description: "functools.reduce.__qualname__ == 'reduce' — C builtin function whose __qualname__ equals __name__; wave 301; new to extra177"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra177.cmp_to_key_qualname_eq:
  description: "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — C builtin function whose __qualname__ equals __name__; wave 301; new to extra177"
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra177.lru_cache_qualname_eq:
  description: "functools.lru_cache.__qualname__ == 'lru_cache' — module-level Python function whose __qualname__ equals __name__; wave 301; new to extra177"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra177.cache_qualname_eq:
  description: "functools.cache.__qualname__ == 'cache' — module-level Python function whose __qualname__ equals __name__; wave 301; new to extra177"
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra177.wrapper_updates_class_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is the tuple ('__dict__',) listing attributes to merge into the wrapper; wave 301; new to extra177"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra177.wrapper_updates_len_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains exactly one element: '__dict__'; wave 301; new to extra177"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra177.wrapper_updates_has_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element in WRAPPER_UPDATES; update_wrapper merges the wrapped function's __dict__ into the wrapper; wave 301; new to extra177"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

invariant functools_extra177.reduce_module_functools_c:
  description: "functools.reduce.__module__ == '_functools' — reduce is defined in the C extension _functools module; functools re-exports it; wave 301; new to extra177"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true
