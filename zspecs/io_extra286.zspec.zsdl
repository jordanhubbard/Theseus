spec: io_extra286
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io_extra285 covers io.TextIOWrapper class identity and method __qualname__ values."
    - "This spec focuses on io module-level constants and builtin function identity."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — standard POSIX seek constants."
    - "io.DEFAULT_BUFFER_SIZE == 131072 — default buffer size is 128 KiB, not 8192."
    - "io.open.__module__ == '_io' — io.open is the C-level open from the _io extension, not the Python wrapper."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' — io.open is a C builtin function."
    - "io.open.__name__ == 'open' — the builtin's __name__ is the bare function name."
    - "io.open_code.__module__ == '_io' — open_code also lives in the _io C extension."
    - "io.open_code.__class__.__name__ == 'builtin_function_or_method' — open_code is a C builtin function."
    - "io.open_code.__name__ == 'open_code' — the builtin's __name__ is the bare function name."
    - "io.BytesIO.__module__ == '_io' — BytesIO is defined in the C extension module '_io'."
    - "io.StringIO.__module__ == '_io' — StringIO is defined in the C extension module '_io'."
    - "io.FileIO.__module__ == '_io' — FileIO is defined in the C extension module '_io'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io SEEK constants — SEEK_SET=0, SEEK_CUR=1, SEEK_END=2
# These are the standard POSIX seek-whence integer constants exposed in the
# io module for use with file seek() methods.
# ---------------------------------------------------------------------------

table io_extra286.seek_constants:
  description: "io SEEK constants: SEEK_SET==0, SEEK_CUR==1, SEEK_END==2"
  kind: python_call_eq
  category: constants
  id_prefix: seek286

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_val,  SEEK_SET.__eq__,              [0], true,  "io.SEEK_SET == 0 — seek from beginning of file"]
    - [seek_cur_val,  SEEK_CUR.__eq__,              [1], true,  "io.SEEK_CUR == 1 — seek relative to current position"]
    - [seek_end_val,  SEEK_END.__eq__,              [2], true,  "io.SEEK_END == 2 — seek relative to end of file"]
    - [seek_set_not1, SEEK_SET.__eq__,              [1], false, "io.SEEK_SET != 1"]
    - [seek_cur_not0, SEEK_CUR.__eq__,              [0], false, "io.SEEK_CUR != 0"]
    - [seek_end_not0, SEEK_END.__eq__,              [0], false, "io.SEEK_END != 0"]

# ---------------------------------------------------------------------------
# io.open and io.open_code __class__.__name__ and __module__
# Both are builtin_function_or_method objects defined in the _io C extension.
# ---------------------------------------------------------------------------

table io_extra286.open_function_identity:
  description: "io.open and io.open_code are builtin_function_or_method objects from the _io C extension"
  kind: python_call_eq
  category: function_identity
  id_prefix: open286

  columns: [id, function, args, expected, description]
  rows:
    - [open_class,      open.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "io.open.__class__.__name__ == 'builtin_function_or_method'"]
    - [open_module,     open.__module__.__eq__,              ["_io"],                        true, "io.open.__module__ == '_io' — defined in the C extension"]
    - [open_name,       open.__name__.__eq__,                ["open"],                       true, "io.open.__name__ == 'open'"]
    - [opencode_class,  open_code.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "io.open_code.__class__.__name__ == 'builtin_function_or_method'"]
    - [opencode_module, open_code.__module__.__eq__,         ["_io"],                        true, "io.open_code.__module__ == '_io' — defined in the C extension"]
    - [opencode_name,   open_code.__name__.__eq__,           ["open_code"],                  true, "io.open_code.__name__ == 'open_code'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra286.SEEK_SET.is_zero:
  description: "io.SEEK_SET == 0 — the seek-from-beginning constant is integer 0"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra286.SEEK_CUR.is_one:
  description: "io.SEEK_CUR == 1 — the seek-from-current-position constant is integer 1"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra286.SEEK_END.is_two:
  description: "io.SEEK_END == 2 — the seek-from-end constant is integer 2"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra286.DEFAULT_BUFFER_SIZE.is_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size is 128 KiB (131072 bytes), not 8192"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra286.DEFAULT_BUFFER_SIZE.not_8192:
  description: "io.DEFAULT_BUFFER_SIZE != 8192 — the buffer size is 131072, not the smaller 8192-byte value"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [8192]
  expected: false

invariant io_extra286.open.module_is_io:
  description: "io.open.__module__ == '_io' — io.open is provided by the C extension '_io', not the pure-Python 'io' wrapper"
  category: function_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra286.BytesIO.module_is_io:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is defined in the C extension module '_io'"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra286.StringIO.module_is_io:
  description: "io.StringIO.__module__ == '_io' — StringIO is defined in the C extension module '_io'"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true
