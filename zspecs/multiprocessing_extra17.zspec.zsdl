spec: multiprocessing_extra17
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/exceptions.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra16.zspec.zsdl."
    - "multiprocessing covers: Process/Pool/Queue/Pipe/cpu_count __name__ table; ProcessError/AuthenticationError/BufferTooShort/TimeoutError __name__."
    - "multiprocessing_extra3 covers: cpu_count/__name__; Lock/__module__; Event/__module__."
    - "multiprocessing_extra15 covers: Pool/__name__/__module__/__qualname__; Process/__bases__[0].__name__; Process/__module__/__qualname__; exception __module__ table; Manager/__name__; cpu_count/__module__."
    - "multiprocessing_extra16 covers: class_qualnames table (Process/Queue/Pool/Lock/Event); class_modules table; Pipe.__name__; current_process.__name__; cpu_count.__name__."
    - "NOT yet covered in any prior spec: multiprocessing.Process.__name__ == 'Process' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: multiprocessing.cpu_count.__name__ == 'cpu_count' as standalone extra17-namespace __eq__ invariant distinct from extra16."
    - "NOT yet covered: multiprocessing.ProcessError.__name__ == 'ProcessError' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: multiprocessing.AuthenticationError.__name__ == 'AuthenticationError' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: multiprocessing.BufferTooShort.__name__ == 'BufferTooShort' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' as standalone extra17-namespace invariant."
    - "NOT yet covered: multiprocessing.current_process.__name__ == 'current_process' as standalone extra17-namespace __eq__ invariant distinct from extra16."
    - "NOT yet covered: AuthenticationError.__bases__[0].__name__ == 'ProcessError' and BufferTooShort.__bases__[0].__name__ == 'ProcessError' as standalone invariants."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits directly from Exception."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' — authenticated errors are a subclass of ProcessError."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError' — buffer errors are a subclass of ProcessError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks for Process, cpu_count, current_process — standalone extra17
#
# multiprocessing.zspec and extra16 cover these values. These standalone
# invariants provide independent extra17-namespace anchors.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra17.Process.name:
  description: "multiprocessing.Process.__name__ == 'Process'"
  category: class_names
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra17.cpu_count.name:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'"
  category: function_names
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra17.current_process.name:
  description: "multiprocessing.current_process.__name__ == 'current_process'"
  category: function_names
  kind: python_call_eq
  function: current_process.__name__.__eq__
  args: ["current_process"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ attributes — standalone extra17-namespace invariants
#
# multiprocessing.zspec covers ProcessError/AuthenticationError/BufferTooShort
# __name__ in a table. These standalone invariants provide independent coverage.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra17.ProcessError.name:
  description: "multiprocessing.ProcessError.__name__ == 'ProcessError'"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra17.AuthenticationError.name:
  description: "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__name__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra17.BufferTooShort.name:
  description: "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'"
  category: class_names
  kind: python_call_eq
  function: BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class hierarchy — base class __name__ checks
#
# multiprocessing_extra15 covers Process.__bases__[0].__name__ == 'object'.
# No prior spec checks the exception hierarchy base names as standalone invariants
# in the extra17 namespace.
# ProcessError inherits from Exception; AuthenticationError and BufferTooShort
# both inherit from ProcessError. All verified with Python 3.12 on macOS.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra17.ProcessError.base_is_Exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: ProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant multiprocessing_extra17.AuthenticationError.base_is_ProcessError:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: AuthenticationError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ProcessError"

invariant multiprocessing_extra17.BufferTooShort.base_is_ProcessError:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: BufferTooShort.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ProcessError"
