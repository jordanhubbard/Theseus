spec: pathlib_extra75
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra74.zspec.zsdl — covers Path.open/read_text/mkdir/iterdir __kwdefaults__.__class__.__name__=='NoneType'; PosixPath/__class__.__name__=='type'/__module__.__eq__('pathlib')/__qualname__.__eq__('PosixPath'); WindowsPath/__class__.__name__=='type'/__module__.__eq__('pathlib')/__qualname__.__eq__('WindowsPath'); PosixPath/__bases__[0].__name__=='Path'; WindowsPath/__bases__[0].__name__=='Path'."
    - "pathlib_extra73.zspec.zsdl — covers Path.open/__defaults__.__class__.__name__=='tuple' and __len__()==5; PurePosixPath/__class__.__name__=='type'/__module__.__eq__('pathlib')/__qualname__=='PurePosixPath'/__bases__[0].__name__=='PurePath'; PureWindowsPath/__bases__[0].__name__=='PurePath'."
    - "pathlib_extra72.zspec.zsdl — covers PurePath/__bases__[0].__name__=='object'; Path/__bases__[0].__name__=='PurePath'; PurePath/__mro__.__len__()==2; Path/__mro__.__len__()==3."
  notes:
    - "This spec extends pathlib_extra74.zspec.zsdl."
    - "Theme: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__ equality; pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath; Path and PurePath __doc__ class identity."
    - "pathlib.Path.__name__ == 'Path' — simple class name for the primary pathlib class. No prior pathlib spec checks Path.__name__.__eq__('Path') in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__name__ == 'PurePath' — simple class name for the abstract base. No prior pathlib spec checks PurePath.__name__.__eq__('PurePath') in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' — pathlib_extra73 covered PurePosixPath module/qualname/bases but NOT __name__.__eq__. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' — no prior pathlib spec checks PureWindowsPath.__name__.__eq__ in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PosixPath.__name__ == 'PosixPath' — pathlib_extra74 covered PosixPath qualname/module/class/bases but NOT __name__.__eq__. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__module__ == 'pathlib' — Path is defined in the pathlib module. No prior pathlib spec checks Path.__module__.__eq__('pathlib') in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in pathlib. No prior pathlib spec checks PurePath.__module__.__eq__('pathlib') in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__doc__.__class__.__name__ == 'str' — Path has a docstring; its type is str. No prior pathlib spec checks Path.__doc__.__class__.__name__ in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__doc__.__class__.__name__ == 'str' — PurePath has a docstring; type is str. No prior pathlib spec checks PurePath.__doc__.__class__.__name__ in pathlibid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib PurePath class names: __name__.__eq__ for
#   PurePath, PurePosixPath, PureWindowsPath, Path
#
# These are the four PurePath-family classes in pathlib. Their __name__
# attributes record their simple class names:
#   PurePath.__name__        == 'PurePath'
#   PurePosixPath.__name__   == 'PurePosixPath'
#   PureWindowsPath.__name__ == 'PureWindowsPath'
#   Path.__name__            == 'Path'
#
# pathlib_extra73 covered PurePosixPath.__qualname__ but NOT __name__.__eq__.
# pathlib_extra74 covered PosixPath/WindowsPath qualname/module but NOT __name__.
# No prior pathlib spec checks any of these __name__.__eq__ values in
# pathlibid75 namespace. Novel class name identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra75.pathlib_purepath_names:
  description: "PurePath/PurePosixPath/PureWindowsPath/Path __name__.__eq__ — all are top-level pathlib classes with __name__ equal to their simple class names; pathlib_extra73 covered PurePosixPath __qualname__ but not __name__.__eq__; pathlib_extra74 covered PosixPath/WindowsPath qualname/module but not __name__; no prior pathlib spec checks these __name__.__eq__ values in pathlibid75 namespace; novel class name identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibid75names

  columns: [id, function, args, expected]
  rows:
    - [purepath_name,        PurePath.__name__.__eq__,         ["PurePath"],        true]
    - [purepositxpath_name,  PurePosixPath.__name__.__eq__,    ["PurePosixPath"],   true]
    - [purewinpath_name,     PureWindowsPath.__name__.__eq__,  ["PureWindowsPath"], true]
    - [path_name,            Path.__name__.__eq__,             ["Path"],            true]

# ---------------------------------------------------------------------------
# pathlib concrete class names: __name__.__eq__ for PosixPath and WindowsPath
#
# PosixPath and WindowsPath are the concrete instantiable path classes.
# pathlib_extra74 covered PosixPath/WindowsPath __qualname__ and __module__
# but NOT __name__.__eq__ directly:
#   PosixPath.__name__   == 'PosixPath'
#   WindowsPath.__name__ == 'WindowsPath'
#
# No prior pathlib spec checks PosixPath.__name__.__eq__ or
# WindowsPath.__name__.__eq__ in pathlibid75 namespace.
# Novel class name identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra75.pathlib_concrete_names:
  description: "PosixPath/WindowsPath __name__.__eq__ — concrete path classes with __name__ equal to their simple class names; pathlib_extra74 covered their __qualname__/__module__ but NOT __name__.__eq__; no prior pathlib spec checks PosixPath.__name__.__eq__ or WindowsPath.__name__.__eq__ in pathlibid75 namespace; novel class name identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibid75concrete

  columns: [id, function, args, expected]
  rows:
    - [posix_name,    PosixPath.__name__.__eq__,    ["PosixPath"],   true]
    - [windows_name,  WindowsPath.__name__.__eq__,  ["WindowsPath"], true]

# ---------------------------------------------------------------------------
# pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath
#
# All pathlib classes are defined in the pathlib module:
#   Path.__module__            == 'pathlib'
#   PurePath.__module__        == 'pathlib'
#   PurePosixPath.__module__   == 'pathlib'
#   PureWindowsPath.__module__ == 'pathlib'
#
# pathlib_extra73 covered PurePosixPath.__module__.__eq__('pathlib') but NOT
# Path or PurePath module equality. pathlib_extra74 covered PosixPath/WindowsPath
# __module__.__eq__('pathlib'). No prior pathlib spec checks Path.__module__ or
# PurePath.__module__.__eq__('pathlib') in pathlibid75 namespace.
# Novel module identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra75.pathlib_modules:
  description: "Path/PurePath/PurePosixPath/PureWindowsPath __module__.__eq__('pathlib')==True — all four are defined in the pathlib module; pathlib_extra73 covered PurePosixPath __module__ but NOT Path or PurePath; pathlib_extra74 covered PosixPath/WindowsPath module; no prior pathlib spec checks Path/__module__ or PurePath/__module__.__eq__('pathlib') in pathlibid75 namespace; novel module identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibid75modules

  columns: [id, function, args, expected]
  rows:
    - [path_module,          Path.__module__.__eq__,             ["pathlib"], true]
    - [purepath_module,      PurePath.__module__.__eq__,         ["pathlib"], true]
    - [purepositxpath_mod,   PurePosixPath.__module__.__eq__,    ["pathlib"], true]
    - [purewinpath_mod,      PureWindowsPath.__module__.__eq__,  ["pathlib"], true]

# ---------------------------------------------------------------------------
# pathlib.Path and PurePath __doc__ type: __doc__.__class__.__name__ == 'str'
#
# Path and PurePath are documented classes with string docstrings:
#   Path.__doc__.__class__.__name__     == 'str'
#   PurePath.__doc__.__class__.__name__ == 'str'
#
# No prior pathlib spec checks Path.__doc__ or PurePath.__doc__ class name
# in pathlibid75 namespace. Novel doc class-name anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra75.pathlib_doc_class:
  description: "Path/__doc__.__class__.__name__=='str'; PurePath/__doc__.__class__.__name__=='str' — both pathlib classes have string docstrings; __doc__.__class__.__name__ is 'str' for both; no prior pathlib spec checks Path/__doc__ or PurePath/__doc__ class name in pathlibid75 namespace; novel doc class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibid75doc

  columns: [id, function, args, expected]
  rows:
    - [path_doc_str,     Path.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [purepath_doc_str, PurePath.__doc__.__class__.__name__.__eq__,  ["str"], true]

invariant pathlib_extra75.Path_name_Path:
  description: "Path.__name__.__eq__('Path') == True — pathlib.Path is the primary filesystem path class; its simple class name is 'Path' (4 chars); no prior pathlib spec checks Path.__name__.__eq__('Path') in pathlibid75 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra75.PurePath_name_PurePath:
  description: "PurePath.__name__.__eq__('PurePath') == True — pathlib.PurePath is the abstract base class for all pathlib path types; its simple class name is 'PurePath' (8 chars); no prior pathlib spec checks PurePath.__name__.__eq__('PurePath') in pathlibid75 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra75.PurePosixPath_name:
  description: "PurePosixPath.__name__.__eq__('PurePosixPath') == True — pathlib.PurePosixPath is the pure POSIX path class; its simple class name is 'PurePosixPath' (13 chars); pathlib_extra73 covered PurePosixPath __qualname__/__module__/__bases__ but NOT __name__.__eq__; no prior pathlib spec checks PurePosixPath.__name__.__eq__ in pathlibid75 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra75.Path_doc_str:
  description: "Path.__doc__.__class__.__name__.__eq__('str') == True — pathlib.Path is a documented class with a string docstring; __doc__.__class__.__name__ is 'str'; no prior pathlib spec checks Path.__doc__.__class__.__name__ in pathlibid75 namespace; novel doc class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra75.PurePath_module_pathlib:
  description: "PurePath.__module__.__eq__('pathlib') == True — pathlib.PurePath is defined in the pathlib module (Lib/pathlib/__init__.py); __module__ is 'pathlib'; no prior pathlib spec checks PurePath.__module__.__eq__('pathlib') in pathlibid75 namespace; novel module identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true
