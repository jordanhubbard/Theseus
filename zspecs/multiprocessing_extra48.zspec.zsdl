spec: multiprocessing_extra48
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — multiprocessing exceptions"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra47.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process'/__module__=='multiprocessing.context', Queue/__name__=='Queue', Pipe/__name__=='Pipe', Process method qualname lens for start/join/run, function __name__/__module__ equality for cpu_count/current_process/active_children, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, exception __module__ equality, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, class/function qualname string equality tables, context class tables (extra40–extra44), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__qualname__=='type', ProcessError/__class__.__qualname__=='type', current_process/__class__.__qualname__=='function', cpu_count/__class__.__qualname__=='method', Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), ProcessError/__bases__[0].__name__=='Exception', AuthenticationError/__bases__[0].__name__=='ProcessError', ProcessError/__mro__.__len__()==4, AuthenticationError/__mro__.__len__()==5, ProcessError/__module__=='multiprocessing.context', AuthenticationError/__module__=='multiprocessing.context', Queue/__class__.__name__=='method', Pipe/__class__.__name__=='method' (extra47)."
    - "This spec covers: Process/__doc__/__class__/__name__=='str'; ProcessError/__doc__/__class__/__name__=='str'; AuthenticationError/__doc__/__class__/__name__=='str'; multiprocessing module __doc__/__class__/__name__=='str'; Process/__doc__/__class__/__qualname__=='str'; ProcessError/__doc__/__class__/__qualname__=='str'; Process/__doc__/__class__/__module__=='builtins'; BufferTooShort/__bases__[0].__name__=='ProcessError'; BufferTooShort/__mro__.__len__()==5; TimeoutError/__mro__.__len__()==5."
    - "multiprocessing.Process.__doc__.__class__.__name__ == 'str'. Process has a class docstring describing the interface for spawning child processes. Python stores docstrings as plain str instances; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__doc__.__class__.__name__ == 'str'. ProcessError is the root of the multiprocessing exception hierarchy and has a docstring. __doc__ is a plain Python string; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__doc__.__class__.__name__ == 'str'. AuthenticationError has a short docstring; it is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__doc__.__class__.__name__ == 'str'. The multiprocessing module has a module-level docstring. Module docstrings are plain Python strings; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__doc__.__class__.__qualname__ == 'str'. The built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope). Process's docstring is a str instance; str.__qualname__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__doc__.__class__.__qualname__ == 'str'. Same reasoning: ProcessError's docstring is a str; str.__qualname__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__doc__.__class__.__module__ == 'builtins'. The str type is a built-in type defined in the builtins module; every str instance's __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'. BufferTooShort is raised when a result object is too large for a provided buffer. It subclasses ProcessError directly. MRO: [BufferTooShort, ProcessError, Exception, BaseException, object] — five entries. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__mro__.__len__() == 5. MRO: [BufferTooShort, ProcessError, Exception, BaseException, object]. Same depth as AuthenticationError (also 5), as both subclass ProcessError directly, gaining one extra level compared to ProcessError's MRO depth of 4. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__mro__.__len__() == 5. multiprocessing.TimeoutError subclasses ProcessError (not the built-in TimeoutError). MRO: [TimeoutError, ProcessError, Exception, BaseException, object] — five entries. Note: this is the multiprocessing-specific TimeoutError, not the built-in TimeoutError (which subclasses OSError and has a different MRO). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessLookupError does not exist as a module-level attribute and is excluded from this spec, consistent with extra47."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing class __doc__.__class__.__name__ — extra48
#
# All multiprocessing class and exception docstrings are instances of the
# built-in str type. Python compiles docstring literals into __doc__
# attributes whose type is always str:
#   Process.__doc__.__class__.__name__          == 'str'
#   ProcessError.__doc__.__class__.__name__     == 'str'
#   AuthenticationError.__doc__.__class__.__name__ == 'str'
# Prior specs (extra40–extra47) covered __class__.__name__ for the classes
# themselves but never traversed into the __doc__ dimension. Extra48 opens
# the __doc__ dimension for multiprocessing for the first time.
# ---------------------------------------------------------------------------

table multiprocessing_extra48.class_doc_class_name_eq:
  description: "multiprocessing class __doc__.__class__.__name__ string equality in extra48 namespace — class docstrings are str instances"
  kind: python_call_eq
  category: class_names
  id_prefix: mpdoc48clsname

  columns: [id, function, args, expected, description]
  rows:
    - [Process,            Process.__doc__.__class__.__name__.__eq__,            ["str"], true, "Process.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string"]
    - [ProcessError,       ProcessError.__doc__.__class__.__name__.__eq__,       ["str"], true, "ProcessError.__doc__.__class__.__name__ == 'str' — exception class docstring is a plain Python string"]
    - [AuthenticationError, AuthenticationError.__doc__.__class__.__name__.__eq__, ["str"], true, "AuthenticationError.__doc__.__class__.__name__ == 'str' — exception class docstring is a plain Python string"]

# ---------------------------------------------------------------------------
# multiprocessing module __doc__.__class__.__name__ — extra48
#
# The multiprocessing module carries a module-level docstring. Module
# docstrings are plain Python strings; __doc__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra48.module_doc_class_name_eq:
  description: "multiprocessing.__doc__.__class__.__name__ == 'str' — module-level docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing class __doc__.__class__.__qualname__ — extra48
#
# The built-in str type has __qualname__ == __name__ == 'str' (no enclosing
# scope). Therefore every docstring (a str instance) has
# __doc__.__class__.__qualname__ == 'str'. Verified here for Process and
# ProcessError as representative samples:
#   Process.__doc__.__class__.__qualname__      == 'str'
#   ProcessError.__doc__.__class__.__qualname__ == 'str'
# ---------------------------------------------------------------------------

table multiprocessing_extra48.doc_class_qualname_eq:
  description: "multiprocessing __doc__.__class__.__qualname__ string equality in extra48 namespace — Process and ProcessError docstrings have __class__.__qualname__ == 'str'"
  kind: python_call_eq
  category: class_names
  id_prefix: mpdoc48clsqual

  columns: [id, function, args, expected, description]
  rows:
    - [Process,      Process.__doc__.__class__.__qualname__.__eq__,      ["str"], true, "Process.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]
    - [ProcessError, ProcessError.__doc__.__class__.__qualname__.__eq__, ["str"], true, "ProcessError.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]

# ---------------------------------------------------------------------------
# multiprocessing Process __doc__.__class__.__module__ — extra48
#
# The str type is a built-in type defined in the builtins module. Every str
# instance's __class__.__module__ == 'builtins':
#   Process.__doc__.__class__.__module__ == 'builtins'
# ---------------------------------------------------------------------------

invariant multiprocessing_extra48.Process_doc_class_module_eq:
  description: "multiprocessing.Process.__doc__.__class__.__module__ == 'builtins' — str is a built-in type; every str instance has __class__.__module__ == 'builtins'"
  category: module_identity
  kind: python_call_eq
  function: Process.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.BufferTooShort exception hierarchy — extra48
#
# BufferTooShort is one of the four multiprocessing exception subclasses.
# It subclasses ProcessError directly:
#   BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# Its MRO has five entries:
#   [BufferTooShort, ProcessError, Exception, BaseException, object]
# This mirrors AuthenticationError's MRO depth (also 5), as both are
# direct subclasses of ProcessError (one level deeper than ProcessError's
# own MRO depth of 4).
# NOTE: function values containing '[' MUST be double-quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra48.BufferTooShort_bases_eq:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort subclasses ProcessError directly; raised when a receive buffer is too small"
  category: exception_hierarchy
  kind: python_call_eq
  function: "BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra48.BufferTooShort_mro_len:
  description: "multiprocessing.BufferTooShort.__mro__.__len__() == 5 — MRO: [BufferTooShort, ProcessError, Exception, BaseException, object]; same depth as AuthenticationError"
  category: exception_hierarchy
  kind: python_call_eq
  function: BufferTooShort.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# multiprocessing.TimeoutError MRO — extra48
#
# multiprocessing.TimeoutError is the multiprocessing-specific timeout
# exception. Unlike the built-in TimeoutError (which subclasses OSError),
# multiprocessing.TimeoutError subclasses ProcessError directly:
#   MRO: [TimeoutError, ProcessError, Exception, BaseException, object]
#   __mro__.__len__() == 5
# This is distinct from the built-in TimeoutError's MRO:
#   [TimeoutError, OSError, Exception, BaseException, object] (also 5,
#   but different chain). The multiprocessing TimeoutError's intermediate
#   node is ProcessError, not OSError.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra48.TimeoutError_mro_len:
  description: "multiprocessing.TimeoutError.__mro__.__len__() == 5 — MRO: [TimeoutError, ProcessError, Exception, BaseException, object]; multiprocessing-specific TimeoutError subclasses ProcessError, not built-in OSError"
  category: exception_hierarchy
  kind: python_call_eq
  function: TimeoutError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Standalone invariants — extra48
# ---------------------------------------------------------------------------

invariant multiprocessing_extra48.Process_doc_class_name_eq:
  description: "multiprocessing.Process.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: Process.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra48.ProcessError_doc_class_name_eq:
  description: "multiprocessing.ProcessError.__doc__.__class__.__name__ == 'str' — exception class docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra48.AuthenticationError_doc_class_name_eq:
  description: "multiprocessing.AuthenticationError.__doc__.__class__.__name__ == 'str' — exception class docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra48.Process_doc_class_qualname_eq:
  description: "multiprocessing.Process.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'; no enclosing scope"
  category: class_names
  kind: python_call_eq
  function: Process.__doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra48.ProcessError_doc_class_qualname_eq:
  description: "multiprocessing.ProcessError.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'; no enclosing scope"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true
