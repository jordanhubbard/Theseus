spec: inspect_extra284
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect module-level metadata: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __file__, and __all__ type and length."
    - "inspect.__name__ == 'inspect' — module's own name attribute. Verified with Python 3.14.3."
    - "inspect.__package__ == '' — empty string; inspect is a top-level pure-Python module. Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' — ModuleSpec.name matches the module name. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure-Python module loaded from inspect.py. Verified with Python 3.14.3."
    - "inspect.__file__.endswith('inspect.py') == True — the module source file ends with inspect.py. Verified with Python 3.14.3."
    - "type(inspect.__all__).__name__ == 'list' — __all__ is a list of public API names. Verified with Python 3.14.3."
    - "len(inspect.__all__) == 107 — inspect exports exactly 107 public names in Python 3.14.3. Verified with Python 3.14.3."
    - "len(inspect.__name__) == 7 — 'inspect' has 7 characters. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module-level identity metadata
#
# inspect.__name__ == 'inspect'
# inspect.__package__ == ''            (empty string, top-level module)
# inspect.__spec__.name == 'inspect'
# inspect.__loader__.__class__.__name__ == 'SourceFileLoader'
# ---------------------------------------------------------------------------

table inspect_extra284.module_metadata:
  description: "inspect module-level metadata: __name__, __package__, __spec__.name, __loader__.__class__.__name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex284mm

  columns: [id, function, args, expected, description]
  rows:
    - [mm_name_eq,
       __name__.__eq__,
       ["inspect"],
       true,
       "inspect.__name__ == 'inspect' — module's own name attribute; verified with Python 3.14.3"]
    - [mm_pkg_eq,
       __package__.__eq__,
       [""],
       true,
       "inspect.__package__ == '' — empty string; inspect is a top-level module; verified with Python 3.14.3"]
    - [mm_spec_name_eq,
       __spec__.name.__eq__,
       ["inspect"],
       true,
       "inspect.__spec__.name == 'inspect' — ModuleSpec.name matches the module name; verified with Python 3.14.3"]
    - [mm_loader_cls_eq,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure-Python module; verified with Python 3.14.3"]
    - [mm_name_len,
       __name__.__len__,
       [],
       7,
       "inspect.__name__.__len__() == 7 — 'inspect' has 7 characters; verified with Python 3.14.3"]
    - [mm_pkg_len,
       __package__.__len__,
       [],
       0,
       "inspect.__package__.__len__() == 0 — empty package string has length 0; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect __all__ metadata
#
# type(inspect.__all__).__name__ == 'list'  (__all__ is a plain list)
# len(inspect.__all__) == 107               (107 public names in Python 3.14.3)
# inspect.__file__.endswith('inspect.py') == True
# inspect.__file__.__contains__('inspect') == True
# ---------------------------------------------------------------------------

table inspect_extra284.module_all_and_file:
  description: "inspect.__all__ is a list of length 107; __file__ ends with 'inspect.py'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex284af

  columns: [id, function, args, expected, description]
  rows:
    - [af_all_type,
       __all__.__class__.__name__.__eq__,
       ["list"],
       true,
       "inspect.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list; verified with Python 3.14.3"]
    - [af_all_len,
       __all__.__len__,
       [],
       107,
       "inspect.__all__.__len__() == 107 — exactly 107 public names in inspect.__all__ on Python 3.14.3; verified with Python 3.14.3"]
    - [af_file_endswith,
       __file__.endswith,
       ["inspect.py"],
       true,
       "inspect.__file__.endswith('inspect.py') == True — source file path ends with inspect.py; verified with Python 3.14.3"]
    - [af_file_contains,
       __file__.__contains__,
       ["inspect"],
       true,
       "inspect.__file__.__contains__('inspect') == True — source file path contains the module name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra284
# ---------------------------------------------------------------------------

invariant inspect_extra284.module_name_is_inspect:
  description: "inspect.__name__ == 'inspect' — module name attribute; new to extra284"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra284.module_package_is_empty_string:
  description: "inspect.__package__ == '' — empty string; inspect is a top-level module; new to extra284"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant inspect_extra284.spec_name_is_inspect:
  description: "inspect.__spec__.name == 'inspect' — ModuleSpec.name matches __name__; new to extra284"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra284.loader_is_source_file_loader:
  description: "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure-Python module loaded from a .py source file; new to extra284"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra284.file_endswith_inspect_py:
  description: "inspect.__file__.endswith('inspect.py') == True — the module source ends with inspect.py; new to extra284"
  category: identity
  kind: python_call_eq
  function: __file__.endswith
  args: ["inspect.py"]
  expected: true

invariant inspect_extra284.all_is_list:
  description: "inspect.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list; new to extra284"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant inspect_extra284.all_len_is_107:
  description: "inspect.__all__.__len__() == 107 — inspect exports exactly 107 public names on Python 3.14.3; new to extra284"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 107

invariant inspect_extra284.name_len_is_7:
  description: "inspect.__name__.__len__() == 7 — 'inspect' has 7 characters; new to extra284"
  category: identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7
