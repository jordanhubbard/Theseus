spec: primes
version: ">=0.0.1"
backend: node(primes)

docs: https://www.npmjs.com/package/primes

provenance:
  derived_from:
    - "primes README — https://www.npmjs.com/package/primes"
    - "Test vectors verified with primes via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "primes source"
  notes:
    - "primes is an npm package. Install: npm install primes"
    - "Returns an array of all prime numbers strictly less than n."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of numbers."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table primes.primes:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: primes

  columns: [id, args, expected]
  rows:
    - [lt_11,  [11],  [2, 3, 5, 7]]
    - [lt_6,   [6],   [2, 3, 5]]
    - [lt_3,   [3],   [2]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:53:10Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
