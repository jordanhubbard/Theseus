spec: asyncio_extra281
version: ">=3.11"
backend: python_module(asyncio.runners)

docs: https://docs.python.org/3/library/asyncio-runner.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-runner.html — Python asyncio.runners module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py"
    - "asyncio_extra280.zspec.zsdl — covers asyncio.exceptions module identity; CancelledError, InvalidStateError, SendfileNotAvailableError class identity"
  notes:
    - "This spec covers: asyncio.runners module identity (__name__, __spec__.name, __name__.__len__()); asyncio.run function identity (__module__, __qualname__, __name__); asyncio.Runner class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); Runner method qualnames (run, close, get_loop, __enter__, __exit__). NEW in extra281: asyncio.runners.__name__=='asyncio.runners' (len=15); asyncio.runners.__spec__.name=='asyncio.runners'; asyncio.run.__module__=='asyncio.runners'; asyncio.run.__qualname__=='run'; asyncio.run.__name__=='run' (len=3); asyncio.Runner.__name__=='Runner'; asyncio.Runner.__module__=='asyncio.runners'; asyncio.Runner.__qualname__=='Runner'; asyncio.Runner.__bases__[0].__name__=='object'; asyncio.Runner.__mro__.__len__()==2 ([Runner, object]); Runner.run.__qualname__=='Runner.run'; Runner.close.__qualname__=='Runner.close'; Runner.get_loop.__qualname__=='Runner.get_loop'; Runner.__enter__.__qualname__=='Runner.__enter__'; Runner.__exit__.__qualname__=='Runner.__exit__'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.runners.__name__.__len__() == 15 — 'asyncio.runners' is 15 characters: 'asyncio'=7+'.runners'=8=15. asyncio.runners.__spec__.name is also 'asyncio.runners' (len=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Runner.__mro__.__len__() == 2 — Runner's MRO is [Runner, object] (length=2); Runner is a direct subclass of object with no intermediate base class; asyncio.Runner is the high-level API for running async code added in Python 3.11 (PEP 667). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Runner method qualnames: Runner.run.__qualname__=='Runner.run' (len=10); Runner.close.__qualname__=='Runner.close' (len=12); Runner.get_loop.__qualname__=='Runner.get_loop' (len=15, longest); Runner.__enter__.__qualname__=='Runner.__enter__' (len=16 with dunders); Runner.__exit__.__qualname__=='Runner.__exit__' (len=15, same as get_loop). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.runners module identity — extra281
#
# asyncio.runners.__name__             == 'asyncio.runners'
# asyncio.runners.__spec__.name        == 'asyncio.runners'
# asyncio.runners.__name__.__len__()   == 15
# asyncio.run.__module__               == 'asyncio.runners'
# asyncio.run.__qualname__             == 'run'
# asyncio.run.__name__                 == 'run'
# ---------------------------------------------------------------------------

table asyncio_extra281.asyncio_runners_module_identity:
  description: "asyncio.runners module identity and asyncio.run function identity checks in asynciorun281 namespace — asyncio.runners is defined in Lib/asyncio/runners.py; its __name__ is 'asyncio.runners' (len=15: 'asyncio'=7+'.runners'=8); __spec__.name is also 'asyncio.runners'; __name__.__len__()==15; asyncio.run is defined in asyncio.runners (added in Python 3.7); asyncio.run.__module__.__eq__('asyncio.runners')==True; asyncio.run.__qualname__.__eq__('run')==True (module-level function, qualname equals __name__); asyncio.run.__name__.__eq__('run')==True; asyncio.run.__name__.__len__()==3 ('run'=3, shortest name in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciorun281

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   asyncio.runners.__name__.__eq__,        ["asyncio.runners"],  true, "asyncio.runners.__name__ == 'asyncio.runners'; verified with Python 3.14.3"]
    - [mod_spec_eq,   asyncio.runners.__spec__.name.__eq__,   ["asyncio.runners"],  true, "asyncio.runners.__spec__.name == 'asyncio.runners'; verified with Python 3.14.3"]
    - [mod_name_len,  asyncio.runners.__name__.__len__,       [],                   15,   "asyncio.runners.__name__.__len__() == 15 ('asyncio.runners'=15); verified with Python 3.14.3"]
    - [run_mod_eq,    asyncio.run.__module__.__eq__,          ["asyncio.runners"],  true, "asyncio.run.__module__ == 'asyncio.runners' (defined in Lib/asyncio/runners.py); verified with Python 3.14.3"]
    - [run_qn_eq,     asyncio.run.__qualname__.__eq__,        ["run"],              true, "asyncio.run.__qualname__ == 'run' (module-level function); verified with Python 3.14.3"]
    - [run_name_eq,   asyncio.run.__name__.__eq__,            ["run"],              true, "asyncio.run.__name__ == 'run'; verified with Python 3.14.3"]
    - [run_name_len,  asyncio.run.__name__.__len__,           [],                   3,    "asyncio.run.__name__.__len__() == 3 ('run'=3, shortest name in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Runner class identity and method qualnames — extra281
#
# Runner.__name__                     == 'Runner'
# Runner.__module__                   == 'asyncio.runners'
# Runner.__qualname__                 == 'Runner'
# Runner.__bases__[0].__name__        == 'object'
# Runner.__mro__.__len__()            == 2
# Runner.run.__qualname__             == 'Runner.run'
# Runner.close.__qualname__           == 'Runner.close'
# Runner.get_loop.__qualname__        == 'Runner.get_loop'
# Runner.__enter__.__qualname__       == 'Runner.__enter__'
# ---------------------------------------------------------------------------

table asyncio_extra281.asyncio_Runner_class_identity:
  description: "asyncio.Runner class identity and method qualname checks in asynciorun281a namespace — asyncio.Runner is defined in Lib/asyncio/runners.py; added in Python 3.11 as a context manager for running async coroutines; Runner.__name__.__eq__('Runner')==True; Runner.__module__.__eq__('asyncio.runners')==True (same module as asyncio.run); Runner.__qualname__.__eq__('Runner')==True; Runner.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, no intermediate base); Runner.__mro__.__len__()==2 ([Runner, object], shortest possible MRO for a new-style class); Runner.run.__qualname__.__eq__('Runner.run')==True (len=10: 'Runner.'=7+'run'=3); Runner.close.__qualname__.__eq__('Runner.close')==True (len=12: 'Runner.'=7+'close'=5); Runner.get_loop.__qualname__.__eq__('Runner.get_loop')==True (len=15: 'Runner.'=7+'get_loop'=8); Runner.__enter__.__qualname__.__eq__('Runner.__enter__')==True (context-manager entry); Runner.__name__.__len__()==6 ('Runner'=6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciorun281a

  columns: [id, function, args, expected, description]
  rows:
    - [runner_name_eq,    asyncio.Runner.__name__.__eq__,                    ["Runner"],           true, "asyncio.Runner.__name__ == 'Runner'; verified with Python 3.14.3"]
    - [runner_mod_eq,     asyncio.Runner.__module__.__eq__,                  ["asyncio.runners"],  true, "asyncio.Runner.__module__ == 'asyncio.runners'; verified with Python 3.14.3"]
    - [runner_qn_eq,      asyncio.Runner.__qualname__.__eq__,                ["Runner"],           true, "asyncio.Runner.__qualname__ == 'Runner' (module-level class); verified with Python 3.14.3"]
    - [runner_base0_eq,   "asyncio.Runner.__bases__[0].__name__.__eq__",     ["object"],           true, "asyncio.Runner.__bases__[0].__name__ == 'object' (direct subclass of object); verified with Python 3.14.3"]
    - [runner_mro_len,    asyncio.Runner.__mro__.__len__,                    [],                   2,    "asyncio.Runner.__mro__.__len__() == 2 — [Runner, object]; verified with Python 3.14.3"]
    - [runner_name_len,   asyncio.Runner.__name__.__len__,                   [],                   6,    "asyncio.Runner.__name__.__len__() == 6 ('Runner'=6); verified with Python 3.14.3"]
    - [run_qn_eq,         asyncio.Runner.run.__qualname__.__eq__,            ["Runner.run"],       true, "asyncio.Runner.run.__qualname__ == 'Runner.run' (len=10); verified with Python 3.14.3"]
    - [close_qn_eq,       asyncio.Runner.close.__qualname__.__eq__,          ["Runner.close"],     true, "asyncio.Runner.close.__qualname__ == 'Runner.close' (len=12); verified with Python 3.14.3"]
    - [get_loop_qn_eq,    asyncio.Runner.get_loop.__qualname__.__eq__,       ["Runner.get_loop"],  true, "asyncio.Runner.get_loop.__qualname__ == 'Runner.get_loop' (len=15); verified with Python 3.14.3"]
    - [enter_qn_eq,       asyncio.Runner.__enter__.__qualname__.__eq__,      ["Runner.__enter__"], true, "asyncio.Runner.__enter__.__qualname__ == 'Runner.__enter__' (context-manager entry); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra281
# ---------------------------------------------------------------------------

invariant asyncio_extra281.runners_module_name_eq:
  description: "asyncio.runners.__name__.__eq__('asyncio.runners') returns True — asyncio.runners is defined in Lib/asyncio/runners.py; its __name__ is 'asyncio.runners' (len=15: 'asyncio'=7+'.runners'=8=15); asyncio.runners.__spec__.name is also 'asyncio.runners'; asyncio.runners contains two top-level public symbols: the asyncio.run() function (added Python 3.7) and the asyncio.Runner class (added Python 3.11); asyncio.run.__module__ is 'asyncio.runners' confirming both live in the same module; NEW in extra281: first standalone asyncio.runners module name invariant in asynciorun281 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.runners.__name__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra281.run_module_is_asyncio_runners:
  description: "asyncio.run.__module__.__eq__('asyncio.runners') returns True — asyncio.run is defined in Lib/asyncio/runners.py; its __module__ attribute reports 'asyncio.runners' (len=15); asyncio.run is the standard high-level entry point for running a top-level coroutine; asyncio.run.__qualname__ is 'run' (module-level, no class prefix); asyncio.run.__name__ is 'run' (len=3); asyncio.run is re-exported into the asyncio namespace from asyncio.runners, but its __module__ always points to its defining module; NEW in extra281: first standalone asyncio.run.__module__ invariant in asynciorun281 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra281.Runner_module_is_asyncio_runners:
  description: "asyncio.Runner.__module__.__eq__('asyncio.runners') returns True — asyncio.Runner is defined in Lib/asyncio/runners.py; its __module__ is 'asyncio.runners' (len=15, same as asyncio.run.__module__); asyncio.Runner is a context manager class that manages the lifecycle of an event loop; asyncio.Runner.__bases__[0].__name__ is 'object' (direct subclass); asyncio.Runner.__mro__.__len__() is 2 ([Runner, object]); asyncio.Runner.__name__.__len__() is 6 ('Runner'=6); NEW in extra281: first standalone Runner.__module__ invariant in asynciorun281a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Runner.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra281.Runner_mro_len_is_2:
  description: "asyncio.Runner.__mro__.__len__() == 2 — Runner's MRO is [Runner, object] (length=2); Runner is a direct subclass of object with no intermediate base; this is the shortest possible MRO for a new-style Python class; asyncio.Runner was added in Python 3.11 to provide a reusable event loop manager for use as a context manager; asyncio.Runner.__bases__[0].__name__ is 'object'; asyncio.Runner.__module__ is 'asyncio.runners'; compare: asyncio.exceptions.CancelledError.__mro__.__len__() is 3 (has BaseException in chain); NEW in extra281: first standalone Runner MRO length invariant in asynciorun281a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Runner.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra281.Runner_run_qualname_eq:
  description: "asyncio.Runner.run.__qualname__.__eq__('Runner.run') returns True — Runner.run.__qualname__ is 'Runner.run' (len=10: 'Runner.'=7+'run'=3); this is the shortest method qualname in this spec; asyncio.Runner.run is the primary method for running a coroutine within the managed event loop; Runner.run.__qualname__ encodes that 'run' is defined as a method on the 'Runner' class; compare qualname lengths: Runner.run=10, Runner.close=12, Runner.get_loop=15; asyncio.Runner.__module__ is 'asyncio.runners'; NEW in extra281: first standalone Runner.run qualname invariant in asynciorun281a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Runner.run.__qualname__.__eq__
  args: ["Runner.run"]
  expected: true

invariant asyncio_extra281.runners_name_len_is_15:
  description: "asyncio.runners.__name__.__len__() == 15 — asyncio.runners.__name__ is 'asyncio.runners' (15 characters: 'asyncio'=7+'.runners'=8=15); asyncio.runners.__spec__.name is also 'asyncio.runners' (len=15); compare module name lengths within asyncio: asyncio.runners=15, asyncio.exceptions=18 (longer), asyncio.events (14); asyncio.runners.__package__ is 'asyncio' (parent package); NEW in extra281: first standalone asyncio.runners name length invariant in asynciorun281 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.runners.__name__.__len__
  args: []
  expected: 15
