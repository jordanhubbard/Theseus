spec: itertools_extra2236
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2236: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__ presence in class dicts."
    - "All itertools types are C extension types implemented in the _itertools module. C extension types do not use __slots__ in the Python sense; they use tp_members/tp_getset instead."
    - "None of the itertools types have __slots__, __weakref__, __dict__, or __abstractmethods__ in their class dicts. This is uniform across all itertools iterator types."
    - "All itertools C types define __new__ (via tp_new) but not __init__ (no tp_init); construction is handled entirely by __new__."
    - "itertools.chain, cycle, count, zip_longest, product, combinations, permutations, islice, repeat all share this pattern."
    - "itertools.accumulate, starmap, groupby, compress, dropwhile, takewhile, filterfalse, pairwise, combinations_with_replacement also share this pattern."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2236.chain_slot_protocol:
  description: "itertools.chain slot descriptor protocol — C extension type, no __slots__, no __weakref__, no __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2236

  columns: [id, function, args, expected]
  rows:
    - ["it2236001", "itertools.chain.__dict__.__contains__", ["__slots__"], false]
    - ["it2236002", "itertools.chain.__dict__.__contains__", ["__weakref__"], false]
    - ["it2236003", "itertools.chain.__dict__.__contains__", ["__dict__"], false]
    - ["it2236004", "itertools.chain.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2236005", "itertools.chain.__dict__.__contains__", ["__init__"], false]
    - ["it2236006", "itertools.chain.__dict__.__contains__", ["__new__"], true]

