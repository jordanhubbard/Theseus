spec: re_extra1951
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "re.Pattern and re.Match are C-implemented types; neither defines iteration protocol methods."
    - "re.error is an alias for re.PatternError in Python 3.13+; its __dict__ defines none of the five methods."
    - "re.RegexFlag is an IntFlag enum; __contains__ for flag membership lives in the metaclass, not RegexFlag.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table re_extra1951.contains_protocol:
  description: "re types __contains__ dict-presence checks — none define __contains__ in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1951

  columns: [id, function, args, expected]
  rows:
    - ["re1951001", "re.Pattern.__dict__.__contains__",   ["__contains__"], false]
    - ["re1951002", "re.Match.__dict__.__contains__",     ["__contains__"], false]
    - ["re1951003", "re.error.__dict__.__contains__",     ["__contains__"], false]
    - ["re1951004", "re.RegexFlag.__dict__.__contains__", ["__contains__"], false]

