invariant itertools_extra178.batched_name_batched:
  description: "itertools.batched.__name__ == 'batched' — C extension type in itertoolsmodule.c (Python 3.12+) with __name__ 'batched' (7 chars); new to extra178"
  kind: python_call_eq
