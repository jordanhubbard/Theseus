spec: itertools_extra178
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain class methods — itertools.chain.from_iterable.__name__=='from_iterable' (len=13); itertools.chain.from_iterable.__qualname__=='chain.from_iterable' (len=19); itertools.chain.__doc__.__class__.__name__=='str'; itertools.compress.__name__=='compress' (len=8); itertools.compress.__mro__.__len__()==2; itertools.pairwise.__name__=='pairwise' (len=8; same as compress); itertools.pairwise.__mro__.__len__()==2; itertools.batched.__name__=='batched' (len=7)."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' — from_iterable is a classmethod descriptor on the chain C extension type in itertoolsmodule.c that makes a chain from a single iterable of iterables; its __name__ is 'from_iterable', 13 characters. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — the qualified name includes the enclosing class; __qualname__ is 'chain.from_iterable', 19 characters. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — the chain type has a __doc__ string; its __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' — compress is a C extension type in itertoolsmodule.c that filters elements of an iterable based on a selectors iterable; its __name__ is 'compress', 8 characters. Verified with Python 3.14.3."
    - "itertools.compress.__mro__.__len__() == 2 — compress is a C extension type inheriting directly from object; its MRO is (compress, object). Verified with Python 3.14.3."
    - "itertools.pairwise.__name__ == 'pairwise' — pairwise is a C extension type in itertoolsmodule.c (added in Python 3.10) that returns successive overlapping pairs from an iterable; its __name__ is 'pairwise', 8 characters, same length as 'compress'. Verified with Python 3.14.3."
    - "itertools.pairwise.__mro__.__len__() == 2 — pairwise is a C extension type inheriting directly from object; its MRO is (pairwise, object). Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' — batched is a C extension type in itertoolsmodule.c (added in Python 3.12) that batches elements into tuples of a given length; its __name__ is 'batched', 7 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain.from_iterable __name__ and __qualname__
#
# itertools.chain.from_iterable.__name__ == 'from_iterable'
# itertools.chain.from_iterable.__name__.__len__() == 13
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
# itertools.chain.from_iterable.__qualname__.__len__() == 19
#
# chain.from_iterable is a classmethod on the chain C extension type that
# creates a chain from a single iterable of iterables. Its __name__ is
# 'from_iterable' (13 chars) and __qualname__ is 'chain.from_iterable' (19
# chars). New to extra178.
# ---------------------------------------------------------------------------

table itertools_extra178.chain_from_iterable_name_and_qualname:
  description: "itertools.chain.from_iterable.__name__ 'from_iterable' len 13; __qualname__ 'chain.from_iterable' len 19; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain178

  columns: [id, function, args, expected, description]
  rows:
    - [chain_from_iterable_name_eq,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — itertools.chain.from_iterable is a classmethod on the chain C extension type in itertoolsmodule.c that makes a flattened chain from a single iterable whose elements are themselves iterables; its __name__ is 'from_iterable'; str.__eq__('from_iterable') returns True; new to extra178"]
    - [chain_from_iterable_name_len_13,
       "chain.from_iterable.__name__.__len__",
       [],
       13,
       "itertools.chain.from_iterable.__name__.__len__() == 13 — the name 'from_iterable' has exactly 13 characters: f-r-o-m-_-i-t-e-r-a-b-l-e; str.__len__() returns 13; new to extra178"]
    - [chain_from_iterable_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — the __qualname__ of chain.from_iterable includes the enclosing class name giving 'chain.from_iterable'; str.__eq__('chain.from_iterable') returns True; new to extra178"]
    - [chain_from_iterable_qualname_len_19,
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — the qualified name 'chain.from_iterable' has exactly 19 characters: c-h-a-i-n-.-f-r-o-m-_-i-t-e-r-a-b-l-e; str.__len__() returns 19; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.__doc__ class name and itertools.compress __name__
#
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.compress.__name__ == 'compress'
# itertools.compress.__name__.__len__() == 8
# itertools.compress.__mro__.__len__() == 2
#
# chain's __doc__ is a regular Python str. compress is a C extension type
# whose __name__ is 'compress' (8 chars). compress's MRO is (compress, object),
# length 2. New to extra178.
# ---------------------------------------------------------------------------

table itertools_extra178.chain_doc_class_and_compress_name:
  description: "itertools.chain.__doc__.__class__.__name__ 'str'; compress.__name__ 'compress' len 8; compress.__mro__ len 2; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain178

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_str,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — itertools.chain is a C extension type in itertoolsmodule.c with a documentation string; its __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra178"]
    - [compress_name_eq,
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — itertools.compress is a C extension type in itertoolsmodule.c that makes an iterator that filters elements from an iterable based on a corresponding selectors iterable; its __name__ is 'compress'; str.__eq__('compress') returns True; new to extra178"]
    - [compress_name_len_8,
       "compress.__name__.__len__",
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — the name 'compress' has exactly 8 characters: c-o-m-p-r-e-s-s; str.__len__() returns 8; new to extra178"]
    - [compress_mro_len_2,
       "compress.__mro__.__len__",
       [],
       2,
       "itertools.compress.__mro__.__len__() == 2 — itertools.compress is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (compress, object), a tuple of length 2; tuple.__len__() returns 2; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: itertools.pairwise __name__ and __mro__ and itertools.batched __name__
#
# itertools.pairwise.__name__ == 'pairwise'
# itertools.pairwise.__name__.__len__() == 8
# itertools.pairwise.__mro__.__len__() == 2
# itertools.batched.__name__ == 'batched'
#
# pairwise (added in Python 3.10) has __name__ 'pairwise' (8 chars, same as
# 'compress'). Its MRO is (pairwise, object), length 2. batched (added in
# Python 3.12) has __name__ 'batched' (7 chars). New to extra178.
# ---------------------------------------------------------------------------

table itertools_extra178.pairwise_name_mro_and_batched_name:
  description: "itertools.pairwise.__name__ 'pairwise' len 8 (same as compress); pairwise.__mro__ len 2; batched.__name__ 'batched' len 7; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain178

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_name_eq,
       "pairwise.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — itertools.pairwise is a C extension type in itertoolsmodule.c (added in Python 3.10) that returns successive overlapping pairs taken from an iterable; its __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra178"]
    - [pairwise_name_len_8,
       "pairwise.__name__.__len__",
       [],
       8,
       "itertools.pairwise.__name__.__len__() == 8 — the name 'pairwise' has exactly 8 characters: p-a-i-r-w-i-s-e; same length as 'compress' (8); str.__len__() returns 8; new to extra178"]
    - [pairwise_mro_len_2,
       "pairwise.__mro__.__len__",
       [],
       2,
       "itertools.pairwise.__mro__.__len__() == 2 — itertools.pairwise is a C extension type defined in itertoolsmodule.c that inherits directly from object; its __mro__ is (pairwise, object), a tuple of length 2; tuple.__len__() returns 2; new to extra178"]
    - [batched_name_eq,
       "batched.__name__.__eq__",
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — itertools.batched is a C extension type in itertoolsmodule.c (added in Python 3.12) that batches elements of an iterable into tuples of at most n elements; its __name__ is 'batched'; str.__eq__('batched') returns True; new to extra178"]

