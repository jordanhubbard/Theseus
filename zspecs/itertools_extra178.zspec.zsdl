invariant itertools_extra178.pairwise_name_pairwise:
  description: "itertools.pairwise.__name__ == 'pairwise' — C extension type in itertoolsmodule.c (Python 3.10+) with __name__ 'pairwise' (8 chars, same as compress); new to extra178"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
