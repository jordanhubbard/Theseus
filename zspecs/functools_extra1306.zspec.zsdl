spec: functools_extra1306
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and counts."
    - "functools.reduce() with no args raises TypeError."
    - "functools.reduce(42) with non-callable raises TypeError."
    - "functools.reduce(None, [1,2]) with None as function raises TypeError."
    - "functools.reduce(lambda a,b:a+b, []) with empty sequence raises TypeError (no initial value)."
    - "functools.partial() with no args raises TypeError."
    - "functools.partial(42) with non-callable raises TypeError."
    - "functools.cmp_to_key() with no args raises TypeError."
    - "functools.wraps() with no args raises TypeError."
    - "functools.lru_cache('bad') raises TypeError when applied as decorator."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra1306.reduce_type_errors:
  description: "functools.reduce raises TypeError on wrong argument types or counts"
  kind: python_call_raises
  category: type_errors
  id_prefix: fu1306re
  columns: [id, function, args, exception]
  rows:
    - [fu1306re001, functools.reduce, [],               "TypeError"]
    - [fu1306re002, functools.reduce, [42],             "TypeError"]
    - [fu1306re003, functools.reduce, [42, [1, 2]],    "TypeError"]
    - [fu1306re004, functools.reduce, [null, [1, 2]],  "TypeError"]
    - [fu1306re005, functools.reduce, ["str", [1, 2]], "TypeError"]
    - [fu1306re006, functools.reduce, [1, 2, 3, 4, 5], "TypeError"]

table functools_extra1306.partial_and_wraps_type_errors:
  description: "functools.partial, functools.cmp_to_key, and functools.wraps raise TypeError on missing or non-callable first argument"
  kind: python_call_raises
  category: type_errors
  id_prefix: fu1306pa
  columns: [id, function, args, exception]
  rows:
    - [fu1306pa001, functools.partial,     [],       "TypeError"]
    - [fu1306pa002, functools.partial,     [42],     "TypeError"]
    - [fu1306pa003, functools.partial,     [null],   "TypeError"]
    - [fu1306pa004, functools.cmp_to_key, [],       "TypeError"]
    - [fu1306pa005, functools.wraps,       [],       "TypeError"]
    - [fu1306pa006, functools.cmp_to_key, [42, 99], "TypeError"]

table functools_extra1306.lru_cache_type_errors:
  description: "functools.lru_cache raises TypeError for non-integer, non-None maxsize values when used as decorator"
  kind: python_call_raises
  category: type_errors
  id_prefix: fu1306lc
  columns: [id, function, args, exception]
  rows:
    - [fu1306lc001, functools.lru_cache, ["not_an_int"], "TypeError"]
    - [fu1306lc002, functools.lru_cache, [3.14],         "TypeError"]
    - [fu1306lc003, functools.lru_cache, [[]],           "TypeError"]
    - [fu1306lc004, functools.lru_cache, [{}],           "TypeError"]
    - [fu1306lc005, functools.reduce,    [[1], [2]],     "TypeError"]
    - [fu1306lc006, functools.reduce,    [null],         "TypeError"]
