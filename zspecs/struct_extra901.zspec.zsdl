spec: struct_extra901
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct callable and exception __module__ attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra901.pack_unpack_modules:
  description: "struct pack/unpack callable __module__ identity"
  kind: python_call_eq
  category: callable_modules
  id_prefix: st901pu
  columns: [id, function, args, expected]
  rows:
    - [st901pu001, struct.pack.__module__.__eq__,        ["struct"], true]
    - [st901pu002, struct.unpack.__module__.__eq__,      ["struct"], true]
    - [st901pu003, struct.pack_into.__module__.__eq__,   ["struct"], true]
    - [st901pu004, struct.unpack_from.__module__.__eq__, ["struct"], true]
    - [st901pu005, struct.iter_unpack.__module__.__eq__, ["struct"], true]

table struct_extra901.utility_callable_modules:
  description: "struct utility callable __module__ identity"
  kind: python_call_eq
  category: utility_modules
  id_prefix: st901uc
  columns: [id, function, args, expected]
  rows:
    - [st901uc001, struct.calcsize.__module__.__eq__,              ["struct"], true]
    - [st901uc002, struct.error.__module__.__eq__,                 ["struct"], true]
    - [st901uc003, struct.pack.__module__.__class__.__name__.__eq__, ["str"],  true]
    - [st901uc004, struct.unpack.__module__.__class__.__name__.__eq__, ["str"], true]
    - [st901uc005, struct.calcsize.__module__.__class__.__name__.__eq__, ["str"], true]

table struct_extra901.error_class_attrs:
  description: "struct.error exception class attribute identity"
  kind: python_call_eq
  category: error_class_attrs
  id_prefix: st901ec
  columns: [id, function, args, expected]
  rows:
    - [st901ec001, struct.error.__module__.__eq__,                   ["struct"],    true]
    - [st901ec002, struct.error.__name__.__eq__,                     ["error"],     true]
    - [st901ec003, struct.error.__bases__.__class__.__name__.__eq__, ["tuple"],     true]
    - [st901ec004, struct.error.__module__.__class__.__name__.__eq__, ["str"],      true]
    - [st901ec005, struct.pack_into.__module__.__class__.__name__.__eq__, ["str"],  true]
