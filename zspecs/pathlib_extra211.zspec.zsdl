  args: ["tuple"]
  expected: true

invariant pathlib_extra211.purepath_mro_len_eq:
  description: "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra211.purepath_mro0_name_eq:
  description: "pathlib.PurePath.__mro__[0].__name__ == 'PurePath' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_members
