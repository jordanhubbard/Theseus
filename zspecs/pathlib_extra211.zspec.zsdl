invariant pathlib_extra211.posixpath_mro_len_eq:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 — MRO is [PosixPath, Path, PurePosixPath, PurePath, object]; confirmed Python 3.14.3 macOS"
