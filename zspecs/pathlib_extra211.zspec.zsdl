# PurePosixPath len == 3; PureWindowsPath len == 3
# ---------------------------------------------------------------------------

table pathlib_extra211.pure_subclass_mro:
  description: "pathlib.PurePosixPath and PureWindowsPath MRO length and element names"
  kind: python_call_eq
  category: mro_members
