  columns: [id, function, args, expected, description]
  rows:
    - [pureposixpath_mro_len_eq,       PurePosixPath.__mro__.__len__,                          [],                   3,     "pathlib.PurePosixPath.__mro__.__len__() == 3; MRO is [PurePosixPath, PurePath, object]; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_mro0_name_eq,     "PurePosixPath.__mro__[0].__name__.__eq__",              ["PurePosixPath"],    true,  "pathlib.PurePosixPath.__mro__[0].__name__ == 'PurePosixPath'; the class itself is first; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_mro1_name_eq,     "PurePosixPath.__mro__[1].__name__.__eq__",              ["PurePath"],         true,  "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath'; PurePosixPath directly inherits from PurePath; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_mro_len_eq,     PureWindowsPath.__mro__.__len__,                         [],                   3,     "pathlib.PureWindowsPath.__mro__.__len__() == 3; MRO is [PureWindowsPath, PurePath, object]; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_mro0_name_eq,   "PureWindowsPath.__mro__[0].__name__.__eq__",             ["PureWindowsPath"],  true,  "pathlib.PureWindowsPath.__mro__[0].__name__ == 'PureWindowsPath'; the class itself is first; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_mro1_name_eq,   "PureWindowsPath.__mro__[1].__name__.__eq__",             ["PurePath"],         true,  "pathlib.PureWindowsPath.__mro__[1].__name__ == 'PurePath'; PureWindowsPath directly inherits from PurePath; confirmed Python 3.14.3 macOS"]

