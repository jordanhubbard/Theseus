spec: pathlib_extra211
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra210.zspec.zsdl — covers pathlib.Path.__mro__ type identity and element names"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, Path.__module__, PurePosixPath component access"
  notes:
    - "pathlib.PurePath.__mro__ is a tuple; len == 2; MRO is [PurePath, object]; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__mro__ is a tuple; len == 3; MRO is [PurePosixPath, PurePath, object]; confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__mro__ is a tuple; len == 3; MRO is [PureWindowsPath, PurePath, object]; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__mro__ is a tuple; len == 5; MRO is [PosixPath, Path, PurePosixPath, PurePath, object]; confirmed Python 3.14.3 macOS."
    - "Index access on __mro__ uses bracket notation — function paths containing '[' must be double-quoted."
    - "PurePath is the root of the pathlib class hierarchy and appears in the MRO of every pathlib path class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath.__mro__ type identity and length
# __class__.__name__ == 'tuple', __len__() == 2
# ---------------------------------------------------------------------------

table pathlib_extra211.purepath_mro_type_and_len:
  description: "pathlib.PurePath.__mro__ type identity and length"
  kind: python_call_eq
  category: mro_identity
  id_prefix: pathlibmro211

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_mro_class_name_eq,  PurePath.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "pathlib.PurePath.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [purepath_mro_class_name_len, PurePath.__mro__.__class__.__name__.__len__,  [],        5,     "pathlib.PurePath.__mro__.__class__.__name__.__len__() == 5; 'tuple' has 5 characters; confirmed Python 3.14.3 macOS"]
    - [purepath_mro_len_eq,         PurePath.__mro__.__len__,                    [],        2,     "pathlib.PurePath.__mro__.__len__() == 2; MRO is [PurePath, object]; confirmed Python 3.14.3 macOS"]
    - [purepath_mro0_name_eq,       "PurePath.__mro__[0].__name__.__eq__",       ["PurePath"], true, "pathlib.PurePath.__mro__[0].__name__ == 'PurePath'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [purepath_mro1_name_eq,       "PurePath.__mro__[1].__name__.__eq__",       ["object"],   true, "pathlib.PurePath.__mro__[1].__name__ == 'object'; PurePath directly inherits from object; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
