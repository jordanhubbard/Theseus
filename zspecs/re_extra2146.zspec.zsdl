spec: re_extra2146
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave extra2146, theme: numeric conversion protocol dict-presence."
    - "Checks __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in re class __dict__."
    - "re.Pattern and re.Match are non-numeric regex engine types; all seven dunders are absent."
    - "re.error is an exception subclass; no numeric protocol defined in its own __dict__."
    - "re.RegexFlag is an IntFlag subclass; despite IntFlag inheritance, none of the seven checked dunders appear in RegexFlag.__dict__ itself — they are inherited, not owned."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Numeric conversion protocol — __trunc__, __floor__, __ceil__
# re.Pattern, re.Match, and re.error are non-numeric; all absent.
# re.RegexFlag (IntFlag) does not define __trunc__/__floor__/__ceil__ in its own __dict__.
# ---------------------------------------------------------------------------

table re_extra2146.trunc_floor_ceil_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re2146001", "re.Pattern.__dict__.__contains__",   ["__trunc__"], false]
    - ["re2146002", "re.Pattern.__dict__.__contains__",   ["__floor__"], false]
    - ["re2146003", "re.Pattern.__dict__.__contains__",   ["__ceil__"],  false]
    - ["re2146004", "re.Match.__dict__.__contains__",     ["__trunc__"], false]
    - ["re2146005", "re.Match.__dict__.__contains__",     ["__floor__"], false]
    - ["re2146006", "re.Match.__dict__.__contains__",     ["__ceil__"],  false]
    - ["re2146007", "re.RegexFlag.__dict__.__contains__", ["__trunc__"], false]
    - ["re2146008", "re.RegexFlag.__dict__.__contains__", ["__floor__"], false]
    - ["re2146009", "re.RegexFlag.__dict__.__contains__", ["__ceil__"],  false]
    - ["re2146010", "re.error.__dict__.__contains__",     ["__trunc__"], false]
    - ["re2146011", "re.error.__dict__.__contains__",     ["__floor__"], false]
    - ["re2146012", "re.error.__dict__.__contains__",     ["__ceil__"],  false]

# ---------------------------------------------------------------------------
# Numeric conversion protocol — __index__, __complex__, __bool__, __int__
# re.Pattern and re.Match are compile-result objects with no integer identity.
# re.RegexFlag inherits integer behavior from IntFlag but does NOT define
# __index__, __complex__, __bool__, or __int__ directly in its own __dict__.
# re.error is an exception class; no numeric protocol in its __dict__.
# ---------------------------------------------------------------------------

table re_extra2146.index_complex_bool_int_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re2146013", "re.Pattern.__dict__.__contains__",   ["__index__"],   false]
    - ["re2146014", "re.Pattern.__dict__.__contains__",   ["__complex__"], false]
    - ["re2146015", "re.Pattern.__dict__.__contains__",   ["__bool__"],    false]
    - ["re2146016", "re.Pattern.__dict__.__contains__",   ["__int__"],     false]
    - ["re2146017", "re.Match.__dict__.__contains__",     ["__index__"],   false]
    - ["re2146018", "re.Match.__dict__.__contains__",     ["__complex__"], false]
    - ["re2146019", "re.Match.__dict__.__contains__",     ["__bool__"],    false]
    - ["re2146020", "re.Match.__dict__.__contains__",     ["__int__"],     false]
    - ["re2146021", "re.RegexFlag.__dict__.__contains__", ["__index__"],   false]
    - ["re2146022", "re.RegexFlag.__dict__.__contains__", ["__complex__"], false]
    - ["re2146023", "re.RegexFlag.__dict__.__contains__", ["__bool__"],    false]
    - ["re2146024", "re.RegexFlag.__dict__.__contains__", ["__int__"],     false]
    - ["re2146025", "re.error.__dict__.__contains__",     ["__index__"],   false]
    - ["re2146026", "re.error.__dict__.__contains__",     ["__complex__"], false]
    - ["re2146027", "re.error.__dict__.__contains__",     ["__bool__"],    false]
    - ["re2146028", "re.error.__dict__.__contains__",     ["__int__"],     false]
