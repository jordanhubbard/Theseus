  columns: [id, function, args, expected]
  rows:
    - ["mp3301017",  operator.contains, [multiprocessing.Process.__dict__,                 "__imod__"], false]
    - ["mp3301018",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__imod__"], false]
    - ["mp3301019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__imod__"], false]
    - ["mp3301020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__imod__"], false]
    - ["mp3301021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__imod__"], false]
    - ["mp3301022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__imod__"], false]
    - ["mp3301023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__imod__"], false]
    - ["mp3301024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__imod__"], false]

# ---------------------------------------------------------------------------
# combined — __itruediv__, __ifloordiv__, __imod__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __itruediv__: false for all 8 — not in any type's own __dict__.
# __ifloordiv__: false for all 8 — not in any type's own __dict__.
# __imod__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# Wave 659 already established that the forward operators __truediv__,
#   __floordiv__, and __mod__ are all false for all 8 mp types. The in-place
#   variants tested here follow directly: absent forward operator implies
#   absent in-place variant.
# BaseListProxy note — no asymmetry in this wave (contrast with wave 666):
#   Unlike wave 666 where BaseListProxy.__iadd__ and __imul__ were false despite
#   __add__ and __mul__ being true (wave 658), this wave has no such asymmetry.
#   Wave 659 already found __truediv__/__floordiv__/__mod__ all false for
#   BaseListProxy (list defines none of these). The in-place variants are
#   therefore absent from BaseListProxy for the same underlying reason.
# _BaseSetProxy note: set defines __sub__ (set difference) but not __mod__,
#   __truediv__, or __floordiv__. All three in-place variants are absent.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — never through Python's in-place augmented assignment operators.
# ---------------------------------------------------------------------------

