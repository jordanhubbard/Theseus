    - ["mp3301015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__ifloordiv__"], false]
    - ["mp3301016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__ifloordiv__"], false]

# ---------------------------------------------------------------------------
# __imod__ dict-presence — operator.contains(Cls.__dict__, '__imod__')
#
# All 8 multiprocessing classes return false for __imod__.
# In-place modulo (__imod__, %=) is the augmented assignment variant of __mod__.
# No multiprocessing type defines __mod__ (wave 659 all false), so __imod__
#   is equally absent.
# managers.BaseListProxy key note: list defines no __mod__ or __imod__.
#   Lists are sequence types; the % operator is not defined for list objects.
#   Contrast with str, which defines __mod__ for string formatting — but
#   BaseListProxy proxies list, not str.
# managers._BaseDictProxy: dict defines no __mod__ or __imod__.
# managers._BaseSetProxy: set defines no __mod__ or __imod__.
# Process/Pool/AsyncResult/MapResult/SyncManager: no modulo or in-place
#   modulo semantics of any kind.
# ---------------------------------------------------------------------------

