spec: mp3301
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (mp3301): __itruediv__, __ifloordiv__, __imod__ dict-presence (in-place /=, //=, %=) for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__itruediv__): all 8 multiprocessing classes return false for __itruediv__. In-place true division (__itruediv__, /=) is the augmented assignment variant of __truediv__. multiprocessing.Process manages a subprocess lifecycle (start/join/terminate/kill); in-place division is undefined for process objects. pool.Pool dispatches work to worker processes; pool /= n is not a defined Python expression. pool.AsyncResult and pool.MapResult are result handles; in-place division is absent. managers.BaseListProxy: proxies list — list defines no __truediv__ or __itruediv__ (lists are not numeric types). managers._BaseDictProxy: proxies dict — dict defines no __truediv__ or __itruediv__. managers._BaseSetProxy: proxies set — set defines no __truediv__ or __itruediv__. managers.SyncManager: server process hosting shared objects; no in-place division defined."
    - "Key finding (__ifloordiv__): all 8 multiprocessing classes return false for __ifloordiv__. In-place floor division (__ifloordiv__, //=) is the augmented assignment variant of __floordiv__. No multiprocessing type defines __floordiv__ (confirmed false in wave 659), so __ifloordiv__ is equally absent. managers._BaseDictProxy proxies dict — dict defines no __floordiv__ or __ifloordiv__. managers._BaseSetProxy proxies set — set defines no __floordiv__ or __ifloordiv__. managers.BaseListProxy proxies list — list defines no __floordiv__ or __ifloordiv__. Process/Pool/AsyncResult/MapResult/SyncManager: no floor division or in-place floor division semantics of any kind."
    - "Key finding (__imod__): all 8 multiprocessing classes return false for __imod__. In-place modulo (__imod__, %=) is the augmented assignment variant of __mod__. No multiprocessing type defines __mod__ (confirmed false in wave 659), so __imod__ is equally absent. managers._BaseDictProxy: dict defines no __mod__ or __imod__. managers._BaseSetProxy: set defines no __mod__ or __imod__. managers.BaseListProxy: list defines no __mod__ or __imod__ (lists use __mul__ for repetition, not __mod__). Note: str defines __mod__ for % string formatting, but none of the proxied types (list, dict, set) are str-like, and the proxy infrastructure would not forward __imod__ even if it existed. Process/Pool/AsyncResult/MapResult/SyncManager: no modulo or in-place modulo semantics of any kind."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its entire API is expressed through explicit method calls, subprocess lifecycle management, and IPC — never through Python's in-place augmented assignment operators."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — operator.contains(Cls.__dict__, '__itruediv__')
#
# All 8 multiprocessing classes return false for __itruediv__.
# In-place true division (__itruediv__, /=) is the augmented assignment variant
#   of __truediv__. No multiprocessing type defines __truediv__ (wave 659), so
#   __itruediv__ is equally absent.
# Process/Pool/AsyncResult/MapResult: process-management and result-handle
#   types; in-place division is not defined for any of them.
# managers.BaseListProxy: proxies list — list defines no __truediv__ or
#   __itruediv__. Lists are sequence types, not numeric types; /= has never
#   been defined for list objects.
# managers._BaseDictProxy: proxies dict — dict defines no __truediv__ or
#   __itruediv__.
# managers._BaseSetProxy: proxies set — set defines no __truediv__ or
#   __itruediv__.
# managers.SyncManager: server process; no in-place division defined.
# ---------------------------------------------------------------------------

table mp3301.itruediv:
  description: "multiprocessing types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3301

  columns: [id, function, args, expected]
  rows:
    - ["mp3301001", operator.contains, [multiprocessing.Process.__dict__,                 "__itruediv__"], false]
    - ["mp3301002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__itruediv__"], false]
    - ["mp3301003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__itruediv__"], false]
    - ["mp3301004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__itruediv__"], false]
    - ["mp3301005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__itruediv__"], false]
    - ["mp3301006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__itruediv__"], false]
    - ["mp3301007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__itruediv__"], false]
    - ["mp3301008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__itruediv__"], false]

# ---------------------------------------------------------------------------
# __ifloordiv__ dict-presence — operator.contains(Cls.__dict__, '__ifloordiv__')
#
# All 8 multiprocessing classes return false for __ifloordiv__.
# In-place floor division (__ifloordiv__, //=) is the augmented assignment
#   variant of __floordiv__. No multiprocessing type defines __floordiv__
#   (wave 659 all false), so __ifloordiv__ is equally absent.
# managers._BaseSetProxy key note: set defines no __floordiv__ or __ifloordiv__
#   at all. Set division is not part of the set data model.
# managers._BaseDictProxy: dict defines no __floordiv__ or __ifloordiv__.
# managers.BaseListProxy: list defines no __floordiv__ or __ifloordiv__.
# Process/Pool/AsyncResult/MapResult/SyncManager: no floor division or in-place
#   floor division semantics of any kind.
# ---------------------------------------------------------------------------

