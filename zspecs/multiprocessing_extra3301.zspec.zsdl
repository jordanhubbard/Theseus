    - ["mp3301011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__ifloordiv__"], false]
    - ["mp3301012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__ifloordiv__"], false]
    - ["mp3301013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__ifloordiv__"], false]
