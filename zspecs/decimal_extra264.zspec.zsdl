spec: decimal_extra264
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "All decimal rounding mode constants (ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP) are plain Python str objects."
    - "Each rounding constant's __class__.__name__ == 'str'."
    - "Each rounding constant's string value equals its own name (e.g. decimal.ROUND_UP == 'ROUND_UP')."
    - "decimal.getcontext().rounding == decimal.ROUND_HALF_EVEN by default."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: rounding constant __class__.__name__ (all 'str')
# ---------------------------------------------------------------------------

table decimal_extra264.rounding_constant_types:
  description: "decimal rounding mode constants __class__.__name__ for ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP"
  kind: python_call_eq
  category: identity
  id_prefix: typ

  columns: [id, function, args, expected, description]
  rows:
    - [ROUND_UP_type,        ROUND_UP.__class__.__name__.__eq__,        ["str"], true, "decimal.ROUND_UP.__class__.__name__ == 'str'"]
    - [ROUND_DOWN_type,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true, "decimal.ROUND_DOWN.__class__.__name__ == 'str'"]
    - [ROUND_CEILING_type,   ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_CEILING.__class__.__name__ == 'str'"]
    - [ROUND_FLOOR_type,     ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true, "decimal.ROUND_FLOOR.__class__.__name__ == 'str'"]
    - [ROUND_HALF_UP_type,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_HALF_UP.__class__.__name__ == 'str'"]
    - [ROUND_HALF_DOWN_type, ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true, "decimal.ROUND_HALF_DOWN.__class__.__name__ == 'str'"]
    - [ROUND_HALF_EVEN_type, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true, "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str'"]
    - [ROUND_05UP_type,      ROUND_05UP.__class__.__name__.__eq__,      ["str"], true, "decimal.ROUND_05UP.__class__.__name__ == 'str'"]

# ---------------------------------------------------------------------------
# Table: rounding constant string values
# ---------------------------------------------------------------------------

table decimal_extra264.rounding_constant_values:
  description: "decimal rounding mode constant string values equal their own names"
  kind: python_call_eq
  category: identity
  id_prefix: val

  columns: [id, function, args, expected, description]
  rows:
    - [ROUND_UP_val,        ROUND_UP.__eq__,        ["ROUND_UP"],        true, "decimal.ROUND_UP == 'ROUND_UP'"]
    - [ROUND_DOWN_val,      ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true, "decimal.ROUND_DOWN == 'ROUND_DOWN'"]
    - [ROUND_CEILING_val,   ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true, "decimal.ROUND_CEILING == 'ROUND_CEILING'"]
    - [ROUND_FLOOR_val,     ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR'"]
    - [ROUND_HALF_UP_val,   ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"]
    - [ROUND_HALF_DOWN_val, ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'"]
    - [ROUND_HALF_EVEN_val, ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'"]
    - [ROUND_05UP_val,      ROUND_05UP.__eq__,      ["ROUND_05UP"],      true, "decimal.ROUND_05UP == 'ROUND_05UP'"]

# ---------------------------------------------------------------------------
# Standalone invariants: default context rounding and cross-checks
# ---------------------------------------------------------------------------

invariant decimal_extra264.ROUND_UP.is_str:
  description: "decimal.ROUND_UP is a plain str, not an enum or special type"
  category: identity
  kind: python_call_eq
  function: ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra264.ROUND_DOWN.is_str:
  description: "decimal.ROUND_DOWN is a plain str"
  category: identity
  kind: python_call_eq
  function: ROUND_DOWN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra264.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra264.ROUND_UP.value:
  description: "decimal.ROUND_UP == 'ROUND_UP'"
  category: identity
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true
