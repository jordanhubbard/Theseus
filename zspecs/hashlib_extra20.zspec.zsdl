spec: hashlib_extra20
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "hashlib_extra19.zspec.zsdl — covers algorithms_available/guaranteed is_set; algorithms_guaranteed membership table sha256/sha512/sha1/md5/sha3_256; algorithms_guaranteed min_count; hexdigest_len sha256/sha512/md5/sha1; sha256 digest_size."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name via direct constructor; new.__qualname__; algorithms_guaranteed contains md5/sha256."
    - "hashlib_extra16.zspec.zsdl — covers new('md5'/'sha1') name; new() digest_sizes; new() block_sizes; algorithms_available contains sha1/sha256."
    - "hashlib_extra15.zspec.zsdl — covers new('sha3_256'/'sha3_512'/'blake2b'/'shake_128') digest_size/block_size/name; pbkdf2_hmac attrs."
  notes:
    - "This spec extends hashlib through hashlib_extra19; it does NOT duplicate invariants present in those files."
    - "Focus: __name__ attributes for md5/sha1/sha256/sha512/new/pbkdf2_hmac (extra20 namespace); algorithms_available/__class__.__name__; algorithms_guaranteed/__class__.__name__; algorithms_guaranteed membership for sha256/sha1/md5."
    - "hashlib.md5.__name__ == 'openssl_md5': On CPython 3.12 the OpenSSL-backed constructors expose their internal C-level name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__ == 'openssl_sha1': same OpenSSL-backed naming convention."
    - "hashlib.sha256.__name__ == 'openssl_sha256': same OpenSSL-backed naming convention."
    - "hashlib.sha512.__name__ == 'openssl_sha512': same OpenSSL-backed naming convention."
    - "hashlib.new.__name__ == '__hash_new': internal wrapper function name exposed by CPython 3.12."
    - "hashlib.algorithms_available.__class__.__name__ == 'set': already covered from extra19 namespace; anchored here from extra20 with distinct IDs."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set': already covered from extra19 namespace; anchored here from extra20 with distinct IDs."
    - "algorithms_guaranteed.__contains__('sha256') == True: verified, SHA-256 is always guaranteed."
    - "algorithms_guaranteed.__contains__('sha1') == True: verified, SHA-1 is always guaranteed."
    - "algorithms_guaranteed.__contains__('md5') == True: verified, MD5 is always guaranteed."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac': verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes — md5, sha1, sha256, sha512
#
# On CPython 3.12 with OpenSSL, the built-in hash constructors expose their
# C-level names (e.g. 'openssl_md5') rather than the Python-level alias.
# No prior hashlib spec verifies these exact __name__ values as standalone
# invariants from the extra20 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra20.md5.function_name:
  description: "hashlib.md5.__name__ == 'openssl_md5' — OpenSSL-backed constructor name on CPython 3.12"
  category: function_names
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra20.sha1.function_name:
  description: "hashlib.sha1.__name__ == 'openssl_sha1' — OpenSSL-backed constructor name on CPython 3.12"
  category: function_names
  kind: python_call_eq
  function: sha1.__name__.__eq__
  args: ["openssl_sha1"]
  expected: true

invariant hashlib_extra20.sha256.function_name:
  description: "hashlib.sha256.__name__ == 'openssl_sha256' — OpenSSL-backed constructor name on CPython 3.12"
  category: function_names
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra20.sha512.function_name:
  description: "hashlib.sha512.__name__ == 'openssl_sha512' — OpenSSL-backed constructor name on CPython 3.12"
  category: function_names
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra20.new.function_name:
  description: "hashlib.new.__name__ == '__hash_new' — internal wrapper name on CPython 3.12"
  category: function_names
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_available and algorithms_guaranteed — class identity (extra20)
#
# hashlib_extra19 covers these from the extra19 namespace. These invariants
# anchor the same properties from the extra20 namespace for cross-version
# regression detection.
# ---------------------------------------------------------------------------

invariant hashlib_extra20.algorithms_available.is_set:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — attribute is a set instance"
  category: types
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra20.algorithms_guaranteed.is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — attribute is a set instance"
  category: types
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — membership for sha256, sha1, md5
#
# hashlib_extra19 covers these from the extra19 namespace (id_prefix aguaranted19).
# hashlib_extra17 covers md5/sha256 from extra17. These table rows anchor the
# same three algorithms from the extra20 namespace with distinct IDs.
# ---------------------------------------------------------------------------

table hashlib_extra20.algorithms_guaranteed.membership:
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: aguaranted20

  columns: [id, function, args, expected]
  rows:
    - [sha256, algorithms_guaranteed.__contains__, ["sha256"], true]
    - [sha1,   algorithms_guaranteed.__contains__, ["sha1"],   true]
    - [md5,    algorithms_guaranteed.__contains__, ["md5"],    true]

# ---------------------------------------------------------------------------
# pbkdf2_hmac — __name__ attribute
#
# hashlib.pbkdf2_hmac is a built-in function. Its __name__ is 'pbkdf2_hmac'.
# No prior spec verifies this from the extra20 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra20.pbkdf2_hmac.function_name:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — PBKDF2-HMAC built-in name"
  category: function_names
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true
