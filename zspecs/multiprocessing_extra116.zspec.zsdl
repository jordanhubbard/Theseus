spec: multiprocessing_extra116
version: ">=3.11"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/reduction.py"
    - "CPython source: Lib/_pickle.c"
  notes:
    - "This spec extends multiprocessing_extra115.zspec.zsdl."
    - "This spec covers: wave 258 theme — multiprocessing.reduction module attributes not previously covered in any prior spec. No prior multiprocessing spec covered the reduction submodule. NEW in extra116: multiprocessing.reduction.__name__.__eq__('multiprocessing.reduction')==True (len=25); multiprocessing.reduction.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (len=10); multiprocessing.reduction.__package__.__eq__('multiprocessing')==True (len=15); multiprocessing.reduction.__spec__.name.__eq__('multiprocessing.reduction')==True (len=25); ForkingPickler.__name__.__eq__('ForkingPickler')==True (len=14); ForkingPickler.__module__.__eq__('multiprocessing.reduction')==True (len=25); ForkingPickler.__bases__[0].__name__.__eq__('Pickler')==True (len=7); ForkingPickler.__mro__.__len__()==3; ForkingPickler.dumps.__code__.co_qualname=='ForkingPickler.dumps' (len=20); ForkingPickler.register.__code__.co_qualname=='ForkingPickler.register' (len=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.reduction is the submodule that handles inter-process object serialization (pickling). ForkingPickler is the main class: it extends _pickle.Pickler with a class-level dispatch table for registering custom reducers. ForkingPickler.__name__='ForkingPickler' (14 chars). ForkingPickler.__module__='multiprocessing.reduction' (25 chars). ForkingPickler.__bases__[0].__name__=='Pickler' (inherits from _pickle.Pickler C extension). ForkingPickler.__mro__.__len__()==3: [ForkingPickler, _pickle.Pickler, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.reduction.__name__=='multiprocessing.reduction' (len=25). __package__=='multiprocessing' (len=15; parent package, not the full dotted name). __spec__.name=='multiprocessing.reduction' (len=25, same as __name__). __spec__.__class__.__name__=='ModuleSpec' (len=10). __spec__.parent=='multiprocessing' (len=15, same as __package__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.reduction module-level identity — extra116
#
# Wave 258 theme: reduction module __name__, __package__, __spec__ (first coverage).
#
# multiprocessing.reduction.__name__                  == 'multiprocessing.reduction' (len=25)
# multiprocessing.reduction.__package__               == 'multiprocessing'            (len=15)
# multiprocessing.reduction.__spec__.__class__.__name__ == 'ModuleSpec'               (len=10)
# multiprocessing.reduction.__spec__.name             == 'multiprocessing.reduction' (len=25)
# ---------------------------------------------------------------------------

table multiprocessing_extra116.mp_reduction_module_identity:
  description: "multiprocessing.reduction module identity checks in mpreduction116 namespace — wave 258 theme: first coverage of multiprocessing.reduction submodule; reduction.__name__.__eq__('multiprocessing.reduction')==True (len=25: 'multiprocessing.'=16+'reduction'=9=25; the dotted module name; compare multiprocessing.__name__.__len__()==15: the parent package name is 10 chars shorter); reduction.__name__.__len__()==25; reduction.__package__.__eq__('multiprocessing')==True (len=15: __package__ is the parent package name, not the full dotted name; for a submodule 'multiprocessing.reduction', __package__=='multiprocessing'); reduction.__package__.__len__()==15; reduction.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (len=10: the importlib ModuleSpec class; same for all standard-library modules); reduction.__spec__.__class__.__name__.__len__()==10; reduction.__spec__.name.__eq__('multiprocessing.reduction')==True (len=25: ModuleSpec.name equals the full module name; same value as __name__); reduction.__spec__.name.__len__()==25; compare: reduction.__name__.__len__()==reduction.__spec__.name.__len__()==25 (tied: both store the full module name); reduction.__package__.__len__()==15 == reduction.__spec__.parent.__len__()==15 (parent package length is consistent); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction116

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,     reduction.__name__.__eq__,                     ["multiprocessing.reduction"], true, "reduction.__name__ == 'multiprocessing.reduction' (len=25); verified with Python 3.14.3"]
    - [name_len,    reduction.__name__.__len__,                    [],                            25,   "reduction.__name__.__len__() == 25 ('multiprocessing.reduction'=25); verified with Python 3.14.3"]
    - [pkg_eq,      reduction.__package__.__eq__,                  ["multiprocessing"],           true, "reduction.__package__ == 'multiprocessing' (len=15; parent package, not full dotted name); verified with Python 3.14.3"]
    - [pkg_len,     reduction.__package__.__len__,                 [],                            15,   "reduction.__package__.__len__() == 15 ('multiprocessing'=15); verified with Python 3.14.3"]
    - [spec_cls_eq, reduction.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"],                true, "reduction.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; importlib standard); verified with Python 3.14.3"]
    - [spec_cls_ln, reduction.__spec__.__class__.__name__.__len__, [],                            10,   "reduction.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10); verified with Python 3.14.3"]
    - [spec_name_eq, reduction.__spec__.name.__eq__,               ["multiprocessing.reduction"], true, "reduction.__spec__.name == 'multiprocessing.reduction' (len=25, same as __name__); verified with Python 3.14.3"]
    - [spec_name_ln, reduction.__spec__.name.__len__,              [],                            25,   "reduction.__spec__.name.__len__() == 25 (same as __name__.__len__()==25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.reduction.ForkingPickler class identity — extra116
#
# Wave 258 theme: ForkingPickler class attributes (first coverage).
#
# ForkingPickler.__name__.__len__()              == 14  ('ForkingPickler')
# ForkingPickler.__module__.__len__()            == 25  ('multiprocessing.reduction')
# ForkingPickler.__bases__[0].__name__.__len__() == 7   ('Pickler')
# ForkingPickler.__mro__.__len__()               == 3   ([ForkingPickler, Pickler, object])
# ---------------------------------------------------------------------------

table multiprocessing_extra116.mp_forkingpickler_identity:
  description: "multiprocessing.reduction.ForkingPickler class identity checks in mpreduction116 namespace — wave 258 theme: ForkingPickler.__name__.__eq__('ForkingPickler')==True (len=14: 'ForkingPickler'=14; the class name describes its role as a Pickler used during forking/process-spawning); ForkingPickler.__name__.__len__()==14; ForkingPickler.__qualname__.__eq__('ForkingPickler')==True (__qualname__==__name__ for top-level class; len=14); ForkingPickler.__qualname__.__len__()==14; ForkingPickler.__module__.__eq__('multiprocessing.reduction')==True (len=25: same as reduction.__name__; defined in the reduction submodule); ForkingPickler.__module__.__len__()==25; ForkingPickler.__mro__.__len__()==3 ([ForkingPickler, _pickle.Pickler, object]: ForkingPickler extends the C-level Pickler with a class-level dispatch table for custom reducers); ForkingPickler.__bases__[0].__name__.__eq__('Pickler')==True (direct base is _pickle.Pickler, the C extension Pickler class; len=7); ForkingPickler.__bases__[0].__name__.__len__()==7; ForkingPickler.__bases__[0].__module__.__eq__('_pickle')==True (base class is in the _pickle C extension module); compare: ForkingPickler.__name__.__len__()==14 == ForkingPickler.__module__.__len__()==25-11 (module is 11 chars longer than class name); ForkingPickler.__mro__.__len__()==3 (same as asyncio.Task.__mro__.__len__()==3, both 3-level hierarchies); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction116a

  columns: [id, function, args, expected, description]
  rows:
    - [fp_name_eq,    ForkingPickler.__name__.__eq__,                    ["ForkingPickler"],             true, "ForkingPickler.__name__ == 'ForkingPickler' (len=14); verified with Python 3.14.3"]
    - [fp_name_len,   ForkingPickler.__name__.__len__,                   [],                             14,   "ForkingPickler.__name__.__len__() == 14 ('ForkingPickler'=14); verified with Python 3.14.3"]
    - [fp_qn_eq,      ForkingPickler.__qualname__.__eq__,                ["ForkingPickler"],             true, "ForkingPickler.__qualname__ == 'ForkingPickler' (__qualname__==__name__; top-level class); verified with Python 3.14.3"]
    - [fp_qn_len,     ForkingPickler.__qualname__.__len__,               [],                             14,   "ForkingPickler.__qualname__.__len__() == 14 (tied with __name__ len=14); verified with Python 3.14.3"]
    - [fp_mod_eq,     ForkingPickler.__module__.__eq__,                  ["multiprocessing.reduction"],  true, "ForkingPickler.__module__ == 'multiprocessing.reduction' (len=25); verified with Python 3.14.3"]
    - [fp_mod_len,    ForkingPickler.__module__.__len__,                 [],                             25,   "ForkingPickler.__module__.__len__() == 25 (same as reduction.__name__ len=25); verified with Python 3.14.3"]
    - [fp_mro_len,    ForkingPickler.__mro__.__len__,                    [],                             3,    "ForkingPickler.__mro__.__len__() == 3 ([ForkingPickler, Pickler, object]); verified with Python 3.14.3"]
    - [fp_base_eq,    "ForkingPickler.__bases__[0].__name__.__eq__",     ["Pickler"],                    true, "ForkingPickler.__bases__[0].__name__ == 'Pickler' (inherits from _pickle.Pickler C extension); verified with Python 3.14.3"]
    - [fp_base_len,   "ForkingPickler.__bases__[0].__name__.__len__",    [],                             7,    "ForkingPickler.__bases__[0].__name__.__len__() == 7 ('Pickler'=7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.reduction.ForkingPickler method code attrs — extra116
#
# Wave 258 theme: ForkingPickler.dumps and .register co_qualname (first coverage).
#
# ForkingPickler.dumps.__code__.co_qualname    == 'ForkingPickler.dumps'    (len=20)
# ForkingPickler.register.__code__.co_qualname == 'ForkingPickler.register' (len=23)
# ForkingPickler.dumps.__code__.co_argcount    == 3   (cls, obj, protocol)
# ForkingPickler.register.__code__.co_argcount == 3   (cls, type, reduce)
# ---------------------------------------------------------------------------

table multiprocessing_extra116.mp_forkingpickler_method_code:
  description: "multiprocessing.reduction.ForkingPickler method code attribute checks in mpreduction116 namespace — wave 258 theme: ForkingPickler.dumps and register co_qualname; ForkingPickler.dumps.__code__.co_qualname.__eq__('ForkingPickler.dumps')==True (len=20: 'ForkingPickler.'=15+'dumps'=5=20; ForkingPickler.dumps is a classmethod that pickles obj using the ForkingPickler dispatch table and returns the bytes; co_argcount=3: cls, obj, protocol); ForkingPickler.dumps.__code__.co_qualname.__len__()==20; ForkingPickler.dumps.__code__.co_argcount.__eq__(3)==True; ForkingPickler.dumps.__code__.co_varnames.__len__()==4 (('cls','obj','protocol','buf'): 3 params plus 1 local 'buf' for the BytesIO buffer); ForkingPickler.register.__code__.co_qualname.__eq__('ForkingPickler.register')==True (len=23: 'ForkingPickler.'=15+'register'=8=23; ForkingPickler.register is a classmethod that stores a custom reducer for a type in the dispatch_table; co_argcount=3: cls, type, reduce); ForkingPickler.register.__code__.co_qualname.__len__()==23; ForkingPickler.register.__code__.co_argcount.__eq__(3)==True; ForkingPickler.register.__code__.co_varnames.__len__()==3 (('cls','type','reduce'): exactly 3 params, no locals); compare co_qualname lengths: dumps=20 (3 shorter) < register=23 (longer by 3: 'register'=8 vs 'dumps'=5, diff=3); compare co_varnames: register=3 (no locals) < dumps=4 (buf local); 'ForkingPickler.'=15 prefix is common to both; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpreduction116b

  columns: [id, function, args, expected, description]
  rows:
    - [dumps_coq_eq,  ForkingPickler.dumps.__code__.co_qualname.__eq__,    ["ForkingPickler.dumps"],    true, "ForkingPickler.dumps.__code__.co_qualname == 'ForkingPickler.dumps' (len=20); verified with Python 3.14.3"]
    - [dumps_coq_len, ForkingPickler.dumps.__code__.co_qualname.__len__,   [],                          20,   "ForkingPickler.dumps co_qualname.__len__() == 20 ('ForkingPickler.dumps'=20); verified with Python 3.14.3"]
    - [dumps_argc,    ForkingPickler.dumps.__code__.co_argcount.__eq__,    [3],                         true, "ForkingPickler.dumps.__code__.co_argcount == 3 (cls, obj, protocol); verified with Python 3.14.3"]
    - [dumps_var_len, ForkingPickler.dumps.__code__.co_varnames.__len__,   [],                          4,    "ForkingPickler.dumps co_varnames.__len__() == 4 (cls, obj, protocol, buf); verified with Python 3.14.3"]
    - [reg_coq_eq,    ForkingPickler.register.__code__.co_qualname.__eq__, ["ForkingPickler.register"], true, "ForkingPickler.register.__code__.co_qualname == 'ForkingPickler.register' (len=23); verified with Python 3.14.3"]
    - [reg_coq_len,   ForkingPickler.register.__code__.co_qualname.__len__, [],                         23,   "ForkingPickler.register co_qualname.__len__() == 23 ('ForkingPickler.register'=23, 3 more than dumps=20); verified with Python 3.14.3"]
    - [reg_argc,      ForkingPickler.register.__code__.co_argcount.__eq__, [3],                         true, "ForkingPickler.register.__code__.co_argcount == 3 (cls, type, reduce; tied with dumps); verified with Python 3.14.3"]
    - [reg_var_len,   ForkingPickler.register.__code__.co_varnames.__len__, [],                         3,    "ForkingPickler.register co_varnames.__len__() == 3 (no locals: cls, type, reduce only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra116
# ---------------------------------------------------------------------------

invariant multiprocessing_extra116.reduction_name_len_25:
  description: "multiprocessing.reduction.__name__.__len__() == 25 — 'multiprocessing.reduction' = 'multiprocessing.'=16+'reduction'=9=25; multiprocessing.reduction.__name__.__eq__('multiprocessing.reduction')==True; this module provides the serialization infrastructure used when sending objects between processes via queues and pipes; it defines ForkingPickler (subclass of _pickle.Pickler) and registers custom reducers for file descriptors, sockets, and other non-picklable objects; reduction.__package__.__len__()==15 ('multiprocessing'=15; the parent package, 10 chars shorter than the full module name); reduction.__spec__.name.__len__()==25 (same as __name__: both store the canonical full module name); no prior multiprocessing spec covered reduction module attributes; first standalone reduction.__name__ length invariant in mpreduction116 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: reduction.__name__.__len__
  args: []
  expected: 25

invariant multiprocessing_extra116.reduction_spec_class_name_ModuleSpec:
  description: "multiprocessing.reduction.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — the module spec is an importlib._bootstrap.ModuleSpec instance; __spec__.__class__.__name__=='ModuleSpec' (len=10); this is consistent across all standard-library modules loaded by the import system; multiprocessing.reduction.__spec__.name=='multiprocessing.reduction' (len=25); multiprocessing.reduction.__spec__.parent=='multiprocessing' (len=15); multiprocessing.reduction.__spec__.__class__.__name__.__len__()==10; multiprocessing.reduction.__name__.__len__()==25; multiprocessing.reduction.__package__.__len__()==15; no prior multiprocessing spec covered reduction.__spec__.__class__.__name__; first standalone reduction spec class name invariant in mpreduction116 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: reduction.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra116.ForkingPickler_name_len_14:
  description: "multiprocessing.reduction.ForkingPickler.__name__.__len__() == 14 — 'ForkingPickler'=14 chars: 'Forking'=7+'Pickler'=7=14 (two equal halves of 7 chars each); ForkingPickler.__name__.__eq__('ForkingPickler')==True; ForkingPickler.__qualname__.__len__()==14 (tied with __name__: top-level class); ForkingPickler.__module__=='multiprocessing.reduction' (len=25; module is 11 chars longer than class name: 25-14=11); ForkingPickler.__mro__.__len__()==3 ([ForkingPickler, _pickle.Pickler, object]); ForkingPickler.__bases__[0].__name__=='Pickler' (len=7: the 'Pickler' half of 'ForkingPickler'=14 is exactly equal to the base class name length); ForkingPickler is the core class that enables multiprocessing inter-process communication by providing a Pickler with a customizable dispatch table; first standalone ForkingPickler.__name__ length invariant in mpreduction116 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: ForkingPickler.__name__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra116.ForkingPickler_module_len_25:
  description: "multiprocessing.reduction.ForkingPickler.__module__.__len__() == 25 — 'multiprocessing.reduction' = 'multiprocessing.'=16+'reduction'=9=25; ForkingPickler.__module__.__eq__('multiprocessing.reduction')==True; ForkingPickler.__module__.__len__()==25 equals reduction.__name__.__len__()==25 (ForkingPickler is defined in the reduction module, so its __module__ equals the module's full name); compare: ForkingPickler.__name__.__len__()==14 (module is 11 chars longer than class name); ForkingPickler.__bases__[0].__module__=='_pickle' (the base Pickler class is in the C extension '_pickle', not in 'multiprocessing.reduction'); ForkingPickler.__mro__.__len__()==3; this is the first coverage of ForkingPickler.__module__ in any multiprocessing spec; first standalone ForkingPickler.__module__ length invariant in mpreduction116 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: ForkingPickler.__module__.__len__
  args: []
  expected: 25

invariant multiprocessing_extra116.ForkingPickler_bases_Pickler:
  description: "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__('Pickler') returns True — ForkingPickler inherits from _pickle.Pickler (the C extension Pickler); __bases__[0].__name__=='Pickler' (len=7); __bases__[0].__module__=='_pickle' (C extension, not multiprocessing.reduction); ForkingPickler overrides the Pickler class by adding a class-level dispatch_table dict that maps types to custom reducer functions; ForkingPickler.__mro__ == [ForkingPickler, _pickle.Pickler, object] with __mro__.__len__()==3; the 'Pickler' base name (7 chars) is exactly half of 'ForkingPickler' (14 chars): 'ForkingPickler'=2*'Pickler' in length; ForkingPickler.__name__.__len__()==14; ForkingPickler.__module__.__len__()==25; first standalone ForkingPickler.__bases__[0].__name__ equality invariant in mpreduction116 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "ForkingPickler.__bases__[0].__name__.__eq__"
  args: ["Pickler"]
  expected: true
