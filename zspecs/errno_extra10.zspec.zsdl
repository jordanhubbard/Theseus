spec: errno_extra10
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno.zspec.zsdl through errno_extra9.zspec.zsdl."
    - "errno_extra7 covers: ECONNREFUSED.__class__.__name__=='int'; ECONNREFUSED==61; ETIMEDOUT positivity check (not value)."
    - "errno_extra9 covers: ENOTSOCK/ECONNRESET/ECONNREFUSED values and class names; errorcode[38/54/61] reverse-lookups; contains 38/54/61."
    - "No prior spec verifies ETIMEDOUT.__class__.__name__ == 'int' as a standalone invariant."
    - "No prior spec verifies ETIMEDOUT == 60 as a standalone value invariant."
    - "No prior spec verifies EHOSTUNREACH.__class__.__name__ == 'int' as a standalone invariant."
    - "No prior spec verifies EHOSTUNREACH == 65 as a standalone value invariant."
    - "No prior spec verifies ENETUNREACH.__class__.__name__ == 'int' as a standalone invariant."
    - "No prior spec verifies ENETUNREACH == 51 as a standalone value invariant."
    - "No prior spec verifies ENETDOWN.__class__.__name__ == 'int' as a standalone invariant."
    - "No prior spec verifies ENETDOWN == 50 as a standalone value invariant."
    - "No prior spec verifies errorcode[60], errorcode[65], errorcode[51], or errorcode[50] as standalone invariants."
    - "No prior spec verifies 60/65/51/50 in errorcode as standalone __contains__ invariants."
    - "errno.ETIMEDOUT == 60 on macOS/Darwin (connection timed out). Verified at runtime."
    - "errno.EHOSTUNREACH == 65 on macOS/Darwin (no route to host). Verified at runtime."
    - "errno.ENETUNREACH == 51 on macOS/Darwin (network is unreachable). Verified at runtime."
    - "errno.ENETDOWN == 50 on macOS/Darwin (network is down). Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ETIMEDOUT — class name and value
#
# errno_extra7 verifies ETIMEDOUT is positive but does not verify its value.
# No prior spec verifies ETIMEDOUT.__class__.__name__ or ETIMEDOUT==60
# as standalone invariants. ETIMEDOUT is 60 on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra10.ETIMEDOUT.class_name:
  description: "errno.ETIMEDOUT.__class__.__name__ == 'int' — ETIMEDOUT is a plain int"
  category: constants
  kind: python_call_eq
  function: ETIMEDOUT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra10.ETIMEDOUT.value:
  description: "errno.ETIMEDOUT == 60 on macOS/Darwin (connection timed out)"
  category: constants
  kind: python_call_eq
  function: ETIMEDOUT.__eq__
  args: [60]
  expected: true

# ---------------------------------------------------------------------------
# EHOSTUNREACH — class name and value
#
# No prior spec verifies EHOSTUNREACH.__class__.__name__ or EHOSTUNREACH==65
# as standalone invariants. EHOSTUNREACH is 65 on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra10.EHOSTUNREACH.class_name:
  description: "errno.EHOSTUNREACH.__class__.__name__ == 'int' — EHOSTUNREACH is a plain int"
  category: constants
  kind: python_call_eq
  function: EHOSTUNREACH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra10.EHOSTUNREACH.value:
  description: "errno.EHOSTUNREACH == 65 on macOS/Darwin (no route to host)"
  category: constants
  kind: python_call_eq
  function: EHOSTUNREACH.__eq__
  args: [65]
  expected: true

# ---------------------------------------------------------------------------
# ENETUNREACH — class name and value
#
# No prior spec verifies ENETUNREACH.__class__.__name__ or ENETUNREACH==51
# as standalone invariants. ENETUNREACH is 51 on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra10.ENETUNREACH.class_name:
  description: "errno.ENETUNREACH.__class__.__name__ == 'int' — ENETUNREACH is a plain int"
  category: constants
  kind: python_call_eq
  function: ENETUNREACH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra10.ENETUNREACH.value:
  description: "errno.ENETUNREACH == 51 on macOS/Darwin (network is unreachable)"
  category: constants
  kind: python_call_eq
  function: ENETUNREACH.__eq__
  args: [51]
  expected: true

# ---------------------------------------------------------------------------
# ENETDOWN — class name and value
#
# No prior spec verifies ENETDOWN.__class__.__name__ or ENETDOWN==50
# as standalone invariants. ENETDOWN is 50 on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra10.ENETDOWN.class_name:
  description: "errno.ENETDOWN.__class__.__name__ == 'int' — ENETDOWN is a plain int"
  category: constants
  kind: python_call_eq
  function: ENETDOWN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra10.ENETDOWN.value:
  description: "errno.ENETDOWN == 50 on macOS/Darwin (network is down)"
  category: constants
  kind: python_call_eq
  function: ENETDOWN.__eq__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# errorcode reverse-lookups — keys 60, 65, 51, 50
#
# No prior spec verifies errorcode[60], errorcode[65], errorcode[51], or
# errorcode[50] as standalone reverse-lookup invariants.
# Verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant errno_extra10.errorcode.etimedout_lookup:
  description: "errno.errorcode[60] == 'ETIMEDOUT' — reverse-lookup of errno 60 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [60]
  expected: "ETIMEDOUT"

invariant errno_extra10.errorcode.ehostunreach_lookup:
  description: "errno.errorcode[65] == 'EHOSTUNREACH' — reverse-lookup of errno 65 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [65]
  expected: "EHOSTUNREACH"

invariant errno_extra10.errorcode.enetunreach_lookup:
  description: "errno.errorcode[51] == 'ENETUNREACH' — reverse-lookup of errno 51 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [51]
  expected: "ENETUNREACH"

invariant errno_extra10.errorcode.enetdown_lookup:
  description: "errno.errorcode[50] == 'ENETDOWN' — reverse-lookup of errno 50 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [50]
  expected: "ENETDOWN"

# ---------------------------------------------------------------------------
# errorcode __contains__ — keys 60, 65, 51, 50
#
# No prior spec verifies 60/65/51/50 in errorcode as standalone __contains__
# invariants. All four error codes are present on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra10.errorcode.contains_etimedout_key:
  description: "60 in errno.errorcode — ETIMEDOUT key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [60]
  expected: true

invariant errno_extra10.errorcode.contains_ehostunreach_key:
  description: "65 in errno.errorcode — EHOSTUNREACH key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [65]
  expected: true

invariant errno_extra10.errorcode.contains_enetunreach_key:
  description: "51 in errno.errorcode — ENETUNREACH key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [51]
  expected: true

invariant errno_extra10.errorcode.contains_enetdown_key:
  description: "50 in errno.errorcode — ENETDOWN key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# Table: new constant integer values — ETIMEDOUT, EHOSTUNREACH, ENETUNREACH, ENETDOWN
#
# Groups the four new constant value checks in one indexed table.
# No prior table covers these constants' values.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra10.constant_values:
  description: "ETIMEDOUT, EHOSTUNREACH, ENETUNREACH, ENETDOWN integer values on macOS/Darwin"
  kind: python_call_eq
  category: constants
  id_prefix: e10cv

  columns: [id, function, args, expected]
  rows:
    - [ETIMEDOUT,   ETIMEDOUT.__eq__,   [60], true]
    - [EHOSTUNREACH, EHOSTUNREACH.__eq__, [65], true]
    - [ENETUNREACH, ENETUNREACH.__eq__, [51], true]
    - [ENETDOWN,    ENETDOWN.__eq__,    [50], true]

# ---------------------------------------------------------------------------
# Table: errorcode reverse-lookups for keys 60, 65, 51, 50
#
# Groups the four new errorcode reverse-lookup checks in one indexed table.
# No prior table covers errorcode[60/65/51/50] lookups.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra10.errorcode_lookups:
  description: "errno.errorcode reverse-lookups for ETIMEDOUT/EHOSTUNREACH/ENETUNREACH/ENETDOWN"
  kind: python_call_eq
  category: errorcode
  id_prefix: e10el

  columns: [id, function, args, expected]
  rows:
    - [etimedout,   errorcode.__getitem__, [60], "ETIMEDOUT"]
    - [ehostunreach, errorcode.__getitem__, [65], "EHOSTUNREACH"]
    - [enetunreach, errorcode.__getitem__, [51], "ENETUNREACH"]
    - [enetdown,    errorcode.__getitem__, [50], "ENETDOWN"]
