spec: threading_extra916
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading synchronization and concurrency classes for __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra916.thread_event_qualnames:
  description: "threading.Thread and threading.Event __qualname__ identity"
  kind: python_call_eq
  category: thread_event_qualnames
  id_prefix: th916te
  columns: [id, function, args, expected]
  rows:
    - [th916te001, threading.Thread.__qualname__.__eq__,   ["Thread"],  true]
    - [th916te002, threading.Thread.__name__.__eq__,       ["Thread"],  true]
    - [th916te003, threading.Thread.__module__.__eq__,     ["threading"], true]
    - [th916te004, threading.Event.__qualname__.__eq__,    ["Event"],   true]
    - [th916te005, threading.Event.__name__.__eq__,        ["Event"],   true]
    - [th916te006, threading.Event.__module__.__eq__,      ["threading"], true]

table threading_extra916.semaphore_condition_qualnames:
  description: "threading.Semaphore, BoundedSemaphore, and Condition __qualname__ identity"
  kind: python_call_eq
  category: semaphore_condition_qualnames
  id_prefix: th916sc
  columns: [id, function, args, expected]
  rows:
    - [th916sc001, threading.Semaphore.__qualname__.__eq__,        ["Semaphore"],        true]
    - [th916sc002, threading.Semaphore.__name__.__eq__,            ["Semaphore"],        true]
    - [th916sc003, threading.Semaphore.__module__.__eq__,          ["threading"],        true]
    - [th916sc004, threading.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [th916sc005, threading.BoundedSemaphore.__name__.__eq__,     ["BoundedSemaphore"], true]
    - [th916sc006, threading.BoundedSemaphore.__module__.__eq__,   ["threading"],        true]
    - [th916sc007, threading.Condition.__qualname__.__eq__,        ["Condition"],        true]
    - [th916sc008, threading.Condition.__name__.__eq__,            ["Condition"],        true]
    - [th916sc009, threading.Condition.__module__.__eq__,          ["threading"],        true]

table threading_extra916.timer_barrier_qualnames:
  description: "threading.Timer and threading.Barrier __qualname__ identity"
  kind: python_call_eq
  category: timer_barrier_qualnames
  id_prefix: th916tb
  columns: [id, function, args, expected]
  rows:
    - [th916tb001, threading.Timer.__qualname__.__eq__,   ["Timer"],   true]
    - [th916tb002, threading.Timer.__name__.__eq__,       ["Timer"],   true]
    - [th916tb003, threading.Timer.__module__.__eq__,     ["threading"], true]
    - [th916tb004, threading.Barrier.__qualname__.__eq__, ["Barrier"],  true]
    - [th916tb005, threading.Barrier.__name__.__eq__,     ["Barrier"],  true]
    - [th916tb006, threading.Barrier.__module__.__eq__,   ["threading"], true]
    - [th916tb007, threading.Lock.__qualname__.__eq__,    ["lock"],     true]
    - [th916tb008, threading.RLock.__qualname__.__eq__,   ["RLock"],    true]
