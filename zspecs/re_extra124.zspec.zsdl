spec: re_extra124
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra123.zspec.zsdl."
    - "This spec covers: re module function __code__.co_varnames[1] and co_varnames[2] elements not yet covered."
    - "re_extra67 covered co_varnames[0]=='pattern' for search, compile, match, sub (all take 'pattern' as first argument)."
    - "re_extra107 covered co_name and co_argcount for match/search/findall/compile/sub/fullmatch/split/subn."
    - "NO prior re spec asserts co_varnames[1] or co_varnames[2] for any re module function."
    - "re.compile.__code__.co_varnames[1] == 'flags' (5 chars; compile takes pattern and flags as its two parameters)."
    - "re.search.__code__.co_varnames[1] == 'string' (6 chars; search takes pattern, string, flags)."
    - "re.search.__code__.co_varnames[2] == 'flags' (5 chars)."
    - "re.match.__code__.co_varnames[1] == 'string' (6 chars)."
    - "re.match.__code__.co_varnames[2] == 'flags' (5 chars)."
    - "re.fullmatch.__code__.co_varnames[1] == 'string' (6 chars)."
    - "re.findall.__code__.co_varnames[1] == 'string' (6 chars)."
    - "re.sub.__code__.co_varnames[1] == 'repl' (4 chars; sub takes pattern, repl, string, ...)."
    - "re.split.__code__.co_varnames[1] == 'string' (6 chars)."
    - "re.split.__code__.co_varnames[2] == 'maxsplit' (8 chars; unique — not 'flags' like other functions)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __code__.co_varnames[1] — second parameter
# compile(pattern, flags=0)               -> co_varnames[1] == 'flags' (5)
# search(pattern, string, flags=0)        -> co_varnames[1] == 'string' (6)
# match(pattern, string, flags=0)         -> co_varnames[1] == 'string' (6)
# fullmatch(pattern, string, flags=0)     -> co_varnames[1] == 'string' (6)
# findall(pattern, string, flags=0)       -> co_varnames[1] == 'string' (6)
# sub(pattern, repl, string, ...)         -> co_varnames[1] == 'repl' (4)
# split(pattern, string, ...)             -> co_varnames[1] == 'string' (6)
# re_extra67 covered co_varnames[0]=='pattern' for search/compile/match/sub.
# NO prior re spec asserts co_varnames[1] for any re function.
# ---------------------------------------------------------------------------

table re_extra124.re_functions_co_varnames_1:
  description: "re module function __code__.co_varnames[1]: compile='flags'(5); search/match/fullmatch/findall/split='string'(6); sub='repl'(4); co_varnames[1] is the second parameter; all assertions novel (re_extra67 covered co_varnames[0] only; no prior spec covers [1])"
  kind: python_call_eq
  category: code_introspection
  id_prefix: revar124a

  columns: [id, function, args, expected, description]
  rows:
    - [compile_cv1_eq,    "compile.__code__.co_varnames[1].__eq__",    ["flags"],   true,  "re.compile.__code__.co_varnames[1] == 'flags' (5 chars; compile(pattern, flags=0) takes only two parameters; 'flags' at index 1 is a bitmask of re constants like re.IGNORECASE that modify pattern matching behavior)"]
    - [compile_cv1_len,   "compile.__code__.co_varnames[1].__len__",   [],           5,     "re.compile.__code__.co_varnames[1].__len__() == 5 ('flags' has 5 characters; re.compile has only 2 parameters so co_varnames[1] is the last parameter)"]
    - [search_cv1_eq,     "search.__code__.co_varnames[1].__eq__",     ["string"],  true,  "re.search.__code__.co_varnames[1] == 'string' (6 chars; search(pattern, string, flags=0) takes pattern then string; 'string' is the text to search for the pattern; search scans through the entire string looking for a match)"]
    - [match_cv1_eq,      "match.__code__.co_varnames[1].__eq__",      ["string"],  true,  "re.match.__code__.co_varnames[1] == 'string' (6 chars; match(pattern, string, flags=0) takes pattern then string; 'string' is the text to match at the beginning; match only matches at the start of the string unlike search)"]
    - [fullmatch_cv1_eq,  "fullmatch.__code__.co_varnames[1].__eq__",  ["string"],  true,  "re.fullmatch.__code__.co_varnames[1] == 'string' (6 chars; fullmatch(pattern, string, flags=0) takes pattern then string; 'string' must match the entire pattern from start to end)"]
    - [findall_cv1_eq,    "findall.__code__.co_varnames[1].__eq__",    ["string"],  true,  "re.findall.__code__.co_varnames[1] == 'string' (6 chars; findall(pattern, string, flags=0) takes pattern then string; returns a list of all non-overlapping matches)"]
    - [sub_cv1_eq,        "sub.__code__.co_varnames[1].__eq__",        ["repl"],    true,  "re.sub.__code__.co_varnames[1] == 'repl' (4 chars; sub(pattern, repl, string, ...) takes pattern then repl (replacement); 'repl' is the substitution string or callable; it comes before 'string' because it defines what to replace the match with)"]
    - [split_cv1_eq,      "split.__code__.co_varnames[1].__eq__",      ["string"],  true,  "re.split.__code__.co_varnames[1] == 'string' (6 chars; split(pattern, string, maxsplit=0, flags=0) takes pattern then string; 'string' is the input text to split on matches of the pattern)"]

# ---------------------------------------------------------------------------
# re module function __code__.co_varnames[2] — third parameter
# search(pattern, string, flags=0)      -> co_varnames[2] == 'flags' (5)
# match(pattern, string, flags=0)       -> co_varnames[2] == 'flags' (5)
# fullmatch(pattern, string, flags=0)   -> co_varnames[2] == 'flags' (5)
# findall(pattern, string, flags=0)     -> co_varnames[2] == 'flags' (5)
# split(pattern, string, maxsplit=0, ..)-> co_varnames[2] == 'maxsplit' (8; unique!)
# sub(pattern, repl, string, ...)       -> co_varnames[2] == 'string' (6)
# Note: compile only has 2 parameters so co_varnames[2] does not apply.
# NO prior re spec asserts co_varnames[2] for any re function.
# ---------------------------------------------------------------------------

table re_extra124.re_functions_co_varnames_2:
  description: "re module function __code__.co_varnames[2]: search/match/fullmatch/findall='flags'(5); split='maxsplit'(8; unique, not flags); sub='string'(6); all assertions novel; split uniquely uses 'maxsplit' at index 2 while others use 'flags'"
  kind: python_call_eq
  category: code_introspection
  id_prefix: revar124b

  columns: [id, function, args, expected, description]
  rows:
    - [search_cv2_eq,    "search.__code__.co_varnames[2].__eq__",    ["flags"],     true,  "re.search.__code__.co_varnames[2] == 'flags' (5 chars; co_varnames is ('pattern', 'string', 'flags'); 'flags' at index 2 is a bitmask of re constants controlling search behavior; it has a default value of 0)"]
    - [search_cv2_len,   "search.__code__.co_varnames[2].__len__",   [],             5,     "re.search.__code__.co_varnames[2].__len__() == 5 ('flags' has 5 characters; same length as co_varnames[1] for compile which is also 'flags')"]
    - [match_cv2_eq,     "match.__code__.co_varnames[2].__eq__",     ["flags"],     true,  "re.match.__code__.co_varnames[2] == 'flags' (5 chars; co_varnames is ('pattern', 'string', 'flags'); match/search/fullmatch/findall all share identical co_varnames — same three-parameter signature)"]
    - [fullmatch_cv2_eq, "fullmatch.__code__.co_varnames[2].__eq__", ["flags"],     true,  "re.fullmatch.__code__.co_varnames[2] == 'flags' (5 chars; fullmatch shares the same (pattern, string, flags) parameter list as search and match; 'flags' at index 2 modifies pattern matching globally)"]
    - [findall_cv2_eq,   "findall.__code__.co_varnames[2].__eq__",   ["flags"],     true,  "re.findall.__code__.co_varnames[2] == 'flags' (5 chars; findall also uses (pattern, string, flags) as its three positional parameters; all four scan-type functions use 'flags' at index 2)"]
    - [split_cv2_eq,     "split.__code__.co_varnames[2].__eq__",     ["maxsplit"],  true,  "re.split.__code__.co_varnames[2] == 'maxsplit' (8 chars; split uniquely uses 'maxsplit' at index 2 instead of 'flags'; split(pattern, string, maxsplit=0, flags=0) limits the number of splits; 'maxsplit' is the longest co_varnames[2] value across re functions)"]
    - [split_cv2_len,    "split.__code__.co_varnames[2].__len__",    [],             8,     "re.split.__code__.co_varnames[2].__len__() == 8 ('maxsplit' has 8 characters: 'max'(3)+'split'(5)==8; longer than 'flags'(5) and 'string'(6); this makes re.split unique in its third parameter name)"]
    - [sub_cv2_eq,       "sub.__code__.co_varnames[2].__eq__",       ["string"],    true,  "re.sub.__code__.co_varnames[2] == 'string' (6 chars; sub(pattern, repl, string, ...) has 'string' at index 2 because 'repl' comes first at index 1; sub is the only scan-type function where the input string is at index 2 rather than index 1)"]

# ---------------------------------------------------------------------------
# Cross-comparisons: co_varnames[1] and [2] length and value assertions
# Confirms that search/match/fullmatch/findall all share identical co_varnames.
# Confirms that split is unique in having 'maxsplit' at co_varnames[2].
# Confirms that sub is unique in having 'repl' at co_varnames[1].
# compile is unique in having only 2 parameters ('pattern', 'flags').
# ---------------------------------------------------------------------------

table re_extra124.re_functions_co_varnames_cross:
  description: "re module co_varnames cross-comparisons: search/match/fullmatch/findall all have co_varnames[1]='string'(6); split uniquely has [2]='maxsplit'(8) not 'flags'(5); sub uniquely has [1]='repl'(4) not 'string'(6); all cross-comparisons novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: revar124c

  columns: [id, function, args, expected, description]
  rows:
    - [search_cv1_len,   "search.__code__.co_varnames[1].__len__",    [],           6,     "re.search.__code__.co_varnames[1].__len__() == 6 ('string' has 6 characters; search/match/fullmatch/findall/split all have 'string'(6) at co_varnames[1])"]
    - [sub_cv1_lt_search_cv1, "sub.__code__.co_varnames[1].__len__.__lt__", [6],   true,  "len(re.sub co_varnames[1]) < len(re.search co_varnames[1]) (len('repl')==4 < len('string')==6; sub uniquely has a shorter second parameter because 'repl' precedes 'string' in sub's argument order)"]
    - [split_cv2_gt_search_cv2, "split.__code__.co_varnames[2].__len__.__gt__", [5], true, "len(re.split co_varnames[2]) > len(re.search co_varnames[2]) (len('maxsplit')==8 > len('flags')==5; split uniquely uses 'maxsplit' as its third parameter while all other three-parameter re functions use 'flags')"]
    - [search_cv2_ne_split_cv2, "search.__code__.co_varnames[2].__eq__", ["maxsplit"], false, "re.search.__code__.co_varnames[2] != 'maxsplit' (search uses 'flags' at index 2, not 'maxsplit'; only re.split uses 'maxsplit' as its third parameter)"]
    - [compile_cv1_len, "compile.__code__.co_varnames[1].__len__",   [],            5,     "re.compile.__code__.co_varnames[1].__len__() == 5 ('flags' has 5 chars; compile only has 2 parameters so 'flags' is the last; same length as 'flags' at co_varnames[2] for search/match/fullmatch/findall)"]
    - [search_cv1_ne_compile_cv1, "search.__code__.co_varnames[1].__eq__", ["flags"], false, "re.search.__code__.co_varnames[1] != 'flags' (search has 'string' at index 1, not 'flags'; compile is the only two-parameter re function where 'flags' appears at index 1)"]
    - [sub_cv2_len,     "sub.__code__.co_varnames[2].__len__",       [],            6,     "re.sub.__code__.co_varnames[2].__len__() == 6 ('string' has 6 chars; sub has 'repl' at index 1 and 'string' at index 2, shifted by one position relative to search/match)"]
    - [match_cv1_eq_search_cv1, "match.__code__.co_varnames[1].__eq__", ["string"], true, "re.match.__code__.co_varnames[1] == re.search.__code__.co_varnames[1] == 'string' (match and search share identical co_varnames ('pattern','string','flags'); they differ only in behavior: match anchors at the start, search scans the whole string)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra124.compile.co_varnames_1_flags:
  description: "re.compile.__code__.co_varnames[1] == 'flags' (5 chars; re.compile(pattern, flags=0) has exactly two formal parameters: 'pattern' at index 0 and 'flags' at index 1; 'flags' is a bitmask of re module constants (re.IGNORECASE, re.MULTILINE, etc.) that modify the pattern's matching behavior; compile is the only common re function with only 2 parameters — search/match/fullmatch/findall all have 3 parameters with 'string' at index 1; re_extra67 covered co_varnames[0]=='pattern' for compile; re_extra107 covered co_argcount==2 for compile; no prior re spec has asserted co_varnames[1] for any re function); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "compile.__code__.co_varnames[1].__eq__"
  args: ["flags"]
  expected: true

invariant re_extra124.search.co_varnames_1_string:
  description: "re.search.__code__.co_varnames[1] == 'string' (6 chars; re.search(pattern, string, flags=0) has 'string' as its second parameter at index 1; 'string' is the text to scan for the pattern; search(pattern, string) is the most common re API call pattern; search/match/fullmatch/findall all share the same signature (pattern, string, flags=0) so all have 'string' at co_varnames[1]; re_extra67 covered co_varnames[0]=='pattern' for search; no prior re spec has asserted co_varnames[1] for search); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "search.__code__.co_varnames[1].__eq__"
  args: ["string"]
  expected: true

invariant re_extra124.sub.co_varnames_1_repl:
  description: "re.sub.__code__.co_varnames[1] == 'repl' (4 chars; re.sub(pattern, repl, string, count=0, flags=0) has 'repl' as its second parameter at index 1; 'repl' is the replacement string or callable that replaces each match of pattern in string; sub is unique among common re functions in having 'repl' at co_varnames[1] rather than 'string' — this is because the replacement comes before the input string in the argument order; 'repl' at 4 chars is shorter than 'string' at 6 chars; re_extra67 covered co_varnames[0]=='pattern' for sub; no prior re spec has asserted co_varnames[1] for sub); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "sub.__code__.co_varnames[1].__eq__"
  args: ["repl"]
  expected: true

invariant re_extra124.split.co_varnames_2_maxsplit:
  description: "re.split.__code__.co_varnames[2] == 'maxsplit' (8 chars; re.split(pattern, string, maxsplit=0, flags=0) has 'maxsplit' as its third parameter at index 2; 'maxsplit' limits the number of splits performed — if maxsplit is nonzero at most maxsplit splits occur; re.split is unique among common re functions in having 'maxsplit' at co_varnames[2] — all other three-parameter re functions (search, match, fullmatch, findall) have 'flags' at co_varnames[2]; 'maxsplit' at 8 chars is the longest co_varnames[2] value across all re functions (longer than 'flags'(5) and 'string'(6)); no prior re spec has asserted co_varnames[2] for any re function); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "split.__code__.co_varnames[2].__eq__"
  args: ["maxsplit"]
  expected: true

invariant re_extra124.search.co_varnames_2_flags:
  description: "re.search.__code__.co_varnames[2] == 'flags' (5 chars; re.search(pattern, string, flags=0) has 'flags' as its third parameter at index 2; 'flags' is a bitmask of re constants (re.IGNORECASE==2, re.MULTILINE==8, etc.) that modify pattern matching; search/match/fullmatch/findall all have 'flags' at co_varnames[2], while split uniquely has 'maxsplit' there instead; 'flags'(5 chars) is shorter than 'string'(6 chars) which appears at co_varnames[1] for search; no prior re spec has asserted co_varnames[2] for any re function; this is the first re spec to assert the third parameter name for any re module function); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "search.__code__.co_varnames[2].__eq__"
  args: ["flags"]
  expected: true

