spec: socket_extra219
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol (TCP)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket(socket.AF_INET, socket.SOCK_STREAM).__class__.__name__ == 'socket' — creates a real TCP/IPv4 socket."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily'; socket.AF_UNIX.value == 1 (macOS/BSD)."
    - "socket.SO_REUSEADDR.__class__.__name__ == 'int'; socket.SO_REUSEADDR == 4 on macOS (Linux uses 2)."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int'; socket.SOL_SOCKET == 65535 on macOS/BSD (Linux uses 1)."
    - "socket.SHUT_RDWR == 2; socket.SHUT_RD == 0; socket.SHUT_WR == 1 — POSIX shutdown(2) direction flags."
    - "NOTE: SO_REUSEADDR==4 and SOL_SOCKET==65535 are macOS/BSD-specific values."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket(AF_INET, SOCK_STREAM) class identity
#
# socket.socket(socket.AF_INET, socket.SOCK_STREAM).__class__.__name__ == 'socket'
# ---------------------------------------------------------------------------

invariant socket_extra219.tcp_socket_class_name:
  description: "socket.socket(socket.AF_INET, socket.SOCK_STREAM).__class__.__name__ == 'socket' — creating an AF_INET/SOCK_STREAM TCP socket returns an instance of the socket class; __class__.__name__ is 'socket'; this creates a real OS socket descriptor (closed after the check); verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "socket.socket(socket.AF_INET, socket.SOCK_STREAM).__class__.__name__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNIX — AddressFamily constant checks (macOS)
#
# socket.AF_UNIX.__class__.__name__ == 'AddressFamily'
# socket.AF_UNIX.value              == 1  (macOS/BSD; same value as Linux)
# ---------------------------------------------------------------------------

table socket_extra219.af_unix_constant:
  description: "socket.AF_UNIX address family constant checks in socketeq219 namespace — wave 219 theme: AF_UNIX.__class__.__name__ == 'AddressFamily'; AF_UNIX.value == 1 on macOS (POSIX UNIX domain sockets; consistent with Linux AF_UNIX==1; AF_UNIX is used for local IPC via filesystem path sockets); verified with Python 3.14.3 on macOS"
  kind: python_call_eq
  category: constants
  id_prefix: socketeq219

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_class,  "socket.AF_UNIX.__class__.__name__.__eq__",  ["AddressFamily"], true, "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an IntEnum member of socket.AddressFamily"]
    - [af_unix_value,  "socket.AF_UNIX.value.__eq__",               [1],               true, "socket.AF_UNIX.value == 1 — UNIX domain socket address family value; consistent across macOS and Linux"]

# ---------------------------------------------------------------------------
# socket.SO_REUSEADDR and socket.SOL_SOCKET — macOS-specific values
#
# socket.SO_REUSEADDR.__class__.__name__ == 'int'
# socket.SO_REUSEADDR                    == 4  (macOS; Linux uses 2)
# socket.SOL_SOCKET.__class__.__name__   == 'int'
# socket.SOL_SOCKET                      == 65535  (macOS/BSD; Linux uses 1)
# ---------------------------------------------------------------------------

table socket_extra219.socket_option_constants:
  description: "socket.SO_REUSEADDR and socket.SOL_SOCKET constant type and value checks in socketeq219a namespace — wave 219 theme: SO_REUSEADDR is plain int value 4 on macOS (Linux uses 2; platform-specific BSD socket constant); SOL_SOCKET is plain int value 65535 (0xFFFF) on macOS/BSD (Linux uses 1); both are plain int not IntEnum; used as arguments to getsockopt/setsockopt; verified with Python 3.14.3 on macOS"
  kind: python_call_eq
  category: constants
  id_prefix: socketeq219a

  columns: [id, function, args, expected, description]
  rows:
    - [so_reuseaddr_class,  "socket.SO_REUSEADDR.__class__.__name__.__eq__",  ["int"],  true,  "socket.SO_REUSEADDR.__class__.__name__ == 'int' — SO_REUSEADDR is a plain Python int on macOS"]
    - [so_reuseaddr_value,  "socket.SO_REUSEADDR.__eq__",                    [4],      true,  "socket.SO_REUSEADDR == 4 — macOS/BSD-specific value (Linux uses 2); allow reuse of local addresses"]
    - [sol_socket_class,    "socket.SOL_SOCKET.__class__.__name__.__eq__",   ["int"],  true,  "socket.SOL_SOCKET.__class__.__name__ == 'int' — SOL_SOCKET is a plain Python int on macOS"]
    - [sol_socket_value,    "socket.SOL_SOCKET.__eq__",                      [65535],  true,  "socket.SOL_SOCKET == 65535 — macOS/BSD-specific value 0xFFFF (Linux uses 1); socket-level option layer"]

# ---------------------------------------------------------------------------
# socket.SHUT_RD, SHUT_WR, SHUT_RDWR — shutdown direction constants
#
# socket.SHUT_RDWR == 2
# socket.SHUT_RD   == 0
# socket.SHUT_WR   == 1
# ---------------------------------------------------------------------------

table socket_extra219.shut_constants_values:
  description: "socket.SHUT_RD/SHUT_WR/SHUT_RDWR shutdown direction constant value checks in socketeq219b namespace — wave 219 theme: SHUT_RD==0 (disable further receives); SHUT_WR==1 (disable further sends); SHUT_RDWR==2 (disable both); these are POSIX shutdown(2) direction flags exposed as plain int; values are consistent across macOS and Linux; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: socketeq219b

  columns: [id, function, args, expected, description]
  rows:
    - [shut_rd_value,    "socket.SHUT_RD.__eq__",    [0],  true,  "socket.SHUT_RD == 0 — POSIX shutdown(2) flag to disable further receive operations"]
    - [shut_wr_value,    "socket.SHUT_WR.__eq__",    [1],  true,  "socket.SHUT_WR == 1 — POSIX shutdown(2) flag to disable further send operations"]
    - [shut_rdwr_value,  "socket.SHUT_RDWR.__eq__",  [2],  true,  "socket.SHUT_RDWR == 2 — POSIX shutdown(2) flag to disable both send and receive operations"]
