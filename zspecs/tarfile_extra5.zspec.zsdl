spec: tarfile_extra5
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl and prior extras."
    - "tarfile (base) covers: USTAR/GNU/PAX/DEFAULT_FORMAT values, BLOCKSIZE, RECORDSIZE, ENCODING, type flag bytes, TarInfo construction, class __name__ for TarFile/TarInfo/TarError/ReadError, exception hierarchy, is_tarfile."
    - "tarfile_extra covers: class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError, open/__name__, is_tarfile/__name__, TarError base, ENCODING class name."
    - "tarfile_extra2 covers: TarFile/__name__/__module__, TarInfo/__name__/__module__, CompressionError/__name__/base, ENCODING class, REGULAR_TYPES/SUPPORTED_TYPES class, open/__name__, TarFile/TarInfo is_type, REGULAR_TYPES/SUPPORTED_TYPES membership."
    - "tarfile_extra3 covers: class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError/ExtractError/HeaderError, open/__name__, is_tarfile/__name__, TarFile __module__, TarError base, ReadError base, REGTYPE/DIRTYPE/SYMTYPE values, TarInfo instance class."
    - "tarfile_extra4 covers: __qualname__ for TarFile/TarInfo (table), exception __qualname__ table, is_tarfile/__qualname__, open/__qualname__, HeaderError/__qualname__, StreamError/__qualname__, GNU/PAX/USTAR format constant type as int."
    - "This spec adds: TarInfo.__module__ (extra2 covers TarInfo.__module__ per notes, but extra3 only covers TarFile.__module__; this is a targeted cross-check), TarError.__module__ and ReadError.__module__ (new — not in any prior spec), and TarFile.__bases__[0].__name__ == 'object' and TarInfo.__bases__[0].__name__ == 'object' (both are direct subclasses of object; not in any prior spec)."
    - "tarfile.TarFile.__bases__[0].__name__ == 'object' — TarFile has no custom base class."
    - "tarfile.TarInfo.__bases__[0].__name__ == 'object' — TarInfo has no custom base class."
    - "tarfile.TarInfo.__module__ == 'tarfile' — defined at top level of the tarfile module."
    - "tarfile.TarError.__module__ == 'tarfile' — defined at top level of the tarfile module."
    - "tarfile.ReadError.__module__ == 'tarfile' — defined at top level of the tarfile module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for TarInfo, TarError, ReadError
# tarfile_extra3 covers TarFile.__module__; these three are complementary and new.
# ---------------------------------------------------------------------------

table tarfile_extra5.exception_modules:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [TarInfo,   TarInfo.__module__.__eq__,   ["tarfile"], true]
    - [TarError,  TarError.__module__.__eq__,  ["tarfile"], true]
    - [ReadError, ReadError.__module__.__eq__, ["tarfile"], true]

# ---------------------------------------------------------------------------
# TarFile.__bases__[0].__name__ == 'object'
# TarFile is a direct subclass of object — no intermediate base class.
# Not covered in any prior tarfile spec.
# ---------------------------------------------------------------------------

invariant tarfile_extra5.TarFile.base_name:
  description: "tarfile.TarFile.__bases__[0].__name__ == 'object' — direct subclass of object"
  category: hierarchy
  kind: python_call_eq
  function: TarFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# TarInfo.__bases__[0].__name__ == 'object'
# TarInfo is also a direct subclass of object — confirmed on Python 3.12.
# Not covered in any prior tarfile spec.
# ---------------------------------------------------------------------------

invariant tarfile_extra5.TarInfo.base_name:
  description: "tarfile.TarInfo.__bases__[0].__name__ == 'object' — direct subclass of object"
  category: hierarchy
  kind: python_call_eq
  function: TarInfo.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# tarfile.__name__ == 'tarfile' — the module's own __name__ attribute.
# Not covered in any prior tarfile spec.
# ---------------------------------------------------------------------------

invariant tarfile_extra5.module.name:
  description: "tarfile.__name__ == 'tarfile' — the module object's __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["tarfile"]
  expected: true
