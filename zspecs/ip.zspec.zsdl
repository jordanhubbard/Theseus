spec: ip
version: ">=2.0.0"
backend: node(ip)

docs: https://www.npmjs.com/package/ip

provenance:
  derived_from:
    - "ip README — https://www.npmjs.com/package/ip"
    - "Test vectors verified with ip via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ip source"
  notes:
    - "ip is an npm package. Install: npm install ip"
    - "ip.toLong(addr) converts a dotted-decimal IPv4 address to a 32-bit integer."
    - "ip.fromLong(n) converts a 32-bit integer to dotted-decimal IPv4."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer or dotted-decimal string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ip.toLong:
  kind: node_module_call_eq
  function: toLong
  category: convert
  id_prefix: iptolong

  columns: [id, args, expected]
  rows:
    - [loopback,   ["127.0.0.1"],       2130706433]
    - [private,    ["192.168.1.1"],     3232235777]
    - [broadcast,  ["255.255.255.255"], 4294967295]

table ip.fromLong:
  kind: node_module_call_eq
  function: fromLong
  category: convert
  id_prefix: ipfromlong

  columns: [id, args, expected]
  rows:
    - [loopback,  [2130706433], "127.0.0.1"]
    - [private,   [3232235777], "192.168.1.1"]
    - [zero,      [0],          "0.0.0.0"]
