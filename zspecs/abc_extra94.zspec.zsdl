spec: abc_extra94
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra93

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra93.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc abstractmethod function attributes and abstractproperty method class names. NEW in extra94: abstractmethod.__code__.co_name=='abstractmethod' (len=14); abstractmethod.__code__.co_argcount==1; abstractmethod.__module__=='abc'; abstractmethod.__qualname__=='abstractmethod' (len=14); abstractmethod.__class__.__name__=='function'; abstractproperty.__init__.__class__.__name__=='wrapper_descriptor'; abstractproperty.__get__.__class__.__name__=='wrapper_descriptor'; abstractproperty.getter.__class__.__name__=='method_descriptor'; abstractproperty.setter.__class__.__name__=='method_descriptor'; abstractproperty.deleter.__class__.__name__=='method_descriptor'; abstractproperty.__module__=='abc'; abstractproperty.__name__.__len__()==16; abstractproperty.__mro__.__len__()==3; ABCMeta.__prepare__.__class__.__name__=='builtin_function_or_method'; ABCMeta.__prepare__.__qualname__=='ABCMeta.__prepare__' (len=19); ABCMeta.register.__class__.__name__=='function'; ABCMeta._dump_registry.__class__.__name__=='function'; ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractmethod.__code__.co_name == 'abstractmethod'. The code object's co_name is the function's own name, which is 'abstractmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'. abstractproperty inherits from property (a C-level type), so its __init__ is a wrapper_descriptor inherited from property. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractproperty.getter.__class__.__name__ == 'method_descriptor'. getter (and setter/deleter) are method_descriptors inherited from property — different from __init__ and __get__ which are wrapper_descriptors. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method'. __prepare__ is a C-level static method inherited from type, not a Python function. Its __module__ is None (not 'abc'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod function attributes — extra94
#
# Wave 254 theme: abc abstractmethod function attributes and abstractproperty
#                 method class names.
#
# abstractmethod.__code__.co_name == 'abstractmethod'  (len=14)
# abstractmethod.__code__.co_argcount == 1
# abstractmethod.__module__ == 'abc'
# abstractmethod.__qualname__ == 'abstractmethod'      (len=14)
# abstractmethod.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table abc_extra94.abc_abstractmethod_code_attrs:
  description: "abc.abstractmethod code object and identity attribute checks in abcabstractmethod94 namespace — wave 254 theme: abc abstractmethod function attributes; abc.abstractmethod is a Python decorator function defined in Lib/abc.py; abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (co_name is the function's own name as defined in the source, which is 'abstractmethod', len=14); abstractmethod.__code__.co_argcount.__eq__(1)==True (abstractmethod takes exactly 1 argument: the function being decorated, bound to parameter 'funcobj'); abstractmethod.__module__.__eq__('abc')==True (Python function in Lib/abc.py); abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14; module-level function so qualname equals name); abstractmethod.__class__.__name__.__eq__('function')==True (a Python function, not a builtin); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabstractmethod94

  columns: [id, function, args, expected, description]
  rows:
    - [am_co_name,   "abc.abstractmethod.__code__.co_name.__eq__",     ["abstractmethod"], true, "abc.abstractmethod.__code__.co_name == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_co_name_l, "abc.abstractmethod.__code__.co_name.__len__",    [],                 14,   "abc.abstractmethod.__code__.co_name.__len__() == 14; verified with Python 3.14.3"]
    - [am_co_argc,   "abc.abstractmethod.__code__.co_argcount.__eq__", [1],                true, "abc.abstractmethod.__code__.co_argcount == 1 (takes one arg: funcobj); verified with Python 3.14.3"]
    - [am_module,    "abc.abstractmethod.__module__.__eq__",            ["abc"],            true, "abc.abstractmethod.__module__ == 'abc' — Python function in Lib/abc.py; verified with Python 3.14.3"]
    - [am_qualname,  "abc.abstractmethod.__qualname__.__eq__",          ["abstractmethod"], true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_class_nm,  "abc.abstractmethod.__class__.__name__.__eq__",    ["function"],       true, "abc.abstractmethod.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractproperty method class names — extra94
#
# abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'
# abstractproperty.__get__.__class__.__name__ == 'wrapper_descriptor'
# abstractproperty.getter.__class__.__name__ == 'method_descriptor'
# abstractproperty.setter.__class__.__name__ == 'method_descriptor'
# abstractproperty.deleter.__class__.__name__ == 'method_descriptor'
# abstractproperty.__module__ == 'abc'
# abstractproperty.__name__.__len__() == 16
# abstractproperty.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table abc_extra94.abc_abstractproperty_method_class_names:
  description: "abc.abstractproperty method class name checks in abcabstractmethod94 namespace — wave 254 theme: abstractproperty method class names; abc.abstractproperty is a deprecated abstract property class that inherits from the builtin property type; since property is a C-level type, its dunder methods are C-level descriptors: abstractproperty.__init__.__class__.__name__.__eq__('wrapper_descriptor')==True (inherited __init__ from property, a C-level wrapper); abstractproperty.__get__.__class__.__name__.__eq__('wrapper_descriptor')==True (getter slot implementation from property); the accessor methods getter/setter/deleter are method_descriptors (different from wrapper_descriptors): abstractproperty.getter.__class__.__name__.__eq__('method_descriptor')==True; abstractproperty.setter.__class__.__name__.__eq__('method_descriptor')==True; abstractproperty.deleter.__class__.__name__.__eq__('method_descriptor')==True; abstractproperty.__module__.__eq__('abc')==True (defined in Lib/abc.py); abstractproperty.__name__.__len__()==16 ('abstractproperty' is 16 chars); abstractproperty.__mro__.__len__()==3 (MRO is [abstractproperty, property, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabstractmethod94a

  columns: [id, function, args, expected, description]
  rows:
    - [ap_init_cls,     "abc.abstractproperty.__init__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true, "abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor' — C-level from property; verified with Python 3.14.3"]
    - [ap_get_cls,      "abc.abstractproperty.__get__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true, "abstractproperty.__get__.__class__.__name__ == 'wrapper_descriptor' — C-level from property; verified with Python 3.14.3"]
    - [ap_getter_cls,   "abc.abstractproperty.getter.__class__.__name__.__eq__",      ["method_descriptor"],  true, "abstractproperty.getter.__class__.__name__ == 'method_descriptor' — different from wrapper_descriptor; verified with Python 3.14.3"]
    - [ap_setter_cls,   "abc.abstractproperty.setter.__class__.__name__.__eq__",      ["method_descriptor"],  true, "abstractproperty.setter.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [ap_deleter_cls,  "abc.abstractproperty.deleter.__class__.__name__.__eq__",     ["method_descriptor"],  true, "abstractproperty.deleter.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [ap_module,       "abc.abstractproperty.__module__.__eq__",                     ["abc"],                true, "abstractproperty.__module__ == 'abc' — defined in Lib/abc.py; verified with Python 3.14.3"]
    - [ap_name_len,     "abc.abstractproperty.__name__.__len__",                      [],                     16,   "abstractproperty.__name__.__len__() == 16 ('abstractproperty' is 16 chars); verified with Python 3.14.3"]
    - [ap_mro_len,      "abc.abstractproperty.__mro__.__len__",                       [],                     3,    "abstractproperty.__mro__.__len__() == 3 — MRO is [abstractproperty, property, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta.__prepare__ and ABCMeta._dump_registry identity — extra94
#
# ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method'
# ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (len=19)
# ABCMeta.register.__class__.__name__ == 'function'
# ABCMeta._dump_registry.__class__.__name__ == 'function'
# ABCMeta._dump_registry.__qualname__ == 'ABCMeta._dump_registry' (len=22)
# ABCMeta._dump_registry.__module__ == 'abc'
# ---------------------------------------------------------------------------

table abc_extra94.abc_abcmeta_prepare_dump_identity:
  description: "ABCMeta.__prepare__ and ABCMeta._dump_registry identity checks in abcabstractmethod94 namespace — wave 254 theme: ABCMeta class method identity; ABCMeta.__prepare__ is a C-level static method inherited from the type metaclass; ABCMeta.__prepare__.__class__.__name__.__eq__('builtin_function_or_method')==True (C-level, not a Python function); ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__')==True (len=19: 'ABCMeta.'=8 + '__prepare__'=11); ABCMeta.__prepare__.__module__ is None (C-level static method from type metaclass, no Python module); ABCMeta.register.__class__.__name__.__eq__('function')==True (register is a Python function defined in Lib/abc.py, unlike __prepare__); ABCMeta._dump_registry.__class__.__name__.__eq__('function')==True (another Python function in abc.py); ABCMeta._dump_registry.__qualname__.__eq__('ABCMeta._dump_registry')==True (len=22: 'ABCMeta.'=8 + '_dump_registry'=14); ABCMeta._dump_registry.__module__.__eq__('abc')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabstractmethod94b

  columns: [id, function, args, expected, description]
  rows:
    - [prepare_cls,    "ABCMeta.__prepare__.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method' — C-level from type; verified with Python 3.14.3"]
    - [prepare_qeq,    "ABCMeta.__prepare__.__qualname__.__eq__",            ["ABCMeta.__prepare__"],        true, "ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (len=19); verified with Python 3.14.3"]
    - [prepare_qlen,   "ABCMeta.__prepare__.__qualname__.__len__",           [],                             19,   "ABCMeta.__prepare__.__qualname__.__len__() == 19; verified with Python 3.14.3"]
    - [register_cls,   "ABCMeta.register.__class__.__name__.__eq__",         ["function"],                   true, "ABCMeta.register.__class__.__name__ == 'function' — Python function in abc.py; verified with Python 3.14.3"]
    - [dump_cls,       "ABCMeta._dump_registry.__class__.__name__.__eq__",   ["function"],                   true, "ABCMeta._dump_registry.__class__.__name__ == 'function' — Python function in abc.py; verified with Python 3.14.3"]
    - [dump_qeq,       "ABCMeta._dump_registry.__qualname__.__eq__",         ["ABCMeta._dump_registry"],     true, "ABCMeta._dump_registry.__qualname__ == 'ABCMeta._dump_registry' (len=22); verified with Python 3.14.3"]
    - [dump_qlen,      "ABCMeta._dump_registry.__qualname__.__len__",        [],                             22,   "ABCMeta._dump_registry.__qualname__.__len__() == 22; verified with Python 3.14.3"]
    - [dump_module,    "ABCMeta._dump_registry.__module__.__eq__",           ["abc"],                        true, "ABCMeta._dump_registry.__module__ == 'abc' — Python function in Lib/abc.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant abc_extra94.abstractmethod_co_name_eq:
  description: "abc.abstractmethod.__code__.co_name.__eq__('abstractmethod') returns True — the code object's co_name attribute holds the name of the function as defined in the source code; for abc.abstractmethod (a module-level Python function), co_name is 'abstractmethod' (len=14); co_name is the same as __qualname__ for module-level functions; abstractmethod.__code__.co_argcount is 1 (takes a single funcobj argument); the abstractmethod decorator sets funcobj.__isabstractmethod__ = True and returns funcobj; the co_name 'abstractmethod' confirms this is the genuine decorator function, not a wrapper; NEW in extra94: first standalone abstractmethod code object invariant in abcabstractmethod94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.abstractmethod.__code__.co_name.__eq__"
  args: ["abstractmethod"]
  expected: true

invariant abc_extra94.abstractproperty_init_is_wrapper_descriptor:
  description: "abc.abstractproperty.__init__.__class__.__name__.__eq__('wrapper_descriptor') returns True — abstractproperty inherits from the builtin property type (a C-level type); because property is implemented in C, its __init__ method is a C-level 'wrapper_descriptor' (not a Python 'function'); this contrasts with ABCMeta.__subclasscheck__ and ABCMeta.__instancecheck__ (extra93) which ARE Python functions ('function' class) defined in Lib/abc.py; the key distinction is that wrapper_descriptors come from C-level type slot wrappers, while method_descriptors (like abstractproperty.getter/setter/deleter) are C-level method slot wrappers; abstractproperty.__mro__ is [abstractproperty, property, object] (len=3); NEW in extra94: first standalone abstractproperty.__init__ class name invariant in abcabstractmethod94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__init__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra94.abstractproperty_getter_is_method_descriptor:
  description: "abc.abstractproperty.getter.__class__.__name__.__eq__('method_descriptor') returns True — abstractproperty.getter is a 'method_descriptor' (not a 'wrapper_descriptor' like __init__ and __get__); both are C-level descriptors but serve different roles: wrapper_descriptors wrap C slot functions (tp_init, tp_descr_get etc.), while method_descriptors wrap C method functions (PyMethodDef entries); abstractproperty.setter and abstractproperty.deleter are also method_descriptors; abstractproperty.getter.__qualname__ is 'property.getter' (len=15, reflecting that getter is defined on property, not on abstractproperty); this is distinct from __init__ which shows 'wrapper_descriptor' class; NEW in extra94: first standalone abstractproperty.getter class name invariant in abcabstractmethod94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.getter.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

invariant abc_extra94.ABCMeta_prepare_is_builtin:
  description: "abc.ABCMeta.__prepare__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABCMeta.__prepare__ is a C-level builtin_function_or_method inherited from the 'type' metaclass; it is NOT a Python function (unlike ABCMeta.__subclasscheck__, __instancecheck__, __new__, register, and _dump_registry which are all Python functions with class='function'); __prepare__ is called by Python's class creation machinery before the class body is executed; ABCMeta.__prepare__.__qualname__ is 'ABCMeta.__prepare__' (len=19); ABCMeta.__prepare__.__module__ is None (C-level static method from type, no Python module attribution); NEW in extra94: first standalone ABCMeta.__prepare__ class name invariant in abcabstractmethod94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__prepare__.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra94.ABCMeta_dump_registry_is_function:
  description: "abc.ABCMeta._dump_registry.__class__.__name__.__eq__('function') returns True — ABCMeta._dump_registry is a Python function defined in Lib/abc.py that outputs the contents of an abstract base class registry to a stream (for debugging); _dump_registry.__module__ is 'abc'; _dump_registry.__qualname__ is 'ABCMeta._dump_registry' (len=22, the longest qualname among the ABCMeta methods checked in extra93 and extra94 — longer than ABCMeta.__subclasscheck__ at len=25? no: __subclasscheck__ is 25 while _dump_registry is 22); all Python-defined ABCMeta methods (register, _dump_registry, __subclasscheck__, __instancecheck__, __new__) have class='function', while the C-inherited __prepare__ has class='builtin_function_or_method'; NEW in extra94: first standalone ABCMeta._dump_registry class name invariant in abcabstractmethod94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta._dump_registry.__class__.__name__.__eq__"
  args: ["function"]
  expected: true
