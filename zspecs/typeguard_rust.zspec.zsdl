spec: typeguard_rust
version: ">=3.9"
backend: rust_module(typeguard_rust)

docs: https://typeguard.readthedocs.io/

provenance:
  derived_from:
    - "https://typeguard.readthedocs.io/ — typeguard library"
  notes:
    - "typeguard provides runtime type checking."
    - "typeguard.check_type is callable."
    - "typeguard.TypeCheckError is an exception class."
    - "typeguard.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant typeguard_rust.has_check_type:
  description: "typeguard.check_type is callable"
  category: presence
  kind: python_call_eq
  function: typeguard_has_check_type
  args: []
  expected: true

invariant typeguard_rust.has_type_check_error:
  description: "typeguard.TypeCheckError is a class"
  category: presence
  kind: python_call_eq
  function: typeguard_has_type_check_error
  args: []
  expected: true

invariant typeguard_rust.version_nonempty:
  description: "typeguard.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: typeguard_version_nonempty
  args: []
  expected: true

