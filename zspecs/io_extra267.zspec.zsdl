spec: io_extra267
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "io.open is a C-level built-in (type name 'builtin_function_or_method'); its __module__ is '_io', not 'io'."
    - "io.open_code is present in Python 3.8+ and is also a C-level built-in."
    - "SEEK_SET=0, SEEK_CUR=1, SEEK_END=2 are integer constants matching POSIX whence values."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open function identity
# ---------------------------------------------------------------------------

invariant io_extra267.open.name:
  description: "io.open.__name__ == 'open'"
  category: identity
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra267.open.qualname:
  description: "io.open.__qualname__ == 'open'"
  category: identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant io_extra267.open.module:
  description: "io.open.__module__ == '_io' — the underlying C module name"
  category: identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra267.open.class_name:
  description: "type(io.open).__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# io.open_code function identity (Python 3.8+)
# ---------------------------------------------------------------------------

invariant io_extra267.open_code.name:
  description: "io.open_code.__name__ == 'open_code'"
  category: identity
  kind: python_call_eq
  function: open_code.__name__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra267.open_code.class_name:
  description: "type(io.open_code).__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: open_code.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# SEEK_SET, SEEK_CUR, SEEK_END — constant values
# ---------------------------------------------------------------------------

table io_extra267.seek_constants:
  description: "io SEEK_* constants match POSIX whence values"
  kind: python_call_eq
  category: constants
  id_prefix: seek

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_value, SEEK_SET.__eq__, [0], true, "SEEK_SET == 0 — seek from beginning of file"]
    - [seek_cur_value, SEEK_CUR.__eq__, [1], true, "SEEK_CUR == 1 — seek from current position"]
    - [seek_end_value, SEEK_END.__eq__, [2], true, "SEEK_END == 2 — seek from end of file"]

# ---------------------------------------------------------------------------
# SEEK_* type identity
# ---------------------------------------------------------------------------

invariant io_extra267.seek_set.type:
  description: "type(io.SEEK_SET).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra267.seek_cur.type:
  description: "type(io.SEEK_CUR).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra267.seek_end.type:
  description: "type(io.SEEK_END).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__class__.__name__.__eq__
  args: ["int"]
  expected: true
