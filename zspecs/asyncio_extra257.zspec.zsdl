spec: asyncio_extra257
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue.__name__ == 'Queue' (len=5); __module__ == 'asyncio.queues' (len=14); __bases__[0].__name__ == '_LoopBoundMixin' (len=15) — Queue's private base mixin provides event-loop binding."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue' (len=13); __module__ == 'asyncio.queues' (len=14); __bases__[0].__name__ == 'Queue' (len=5) — PriorityQueue inherits from Queue."
    - "asyncio.Queue method name lengths: put=3, get=3, put_nowait=10, get_nowait=10, empty=5, full=4, qsize=5. All method qualnames have prefix 'Queue.' (len=6)."
    - "asyncio.PriorityQueue inherits all Queue methods unchanged — PriorityQueue.put.__qualname__ == 'Queue.put', not 'PriorityQueue.put'; all 7 method qualnames remain rooted at 'Queue'."
    - "put_nowait and get_nowait share name length 10 and qualname length 16; put and get share name length 3 and qualname length 9; empty and qsize share name length 5 and qualname length 11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

