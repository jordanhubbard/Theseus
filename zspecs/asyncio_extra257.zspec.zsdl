    - [pq_mod_len,         PriorityQueue.__module__.__len__,                [],                    14,   "asyncio.PriorityQueue.__module__.__len__() == 14; verified with Python 3.14.3"]
    - [pq_base_eq,         "PriorityQueue.__bases__[0].__name__.__eq__",    ["Queue"],             true, "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue inherits from Queue; verified with Python 3.14.3"]
    - [pq_base_len,        "PriorityQueue.__bases__[0].__name__.__len__",   [],                    5,    "asyncio.PriorityQueue.__bases__[0].__name__.__len__() == 5; verified with Python 3.14.3"]
    - [pq_put_qn_eq,       PriorityQueue.put.__qualname__.__eq__,           ["Queue.put"],         true, "asyncio.PriorityQueue.put.__qualname__ == 'Queue.put' — method is inherited unchanged from Queue; verified with Python 3.14.3"]
    - [pq_get_qn_eq,       PriorityQueue.get.__qualname__.__eq__,           ["Queue.get"],         true, "asyncio.PriorityQueue.get.__qualname__ == 'Queue.get' — inherited from Queue; verified with Python 3.14.3"]
    - [pq_putnw_qn_eq,     PriorityQueue.put_nowait.__qualname__.__eq__,    ["Queue.put_nowait"],  true, "asyncio.PriorityQueue.put_nowait.__qualname__ == 'Queue.put_nowait' — inherited from Queue; verified with Python 3.14.3"]
    - [pq_getnw_qn_eq,     PriorityQueue.get_nowait.__qualname__.__eq__,    ["Queue.get_nowait"],  true, "asyncio.PriorityQueue.get_nowait.__qualname__ == 'Queue.get_nowait' — inherited from Queue; verified with Python 3.14.3"]
    - [pq_empty_qn_eq,     PriorityQueue.empty.__qualname__.__eq__,         ["Queue.empty"],       true, "asyncio.PriorityQueue.empty.__qualname__ == 'Queue.empty' — inherited from Queue; verified with Python 3.14.3"]
    - [pq_full_qn_eq,      PriorityQueue.full.__qualname__.__eq__,          ["Queue.full"],        true, "asyncio.PriorityQueue.full.__qualname__ == 'Queue.full' — inherited from Queue; verified with Python 3.14.3"]
