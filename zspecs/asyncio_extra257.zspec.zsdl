# ---------------------------------------------------------------------------

table asyncio_extra257.queue_class_identity:
  description: "asyncio.Queue(len=5) class identity — inherits from '_LoopBoundMixin'(len=15); defined in asyncio.queues(len=14); put/get share name length 3 and qualname length 9; put_nowait/get_nowait share name length 10 and qualname length 16; empty/qsize share name length 5 and qualname length 11; full has name length 4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async257q

  columns: [id, function, args, expected, description]
  rows:
    - [q_name_eq,          Queue.__name__.__eq__,                           ["Queue"],             true, "asyncio.Queue.__name__ == 'Queue'; verified with Python 3.14.3"]
    - [q_name_len,         Queue.__name__.__len__,                          [],                    5,    "asyncio.Queue.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [q_mod_eq,           Queue.__module__.__eq__,                         ["asyncio.queues"],    true, "asyncio.Queue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [q_mod_len,          Queue.__module__.__len__,                        [],                    14,   "asyncio.Queue.__module__.__len__() == 14; verified with Python 3.14.3"]
    - [q_base_eq,          "Queue.__bases__[0].__name__.__eq__",            ["_LoopBoundMixin"],   true, "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'; verified with Python 3.14.3"]
    - [q_base_len,         "Queue.__bases__[0].__name__.__len__",           [],                    15,   "asyncio.Queue.__bases__[0].__name__.__len__() == 15; verified with Python 3.14.3"]
    - [q_put_name_eq,      Queue.put.__name__.__eq__,                       ["put"],               true, "asyncio.Queue.put.__name__ == 'put'; verified with Python 3.14.3"]
    - [q_put_name_len,     Queue.put.__name__.__len__,                      [],                    3,    "asyncio.Queue.put.__name__.__len__() == 3; verified with Python 3.14.3"]
