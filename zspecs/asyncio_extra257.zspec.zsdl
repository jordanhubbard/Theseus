table asyncio_extra257.priority_queue_class_identity:
  description: "asyncio.PriorityQueue(len=13) class identity — inherits from Queue(len=5); defined in asyncio.queues(len=14); all 7 methods (put/get/put_nowait/get_nowait/empty/full/qsize) are inherited from Queue with qualnames rooted at 'Queue.' — not 'PriorityQueue.'; verified with Python 3.14.3"
