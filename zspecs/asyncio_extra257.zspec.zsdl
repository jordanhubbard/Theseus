  category: identity
  id_prefix: async257pq

  columns: [id, function, args, expected, description]
  rows:
    - [pq_name_eq,         PriorityQueue.__name__.__eq__,                   ["PriorityQueue"],     true, "asyncio.PriorityQueue.__name__ == 'PriorityQueue'; verified with Python 3.14.3"]
    - [pq_name_len,        PriorityQueue.__name__.__len__,                  [],                    13,   "asyncio.PriorityQueue.__name__.__len__() == 13; verified with Python 3.14.3"]
