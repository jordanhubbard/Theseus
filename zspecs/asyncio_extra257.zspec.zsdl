invariant asyncio_extra257.queue_base_is_loop_bound_mixin:
  description: "asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — Queue's private base class '_LoopBoundMixin'(len=15) provides event-loop binding for all asyncio queue types; Queue and PriorityQueue both ultimately inherit this mixin through the Queue inheritance chain; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra257.priority_queue_methods_rooted_at_queue:
  description: "asyncio.PriorityQueue.put.__qualname__.__eq__('Queue.put') returns True — all 7 PriorityQueue methods (put/get/put_nowait/get_nowait/empty/full/qsize) have qualnames rooted at 'Queue.' rather than 'PriorityQueue.', confirming that PriorityQueue provides no method overrides for these operations and relies entirely on Queue's implementations; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true
