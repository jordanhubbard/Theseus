spec: uuid_extra1216
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module UUID class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID.__dict__.__contains__ for __init__/__str__/__repr__/__hash__/__eq__ method keys and int/hex/bytes property keys; also uuid.UUID.__dict__.__class__ identity and uuid.UUID.__dict__.__len__ as an upper bound"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1216.uuid_dict_contains_methods:
  description: "uuid.UUID.__dict__.__contains__ checks for core dunder method keys"
  kind: python_call_eq
  category: uuid_dict_contains_methods
  id_prefix: uu1216dm
  columns: [id, function, args, expected]
  rows:
    - [uu1216dm001, uuid.UUID.__dict__.__contains__,                     ["__init__"],    true]
    - [uu1216dm002, uuid.UUID.__dict__.__contains__,                     ["__str__"],     true]
    - [uu1216dm003, uuid.UUID.__dict__.__contains__,                     ["__repr__"],    true]
    - [uu1216dm004, uuid.UUID.__dict__.__contains__,                     ["__hash__"],    true]
    - [uu1216dm005, uuid.UUID.__dict__.__contains__,                     ["__eq__"],      true]
    - [uu1216dm006, uuid.UUID.__dict__.__contains__,                     ["__setattr__"], true]
    - [uu1216dm007, uuid.UUID.__dict__.__contains__,                     ["__int__"],     true]
    - [uu1216dm008, uuid.UUID.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
    - [uu1216dm009, uuid.UUID.__dict__.__class__.__qualname__.__eq__,    ["mappingproxy"], true]

table uuid_extra1216.uuid_dict_contains_properties:
  description: "uuid.UUID.__dict__.__contains__ checks for int, hex, bytes, and version property keys"
  kind: python_call_eq
  category: uuid_dict_contains_properties
  id_prefix: uu1216dp
  columns: [id, function, args, expected]
  rows:
    - [uu1216dp001, uuid.UUID.__dict__.__contains__,                     ["int"],         true]
    - [uu1216dp002, uuid.UUID.__dict__.__contains__,                     ["hex"],         true]
    - [uu1216dp003, uuid.UUID.__dict__.__contains__,                     ["bytes"],       true]
    - [uu1216dp004, uuid.UUID.__dict__.__contains__,                     ["version"],     true]
    - [uu1216dp005, uuid.UUID.__dict__.__contains__,                     ["variant"],     true]
    - [uu1216dp006, uuid.UUID.__dict__.__contains__,                     ["urn"],         true]
    - [uu1216dp007, uuid.UUID.__dict__.__class__.__module__.__eq__,      ["builtins"],    true]
    - [uu1216dp008, uuid.UUID.__dict__.__contains__,                     ["fields"],      true]
    - [uu1216dp009, uuid.UUID.__dict__.__contains__,                     ["bytes_le"],    true]

table uuid_extra1216.uuid_dict_class_and_module:
  description: "uuid.UUID.__dict__ class identity and uuid.UUID module membership"
  kind: python_call_eq
  category: uuid_dict_class_and_module
  id_prefix: uu1216dc
  columns: [id, function, args, expected]
  rows:
    - [uu1216dc001, uuid.UUID.__dict__.__class__.__name__.__class__.__name__.__eq__,  ["str"],   true]
    - [uu1216dc002, uuid.UUID.__dict__.__class__.__module__.__class__.__name__.__eq__, ["str"],   true]
    - [uu1216dc003, uuid.UUID.__module__.__eq__,                                       ["uuid"],  true]
    - [uu1216dc004, uuid.UUID.__name__.__eq__,                                         ["UUID"],  true]
    - [uu1216dc005, uuid.UUID.__name__.__class__.__name__.__eq__,                      ["str"],   true]
    - [uu1216dc006, uuid.UUID.__module__.__class__.__name__.__eq__,                    ["str"],   true]
