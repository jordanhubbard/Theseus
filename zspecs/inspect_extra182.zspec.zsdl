spec: inspect_extra182
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect module-level function name lengths — inspect.ismodule.__name__=='ismodule' (len=8); inspect.isclass.__name__=='isclass' (len=7); inspect.isfunction.__name__=='isfunction' (len=10); inspect.ismethod.__name__=='ismethod' (len=8); inspect.isbuiltin.__name__=='isbuiltin' (len=9); inspect.isgenerator.__name__=='isgenerator' (len=11); inspect.iscoroutine.__name__=='iscoroutine' (len=11); inspect.isawaitable.__name__=='isawaitable' (len=11)."
    - "inspect.ismodule.__name__ == 'ismodule' — ismodule is a Python function in Lib/inspect.py that returns True if the object is a module; its __name__ is 'ismodule', 8 characters. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' — isclass is a Python function in Lib/inspect.py that returns True if the object is a class; its __name__ is 'isclass', 7 characters (shortest of the is-predicate group). Verified with Python 3.14.3."
    - "inspect.isfunction.__name__ == 'isfunction' — isfunction is a Python function in Lib/inspect.py that returns True if the object is a Python function (created by a def statement); its __name__ is 'isfunction', 10 characters. Verified with Python 3.14.3."
    - "inspect.ismethod.__name__ == 'ismethod' — ismethod is a Python function in Lib/inspect.py that returns True if the object is a bound method; its __name__ is 'ismethod', 8 characters (same length as ismodule). Verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — isbuiltin is a Python function in Lib/inspect.py that returns True if the object is a built-in function or method; its __name__ is 'isbuiltin', 9 characters. Verified with Python 3.14.3."
    - "inspect.isgenerator.__name__ == 'isgenerator' — isgenerator is a Python function in Lib/inspect.py that returns True if the object is a generator; its __name__ is 'isgenerator', 11 characters. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__name__ == 'iscoroutine' — iscoroutine is a Python function in Lib/inspect.py that returns True if the object is a coroutine (created by an async def function and awaited); its __name__ is 'iscoroutine', 11 characters (same as isgenerator and isawaitable). Verified with Python 3.14.3."
    - "inspect.isawaitable.__name__ == 'isawaitable' — isawaitable is a Python function in Lib/inspect.py that returns True if the object can be used in an await expression (coroutines, objects with __await__); its __name__ is 'isawaitable', 11 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect is-predicates with __name__ len 7-9
#          (isclass=7, ismodule=8, ismethod=8, isbuiltin=9)
#
# inspect.isclass.__name__ == 'isclass' (len=7) — shortest
# inspect.ismodule.__name__ == 'ismodule' (len=8)
# inspect.ismethod.__name__ == 'ismethod' (len=8)
# inspect.isbuiltin.__name__ == 'isbuiltin' (len=9)
#
# These four inspect predicates share the shortest name lengths in the group.
# isclass at 7 chars is the shortest; ismodule and ismethod tie at 8;
# isbuiltin is 9. All are Python functions in Lib/inspect.py. New to extra182.
# ---------------------------------------------------------------------------

table inspect_extra182.is_predicates_short_names:
  description: "inspect is-predicate names len 7-9: isclass(7), ismodule(8), ismethod(8), isbuiltin(9); __name__ equality checks; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: inspectisX182

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a Python function in Lib/inspect.py returning True if the object is a class; its __name__ is 'isclass' (7 chars, shortest of the is-predicate group); str.__eq__('isclass') returns True; new to extra182"]
    - [isclass_name_len_7,
       isclass.__name__.__len__,
       [],
       7,
       "inspect.isclass.__name__.__len__() == 7 — the name 'isclass' has exactly 7 characters: i-s-c-l-a-s-s; str.__len__() returns 7 (shortest among ismodule, isclass, isfunction, ismethod, isbuiltin, isgenerator, iscoroutine, isawaitable); new to extra182"]
    - [ismodule_name_eq,
       ismodule.__name__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — ismodule is a Python function in Lib/inspect.py returning True if the object is a module; its __name__ is 'ismodule' (8 chars); str.__eq__('ismodule') returns True; new to extra182"]
    - [ismodule_name_len_8,
       ismodule.__name__.__len__,
       [],
       8,
       "inspect.ismodule.__name__.__len__() == 8 — the name 'ismodule' has exactly 8 characters: i-s-m-o-d-u-l-e; str.__len__() returns 8 (ties with ismethod at 8 chars); new to extra182"]
    - [ismethod_name_eq,
       ismethod.__name__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — ismethod is a Python function in Lib/inspect.py returning True if the object is a bound method; its __name__ is 'ismethod' (8 chars, ties with ismodule); str.__eq__('ismethod') returns True; new to extra182"]
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin is a Python function in Lib/inspect.py returning True if the object is a built-in function or method (implemented in C); its __name__ is 'isbuiltin' (9 chars); str.__eq__('isbuiltin') returns True; new to extra182"]
    - [isbuiltin_name_len_9,
       isbuiltin.__name__.__len__,
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — the name 'isbuiltin' has exactly 9 characters: i-s-b-u-i-l-t-i-n; str.__len__() returns 9; new to extra182"]

# ---------------------------------------------------------------------------
# Table 2: inspect is-predicates with __name__ len 10-11
#          (isfunction=10, isgenerator=11, iscoroutine=11, isawaitable=11)
#
# inspect.isfunction.__name__ == 'isfunction' (len=10)
# inspect.isgenerator.__name__ == 'isgenerator' (len=11)
# inspect.iscoroutine.__name__ == 'iscoroutine' (len=11)
# inspect.isawaitable.__name__ == 'isawaitable' (len=11)
#
# These four predicates have the longest names in the is-predicate group.
# isgenerator, iscoroutine, and isawaitable all tie at 11 chars. New to extra182.
# ---------------------------------------------------------------------------

table inspect_extra182.is_predicates_long_names:
  description: "inspect is-predicate names len 10-11: isfunction(10), isgenerator(11), iscoroutine(11), isawaitable(11); __name__ equality checks; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: inspectisX182

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a Python function in Lib/inspect.py returning True only if the object is a Python function created by a def statement (not a built-in or bound method); its __name__ is 'isfunction' (10 chars); str.__eq__('isfunction') returns True; new to extra182"]
    - [isfunction_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — the name 'isfunction' has exactly 10 characters: i-s-f-u-n-c-t-i-o-n; str.__len__() returns 10; new to extra182"]
    - [isgenerator_name_eq,
       isgenerator.__name__.__eq__,
       ["isgenerator"],
       true,
       "inspect.isgenerator.__name__.__eq__('isgenerator') == True — isgenerator is a Python function in Lib/inspect.py returning True if the object is a generator (has gi_frame and gi_running attributes); its __name__ is 'isgenerator' (11 chars); str.__eq__('isgenerator') returns True; new to extra182"]
    - [isgenerator_name_len_11,
       isgenerator.__name__.__len__,
       [],
       11,
       "inspect.isgenerator.__name__.__len__() == 11 — the name 'isgenerator' has exactly 11 characters: i-s-g-e-n-e-r-a-t-o-r; str.__len__() returns 11 (ties with iscoroutine and isawaitable); new to extra182"]
    - [iscoroutine_name_eq,
       iscoroutine.__name__.__eq__,
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__name__.__eq__('iscoroutine') == True — iscoroutine is a Python function in Lib/inspect.py returning True if the object is a coroutine created by an async def function; its __name__ is 'iscoroutine' (11 chars, ties with isgenerator and isawaitable); str.__eq__('iscoroutine') returns True; new to extra182"]
    - [isawaitable_name_eq,
       isawaitable.__name__.__eq__,
       ["isawaitable"],
       true,
       "inspect.isawaitable.__name__.__eq__('isawaitable') == True — isawaitable is a Python function in Lib/inspect.py returning True if the object can be used in an await expression (coroutines, objects implementing __await__); its __name__ is 'isawaitable' (11 chars, ties with isgenerator and iscoroutine); str.__eq__('isawaitable') returns True; new to extra182"]
    - [isawaitable_name_len_11,
       isawaitable.__name__.__len__,
       [],
       11,
       "inspect.isawaitable.__name__.__len__() == 11 — the name 'isawaitable' has exactly 11 characters: i-s-a-w-a-i-t-a-b-l-e; str.__len__() returns 11 (ties with isgenerator and iscoroutine at 11 chars); new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: inspect is-predicate __module__ values
#
# All eight inspect is-predicates report __module__ == 'inspect'.
# This table verifies __module__ for ismodule, isclass, isfunction,
# ismethod, isbuiltin, isgenerator, iscoroutine, isawaitable.
# All are pure-Python functions defined in Lib/inspect.py. New to extra182.
# ---------------------------------------------------------------------------

table inspect_extra182.is_predicates_module:
  description: "inspect is-predicate __module__ == 'inspect' for ismodule, isclass, isfunction, ismethod, isbuiltin, isgenerator, iscoroutine, isawaitable; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: inspectisX182

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_module_eq,
       ismodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [isclass_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [isfunction_module_eq,
       isfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [ismethod_module_eq,
       ismethod.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — ismethod is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [isgenerator_module_eq,
       isgenerator.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isgenerator.__module__.__eq__('inspect') == True — isgenerator is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [iscoroutine_module_eq,
       iscoroutine.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.iscoroutine.__module__.__eq__('inspect') == True — iscoroutine is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]
    - [isawaitable_module_eq,
       isawaitable.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isawaitable.__module__.__eq__('inspect') == True — isawaitable is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra182
# ---------------------------------------------------------------------------

invariant inspect_extra182.ismodule_name_is_ismodule:
  description: "inspect.ismodule.__name__ == 'ismodule' — Python function in Lib/inspect.py returning True if the object is a module; __name__ is 'ismodule' (8 chars); new to extra182"
  category: identity
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra182.isclass_name_is_isclass:
  description: "inspect.isclass.__name__ == 'isclass' — Python function in Lib/inspect.py returning True if the object is a class; __name__ is 'isclass' (7 chars, shortest of the is-predicate group); new to extra182"
  category: identity
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra182.isfunction_name_is_isfunction:
  description: "inspect.isfunction.__name__ == 'isfunction' — Python function in Lib/inspect.py returning True if the object is a Python def-created function; __name__ is 'isfunction' (10 chars); new to extra182"
  category: identity
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra182.ismethod_name_is_ismethod:
  description: "inspect.ismethod.__name__ == 'ismethod' — Python function in Lib/inspect.py returning True if the object is a bound method; __name__ is 'ismethod' (8 chars, ties with ismodule); new to extra182"
  category: identity
  kind: python_call_eq
  function: ismethod.__name__.__eq__
  args: ["ismethod"]
  expected: true

invariant inspect_extra182.isbuiltin_name_is_isbuiltin:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — Python function in Lib/inspect.py returning True if the object is a C-implemented built-in function or method; __name__ is 'isbuiltin' (9 chars); new to extra182"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra182.isgenerator_name_is_isgenerator:
  description: "inspect.isgenerator.__name__ == 'isgenerator' — Python function in Lib/inspect.py returning True if the object is a generator; __name__ is 'isgenerator' (11 chars, ties with iscoroutine and isawaitable); new to extra182"
  category: identity
  kind: python_call_eq
  function: isgenerator.__name__.__eq__
  args: ["isgenerator"]
  expected: true

invariant inspect_extra182.iscoroutine_name_is_iscoroutine:
  description: "inspect.iscoroutine.__name__ == 'iscoroutine' — Python function in Lib/inspect.py returning True if the object is an async-def coroutine; __name__ is 'iscoroutine' (11 chars, ties with isgenerator and isawaitable); new to extra182"
  category: identity
  kind: python_call_eq
  function: iscoroutine.__name__.__eq__
  args: ["iscoroutine"]
  expected: true

invariant inspect_extra182.isawaitable_name_is_isawaitable:
  description: "inspect.isawaitable.__name__ == 'isawaitable' — Python function in Lib/inspect.py returning True if the object can be used in an await expression; __name__ is 'isawaitable' (11 chars, ties with isgenerator and iscoroutine); new to extra182"
  category: identity
  kind: python_call_eq
  function: isawaitable.__name__.__eq__
  args: ["isawaitable"]
  expected: true

