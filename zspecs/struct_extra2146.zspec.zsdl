table struct_extra2146.struct_real_attrs:
  description: "struct.Struct __dict__ positive presence — known real attributes confirm __dict__.__contains__ works for Struct"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["st2146015", "struct.Struct.__dict__.__contains__", ["pack"],         true]
    - ["st2146016", "struct.Struct.__dict__.__contains__", ["unpack"],       true]
    - ["st2146017", "struct.Struct.__dict__.__contains__", ["pack_into"],    true]
    - ["st2146018", "struct.Struct.__dict__.__contains__", ["unpack_from"],  true]
    - ["st2146019", "struct.Struct.__dict__.__contains__", ["iter_unpack"],  true]
