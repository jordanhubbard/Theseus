    - ["st2146021", "struct.Struct.__dict__.__contains__", ["size"],         true]

table struct_extra2146.error_real_attrs:
  description: "struct.error __dict__ positive presence — known real attributes confirm __dict__.__contains__ works for struct.error"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["st2146022", "struct.error.__dict__.__contains__", ["__module__"],  true]
    - ["st2146023", "struct.error.__dict__.__contains__", ["__doc__"],     true]
    - ["st2146024", "struct.error.__dict__.__contains__", ["__weakref__"], true]
    - ["st2146025", "struct.Struct.__dict__.__contains__", ["__doc__"],    true]
