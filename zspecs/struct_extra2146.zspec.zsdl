spec: struct_extra2146
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "_struct.zspec.zsdl — covers pack/unpack/calcsize vectors at the C extension level"
    - "_struct_extra.zspec.zsdl — covers error type and attribute presence"
    - "struct_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "struct.Struct is a C extension type representing a compiled format string; it is not a numeric type and defines none of the numeric conversion protocol methods."
    - "struct.error is a plain Exception subclass (not numeric); its own __dict__ contains only __module__, __weakref__, and __doc__ — no numeric conversion protocol methods."
    - "struct.Struct.__dict__ contains: iter_unpack, pack, pack_into, unpack, unpack_from, format, size — all packing-specific, none numeric."
    - "struct.error.__dict__ confirmed: all seven numeric conversion dunders absent (False)."
    - "All expected values (false) verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2146.struct_trunc_floor_ceil:
  description: "struct.Struct __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["st2146001", "struct.Struct.__dict__.__contains__", ["__trunc__"], false]
    - ["st2146002", "struct.Struct.__dict__.__contains__", ["__floor__"], false]
    - ["st2146003", "struct.Struct.__dict__.__contains__", ["__ceil__"], false]

