spec: decimal_extra28
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra27.zspec.zsdl."
    - "Prior specs covered: Decimal/Context/__module__/__name__/__qualname__ and lengths, decimal exception class __module__/__name__ lengths, getcontext/setcontext/localcontext __module__ lengths."
    - "This spec covers: Decimal.__mro__.__len__() and __bases__[0].__name__; DecimalException.__mro__.__len__() and selected exception subclass MRO depths; Decimal method __qualname__.__len__() for __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__."
    - "Decimal.__mro__ == [Decimal, object] — length 2; Decimal is a C-extension type with no Python class parents."
    - "DecimalException.__mro__ == [DecimalException, ArithmeticError, Exception, BaseException, object] — length 5."
    - "Underflow has the deepest MRO among exception subclasses (length 9) due to multiple inheritance: Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object."
    - "Decimal arithmetic methods (__add__, __mul__, __sub__, __str__, __neg__) all have qualname length 15; quantize and __repr__ share length 16; to_eng_string is 21."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal method __qualname__.__len__() — combined table
#
# Decimal is a C-extension class whose methods still expose __qualname__.
# Arithmetic operators (__add__, __mul__, __sub__, __str__, __neg__) have
# qualnames of the form 'Decimal.<name>' with short method names, giving
# length 15. Longer method names increase the composite length: quantize and
# __repr__ reach 16; to_eng_string reaches 21.
# No prior decimal spec records __qualname__.__len__() for Decimal methods.
# ---------------------------------------------------------------------------

table decimal_extra28.decimal_method_qualname_lens:
  description: "__qualname__.__len__() for Decimal methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [__add__,         "Decimal.__add__.__qualname__.__len__",         [], 15]
    - [__mul__,         "Decimal.__mul__.__qualname__.__len__",         [], 15]
    - [__sub__,         "Decimal.__sub__.__qualname__.__len__",         [], 15]
    - [__str__,         "Decimal.__str__.__qualname__.__len__",         [], 15]
    - [__neg__,         "Decimal.__neg__.__qualname__.__len__",         [], 15]
    - [__repr__,        "Decimal.__repr__.__qualname__.__len__",        [], 16]
    - [quantize,        "Decimal.quantize.__qualname__.__len__",        [], 16]
    - [to_eng_string,   "Decimal.to_eng_string.__qualname__.__len__",   [], 21]

# ---------------------------------------------------------------------------
# decimal exception class __mro__.__len__() — selected subclasses
#
# The decimal exception hierarchy uses multiple inheritance in places.
# DecimalException (root) has MRO length 5. Direct subclasses (InvalidOperation,
# Inexact, Rounded, Subnormal) each add one level for length 6.
# DivisionByZero adds the ZeroDivisionError branch giving length 7.
# Overflow mixes in Inexact and Rounded giving length 8.
# Underflow mixes in Inexact, Rounded, and Subnormal giving the deepest MRO
# of length 9. No prior decimal spec records __mro__.__len__() for the exception
# subclasses.
# ---------------------------------------------------------------------------

table decimal_extra28.exception_mro_lens:
  description: "__mro__.__len__() for decimal exception classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: mro_len

  columns: [id, function, args, expected, description]
  rows:
    - [DecimalException,
       DecimalException.__mro__.__len__,
       [],
       5,
       "len(decimal.DecimalException.__mro__) == 5"]
    - [InvalidOperation,
       InvalidOperation.__mro__.__len__,
       [],
       6,
       "len(decimal.InvalidOperation.__mro__) == 6"]
    - [Inexact,
       Inexact.__mro__.__len__,
       [],
       6,
       "len(decimal.Inexact.__mro__) == 6"]
    - [Rounded,
       Rounded.__mro__.__len__,
       [],
       6,
       "len(decimal.Rounded.__mro__) == 6"]
    - [Subnormal,
       Subnormal.__mro__.__len__,
       [],
       6,
       "len(decimal.Subnormal.__mro__) == 6"]
    - [DivisionByZero,
       DivisionByZero.__mro__.__len__,
       [],
       7,
       "len(decimal.DivisionByZero.__mro__) == 7 — includes ZeroDivisionError branch"]
    - [Overflow,
       Overflow.__mro__.__len__,
       [],
       8,
       "len(decimal.Overflow.__mro__) == 8 — mixes in Inexact and Rounded"]
    - [Underflow,
       Underflow.__mro__.__len__,
       [],
       9,
       "len(decimal.Underflow.__mro__) == 9 — mixes in Inexact, Rounded, and Subnormal"]

# ---------------------------------------------------------------------------
# Decimal.__mro__.__len__() == 2 — standalone
#
# Decimal is a C-extension type. Its __mro__ contains exactly two entries:
# Decimal and object. It does not inherit from any Python-level numeric ABC
# or exception class. This minimal depth mirrors other built-in C types.
# No prior decimal spec records Decimal.__mro__.__len__() as a standalone.
# ---------------------------------------------------------------------------

invariant decimal_extra28.Decimal.mro_len:
  description: "len(decimal.Decimal.__mro__) == 2 — [Decimal, object]"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Decimal.__bases__[0].__name__ == 'object' — standalone
#
# Decimal has a single base: object. This confirms that Decimal is a top-level
# C-extension class and does not extend any Python numeric ABC. No prior
# decimal spec records this check as a standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra28.Decimal.bases0_name:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object'"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Decimal.to_eng_string.__qualname__.__len__() == 21 — standalone
#
# Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string' (21 chars).
# This is the longest __qualname__ among all Decimal methods measured in this
# spec; the 13-char method name 'to_eng_string' combined with the 'Decimal.'
# prefix (8 chars) gives 21. No prior decimal spec records this as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra28.Decimal.to_eng_string_qualname_len:
  description: "len(decimal.Decimal.to_eng_string.__qualname__) == 21 — 'Decimal.to_eng_string' is 21 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: "Decimal.to_eng_string.__qualname__.__len__"
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# Underflow.__mro__.__len__() == 9 — standalone
#
# decimal.Underflow has the deepest MRO among all decimal exception classes
# (length 9). It inherits from Inexact, Rounded, and Subnormal simultaneously,
# which in turn inherit from DecimalException → ArithmeticError → Exception →
# BaseException → object. This multiple-inheritance depth is unique within the
# decimal exception hierarchy. No prior decimal spec records this as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra28.Underflow.mro_len:
  description: "len(decimal.Underflow.__mro__) == 9 — deepest MRO in decimal exception hierarchy"
  category: class_identity
  kind: python_call_eq
  function: Underflow.__mro__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# DecimalException.__mro__.__len__() == 5 — standalone
#
# decimal.DecimalException is the root of the decimal signal/exception tree.
# Its MRO is [DecimalException, ArithmeticError, Exception, BaseException,
# object] — length 5. This is the same depth as statistics.StatisticsError
# (which inherits ValueError → Exception → BaseException → object).
# No prior decimal spec records DecimalException.__mro__.__len__() as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra28.DecimalException.mro_len:
  description: "len(decimal.DecimalException.__mro__) == 5 — [DecimalException, ArithmeticError, Exception, BaseException, object]"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5
