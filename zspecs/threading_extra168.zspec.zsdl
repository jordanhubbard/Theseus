spec: threading_extra168
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Timer.__name__ 'Timer'; threading.Timer.__module__ 'threading'; threading.Timer.__bases__[0].__name__ 'Thread'; threading.Barrier.__name__ 'Barrier'; threading.Barrier.__module__ 'threading'; threading.Barrier.__bases__[0].__name__ 'object'; threading.local.__name__ '_local'; threading.local.__module__ '_thread' (Wave 296)."
    - "threading.Timer.__name__ == 'Timer' — threading.Timer is a Python class defined in Lib/threading.py that runs a function after a specified interval; its class __name__ is 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; its __module__ attribute is 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — threading.Timer is a subclass of threading.Thread (not a direct subclass of object); its __bases__[0].__name__ is 'Thread'. This distinguishes Timer from Event/Condition/Semaphore/Barrier which all inherit from object. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' — threading.Barrier is a Python class defined in Lib/threading.py implementing a synchronization barrier; its class __name__ is 'Barrier'. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; its __module__ attribute is 'threading'. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — threading.Barrier inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "threading.local.__name__ == '_local' — threading.local is actually the C extension type _thread._local defined in Modules/_threadmodule.c; the internal C type name is '_local' (with underscore), NOT 'local'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — threading.local is an alias for _thread._local, a C extension type; its __module__ is '_thread' (the private C module), not 'threading'. This mirrors threading.Lock whose __module__ is also '_thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer class identity — __name__, __module__, __bases__
#
# Wave 296 theme: threading.Timer Python class identity — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__bases__[0].__name__ == 'Thread'
# threading.Timer.__class__.__name__ == 'type'
#
# threading.Timer(interval, function, args=None, kwargs=None) is a Python class
# defined in Lib/threading.py. It represents an action that should be run only
# after a certain amount of time has passed. Timer is a subclass of Thread; it
# starts the thread on start() and runs function(*args, **kwargs) after interval
# seconds. Its __bases__[0].__name__ is 'Thread', distinguishing it from other
# threading primitives that inherit from object. New to extra168.
# ---------------------------------------------------------------------------

table threading_extra168.timer_class_identity:
  description: "threading.Timer: __name__ 'Timer', __module__ 'threading', __bases__[0].__name__ 'Thread', __class__.__name__ 'type'; wave 296; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtci168

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_timer,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — threading.Timer is a Python class defined in Lib/threading.py that runs a function after a specified interval; it is a Thread subclass; its class __name__ attribute is 'Timer'; str.__eq__('Timer') returns True; new to extra168"]
    - [timer_module_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — threading.Timer is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra168"]
    - ["timer_bases_0_thread",
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — threading.Timer is a subclass of threading.Thread (not a direct subclass of object); its __bases__ tuple has one element whose __name__ is 'Thread'; this distinguishes Timer from Event/Condition/Semaphore/Barrier which all inherit from object; str.__eq__('Thread') returns True; new to extra168"]
    - [timer_class_name_type,
       "Timer.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Timer.__class__.__name__.__eq__('type') == True — threading.Timer is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier class identity — __name__, __module__, __bases__
#
# Wave 296 theme: threading.Barrier Python class identity — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# threading.Barrier.__name__ == 'Barrier'
# threading.Barrier.__module__ == 'threading'
# threading.Barrier.__bases__[0].__name__ == 'object'
# threading.Barrier.__class__.__name__ == 'type'
#
# threading.Barrier(parties, action=None, timeout=None) is a Python class
# defined in Lib/threading.py implementing a synchronization barrier primitive.
# A barrier waits until all of the specified number of threads (parties) have
# called wait() on the barrier before any are released. Unlike Timer, Barrier
# inherits directly from object (not from Thread). New to extra168.
# ---------------------------------------------------------------------------

table threading_extra168.barrier_class_identity:
  description: "threading.Barrier: __name__ 'Barrier', __module__ 'threading', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: threadingbci168

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_barrier,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — threading.Barrier is a Python class defined in Lib/threading.py implementing a synchronization barrier (waits until all parties have called wait() before releasing any); its class __name__ attribute is 'Barrier'; str.__eq__('Barrier') returns True; new to extra168"]
    - [barrier_module_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — threading.Barrier is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra168"]
    - ["barrier_bases_0_object",
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — threading.Barrier is a Python class that inherits directly from object (unlike Timer which subclasses Thread); its __bases__ tuple has one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra168"]
    - [barrier_class_name_type,
       "Barrier.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — threading.Barrier is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 3: threading.local C extension type identity — __name__ and __module__
#
# Wave 296 theme: threading.local C extension type identity — __name__,
# __module__, __bases__[0], and __class__.__name__.
#
# threading.local.__name__ == '_local'
# threading.local.__module__ == '_thread'
# threading.local.__bases__[0].__name__ == 'object'
# threading.local.__class__.__name__ == 'type'
#
# threading.local is NOT a Python class defined in Lib/threading.py. It is
# an alias for the C extension type _thread._local defined in
# Modules/_threadmodule.c. Its internal C type name is '_local' (with a leading
# underscore), NOT 'local'. Its __module__ is '_thread' (the private C
# implementation module), mirroring threading.Lock whose __module__ is also
# '_thread'. This is a critical invariant to verify since the public-facing
# attribute name ('local') differs from the internal C type name ('_local').
# New to extra168.
# ---------------------------------------------------------------------------

table threading_extra168.local_c_extension_identity:
  description: "threading.local: __name__ '_local' (C type name, not 'local'), __module__ '_thread', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglcei168

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_underscore_local,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is the C extension type _thread._local defined in Modules/_threadmodule.c; the internal C type name is '_local' (with a leading underscore), NOT 'local'; the public attribute name 'local' in the threading namespace is distinct from the C type name; str.__eq__('_local') returns True; new to extra168"]
    - [local_module_thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is an alias for _thread._local, a C extension type in Modules/_threadmodule.c; its __module__ is '_thread' (the private C implementation module), not 'threading'; this mirrors threading.Lock which also has __module__ '_thread'; str.__eq__('_thread') returns True; new to extra168"]
    - ["local_bases_0_object",
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — threading.local (_thread._local) is a C extension type that inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra168"]
    - [local_class_name_type,
       "local.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — threading.local is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — Timer subclasses Thread, not object; local vs Lock module
#
# Wave 296 theme: cross-checks contrasting threading.Timer (Thread subclass)
# with threading.Barrier (object subclass), and threading.local (module '_thread')
# with threading.Barrier (module 'threading').
#
# threading.Timer.__bases__[0].__name__ != 'object'
#   (Timer subclasses Thread, not object)
# threading.Barrier.__bases__[0].__name__ != 'Thread'
#   (Barrier subclasses object, not Thread)
# threading.local.__name__ != 'local'
#   (C type name is '_local', not 'local')
# threading.local.__module__ != 'threading'
#   (module is '_thread', not 'threading')
#
# These cross-checks highlight the structural differences: Timer's special
# Thread inheritance, Barrier's ordinary object inheritance, and local's C
# extension nature (with its surprising '_local' type name and '_thread' module).
# New to extra168.
# ---------------------------------------------------------------------------

table threading_extra168.timer_barrier_local_cross_checks:
  description: "threading: Timer base != 'object', Barrier base != 'Thread', local.__name__ != 'local', local.__module__ != 'threading'; wave 296; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtblcc168

  columns: [id, function, args, expected, description]
  rows:
    - ["timer_bases_not_object",
       "Timer.__bases__[0].__name__.__eq__",
       ["object"],
       false,
       "threading.Timer.__bases__[0].__name__.__eq__('object') == False — threading.Timer inherits from Thread, NOT from object; its __bases__[0].__name__ is 'Thread', not 'object'; this contrasts with Event, Condition, Semaphore, and Barrier which all inherit from object; str.__eq__('object') returns False; new to extra168"]
    - ["barrier_bases_not_thread",
       "Barrier.__bases__[0].__name__.__eq__",
       ["Thread"],
       false,
       "threading.Barrier.__bases__[0].__name__.__eq__('Thread') == False — threading.Barrier inherits directly from object, NOT from Thread; its __bases__[0].__name__ is 'object', not 'Thread'; only Timer (among the threading synchronization primitives) inherits from Thread; str.__eq__('Thread') returns False; new to extra168"]
    - [local_name_not_local,
       "local.__name__.__eq__",
       ["local"],
       false,
       "threading.local.__name__.__eq__('local') == False — the C extension type for threading.local has the internal name '_local' (with underscore), not 'local'; the public-facing attribute name in the threading module is 'local' but that is just the namespace attribute name; str.__eq__('local') returns False; new to extra168"]
    - [local_module_not_threading,
       "local.__module__.__eq__",
       ["threading"],
       false,
       "threading.local.__module__.__eq__('threading') == False — threading.local is implemented as _thread._local in Modules/_threadmodule.c; its __module__ is '_thread', not 'threading'; Barrier and Timer have __module__ 'threading' but local does not; str.__eq__('threading') returns False; new to extra168"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra168
# ---------------------------------------------------------------------------

invariant threading_extra168.timer_name_timer:
  description: "threading.Timer.__name__ == 'Timer' — Python class that runs a function after a specified interval; subclasses Thread; wave 296; new to extra168"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra168.timer_module_threading:
  description: "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; wave 296; new to extra168"
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra168.timer_bases_0_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread (not object); unique among threading primitives; wave 296; new to extra168"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra168.barrier_name_barrier:
  description: "threading.Barrier.__name__ == 'Barrier' — Python class implementing a synchronization barrier; wave 296; new to extra168"
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra168.barrier_module_threading:
  description: "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; wave 296; new to extra168"
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra168.barrier_bases_0_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier Python class inherits directly from object; wave 296; new to extra168"
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra168.local_name_underscore_local:
  description: "threading.local.__name__ == '_local' — the C type name is '_local' (with underscore), not 'local'; mirrors Lock whose name is 'lock'; wave 296; new to extra168"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra168.local_module_thread:
  description: "threading.local.__module__ == '_thread' — threading.local is the C extension type _thread._local; its module is '_thread', not 'threading'; wave 296; new to extra168"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true
