spec: multiprocessing_extra2821
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, base class, factory __name__ checks"
    - "multiprocessing_extra2.zspec.zsdl — covers factory __module__ checks, extra primitive names"
    - "multiprocessing_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "None of the multiprocessing public classes define __radd__, __rsub__, or __rmul__ in their __dict__."
    - "multiprocessing.Process is a real class (Lib/multiprocessing/process.py); Pool and ApplyResult are in Lib/multiprocessing/pool.py."
    - "multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult; __name__ is 'ApplyResult' in Python 3.14.4."
    - "Process, Pool, and ApplyResult are process-management/coordination classes, not numeric types."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — __radd__/__rsub__/__rmul__ dict-presence checks
#
# Process is the core class for spawning new OS processes. It manages process
# lifecycle (start, join, terminate) and does not implement reflected arithmetic
# operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2821.process_operator_dict:
  description: "multiprocessing.Process __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2821p

  columns: [id, function, args, expected]
  rows:
    - ["mp2821p_rad",  multiprocessing.Process.__dict__.__contains__, ["__radd__"],  false]
    - ["mp2821p_rsb",  multiprocessing.Process.__dict__.__contains__, ["__rsub__"],  false]
    - ["mp2821p_rml",  multiprocessing.Process.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — __radd__/__rsub__/__rmul__ dict-presence checks
#
# Pool is a process pool manager providing map/apply/starmap/imap interfaces.
# It coordinates worker processes and does not define reflected arithmetic
# operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2821.pool_operator_dict:
  description: "multiprocessing.pool.Pool __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2821pl

  columns: [id, function, args, expected]
  rows:
    - ["mp2821pl_rad",  multiprocessing.pool.Pool.__dict__.__contains__, ["__radd__"],  false]
    - ["mp2821pl_rsb",  multiprocessing.pool.Pool.__dict__.__contains__, ["__rsub__"],  false]
    - ["mp2821pl_rml",  multiprocessing.pool.Pool.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.ApplyResult — __radd__/__rsub__/__rmul__ dict-presence checks
#
# ApplyResult (also exported as AsyncResult) is the result object returned by
# Pool.apply_async(). It wraps a pending result and provides get()/ready()/wait().
# It does not implement reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2821.applyresult_operator_dict:
  description: "multiprocessing.pool.ApplyResult __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2821ar

  columns: [id, function, args, expected]
  rows:
    - ["mp2821ar_rad",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__radd__"],  false]
    - ["mp2821ar_rsb",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rsub__"],  false]
    - ["mp2821ar_rml",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — Process, Pool, ApplyResult × three reflected arithmetic operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Process, Pool, and ApplyResult do not define +, -, or *
# reflected operator dunders in their respective __dict__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2821.all_types_radd_rsub_rmul_matrix:
  description: "Full 3×3 dict-presence matrix for multiprocessing types vs __radd__/__rsub__/__rmul__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2821mx

  columns: [id, function, args, expected]
  rows:
    - ["mp2821mx_p_rad",   multiprocessing.Process.__dict__.__contains__,          ["__radd__"],  false]
    - ["mp2821mx_p_rsb",   multiprocessing.Process.__dict__.__contains__,          ["__rsub__"],  false]
    - ["mp2821mx_p_rml",   multiprocessing.Process.__dict__.__contains__,          ["__rmul__"],  false]
    - ["mp2821mx_pl_rad",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__radd__"],  false]
    - ["mp2821mx_pl_rsb",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__rsub__"],  false]
    - ["mp2821mx_pl_rml",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__rmul__"],  false]
    - ["mp2821mx_ar_rad",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__radd__"],  false]
    - ["mp2821mx_ar_rsb",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rsub__"],  false]
    - ["mp2821mx_ar_rml",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rmul__"],  false]
