spec: array_first
version: ">=1.0.2"
backend: node(array-first)

docs: https://www.npmjs.com/package/array-first

provenance:
  derived_from:
    - "array-first README — https://www.npmjs.com/package/array-first"
    - "Test vectors verified with array-first via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-first source"
  notes:
    - "array-first is an npm package. Install: npm install array-first"
    - "Returns the first element (or first n elements) of an array."
    - "Without n argument: returns the element directly. With n: returns an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a value or array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_first.first:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: afirst

  columns: [id, args, expected]
  rows:
    - [single,  [[1, 2, 3]],     1]
    - [two,     [[1, 2, 3], 2],  [1, 2]]
    - [one,     [[5, 6], 1],     5]
