spec: theseus_statistics_cr
version: ">=3.8"
backend: python_cleanroom(theseus_statistics_cr)
blocks: statistics

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/statistics.html"
  not_derived_from:
    - "CPython source: Lib/statistics.py (internal implementation)"
  notes:
    - "Clean-room statistics module. Do NOT import statistics."
    - "mean(data): arithmetic mean."
    - "median(data): median value."
    - "stdev(data): sample standard deviation."
    - "variance(data): sample variance."
    - "mode(data): most common value."

error_model: python_exceptions

invariant theseus_statistics_cr.statistics2_mean:
  description: "mean([1,2,3,4,5]) == 3.0"
  category: mean
  kind: python_call_eq
  function: statistics2_mean
  args: []
  expected: 3.0

invariant theseus_statistics_cr.statistics2_median:
  description: "median([1,3,5]) == 3"
  category: median
  kind: python_call_eq
  function: statistics2_median
  args: []
  expected: 3

invariant theseus_statistics_cr.statistics2_stdev:
  description: "stdev([2,4,4,4,5,5,7,9]) approx 2.0"
  category: stdev
  kind: python_call_eq
  function: statistics2_stdev
  args: []
  expected: true
