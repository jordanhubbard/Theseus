spec: uuid_extra125
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra124.zspec.zsdl — covers UUID property __class__.__name__ equality / UUID property fget __class__.__name__ and co_argcount / UUID.is_safe member_descriptor identity, qualname, and name (table + invariants)."
    - "uuid_extra123.zspec.zsdl — covers UUID.__slots__ class name/length/contains / UUID.__weakref__ descriptor / UUID.int member_descriptor identity / UUID.__hash__ code co_argcount (table + invariants)."
    - "uuid_extra122.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__ co_varnames[0] ('self') and co_varnames.__len__() / co_argcount for __str__/__repr__/__eq__ (table + invariants)."
    - "uuid_extra121.zspec.zsdl — covers uuid6/uuid7/uuid8 function __name__/__qualname__/__module__/__code__.co_argcount identity / uuid.NIL and uuid.MAX sentinel UUID values (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__.__name__/__qualname__ (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 346 theme: uuid.getnode __name__/__qualname__/__module__/co_name/co_argcount identity / uuid1/uuid3/uuid5 co_varnames[0] / uuid.SafeUUID __name__/__qualname__/__module__/__class__.__name__ / uuid.UUID.__name__/__qualname__ lengths."
    - "uuid.getnode.__name__ == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__qualname__ == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_argcount == 0. getnode takes no arguments. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_name == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_varnames[0] == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_varnames[0] == 'namespace'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_varnames[0] == 'namespace'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_varnames[0] == 'int_uuid_4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType'. SafeUUID's metaclass is EnumType (not 'type'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__.__len__() == 4. uuid.UUID.__qualname__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode co_varnames[0] == 'getter'. The internal variable named 'getter' is the first local in getnode. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra86 anchors getnode __qualname__/__module__/co_argcount at table level. This spec anchors getnode __name__/__code__.co_name and co_varnames[0] and SafeUUID class identity under uuidident125."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.getnode.__name__.__eq__('getnode')
# uuid.getnode.__qualname__.__eq__('getnode')
# uuid.getnode.__module__.__eq__('uuid')
# uuid.getnode.__code__.co_argcount.__eq__(0)
# uuid.getnode.__code__.co_name.__eq__('getnode')
#
# Wave 346 theme: getnode function identity and code attributes.
#
# uuid.getnode is a pure-Python function that returns the hardware MAC address
# as a 48-bit integer (or a random fallback). It takes no arguments (co_argcount
# == 0). Its __code__.co_name equals its __name__ ('getnode'). The first
# co_varnames entry is 'getter' — an internal local used to store a candidate
# MAC-address getter function. uuid_extra86 anchors getnode __qualname__/__module__/
# co_argcount at table level; this spec anchors __name__/__code__.co_name via
# __eq__ calls under uuidident125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra125.getnode_identity:
  description: "uuid.getnode/__name__.__eq__('getnode')==True / getnode/__qualname__.__eq__('getnode')==True / getnode/__module__.__eq__('uuid')==True / getnode/__code__/co_argcount.__eq__(0)==True / getnode/__code__/co_name.__eq__('getnode')==True — getnode is a pure-Python function returning hardware MAC as 48-bit integer; takes no args; extra86 anchors __qualname__/__module__/co_argcount at table level; first uuidident125 anchor for getnode __name__ and co_name via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidident125

  columns: [id, function, args, expected, description]
  rows:
    - [getnode_name,     getnode.__name__.__eq__,               ["getnode"], true, "getnode.__name__ is 'getnode' (7 chars)"]
    - [getnode_qualname, getnode.__qualname__.__eq__,            ["getnode"], true, "getnode.__qualname__ is 'getnode' (top-level, no class prefix)"]
    - [getnode_module,   getnode.__module__.__eq__,              ["uuid"],    true, "getnode.__module__ is 'uuid' (pure-Python in Lib/uuid.py)"]
    - [getnode_argc,     getnode.__code__.co_argcount.__eq__,    [0],         true, "getnode takes no arguments (co_argcount == 0)"]
    - [getnode_coname,   getnode.__code__.co_name.__eq__,        ["getnode"], true, "getnode.__code__.co_name is 'getnode' (matches __name__)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_varnames[0].__eq__('node')
# uuid.uuid3.__code__.co_varnames[0].__eq__('namespace')
# uuid.uuid5.__code__.co_varnames[0].__eq__('namespace')
# uuid.uuid4.__code__.co_varnames[0].__eq__('int_uuid_4')
# uuid.uuid1.__code__.co_varnames.__len__().__eq__(13)
#
# Wave 346 theme: uuid function co_varnames first entry and uuid1 total varcount.
#
# Each uuid generator function has different first local variables reflecting
# their parameters: uuid1 starts with 'node', uuid3/uuid5 start with 'namespace',
# uuid4 starts with 'int_uuid_4' (an internal variable, since uuid4 takes no args).
# uuid1 has 13 total co_varnames due to its complex datetime-based algorithm.
# uuid_extra122 anchors UUID.__init__/etc. co_varnames[0]=='self'; this spec
# anchors the generator function co_varnames[0] under uuidident125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra125.uuid_generator_co_varnames:
  description: "uuid.uuid1/__code__/co_varnames[0].__eq__('node')==True / uuid3/__code__/co_varnames[0].__eq__('namespace')==True / uuid5/__code__/co_varnames[0].__eq__('namespace')==True / uuid4/__code__/co_varnames[0].__eq__('int_uuid_4')==True / uuid1/__code__/co_varnames/__len__().__eq__(13)==True — uuid generator functions have different first locals; uuid4 has no params so first local is internal 'int_uuid_4'; uuid1 has 13 total locals; extra122 anchors UUID method co_varnames[0]=='self'; first uuidident125 anchor for generator co_varnames"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidident125

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_var0,   "uuid1.__code__.co_varnames[0].__eq__",   ["node"],       true, "uuid1 first local is 'node' (the MAC address parameter)"]
    - [uuid3_var0,   "uuid3.__code__.co_varnames[0].__eq__",   ["namespace"],  true, "uuid3 first local is 'namespace' (the UUID namespace parameter)"]
    - [uuid5_var0,   "uuid5.__code__.co_varnames[0].__eq__",   ["namespace"],  true, "uuid5 first local is 'namespace' (same structure as uuid3, using SHA-1)"]
    - [uuid4_var0,   "uuid4.__code__.co_varnames[0].__eq__",   ["int_uuid_4"], true, "uuid4 first local is 'int_uuid_4' (internal; uuid4 takes no user args)"]
    - [uuid1_varlen, "uuid1.__code__.co_varnames.__len__",     [],             13,   "uuid1 has 13 total co_varnames (complex datetime-based algorithm with many locals)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__qualname__.__eq__('SafeUUID')
# uuid.SafeUUID.__module__.__eq__('uuid')
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType')
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum')
#
# Wave 346 theme: SafeUUID enum class identity.
#
# uuid.SafeUUID is an IntEnum class whose metaclass is 'EnumType' (not the plain
# 'type' metaclass used by regular classes). It has two members: safe (value=0)
# and unsafe (value=-1). SafeUUID's __bases__[0] is Enum (the parent). Its
# __class__.__name__ is 'EnumType', distinguishing enum classes from regular ones.
# uuid_extra95 anchors SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 at
# table level. This spec is the first to anchor SafeUUID class identity attributes
# via __eq__ calls under uuidident125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra125.SafeUUID_class_identity:
  description: "uuid.SafeUUID/__name__.__eq__('SafeUUID')==True / SafeUUID/__qualname__.__eq__('SafeUUID')==True / SafeUUID/__module__.__eq__('uuid')==True / SafeUUID/__class__.__name__.__eq__('EnumType')==True / SafeUUID/__bases__[0]/__name__.__eq__('Enum')==True — SafeUUID is an IntEnum class with metaclass EnumType; extra95 anchors SafeUUID member values; first uuidident125 anchor for SafeUUID class identity via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidident125

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_name,       "SafeUUID.__name__.__eq__",            ["SafeUUID"],  true, "SafeUUID.__name__ is 'SafeUUID' (8 chars)"]
    - [safeuuid_qualname,   "SafeUUID.__qualname__.__eq__",        ["SafeUUID"],  true, "SafeUUID.__qualname__ is 'SafeUUID' (top-level, no nesting)"]
    - [safeuuid_module,     "SafeUUID.__module__.__eq__",          ["uuid"],      true, "SafeUUID.__module__ is 'uuid' (defined in Lib/uuid.py)"]
    - [safeuuid_metaclass,  "SafeUUID.__class__.__name__.__eq__",  ["EnumType"],  true, "SafeUUID.__class__.__name__ is 'EnumType' (enum metaclass, not 'type')"]
    - [safeuuid_base,       "SafeUUID.__bases__[0].__name__.__eq__", ["Enum"],    true, "SafeUUID.__bases__[0].__name__ is 'Enum' (parent class of IntEnum enums)"]

# ---------------------------------------------------------------------------
# uuid.getnode.__name__.__eq__('getnode') — standalone
#
# uuid.getnode.__name__ is 'getnode' (7 chars). Unlike hashlib.new whose __name__
# reveals private aliasing ('__hash_new' != 'new'), getnode.__name__ equals the
# public attribute name. uuid.getnode finds the hardware MAC address by trying
# various platform-specific methods. uuid_extra86 anchors getnode __qualname__/
# __module__/co_argcount at table level; this is the first standalone for
# getnode.__name__.__eq__('getnode') under uuidident125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra125.getnode_name:
  description: "uuid.getnode.__name__.__eq__('getnode') == True — getnode.__name__ equals the public attribute name (no private aliasing); finds hardware MAC via platform-specific methods; extra86 anchors __qualname__/__module__/co_argcount at table level; first standalone for getnode.__name__.__eq__ under uuidident125"
  category: type_identity
  kind: python_call_eq
  function: getnode.__name__.__eq__
  args: ["getnode"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_varnames[0].__eq__('node') — standalone
#
# uuid.uuid1.__code__.co_varnames[0] is 'node'. The first formal parameter of
# uuid1 is 'node', the optional MAC address (defaults to None, which causes the
# system MAC to be obtained via getnode()). uuid_extra122 anchors UUID.__init__
# co_varnames[0]=='self'; this is the first standalone for uuid1 co_varnames[0]
# under uuidident125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra125.uuid1_co_varnames_0:
  description: "uuid.uuid1.__code__.co_varnames[0].__eq__('node') == True — uuid1's first parameter is 'node' (optional MAC address; None causes getnode() lookup); extra122 anchors UUID.__init__ co_varnames[0]=='self'; first standalone for uuid1 co_varnames[0] under uuidident125"
  category: type_identity
  kind: python_call_eq
  function: "uuid1.__code__.co_varnames[0].__eq__"
  args: ["node"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType') — standalone
#
# uuid.SafeUUID.__class__.__name__ is 'EnumType'. Enum classes in Python 3 use
# a special metaclass 'EnumType' (previously named 'EnumMeta' in older Python
# versions, renamed to 'EnumType' in Python 3.11+). This means SafeUUID's type
# (its __class__) is EnumType, not the plain 'type' metaclass used for ordinary
# Python classes. uuid_extra95 anchors SafeUUID member values; this is the first
# standalone for SafeUUID.__class__.__name__.__eq__('EnumType') under uuidident125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra125.SafeUUID_metaclass_EnumType:
  description: "uuid.SafeUUID.__class__.__name__.__eq__('EnumType') == True — SafeUUID's metaclass is 'EnumType' (Python 3.11+ rename of EnumMeta); distinguishes enum classes from ordinary classes whose __class__.__name__ is 'type'; extra95 anchors SafeUUID member values; first standalone for SafeUUID metaclass name under uuidident125"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__class__.__name__.__eq__"
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_varnames[0].__eq__('int_uuid_4') — standalone
#
# uuid.uuid4.__code__.co_varnames[0] is 'int_uuid_4'. uuid4 takes no user
# arguments (co_argcount == 0), so its first co_varnames entry is an internal
# local variable named 'int_uuid_4' that holds the raw 128-bit random integer
# before it is wrapped in a UUID object. This is unique among the uuid generator
# functions; uuid1/uuid3/uuid5 all have user parameter names as their first
# co_varnames entry. This is the first standalone for uuid4 co_varnames[0] under
# uuidident125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra125.uuid4_co_varnames_0:
  description: "uuid.uuid4.__code__.co_varnames[0].__eq__('int_uuid_4') == True — uuid4 takes no user args so first co_varnames entry is internal 'int_uuid_4' (the raw 128-bit random integer); unique among uuid generators (uuid1/uuid3/uuid5 start with user param names); first standalone for uuid4 co_varnames[0] under uuidident125"
  category: type_identity
  kind: python_call_eq
  function: "uuid4.__code__.co_varnames[0].__eq__"
  args: ["int_uuid_4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_varnames.__len__().__eq__(13) — standalone
#
# uuid.uuid1.__code__.co_varnames.__len__() is 13. uuid1 has the most complex
# implementation among the uuid generator functions, requiring numerous local
# variables to compute the time-based UUID: it must obtain a timestamp,
# sequence number, and node identifier, then pack them into the 128-bit UUID
# structure. uuid3/uuid5 have only 5 co_varnames; uuid4 has only 1.
# This is the first standalone for uuid1 co_varnames.__len__()==13 under
# uuidident125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra125.uuid1_co_varnames_len:
  description: "uuid.uuid1.__code__.co_varnames.__len__() == 13 — uuid1 has the most complex implementation (13 locals) vs uuid3/uuid5 (5 locals) and uuid4 (1 local); complexity reflects time-based UUID generation requiring timestamp/sequence/node computation; first standalone for uuid1 co_varnames length under uuidident125"
  category: type_identity
  kind: python_call_eq
  function: "uuid1.__code__.co_varnames.__len__"
  args: []
  expected: 13
