spec: turtle_extra3
version: ">=3.9"
backend: python_module(turtle)

docs: https://docs.python.org/3/library/turtle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/turtle.html — Python turtle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/turtle.py"
  notes:
    - "This spec extends turtle.zspec.zsdl, turtle_extra.zspec.zsdl, and turtle_extra2.zspec.zsdl."
    - "turtle.zspec.zsdl covers: Turtle/Screen/RawTurtle/TurtleScreen/Vec2D/Pen __name__; forward/backward/penup/pendown/circle/done __name__."
    - "turtle_extra.zspec.zsdl covers: Turtle/Screen/Pen __name__+__module__; forward/backward/bgcolor/done __name__; function type checks."
    - "turtle_extra2.zspec.zsdl covers: right/left/speed __name__; Turtle.__qualname__; navigation function name table."
    - "This spec adds: Vec2D/__module__, RawTurtle/__module__, TurtleScreen/__module__, Screen/__qualname__, color/__name__, pencolor/__name__, fillcolor/__name__, goto/__name__, setheading/__name__."
    - "All class and function name checks are safe without a running display or Tk instance."
    - "All expected values verified with Python 3.12 turtle on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Vec2D — module affiliation
# turtle.zspec.zsdl and turtle_extra cover Vec2D.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra3.Vec2D.module:
  description: "turtle.Vec2D.__module__ == 'turtle'"
  category: class_modules
  kind: python_call_eq
  function: Vec2D.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# RawTurtle — module affiliation
# turtle.zspec.zsdl covers RawTurtle.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra3.RawTurtle.module:
  description: "turtle.RawTurtle.__module__ == 'turtle'"
  category: class_modules
  kind: python_call_eq
  function: RawTurtle.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# TurtleScreen — module affiliation
# turtle.zspec.zsdl covers TurtleScreen.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra3.TurtleScreen.module:
  description: "turtle.TurtleScreen.__module__ == 'turtle'"
  category: class_modules
  kind: python_call_eq
  function: TurtleScreen.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# Screen — qualname
# turtle_extra covers Screen.__name__ and __module__; __qualname__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra3.Screen.qualname:
  description: "turtle.Screen.__qualname__ == 'Screen'"
  category: class_qualnames
  kind: python_call_eq
  function: Screen.__qualname__.__eq__
  args: ["Screen"]
  expected: true

# ---------------------------------------------------------------------------
# color — function __name__
# Not covered in any prior turtle spec.
# ---------------------------------------------------------------------------

invariant turtle_extra3.color.name:
  description: "turtle.color.__name__ == 'color'"
  category: functions
  kind: python_call_eq
  function: color.__name__.__eq__
  args: ["color"]
  expected: true

# ---------------------------------------------------------------------------
# pencolor — function __name__
# Not covered in any prior turtle spec.
# ---------------------------------------------------------------------------

invariant turtle_extra3.pencolor.name:
  description: "turtle.pencolor.__name__ == 'pencolor'"
  category: functions
  kind: python_call_eq
  function: pencolor.__name__.__eq__
  args: ["pencolor"]
  expected: true

# ---------------------------------------------------------------------------
# fillcolor — function __name__
# Not covered in any prior turtle spec.
# ---------------------------------------------------------------------------

invariant turtle_extra3.fillcolor.name:
  description: "turtle.fillcolor.__name__ == 'fillcolor'"
  category: functions
  kind: python_call_eq
  function: fillcolor.__name__.__eq__
  args: ["fillcolor"]
  expected: true

# ---------------------------------------------------------------------------
# goto — function __name__
# Not covered in any prior turtle spec.
# ---------------------------------------------------------------------------

invariant turtle_extra3.goto.name:
  description: "turtle.goto.__name__ == 'goto'"
  category: functions
  kind: python_call_eq
  function: goto.__name__.__eq__
  args: ["goto"]
  expected: true

# ---------------------------------------------------------------------------
# setheading — function __name__
# Not covered in any prior turtle spec.
# ---------------------------------------------------------------------------

invariant turtle_extra3.setheading.name:
  description: "turtle.setheading.__name__ == 'setheading'"
  category: functions
  kind: python_call_eq
  function: setheading.__name__.__eq__
  args: ["setheading"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __name__ checks for drawing-control functions
# color, pencolor, fillcolor, goto, and setheading are all new; speed was
# covered in turtle_extra2 as an individual invariant.
# ---------------------------------------------------------------------------

table turtle_extra3.drawing_functions.names:
  kind: python_call_eq
  category: functions
  id_prefix: drawname

  columns: [id, function, args, expected]
  rows:
    - [color,      color.__name__.__eq__,      ["color"],      true]
    - [pencolor,   pencolor.__name__.__eq__,   ["pencolor"],   true]
    - [fillcolor,  fillcolor.__name__.__eq__,  ["fillcolor"],  true]
    - [goto,       goto.__name__.__eq__,       ["goto"],       true]
    - [setheading, setheading.__name__.__eq__, ["setheading"], true]
    - [speed,      speed.__name__.__eq__,      ["speed"],      true]
