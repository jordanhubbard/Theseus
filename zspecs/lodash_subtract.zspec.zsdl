spec: lodash_subtract
version: ">=4.0.0"
backend: node(lodash.subtract)

docs: https://lodash.com/docs/#subtract

provenance:
  derived_from:
    - "lodash.subtract README — https://www.npmjs.com/package/lodash.subtract"
    - "Test vectors verified with lodash.subtract@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.subtract exports the _.subtract function directly as module.exports."
    - "subtract(minuend, subtrahend) subtracts two numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns difference of two numbers."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_subtract.subtract:
  kind: node_module_call_eq
  function: ~
  category: subtract
  id_prefix: lsub

  columns: [id, args, expected]
  rows:
    - [basic,     [6, 4],   2]
    - [zero,      [0, 0],   0]
    - [negative,  [3, 7],   -4]
    - [float,     [5.5, 2.0], 3.5]
