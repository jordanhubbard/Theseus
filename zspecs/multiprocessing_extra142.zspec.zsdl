table multiprocessing_extra142.process_identity:
  description: "multiprocessing.Process identity checks — Process.__name__.__eq__('Process')==True (len=7: 'Process'=7; the class is accessed via the context object so it is a context-specific subclass of BaseProcess); Process.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; same context module length as Manager, Value, Array, cpu_count); Process.__qualname__.__eq__('Process')==True (len=7: top-level class within the context module, qualname equals name); Process.__doc__ is None (no docstring on the context-specific Process subclass; the BaseProcess parent has doc at len=116); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mprocess142

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    multiprocessing.Process.__name__.__eq__,    ["Process"],                    true,  "multiprocessing.Process.__name__ == 'Process' (len=7); verified with Python 3.14.3"]
    - [name_len,   multiprocessing.Process.__name__.__len__,    [],                             7,     "multiprocessing.Process.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [mod_eq,     multiprocessing.Process.__module__.__eq__,  ["multiprocessing.context"],    true,  "multiprocessing.Process.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [mod_len,    multiprocessing.Process.__module__.__len__,  [],                             23,    "multiprocessing.Process.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [qn_eq,      multiprocessing.Process.__qualname__.__eq__, ["Process"],                    true,  "multiprocessing.Process.__qualname__ == 'Process' (len=7: qualname equals name); verified with Python 3.14.3"]
    - [qn_len,     multiprocessing.Process.__qualname__.__len__, [],                            7,     "multiprocessing.Process.__qualname__.__len__() == 7; verified with Python 3.14.3"]

