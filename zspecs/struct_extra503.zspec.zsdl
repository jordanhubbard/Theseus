spec: struct_extra503
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module functions, Struct class methods, and error class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers top-level struct functions, Struct class and its methods, and struct.error __qualname__ identity"
    - "Struct method __qualname__ values include the class prefix e.g. 'Struct.pack'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra503.qualname_checks:
  description: "struct module function, class, method, and error __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: SE503

  columns: [id, function, args, expected]
  rows:
    - [id001, struct.pack.__qualname__.__eq__, ["pack"], true]
    - [id002, struct.unpack.__qualname__.__eq__, ["unpack"], true]
    - [id003, struct.calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [id004, struct.pack_into.__qualname__.__eq__, ["pack_into"], true]
    - [id005, struct.unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [id006, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [id007, struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - [id008, struct.Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [id009, struct.Struct.unpack.__qualname__.__eq__, ["Struct.unpack"], true]
    - [id010, struct.Struct.pack_into.__qualname__.__eq__, ["Struct.pack_into"], true]
    - [id011, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [id012, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]
    - [id013, struct.error.__qualname__.__eq__, ["error"], true]
