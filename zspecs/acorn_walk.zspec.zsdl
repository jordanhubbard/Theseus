spec: acorn_walk
version: ">=8.0.0"
backend: node(acorn-walk)

docs: https://github.com/acornjs/acorn/tree/master/acorn-walk#readme

provenance:
  derived_from:
    - "acorn-walk README — https://github.com/acornjs/acorn/tree/master/acorn-walk#readme"
    - "Test vectors verified with acorn-walk via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "acorn-walk source"
  notes:
    - "ESTree AST walker that pairs with acorn — used by bundlers, linters, and codemod tools."
    - "Install: npm install acorn-walk"
    - "v8 CJS; named exports simple / full / ancestor / recursive / make / findNodeAt / findNodeAround / findNodeAfter / findNodeBefore / fullAncestor / base."
    - "Walking requires JS visitor functions which can't be passed via JSON, so this spec covers the API shape: which exports exist, base visitor table size, function arity."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on valid AST nodes."
  stderr: "null"
  stickiness: "N/A — each walk independent."
  codes: {}

invariant acorn_walk.simple_is_function:
  description: "simple() walker is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "simple.constructor.name"}
  expected: "Function"

invariant acorn_walk.full_is_function:
  description: "full() walker is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "full.constructor.name"}
  expected: "Function"

invariant acorn_walk.ancestor_is_function:
  description: "ancestor() walker is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ancestor.constructor.name"}
  expected: "Function"

invariant acorn_walk.recursive_is_function:
  description: "recursive() walker is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "recursive.constructor.name"}
  expected: "Function"

invariant acorn_walk.findNodeAt_is_function:
  description: "findNodeAt() locator is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "findNodeAt.constructor.name"}
  expected: "Function"

invariant acorn_walk.base_has_Program_visitor:
  description: "base.Program is the default Program visitor (function)"
  category: base
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "base.Program.constructor.name"}
  expected: "Function"

invariant acorn_walk.base_has_FunctionDeclaration:
  description: "base table includes a FunctionDeclaration visitor"
  category: base
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: base}
    - {method: hasOwnProperty, args: ["FunctionDeclaration"]}
  expected: true

invariant acorn_walk.base_has_VariableDeclaration:
  description: "base table includes a VariableDeclaration visitor"
  category: base
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: base}
    - {method: hasOwnProperty, args: ["VariableDeclaration"]}
  expected: true

invariant acorn_walk.base_has_BinaryExpression:
  description: "base table includes a BinaryExpression visitor"
  category: base
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: base}
    - {method: hasOwnProperty, args: ["BinaryExpression"]}
  expected: true
