spec: functools_extra2026
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__/__rtruediv__/__itruediv__, __floordiv__/__rfloordiv__/__ifloordiv__, __mod__/__rmod__/__imod__, __pow__/__rpow__, __divmod__/__rdivmod__ dict-presence checks."
    - "functools classes are not numeric types — none define division, modulo, exponentiation, or divmod operators."
    - "functools.partial: C extension type — division/modulo/pow/divmod dunders absent from __dict__."
    - "functools.partialmethod: Python class — same dunders absent from __dict__."
    - "functools.cached_property: Python descriptor class — same dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __truediv__ / __rtruediv__ / __itruediv__ dict-presence
#
# functools.partial, functools.partialmethod, functools.cached_property are
# not numeric types and do not define any true-division operators in their
# __dict__. All checks expected False.
# ---------------------------------------------------------------------------

table functools_extra2026.truediv_protocol:
  description: "functools types __truediv__/__rtruediv__/__itruediv__ dict-presence checks — all False — wave 582 _extra2026"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2026

  columns: [id, function, args, expected]
  rows:
    - ["ft2026001", "functools.partial.__dict__.__contains__", ["__truediv__"], false]
    - ["ft2026002", "functools.partial.__dict__.__contains__", ["__rtruediv__"], false]
    - ["ft2026003", "functools.partial.__dict__.__contains__", ["__itruediv__"], false]
    - ["ft2026004", "functools.partialmethod.__dict__.__contains__", ["__truediv__"], false]
    - ["ft2026005", "functools.partialmethod.__dict__.__contains__", ["__rtruediv__"], false]
    - ["ft2026006", "functools.partialmethod.__dict__.__contains__", ["__itruediv__"], false]
    - ["ft2026007", "functools.cached_property.__dict__.__contains__", ["__truediv__"], false]
    - ["ft2026008", "functools.cached_property.__dict__.__contains__", ["__rtruediv__"], false]
    - ["ft2026009", "functools.cached_property.__dict__.__contains__", ["__itruediv__"], false]

