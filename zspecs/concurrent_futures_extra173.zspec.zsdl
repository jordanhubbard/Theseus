spec: concurrent_futures_extra173
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.as_completed and wait functions — concurrent.futures.as_completed.__name__=='as_completed' (len=12: 'as_completed'=12); concurrent.futures.as_completed.__module__=='concurrent.futures._base' (len=25: 'concurrent.futures._base'=25); concurrent.futures.wait.__name__=='wait' (len=4); concurrent.futures.wait.__module__=='concurrent.futures._base' (same module as as_completed; len=25); concurrent.futures.FIRST_COMPLETED.__class__.__name__=='str' (it's a string constant); concurrent.futures.ALL_COMPLETED.__class__.__name__=='str'; concurrent.futures.FIRST_EXCEPTION.__class__.__name__=='str'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__name__.__len__() == 12. 'as_completed' is 12 characters: 'as'=2+'_'=1+'completed'=9=12. as_completed yields futures as they complete, in completion order (not submission order). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=6=25). Both as_completed and wait are defined in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__name__.__len__() == 4. 'wait' is 4 characters: w-a-i-t. wait() takes a set of futures and returns two sets: done and not_done. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.FIRST_COMPLETED, concurrent.futures.ALL_COMPLETED, concurrent.futures.FIRST_EXCEPTION are string constants (class 'str'). These are the wait condition sentinel values. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.as_completed __name__ and __module__
#
# concurrent.futures.as_completed.__name__ == 'as_completed' (len=12)
# concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (len=25)
#
# as_completed(fs, timeout=None) is a generator function that yields futures
# from the fs iterable as they complete, regardless of submission order.
# Defined in Lib/concurrent/futures/_base.py. New to extra173.
# ---------------------------------------------------------------------------

table concurrent_futures_extra173.as_completed_name_module:
  description: "concurrent.futures.as_completed.__name__ 'as_completed' len 12; __module__ 'concurrent.futures._base' len 25; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait173

  columns: [id, function, args, expected, description]
  rows:
    - [asc_name_eq,
       "concurrent.futures.as_completed.__name__.__eq__",
       ["as_completed"],
       true,
       "concurrent.futures.as_completed.__name__.__eq__('as_completed') == True — as_completed is a generator function in Lib/concurrent/futures/_base.py that yields futures as they complete; its __name__ is 'as_completed' (12 chars: 'as'=2+'_'=1+'completed'=9=12); str.__eq__('as_completed') returns True; new to extra173"]
    - [asc_name_len_12,
       "concurrent.futures.as_completed.__name__.__len__",
       [],
       12,
       "concurrent.futures.as_completed.__name__.__len__() == 12 — the name 'as_completed' has 12 characters: 'as'=2+'_completed'=10=12; str.__len__() returns 12; new to extra173"]
    - [asc_module_eq,
       "concurrent.futures.as_completed.__module__.__eq__",
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') == True — as_completed is defined in Lib/concurrent/futures/_base.py; its __module__ is 'concurrent.futures._base' (25 chars); str.__eq__('concurrent.futures._base') returns True; new to extra173"]
    - [asc_module_len_25,
       "concurrent.futures.as_completed.__module__.__len__",
       [],
       25,
       "concurrent.futures.as_completed.__module__.__len__() == 25 — 'concurrent.futures._base' has 25 characters: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=6=25; str.__len__() returns 25; new to extra173"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.wait __name__ and __module__
#
# concurrent.futures.wait.__name__ == 'wait' (len=4)
# concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=25; same as as_completed)
#
# wait(fs, timeout=None, return_when=ALL_COMPLETED) waits for futures and
# returns a named tuple (done, not_done). Both sets contain Future objects.
# Defined alongside as_completed in Lib/concurrent/futures/_base.py.
# NAME LENGTH: 'wait'=4 is much shorter than 'as_completed'=12. New to extra173.
# ---------------------------------------------------------------------------

table concurrent_futures_extra173.wait_name_module:
  description: "concurrent.futures.wait.__name__ 'wait' len 4; __module__ 'concurrent.futures._base' len 25 (same as as_completed); new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait173

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,
       "concurrent.futures.wait.__name__.__eq__",
       ["wait"],
       true,
       "concurrent.futures.wait.__name__.__eq__('wait') == True — concurrent.futures.wait is a function in Lib/concurrent/futures/_base.py that waits for a set of futures and returns a named 2-tuple (done, not_done); its __name__ is 'wait' (4 chars: w-a-i-t); str.__eq__('wait') returns True; new to extra173"]
    - [wait_name_len_4,
       "concurrent.futures.wait.__name__.__len__",
       [],
       4,
       "concurrent.futures.wait.__name__.__len__() == 4 — the name 'wait' has exactly 4 characters: w-a-i-t; 8 chars shorter than 'as_completed'=12; str.__len__() returns 4; new to extra173"]
    - [wait_module_eq,
       "concurrent.futures.wait.__module__.__eq__",
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') == True — concurrent.futures.wait is defined in Lib/concurrent/futures/_base.py alongside as_completed; both share the same __module__ 'concurrent.futures._base' (25 chars); str.__eq__('concurrent.futures._base') returns True; new to extra173"]
    - [wait_module_len_25,
       "concurrent.futures.wait.__module__.__len__",
       [],
       25,
       "concurrent.futures.wait.__module__.__len__() == 25 — 'concurrent.futures._base' has 25 characters: same as as_completed.__module__.__len__()==25; both functions are co-defined in _base.py; str.__len__() returns 25; new to extra173"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures wait condition string constants
#
# concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'
# concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'
# concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'
#
# The three wait condition sentinels are plain string constants defined in
# Lib/concurrent/futures/_base.py. They are passed as the return_when
# argument to concurrent.futures.wait(). New to extra173.
# ---------------------------------------------------------------------------

table concurrent_futures_extra173.wait_condition_constants_class:
  description: "FIRST_COMPLETED, ALL_COMPLETED, FIRST_EXCEPTION are str constants; __class__.__name__=='str' for each; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait173

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_class_str,
       "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') == True — FIRST_COMPLETED is a plain string constant in Lib/concurrent/futures/_base.py used as the return_when sentinel for wait(); its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra173"]
    - [all_completed_class_str,
       "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__('str') == True — ALL_COMPLETED is a plain string constant in Lib/concurrent/futures/_base.py; it is the default return_when value for wait(); __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra173"]
    - [first_exception_class_str,
       "concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__('str') == True — FIRST_EXCEPTION is a plain string constant in Lib/concurrent/futures/_base.py; when passed to wait() it causes return when any future raises an exception or all are done; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra173"]
    - [first_completed_value_eq,
       "concurrent.futures.FIRST_COMPLETED.__eq__",
       ["FIRST_COMPLETED"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True — the string value of FIRST_COMPLETED is 'FIRST_COMPLETED'; it is a self-descriptive string constant; str.__eq__('FIRST_COMPLETED') returns True; new to extra173"]
    - [all_completed_value_eq,
       "concurrent.futures.ALL_COMPLETED.__eq__",
       ["ALL_COMPLETED"],
       true,
       "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True — the string value of ALL_COMPLETED is 'ALL_COMPLETED'; default return_when mode for wait(); str.__eq__('ALL_COMPLETED') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra173
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra173.as_completed_name_eq:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed' — generator function in _base.py; __name__ is 'as_completed' (12 chars: 'as'=2+'_completed'=10=12); new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__name__.__eq__"
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra173.as_completed_module_eq:
  description: "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py; __module__ len=25; new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra173.wait_name_eq:
  description: "concurrent.futures.wait.__name__ == 'wait' — function in _base.py; __name__ is 'wait' (4 chars); 8 chars shorter than 'as_completed'=12; new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.wait.__name__.__eq__"
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra173.wait_module_eq:
  description: "concurrent.futures.wait.__module__ == 'concurrent.futures._base' — same module as as_completed; both defined in Lib/concurrent/futures/_base.py; new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.wait.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra173.first_completed_is_str:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — FIRST_COMPLETED is a plain string constant (not an enum); used as return_when sentinel in wait(); new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant concurrent_futures_extra173.all_completed_is_str:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — ALL_COMPLETED is a plain string constant; default return_when value for wait(); new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant concurrent_futures_extra173.first_exception_is_str:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — FIRST_EXCEPTION is a plain string constant; causes wait() to return early when any future raises; new to extra173"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

