spec: importlib_extra2
version: ">=3.4"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "importlib.zspec.zsdl — covers import_module/__name__, reload/__name__, invalidate_caches/__name__, import_module behavior, __spec__.name for returned modules, ModuleNotFoundError, invalidate_caches returns None"
    - "importlib_extra.zspec.zsdl — covers import_module/reload/invalidate_caches __module__; find_loader __name__/__module__; import_module __spec__.name for os/sys; importlib.abc and importlib.machinery submodule names"
    - "importlib_metadata.zspec.zsdl — covers importlib.metadata subpackage"
    - "importlib_resources.zspec.zsdl — covers importlib.resources subpackage"
    - "importlib_util.zspec.zsdl — covers importlib.util subpackage"
    - "importlib_machinery.zspec.zsdl — covers importlib.machinery subpackage"
    - "importlib_abc.zspec.zsdl — covers importlib.abc subpackage"
  notes:
    - "importlib.__spec__.__class__.__name__ == 'ModuleSpec' — the module's own spec is a ModuleSpec instance."
    - "importlib.__spec__.name == 'importlib' — the spec identifies the module by its canonical name."
    - "importlib.__package__ == 'importlib' — the package attribute equals the module name for a package."
    - "import_module.__name__ == 'import_module' already in importlib.zspec.zsdl; here we add __qualname__ checks."
    - "reload.__qualname__ == 'reload' — qualname equals name for module-level functions."
    - "invalidate_caches.__qualname__ == 'invalidate_caches'."
    - "All expected values verified by running Python 3.14.3 importlib on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "importlib raises ModuleNotFoundError (subclass of ImportError) when a module cannot be found."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# importlib.__spec__ — class name and spec.name
# importlib is a package; its __spec__ is a ModuleSpec instance.
# ---------------------------------------------------------------------------

invariant importlib_extra2.module_spec.class_name:
  description: "importlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: module_spec
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant importlib_extra2.module_spec.name:
  description: "importlib.__spec__.name == 'importlib'"
  category: module_spec
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__package__ — package identity
# ---------------------------------------------------------------------------

invariant importlib_extra2.package_attr:
  description: "importlib.__package__ == 'importlib'"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level importlib functions
# (import_module/__name__, reload/__name__, invalidate_caches/__name__
# are already in importlib.zspec.zsdl; __qualname__ is new coverage)
# ---------------------------------------------------------------------------

table importlib_extra2.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [import_module,     import_module.__qualname__.__eq__,     ["import_module"],     true]
    - [reload,            reload.__qualname__.__eq__,            ["reload"],            true]
    - [invalidate_caches, invalidate_caches.__qualname__.__eq__, ["invalidate_caches"], true]
