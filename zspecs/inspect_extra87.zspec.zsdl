spec: inspect_extra87
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra86

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra86.zspec.zsdl."
    - "This spec covers: inspect.Parameter, inspect.Signature, inspect.BoundArguments class identity — __name__, __qualname__, __module__, __mro__.__len__() (Wave 250)."
    - "inspect.Parameter.__name__ == 'Parameter' — class name attribute. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' — qualified name for module-level class. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__mro__.__len__() == 2 — MRO is [Parameter, object]. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' — class name attribute. Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' — qualified name for module-level class. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Signature.__mro__.__len__() == 2 — MRO is [Signature, object]. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' — class name attribute. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' — qualified name for module-level class. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__mro__.__len__() == 2 — MRO is [BoundArguments, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter identity: __name__, __qualname__, __module__, __mro__.__len__()
#
# Wave 250 theme: inspect.Parameter class identity.
#
# inspect.Parameter.__name__.__eq__('Parameter')     == True
# inspect.Parameter.__qualname__.__eq__('Parameter') == True
# inspect.Parameter.__module__.__eq__('inspect')     == True
# inspect.Parameter.__mro__.__len__()                == 2
#
# No prior inspect spec checks Parameter class identity via inspectparamid87. New to extra87.
# ---------------------------------------------------------------------------

table inspect_extra87.Parameter_identity:
  description: "Parameter __name__//__qualname__/__module__==inspect; __mro__.__len__()==2; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectparamid87

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_name_eq_Parameter,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a pure-Python class defined in Lib/inspect.py that represents a parameter in a function signature; __name__ is the unqualified class name 'Parameter' (9 chars); str.__eq__('Parameter') returns True; no prior inspect spec checks Parameter.__name__.__eq__ via inspectparamid87; new to extra87"]
    - [Parameter_qualname_eq_Parameter,
       Parameter.__qualname__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a module-level class in Lib/inspect.py; for a top-level class __qualname__ equals __name__; __qualname__ is 'Parameter' (9 chars); str.__eq__('Parameter') returns True; no prior inspect spec checks Parameter.__qualname__.__eq__ via inspectparamid87; new to extra87"]
    - [Parameter_module_eq_inspect,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks Parameter.__module__.__eq__ via inspectparamid87; new to extra87"]
    - [Parameter_mro_len_eq_2,
       Parameter.__mro__.__len__,
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter is a pure-Python class that inherits directly from object; MRO is [Parameter, object] (depth 2); tuple.__len__() returns 2; no prior inspect spec checks Parameter.__mro__.__len__ via inspectparamid87; new to extra87"]

# ---------------------------------------------------------------------------
# Signature identity: __name__, __qualname__, __module__, __mro__.__len__()
#
# Wave 250 theme: inspect.Signature class identity.
#
# inspect.Signature.__name__.__eq__('Signature')     == True
# inspect.Signature.__qualname__.__eq__('Signature') == True
# inspect.Signature.__module__.__eq__('inspect')     == True
# inspect.Signature.__mro__.__len__()                == 2
#
# No prior inspect spec checks Signature class identity via inspectparamid87. New to extra87.
# ---------------------------------------------------------------------------

table inspect_extra87.Signature_identity:
  description: "Signature __name__//__qualname__/__module__==inspect; __mro__.__len__()==2; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectparamid87

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_name_eq_Signature,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a pure-Python class defined in Lib/inspect.py that represents the call signature of a callable; __name__ is the unqualified class name 'Signature' (9 chars); str.__eq__('Signature') returns True; no prior inspect spec checks Signature.__name__.__eq__ via inspectparamid87; new to extra87"]
    - [Signature_qualname_eq_Signature,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is a module-level class in Lib/inspect.py; for a top-level class __qualname__ equals __name__; __qualname__ is 'Signature' (9 chars); str.__eq__('Signature') returns True; no prior inspect spec checks Signature.__qualname__.__eq__ via inspectparamid87; new to extra87"]
    - [Signature_module_eq_inspect,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks Signature.__module__.__eq__ via inspectparamid87; new to extra87"]
    - [Signature_mro_len_eq_2,
       Signature.__mro__.__len__,
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature is a pure-Python class that inherits directly from object; MRO is [Signature, object] (depth 2); tuple.__len__() returns 2; no prior inspect spec checks Signature.__mro__.__len__ via inspectparamid87; new to extra87"]

# ---------------------------------------------------------------------------
# BoundArguments identity: __name__, __qualname__, __module__, __mro__.__len__()
#
# Wave 250 theme: inspect.BoundArguments class identity.
#
# inspect.BoundArguments.__name__.__eq__('BoundArguments')     == True
# inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True
# inspect.BoundArguments.__module__.__eq__('inspect')          == True
# inspect.BoundArguments.__mro__.__len__()                     == 2
#
# No prior inspect spec checks BoundArguments class identity via inspectparamid87. New to extra87.
# ---------------------------------------------------------------------------

table inspect_extra87.BoundArguments_identity:
  description: "BoundArguments __name__//__qualname__/__module__==inspect; __mro__.__len__()==2; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectparamid87

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_name_eq_BoundArguments,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py that represents the arguments bound to a function signature; __name__ is the unqualified class name 'BoundArguments' (14 chars); str.__eq__('BoundArguments') returns True; no prior inspect spec checks BoundArguments.__name__.__eq__ via inspectparamid87; new to extra87"]
    - [BoundArguments_qualname_eq_BoundArguments,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is a module-level class in Lib/inspect.py; for a top-level class __qualname__ equals __name__; __qualname__ is 'BoundArguments' (14 chars); str.__eq__('BoundArguments') returns True; no prior inspect spec checks BoundArguments.__qualname__.__eq__ via inspectparamid87; new to extra87"]
    - [BoundArguments_module_eq_inspect,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks BoundArguments.__module__.__eq__ via inspectparamid87; new to extra87"]
    - [BoundArguments_mro_len_eq_2,
       BoundArguments.__mro__.__len__,
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — BoundArguments is a pure-Python class that inherits directly from object; MRO is [BoundArguments, object] (depth 2); tuple.__len__() returns 2; no prior inspect spec checks BoundArguments.__mro__.__len__ via inspectparamid87; new to extra87"]

# ---------------------------------------------------------------------------
# Cross-check / MRO: verify all three classes have consistent MRO depth and
# confirm __module__ consistency across all three.
#
# Wave 250 theme: Parameter/Signature/BoundArguments cross-check.
#
# inspect.Parameter.__mro__.__len__()    == 2  (double-confirm)
# inspect.Signature.__mro__.__len__()    == 2  (double-confirm)
# inspect.BoundArguments.__mro__.__len__() == 2  (double-confirm)
# inspect.Parameter.__module__.__eq__('inspect')  (double-confirm)
#
# New to extra87.
# ---------------------------------------------------------------------------

table inspect_extra87.cross_check_mro_and_module:
  description: "Parameter/Signature/BoundArguments MRO depth double-confirms; Parameter __module__ double-confirm; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectparamid87

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_mro_len_confirm,
       Parameter.__mro__.__len__,
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — double-confirms Parameter MRO depth is 2; MRO is [Parameter, object]; Parameter inherits from no intermediate class; new to extra87"]
    - [Signature_mro_len_confirm,
       Signature.__mro__.__len__,
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — double-confirms Signature MRO depth is 2; MRO is [Signature, object]; Signature inherits from no intermediate class; new to extra87"]
    - [BoundArguments_mro_len_confirm,
       BoundArguments.__mro__.__len__,
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — double-confirms BoundArguments MRO depth is 2; MRO is [BoundArguments, object]; BoundArguments inherits from no intermediate class; new to extra87"]
    - [Parameter_module_inspect_confirm,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — double-confirms Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; all three classes (Parameter, Signature, BoundArguments) share the same __module__; new to extra87"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra87
# ---------------------------------------------------------------------------

invariant inspect_extra87.Parameter_name_eq_Parameter:
  description: "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter class __name__ is 'Parameter'; wave 250; new to extra87"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra87.Signature_name_eq_Signature:
  description: "inspect.Signature.__name__.__eq__('Signature') == True — Signature class __name__ is 'Signature'; wave 250; new to extra87"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra87.BoundArguments_name_eq_BoundArguments:
  description: "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments class __name__ is 'BoundArguments'; wave 250; new to extra87"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra87.Parameter_mro_len_eq_2:
  description: "inspect.Parameter.__mro__.__len__() == 2 — Parameter MRO is [Parameter, object]; wave 250; new to extra87"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra87.BoundArguments_module_eq_inspect:
  description: "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; wave 250; new to extra87"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true
