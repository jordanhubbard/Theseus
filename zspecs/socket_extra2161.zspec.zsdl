spec: socket_extra2161
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py and Modules/socketmodule.c"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2161: descriptor protocol dict-presence — __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__."
    - "socket.socket is a Python class (not a descriptor class) with two property objects in its __dict__: family and type."
    - "socket.socket does NOT define __get__/__set__/__delete__ in its own __dict__ — it is not itself a descriptor."
    - "socket.error (alias for OSError) is an exception class and defines none of the descriptor protocol attrs in its own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses and define none of the descriptor protocol attrs in their own __dict__."
    - "socket.socket.__dict__ contains member_descriptor objects (_closed, _io_refs) which have __objclass__, but the socket class itself does not."
    - "socket.error.__dict__ contains member_descriptor objects (errno, strerror, filename, filename2) and characters_written (getset_descriptor)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2161.socket_descriptor_protocol:
  description: "socket.socket descriptor protocol dict-presence — socket is not itself a descriptor class"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2161

  columns: [id, function, args, expected]
  rows:
    - ["sk2161001", "socket.socket.__dict__.__contains__", ["__get__"], false]
    - ["sk2161002", "socket.socket.__dict__.__contains__", ["__set__"], false]
    - ["sk2161003", "socket.socket.__dict__.__contains__", ["__delete__"], false]
    - ["sk2161004", "socket.socket.__dict__.__contains__", ["__set_name__"], false]
    - ["sk2161005", "socket.socket.__dict__.__contains__", ["fget"], false]
    - ["sk2161006", "socket.socket.__dict__.__contains__", ["fset"], false]
    - ["sk2161007", "socket.socket.__dict__.__contains__", ["fdel"], false]
    - ["sk2161008", "socket.socket.__dict__.__contains__", ["__objclass__"], false]
    - ["sk2161009", "socket.socket.__dict__.__contains__", ["__func__"], false]

