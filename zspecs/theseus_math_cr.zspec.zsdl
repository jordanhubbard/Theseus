spec: theseus_math_cr
version: ">=3.0"
backend: python_cleanroom(theseus_math_cr)
blocks: math

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/math.html"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "Clean-room math module. Do NOT import math."

error_model: python_exceptions

invariant theseus_math_cr.math2_sqrt:
  description: "sqrt() computes square roots correctly"
  category: behavior
  kind: python_call_eq
  function: math2_sqrt
  args: []
  expected: true

invariant theseus_math_cr.math2_constants:
  description: "pi, e, tau, inf, nan constants are defined"
  category: behavior
  kind: python_call_eq
  function: math2_constants
  args: []
  expected: true

invariant theseus_math_cr.math2_trig:
  description: "sin/cos/tan functions work correctly"
  category: behavior
  kind: python_call_eq
  function: math2_trig
  args: []
  expected: true
