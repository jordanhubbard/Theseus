spec: concurrent_futures_extra144
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ProcessPoolExecutor — ProcessPoolExecutor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py, Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.ProcessPoolExecutor class identity and method qualnames. ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19: 1 more than ThreadPoolExecutor at 18). ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26; 1 more than 'concurrent.futures.thread' at len=25). ProcessPoolExecutor.__bases__[0].__name__=='Executor' (len=8). ProcessPoolExecutor.__doc__ is None. ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26: 1 more than ThreadPoolExecutor.submit at 25). ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28: 1 more than ThreadPoolExecutor.__init__ at 27). ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28: tied with __init__ for longest). ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23: differs from ThreadPoolExecutor.map which shows 'Executor.map'; PPE.map is defined on ProcessPoolExecutor directly). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Unlike ThreadPoolExecutor.map (qualname 'Executor.map', len=12), ProcessPoolExecutor.map has qualname 'ProcessPoolExecutor.map' (len=23) because PPE overrides map directly. PPE.submit varnames len==6 vs TPE.submit varnames len==7. PPE.__init__ takes 5 argcount (same as TPE) but 7 varnames (vs 6 for TPE). PPE.shutdown co_argcount==2 with varnames len==3 (fewer locals than TPE.shutdown at 5). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor class identity — extra144
#
# ProcessPoolExecutor.__name__              == 'ProcessPoolExecutor' (len=19)
# ProcessPoolExecutor.__module__            == 'concurrent.futures.process' (len=26)
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'            (len=8)
# ProcessPoolExecutor.__doc__               == None
# ---------------------------------------------------------------------------

table concurrent_futures_extra144.ppe_class_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity checks — ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (len=19: 'ProcessPool'=11+'Executor'=8=19; 1 more than ThreadPoolExecutor at 18 which was covered in extra143); ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26; 1 more than 'concurrent.futures.thread' at len=25); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (len=8: inherits from the same abstract Executor base class as ThreadPoolExecutor); ProcessPoolExecutor.__doc__ is None (no class-level docstring, same as ThreadPoolExecutor); ProcessPoolExecutor.__name__.__len__()==19; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppe_id144

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   concurrent.futures.ProcessPoolExecutor.__name__.__eq__,              ["ProcessPoolExecutor"],            true,  "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); verified with Python 3.14.3"]
    - [name_len,  concurrent.futures.ProcessPoolExecutor.__name__.__len__,              [],                                 19,    "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [mod_eq,    concurrent.futures.ProcessPoolExecutor.__module__.__eq__,            ["concurrent.futures.process"],     true,  "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [mod_len,   concurrent.futures.ProcessPoolExecutor.__module__.__len__,            [],                                 26,    "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [base_eq,   "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                      true,  "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [base_len,  "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__len__", [],                               8,     "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__len__() == 8; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.submit and __init__ — extra144
#
# ProcessPoolExecutor.submit.__qualname__      == 'ProcessPoolExecutor.submit' (len=26)
# ProcessPoolExecutor.submit.__module__        == 'concurrent.futures.process' (len=26)
# ProcessPoolExecutor.submit.__doc__.__len__() == 248
# ProcessPoolExecutor.submit co_argcount       == 2
# ProcessPoolExecutor.submit co_varnames len   == 6
# ProcessPoolExecutor.__init__.__qualname__    == 'ProcessPoolExecutor.__init__' (len=28)
# ProcessPoolExecutor.__init__ co_argcount     == 5
# ProcessPoolExecutor.__init__ co_varnames len == 7
# ---------------------------------------------------------------------------

table concurrent_futures_extra144.ppe_submit_and_init:
  description: "concurrent.futures.ProcessPoolExecutor.submit and __init__ qualname, doc, and code checks — submit.__qualname__.__eq__('ProcessPoolExecutor.submit')==True (len=26: 'ProcessPoolExecutor'=19+'.'=1+'submit'=6=26; 1 more than ThreadPoolExecutor.submit at 25; unlike TPE.map, PPE.submit qualname length coincidentally equals its module length at 26); submit.__module__.__eq__('concurrent.futures.process')==True (len=26: same process module; qualname and module both len=26); submit.__doc__.__len__()==248 (same doc length as TPE.submit at 248: the shared submit doc from the Executor interface); submit.__code__.co_argcount.__eq__(2)==True ('self','fn'); submit.__code__.co_varnames.__len__()==6 ('self','fn','args','kwargs','f','w' — 2 params + 4 locals; 1 fewer than TPE.submit which has 7 co_varnames); __init__.__qualname__.__eq__('ProcessPoolExecutor.__init__')==True (len=28: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28; tied with shutdown for longest method qualname in this spec; 1 more than TPE.__init__ at 27); __init__.__code__.co_argcount.__eq__(5)==True ('self','max_workers','mp_context','initializer','initargs'); __init__.__code__.co_varnames.__len__()==7 ('self','max_workers','mp_context','initializer','initargs','max_tasks_per_child','queue_size' — 5 params + 2 additional locals; 1 more than TPE.__init__ at 6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppe_si144

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qn_eq,    concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__,          ["ProcessPoolExecutor.submit"],  true,  "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26); verified with Python 3.14.3"]
    - [sub_qn_len,   concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__len__,          [],                             26,    "ProcessPoolExecutor.submit.__qualname__.__len__() == 26; verified with Python 3.14.3"]
    - [sub_mod_eq,   concurrent.futures.ProcessPoolExecutor.submit.__module__.__eq__,            ["concurrent.futures.process"],  true,  "ProcessPoolExecutor.submit.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [sub_mod_len,  concurrent.futures.ProcessPoolExecutor.submit.__module__.__len__,            [],                             26,    "ProcessPoolExecutor.submit.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [sub_doc_len,  concurrent.futures.ProcessPoolExecutor.submit.__doc__.__len__,               [],                             248,   "ProcessPoolExecutor.submit.__doc__.__len__() == 248 (same as TPE.submit); verified with Python 3.14.3"]
    - [sub_argc,     concurrent.futures.ProcessPoolExecutor.submit.__code__.co_argcount.__eq__,  [2],                             true,  "ProcessPoolExecutor.submit.__code__.co_argcount == 2 ('self','fn'); verified with Python 3.14.3"]
    - [sub_vlen,     concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames.__len__,  [],                             6,     "ProcessPoolExecutor.submit.__code__.co_varnames.__len__() == 6; verified with Python 3.14.3"]
    - [ini_qn_eq,    concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__,        ["ProcessPoolExecutor.__init__"], true,  "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28); verified with Python 3.14.3"]
    - [ini_qn_len,   concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__,        [],                             28,    "ProcessPoolExecutor.__init__.__qualname__.__len__() == 28; verified with Python 3.14.3"]
    - [ini_argc,     concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],                            true,  "ProcessPoolExecutor.__init__.__code__.co_argcount == 5; verified with Python 3.14.3"]
    - [ini_vlen,     concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__, [],                            7,     "ProcessPoolExecutor.__init__.__code__.co_varnames.__len__() == 7; verified with Python 3.14.3"]

