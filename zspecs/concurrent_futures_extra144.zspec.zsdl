    - [sdn_qn_len,   concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__,          [],                               28,    "ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28; verified with Python 3.14.3"]
    - [sdn_mod_len,  concurrent.futures.ProcessPoolExecutor.shutdown.__module__.__len__,            [],                               26,    "ProcessPoolExecutor.shutdown.__module__.__len__() == 26 ('concurrent.futures.process'); verified with Python 3.14.3"]
    - [sdn_doc_len,  concurrent.futures.ProcessPoolExecutor.shutdown.__doc__.__len__,               [],                               491,   "ProcessPoolExecutor.shutdown.__doc__.__len__() == 491 (same as TPE.shutdown); verified with Python 3.14.3"]
    - [sdn_argc,     concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_argcount.__eq__,  [2],                               true,  "ProcessPoolExecutor.shutdown.__code__.co_argcount == 2 ('self','wait'); verified with Python 3.14.3"]
