    - [map_qn_eq,    concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__,               ["ProcessPoolExecutor.map"],       true,  "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23); verified with Python 3.14.3"]
    - [map_qn_len,   concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__,               [],                               23,    "ProcessPoolExecutor.map.__qualname__.__len__() == 23 (not 'Executor.map' like TPE); verified with Python 3.14.3"]
    - [map_mod_eq,   concurrent.futures.ProcessPoolExecutor.map.__module__.__eq__,                 ["concurrent.futures.process"],    true,  "ProcessPoolExecutor.map.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [map_mod_len,  concurrent.futures.ProcessPoolExecutor.map.__module__.__len__,                 [],                               26,    "ProcessPoolExecutor.map.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [map_doc_len,  concurrent.futures.ProcessPoolExecutor.map.__doc__.__len__,                    [],                               1052,  "ProcessPoolExecutor.map.__doc__.__len__() == 1052; verified with Python 3.14.3"]
    - [map_argc,     concurrent.futures.ProcessPoolExecutor.map.__code__.co_argcount.__eq__,       [2],                               true,  "ProcessPoolExecutor.map.__code__.co_argcount == 2 ('self','fn'); verified with Python 3.14.3"]
