invariant concurrent_futures_extra144.ppe_name_len_19:
  description: "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 — concurrent.futures.ProcessPoolExecutor.__name__ is 'ProcessPoolExecutor' (19 chars: 'ProcessPool'=11+'Executor'=8=19); this is 1 more than ThreadPoolExecutor.__name__.__len__()==18 (covered in extra143); __module__=='concurrent.futures.process' (len=26); __bases__[0].__name__=='Executor' (len=8); __doc__ is None; NEW in extra144: first standalone ProcessPoolExecutor class name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
