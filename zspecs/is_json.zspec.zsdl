spec: is_json
version: ">=2.0.1"
backend: node(is-json)

docs: https://www.npmjs.com/package/is-json

provenance:
  derived_from:
    - "is-json README — https://www.npmjs.com/package/is-json"
    - "Test vectors verified with is-json via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-json source"
  notes:
    - "is-json is an npm package. Install: npm install is-json"
    - "Returns true only for non-empty JSON objects ({\"key\":value,...}); arrays, empty objects, and primitives return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_json.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: isjson

  columns: [id, args, expected]
  rows:
    - [object,    ["{\"a\":1}"],     true]
    - [multi,     ["{\"a\":1,\"b\":2}"], true]
    - [empty_obj, ["{}"],           false]
    - [array,     ["[1,2,3]"],      false]
    - [text,      ["not json"],     false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:28:20Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
