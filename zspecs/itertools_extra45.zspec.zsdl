spec: itertools_extra45
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra44.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types (groupby/chain/compress/islice/zip_longest/permutations/combinations/product/accumulate/starmap/dropwhile/takewhile/repeat/count/cycle); __bases__[0].__name__.__len__()==6 for all types; __name__/__qualname__ string equality for all major types; __bases__[0].__name__=='object' string equality for chain/count/product/permutations/combinations/combinations_with_replacement/groupby/islice/zip_longest/accumulate/compress/dropwhile/takewhile/filterfalse/starmap/pairwise/batched/repeat/cycle."
    - "This spec covers: itertools.groupby.__bases__[0].__qualname__ == 'object'; itertools.chain.__bases__[0].__qualname__ == 'object'; itertools.compress.__bases__[0].__qualname__ == 'object'; itertools.islice.__bases__[0].__qualname__ == 'object'; itertools.zip_longest.__bases__[0].__qualname__ == 'object'; itertools.permutations.__bases__[0].__qualname__ == 'object'; itertools.combinations.__bases__[0].__qualname__ == 'object'; itertools.product.__bases__[0].__qualname__ == 'object'; itertools.accumulate.__bases__[0].__qualname__ == 'object'."
    - "Key findings: All nine itertools C-extension types covered in this spec have __bases__[0].__qualname__ == 'object'. Every itertools type defined in Modules/itertoolsmodule.c inherits directly from PyBaseObject_Type (object) with no intermediate class. For the built-in object type, __qualname__ equals __name__ (both are 'object'). Prior specs recorded __bases__[0].__name__ == 'object' for all these types (string equality via __name__), and __bases__[0].__name__.__len__() == 6 for all, but no prior spec recorded __bases__[0].__qualname__ for any itertools type. The __qualname__ attribute provides the same value as __name__ for the built-in object type, but these are distinct attribute lookups."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools types __bases__[0].__qualname__ — extra45 namespace
#
# All itertools C-extension types inherit directly from object. For the
# built-in object type, __qualname__ == __name__ == 'object'. Prior specs
# recorded __bases__[0].__name__ == 'object' (string equality) and
# __bases__[0].__name__.__len__() == 6 for all these types. No prior spec
# recorded __bases__[0].__qualname__ for any itertools type. The nine types
# covered here span the major grouping, filtering, combining, and slicing
# categories of the itertools module. All are C-extension types in
# Modules/itertoolsmodule.c.
# ---------------------------------------------------------------------------

table itertools_extra45.groupby_chain_compress_bases_qualname:
  description: "itertools groupby/chain/compress __bases__[0].__qualname__ == 'object' — C-extension types inheriting directly from object; __qualname__ == __name__ for built-in object type"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: gccbq45

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_bases_qualname,
       "groupby.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.groupby.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; groups consecutive elements of an iterable by a key function"]
    - [chain_bases_qualname,
       "chain.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; chains multiple iterables into a single sequential iterator"]
    - [compress_bases_qualname,
       "compress.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.compress.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; filters elements using a boolean selector iterable"]

# ---------------------------------------------------------------------------
# itertools islice/zip_longest/permutations/combinations __bases__[0].__qualname__
# — extra45 namespace
#
# islice, zip_longest, permutations, and combinations all have
# __bases__[0].__qualname__ == 'object'. Like all itertools types they are
# C-extension classes in itertoolsmodule.c inheriting directly from PyBaseObject_Type.
# Prior specs recorded __bases__[0].__name__ == 'object' (string equality) for
# all four types in extra43. The __qualname__ attribute on the base is new here.
# ---------------------------------------------------------------------------

table itertools_extra45.islice_ziplong_perms_combs_bases_qualname:
  description: "itertools islice/zip_longest/permutations/combinations __bases__[0].__qualname__ == 'object' — C-extension types inheriting directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: izpcbq45

  columns: [id, function, args, expected, description]
  rows:
    - [islice_bases_qualname,
       "islice.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; slices an iterator returning selected elements by index and step"]
    - [zip_longest_bases_qualname,
       "zip_longest.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; zips iterables to the length of the longest, filling shorter ones with a fillvalue"]
    - [permutations_bases_qualname,
       "permutations.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; yields all ordered arrangements of r elements from the input iterable"]
    - [combinations_bases_qualname,
       "combinations.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; yields all r-length subsequences of the input iterable without repetition"]

# ---------------------------------------------------------------------------
# itertools product/accumulate __bases__[0].__qualname__ — extra45 namespace
#
# itertools.product and itertools.accumulate both have
# __bases__[0].__qualname__ == 'object'. product generates the Cartesian
# product of input iterables; accumulate computes running totals (or other
# cumulative operations). Prior specs recorded __bases__[0].__name__ == 'object'
# for both in extra43. The __qualname__ attribute on the base is new here.
# ---------------------------------------------------------------------------

table itertools_extra45.product_accumulate_bases_qualname:
  description: "itertools product/accumulate __bases__[0].__qualname__ == 'object' — C-extension types; Cartesian product and running-total iterators; both inherit directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pabq45

  columns: [id, function, args, expected, description]
  rows:
    - [product_bases_qualname,
       "product.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; computes Cartesian product of input iterables, equivalent to nested for-loops"]
    - [accumulate_bases_qualname,
       "accumulate.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.accumulate.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; yields accumulated sums (or other binary function results) of an iterable"]
