spec: concurrent_futures_extra160
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Future method qualnames accessible from the top-level package (done, running, cancelled, cancel). concurrent.futures.Future.done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11); concurrent.futures.Future.running.__qualname__=='Future.running' (len=14: 'Future'=6+'.'=1+'running'=7=14); concurrent.futures.Future.cancelled.__qualname__=='Future.cancelled' (len=16: 'Future'=6+'.'=1+'cancelled'=9=16); concurrent.futures.Future.cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13). Length ordering: done(11) < cancel(13) < running(14) < cancelled(16). Note: concurrent.futures.Future is the same object as concurrent.futures._base.Future (concurrent.futures.Future is concurrent.futures._base.Future == True). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.done.__qualname__=='Future.done' (len=11) — done() returns True if the Future was successfully cancelled or finished running; 'done'=4 is the shortest method name here: done(4) < cancel(6) < running(7) < cancelled(9); qualname lengths follow method name lengths plus constant 'Future.'=7 prefix: done(7+4=11) < cancel(7+6=13) < running(7+7=14) < cancelled(7+9=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "The cancel/cancelled naming pair: cancel.__qualname__=='Future.cancel' (len=13: 'cancel'=6) and cancelled.__qualname__=='Future.cancelled' (len=16: 'cancelled'=9='cancel'=6+'led'=3=9); 'cancelled' (len=9) = 'cancel' (len=6) + 'led' (len=3); so cancelled qualname(16) = cancel qualname(13) + 3; cancel() attempts to cancel the Future; cancelled() returns True if the Future was successfully cancelled. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Method name lengths for this spec: done(4) < cancel(6) < running(7) < cancelled(9); qualname lengths: done(11) < cancel(13) < running(14) < cancelled(16); compare with extra159 qualnames: result(13) < exception(16) < set_result(17) < set_exception(20); the four state-query methods (done, running, cancelled, cancel) covered here have shorter qualnames than the result/exception methods from extra159 because their method names are shorter. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future.done and .running qualnames — extra160
#
# concurrent.futures.Future.done.__qualname__.__eq__('Future.done')       == True
# concurrent.futures.Future.running.__qualname__.__eq__('Future.running') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra160.cf_future_done_running_qualnames:
  description: "concurrent.futures.Future.done and running method qualname checks in cffutdr160 namespace — Future.done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11; done() returns True if the Future was successfully cancelled or finished running; 'done'=4 is the shortest method name in this spec and yields the shortest qualname len=11); Future.running.__qualname__=='Future.running' (len=14: 'Future'=6+'.'=1+'running'=7=14; running() returns True if the Future is currently being executed and cannot be cancelled; 'running'=7 > 'done'=4 so running qualname(14) > done qualname(11) by 3); the 'Future.'=7 prefix (6+1=7) is constant for all four method qualnames; qualname length ordering in this spec: done(11) < cancel(13) < running(14) < cancelled(16); concurrent.futures.Future is the same object as concurrent.futures._base.Future (both access the same class); method qualnames are the same whether accessed via the package or _base submodule; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutdr160

  columns: [id, function, args, expected, description]
  rows:
    - [done_qn_eq,     concurrent.futures.Future.done.__qualname__.__eq__,     ["Future.done"],     true,  "Future.done.__qualname__ == 'Future.done' (len=11; done() checks if Future is finished or cancelled); verified with Python 3.14.3"]
    - [running_qn_eq,  concurrent.futures.Future.running.__qualname__.__eq__,  ["Future.running"],  true,  "Future.running.__qualname__ == 'Future.running' (len=14; running() checks if Future is executing); verified with Python 3.14.3"]
    - [done_qn_len,    concurrent.futures.Future.done.__qualname__.__len__,     [],                  11,    "Future.done.__qualname__.__len__() == 11 ('Future.done'; shortest qualname in spec; 'done'=4); verified with Python 3.14.3"]
    - [running_qn_len, concurrent.futures.Future.running.__qualname__.__len__,  [],                  14,    "Future.running.__qualname__.__len__() == 14 ('Future.running'; 'running'=7; 3 longer than done=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future.cancelled and .cancel qualnames — extra160
#
# concurrent.futures.Future.cancelled.__qualname__.__eq__('Future.cancelled') == True
# concurrent.futures.Future.cancel.__qualname__.__eq__('Future.cancel')       == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra160.cf_future_cancelled_cancel_qualnames:
  description: "concurrent.futures.Future.cancelled and cancel method qualname checks in cffutcc160 namespace — Future.cancelled.__qualname__=='Future.cancelled' (len=16: 'Future'=6+'.'=1+'cancelled'=9=16; 'cancelled'='cancel'=6+'led'=3=9; cancelled() returns True if the Future was successfully cancelled by cancel()); Future.cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13; cancel() attempts to cancel the Future; if the call is still pending or running it can be cancelled; returns True if the Future was successfully cancelled); 'cancelled' (len=9) = 'cancel' (len=6) + 'led' (len=3); so cancelled qualname(16) = cancel qualname(13) + 3 (the 'led' suffix adds 3 chars); qualname length ordering: done(11) < cancel(13) < running(14) < cancelled(16); cancelled is the longest qualname in this spec because 'cancelled'=9 is the longest method name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutcc160

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_qn_eq,   concurrent.futures.Future.cancelled.__qualname__.__eq__,  ["Future.cancelled"],  true,  "Future.cancelled.__qualname__ == 'Future.cancelled' (len=16; 'cancelled'=9; longest qualname in spec); verified with Python 3.14.3"]
    - [cancel_qn_eq,      concurrent.futures.Future.cancel.__qualname__.__eq__,     ["Future.cancel"],     true,  "Future.cancel.__qualname__ == 'Future.cancel' (len=13; 'cancel'=6; shorter than cancelled by 3); verified with Python 3.14.3"]
    - [cancelled_qn_len,  concurrent.futures.Future.cancelled.__qualname__.__len__, [],                    16,    "Future.cancelled.__qualname__.__len__() == 16 ('Future.cancelled'; cancelled=cancel+led; 3 longer than cancel=13); verified with Python 3.14.3"]
    - [cancel_qn_len,     concurrent.futures.Future.cancel.__qualname__.__len__,    [],                    13,    "Future.cancel.__qualname__.__len__() == 13 ('Future.cancel'; 2 longer than done=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Cross-comparison of all four method qualname lengths — extra160
#
# done(11) < cancel(13) < running(14) < cancelled(16)
# ---------------------------------------------------------------------------

table concurrent_futures_extra160.cf_future_state_qualname_comparison:
  description: "concurrent.futures.Future state-query method qualname length cross-comparison in cffutstqn160 namespace — the four state-query methods form a qualname length ordering: done(11) < cancel(13) < running(14) < cancelled(16); method name lengths: done(4) < cancel(6) < running(7) < cancelled(9); all share 'Future.'=7 prefix (6+1=7); done qualname(11) is the shortest because 'done'=4 is the shortest method name; cancelled qualname(16) is the longest because 'cancelled'=9 is the longest method name; cancel-to-cancelled difference: 3 chars (the 'led' suffix); running-to-cancelled difference: 2 chars ('cancelled'=9 > 'running'=7 by 2); compare with extra159 result/exception setter qualnames: result(13) < exception(16) < set_result(17) < set_exception(20) — the setter methods (extra159) have longer qualnames than the state-query methods (extra160); note: concurrent.futures.Future is concurrent.futures._base.Future (same object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutstqn160

  columns: [id, function, args, expected, description]
  rows:
    - [done_len,      concurrent.futures.Future.done.__qualname__.__len__,      [],  11,  "Future.done qualname len==11 (shortest state-query qualname; 'done'=4); verified with Python 3.14.3"]
    - [cancel_len,    concurrent.futures.Future.cancel.__qualname__.__len__,    [],  13,  "Future.cancel qualname len==13 (2 longer than done=11; 'cancel'=6); verified with Python 3.14.3"]
    - [running_len,   concurrent.futures.Future.running.__qualname__.__len__,   [],  14,  "Future.running qualname len==14 (1 longer than cancel=13; 'running'=7); verified with Python 3.14.3"]
    - [cancelled_len, concurrent.futures.Future.cancelled.__qualname__.__len__, [],  16,  "Future.cancelled qualname len==16 (longest; 'cancelled'=9=='cancel'=6+'led'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra160
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra160.cf_Future_done_qualname_eq:
  description: "concurrent.futures.Future.done.__qualname__.__eq__('Future.done') returns True — Future.done is defined directly on Future (in Future.__dict__); done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11); done() returns True if the Future was successfully cancelled or finished running — it is the general 'is this Future no longer pending or running?' query; done() returning True means the Future has reached a terminal state (either finished with result/exception, or cancelled); 'done'=4 is the shortest method name in this spec; done qualname(11) is the shortest among done(11) < cancel(13) < running(14) < cancelled(16); compare extra159 qualnames: result(13) < exception(16) < set_result(17) < set_exception(20) — the getter/setter methods have longer qualnames than done(11); NEW in extra160: first standalone concurrent.futures.Future.done.__qualname__ identity invariant in cffutdr160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

invariant concurrent_futures_extra160.cf_Future_running_qualname_eq:
  description: "concurrent.futures.Future.running.__qualname__.__eq__('Future.running') returns True — Future.running is defined directly on Future; running.__qualname__=='Future.running' (len=14: 'Future'=6+'.'=1+'running'=7=14); running() returns True if the Future is currently executing in an executor thread or process and cannot be cancelled; after a Future transitions from pending to running (when the executor picks it up), cancel() can no longer cancel it; 'running'=7 is 3 chars longer than 'done'=4 explaining the 3-char qualname difference: running(14) vs done(11); compare: 'running'=7 > 'cancel'=6 by 1 char explaining running(14) > cancel(13) by 1; qualname length ordering: done(11) < cancel(13) < running(14) < cancelled(16); NEW in extra160: first standalone concurrent.futures.Future.running.__qualname__ identity invariant in cffutdr160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.running.__qualname__.__eq__
  args: ["Future.running"]
  expected: true

invariant concurrent_futures_extra160.cf_Future_cancelled_qualname_eq:
  description: "concurrent.futures.Future.cancelled.__qualname__.__eq__('Future.cancelled') returns True — Future.cancelled is defined directly on Future; cancelled.__qualname__=='Future.cancelled' (len=16: 'Future'=6+'.'=1+'cancelled'=9=16; 'cancelled'='cancel'=6+'led'=3=9); cancelled() returns True if the Future was successfully cancelled via cancel(); 'cancelled' (len=9) is the longest method name in this spec and 'Future.cancelled' (len=16) is the longest qualname; compare: cancel.__qualname__=='Future.cancel' (len=13; the 'cancel' action method is 3 chars shorter: 'cancel'=6 vs 'cancelled'=9); the suffix 'led' (3 chars) distinguishes the state-query method 'cancelled' from the action method 'cancel'; cancelled qualname(16) = cancel qualname(13) + 3 (the 'led' suffix); NEW in extra160: first standalone concurrent.futures.Future.cancelled.__qualname__ identity invariant in cffutcc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.cancelled.__qualname__.__eq__
  args: ["Future.cancelled"]
  expected: true

invariant concurrent_futures_extra160.cf_Future_cancel_qualname_eq:
  description: "concurrent.futures.Future.cancel.__qualname__.__eq__('Future.cancel') returns True — Future.cancel is defined directly on Future; cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13); cancel() attempts to cancel the Future; if the Future is currently pending (not yet running), cancel() succeeds and the Future transitions to the cancelled state; if the Future is already running, cancel() may fail and return False; cancel() returns True if the Future was successfully cancelled; compare: cancelled.__qualname__=='Future.cancelled' (len=16; the state-query 'cancelled' method is 3 chars longer than the action 'cancel' method); qualname ordering in spec: done(11) < cancel(13) < running(14) < cancelled(16); NEW in extra160: first standalone concurrent.futures.Future.cancel.__qualname__ identity invariant in cffutcc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true
