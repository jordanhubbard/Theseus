spec: calendar_extra14
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra3.zspec.zsdl — covers __qualname__ for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/isleap/monthrange/weekday; MONDAY/SUNDAY class base; isleap.__module__ and Calendar.__module__"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__"
    - "calendar_extra9.zspec.zsdl — covers TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__; setfirstweekday/__name__; firstweekday/__name__"
    - "calendar_extra13.zspec.zsdl — covers LocaleTextCalendar/__qualname__; LocaleHTMLCalendar/__qualname__; isleap/__qualname__; month/__qualname__; calendar/__qualname__"
  notes:
    - "This spec extends calendar.zspec.zsdl and prior extras through calendar_extra13.zspec.zsdl."
    - "NEW in extra14 — Axis 1: __qualname__ for leapdays and timegm — flat qualnames not yet anchored as standalone invariants."
    - "NEW in extra14 — Axis 2: __qualname__ for setfirstweekday — flat qualname; distinct from firstweekday whose __qualname__ is dotted."
    - "NEW in extra14 — Axis 3: __qualname__ for firstweekday and monthcalendar — both are bound methods with dotted qualnames."
    - "NEW in extra14 — Axis 4: __qualname__ for prmonth and prcal — bound methods of the default TextCalendar instance."
    - "calendar.leapdays.__qualname__ == 'leapdays' — verified Python 3.12."
    - "calendar.timegm.__qualname__ == 'timegm' — verified Python 3.12."
    - "calendar.setfirstweekday.__qualname__ == 'setfirstweekday' — verified Python 3.12."
    - "calendar.firstweekday.__qualname__ == 'Calendar.getfirstweekday' — module-level 'firstweekday' is a bound method of the default Calendar instance."
    - "calendar.monthcalendar.__qualname__ == 'Calendar.monthdayscalendar' — module-level 'monthcalendar' is a bound method of the default Calendar instance."
    - "calendar.prmonth.__qualname__ == 'TextCalendar.prmonth' — module-level 'prmonth' is a bound method of the default TextCalendar instance."
    - "calendar.prcal.__qualname__ == 'TextCalendar.pryear' — module-level 'prcal' is a bound method of the default TextCalendar instance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# leapdays and timegm __qualname__ — standalone extra14-namespace invariants
#
# calendar_extra7 covers leapdays/__module__ and timegm/__module__. No prior
# spec checks their __qualname__. Both are flat module-level functions whose
# qualname equals their name.
# ---------------------------------------------------------------------------

invariant calendar_extra14.leapdays.qualname:
  description: "calendar.leapdays.__qualname__ == 'leapdays' — flat qualname for module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: leapdays.__qualname__.__eq__
  args: ["leapdays"]
  expected: true

invariant calendar_extra14.timegm.qualname:
  description: "calendar.timegm.__qualname__ == 'timegm' — flat qualname for module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: timegm.__qualname__.__eq__
  args: ["timegm"]
  expected: true

# ---------------------------------------------------------------------------
# setfirstweekday __qualname__
#
# calendar_extra9 covers setfirstweekday/__name__. No prior spec checks its
# __qualname__, which is also flat ('setfirstweekday').
# ---------------------------------------------------------------------------

invariant calendar_extra14.setfirstweekday.qualname:
  description: "calendar.setfirstweekday.__qualname__ == 'setfirstweekday' — flat qualname for module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: setfirstweekday.__qualname__.__eq__
  args: ["setfirstweekday"]
  expected: true

# ---------------------------------------------------------------------------
# firstweekday and monthcalendar — bound method __qualname__ values
#
# The module-level name 'firstweekday' is bound to the getfirstweekday method
# of the default Calendar instance, so its __qualname__ is 'Calendar.getfirstweekday'.
# Similarly, 'monthcalendar' is bound to monthdayscalendar, giving
# 'Calendar.monthdayscalendar'. No prior spec checks these __qualname__ values.
# ---------------------------------------------------------------------------

invariant calendar_extra14.firstweekday.qualname:
  description: "calendar.firstweekday.__qualname__ == 'Calendar.getfirstweekday' — module-level alias is a bound method"
  category: function_qualnames
  kind: python_call_eq
  function: firstweekday.__qualname__.__eq__
  args: ["Calendar.getfirstweekday"]
  expected: true

invariant calendar_extra14.monthcalendar.qualname:
  description: "calendar.monthcalendar.__qualname__ == 'Calendar.monthdayscalendar' — module-level alias is a bound method"
  category: function_qualnames
  kind: python_call_eq
  function: monthcalendar.__qualname__.__eq__
  args: ["Calendar.monthdayscalendar"]
  expected: true

# ---------------------------------------------------------------------------
# prmonth and prcal — bound method __qualname__ values
#
# The module-level names 'prmonth' and 'prcal' are bound to methods on the
# default TextCalendar instance created at import time. Their __qualname__
# values are 'TextCalendar.prmonth' and 'TextCalendar.pryear' respectively.
# No prior spec checks these __qualname__ values.
# ---------------------------------------------------------------------------

invariant calendar_extra14.prmonth.qualname:
  description: "calendar.prmonth.__qualname__ == 'TextCalendar.prmonth' — module-level alias is a bound method"
  category: function_qualnames
  kind: python_call_eq
  function: prmonth.__qualname__.__eq__
  args: ["TextCalendar.prmonth"]
  expected: true

invariant calendar_extra14.prcal.qualname:
  description: "calendar.prcal.__qualname__ == 'TextCalendar.pryear' — module-level alias is a bound method"
  category: function_qualnames
  kind: python_call_eq
  function: prcal.__qualname__.__eq__
  args: ["TextCalendar.pryear"]
  expected: true
