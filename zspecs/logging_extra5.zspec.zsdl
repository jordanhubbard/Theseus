spec: logging_extra5
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends prior logging specs."
    - "Focus: Logger class attributes, Formatter class, Handler class names."
    - "logging.DEBUG == 10; logging.INFO == 20; logging.WARNING == 30; logging.ERROR == 40; logging.CRITICAL == 50."
    - "logging.NOTSET == 0."
    - "logging.Logger.__name__ == 'Logger'."
    - "logging.Handler.__name__ == 'Handler'."
    - "logging.Formatter.__name__ == 'Formatter'."
    - "logging.Filter.__name__ == 'Filter'."
    - "logging.LogRecord.__name__ == 'LogRecord'."
    - "logging.StreamHandler.__name__ == 'StreamHandler'."
    - "logging.FileHandler.__name__ == 'FileHandler'."
    - "logging.NullHandler.__name__ == 'NullHandler'."
    - "logging.getLogger.__name__ == 'getLogger'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table logging_extra5.level_constants:
  kind: python_call_eq
  category: constants
  id_prefix: level

  columns: [id, function, args, expected]
  rows:
    - [NOTSET,    NOTSET.__eq__,    [0],  true]
    - [DEBUG,     DEBUG.__eq__,     [10], true]
    - [INFO,      INFO.__eq__,      [20], true]
    - [WARNING,   WARNING.__eq__,   [30], true]
    - [ERROR,     ERROR.__eq__,     [40], true]
    - [CRITICAL,  CRITICAL.__eq__,  [50], true]

table logging_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Logger,        Logger.__name__.__eq__,        ["Logger"],        true]
    - [Handler,       Handler.__name__.__eq__,       ["Handler"],       true]
    - [Formatter,     Formatter.__name__.__eq__,     ["Formatter"],     true]
    - [Filter,        Filter.__name__.__eq__,        ["Filter"],        true]
    - [LogRecord,     LogRecord.__name__.__eq__,     ["LogRecord"],     true]
    - [StreamHandler, StreamHandler.__name__.__eq__, ["StreamHandler"], true]
    - [FileHandler,   FileHandler.__name__.__eq__,   ["FileHandler"],   true]
    - [NullHandler,   NullHandler.__name__.__eq__,   ["NullHandler"],   true]

invariant logging_extra5.Logger.module:
  description: "logging.Logger.__module__ == 'logging'"
  category: module
  kind: python_call_eq
  function: Logger.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra5.Handler.module:
  description: "logging.Handler.__module__ == 'logging'"
  category: module
  kind: python_call_eq
  function: Handler.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra5.Formatter.module:
  description: "logging.Formatter.__module__ == 'logging'"
  category: module
  kind: python_call_eq
  function: Formatter.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra5.getLogger.name:
  description: "logging.getLogger.__name__ == 'getLogger'"
  category: function_names
  kind: python_call_eq
  function: getLogger.__name__.__eq__
  args: ["getLogger"]
  expected: true

invariant logging_extra5.getLevelName.name:
  description: "logging.getLevelName.__name__ == 'getLevelName'"
  category: function_names
  kind: python_call_eq
  function: getLevelName.__name__.__eq__
  args: ["getLevelName"]
  expected: true

invariant logging_extra5.getLevelName.debug:
  description: "logging.getLevelName(10) == 'DEBUG'"
  category: getLevelName
  kind: python_call_eq
  function: getLevelName
  args: [10]
  expected: "DEBUG"

invariant logging_extra5.getLevelName.info:
  description: "logging.getLevelName(20) == 'INFO'"
  category: getLevelName
  kind: python_call_eq
  function: getLevelName
  args: [20]
  expected: "INFO"
