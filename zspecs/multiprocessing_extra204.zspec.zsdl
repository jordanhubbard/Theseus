spec: multiprocessing_extra204
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers multiprocessing exception class identity."
    - "All four exception classes (ProcessError, BufferTooShort, TimeoutError, AuthenticationError) are defined in multiprocessing.context."
    - "ProcessError inherits from Exception — it is the root of the multiprocessing exception hierarchy."
    - "BufferTooShort, TimeoutError, and AuthenticationError all inherit from ProcessError."
    - "None of the four exception classes have a non-None __doc__ string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing exception class __name__ string equality — extra204 namespace
#
# ProcessError is the base of the multiprocessing exception hierarchy.
# BufferTooShort, TimeoutError, and AuthenticationError are leaf exceptions
# under ProcessError.
# ---------------------------------------------------------------------------

table multiprocessing_extra204.exception_names:
  description: "multiprocessing exception class __name__ string equality in extra204 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcname204

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError_name,       ProcessError.__name__.__eq__,       ["ProcessError"],       true, "multiprocessing.ProcessError.__name__ == 'ProcessError'"]
    - [BufferTooShort_name,     BufferTooShort.__name__.__eq__,     ["BufferTooShort"],     true, "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'"]
    - [TimeoutError_name,       TimeoutError.__name__.__eq__,       ["TimeoutError"],       true, "multiprocessing.TimeoutError.__name__ == 'TimeoutError'"]
    - [AuthenticationError_name, AuthenticationError.__name__.__eq__, ["AuthenticationError"], true, "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'"]

# ---------------------------------------------------------------------------
# multiprocessing exception class __module__ string equality — extra204
#
# All four exceptions are defined in multiprocessing.context — the module
# that bootstraps the multiprocessing exception classes for each start method
# context. The __module__ is 'multiprocessing.context' for all of them.
# ---------------------------------------------------------------------------

table multiprocessing_extra204.exception_modules:
  description: "multiprocessing exception class __module__ string equality in extra204 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcmod204

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError_module,        ProcessError.__module__.__eq__,        ["multiprocessing.context"], true, "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'"]
    - [BufferTooShort_module,      BufferTooShort.__module__.__eq__,      ["multiprocessing.context"], true, "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context'"]
    - [TimeoutError_module,        TimeoutError.__module__.__eq__,        ["multiprocessing.context"], true, "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'"]
    - [AuthenticationError_module, AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'"]

# ---------------------------------------------------------------------------
# multiprocessing exception class base class __name__ — extra204 namespace
#
# ProcessError inherits directly from Exception (root of mp exception tree).
# BufferTooShort, TimeoutError, and AuthenticationError all inherit from
# ProcessError. Note: multiprocessing.TimeoutError is distinct from the
# built-in TimeoutError — it derives from ProcessError, not OSError.
# ---------------------------------------------------------------------------

table multiprocessing_extra204.exception_bases:
  description: "multiprocessing exception class __bases__[0].__name__ string equality in extra204 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcbase204

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError_base,        "ProcessError.__bases__[0].__name__.__eq__",        ["Exception"],    true, "multiprocessing.ProcessError inherits from Exception — root of mp exception hierarchy"]
    - [BufferTooShort_base,      "BufferTooShort.__bases__[0].__name__.__eq__",      ["ProcessError"], true, "multiprocessing.BufferTooShort inherits from ProcessError"]
    - [TimeoutError_base,        "TimeoutError.__bases__[0].__name__.__eq__",        ["ProcessError"], true, "multiprocessing.TimeoutError inherits from ProcessError (not from built-in OSError)"]
    - [AuthenticationError_base, "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "multiprocessing.AuthenticationError inherits from ProcessError"]

# ---------------------------------------------------------------------------
# multiprocessing exception __doc__ is None — extra204 namespace
#
# None of the four exception classes have a docstring. __doc__ is None for
# all of them. This is verified via the __doc__.__class__.__name__ attribute
# which would be 'NoneType' for a None value.
# ---------------------------------------------------------------------------

table multiprocessing_extra204.exception_doc_none:
  description: "multiprocessing exception class __doc__ is None — __doc__.__class__.__name__ == 'NoneType' in extra204 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcdoc204

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError_doc,        ProcessError.__doc__.__class__.__name__.__eq__,        ["NoneType"], true, "multiprocessing.ProcessError.__doc__ is None — no docstring defined"]
    - [BufferTooShort_doc,      BufferTooShort.__doc__.__class__.__name__.__eq__,      ["NoneType"], true, "multiprocessing.BufferTooShort.__doc__ is None — no docstring defined"]
    - [TimeoutError_doc,        TimeoutError.__doc__.__class__.__name__.__eq__,        ["NoneType"], true, "multiprocessing.TimeoutError.__doc__ is None — no docstring defined"]
    - [AuthenticationError_doc, AuthenticationError.__doc__.__class__.__name__.__eq__, ["NoneType"], true, "multiprocessing.AuthenticationError.__doc__ is None — no docstring defined"]

# ---------------------------------------------------------------------------
# multiprocessing.TimeoutError is distinct from builtins.TimeoutError — extra204
#
# multiprocessing defines its own TimeoutError that inherits from ProcessError,
# not from OSError. This distinguishes it from the built-in TimeoutError alias
# used by asyncio and concurrent.futures. The __module__ confirms this is the
# multiprocessing-specific version.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra204.TimeoutError_module_eq:
  description: "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context' — distinct from builtins.TimeoutError (which has module 'builtins')"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra204.ProcessError_base_module_eq:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is the root of the multiprocessing exception hierarchy, inheriting from the built-in Exception"
  category: identity
  kind: python_call_eq
  function: ProcessError.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true
