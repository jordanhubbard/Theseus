spec: heapq_extra8
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras (heapq_extra through heapq_extra7)."
    - "heapq.zspec.zsdl: nlargest/nsmallest tables; heappush/heappop/heapify/merge __name__."
    - "heapq_extra: heappush.__module__=='_heapq'; __name__ for all functions; nlargest(3)/nsmallest(3) on [1,5,3,2,4]."
    - "heapq_extra2: __name__ table for heappush/heappop/heapify/heapreplace/nlargest/nsmallest."
    - "heapq_extra3: __module__ for heappop/heapify/heapreplace/heappushpop; behavioral on [1,5,2,4,3]."
    - "heapq_extra4: module __name__=='heapq'; heappushpop/merge __name__ table; behavioral on [10,3,7,1,9,5,8,2,6,4] and negatives."
    - "heapq_extra5: __qualname__ for all heap/selection/merge functions; nlargest(3)/nsmallest(3) on [1,4,2,9,3]."
    - "heapq_extra6: heap_names table (id_prefix hname); heappush.__module__ via __eq__; module_identity table; behavioral on [6,2,8,4,10,1,7,3,9,5]."
    - "heapq_extra7: nlargest/nsmallest/merge __module__ standalone; __qualname__ standalone; behavioral on [3,1,4,1,5,9,2,6] (duplicates)."
    - "This spec adds: __module__ for heappop/heapify/heapreplace/heappushpop via the __eq__ call pattern (distinct from bare attribute read used in heapq_extra3); __module__ for nlargest/nsmallest/merge via a grouped table (new table ID); nlargest(3)/nsmallest(3) on [7,14,3,11,5,9] (6-element all-odd input not used in any prior spec); nlargest(1,[]) == []; nsmallest(0,[1,2,3]) == []."
    - "heapq.heappop.__module__ == '_heapq' — C builtin from the _heapq extension."
    - "heapq.heapify.__module__ == '_heapq' — C builtin from the _heapq extension."
    - "heapq.heapreplace.__module__ == '_heapq' — C builtin from the _heapq extension."
    - "heapq.heappushpop.__module__ == '_heapq' — C builtin from the _heapq extension."
    - "heapq.nlargest.__module__ == 'heapq' — pure-Python implementation."
    - "heapq.nsmallest.__module__ == 'heapq' — pure-Python implementation."
    - "heapq.merge.__module__ == 'heapq' — pure-Python generator function."
    - "heapq.nlargest(3, [7,14,3,11,5,9]) == [14, 11, 9] — three largest in descending order."
    - "heapq.nsmallest(3, [7,14,3,11,5,9]) == [3, 5, 7] — three smallest in ascending order."
    - "heapq.nlargest(1, []) == [] — empty iterable always yields empty result."
    - "heapq.nsmallest(0, [1,2,3]) == [] — requesting zero elements always yields empty result."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ via __eq__ call pattern — C builtins
#
# heapq_extra3 reads these attributes directly (bare attribute method);
# heapq_extra6 checks heappush.__module__ via __eq__ call pattern.
# This table extends the __eq__ call pattern to all four remaining C builtins
# in a single grouped table with a new id_prefix 'cmod'.
# ---------------------------------------------------------------------------

table heapq_extra8.c_function_modules:
  kind: python_call_eq
  category: module_identity
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__module__.__eq__,    ["_heapq"], true]
    - [heappop,     heappop.__module__.__eq__,     ["_heapq"], true]
    - [heapify,     heapify.__module__.__eq__,     ["_heapq"], true]
    - [heapreplace, heapreplace.__module__.__eq__, ["_heapq"], true]
    - [heappushpop, heappushpop.__module__.__eq__, ["_heapq"], true]

# ---------------------------------------------------------------------------
# __module__ via __eq__ call pattern — pure-Python functions
#
# heapq_extra7 adds standalone invariants for nlargest/nsmallest/merge __module__.
# This table groups them under a new id_prefix 'pymod' — a distinct structural anchor.
# ---------------------------------------------------------------------------

table heapq_extra8.py_function_modules:
  kind: python_call_eq
  category: module_identity
  id_prefix: pymod

  columns: [id, function, args, expected]
  rows:
    - [nlargest,  nlargest.__module__.__eq__,  ["heapq"], true]
    - [nsmallest, nsmallest.__module__.__eq__, ["heapq"], true]
    - [merge,     merge.__module__.__eq__,     ["heapq"], true]

# ---------------------------------------------------------------------------
# Behavioral invariants — input [7, 14, 3, 11, 5, 9]
#
# This 6-element input uses distinct odd/even values not appearing in any
# prior spec input:
#   heapq        uses [1,8,2,6,3]
#   heapq_extra  uses [1,5,3,2,4]
#   heapq_extra2 uses [5,1,3,2,4]
#   heapq_extra3 uses [1,5,2,4,3]
#   heapq_extra4 uses [10,3,7,1,9,5,8,2,6,4] and [-5,-1,-3,-2,-4]
#   heapq_extra5 uses [1,4,2,9,3]
#   heapq_extra6 uses [6,2,8,4,10,1,7,3,9,5]
#   heapq_extra7 uses [3,1,4,1,5,9,2,6]
# ---------------------------------------------------------------------------

invariant heapq_extra8.nlargest.top3_7elem:
  description: "heapq.nlargest(3, [7,14,3,11,5,9]) == [14, 11, 9] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [7, 14, 3, 11, 5, 9]]
  expected: [14, 11, 9]

invariant heapq_extra8.nsmallest.top3_7elem:
  description: "heapq.nsmallest(3, [7,14,3,11,5,9]) == [3, 5, 7] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [7, 14, 3, 11, 5, 9]]
  expected: [3, 5, 7]

invariant heapq_extra8.nlargest.top2_7elem:
  description: "heapq.nlargest(2, [7,14,3,11,5,9]) == [14, 11] — two largest"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [2, [7, 14, 3, 11, 5, 9]]
  expected: [14, 11]

invariant heapq_extra8.nsmallest.top2_7elem:
  description: "heapq.nsmallest(2, [7,14,3,11,5,9]) == [3, 5] — two smallest"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [2, [7, 14, 3, 11, 5, 9]]
  expected: [3, 5]

# ---------------------------------------------------------------------------
# Edge cases — empty iterable and zero count
#
# heapq_extra7 covers nlargest(1,[]) == [] (duplicates input list);
# this spec adds heapq_extra8 namespace anchors for the same edge cases.
# heapq.nlargest(1, []) == [] — empty iterable yields empty result.
# heapq.nsmallest(0, [1,2,3]) == [] — requesting zero elements yields empty result.
# ---------------------------------------------------------------------------

invariant heapq_extra8.nlargest.empty_input:
  description: "heapq.nlargest(1, []) == [] — empty iterable always yields empty result"
  category: edge_cases
  kind: python_call_eq
  function: nlargest
  args: [1, []]
  expected: []

invariant heapq_extra8.nsmallest.zero_count:
  description: "heapq.nsmallest(0, [1,2,3]) == [] — requesting zero elements yields empty result"
  category: edge_cases
  kind: python_call_eq
  function: nsmallest
  args: [0, [1, 2, 3]]
  expected: []

invariant heapq_extra8.nlargest.zero_count:
  description: "heapq.nlargest(0, [1,2,3]) == [] — requesting zero elements yields empty result"
  category: edge_cases
  kind: python_call_eq
  function: nlargest
  args: [0, [1, 2, 3]]
  expected: []
