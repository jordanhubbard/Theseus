docs: https://pytest-mock.readthedocs.io/

provenance:
  derived_from:
    - "https://pytest-mock.readthedocs.io/ — pytest-mock"
  notes:
    - "pytest-mock provides mock fixtures for pytest."
    - "pytest_mock.MockerFixture is a class."
    - "pytest_mock.MockFixture is a class."
    - "pytest_mock.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pytest_mock_rust.has_mocker_fixture:
  description: "pytest_mock.MockerFixture is a class"
  category: presence
  kind: python_call_eq
  function: pytest_mock_has_mocker_fixture
  args: []
  expected: true

invariant pytest_mock_rust.has_mock_fixture:
  description: "pytest_mock.MockFixture is a class"
  category: presence
  kind: python_call_eq
  function: pytest_mock_has_mock_fixture
  args: []
  expected: true

invariant pytest_mock_rust.version_nonempty:
  description: "pytest_mock.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pytest_mock_version_nonempty
  args: []
  expected: true

