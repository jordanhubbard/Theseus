spec: asyncio_extra2116
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-stream.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
    - "asyncio_extra.zspec.zsdl — covers __name__/__module__ checks and function name checks"
    - "asyncio_extra1366.zspec.zsdl — covers __flags__/__basicsize__/__itemsize__ C-type attributes"
  notes:
    - "Wave (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "These are the set/dict merge operators (|, &, ^) and their reflected/in-place variants."
    - "None of the asyncio classes (Task, Future, Event, Lock, Queue, Semaphore, Condition, StreamReader, BoundedSemaphore) define these operators in their own __dict__."
    - "These operators belong to dict and set builtins, not to asyncio synchronization or coroutine primitives."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2116.or_operator:
