spec: traceback_extra25
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback_extra24.zspec.zsdl."
    - "Prior specs covered: TracebackException/StackSummary/FrameSummary __module__.__len__()==9 and __name__.__len__(), method __qualname__.__len__() for TracebackException (from_exception=33, format=25, format_exception_only=40, __init__=27), StackSummary (extract=20, from_list=22), FrameSummary (__qualname__==12), module-level function __name__.__len__() for format_exception/format_stack/extract_tb/extract_stack/print_last/print_stack."
    - "This spec covers: __mro__.__len__() for TracebackException (2), StackSummary (3), FrameSummary (2); __bases__[0].__name__ and __bases__[0].__name__.__len__() for TracebackException ('object', 6), StackSummary ('list', 4), FrameSummary ('object', 6); FrameSummary.__init__.__qualname__.__len__()==21; FrameSummary.line property fget.__qualname__.__len__()==17; TracebackException.__init__.__qualname__.__len__()==27."
    - "traceback.TracebackException.__mro__.__len__() == 2 — mro is (TracebackException, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.__mro__.__len__() == 3 — mro is (StackSummary, list, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.__mro__.__len__() == 2 — mro is (FrameSummary, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.__bases__[0].__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.__init__.__qualname__ == 'FrameSummary.__init__' (len 21). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.line.fget.__qualname__ == 'FrameSummary.line' (len 17). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.__init__.__qualname__ == 'TracebackException.__init__' (len 27). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for TracebackException, StackSummary, FrameSummary
#
# No prior spec checks __mro__.__len__() for any traceback class.
# TracebackException inherits only from object: mro depth 2.
# StackSummary inherits from list: mro depth 3 (StackSummary, list, object).
# FrameSummary inherits only from object: mro depth 2.
# ---------------------------------------------------------------------------

invariant traceback_extra25.TracebackException.mro.len:
  description: "traceback.TracebackException.__mro__.__len__() == 2 — (TracebackException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: TracebackException.__mro__.__len__
  args: []
  expected: 2

invariant traceback_extra25.StackSummary.mro.len:
  description: "traceback.StackSummary.__mro__.__len__() == 3 — (StackSummary, list, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: StackSummary.__mro__.__len__
  args: []
  expected: 3

invariant traceback_extra25.FrameSummary.mro.len:
  description: "traceback.FrameSummary.__mro__.__len__() == 2 — (FrameSummary, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: FrameSummary.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for TracebackException, StackSummary, FrameSummary
#
# No prior spec checks __bases__[0].__name__ for any traceback class.
# TracebackException and FrameSummary both directly extend object.
# StackSummary extends list, making its base name 'list' (len 4).
# ---------------------------------------------------------------------------

invariant traceback_extra25.TracebackException.bases0.name.len:
  description: "traceback.TracebackException.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "TracebackException.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant traceback_extra25.StackSummary.bases0.name.len:
  description: "traceback.StackSummary.__bases__[0].__name__.__len__() == 4 — base is 'list'"
  category: class_hierarchy
  kind: python_call_eq
  function: "StackSummary.__bases__[0].__name__.__len__"
  args: []
  expected: 4

invariant traceback_extra25.FrameSummary.bases0.name.len:
  description: "traceback.FrameSummary.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "FrameSummary.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# FrameSummary method __qualname__.__len__() — __init__ and line property
#
# No prior spec covers FrameSummary.__init__.__qualname__.__len__() or the
# line property fget qualname length. FrameSummary.__init__ has qualname
# 'FrameSummary.__init__' (len 21). FrameSummary.line is a property whose
# fget qualname is 'FrameSummary.line' (len 17).
# ---------------------------------------------------------------------------

invariant traceback_extra25.FrameSummary.__init__.qualname.len:
  description: "traceback.FrameSummary.__init__.__qualname__.__len__() == 21 — 'FrameSummary.__init__' has 21 characters"
  category: string_length
  kind: python_call_eq
  function: FrameSummary.__init__.__qualname__.__len__
  args: []
  expected: 21

invariant traceback_extra25.FrameSummary.line.qualname.len:
  description: "traceback.FrameSummary.line.fget.__qualname__.__len__() == 17 — 'FrameSummary.line' has 17 characters"
  category: string_length
  kind: python_call_eq
  function: FrameSummary.line.fget.__qualname__.__len__
  args: []
  expected: 17

invariant traceback_extra25.TracebackException.__init__.qualname.len:
  description: "traceback.TracebackException.__init__.__qualname__.__len__() == 27 — 'TracebackException.__init__' has 27 characters"
  category: string_length
  kind: python_call_eq
  function: TracebackException.__init__.__qualname__.__len__
  args: []
  expected: 27

# ---------------------------------------------------------------------------
# Table: __mro__.__len__() and __bases__[0].__name__.__len__() for the three
# main traceback classes
#
# Groups MRO depth and direct-base name length into a single verifiable table.
# No prior spec groups these hierarchy measurements together.
# ---------------------------------------------------------------------------

table traceback_extra25.class_hierarchy_depths:
  description: "traceback class __mro__.__len__() — TracebackException (2), StackSummary (3), FrameSummary (2)"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected, description]
  rows:
    - [TE_mro_len,
       TracebackException.__mro__.__len__,
       [],
       2,
       "len(TracebackException.__mro__) == 2"]
    - [SS_mro_len,
       StackSummary.__mro__.__len__,
       [],
       3,
       "len(StackSummary.__mro__) == 3"]
    - [FS_mro_len,
       FrameSummary.__mro__.__len__,
       [],
       2,
       "len(FrameSummary.__mro__) == 2"]

# ---------------------------------------------------------------------------
# Table: __bases__[0].__name__.__len__() and FrameSummary method qualnames
#
# Groups direct-base name lengths and FrameSummary method qualname lengths.
# No prior spec groups these measurements together.
# ---------------------------------------------------------------------------

table traceback_extra25.bases_and_method_qualnames:
  description: "traceback class __bases__[0].__name__.__len__() and FrameSummary method qualname lengths"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected, description]
  rows:
    - [TE_bases0_name_len,
       "TracebackException.__bases__[0].__name__.__len__",
       [],
       6,
       "len('object') == 6 — TracebackException base"]
    - [SS_bases0_name_len,
       "StackSummary.__bases__[0].__name__.__len__",
       [],
       4,
       "len('list') == 4 — StackSummary base"]
    - [FS_bases0_name_len,
       "FrameSummary.__bases__[0].__name__.__len__",
       [],
       6,
       "len('object') == 6 — FrameSummary base"]
    - [FS_init_qualname_len,
       FrameSummary.__init__.__qualname__.__len__,
       [],
       21,
       "len('FrameSummary.__init__') == 21"]
    - [FS_line_qualname_len,
       FrameSummary.line.fget.__qualname__.__len__,
       [],
       17,
       "len('FrameSummary.line') == 17"]
    - [TE_init_qualname_len,
       TracebackException.__init__.__qualname__.__len__,
       [],
       27,
       "len('TracebackException.__init__') == 27"]
