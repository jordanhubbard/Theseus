spec: io_extra206
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers io module class __doc__.__class__.__name__ identity not covered by prior io_extra specs."
    - "io.IOBase.__doc__.__class__.__name__ == 'str'; the abstract base class for all I/O has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.__doc__.__class__.__name__ == 'str'; abstract base for raw binary I/O has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.BufferedIOBase.__doc__.__class__.__name__ == 'str'; abstract base for buffered binary I/O has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.TextIOBase.__doc__.__class__.__name__ == 'str'; abstract base for text I/O has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__doc__.__class__.__name__ == 'str'; raw binary file I/O class has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__doc__.__class__.__name__ == 'str'; buffered binary reader has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__doc__.__class__.__name__ == 'str'; in-memory text stream has a str docstring; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__doc__.__class__.__name__ == 'str'; in-memory binary stream has a str docstring; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io abstract base class __doc__.__class__.__name__ identity
# IOBase, RawIOBase, BufferedIOBase, TextIOBase — all 'str'
# ---------------------------------------------------------------------------

table io_extra206.abstract_base_doc_class_names:
  description: "io abstract base class __doc__.__class__.__name__: IOBase, RawIOBase, BufferedIOBase, TextIOBase — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iodocs206

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_doc_class_name,       io.IOBase.__doc__.__class__.__name__.__eq__,       ["str"], true, "io.IOBase.__doc__.__class__.__name__ == 'str'; IOBase is the abstract root of the io class hierarchy; its docstring is a str; confirmed Python 3.14.3 macOS"]
    - [rawiobase_doc_class_name,    io.RawIOBase.__doc__.__class__.__name__.__eq__,    ["str"], true, "io.RawIOBase.__doc__.__class__.__name__ == 'str'; abstract base for raw unbuffered binary I/O; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [bufferediobase_doc_class_name, io.BufferedIOBase.__doc__.__class__.__name__.__eq__, ["str"], true, "io.BufferedIOBase.__doc__.__class__.__name__ == 'str'; abstract base for buffered binary I/O; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [textiobase_doc_class_name,   io.TextIOBase.__doc__.__class__.__name__.__eq__,   ["str"], true, "io.TextIOBase.__doc__.__class__.__name__ == 'str'; abstract base for text-mode I/O; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [iobase_doc_class_name_len,   io.IOBase.__doc__.__class__.__name__.__len__,       [], 3, "io.IOBase.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

