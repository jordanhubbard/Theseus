#
# Wave 256 theme: asyncio.Condition class identity and method qualnames.
#
# asyncio.Condition.__name__              == 'Condition'             (len=9)
# asyncio.Condition.__module__            == 'asyncio.locks'
# asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'
# asyncio.Condition.__mro__.__len__()     == 4   [Condition, _ContextManagerMixin, _LoopBoundMixin, object]
# asyncio.Condition.__qualname__          == 'Condition'             (len=9)
# asyncio.Condition.__class__.__name__    == 'type'
# ---------------------------------------------------------------------------

table asyncio_extra128.asyncio_condition_class_identity:
  description: "asyncio.Condition class identity checks in asynciocondident128 namespace — wave 256 theme: asyncio.Condition is a pure-Python class defined in Lib/asyncio/locks.py; it shares the same class hierarchy structure as asyncio.Lock and asyncio.Semaphore (covered in extra127), both of which inherit from _ContextManagerMixin and _LoopBoundMixin; asyncio.Condition.__name__.__eq__('Condition')==True (len=9: 'Condition'=9, five more chars than Lock=4); asyncio.Condition.__module__.__eq__('asyncio.locks')==True (same module as Lock and Semaphore); asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (same direct base as Lock and Semaphore — _ContextManagerMixin provides __aenter__ and __aexit__); asyncio.Condition.__mro__.__len__()==4 (MRO=[Condition, _ContextManagerMixin, _LoopBoundMixin, object]; same 4-element structure as Lock and Semaphore); asyncio.Condition.__mro__[1].__name__.__eq__('_ContextManagerMixin')==True; asyncio.Condition.__mro__[2].__name__.__eq__('_LoopBoundMixin')==True; asyncio.Condition.__qualname__.__eq__('Condition')==True (len=9, module-level class so qualname equals name); asyncio.Condition.__class__.__name__.__eq__('type')==True (regular class, metaclass is type); verified with Python 3.14.3"
