invariant asyncio_extra128.Condition_module_is_asyncio_locks:
  description: "asyncio.Condition.__module__.__eq__('asyncio.locks') returns True — asyncio.Condition is a pure-Python class defined in Lib/asyncio/locks.py; its __module__ is 'asyncio.locks', the same as asyncio.Lock and asyncio.Semaphore (covered in extra127); Condition.__bases__[0].__name__ is '_ContextManagerMixin' (same direct base as Lock and Semaphore); Condition.__mro__.__len__() is 4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); the 4-element MRO is identical in structure to Lock and Semaphore, confirming Condition is built from the same mixin pattern in Lib/asyncio/locks.py; unlike asyncio.Task and asyncio.Future whose __module__ is '_asyncio' (C extension), Condition.__module__ is 'asyncio.locks' (pure-Python); NEW in extra128: first standalone Condition module invariant in asynciocondident128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra128.Condition_mro_len_is_4:
  description: "asyncio.Condition.__mro__.__len__() == 4 — asyncio.Condition.__mro__ is [Condition, _ContextManagerMixin, _LoopBoundMixin, object]; this 4-element MRO is identical in structure to asyncio.Lock.__mro__ (also len=4) and asyncio.Semaphore.__mro__ (also len=4), confirming all three synchronization primitives share the same class hierarchy; the two mixin classes are: _ContextManagerMixin (provides async context manager protocol via __aenter__ and __aexit__) and _LoopBoundMixin (binds the object to the running event loop); Condition.__bases__[0].__name__ is '_ContextManagerMixin'; Condition.__mro__[2].__name__ is '_LoopBoundMixin'; NEW in extra128: first standalone Condition MRO length invariant in asynciocondident128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra128.Condition_notify_all_qualname_len_20:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — asyncio.Condition.notify_all.__qualname__ is 'Condition.notify_all' (20 chars: 'Condition.'=10 + 'notify_all'=10 = 20); this is the longest method qualname in this spec; compare qualname lengths: wait=14, notify=16, wait_for=18, __init__=18 (tied), notify_all=20 (longest); asyncio.Condition.notify_all.__code__.co_argcount is 1 (self only; it wakes all waiting coroutines by calling notify with no limit); unlike notify (co_argcount=2, self+n), notify_all takes no count parameter; asyncio.Condition.notify_all.__code__.co_varnames[0] is 'self'; the compound name 'notify_all' contributes 10 chars (same as the 'Condition.' prefix itself); NEW in extra128: first standalone Condition.notify_all qualname length invariant in asynciocondident128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra128.Condition_notify_argcount_2:
  description: "asyncio.Condition.notify.__code__.co_argcount == 2 — asyncio.Condition.notify is defined as 'def notify(self, n=1)'; co_argcount counts positional parameters giving 2 (self and n); n is the number of waiting coroutines to wake (default 1); notify.__code__.co_varnames[0] is 'self' and co_varnames[1] is 'n' (a single-char parameter name); this contrasts with notify_all whose co_argcount is 1 (self only — it wakes all waiters regardless of count); asyncio.Condition.notify.__qualname__ is 'Condition.notify' (len=16: 'Condition.'=10+'notify'=6=16); NEW in extra128: first standalone Condition.notify co_argcount invariant in asynciocondident128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.notify.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra128.Condition_wait_qualname_len_14:
  description: "asyncio.Condition.wait.__qualname__.__len__() == 14 — asyncio.Condition.wait.__qualname__ is 'Condition.wait' (14 chars: 'Condition.'=10 + 'wait'=4 = 14); this is the shortest method qualname in this spec; compare qualname lengths: wait=14 (shortest), notify=16, wait_for=18 (tied), __init__=18 (tied), notify_all=20 (longest); asyncio.Condition.wait.__code__.co_argcount is 1 (self only; it suspends the current coroutine and waits for notification); the 4-char suffix 'wait' is the shortest method name in the spec; asyncio.Condition.wait.__code__.co_varnames[0] is 'self'; asyncio.Condition.wait is an async coroutine that releases the underlying lock, suspends, then re-acquires the lock upon notification; NEW in extra128: first standalone Condition.wait qualname length invariant in asynciocondident128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
