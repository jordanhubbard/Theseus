spec: pathlib_extra210
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra209.zspec.zsdl — covers pathlib.__spec__ deeper attributes"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, Path.__module__, PurePosixPath component access"
  notes:
    - "pathlib.Path.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__mro__.__len__() == 3; MRO is [Path, PurePath, object]; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__mro__[0].__name__ == 'Path'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__mro__[1].__name__ == 'PurePath'; Path directly inherits from PurePath; confirmed Python 3.14.3 macOS."
    - "Index access on __mro__ uses bracket notation — function paths containing '[' must be double-quoted."
    - "pathlib.Path.__mro__.__getitem__(0).__name__ == 'Path' — equivalently testable via __getitem__."
    - "pathlib.Path.__mro__.__getitem__(1).__name__ == 'PurePath' — confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path.__mro__ type identity and length
# __class__.__name__ == 'tuple', __len__() == 3
# ---------------------------------------------------------------------------

table pathlib_extra210.mro_type_and_len:
  description: "pathlib.Path.__mro__ type identity and length"
  kind: python_call_eq
  category: mro_identity
  id_prefix: pathlibpath210

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,  Path.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "pathlib.Path.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [class_name_len, Path.__mro__.__class__.__name__.__len__,  [],        5,     "pathlib.Path.__mro__.__class__.__name__.__len__() == 5; 'tuple' has t(1)u(2)p(3)l(4)e(5); confirmed Python 3.14.3 macOS"]
    - [len_eq,         Path.__mro__.__len__,                    [],        3,     "pathlib.Path.__mro__.__len__() == 3; MRO is [Path, PurePath, object]; confirmed Python 3.14.3 macOS"]
    - [len_gt_two,     Path.__mro__.__len__,                    [],        3,     "pathlib.Path.__mro__.__len__() == 3; Path has exactly two ancestors; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path.__mro__ element names via __getitem__
# MRO[0].__name__ == 'Path', MRO[1].__name__ == 'PurePath'
# ---------------------------------------------------------------------------

table pathlib_extra210.mro_element_names:
  description: "pathlib.Path.__mro__ element __name__ checks using double-quoted bracket notation"
  kind: python_call_eq
  category: mro_members
  id_prefix: pathlibpath210

  columns: [id, function, args, expected, description]
  rows:
    - [mro0_name_eq,    "Path.__mro__[0].__name__.__eq__",  ["Path"],     true,  "pathlib.Path.__mro__[0].__name__ == 'Path'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [mro1_name_eq,    "Path.__mro__[1].__name__.__eq__",  ["PurePath"], true,  "pathlib.Path.__mro__[1].__name__ == 'PurePath'; Path directly inherits from PurePath; confirmed Python 3.14.3 macOS"]
    - [mro_not_empty,   Path.__mro__.__len__,                [],           3,     "pathlib.Path.__mro__.__len__() == 3; MRO has exactly 3 entries; confirmed Python 3.14.3 macOS"]
    - [mro_class_tuple, Path.__mro__.__class__.__name__.__eq__, ["tuple"], true,  "pathlib.Path.__mro__.__class__.__name__ == 'tuple'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: MRO element names via double-quoted bracket notation
# Function paths with '[' must be double-quoted
# ---------------------------------------------------------------------------

table pathlib_extra210.mro_bracket_access:
  description: "pathlib.Path.__mro__ element name checks using double-quoted bracket notation"
  kind: python_call_eq
  category: mro_members
  id_prefix: pathlibpath210

  columns: [id, function, args, expected, description]
  rows:
    - [mro0_name_bracket_eq,   "Path.__mro__[0].__name__.__eq__",   ["Path"],     true,  "pathlib.Path.__mro__[0].__name__ == 'Path'; the class is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [mro1_name_bracket_eq,   "Path.__mro__[1].__name__.__eq__",   ["PurePath"], true,  "pathlib.Path.__mro__[1].__name__ == 'PurePath'; Path inherits directly from PurePath; confirmed Python 3.14.3 macOS"]
    - [mro0_name_bracket_len,  "Path.__mro__[0].__name__.__len__",  [],           4,     "pathlib.Path.__mro__[0].__name__.__len__() == 4; 'Path' has P(1)a(2)t(3)h(4); confirmed Python 3.14.3 macOS"]
    - [mro1_name_bracket_len,  "Path.__mro__[1].__name__.__len__",  [],           8,     "pathlib.Path.__mro__[1].__name__.__len__() == 8; 'PurePath' has P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra210.mro_class_name_eq:
  description: "pathlib.Path.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Path.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pathlib_extra210.mro_len_eq:
  description: "pathlib.Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra210.mro0_name_bracket_eq:
  description: "pathlib.Path.__mro__[0].__name__ == 'Path' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Path.__mro__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra210.mro1_name_bracket_eq:
  description: "pathlib.Path.__mro__[1].__name__ == 'PurePath' — Path directly inherits from PurePath; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Path.__mro__[1].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra210.mro0_name_bracket_len:
  description: "pathlib.Path.__mro__[0].__name__.__len__() == 4 — 'Path' has four characters; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Path.__mro__[0].__name__.__len__"
  args: []
  expected: 4

invariant pathlib_extra210.mro1_name_bracket_len:
  description: "pathlib.Path.__mro__[1].__name__.__len__() == 8 — 'PurePath' has eight characters; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Path.__mro__[1].__name__.__len__"
  args: []
  expected: 8

invariant pathlib_extra210.mro_getitem0_name:
  description: "pathlib.Path.__mro__.__getitem__(0).__name__ == 'Path' — equivalent to MRO[0].__name__; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: Path.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Path"

invariant pathlib_extra210.mro_getitem1_name:
  description: "pathlib.Path.__mro__.__getitem__(1).__name__ == 'PurePath' — equivalent to MRO[1].__name__; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: Path.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "PurePath"
