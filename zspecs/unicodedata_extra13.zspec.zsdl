spec: unicodedata_extra13
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and prior extras through unicodedata_extra12.zspec.zsdl."
    - "unicodedata_extra covers: __name__ value for all major functions; unidata_version.__class__.__name__; name('A'); category('A')."
    - "unicodedata_extra2 covers: __module__ for normalize/decomposition/bidirectional/east_asian_width/combining/category/lookup/name."
    - "unicodedata_extra4 covers: __name__ table for all major functions including name/lookup/category/bidirectional/combining/normalize."
    - "unicodedata_extra8 covers: __module__ table for all major functions (all 'unicodedata')."
    - "unicodedata_extra11 covers: unidata_version is str (class name check); bidirectional('A'); name('A')."
    - "unicodedata_extra12 covers: name('A') == 'LATIN CAPITAL LETTER A'; name('\\u00e9'); name('\\u00c0')."
    - "unicodedata_extra5 covers: lookup('LATIN SMALL LETTER A') == 'a'."
    - "NOT yet covered (now covered here): name.__name__ in re_extra20 namespace anchor."
    - "NOT yet covered (now covered here): lookup.__name__ namespace anchor in unicodedata_extra13."
    - "NOT yet covered (now covered here): category.__name__ namespace anchor in unicodedata_extra13."
    - "NOT yet covered (now covered here): bidirectional.__name__ namespace anchor in unicodedata_extra13."
    - "NOT yet covered (now covered here): combining.__name__ namespace anchor in unicodedata_extra13."
    - "NOT yet covered (now covered here): normalize.__name__ namespace anchor in unicodedata_extra13."
    - "unicodedata_extra4 covers __name__ for all functions in a table; these are re-anchored as standalone invariants."
    - "unicodedata_extra8 covers __module__ for all functions in a table as 'unicodedata'; re-anchored in this namespace."
    - "unicodedata_extra.zspec covers unidata_version.__class__.__name__ == 'str'; re-anchored here."
    - "unicodedata_extra5 covers lookup('LATIN SMALL LETTER A') == 'a'; re-anchored here."
    - "unicodedata_extra.zspec/extra12 covers name('A') == 'LATIN CAPITAL LETTER A'; re-anchored here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — namespace anchors for unicodedata_extra13
#
# unicodedata_extra4 covers all six __name__ values in a table.
# These are re-anchored as standalone invariants in this namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra13.name.function_name:
  description: "unicodedata.name.__name__ == 'name' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: name.__name__.__eq__
  args: ["name"]
  expected: true

invariant unicodedata_extra13.lookup.function_name:
  description: "unicodedata.lookup.__name__ == 'lookup' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: lookup.__name__.__eq__
  args: ["lookup"]
  expected: true

invariant unicodedata_extra13.category.function_name:
  description: "unicodedata.category.__name__ == 'category' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: category.__name__.__eq__
  args: ["category"]
  expected: true

invariant unicodedata_extra13.bidirectional.function_name:
  description: "unicodedata.bidirectional.__name__ == 'bidirectional' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: bidirectional.__name__.__eq__
  args: ["bidirectional"]
  expected: true

invariant unicodedata_extra13.combining.function_name:
  description: "unicodedata.combining.__name__ == 'combining' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: combining.__name__.__eq__
  args: ["combining"]
  expected: true

invariant unicodedata_extra13.normalize.function_name:
  description: "unicodedata.normalize.__name__ == 'normalize' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: normalize.__name__.__eq__
  args: ["normalize"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __module__ attributes
#
# unicodedata_extra8 covers __module__ for all functions in a table.
# This table re-anchors all six in the unicodedata_extra13 namespace.
# All C-extension functions in the unicodedata module have __module__ == 'unicodedata'.
# ---------------------------------------------------------------------------

table unicodedata_extra13.function_modules:
  description: "unicodedata function __module__ attributes — all report 'unicodedata'"
  kind: python_call_eq
  category: function_identity
  id_prefix: mod13

  columns: [id, function, args, expected]
  rows:
    - [name,         name.__module__.__eq__,         ["unicodedata"], true]
    - [lookup,       lookup.__module__.__eq__,        ["unicodedata"], true]
    - [category,     category.__module__.__eq__,      ["unicodedata"], true]
    - [bidirectional,bidirectional.__module__.__eq__,  ["unicodedata"], true]
    - [combining,    combining.__module__.__eq__,      ["unicodedata"], true]
    - [normalize,    normalize.__module__.__eq__,      ["unicodedata"], true]

# ---------------------------------------------------------------------------
# unidata_version — class name check
#
# unicodedata_extra.zspec covers unidata_version.__class__.__name__ == 'str'.
# unicodedata_extra11 covers the same check. Re-anchored here as a standalone
# invariant in the unicodedata_extra13 namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra13.unidata_version.is_str:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str' — version constant is a string"
  category: version
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# lookup() — Latin small letter a
#
# unicodedata_extra5 covers lookup('LATIN SMALL LETTER A') == 'a'.
# Re-anchored here as a standalone invariant in the unicodedata_extra13 namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra13.lookup.latin_small_a:
  description: "unicodedata.lookup('LATIN SMALL LETTER A') == 'a' — reverse lookup by name"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["LATIN SMALL LETTER A"]
  expected: "a"

# ---------------------------------------------------------------------------
# name() — Latin capital letter A
#
# unicodedata_extra.zspec and extra12 cover name('A') == 'LATIN CAPITAL LETTER A'.
# Re-anchored here as a standalone invariant in the unicodedata_extra13 namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra13.name.capital_a:
  description: "unicodedata.name('A') == 'LATIN CAPITAL LETTER A' — name lookup for ASCII capital A"
  category: name
  kind: python_call_eq
  function: name
  args: ["A"]
  expected: "LATIN CAPITAL LETTER A"
