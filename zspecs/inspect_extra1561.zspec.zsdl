spec: inspect_extra1561
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 551 theme: numeric type conversion protocol dict-presence checks via __dict__.__contains__ for inspect classes."
    - "inspect.Parameter.__dict__.__contains__ returns False for all numeric dunder methods. Parameter is a Python class representing a callable parameter; it is not a numeric type. Verified with Python 3.14."
    - "inspect.Signature.__dict__.__contains__ returns False for all numeric dunder methods. Signature is a Python class representing a callable's signature; numeric conversion protocol is inapplicable. Verified with Python 3.14."
    - "inspect.BoundArguments.__dict__.__contains__ returns False for all numeric dunder methods. BoundArguments is a Python class holding bound argument mappings; it defines no numeric conversion protocol. Verified with Python 3.14."
    - "Parameter.kind is a property returning a ParameterKind enum value. ParameterKind is an IntEnum subclass and inherits numeric conversions from int, but Parameter itself does not define any numeric dunder methods in its own __dict__. Verified with Python 3.14."
    - "Numeric dunders checked: __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — numeric type conversion protocol dict-presence checks
#
# Wave 551 theme: Parameter is a Python class defined in Lib/inspect.py.
# Its own __dict__ does not contain any numeric conversion dunder methods.
# Parameter represents a parameter in a function signature; it is not numeric.
# Note: Parameter.kind returns a ParameterKind (IntEnum) value, but Parameter
# itself defines no numeric dunders in its own class __dict__.
# ---------------------------------------------------------------------------

table inspect_extra1561.parameter_numeric_dict_contains:
  description: "inspect.Parameter.__dict__.__contains__ returns False for all numeric type conversion dunders; wave 551; new to extra1561"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1561pa

  columns: [id, function, args, expected, description]
  rows:
    - ["in1561pa001",
       "Parameter.__dict__.__contains__",
       ["__bool__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__bool__') == False — Parameter is a Python class for callable parameters; its __dict__ does not define __bool__; wave 551; new to extra1561"]
    - ["in1561pa002",
       "Parameter.__dict__.__contains__",
       ["__int__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__int__') == False — Parameter does not define __int__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa003",
       "Parameter.__dict__.__contains__",
       ["__float__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__float__') == False — Parameter does not define __float__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa004",
       "Parameter.__dict__.__contains__",
       ["__complex__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__complex__') == False — Parameter does not define __complex__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa005",
       "Parameter.__dict__.__contains__",
       ["__index__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__index__') == False — Parameter does not define __index__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa006",
       "Parameter.__dict__.__contains__",
       ["__trunc__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__trunc__') == False — Parameter does not define __trunc__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa007",
       "Parameter.__dict__.__contains__",
       ["__floor__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__floor__') == False — Parameter does not define __floor__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa008",
       "Parameter.__dict__.__contains__",
       ["__ceil__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__ceil__') == False — Parameter does not define __ceil__ in its own class __dict__; wave 551; new to extra1561"]
    - ["in1561pa009",
       "Parameter.__dict__.__contains__",
       ["__round__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__round__') == False — Parameter does not define __round__ in its own class __dict__; wave 551; new to extra1561"]

