# ---------------------------------------------------------------------------
# Standalone invariants — extra1561
# ---------------------------------------------------------------------------

invariant inspect_extra1561.parameter_no_bool:
  description: "inspect.Parameter.__dict__.__contains__('__bool__') == False — Parameter defines no __bool__; wave 551; new to extra1561"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__bool__"]
  expected: false

invariant inspect_extra1561.parameter_no_int:
