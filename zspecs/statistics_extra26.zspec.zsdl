spec: statistics_extra26
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra25.zspec.zsdl."
    - "Prior specs covered: mean/median/mode/stdev/variance/pstdev/pvariance, StatisticsError.__name__/__module__/__bases__[0].__name__, NormalDist.__name__/__module__/__qualname__/__bases__[0].__name__, NormalDist.__init__.__name__, NormalDist(0,1) mean/stdev/variance, fmean/geometric_mean/harmonic_mean/median_low/median_high/median_grouped/__name__, statistics.__all__ type/length, mean/median/mode/stdev/variance/fmean/geometric_mean/harmonic_mean __qualname__, mean/median/stdev/NormalDist __module__.__len__()."
    - "This spec covers: __module__.__len__() for mode/variance/fmean/geometric_mean/harmonic_mean/pstdev/pvariance/median_low/median_high/median_grouped/StatisticsError; __name__.__len__() for pstdev/pvariance/median_low/median_high/median_grouped/StatisticsError; NormalDist method __qualname__.__len__() for pdf/cdf/inv_cdf/overlap/quantiles/zscore/samples/from_samples."
    - "All module-level statistics functions and NormalDist have __module__ == 'statistics' (10 chars)."
    - "StatisticsError.__name__ == 'StatisticsError' (length 15); longest __name__ among statistics module objects measured so far."
    - "NormalDist method __qualname__ values are prefixed 'NormalDist.' (11 chars) plus the method name."
    - "NormalDist.from_samples.__qualname__ == 'NormalDist.from_samples' (length 23) — longest NormalDist method qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for mode/variance/fmean/geometric_mean/harmonic_mean/
# pstdev/pvariance/median_low/median_high/median_grouped/StatisticsError
#
# extra25 recorded __module__.__len__() for mean, median, stdev, NormalDist.
# This table extends that coverage to the remaining major statistics objects.
# All have __module__ == 'statistics' (length 10).
# ---------------------------------------------------------------------------

table statistics_extra26.module_lens_extended:
  description: "__module__.__len__() for remaining statistics module objects not covered in extra25"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [mode,            mode.__module__.__len__,            [], 10]
    - [variance,        variance.__module__.__len__,        [], 10]
    - [fmean,           fmean.__module__.__len__,           [], 10]
    - [geometric_mean,  geometric_mean.__module__.__len__,  [], 10]
    - [harmonic_mean,   harmonic_mean.__module__.__len__,   [], 10]
    - [pstdev,          pstdev.__module__.__len__,          [], 10]
    - [pvariance,       pvariance.__module__.__len__,       [], 10]
    - [median_low,      median_low.__module__.__len__,      [], 10]
    - [median_high,     median_high.__module__.__len__,     [], 10]
    - [median_grouped,  median_grouped.__module__.__len__,  [], 10]
    - [StatisticsError, StatisticsError.__module__.__len__, [], 10]

# ---------------------------------------------------------------------------
# __name__.__len__() for pstdev/pvariance/median_low/median_high/
# median_grouped/StatisticsError
#
# These names were not measured in prior extra specs. Note that median_low
# (10), median_high (11), and median_grouped (14) have longer names than the
# core functions; StatisticsError (15) is the longest __name__ measured so far.
# ---------------------------------------------------------------------------

table statistics_extra26.name_lens_extended:
  description: "__name__.__len__() for statistics functions and error not covered in prior extra specs"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [pstdev,          pstdev.__name__.__len__,          [], 6]
    - [pvariance,       pvariance.__name__.__len__,       [], 9]
    - [median_low,      median_low.__name__.__len__,      [], 10]
    - [median_high,     median_high.__name__.__len__,     [], 11]
    - [median_grouped,  median_grouped.__name__.__len__,  [], 14]
    - [StatisticsError, StatisticsError.__name__.__len__, [], 15]

# ---------------------------------------------------------------------------
# NormalDist method __qualname__.__len__() — combined table
#
# Each NormalDist method has __qualname__ == 'NormalDist.' + method_name.
# No prior statistics spec records __qualname__.__len__() for NormalDist methods.
# pdf/cdf share the shortest qualname (14); from_samples has the longest (23).
# ---------------------------------------------------------------------------

table statistics_extra26.normaldist_method_qualname_lens:
  description: "__qualname__.__len__() for NormalDist methods — 'NormalDist.' prefix adds 11 chars"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [pdf,          NormalDist.pdf.__qualname__.__len__,          [], 14]
    - [cdf,          NormalDist.cdf.__qualname__.__len__,          [], 14]
    - [inv_cdf,      NormalDist.inv_cdf.__qualname__.__len__,      [], 18]
    - [overlap,      NormalDist.overlap.__qualname__.__len__,      [], 18]
    - [quantiles,    NormalDist.quantiles.__qualname__.__len__,    [], 20]
    - [zscore,       NormalDist.zscore.__qualname__.__len__,       [], 17]
    - [samples,      NormalDist.samples.__qualname__.__len__,      [], 18]
    - [from_samples, NormalDist.from_samples.__qualname__.__len__, [], 23]

# ---------------------------------------------------------------------------
# statistics.StatisticsError.__name__.__len__() == 15 — standalone
#
# StatisticsError.__name__ is 'StatisticsError', length 15. This is the longest
# __name__ among all statistics module objects measured across extra21–extra26.
# It exceeds NormalDist.__name__ (10) and all function __name__ values.
# ---------------------------------------------------------------------------

invariant statistics_extra26.StatisticsError.name_len:
  description: "statistics.StatisticsError.__name__.__len__() == 15 — 'StatisticsError' is the longest __name__ among measured statistics module objects"
  category: name_attr_lengths
  kind: python_call_eq
  function: StatisticsError.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# statistics.NormalDist.from_samples.__qualname__.__len__() == 23 — standalone
#
# NormalDist.from_samples.__qualname__ is 'NormalDist.from_samples', which at
# 23 characters is the longest __qualname__ among all NormalDist methods.
# from_samples is a classmethod; the composite qualname reflects the class prefix.
# ---------------------------------------------------------------------------

invariant statistics_extra26.NormalDist.from_samples.qualname_len:
  description: "statistics.NormalDist.from_samples.__qualname__.__len__() == 23 — 'NormalDist.from_samples' is the longest NormalDist method qualname"
  category: method_qualname_lengths
  kind: python_call_eq
  function: NormalDist.from_samples.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# statistics.NormalDist.pdf.__qualname__.__len__() == 14 — standalone
#
# NormalDist.pdf.__qualname__ is 'NormalDist.pdf' (14 chars). pdf and cdf share
# the shortest __qualname__ length among all NormalDist methods; the three-char
# method name keeps the composite qualname compact.
# ---------------------------------------------------------------------------

invariant statistics_extra26.NormalDist.pdf.qualname_len:
  description: "statistics.NormalDist.pdf.__qualname__.__len__() == 14 — 'NormalDist.pdf' is the shortest NormalDist method qualname (tied with cdf)"
  category: method_qualname_lengths
  kind: python_call_eq
  function: NormalDist.pdf.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# statistics.median_grouped.__module__.__len__() == 10 — standalone
#
# median_grouped has the longest __name__ among the median_* family (14 chars)
# while still sharing __module__ == 'statistics' (10 chars) with all other
# module-level functions. Re-anchored as a standalone to contrast name length
# (14) with module length (10).
# ---------------------------------------------------------------------------

invariant statistics_extra26.median_grouped.module_len:
  description: "statistics.median_grouped.__module__.__len__() == 10 — 'statistics' has length 10; __module__ length uniform despite long __name__ (14)"
  category: module_attr_lengths
  kind: python_call_eq
  function: median_grouped.__module__.__len__
  args: []
  expected: 10
