spec: functools_extra1711
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "C extension types (functools.partial, _lru_cache_wrapper) use __new__ for initialization and do NOT define __init__ in their own __dict__."
    - "Pure Python classes (cached_property, partialmethod) define __init__ in their own __dict__."
    - "Cross-checks between __init__ and __new__ presence, and related dunder attributes (__init_subclass__, __class_getitem__)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init__ dict-presence checks
#
# Wave 561 theme: which functools types define __init__ in their own __dict__
# (as opposed to inheriting from object or a C base).
#
# functools.partial is a C extension type — uses __new__ for construction,
# does NOT define __init__ in its __dict__ → False.
#
# functools.cached_property is a pure Python class — its __init__ accepts
# the fget function argument and is defined directly on the class → True.
#
# functools.partialmethod is a pure Python class — defines its own __init__
# to accept func, *args, **keywords → True.
#
# functools._lru_cache_wrapper is a C extension type (the internal wrapper
# created by @lru_cache) — uses __new__; no Python __init__ in its __dict__
# → False.
# ---------------------------------------------------------------------------

table functools_extra1711.init_protocol:
  description: "functools types: __init__ dict-presence via __dict__.__contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1711

  columns: [id, function, args, expected]
  rows:
    - ["fu1711001", "functools.partial.__dict__.__contains__", ["__init__"], false]
    - ["fu1711002", "functools.cached_property.__dict__.__contains__", ["__init__"], true]
    - ["fu1711003", "functools.partialmethod.__dict__.__contains__", ["__init__"], true]
    - ["fu1711004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__init__"], false]

# ---------------------------------------------------------------------------
# Table 2: __new__ dict-presence cross-checks
#
# Wave 561 cross-check: C extension types that lack __init__ in their __dict__
# instead rely on __new__ for construction. Pure Python classes also inherit
# __new__ from object and typically do NOT add it to their own __dict__.
#
# functools.partial (C type): __new__ IS in its __dict__ → True.
# functools._lru_cache_wrapper (C type): __new__ IS in its __dict__ → True.
# functools.cached_property (pure Python): __new__ is inherited from object,
#   NOT in its own __dict__ → False.
# functools.partialmethod (pure Python): similarly NOT in its own __dict__ → False.
# ---------------------------------------------------------------------------

table functools_extra1711.new_protocol:
  description: "functools types: __new__ dict-presence cross-check (C types vs pure Python)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1711

  columns: [id, function, args, expected]
  rows:
    - ["fu1711005", "functools.partial.__dict__.__contains__", ["__new__"], true]
    - ["fu1711006", "functools._lru_cache_wrapper.__dict__.__contains__", ["__new__"], true]
    - ["fu1711007", "functools.cached_property.__dict__.__contains__", ["__new__"], false]
    - ["fu1711008", "functools.partialmethod.__dict__.__contains__", ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 3: related dunder protocol cross-checks
#
# Wave 561 extension: related dunder attributes that may or may not appear in
# each type's own __dict__: __init_subclass__ and __class_getitem__.
#
# __init_subclass__ is defined on object and inherited by all classes. Pure
# Python classes that do not override it will NOT have it in their own __dict__.
# C extension types also typically inherit it rather than defining it.
#
# __class_getitem__ is defined by classes that support generic syntax (PEP 560).
# functools types do NOT support generic syntax and will not have this in their
# __dict__.
# ---------------------------------------------------------------------------

table functools_extra1711.related_dunder_protocol:
  description: "functools types: __init_subclass__ and __class_getitem__ dict-presence (both inherited, not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1711

  columns: [id, function, args, expected]
  rows:
    - ["fu1711009",  "functools.partial.__dict__.__contains__", ["__init_subclass__"], false]
    - ["fu1711010",  "functools.cached_property.__dict__.__contains__", ["__init_subclass__"], false]
    - ["fu1711011",  "functools.partialmethod.__dict__.__contains__", ["__init_subclass__"], false]
    - ["fu1711012",  "functools._lru_cache_wrapper.__dict__.__contains__", ["__init_subclass__"], false]
    - ["fu1711013",  "functools.partial.__dict__.__contains__", ["__class_getitem__"], false]
    - ["fu1711014",  "functools.cached_property.__dict__.__contains__", ["__class_getitem__"], false]
    - ["fu1711015",  "functools.partialmethod.__dict__.__contains__", ["__class_getitem__"], false]
    - ["fu1711016",  "functools._lru_cache_wrapper.__dict__.__contains__", ["__class_getitem__"], false]
