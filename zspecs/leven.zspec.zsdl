spec: leven
version: ">=3.0.0"
backend: node(leven)

docs: https://github.com/sindresorhus/leven#readme

provenance:
  derived_from:
    - "leven README — https://github.com/sindresorhus/leven#readme"
    - "Test vectors verified with leven@3.1.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "leven source: index.js"
  notes:
    - "leven exports the function as the module default (CJS)."
    - "Computes the Levenshtein edit distance between two strings."
    - "Returns 0 for identical strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a non-negative integer. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table leven.distance:
  kind: node_module_call_eq
  function: ~
  category: distance
  id_prefix: lev

  columns: [id, args, expected]
  rows:
    - [same,           ["kitten", "kitten"],  0]
    - [kitten_sitting, ["kitten", "sitting"], 3]
    - [empty_abc,      ["", "abc"],           3]
    - [a_empty,        ["a", ""],             1]
    - [abc_cba,        ["abc", "cba"],        2]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:12:45Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
