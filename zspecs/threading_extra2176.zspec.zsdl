  rows:
    - ["th2176005", "threading.Condition.__dict__.__contains__",        ["__iter__"],  false]
    - ["th2176006", "threading.Condition.__dict__.__contains__",        ["__next__"],  false]
    - ["th2176007", "threading.Semaphore.__dict__.__contains__",        ["__iter__"],  false]
    - ["th2176008", "threading.Semaphore.__dict__.__contains__",        ["__next__"],  false]
    - ["th2176009", "threading.BoundedSemaphore.__dict__.__contains__", ["__iter__"],  false]
    - ["th2176010", "threading.BoundedSemaphore.__dict__.__contains__", ["__next__"],  false]
    - ["th2176011", "threading.Barrier.__dict__.__contains__",          ["__iter__"],  false]
    - ["th2176012", "threading.Barrier.__dict__.__contains__",          ["__next__"],  false]

