spec: hashlib_extra74
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra73.zspec.zsdl — covers algorithms_guaranteed/__class__/__name__=='set' / algorithms_available/__class__.__name__=='set' / algorithms_guaranteed/__contains__ md5/sha256/sha512 / algorithms_available/__contains__ md5/sha256 / new/__class__/__name__=='function' / new/__module__=='hashlib' (table + invariants)."
    - "hashlib_extra72.zspec.zsdl — covers __spec__/__class__/__name__=='ModuleSpec' / __file__/__contains__('.py') / pbkdf2_hmac/__qualname__/__eq__('pbkdf2_hmac') (table + invariants)."
    - "hashlib_extra71.zspec.zsdl — covers pbkdf2_hmac/__class__/__name__=='builtin_function_or_method' / new/__class__/__name__=='function' / file_digest/__class__/__name__=='function' / new/__module__=='hashlib' / file_digest/__module__=='hashlib' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra73; it does NOT duplicate invariants present in those files."
    - "Wave 238 theme: hashlib HASH object method descriptor identity."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — md5 is a C builtin constructor; its __class__.__name__ is 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — sha256 is a C builtin constructor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method' — sha1 is a C builtin constructor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method' — sha512 is a C builtin constructor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__class__.__name__ == 'builtin_function_or_method' — shake_128 is a C builtin constructor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' — sha3_256 is a C builtin constructor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' — scrypt is a C builtin (not available on all platforms but present on macOS/Darwin 25.4.0). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__ == 'type' — unlike md5/sha256, blake2b is exposed as a type (C type) in Python 3.14.3 on macOS/Darwin 25.4.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__name__ == 'type' — blake2s is also a type (C type), not a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function' — file_digest is a Python function in Lib/hashlib.py. hashlib_extra71 covers this; re-anchored in extra74 namespace alongside novel __code__ checks. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_name == 'file_digest' — the code object co_name for the Python file_digest function. No prior hashlib spec checks file_digest.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib' — hashlib_extra71 covers this; re-anchored in extra74 namespace for completeness. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5 / sha256 / sha1 / sha512 __class__.__name__
#
# Wave 238 theme: hashlib hash function __class__ identity.
#
# hashlib.md5, sha256, sha1, and sha512 are all C builtin constructors exposed
# in the hashlib namespace. Their __class__.__name__ is
# 'builtin_function_or_method'. No prior hashlib spec checks __class__.__name__
# for these four hash functions. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra74.core_hash_class_identity:
  description: "hashlib.md5/__class__/__name__.__eq__('builtin_function_or_method')==True / sha256/__class__/__name__.__eq__('builtin_function_or_method')==True / sha1/__class__/__name__.__eq__('builtin_function_or_method')==True / sha512/__class__/__name__.__eq__('builtin_function_or_method')==True — md5/sha256/sha1/sha512 are C builtin constructors; no prior hashlib spec checks __class__.__name__ for these four hash functions; first class identity anchor for md5/sha256/sha1/sha512"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibcode74

  columns: [id, function, args, expected]
  rows:
    - [md5_class_builtin,    md5.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [sha256_class_builtin, sha256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha1_class_builtin,   sha1.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [sha512_class_builtin, sha512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.shake_128 / sha3_256 / scrypt __class__.__name__
#
# Wave 238 theme: SHA-3 and scrypt function class identity.
#
# hashlib.shake_128, sha3_256, and scrypt are all C builtin constructors.
# shake_128 and sha3_256 are SHA-3 family functions; scrypt is a key
# derivation function available on macOS/Darwin 25.4.0. No prior hashlib
# spec checks __class__.__name__ for these three functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra74.sha3_scrypt_class_identity:
  description: "hashlib.shake_128/__class__/__name__.__eq__('builtin_function_or_method')==True / sha3_256/__class__/__name__.__eq__('builtin_function_or_method')==True / scrypt/__class__/__name__.__eq__('builtin_function_or_method')==True — shake_128/sha3_256/scrypt are C builtin constructors; no prior hashlib spec checks __class__.__name__ for these three; first class identity anchor for shake_128/sha3_256/scrypt"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibcode74

  columns: [id, function, args, expected]
  rows:
    - [shake_128_class_builtin, shake_128.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_256_class_builtin,  sha3_256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [scrypt_class_builtin,    scrypt.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b / blake2s __class__.__name__
#
# Wave 238 theme: blake2 class type identity.
#
# hashlib.blake2b and hashlib.blake2s are exposed as C types in Python 3.14.3
# on macOS/Darwin 25.4.0. Unlike md5/sha256 which are builtin_function_or_method,
# blake2b and blake2s have __class__.__name__ == 'type'. No prior hashlib spec
# checks __class__.__name__ for blake2b or blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra74.blake2_class_identity:
  description: "hashlib.blake2b/__class__/__name__.__eq__('type')==True / blake2s/__class__/__name__.__eq__('type')==True — blake2b and blake2s are C types (not builtin_function_or_method like md5/sha256); no prior hashlib spec checks __class__.__name__ for blake2b or blake2s; first class identity anchor for blake2b/blake2s as 'type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibcode74

  columns: [id, function, args, expected]
  rows:
    - [blake2b_class_type, blake2b.__class__.__name__.__eq__, ["type"], true]
    - [blake2s_class_type, blake2s.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# hashlib.file_digest __class__.__name__ and __code__.co_name
#
# Wave 238 theme: file_digest Python function identity.
#
# hashlib.file_digest is a Python function defined in Lib/hashlib.py. Its
# __class__.__name__ is 'function'. Its code object co_name is 'file_digest'.
# hashlib_extra71 covers __class__.__name__=='function' and __module__=='hashlib'.
# No prior hashlib spec checks file_digest.__code__.co_name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra74.file_digest_identity:
  description: "hashlib.file_digest/__class__/__name__.__eq__('function')==True / file_digest/__code__.co_name.__eq__('file_digest')==True / file_digest/__module__.__eq__('hashlib')==True — file_digest is a Python function; __code__.co_name is 'file_digest'; hashlib_extra71 covers __class__/__name__ and __module__; this spec adds __code__.co_name; first code object anchor for file_digest"
  kind: python_call_eq
  category: func_identity
  id_prefix: hashlibcode74

  columns: [id, function, args, expected]
  rows:
    - [file_digest_class_function,  file_digest.__class__.__name__.__eq__,  ["function"],     true]
    - [file_digest_co_name,         file_digest.__code__.co_name.__eq__,    ["file_digest"],  true]
    - [file_digest_module_hashlib,  file_digest.__module__.__eq__,          ["hashlib"],      true]

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.md5 is a C builtin constructor. Its __class__.__name__ is
# 'builtin_function_or_method'. No prior hashlib spec checks
# md5.__class__.__name__. First class identity standalone for md5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra74.md5_class_builtin:
  description: "hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') == True — md5 is a C builtin constructor; no prior hashlib spec checks md5.__class__.__name__; first class identity standalone for md5"
  category: class_identity
  kind: python_call_eq
  function: md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.shake_128 is a C builtin constructor. Its __class__.__name__ is
# 'builtin_function_or_method'. No prior hashlib spec checks
# shake_128.__class__.__name__. First class identity standalone for shake_128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra74.shake_128_class_builtin:
  description: "hashlib.shake_128.__class__.__name__.__eq__('builtin_function_or_method') == True — shake_128 is a C builtin constructor; no prior hashlib spec checks shake_128.__class__.__name__; first class identity standalone for shake_128"
  category: class_identity
  kind: python_call_eq
  function: shake_128.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__eq__('type') — standalone
#
# hashlib.blake2b is a C type (not a builtin_function_or_method like md5/sha256).
# Its __class__.__name__ is 'type'. No prior hashlib spec checks
# blake2b.__class__.__name__. First class identity standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra74.blake2b_class_type:
  description: "hashlib.blake2b.__class__.__name__.__eq__('type') == True — blake2b is a C type in Python 3.14.3 (unlike md5/sha256 which are builtin_function_or_method); no prior hashlib spec checks blake2b.__class__.__name__; first class identity standalone for blake2b"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__class__.__name__.__eq__('type') — standalone
#
# hashlib.blake2s is a C type. Its __class__.__name__ is 'type'.
# No prior hashlib spec checks blake2s.__class__.__name__.
# First class identity standalone for blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra74.blake2s_class_type:
  description: "hashlib.blake2s.__class__.__name__.__eq__('type') == True — blake2s is a C type in Python 3.14.3; no prior hashlib spec checks blake2s.__class__.__name__; first class identity standalone for blake2s"
  category: class_identity
  kind: python_call_eq
  function: blake2s.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_name.__eq__('file_digest') — standalone
#
# hashlib.file_digest is a Python function in Lib/hashlib.py. Its code
# object co_name is 'file_digest'. No prior hashlib spec checks
# file_digest.__code__.co_name. First code object co_name standalone for
# file_digest. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra74.file_digest_co_name:
  description: "hashlib.file_digest.__code__.co_name.__eq__('file_digest') == True — file_digest is a Python function in Lib/hashlib.py; code object co_name is 'file_digest'; no prior hashlib spec checks file_digest.__code__.co_name; first code object co_name standalone for file_digest"
  category: func_identity
  kind: python_call_eq
  function: file_digest.__code__.co_name.__eq__
  args: ["file_digest"]
  expected: true
