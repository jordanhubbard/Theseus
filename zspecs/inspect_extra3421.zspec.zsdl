spec: in3421
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (in3421): __hash__, __eq__, __lt__ dict-presence checks for inspect types."
    - "Theme: __hash__/__eq__/__lt__ dict-presence (hash(x), x==y, x<y)."
    - "All values False — inspect introspection types have no custom hash/eq/lt comparison in their own __dict__."
    - "None of the inspect types define __hash__, __eq__, or __lt__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement hash, eq, or lt comparison protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3421.hash:
  description: "inspect types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3421
  columns: [id, function, args, expected]
  rows:
    - ["in3421001", operator.contains, [inspect.Parameter.__dict__,           "__hash__"], false]
    - ["in3421002", operator.contains, [inspect.Signature.__dict__,           "__hash__"], false]
    - ["in3421003", operator.contains, [inspect.BoundArguments.__dict__,      "__hash__"], false]
    - ["in3421004", operator.contains, [inspect.FrameInfo.__dict__,           "__hash__"], false]
    - ["in3421005", operator.contains, [inspect.ArgInfo.__dict__,             "__hash__"], false]
    - ["in3421006", operator.contains, [inspect.FullArgSpec.__dict__,         "__hash__"], false]
    - ["in3421007", operator.contains, [inspect.Attribute.__dict__,           "__hash__"], false]
    - ["in3421008", operator.contains, [inspect.ClassFoundException.__dict__, "__hash__"], false]
    - ["in3421009", operator.contains, [inspect.EndOfBlock.__dict__,          "__hash__"], false]

