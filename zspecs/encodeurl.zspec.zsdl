spec: encodeurl
version: ">=1.0.0"
backend: node(encodeurl)

docs: https://github.com/pillarjs/encodeurl#readme

provenance:
  derived_from:
    - "encodeurl README — https://github.com/pillarjs/encodeurl#readme"
    - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax — https://www.rfc-editor.org/rfc/rfc3986"
    - "Test vectors verified with encodeurl@2.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "encodeurl source: index.js"
  notes:
    - "encodeurl exports the encode function as the module default (CJS)."
    - "require('encodeurl') returns the function directly; fn_name is null (call module itself)."
    - "Encodes characters that are illegal in URLs (spaces → %20, non-ASCII → percent-encoded)."
    - "Unlike encodeURIComponent, encodeurl does NOT double-encode already-percent-encoded sequences."
    - "Characters legal in URLs (/, ?, =, &, #, :, @, etc.) are preserved."
    - "Already-encoded sequences like %20 are passed through unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "No errors thrown for string inputs. Returns the percent-encoded URL string directly."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

# ---------------------------------------------------------------------------
# URL encoding
# ---------------------------------------------------------------------------

table encodeurl.passthrough:
  kind: node_module_call_eq
  function: ~
  category: passthrough
  id_prefix: pass

  columns: [id, args, expected]
  rows:
    - [plain_path,  ["/path/to/file"],     "/path/to/file"]
    - [query,       ["/search?q=hello"],   "/search?q=hello"]
    - [already_enc, ["/path%20to"],        "/path%20to"]

table encodeurl.encode:
  kind: node_module_call_eq
  function: ~
  category: encode
  id_prefix: enc

  columns: [id, args, expected]
  rows:
    - [space,       ["/path with spaces"], "/path%20with%20spaces"]
    - [query_space, ["/search?q=hello world"], "/search?q=hello%20world"]
    - [non_ascii,   ["/café"],        "/caf%C3%A9"]
