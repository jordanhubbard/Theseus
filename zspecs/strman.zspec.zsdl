spec: strman
version: ">=2.0.0"
backend: node(strman)

docs: https://www.npmjs.com/package/strman

provenance:
  derived_from:
    - "strman README — https://www.npmjs.com/package/strman"
    - "Test vectors verified with strman via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "strman source"
  notes:
    - "strman is an npm package. Install: npm install strman"
    - "Provides string utilities: collapseWhitespace, truncate, surround, leftPad."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns transformed string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table strman.collapseWhitespace:
  kind: node_module_call_eq
  function: collapseWhitespace
  category: transform
  id_prefix: smcw

  columns: [id, args, expected]
  rows:
    - [spaces, ["  hello   world  "], "hello world"]

table strman.truncate:
  kind: node_module_call_eq
  function: truncate
  category: transform
  id_prefix: smtrunc

  columns: [id, args, expected]
  rows:
    - [short, ["Hello World", 5], "Hello"]

table strman.surround:
  kind: node_module_call_eq
  function: surround
  category: transform
  id_prefix: smsurr

  columns: [id, args, expected]
  rows:
    - [parens, ["hello", "(", ")"], "(hello)"]

table strman.leftPad:
  kind: node_module_call_eq
  function: leftPad
  category: transform
  id_prefix: smlpad

  columns: [id, args, expected]
  rows:
    - [dash_pad, ["hello", 10, "-"], "-----hello"]
