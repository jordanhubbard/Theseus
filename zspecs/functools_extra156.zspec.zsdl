spec: functools_extra156
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.__dict__.__len__() 62; functools.__dict__.__class__.__name__ 'dict'; functools.__dict__.__contains__ checks for partial, reduce, lru_cache, cached_property, singledispatch, total_ordering, wraps, update_wrapper (Wave 280)."
    - "functools.__dict__.__len__() == 62 — the functools module dict has 62 entries in Python 3.14.3; this includes all public callables, internal helpers, and dunder attributes. Verified with Python 3.14.3."
    - "functools.__dict__.__class__.__name__ == 'dict' — the module __dict__ of a Python-level module (even one with C helpers) is a plain dict, not a mappingproxy. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('partial') == True — partial is a C extension type from _functoolsmodule.c exported into the functools namespace. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('reduce') == True — reduce is a C builtin from _functoolsmodule.c exported into functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('lru_cache') == True — lru_cache is a Python decorator defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('cached_property') == True — cached_property is a Python class in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('singledispatch') == True — singledispatch is a Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('total_ordering') == True — total_ordering is a Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('wraps') == True — wraps is a Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('update_wrapper') == True — update_wrapper is a Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__dict__ — module dict identity (plain dict, len 62)
#
# Wave 280 theme: functools module dict type and size.
#
# functools.__dict__.__class__.__name__ == 'dict'
# functools.__dict__.__len__() == 62
#
# The module __dict__ of a Python-level module is a plain dict (not a
# mappingproxy). In Python 3.14.3 the functools module dict has 62 entries,
# covering all public and private names. New to extra156.
# ---------------------------------------------------------------------------

table functools_extra156.module_dict_identity:
  description: "functools.__dict__: plain dict (not mappingproxy), len 62; module-level dict for a mixed Python/C module; wave 280; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmoddict156

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_class_eq_dict,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.__dict__.__class__.__name__.__eq__('dict') == True — the module __dict__ of a Python-level module is a plain Python dict, not a mappingproxy; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra156"]
    - [module_dict_len_eq_62,
       "__dict__.__len__",
       [],
       62,
       "functools.__dict__.__len__() == 62 — the functools module dict has 62 entries in Python 3.14.3; includes all public callables (partial, reduce, lru_cache, etc.) plus private helpers and dunder attributes; len == 62; verified with Python 3.14.3; new to extra156"]

# ---------------------------------------------------------------------------
# Table 2: functools.__dict__.__contains__ — core public names (partial, reduce)
#
# Wave 280 theme: functools module dict membership checks for C-backed exports.
#
# functools.__dict__.__contains__('partial') == True
# functools.__dict__.__contains__('reduce') == True
#
# partial is a C extension type from _functoolsmodule.c.
# reduce is a C builtin from _functoolsmodule.c.
# Both are re-exported into the functools namespace. New to extra156.
# ---------------------------------------------------------------------------

table functools_extra156.module_dict_contains_c_exports:
  description: "functools.__dict__.__contains__: partial True, reduce True; C-backed exports from _functoolsmodule.c in module dict; wave 280; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmdcexports156

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_partial,
       "__dict__.__contains__",
       ["partial"],
       true,
       "functools.__dict__.__contains__('partial') == True — partial is a C extension type defined in Modules/_functoolsmodule.c and exported into the functools namespace; dict.__contains__('partial') returns True; new to extra156"]
    - [dict_contains_reduce,
       "__dict__.__contains__",
       ["reduce"],
       true,
       "functools.__dict__.__contains__('reduce') == True — reduce is a C builtin function defined in Modules/_functoolsmodule.c and exported into the functools namespace; dict.__contains__('reduce') returns True; new to extra156"]

# ---------------------------------------------------------------------------
# Table 3: functools.__dict__.__contains__ — Python-level decorators and helpers
#
# Wave 280 theme: functools module dict membership for Python-defined names.
#
# functools.__dict__.__contains__('lru_cache') == True
# functools.__dict__.__contains__('cached_property') == True
# functools.__dict__.__contains__('singledispatch') == True
# functools.__dict__.__contains__('total_ordering') == True
# functools.__dict__.__contains__('wraps') == True
# functools.__dict__.__contains__('update_wrapper') == True
#
# All six are pure-Python names defined in Lib/functools.py.
# New to extra156.
# ---------------------------------------------------------------------------

table functools_extra156.module_dict_contains_python_names:
  description: "functools.__dict__.__contains__: lru_cache True, cached_property True, singledispatch True, total_ordering True, wraps True, update_wrapper True; Python-defined names in module dict; wave 280; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmdcpython156

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_lru_cache,
       "__dict__.__contains__",
       ["lru_cache"],
       true,
       "functools.__dict__.__contains__('lru_cache') == True — lru_cache is a Python decorator (wrapping _lru_cache_wrapper) defined in Lib/functools.py; dict.__contains__('lru_cache') returns True; new to extra156"]
    - [dict_contains_cached_property,
       "__dict__.__contains__",
       ["cached_property"],
       true,
       "functools.__dict__.__contains__('cached_property') == True — cached_property is a Python class defined in Lib/functools.py that caches a property value on first access; dict.__contains__('cached_property') returns True; new to extra156"]
    - [dict_contains_singledispatch,
       "__dict__.__contains__",
       ["singledispatch"],
       true,
       "functools.__dict__.__contains__('singledispatch') == True — singledispatch is a Python decorator in Lib/functools.py implementing generic single-dispatch functions; dict.__contains__('singledispatch') returns True; new to extra156"]
    - [dict_contains_total_ordering,
       "__dict__.__contains__",
       ["total_ordering"],
       true,
       "functools.__dict__.__contains__('total_ordering') == True — total_ordering is a Python class decorator in Lib/functools.py that fills in missing comparison methods; dict.__contains__('total_ordering') returns True; new to extra156"]
    - [dict_contains_wraps,
       "__dict__.__contains__",
       ["wraps"],
       true,
       "functools.__dict__.__contains__('wraps') == True — wraps is a Python decorator in Lib/functools.py that updates a wrapper function to look like the wrapped function; dict.__contains__('wraps') returns True; new to extra156"]
    - [dict_contains_update_wrapper,
       "__dict__.__contains__",
       ["update_wrapper"],
       true,
       "functools.__dict__.__contains__('update_wrapper') == True — update_wrapper is a Python function in Lib/functools.py that copies attributes from the wrapped function; dict.__contains__('update_wrapper') returns True; new to extra156"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra156
# ---------------------------------------------------------------------------

invariant functools_extra156.module_dict_class_dict:
  description: "functools.__dict__.__class__.__name__ == 'dict' — module __dict__ of a Python-level module is a plain dict; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant functools_extra156.module_dict_len:
  description: "len(functools.__dict__) == 62 — functools module dict has 62 entries in Python 3.14.3; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 62

invariant functools_extra156.dict_contains_partial:
  description: "functools.__dict__.__contains__('partial') == True — C extension type exported into functools; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra156.dict_contains_reduce:
  description: "functools.__dict__.__contains__('reduce') == True — C builtin exported into functools; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra156.dict_contains_lru_cache:
  description: "functools.__dict__.__contains__('lru_cache') == True — Python decorator wrapping _lru_cache_wrapper; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra156.dict_contains_cached_property:
  description: "functools.__dict__.__contains__('cached_property') == True — Python class caching property values on first access; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["cached_property"]
  expected: true

invariant functools_extra156.dict_contains_singledispatch:
  description: "functools.__dict__.__contains__('singledispatch') == True — Python decorator for single-dispatch generics; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["singledispatch"]
  expected: true

invariant functools_extra156.dict_contains_total_ordering:
  description: "functools.__dict__.__contains__('total_ordering') == True — Python class decorator filling in comparison methods; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["total_ordering"]
  expected: true

invariant functools_extra156.dict_contains_wraps:
  description: "functools.__dict__.__contains__('wraps') == True — Python decorator updating wrapper function attributes; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["wraps"]
  expected: true

invariant functools_extra156.dict_contains_update_wrapper:
  description: "functools.__dict__.__contains__('update_wrapper') == True — Python function copying wrapped function attributes; wave 280; new to extra156"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["update_wrapper"]
  expected: true
