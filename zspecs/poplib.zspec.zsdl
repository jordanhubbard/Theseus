spec: poplib
version: ">=3.9"
backend: python_module(poplib)

docs: https://docs.python.org/3/library/poplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/poplib.html"
    - "RFC 1939 — Post Office Protocol - Version 3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/poplib.py internal socket and SSL handling"
  notes:
    - "poplib.POP3 is the core POP3 client class; POP3_SSL extends it with TLS support."
    - "POP3.port is a class-level attribute set to 110 (the standard POP3 port)."
    - "POP3_SSL.port is a class-level attribute set to 995 (the standard POP3S port)."
    - "poplib.error_proto is the sole exception class; it inherits from Exception."
    - "POP3.pass_ uses a trailing underscore to avoid collision with the Python 'pass' keyword."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table poplib.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [pop3,       POP3.__name__.__eq__,       ["POP3"],       true]
    - [pop3_ssl,   POP3_SSL.__name__.__eq__,   ["POP3_SSL"],   true]
    - [error_proto, error_proto.__name__.__eq__, ["error_proto"], true]

# ---------------------------------------------------------------------------
# Module check
# ---------------------------------------------------------------------------

invariant poplib.module.POP3:
  description: "poplib.POP3.__module__ == 'poplib'"
  category: module
  kind: python_call_eq
  function: POP3.__module__.__eq__
  args: ["poplib"]
  expected: true

# ---------------------------------------------------------------------------
# Class attributes: port numbers
# ---------------------------------------------------------------------------

invariant poplib.port.pop3:
  description: "poplib.POP3.port == 110 — standard POP3 port"
  category: constants
  kind: python_call_eq
  function: POP3.port.__eq__
  args: [110]
  expected: true

invariant poplib.port.pop3_ssl:
  description: "poplib.POP3_SSL.port == 995 — standard POP3S port"
  category: constants
  kind: python_call_eq
  function: POP3_SSL.port.__eq__
  args: [995]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy
# ---------------------------------------------------------------------------

invariant poplib.hierarchy.error_proto_base:
  description: "poplib.error_proto.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: error_proto.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# POP3 method name checks
# ---------------------------------------------------------------------------

table poplib.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [user,  POP3.user.__name__.__eq__,  ["user"],  true]
    - [pass_, POP3.pass_.__name__.__eq__, ["pass_"], true]
    - [stat,  POP3.stat.__name__.__eq__,  ["stat"],  true]
    - [list,  POP3.list.__name__.__eq__,  ["list"],  true]
    - [retr,  POP3.retr.__name__.__eq__,  ["retr"],  true]
    - [dele,  POP3.dele.__name__.__eq__,  ["dele"],  true]
    - [quit,  POP3.quit.__name__.__eq__,  ["quit"],  true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T10:45:55Z
  iterations: 1
  pass_count: 14
  fail_count: 0
  total_invariants: 14
  notes: Synthesis succeeded in 1 iteration(s). 14 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
