spec: pathlib_extra133
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __code__.co_consts.__len__() values for key methods."
    - "Path.open.__code__.co_consts.__len__() = 2 — co_consts contains the docstring and the string 'b'."
    - "Path.read_text.__code__.co_consts.__len__() = 4 — co_consts contains docstring, 'r', a tuple of kwarg names, and None."
    - "Path.write_text.__code__.co_consts.__len__() = 5 — co_consts contains docstring, error format, 'w', kwarg tuple, None."
    - "Path.mkdir.__code__.co_consts.__len__() = 5 — co_consts contains docstring, True, kwarg tuple, False, None."
    - "Path.exists.__code__.co_consts.__len__() = 1 — co_consts contains only the docstring."
    - "Path.is_file.__code__.co_consts.__len__() = 3 — co_consts contains docstring, kwarg tuple, False."
    - "Path.stat.__code__.co_consts.__len__() = 2 — co_consts contains docstring and kwarg tuple."
    - "Path.unlink.__code__.co_consts.__len__() = 2 — co_consts contains docstring and None."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method co_consts lengths
# open co_consts len=2 (docstring, 'b').
# read_text co_consts len=4 (docstring, 'r', kwarg-name-tuple, None).
# write_text co_consts len=5 (docstring, error-fmt, 'w', kwarg-name-tuple, None).
# ---------------------------------------------------------------------------

table pathlib_extra133.Path_io_method_co_consts:
  description: "pathlib.Path I/O method __code__.co_consts.__len__(): open=2, read_text=4, write_text=5"
  kind: python_call_eq
  category: code_consts
  id_prefix: pathlibcoconsts133

  columns: [id, function, args, expected]
  rows:
    - [open_coconsts_len,       Path.open.__code__.co_consts.__len__,       [], 2]
    - [open_not_1,              Path.open.__code__.co_consts.__len__,       [], 2]
    - [read_text_coconsts_len,  Path.read_text.__code__.co_consts.__len__,  [], 4]
    - [write_text_coconsts_len, Path.write_text.__code__.co_consts.__len__, [], 5]
    - [open_consts_has_b,       "Path.open.__code__.co_consts.__contains__",  ["b"], true]
    - [read_text_consts_has_r,  "Path.read_text.__code__.co_consts.__contains__", ["r"], true]
    - [write_text_consts_has_w, "Path.write_text.__code__.co_consts.__contains__", ["w"], true]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem method co_consts lengths
# mkdir co_consts len=5 (docstring, True, kwarg-tuple, False, None).
# exists co_consts len=1 (docstring only).
# is_file co_consts len=3 (docstring, kwarg-tuple, False).
# ---------------------------------------------------------------------------

table pathlib_extra133.Path_fs_method_co_consts:
  description: "pathlib.Path filesystem method __code__.co_consts.__len__(): mkdir=5, exists=1, is_file=3"
  kind: python_call_eq
  category: code_consts
  id_prefix: pathlibcoconsts133

  columns: [id, function, args, expected]
  rows:
    - [mkdir_coconsts_len,    Path.mkdir.__code__.co_consts.__len__,    [], 5]
    - [exists_coconsts_len,   Path.exists.__code__.co_consts.__len__,   [], 1]
    - [is_file_coconsts_len,  Path.is_file.__code__.co_consts.__len__,  [], 3]
    - [mkdir_consts_has_true, "Path.mkdir.__code__.co_consts.__contains__",   [true], true]
    - [mkdir_consts_has_false,"Path.mkdir.__code__.co_consts.__contains__",   [false], true]
    - [is_file_consts_has_false, "Path.is_file.__code__.co_consts.__contains__", [false], true]

# ---------------------------------------------------------------------------
# pathlib.Path stat and unlink co_consts lengths
# stat co_consts len=2 (docstring, kwarg-tuple ('follow_symlinks',)).
# unlink co_consts len=2 (docstring, None).
# ---------------------------------------------------------------------------

table pathlib_extra133.Path_stat_unlink_co_consts:
  description: "pathlib.Path stat and unlink method __code__.co_consts.__len__(): stat=2, unlink=2"
  kind: python_call_eq
  category: code_consts
  id_prefix: pathlibcoconsts133

  columns: [id, function, args, expected]
  rows:
    - [stat_coconsts_len,   Path.stat.__code__.co_consts.__len__,   [], 2]
    - [unlink_coconsts_len, Path.unlink.__code__.co_consts.__len__, [], 2]
    - [stat_consts_has_none, "Path.stat.__code__.co_consts.__contains__",   [null], false]
    - [unlink_consts_has_none,"Path.unlink.__code__.co_consts.__contains__", [null], true]
    - [stat_write_text_differ, Path.stat.__code__.co_consts.__len__, [], 2]
    - [exists_is_file_differ,  Path.exists.__code__.co_consts.__len__, [], 1]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra133.Path.open_co_consts_len_2:
  description: "pathlib.Path.open.__code__.co_consts.__len__() == 2 (co_consts contains the docstring and the literal 'b' used in mode checking)"
  category: code_consts
  kind: python_call_eq
  function: Path.open.__code__.co_consts.__len__
  args: []
  expected: 2

invariant pathlib_extra133.Path.read_text_co_consts_len_4:
  description: "pathlib.Path.read_text.__code__.co_consts.__len__() == 4 (co_consts contains docstring, 'r', kwarg-name tuple, and None)"
  category: code_consts
  kind: python_call_eq
  function: Path.read_text.__code__.co_consts.__len__
  args: []
  expected: 4

invariant pathlib_extra133.Path.write_text_co_consts_len_5:
  description: "pathlib.Path.write_text.__code__.co_consts.__len__() == 5 (co_consts contains docstring, error format string, 'w', kwarg-name tuple, None)"
  category: code_consts
  kind: python_call_eq
  function: Path.write_text.__code__.co_consts.__len__
  args: []
  expected: 5

invariant pathlib_extra133.Path.mkdir_co_consts_len_5:
  description: "pathlib.Path.mkdir.__code__.co_consts.__len__() == 5 (co_consts contains docstring, True, kwarg-name tuple, False, None)"
  category: code_consts
  kind: python_call_eq
  function: Path.mkdir.__code__.co_consts.__len__
  args: []
  expected: 5

invariant pathlib_extra133.Path.exists_co_consts_len_1:
  description: "pathlib.Path.exists.__code__.co_consts.__len__() == 1 (co_consts contains only the docstring; exists delegates entirely to os.stat)"
  category: code_consts
  kind: python_call_eq
  function: Path.exists.__code__.co_consts.__len__
  args: []
  expected: 1
