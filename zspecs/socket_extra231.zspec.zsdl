spec: socket_extra231
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — qualname has socket class prefix (14 characters)."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — qualname is 'socket.bind' (11 characters)."
    - "socket.socket.send.__qualname__ == 'socket.send' — qualname is 'socket.send' (11 characters)."
    - "socket.socket.recv.__qualname__ == 'socket.recv' — qualname is 'socket.recv' (11 characters)."
    - "socket.socket.close.__qualname__ == 'socket.close' — qualname is 'socket.close' (12 characters)."
    - "socket.socket.accept.__qualname__ == 'socket.accept' — qualname is 'socket.accept' (13 characters)."
    - "socket.socket.listen.__qualname__ == 'socket.listen' — qualname is 'socket.listen' (13 characters)."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' — qualname is 'socket.setsockopt' (17 characters)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket instance method qualname contracts — connect/bind/send/recv
#
# socket.socket.connect.__qualname__  == 'socket.connect'
# socket.socket.bind.__qualname__     == 'socket.bind'
# socket.socket.send.__qualname__     == 'socket.send'
# socket.socket.recv.__qualname__     == 'socket.recv'
#
# socket.socket is the primary socket class. Its method qualnames use the
# lowercase 'socket.' class prefix (note: the class is named 'socket',
# not 'Socket'). connect() establishes a connection; bind() assigns a local
# address; send() transmits data; recv() receives data.
# ---------------------------------------------------------------------------

table socket_extra231.socket_method_qualnames_group1:
  description: "socket.connect.__qualname__=='socket.connect'; bind.__qualname__=='socket.bind'; send.__qualname__=='socket.send'; recv.__qualname__=='socket.recv'; method qualname contracts; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: socket231

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qualname_eq,
       "socket.connect.__qualname__.__eq__",
       ["socket.connect"],
       true,
       "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — connect qualname uses the lowercase 'socket.' class prefix; 'socket.connect' is 14 characters; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [bind_qualname_eq,
       "socket.bind.__qualname__.__eq__",
       ["socket.bind"],
       true,
       "socket.socket.bind.__qualname__.__eq__('socket.bind') == True — bind qualname is 'socket.bind' (11 characters); same length as send and recv qualnames; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [send_qualname_eq,
       "socket.send.__qualname__.__eq__",
       ["socket.send"],
       true,
       "socket.socket.send.__qualname__.__eq__('socket.send') == True — send qualname is 'socket.send' (11 characters); same length as bind and recv qualnames; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [recv_qualname_eq,
       "socket.recv.__qualname__.__eq__",
       ["socket.recv"],
       true,
       "socket.socket.recv.__qualname__.__eq__('socket.recv') == True — recv qualname is 'socket.recv' (11 characters); same length as bind and send qualnames; new anchor in extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket instance method qualname contracts — close/accept/listen/setsockopt
#
# socket.socket.close.__qualname__     == 'socket.close'
# socket.socket.accept.__qualname__    == 'socket.accept'
# socket.socket.listen.__qualname__    == 'socket.listen'
# socket.socket.setsockopt.__qualname__ == 'socket.setsockopt'
#
# close() releases the socket; accept() accepts an incoming connection;
# listen() marks the socket for passive connection acceptance;
# setsockopt() sets a socket-level option.
# ---------------------------------------------------------------------------

table socket_extra231.socket_method_qualnames_group2:
  description: "socket.close.__qualname__=='socket.close'; accept.__qualname__=='socket.accept'; listen.__qualname__=='socket.listen'; setsockopt.__qualname__=='socket.setsockopt'; method qualname contracts; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: socket231a

  columns: [id, function, args, expected, description]
  rows:
    - [close_qualname_eq,
       "socket.close.__qualname__.__eq__",
       ["socket.close"],
       true,
       "socket.socket.close.__qualname__.__eq__('socket.close') == True — close qualname is 'socket.close' (12 characters); new anchor in extra231 namespace; verified Python 3.14.3"]
    - [accept_qualname_eq,
       "socket.accept.__qualname__.__eq__",
       ["socket.accept"],
       true,
       "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — accept qualname is 'socket.accept' (13 characters); same length as listen qualname; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [listen_qualname_eq,
       "socket.listen.__qualname__.__eq__",
       ["socket.listen"],
       true,
       "socket.socket.listen.__qualname__.__eq__('socket.listen') == True — listen qualname is 'socket.listen' (13 characters); same length as accept qualname; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [setsockopt_qualname_eq,
       "socket.setsockopt.__qualname__.__eq__",
       ["socket.setsockopt"],
       true,
       "socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') == True — setsockopt qualname is 'socket.setsockopt' (17 characters); longest of the listed method qualnames; new anchor in extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket method qualname length contracts
#
# len('socket.connect')   == 14
# len('socket.bind')      == 11
# len('socket.send')      == 11
# len('socket.recv')      == 11
# len('socket.close')     == 12
# len('socket.accept')    == 13
# len('socket.listen')    == 13
# len('socket.setsockopt') == 17
#
# These length anchors verify the correct qualname string lengths.
# The 'socket.' prefix is always 7 characters.
# ---------------------------------------------------------------------------

table socket_extra231.socket_method_qualname_lengths:
  description: "connect qualname len==14; bind/send/recv qualname len==11; close len==12; accept/listen len==13; setsockopt len==17; qualname length contracts; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: socket231b

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qualname_len_14,
       "socket.connect.__qualname__.__len__",
       [],
       14,
       "socket.socket.connect.__qualname__.__len__() == 14 — 'socket.connect' has 14 characters: 'socket.' (7) + 'connect' (7); portable length anchor; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [bind_qualname_len_11,
       "socket.bind.__qualname__.__len__",
       [],
       11,
       "socket.socket.bind.__qualname__.__len__() == 11 — 'socket.bind' has 11 characters: 'socket.' (7) + 'bind' (4); same length as send and recv qualnames; portable length anchor; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [close_qualname_len_12,
       "socket.close.__qualname__.__len__",
       [],
       12,
       "socket.socket.close.__qualname__.__len__() == 12 — 'socket.close' has 12 characters: 'socket.' (7) + 'close' (5); portable length anchor; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [accept_qualname_len_13,
       "socket.accept.__qualname__.__len__",
       [],
       13,
       "socket.socket.accept.__qualname__.__len__() == 13 — 'socket.accept' has 13 characters: 'socket.' (7) + 'accept' (6); same length as listen qualname; portable length anchor; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [setsockopt_qualname_len_17,
       "socket.setsockopt.__qualname__.__len__",
       [],
       17,
       "socket.socket.setsockopt.__qualname__.__len__() == 17 — 'socket.setsockopt' has 17 characters: 'socket.' (7) + 'setsockopt' (10); longest listed qualname; portable length anchor; new anchor in extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra231.connect_qualname_eq:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — socket.connect establishes a connection to the remote address; its __qualname__ is 'socket.connect' (14 characters), using the lowercase class name 'socket' as prefix (note: the class is named 'socket', same as the module); the qualname format is '<class>.<method>' where class is the 6-character lowercase 'socket'; 'socket.connect' is the longest of the send/recv/bind/connect group; extra231 is the first namespace to anchor socket.socket.connect.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "socket.connect.__qualname__.__eq__"
  args: ["socket.connect"]
  expected: true

invariant socket_extra231.setsockopt_qualname_eq:
  description: "socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') == True — socket.setsockopt sets the value of the given socket option; its __qualname__ is 'socket.setsockopt' (17 characters), composed of the 'socket.' prefix (7 characters) and 'setsockopt' (10 characters); this is the longest qualname among the commonly used socket instance methods; extra231 is the first namespace to anchor socket.socket.setsockopt.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "socket.setsockopt.__qualname__.__eq__"
  args: ["socket.setsockopt"]
  expected: true

invariant socket_extra231.accept_qualname_len_13:
  description: "socket.socket.accept.__qualname__.__len__() == 13 — the qualname 'socket.accept' has 13 characters: the 'socket.' prefix (7 characters) plus 'accept' (6 characters); socket.accept() accepts a connection on a listening socket and returns a (conn, address) pair; the qualname length 13 is shared with socket.listen (both have 6-character method names following the 7-character prefix); extra231 is the first namespace to anchor this qualname length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "socket.accept.__qualname__.__len__"
  args: []
  expected: 13
