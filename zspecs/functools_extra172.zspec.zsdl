invariant functools_extra172.wrapper_assignments_contains_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is the second element of WRAPPER_ASSIGNMENTS; wave 296; new to extra172"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra172.wrapper_assignments_contains_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of WRAPPER_ASSIGNMENTS; wave 296; new to extra172"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools_extra172.wrapper_assignments_len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14.3; wave 296; new to extra172"
