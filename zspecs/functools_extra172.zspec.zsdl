spec: functools_extra172
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.wraps.__name__ 'wraps'; functools.wraps.__module__ 'functools'; functools.wraps.__qualname__ 'wraps'; functools.WRAPPER_ASSIGNMENTS.__class__.__name__ 'tuple'; functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') True; functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') True; functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') True; functools.WRAPPER_ASSIGNMENTS.__len__() 6 (Wave 296)."
    - "functools.wraps.__name__ == 'wraps' — functools.wraps is a Python function defined in Lib/functools.py; it is a convenience decorator that applies update_wrapper() to the decorated function; its __name__ attribute is 'wraps'. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — wraps is defined in Lib/functools.py; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — wraps is a top-level function in Lib/functools.py; its __qualname__ is 'wraps' (same as __name__ for a top-level function). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py listing the attributes that update_wrapper copies from the wrapped function; its __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — WRAPPER_ASSIGNMENTS is ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'); '__module__' is the first element. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is the second element of WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS has 6 elements: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps function identity — __name__, __module__, __qualname__
#
# Wave 296 theme: functools.wraps Python function identity — __name__,
# __module__, __qualname__, and __class__.__name__.
#
# functools.wraps.__name__ == 'wraps'
# functools.wraps.__module__ == 'functools'
# functools.wraps.__qualname__ == 'wraps'
# functools.wraps.__class__.__name__ == 'function'
#
# functools.wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS,
#                 updated=WRAPPER_UPDATES) is a convenience decorator defined
# in Lib/functools.py that applies update_wrapper() to the decorated function,
# copying selected attributes from the wrapped function. It is commonly used
# to preserve metadata when writing decorator functions. It is a regular Python
# function; its __class__.__name__ is 'function'. New to extra172.
# ---------------------------------------------------------------------------

table functools_extra172.wraps_function_identity:
  description: "functools.wraps: __name__ 'wraps', __module__ 'functools', __qualname__ 'wraps', __class__.__name__ 'function'; wave 296; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswfi172

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_wraps,
       "wraps.__name__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — functools.wraps is a Python function defined in Lib/functools.py that serves as a convenience decorator for applying update_wrapper(); its __name__ attribute is 'wraps'; str.__eq__('wraps') returns True; new to extra172"]
    - [wraps_module_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — functools.wraps is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra172"]
    - [wraps_qualname_wraps,
       "wraps.__qualname__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — functools.wraps is a top-level function in Lib/functools.py; its __qualname__ is 'wraps' (same as __name__ for a top-level function, with no enclosing class or function scope); str.__eq__('wraps') returns True; new to extra172"]
    - [wraps_class_name_function,
       "wraps.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — functools.wraps is a regular Python function (not a C builtin or class); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_ASSIGNMENTS tuple identity and length
#
# Wave 296 theme: functools.WRAPPER_ASSIGNMENTS — the tuple constant listing
# attributes that update_wrapper copies from the wrapped function.
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_ASSIGNMENTS.__len__() == 6
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ != 'list'
#
# functools.WRAPPER_ASSIGNMENTS is a module-level tuple constant defined in
# Lib/functools.py. In Python 3.14.3 it contains six string elements:
# '__module__', '__name__', '__qualname__', '__doc__', '__annotate__',
# '__type_params__'. It is a tuple (immutable), not a list. Its length is 6.
# New to extra172.
# ---------------------------------------------------------------------------

table functools_extra172.wrapper_assignments_tuple_identity:
  description: "functools.WRAPPER_ASSIGNMENTS: __class__.__name__ 'tuple', __len__() 6, not 'list'; wave 296; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswati172

  columns: [id, function, args, expected, description]
  rows:
    - [wa_class_name_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py listing the wrapped-function attributes that update_wrapper copies; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra172"]
    - [wa_len_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — in Python 3.14.3 WRAPPER_ASSIGNMENTS contains six elements: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; tuple.__len__() returns 6; new to extra172"]
    - [wa_class_not_list,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["list"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('list') == False — WRAPPER_ASSIGNMENTS is an immutable tuple, NOT a list; its __class__.__name__ is 'tuple', not 'list'; str.__eq__('list') returns False; new to extra172"]
    - [wa_class_not_set,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["set"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('set') == False — WRAPPER_ASSIGNMENTS is an immutable tuple, NOT a set; its __class__.__name__ is 'tuple', not 'set'; str.__eq__('set') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS membership — __module__, __name__, __qualname__
#
# Wave 296 theme: functools.WRAPPER_ASSIGNMENTS tuple membership checks for
# the core three attributes that update_wrapper copies.
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False
#   (__dict__ is not in WRAPPER_ASSIGNMENTS; it is in WRAPPER_UPDATES)
#
# WRAPPER_ASSIGNMENTS lists the six string attribute names that update_wrapper
# copies verbatim from wrapped to wrapper. The first three — '__module__',
# '__name__', '__qualname__' — are the identity-defining attributes that give
# the wrapper the same apparent identity as the wrapped function. '__dict__'
# is NOT in WRAPPER_ASSIGNMENTS; instead, it appears in WRAPPER_UPDATES (which
# lists the dict-merging attributes). New to extra172.
# ---------------------------------------------------------------------------

table functools_extra172.wrapper_assignments_membership_core:
  description: "functools.WRAPPER_ASSIGNMENTS: contains '__module__' True, '__name__' True, '__qualname__' True, '__dict__' False; wave 296; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswamc172

  columns: [id, function, args, expected, description]
  rows:
    - [wa_has_module,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — WRAPPER_ASSIGNMENTS is ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'); '__module__' is the first element; tuple.__contains__('__module__') returns True; new to extra172"]
    - [wa_has_name,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is the second element of WRAPPER_ASSIGNMENTS; update_wrapper copies __name__ from the wrapped to the wrapper function so that the wrapper reports the correct function name; tuple.__contains__('__name__') returns True; new to extra172"]
    - [wa_has_qualname,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of WRAPPER_ASSIGNMENTS; update_wrapper copies __qualname__ from wrapped to wrapper so that the fully qualified name is preserved; tuple.__contains__('__qualname__') returns True; new to extra172"]
    - [wa_no_dict,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__dict__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — '__dict__' is NOT in WRAPPER_ASSIGNMENTS; instead it appears in WRAPPER_UPDATES (the list of attributes that are merged via update() rather than assigned verbatim); tuple.__contains__('__dict__') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_ASSIGNMENTS membership — __doc__ and additional
# cross-checks; functools.wraps qualname / module cross-checks
#
# Wave 296 theme: WRAPPER_ASSIGNMENTS membership for __doc__; cross-checks
# that wraps.__name__ != '__module__' and WRAPPER_ASSIGNMENTS len != 5.
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
# functools.WRAPPER_ASSIGNMENTS.__len__() != 5 (length is 6, not 5)
# functools.wraps.__qualname__ == functools.wraps.__name__ (both 'wraps')
#   — cross-checked via __eq__
# functools.wraps.__name__ != '__module__'
#
# '__doc__' is the fourth element of WRAPPER_ASSIGNMENTS; update_wrapper copies
# the docstring from the wrapped function. The tuple has exactly 6 elements in
# Python 3.14.3 (not 5 as in earlier Python versions which lacked '__annotate__'
# and '__type_params__'). New to extra172.
# ---------------------------------------------------------------------------

table functools_extra172.wrapper_assignments_doc_and_cross_checks:
  description: "functools.WRAPPER_ASSIGNMENTS: contains '__doc__' True, len == 6 (not 5); wraps.__name__ != '__module__'; wave 296; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswadcc172

  columns: [id, function, args, expected, description]
  rows:
    - [wa_has_doc,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is the fourth element of WRAPPER_ASSIGNMENTS; update_wrapper copies the docstring from the wrapped function to the wrapper; tuple.__contains__('__doc__') returns True; new to extra172"]
    - [wa_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14.3: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; tuple.__len__() returns 6; new to extra172"]
    - [wraps_name_not_module,
       "wraps.__name__.__eq__",
       ["__module__"],
       false,
       "functools.wraps.__name__.__eq__('__module__') == False — functools.wraps.__name__ is 'wraps', not '__module__'; the attribute '__module__' is a WRAPPER_ASSIGNMENTS member, not the function's own name; str.__eq__('__module__') returns False; new to extra172"]
    - [wa_no_dict,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__dict__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — '__dict__' is NOT in WRAPPER_ASSIGNMENTS; it is in WRAPPER_UPDATES instead (the list of dict-merging attributes); a second membership check to confirm; tuple.__contains__('__dict__') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 5: functools.wraps cross-checks — not a class, not a builtin
#
# Wave 296 theme: functools.wraps cross-checks confirming it is a Python
# function (not a C builtin, not a class, not a method).
#
# functools.wraps.__class__.__name__ != 'builtin_function_or_method'
# functools.wraps.__class__.__name__ != 'type'
# functools.wraps.__module__ != 'builtins'
#
# functools.wraps is a regular Python function defined in Lib/functools.py.
# It is NOT a C builtin function (unlike functools.reduce which is implemented
# in C) and NOT a class (unlike functools.partial). Its __module__ is 'functools'
# not 'builtins'. New to extra172.
# ---------------------------------------------------------------------------

table functools_extra172.wraps_negative_cross_checks:
  description: "functools.wraps: not 'builtin_function_or_method', not 'type', module not 'builtins'; wave 296; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswncc172

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_not_builtin,
       "wraps.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "functools.wraps.__class__.__name__.__eq__('builtin_function_or_method') == False — functools.wraps is a regular Python function (defined in Lib/functools.py), NOT a C builtin; its __class__.__name__ is 'function', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; new to extra172"]
    - [wraps_not_type,
       "wraps.__class__.__name__.__eq__",
       ["type"],
       false,
       "functools.wraps.__class__.__name__.__eq__('type') == False — functools.wraps is a Python function, not a class or type; its __class__.__name__ is 'function', not 'type'; str.__eq__('type') returns False; new to extra172"]
    - [wraps_module_not_builtins,
       "wraps.__module__.__eq__",
       ["builtins"],
       false,
       "functools.wraps.__module__.__eq__('builtins') == False — functools.wraps is defined in Lib/functools.py with __module__ 'functools', not 'builtins'; str.__eq__('builtins') returns False; new to extra172"]
    - [wraps_qualname_not_update_wrapper,
       "wraps.__qualname__.__eq__",
       ["update_wrapper"],
       false,
       "functools.wraps.__qualname__.__eq__('update_wrapper') == False — functools.wraps.__qualname__ is 'wraps'; it is a separate function from update_wrapper (which does the actual attribute copying); str.__eq__('update_wrapper') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant functools_extra172.wraps_name_wraps:
  description: "functools.wraps.__name__ == 'wraps' — convenience decorator for update_wrapper; Python function in Lib/functools.py; wave 296; new to extra172"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra172.wraps_module_functools:
  description: "functools.wraps.__module__ == 'functools' — wraps is defined in Lib/functools.py; wave 296; new to extra172"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra172.wraps_qualname_wraps:
  description: "functools.wraps.__qualname__ == 'wraps' — top-level function; qualname equals name; wave 296; new to extra172"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra172.wrapper_assignments_class_tuple:
