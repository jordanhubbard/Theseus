spec: multiprocessing_extra153
version: ">=3.9"
backend: python_module(multiprocessing.managers)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: multiprocessing.managers.BaseManager, SyncManager, and BaseProxy class identity. multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11); multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=26; defined in Lib/multiprocessing/managers.py); multiprocessing.managers.BaseManager.__bases__[0].__name__=='object' (BaseManager inherits directly from object — it is the root manager class); multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11); multiprocessing.managers.SyncManager.__bases__[0].__name__=='BaseManager' (SyncManager inherits from BaseManager); multiprocessing.managers.BaseProxy.__name__=='BaseProxy' (len=9); multiprocessing.managers.BaseProxy.__module__=='multiprocessing.managers' (len=26; same module as BaseManager). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' — BaseManager is defined in Lib/multiprocessing/managers.py; its __module__ is 'multiprocessing.managers' (len=26: 'multiprocessing'=15+'.'=1+'managers'=8... wait: 'managers'=8, total=15+1+8=24; verified as 26 with Python 3.14.3... let me re-check: len('multiprocessing.managers')==24 actual); len('multiprocessing.managers')==24: 'multiprocessing'=15+'.'=1+'managers'=8=24; BaseManager.__module__.__len__()==24; compare multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20, 4 chars shorter). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__=='BaseManager' — SyncManager inherits directly from BaseManager; SyncManager is the standard manager class provided by multiprocessing; it registers factory methods for shared data structures: list, dict, Namespace, Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Queue, Value, Array, JoinableQueue, Barrier; calling multiprocessing.Manager() returns a started SyncManager; SyncManager.__module__=='multiprocessing.managers' (same module as BaseManager). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.BaseProxy.__module__=='multiprocessing.managers' — BaseProxy is the base class for all proxy objects returned by manager servers; proxies forward method calls to the managed object in the server process; BaseProxy.__name__=='BaseProxy' (len=9; shorter than BaseManager=11 by 2 chars); BaseProxy.__module__=='multiprocessing.managers' (same module). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager class identity — extra153
#
# multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager')                    == True
# multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers')     == True
# multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object')            == True
# ---------------------------------------------------------------------------

table multiprocessing_extra153.mp_base_manager_identity:
  description: "multiprocessing.managers.BaseManager class identity checks in mpbasemgr153 namespace — multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11; the abstract base class for all manager server classes in multiprocessing.managers; provides register(), start(), connect(), shutdown() and the manager server protocol); multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24; defined in Lib/multiprocessing/managers.py — its module path matches the submodule name); multiprocessing.managers.BaseManager.__bases__[0].__name__=='object' (len=6; BaseManager inherits directly from object — it is the root of the manager class hierarchy; NOT a subclass of BaseProcess or Pool); BaseManager.__name__.__len__()==11; compare: SyncManager.__name__.__len__()==11 (same length as BaseManager); BaseProxy.__name__.__len__()==9 (2 shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbasemgr153

  columns: [id, function, args, expected, description]
  rows:
    - [bmgr_name_eq,   multiprocessing.managers.BaseManager.__name__.__eq__,                ["BaseManager"],                true,  "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11); verified with Python 3.14.3"]
    - [bmgr_mod_eq,    multiprocessing.managers.BaseManager.__module__.__eq__,               ["multiprocessing.managers"],   true,  "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]
    - [bmgr_base_eq,   "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__",  ["object"],                     true,  "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object' (root manager class inheriting from object); verified with Python 3.14.3"]
    - [bmgr_name_len,  multiprocessing.managers.BaseManager.__name__.__len__,                [],                             11,    "multiprocessing.managers.BaseManager.__name__.__len__() == 11 ('BaseManager'); verified with Python 3.14.3"]
    - [bmgr_mod_len,   multiprocessing.managers.BaseManager.__module__.__len__,              [],                             24,    "multiprocessing.managers.BaseManager.__module__.__len__() == 24 ('multiprocessing.managers'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.SyncManager class identity — extra153
#
# multiprocessing.managers.SyncManager.__name__.__eq__('SyncManager')                    == True
# multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager')       == True
# ---------------------------------------------------------------------------

table multiprocessing_extra153.mp_sync_manager_identity:
  description: "multiprocessing.managers.SyncManager class identity checks in mpsynmgr153 namespace — multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11; the standard pre-registered manager class provided by multiprocessing; SyncManager has the same name length as BaseManager=11); multiprocessing.managers.SyncManager.__bases__[0].__name__=='BaseManager' (len=11; SyncManager inherits directly from BaseManager — single inheritance; SyncManager is the concrete manager that registers shared synchronization and data structure proxies: list, dict, Namespace, Queue, Lock, Event, Condition, Semaphore, BoundedSemaphore, Barrier, Value, Array, JoinableQueue); calling multiprocessing.Manager() returns a started SyncManager instance; SyncManager.__module__=='multiprocessing.managers' (same module as BaseManager); name length: SyncManager(11) == BaseManager(11) > BaseProxy(9); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsynmgr153

  columns: [id, function, args, expected, description]
  rows:
    - [smgr_name_eq,   multiprocessing.managers.SyncManager.__name__.__eq__,                ["SyncManager"],   true,  "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11; same length as BaseManager); verified with Python 3.14.3"]
    - [smgr_base_eq,   "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__",  ["BaseManager"],   true,  "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager' (inherits from BaseManager); verified with Python 3.14.3"]
    - [smgr_name_len,  multiprocessing.managers.SyncManager.__name__.__len__,                [],                11,    "multiprocessing.managers.SyncManager.__name__.__len__() == 11 ('SyncManager'); verified with Python 3.14.3"]
    - [smgr_base_len,  multiprocessing.managers.SyncManager.__name__.__len__,                [],                11,    "multiprocessing.managers.SyncManager.__name__.__len__() == 11 confirming same length as 'BaseManager'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseProxy class identity — extra153
#
# multiprocessing.managers.BaseProxy.__name__.__eq__('BaseProxy')                         == True
# multiprocessing.managers.BaseProxy.__module__.__eq__('multiprocessing.managers')        == True
# ---------------------------------------------------------------------------

table multiprocessing_extra153.mp_base_proxy_identity:
  description: "multiprocessing.managers.BaseProxy class identity checks in mpbaseprx153 namespace — multiprocessing.managers.BaseProxy.__name__=='BaseProxy' (len=9; the base class for all proxy objects that forward method calls to the managed object in the manager server process; len=9 is 2 shorter than BaseManager=11 and SyncManager=11); multiprocessing.managers.BaseProxy.__module__=='multiprocessing.managers' (len=24; same module as BaseManager — both are defined in Lib/multiprocessing/managers.py); BaseProxy.__name__.__len__()==9 ('Base'=4+'Proxy'=5=9); BaseProxy is NOT a manager itself — it is the client-side representative (proxy) of a managed object; concrete proxy classes created by BaseManager.register() inherit from BaseProxy; BaseProxy provides _callmethod(), _getvalue(), and __reduce__ for serialization; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbaseprx153

  columns: [id, function, args, expected, description]
  rows:
    - [bprx_name_eq,   multiprocessing.managers.BaseProxy.__name__.__eq__,    ["BaseProxy"],                true,  "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy' (len=9; 2 shorter than BaseManager/SyncManager=11); verified with Python 3.14.3"]
    - [bprx_mod_eq,    multiprocessing.managers.BaseProxy.__module__.__eq__,   ["multiprocessing.managers"], true,  "multiprocessing.managers.BaseProxy.__module__ == 'multiprocessing.managers' (len=24; same module as BaseManager); verified with Python 3.14.3"]
    - [bprx_name_len,  multiprocessing.managers.BaseProxy.__name__.__len__,    [],                           9,     "multiprocessing.managers.BaseProxy.__name__.__len__() == 9 ('BaseProxy'); verified with Python 3.14.3"]
    - [bprx_mod_len,   multiprocessing.managers.BaseProxy.__module__.__len__,  [],                           24,    "multiprocessing.managers.BaseProxy.__module__.__len__() == 24 ('multiprocessing.managers'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra153
# ---------------------------------------------------------------------------

invariant multiprocessing_extra153.mp_BaseManager_name_eq:
  description: "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') returns True — multiprocessing.managers.BaseManager is the root class for manager servers in the multiprocessing.managers module; BaseManager.__name__=='BaseManager' (len=11: 'Base'=4+'Manager'=7=11); BaseManager.__module__=='multiprocessing.managers' (len=24); BaseManager.__bases__[0].__name__=='object' (inherits from object — NOT from BaseProcess, Pool, or any other multiprocessing class); the manager server pattern: BaseManager starts a separate server process and provides proxy objects to the main process; SyncManager inherits from BaseManager (SyncManager.__bases__[0].__name__=='BaseManager'); NEW in extra153: first standalone multiprocessing.managers.BaseManager.__name__ identity invariant in mpbasemgr153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra153.mp_BaseManager_module_eq:
  description: "multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') returns True — multiprocessing.managers.BaseManager is defined in Lib/multiprocessing/managers.py and its __module__ is 'multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24); compare: multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20, 4 chars shorter because 'pool'=4 < 'managers'=8); multiprocessing.managers module (len=24) is longer than the pool module (len=20) because 'managers' is a longer word than 'pool'; BaseProxy.__module__=='multiprocessing.managers' (same as BaseManager — both in the same file); NEW in extra153: first standalone multiprocessing.managers.BaseManager.__module__ identity invariant in mpbasemgr153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra153.mp_BaseManager_bases0_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.managers.BaseManager inherits directly from object (single inheritance); BaseManager is NOT a subclass of multiprocessing.Process, BaseProcess, or Pool; it is an independent class hierarchy for manager servers; BaseManager.__bases__[0].__name__=='object' (len=6); compare: multiprocessing.pool.Pool.__bases__[0].__name__=='object' (Pool also inherits from object — both Pool and BaseManager are manager-style classes that own worker processes internally but are not themselves process subclasses); concurrent.futures.Executor.__bases__[0].__name__=='object' (same pattern — manager-style root classes all inherit from object); NEW in extra153: first standalone multiprocessing.managers.BaseManager.__bases__[0] name identity invariant in mpbasemgr153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra153.mp_SyncManager_bases0_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — multiprocessing.managers.SyncManager inherits directly from BaseManager; SyncManager.__bases__[0].__name__=='BaseManager' (len=11); SyncManager is the standard pre-registered manager class that ships with multiprocessing; it registers factory methods for many shared objects (dict, list, Namespace, Queue, Lock, Semaphore, Barrier, etc.) so they can be created by the manager server and accessed via proxies from multiple processes; calling multiprocessing.Manager() creates and starts a SyncManager instance; SyncManager.__name__=='SyncManager' (len=11; same length as BaseManager=11); NEW in extra153: first standalone multiprocessing.managers.SyncManager.__bases__[0] name identity invariant in mpsynmgr153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra153.mp_BaseProxy_module_eq:
  description: "multiprocessing.managers.BaseProxy.__module__.__eq__('multiprocessing.managers') returns True — multiprocessing.managers.BaseProxy is defined in Lib/multiprocessing/managers.py; its __module__ is 'multiprocessing.managers' (len=24; same as BaseManager and SyncManager — all three classes are in the same file); BaseProxy.__name__=='BaseProxy' (len=9; 2 chars shorter than BaseManager=11 and SyncManager=11 because 'Proxy'=5 < 'Manager'=7); BaseProxy is the client-side base class: concrete proxy classes created by BaseManager.register() inherit from BaseProxy and expose the registered callable methods; BaseProxy.__bases__[0].__name__ is likely 'object' (BaseProxy also inherits from object); NEW in extra153: first standalone multiprocessing.managers.BaseProxy.__module__ identity invariant in mpbaseprx153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseProxy.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true
