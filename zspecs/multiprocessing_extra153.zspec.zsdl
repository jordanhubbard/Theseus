spec: multiprocessing_extra153
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec covers multiprocessing.__all__: its type (list), length (37), and membership of key public names."
    - "multiprocessing.__all__ is a list of 37 strings; unlike asyncio (which uses a tuple), multiprocessing uses a list. Verified with Python 3.14.3."
    - "multiprocessing.__all__.__class__.__name__ == 'list' — multiprocessing uses a list for __all__. Verified with Python 3.14.3."
    - "multiprocessing.__all__.__len__() == 37 — the public API exports exactly 37 names as of Python 3.14.3."
    - "'Process' in multiprocessing.__all__ == True — Process is the central class of the multiprocessing module. Verified with Python 3.14.3."
    - "'Pool' in multiprocessing.__all__ == True — Pool provides a pool of worker processes. Verified with Python 3.14.3."
    - "'cpu_count' in multiprocessing.__all__ == True — cpu_count returns the number of CPUs. Verified with Python 3.14.3."
    - "'Manager' in multiprocessing.__all__ == True — Manager provides shared state between processes. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.__all__ type and length
