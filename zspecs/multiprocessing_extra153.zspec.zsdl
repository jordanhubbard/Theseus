# multiprocessing.__all__.__len__() == 37
# New to multiprocessing_extra153.
# ---------------------------------------------------------------------------

table multiprocessing_extra153.all_type_and_len:
  description: "multiprocessing.__all__ is a list of 37 public names; new to multiprocessing_extra153"
