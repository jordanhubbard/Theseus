spec: concurrent_futures_extra265
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "ThreadPoolExecutor.submit is defined in concurrent.futures.thread; __module__ == 'concurrent.futures.thread'."
    - "ThreadPoolExecutor.map inherits from Executor; its __qualname__ == 'Executor.map'."
    - "Executor base methods (submit, map, shutdown, __enter__, __exit__) have __module__ == 'concurrent.futures._base'."
    - "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' — overridden in the subclass."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __name__ — table
#
# Three methods of ThreadPoolExecutor: submit, map, shutdown.
# map is inherited from Executor; submit and shutdown are overridden.
# ---------------------------------------------------------------------------

table concurrent_futures_extra265.tpe_method_names:
  description: "concurrent.futures.ThreadPoolExecutor methods report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: tpename

  columns: [id, function, args, expected, description]
  rows:
    - [submit,   ThreadPoolExecutor.submit.__name__.__eq__,   ["submit"],   true, "ThreadPoolExecutor.submit.__name__ == 'submit'"]
    - [map,      ThreadPoolExecutor.map.__name__.__eq__,      ["map"],      true, "ThreadPoolExecutor.map.__name__ == 'map'"]
    - [shutdown, ThreadPoolExecutor.shutdown.__name__.__eq__, ["shutdown"], true, "ThreadPoolExecutor.shutdown.__name__ == 'shutdown'"]

# ---------------------------------------------------------------------------
# Executor base method __name__ — table
#
# Five methods on the Executor base class: submit, map, shutdown,
# __enter__, __exit__. submit is abstract; the rest are concrete.
# ---------------------------------------------------------------------------

table concurrent_futures_extra265.executor_method_names:
  description: "concurrent.futures.Executor base methods report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: exname

  columns: [id, function, args, expected, description]
  rows:
    - [submit,    Executor.submit.__name__.__eq__,    ["submit"],    true, "Executor.submit.__name__ == 'submit'"]
    - [map,       Executor.map.__name__.__eq__,       ["map"],       true, "Executor.map.__name__ == 'map'"]
    - [shutdown,  Executor.shutdown.__name__.__eq__,  ["shutdown"],  true, "Executor.shutdown.__name__ == 'shutdown'"]
    - [__enter__, Executor.__enter__.__name__.__eq__, ["__enter__"], true, "Executor.__enter__.__name__ == '__enter__'"]
    - [__exit__,  Executor.__exit__.__name__.__eq__,  ["__exit__"],  true, "Executor.__exit__.__name__ == '__exit__'"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__class__.__name__ and __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra265.tpe_submit.class_name:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra265.tpe_submit.qualname:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra265.tpe_shutdown.qualname:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessPoolExecutor method identity — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra265.ppe_submit.qualname:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.submit.__qualname__.__eq__
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra265.ppe_shutdown.name:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__name__ == 'shutdown'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__name__.__eq__
  args: ["shutdown"]
  expected: true

invariant concurrent_futures_extra265.ppe_shutdown.qualname:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ProcessPoolExecutor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# Executor base method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra265.executor_submit.qualname:
  description: "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'"
  category: identity
  kind: python_call_eq
  function: Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true

invariant concurrent_futures_extra265.executor_map.qualname:
  description: "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'"
  category: identity
  kind: python_call_eq
  function: Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true
