spec: it3121
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (it3121): __ge__, __repr__, __str__ dict-presence checks for itertools types."
    - "No itertools type defines __ge__ or __str__ in its own __dict__."
    - "itertools.repeat and itertools.count define __repr__; all other itertools iterator types do not."
    - "itertools.repeat.__repr__ renders as 'repeat(val)' or 'repeat(val, n)'; itertools.count.__repr__ renders as 'count(start[, step])'."
    - "itertools iterator types are C-level types; none define __ge__ or __str__ in their own __dict__."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table it3121.ge:
  description: "itertools types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it3121
  columns: [id, function, args, expected]
  rows:
    - ["it3121001", operator.contains, [itertools.chain.__dict__,                        "__ge__"], false]
