spec: inspect_extra152
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter enum-like class attributes and their string values — POSITIONAL_ONLY name/value (0), POSITIONAL_OR_KEYWORD name/value (1), VAR_POSITIONAL name/value (2), KEYWORD_ONLY name/value (3), VAR_KEYWORD name/value (4); inspect.Parameter.__module__ 'inspect', __name__ 'Parameter' (Wave 281)."
    - "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY', value == 0 — POSITIONAL_ONLY is the first _ParameterKind enum member with integer value 0. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD', value == 1 — second _ParameterKind member, value 1. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL', value == 2 — third _ParameterKind member, value 2. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY', value == 3 — fourth _ParameterKind member, value 3. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD', value == 4 — fifth _ParameterKind member, value 4. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' — the public-facing class name is 'Parameter'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind enum members — name string checks
#
# Wave 281 theme: inspect.Parameter enum-like class attributes.
#
# inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True
# inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True
# inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True
# inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True
#
# Each _ParameterKind member has a .name attribute that equals the Python
# identifier used to define it. New to extra152.
# ---------------------------------------------------------------------------

table inspect_extra152.parameter_kind_names:
  description: "inspect.Parameter kind enum .name values: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD; all __eq__ their string names; wave 281; new to extra152"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamkind152

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_eq,
       "Parameter.POSITIONAL_ONLY.name.__eq__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY is the first _ParameterKind enum member representing parameters that can only be supplied positionally (before /); .name is 'POSITIONAL_ONLY'; str.__eq__('POSITIONAL_ONLY') returns True; new to extra152"]
    - [positional_or_keyword_name_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.name.__eq__",
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — POSITIONAL_OR_KEYWORD is the second _ParameterKind member representing the default Python parameter kind (can be passed positionally or as keyword); .name is 'POSITIONAL_OR_KEYWORD'; str.__eq__('POSITIONAL_OR_KEYWORD') returns True; new to extra152"]
    - [var_positional_name_eq,
       "Parameter.VAR_POSITIONAL.name.__eq__",
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL is the third _ParameterKind member representing *args parameters; .name is 'VAR_POSITIONAL'; str.__eq__('VAR_POSITIONAL') returns True; new to extra152"]
    - [keyword_only_name_eq,
       "Parameter.KEYWORD_ONLY.name.__eq__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — KEYWORD_ONLY is the fourth _ParameterKind member representing parameters after * or *args that must be passed as keywords; .name is 'KEYWORD_ONLY'; str.__eq__('KEYWORD_ONLY') returns True; new to extra152"]
    - [var_keyword_name_eq,
       "Parameter.VAR_KEYWORD.name.__eq__",
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — VAR_KEYWORD is the fifth _ParameterKind member representing **kwargs parameters; .name is 'VAR_KEYWORD'; str.__eq__('VAR_KEYWORD') returns True; new to extra152"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind enum members — integer values
#
# Wave 281 theme: inspect.Parameter _ParameterKind enum integer values.
#
# inspect.Parameter.POSITIONAL_ONLY.value == 0
# inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1
# inspect.Parameter.VAR_POSITIONAL.value == 2
# inspect.Parameter.KEYWORD_ONLY.value == 3
# inspect.Parameter.VAR_KEYWORD.value == 4
#
# The _ParameterKind enum members have sequential integer values starting
# at 0. New to extra152.
# ---------------------------------------------------------------------------

table inspect_extra152.parameter_kind_values:
  description: "inspect.Parameter kind enum .value integers: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4; wave 281; new to extra152"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparamval152

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_value_eq_0,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY has integer value 0; it is the first member in the _ParameterKind IntEnum; int.__eq__(0) returns True; new to extra152"]
    - [positional_or_keyword_value_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD has integer value 1; it is the second member in the _ParameterKind IntEnum; int.__eq__(1) returns True; new to extra152"]
    - [var_positional_value_eq_2,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL has integer value 2; it represents *args parameters; int.__eq__(2) returns True; new to extra152"]
    - [keyword_only_value_eq_3,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY has integer value 3; it represents parameters that must be keyword-only; int.__eq__(3) returns True; new to extra152"]
    - [var_keyword_value_eq_4,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD has integer value 4; it represents **kwargs parameters; int.__eq__(4) returns True; new to extra152"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter class identity — __module__, __name__, __qualname__
#
# Wave 281 theme: inspect.Parameter class-level identity attributes.
#
# inspect.Parameter.__module__.__eq__('inspect') == True
# inspect.Parameter.__name__.__eq__('Parameter') == True
# inspect.Parameter.__qualname__.__eq__('Parameter') == True
# inspect.Parameter.__bases__[0].__name__.__eq__('object') == True
#
# Parameter is a Python class defined in Lib/inspect.py. It is the
# public-facing class for callable parameter introspection. New to extra152.
# ---------------------------------------------------------------------------

table inspect_extra152.parameter_class_identity:
  description: "inspect.Parameter class: __module__ 'inspect', __name__ 'Parameter', __qualname__ 'Parameter', __bases__[0] 'object'; wave 281; new to extra152"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamclass152

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra152"]
    - [parameter_name_eq_parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — the class name of the Parameter class is 'Parameter'; __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra152"]
    - [parameter_qualname_eq_parameter,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is defined at module scope in Lib/inspect.py; __qualname__ equals __name__ == 'Parameter'; str.__eq__('Parameter') returns True; new to extra152"]
    - ["parameter_bases_0_name_eq_object",
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra152"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant inspect_extra152.positional_only_name_eq:
  description: "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' — first _ParameterKind enum member name; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.name.__eq__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra152.positional_or_keyword_name_eq:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' — second _ParameterKind enum member name; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.name.__eq__
  args: ["POSITIONAL_OR_KEYWORD"]
  expected: true

invariant inspect_extra152.var_positional_name_eq:
  description: "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL' — third _ParameterKind enum member name; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.name.__eq__
  args: ["VAR_POSITIONAL"]
  expected: true

invariant inspect_extra152.keyword_only_name_eq:
  description: "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY' — fourth _ParameterKind enum member name; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.name.__eq__
  args: ["KEYWORD_ONLY"]
  expected: true

invariant inspect_extra152.var_keyword_name_eq:
  description: "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD' — fifth _ParameterKind enum member name; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__eq__
  args: ["VAR_KEYWORD"]
  expected: true

invariant inspect_extra152.positional_only_value_eq_0:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0 — first _ParameterKind IntEnum value; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra152.parameter_module_eq_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter class defined in Lib/inspect.py; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra152.parameter_name_eq_parameter:
  description: "inspect.Parameter.__name__ == 'Parameter' — public-facing class name for callable parameter introspection; wave 281; new to extra152"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra152.parameter_bases_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object; wave 281; new to extra152"
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
