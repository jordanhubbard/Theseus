spec: multiprocessing_extra98
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra97

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra97.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.pool.Pool class identity and method class names. NEW in extra98: Pool.__class__.__name__=='type'; Pool.__module__=='multiprocessing.pool'; Pool.__bases__[0].__name__=='object' (Pool inherits directly from object, unlike Process which inherits from BaseProcess); Pool.__mro__.__len__()==2 (MRO is [Pool, object], minimal depth); Pool.map.__class__.__name__=='function'; Pool.apply.__class__.__name__=='function'; Pool.apply_async.__class__.__name__=='function'; Pool.starmap.__class__.__name__=='function'; Pool.close.__class__.__name__=='function'; Pool.terminate.__class__.__name__=='function'; Pool.join.__class__.__name__=='function'; Pool.map.__qualname__=='Pool.map' (len=8); Pool.apply.__qualname__=='Pool.apply' (len=10); Pool.apply_async.__qualname__=='Pool.apply_async' (len=16); Pool.starmap.__qualname__=='Pool.starmap' (len=12); Pool.close.__qualname__=='Pool.close' (len=10); Pool.terminate.__qualname__=='Pool.terminate' (len=14); Pool.join.__qualname__=='Pool.join' (len=9). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__bases__[0].__name__ == 'object'. Pool inherits directly from object (MRO depth=2), unlike multiprocessing.Process which inherits from BaseProcess (MRO depth=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__module__ == 'multiprocessing.pool'. Pool is defined in Lib/multiprocessing/pool.py, distinct from the Process classes in Lib/multiprocessing/process.py and Lib/multiprocessing/context.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — extra98
#
# Wave 254 theme: multiprocessing.pool.Pool class identity and method class names.
#
# Pool.__class__.__name__ == 'type'
# Pool.__module__ == 'multiprocessing.pool'
# Pool.__bases__[0].__name__ == 'object'   (direct subclass of object)
# Pool.__mro__.__len__() == 2              [Pool, object]
# Pool.__name__ == 'Pool'    (len=4)
# Pool.__qualname__ == 'Pool' (len=4)
# ---------------------------------------------------------------------------

table multiprocessing_extra98.mp_pool_class_identity:
  description: "multiprocessing.pool.Pool class identity checks in mppoolident98 namespace — wave 254 theme: multiprocessing.pool.Pool class hierarchy; Pool is a pure-Python class defined in Lib/multiprocessing/pool.py; Pool.__class__.__name__.__eq__('type')==True (it is a class, metaclass is type); Pool.__module__.__eq__('multiprocessing.pool')==True (defined in the pool submodule, distinct from Process in context.py); Pool.__bases__[0].__name__.__eq__('object')==True (Pool inherits directly from object, unlike multiprocessing.Process which inherits from BaseProcess — Pool's simpler inheritance means it manages its own worker lifecycle without a shared base); Pool.__mro__.__len__()==2 (MRO is [Pool, object], the minimal 2-element chain — contrasts with Process.__mro__.__len__()==3 which has the intermediate BaseProcess); Pool.__name__.__eq__('Pool')==True (len=4, the shortest class name in the multiprocessing series); Pool.__qualname__.__eq__('Pool')==True (len=4, module-level class so qualname equals name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolident98

  columns: [id, function, args, expected, description]
  rows:
    - [pool_class_nm,  "multiprocessing.pool.Pool.__class__.__name__.__eq__",      ["type"],                       true, "multiprocessing.pool.Pool.__class__.__name__ == 'type' — genuine Python class; verified with Python 3.14.3"]
    - [pool_module,    "multiprocessing.pool.Pool.__module__.__eq__",               ["multiprocessing.pool"],       true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' — defined in pool.py; verified with Python 3.14.3"]
    - [pool_base0,     "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__",    ["object"],                     true, "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' — inherits directly from object; verified with Python 3.14.3"]
    - [pool_mro_len,   "multiprocessing.pool.Pool.__mro__.__len__",                 [],                             2,    "multiprocessing.pool.Pool.__mro__.__len__() == 2 — MRO is [Pool, object]; verified with Python 3.14.3"]
    - [pool_name,      "multiprocessing.pool.Pool.__name__.__eq__",                 ["Pool"],                       true, "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4); verified with Python 3.14.3"]
    - [pool_qualname,  "multiprocessing.pool.Pool.__qualname__.__eq__",             ["Pool"],                       true, "multiprocessing.pool.Pool.__qualname__ == 'Pool' (len=4, module-level class so qualname equals name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method class names — extra98
#
# All Pool methods are Python functions defined in Pool itself.
#
# Pool.map.__class__.__name__ == 'function'
# Pool.apply.__class__.__name__ == 'function'
# Pool.apply_async.__class__.__name__ == 'function'
# Pool.starmap.__class__.__name__ == 'function'
# Pool.close.__class__.__name__ == 'function'
# Pool.terminate.__class__.__name__ == 'function'
# Pool.join.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra98.mp_pool_method_class_names:
  description: "multiprocessing.pool.Pool method class name checks in mppoolident98 namespace — wave 254 theme: Pool methods are Python functions defined in Pool itself; unlike multiprocessing.Process whose methods are inherited from BaseProcess, Pool defines all its methods directly in Lib/multiprocessing/pool.py; Pool.map.__class__.__name__.__eq__('function')==True (map applies a function to every item in an iterable across worker processes); Pool.apply.__class__.__name__.__eq__('function')==True (apply runs a function in a single worker, blocking until result); Pool.apply_async.__class__.__name__.__eq__('function')==True (async variant returning AsyncResult); Pool.starmap.__class__.__name__.__eq__('function')==True (like map but unpacks argument tuples); Pool.close.__class__.__name__.__eq__('function')==True (prevents new tasks from being submitted); Pool.terminate.__class__.__name__.__eq__('function')==True (immediately stops workers); Pool.join.__class__.__name__.__eq__('function')==True (waits for workers to exit after close/terminate); all seven methods have class='function' (pure-Python); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolident98a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_map_cls,        "multiprocessing.pool.Pool.map.__class__.__name__.__eq__",          ["function"], true, "multiprocessing.pool.Pool.map.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [pool_apply_cls,      "multiprocessing.pool.Pool.apply.__class__.__name__.__eq__",        ["function"], true, "multiprocessing.pool.Pool.apply.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [pool_apasync_cls,    "multiprocessing.pool.Pool.apply_async.__class__.__name__.__eq__",  ["function"], true, "multiprocessing.pool.Pool.apply_async.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [pool_starmap_cls,    "multiprocessing.pool.Pool.starmap.__class__.__name__.__eq__",      ["function"], true, "multiprocessing.pool.Pool.starmap.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [pool_close_cls,      "multiprocessing.pool.Pool.close.__class__.__name__.__eq__",        ["function"], true, "multiprocessing.pool.Pool.close.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [pool_terminate_cls,  "multiprocessing.pool.Pool.terminate.__class__.__name__.__eq__",    ["function"], true, "multiprocessing.pool.Pool.terminate.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [pool_join_cls,       "multiprocessing.pool.Pool.join.__class__.__name__.__eq__",         ["function"], true, "multiprocessing.pool.Pool.join.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method qualnames — extra98
#
# All qualnames have 'Pool.' prefix (methods defined directly in Pool).
#
# Pool.map.__qualname__         == 'Pool.map'         (len=8)
# Pool.apply.__qualname__       == 'Pool.apply'       (len=10)
# Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16)
# Pool.starmap.__qualname__     == 'Pool.starmap'     (len=12)
# Pool.close.__qualname__       == 'Pool.close'       (len=10)
# Pool.terminate.__qualname__   == 'Pool.terminate'   (len=14)
# Pool.join.__qualname__        == 'Pool.join'        (len=9)
# ---------------------------------------------------------------------------

table multiprocessing_extra98.mp_pool_method_qualnames:
  description: "multiprocessing.pool.Pool method __qualname__ checks in mppoolident98 namespace — wave 254 theme: Pool method qualnames all use 'Pool.' prefix (length=5); since Pool defines all methods directly (not inheriting from a base class like Process inherits from BaseProcess), all qualnames use 'Pool.' as the prefix; Pool.map.__qualname__.__eq__('Pool.map')==True (len=8: 'Pool.'=5 + 'map'=3, the shortest Pool method qualname); Pool.join.__qualname__.__eq__('Pool.join')==True (len=9: 'Pool.'=5 + 'join'=4); Pool.apply.__qualname__.__eq__('Pool.apply')==True (len=10: 'Pool.'=5 + 'apply'=5); Pool.close.__qualname__.__eq__('Pool.close')==True (len=10: same as apply); Pool.starmap.__qualname__.__eq__('Pool.starmap')==True (len=12: 'Pool.'=5 + 'starmap'=7); Pool.terminate.__qualname__.__eq__('Pool.terminate')==True (len=14: 'Pool.'=5 + 'terminate'=9); Pool.apply_async.__qualname__.__eq__('Pool.apply_async')==True (len=16: 'Pool.'=5 + 'apply_async'=11, the longest Pool method qualname); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolident98b

  columns: [id, function, args, expected, description]
  rows:
    - [pool_map_qeq,      "multiprocessing.pool.Pool.map.__qualname__.__eq__",          ["Pool.map"],         true, "Pool.map.__qualname__ == 'Pool.map' (len=8, shortest); verified with Python 3.14.3"]
    - [pool_map_qlen,     "multiprocessing.pool.Pool.map.__qualname__.__len__",          [],                   8,    "Pool.map.__qualname__.__len__() == 8; verified with Python 3.14.3"]
    - [pool_join_qeq,     "multiprocessing.pool.Pool.join.__qualname__.__eq__",          ["Pool.join"],        true, "Pool.join.__qualname__ == 'Pool.join' (len=9); verified with Python 3.14.3"]
    - [pool_join_qlen,    "multiprocessing.pool.Pool.join.__qualname__.__len__",          [],                   9,    "Pool.join.__qualname__.__len__() == 9; verified with Python 3.14.3"]
    - [pool_apply_qeq,    "multiprocessing.pool.Pool.apply.__qualname__.__eq__",         ["Pool.apply"],       true, "Pool.apply.__qualname__ == 'Pool.apply' (len=10); verified with Python 3.14.3"]
    - [pool_apply_qlen,   "multiprocessing.pool.Pool.apply.__qualname__.__len__",        [],                   10,   "Pool.apply.__qualname__.__len__() == 10; verified with Python 3.14.3"]
    - [pool_close_qeq,    "multiprocessing.pool.Pool.close.__qualname__.__eq__",         ["Pool.close"],       true, "Pool.close.__qualname__ == 'Pool.close' (len=10, same as apply); verified with Python 3.14.3"]
    - [pool_stmap_qeq,    "multiprocessing.pool.Pool.starmap.__qualname__.__eq__",       ["Pool.starmap"],     true, "Pool.starmap.__qualname__ == 'Pool.starmap' (len=12); verified with Python 3.14.3"]
    - [pool_stmap_qlen,   "multiprocessing.pool.Pool.starmap.__qualname__.__len__",      [],                   12,   "Pool.starmap.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [pool_term_qeq,     "multiprocessing.pool.Pool.terminate.__qualname__.__eq__",     ["Pool.terminate"],   true, "Pool.terminate.__qualname__ == 'Pool.terminate' (len=14); verified with Python 3.14.3"]
    - [pool_term_qlen,    "multiprocessing.pool.Pool.terminate.__qualname__.__len__",    [],                   14,   "Pool.terminate.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [pool_apas_qeq,     "multiprocessing.pool.Pool.apply_async.__qualname__.__eq__",   ["Pool.apply_async"], true, "Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16, longest); verified with Python 3.14.3"]
    - [pool_apas_qlen,    "multiprocessing.pool.Pool.apply_async.__qualname__.__len__",  [],                   16,   "Pool.apply_async.__qualname__.__len__() == 16 (longest Pool method qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant multiprocessing_extra98.Pool_base_is_object:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') returns True — Pool inherits directly from object (MRO=[Pool, object], depth=2); this is a key structural difference from multiprocessing.Process (extra97) which inherits from BaseProcess (MRO=[Process, BaseProcess, object], depth=3); Pool's direct inheritance from object means it defines all its worker management logic internally in Lib/multiprocessing/pool.py without delegation to a base class; Pool.__module__ is 'multiprocessing.pool'; Pool.__class__.__name__ is 'type'; Pool.__mro__.__len__() is 2 (same minimal depth as asyncio.Future and concurrent.futures.Future, both of which are direct object subclasses); NEW in extra98: first standalone Pool base class invariant in mppoolident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra98.Pool_mro_len_is_2:
  description: "multiprocessing.pool.Pool.__mro__.__len__() == 2 — Pool's MRO is [Pool, object] (length=2); this minimal 2-element MRO contrasts with multiprocessing.Process (MRO depth=3, includes BaseProcess) and is the same depth as asyncio.Future (MRO=[Future, object]) and concurrent.futures.Future (MRO=[Future, object]); Pool.__module__ is 'multiprocessing.pool'; Pool.__bases__[0].__name__ is 'object'; Pool implements all seven worker-pool methods directly (map, apply, apply_async, starmap, close, terminate, join) without inheriting from any intermediate base class; the minimal MRO depth (2) means Pool has no framework inheritance chain; NEW in extra98: first standalone Pool MRO length invariant in mppoolident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra98.Pool_module_is_pool:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — Pool is defined in Lib/multiprocessing/pool.py (the 'multiprocessing.pool' submodule); this is distinct from the Process class hierarchy: Process is in 'multiprocessing.context' (context.py) and BaseProcess is in 'multiprocessing.process' (process.py); Pool's module name 'multiprocessing.pool' directly matches its submodule name; Pool.__class__.__name__ is 'type'; Pool.__bases__[0].__name__ is 'object'; all Pool methods (map, apply, apply_async, starmap, close, terminate, join) also have __module__=='multiprocessing.pool'; NEW in extra98: first standalone Pool module invariant in mppoolident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__module__.__eq__"
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra98.Pool_apply_async_qualname_longest:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__eq__('Pool.apply_async') returns True — Pool.apply_async.__qualname__ is 'Pool.apply_async' (len=16), the longest qualname among the seven core Pool methods (map=8, join=9, apply=10, close=10, starmap=12, terminate=14, apply_async=16); the longer qualname reflects the compound method name 'apply_async' (11 chars: 'apply'=5 + '_'=1 + 'async'=5); apply_async returns a multiprocessing.pool.AsyncResult object immediately without blocking, in contrast to apply which blocks; Pool.apply_async.__class__.__name__ is 'function'; Pool.apply_async.__qualname__.__len__() is 16; NEW in extra98: first standalone Pool.apply_async qualname invariant in mppoolident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.apply_async.__qualname__.__eq__"
  args: ["Pool.apply_async"]
  expected: true

invariant multiprocessing_extra98.Pool_map_qualname_shortest:
  description: "multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map') returns True — Pool.map.__qualname__ is 'Pool.map' (len=8), the shortest qualname among the seven core Pool methods; the length-8 qualname comes from 'Pool.'=5 + 'map'=3; Pool.map applies a function to every item in an iterable and returns a list of results (blocking until all complete); Pool.map.__class__.__name__ is 'function' (pure-Python); compare: Pool.map.__qualname__.__len__()==8 while Pool.apply_async.__qualname__.__len__()==16 (the longest), a ratio of 2:1 between shortest and longest Pool method qualnames; unlike multiprocessing.Process where all methods are inherited from BaseProcess (qualnames='BaseProcess.method'), Pool methods are defined directly in Pool itself (qualnames='Pool.method'); NEW in extra98: first standalone Pool.map qualname invariant in mppoolident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.map.__qualname__.__eq__"
  args: ["Pool.map"]
  expected: true
