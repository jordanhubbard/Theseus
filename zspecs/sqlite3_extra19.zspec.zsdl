spec: sqlite3_extra19
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra18.zspec.zsdl."
    - "sqlite3_extra18 covers: __qualname__.__class__.__name__ type axis for Connection, Cursor, Row, Error, OperationalError, connect; __class__.__qualname__ for sqlite_version and sqlite_version_info."
    - "sqlite3_extra14 covers: Connection/__qualname__; Cursor/__qualname__; Row/__qualname__; connect/__qualname__."
    - "sqlite3_extra5 covers: Error/__qualname__; OperationalError/__qualname__."
    - "Focus: __qualname__ for Connection and Cursor instance methods — execute, executemany, executescript, cursor, commit, rollback, close, Cursor.execute, Cursor.fetchone, Cursor.fetchall."
    - "No prior sqlite3 spec checks Connection.execute.__qualname__."
    - "No prior sqlite3 spec checks Connection.executemany.__qualname__."
    - "No prior sqlite3 spec checks Connection.executescript.__qualname__."
    - "No prior sqlite3 spec checks Connection.cursor.__qualname__."
    - "No prior sqlite3 spec checks Connection.commit.__qualname__."
    - "No prior sqlite3 spec checks Connection.rollback.__qualname__."
    - "No prior sqlite3 spec checks Connection.close.__qualname__."
    - "No prior sqlite3 spec checks Cursor.execute.__qualname__."
    - "No prior sqlite3 spec checks Cursor.fetchone.__qualname__."
    - "No prior sqlite3 spec checks Cursor.fetchall.__qualname__."
    - "sqlite3.Connection.execute.__qualname__ == 'Connection.execute' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.executemany.__qualname__ == 'Connection.executemany' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.executescript.__qualname__ == 'Connection.executescript' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.cursor.__qualname__ == 'Connection.cursor' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.commit.__qualname__ == 'Connection.commit' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.rollback.__qualname__ == 'Connection.rollback' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.close.__qualname__ == 'Connection.close' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Cursor.execute.__qualname__ == 'Cursor.execute' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Cursor.fetchone.__qualname__ == 'Cursor.fetchone' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Cursor.fetchall.__qualname__ == 'Cursor.fetchall' — C-accelerated method; compound dotted qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Connection method __qualname__ values
#
# sqlite3_extra14 checks Connection.__qualname__ == 'Connection' for the class.
# No prior sqlite3 spec checks __qualname__ for any instance method of
# Connection. For C-accelerated methods defined in class Connection, __qualname__
# uses the compound dotted form 'Connection.method'.
# ---------------------------------------------------------------------------

table sqlite3_extra19.connection_method_qualnames:
  description: "sqlite3.Connection instance methods — __qualname__ compound dotted names"
  kind: python_call_eq
  category: method_attrs
  id_prefix: sqm19c

  columns: [id, function, args, expected]
  rows:
    - [execute_qn,       "Connection.execute.__qualname__.__eq__",       ["Connection.execute"],       true]
    - [executemany_qn,   "Connection.executemany.__qualname__.__eq__",   ["Connection.executemany"],   true]
    - [executescript_qn, "Connection.executescript.__qualname__.__eq__", ["Connection.executescript"], true]
    - [cursor_qn,        "Connection.cursor.__qualname__.__eq__",        ["Connection.cursor"],        true]
    - [commit_qn,        "Connection.commit.__qualname__.__eq__",        ["Connection.commit"],        true]
    - [rollback_qn,      "Connection.rollback.__qualname__.__eq__",      ["Connection.rollback"],      true]
    - [close_qn,         "Connection.close.__qualname__.__eq__",         ["Connection.close"],         true]

# ---------------------------------------------------------------------------
# Cursor method __qualname__ values
#
# sqlite3_extra14 checks Cursor.__qualname__ == 'Cursor' for the class.
# No prior sqlite3 spec checks __qualname__ for any instance method of Cursor.
# For C-accelerated methods in class Cursor, __qualname__ == 'Cursor.method'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra19.Cursor.execute.qualname:
  description: "sqlite3.Cursor.execute.__qualname__ == 'Cursor.execute' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.execute.__qualname__.__eq__
  args: ["Cursor.execute"]
  expected: true

invariant sqlite3_extra19.Cursor.fetchone.qualname:
  description: "sqlite3.Cursor.fetchone.__qualname__ == 'Cursor.fetchone' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.fetchone.__qualname__.__eq__
  args: ["Cursor.fetchone"]
  expected: true

invariant sqlite3_extra19.Cursor.fetchall.qualname:
  description: "sqlite3.Cursor.fetchall.__qualname__ == 'Cursor.fetchall' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.fetchall.__qualname__.__eq__
  args: ["Cursor.fetchall"]
  expected: true

# ---------------------------------------------------------------------------
# Cursor method __qualname__ table
#
# Consolidates the three Cursor method qualname checks into a single table.
# All three are first covered in this spec (sqlite3_extra19).
# ---------------------------------------------------------------------------

table sqlite3_extra19.cursor_method_qualnames:
  description: "sqlite3.Cursor instance methods — __qualname__ compound dotted names"
  kind: python_call_eq
  category: method_attrs
  id_prefix: sqm19k

  columns: [id, function, args, expected]
  rows:
    - [execute_qn,  Cursor.execute.__qualname__.__eq__,  ["Cursor.execute"],  true]
    - [fetchone_qn, Cursor.fetchone.__qualname__.__eq__, ["Cursor.fetchone"], true]
    - [fetchall_qn, Cursor.fetchall.__qualname__.__eq__, ["Cursor.fetchall"], true]
