spec: types_extra25
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra24.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CodeType/ModuleType/__name__/__module__/__qualname__, SimpleNamespace/__name__/__module__/__qualname__, MappingProxyType/__name__, DynamicClassAttribute/__name__, GenericAlias/__name__, UnionType/__name__, various __bases__[0].__name__ checks, NoneType/EllipsisType/NotImplementedType, FunctionType/MethodType/GeneratorType/CodeType/ModuleType __module__, various __bases__ checks."
    - "This spec covers: __module__.__len__() for FunctionType/MethodType/GeneratorType/CodeType/ModuleType/SimpleNamespace, __name__.__len__() for FunctionType/MethodType/GeneratorType/CodeType/ModuleType/SimpleNamespace."
    - "types.FunctionType.__module__.__len__() == 8 — 'builtins' has length 8."
    - "types.MethodType.__module__.__len__() == 8 — 'builtins' has length 8."
    - "types.GeneratorType.__module__.__len__() == 8 — 'builtins' has length 8."
    - "types.CodeType.__module__.__len__() == 8 — 'builtins' has length 8."
    - "types.ModuleType.__module__.__len__() == 8 — 'builtins' has length 8."
    - "types.SimpleNamespace.__module__.__len__() == 5 — 'types' has length 5."
    - "types.FunctionType.__name__.__len__() == 8 — 'function' has length 8."
    - "types.MethodType.__name__.__len__() == 6 — 'method' has length 6."
    - "types.GeneratorType.__name__.__len__() == 9 — 'generator' has length 9."
    - "types.CodeType.__name__.__len__() == 4 — 'code' has length 4."
    - "types.ModuleType.__name__.__len__() == 6 — 'module' has length 6."
    - "types.SimpleNamespace.__name__.__len__() == 15 — 'SimpleNamespace' has length 15."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() combined table for FunctionType/MethodType/GeneratorType/
# CodeType/ModuleType/SimpleNamespace (extra25 namespace)
#
# FunctionType/MethodType/GeneratorType/CodeType/ModuleType are all C-level
# types with __module__ == 'builtins' (length 8). SimpleNamespace is a Python
# class with __module__ == 'types' (length 5). Prior specs record the __module__
# string values in types_extra24; this table exercises the __len__ call path
# for these six types together for the first time.
# ---------------------------------------------------------------------------

table types_extra25.module_lens:
  description: "__module__.__len__() for selected types module class types in the extra25 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,    FunctionType.__module__.__len__,    [], 8]
    - [MethodType,      MethodType.__module__.__len__,      [], 8]
    - [GeneratorType,   GeneratorType.__module__.__len__,   [], 8]
    - [CodeType,        CodeType.__module__.__len__,        [], 8]
    - [ModuleType,      ModuleType.__module__.__len__,      [], 8]
    - [SimpleNamespace, SimpleNamespace.__module__.__len__, [], 5]

# ---------------------------------------------------------------------------
# __name__.__len__() combined table for FunctionType/MethodType/GeneratorType/
# CodeType/ModuleType/SimpleNamespace (extra25 namespace)
#
# The C-level type __name__ values differ from the Python class names:
#   FunctionType.__name__ == 'function' (8), MethodType.__name__ == 'method' (6),
#   GeneratorType.__name__ == 'generator' (9), CodeType.__name__ == 'code' (4),
#   ModuleType.__name__ == 'module' (6), SimpleNamespace.__name__ == 'SimpleNamespace' (15).
# No prior types spec records __name__.__len__() for any of these.
# ---------------------------------------------------------------------------

table types_extra25.name_lens:
  description: "__name__.__len__() for selected types module class types in the extra25 namespace"
  kind: python_call_eq
  category: name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,    FunctionType.__name__.__len__,    [], 8]
    - [MethodType,      MethodType.__name__.__len__,      [], 6]
    - [GeneratorType,   GeneratorType.__name__.__len__,   [], 9]
    - [CodeType,        CodeType.__name__.__len__,        [], 4]
    - [ModuleType,      ModuleType.__name__.__len__,      [], 6]
    - [SimpleNamespace, SimpleNamespace.__name__.__len__, [], 15]

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__module__.__len__() == 5 — standalone (extra25 namespace)
#
# SimpleNamespace is defined in Lib/types.py; its __module__ is 'types' (length 5).
# All other types in this spec have __module__ == 'builtins' (length 8).
# Re-anchored as a standalone to emphasize the distinction from C-level types.
# ---------------------------------------------------------------------------

invariant types_extra25.SimpleNamespace.module.len:
  description: "types.SimpleNamespace.__module__.__len__() == 5 — 'types' has length 5; differs from C-level types whose __module__ is 'builtins' (length 8)"
  category: module_attrs
  kind: python_call_eq
  function: SimpleNamespace.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# types.CodeType.__name__.__len__() == 4 — standalone (extra25 namespace)
#
# CodeType.__name__ is 'code', the shortest __name__ among the six types covered
# in this spec (length 4). Re-anchored as a standalone invariant to highlight
# that CodeType uses the minimal lowercase type name.
# ---------------------------------------------------------------------------

invariant types_extra25.CodeType.name.len:
  description: "types.CodeType.__name__.__len__() == 4 — 'code' has length 4; shortest __name__ among common types module types"
  category: name_attrs
  kind: python_call_eq
  function: CodeType.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__name__.__len__() == 15 — standalone (extra25 namespace)
#
# SimpleNamespace.__name__ is 'SimpleNamespace', which has length 15. This is
# substantially longer than the C-level type names ('function' -> 8, 'generator' -> 9).
# Re-anchored as a standalone to contrast the Python-level class name length
# with the C-level type names.
# ---------------------------------------------------------------------------

invariant types_extra25.SimpleNamespace.name.len:
  description: "types.SimpleNamespace.__name__.__len__() == 15 — 'SimpleNamespace' has length 15; much longer than C-level type names like 'code' (4) or 'method' (6)"
  category: name_attrs
  kind: python_call_eq
  function: SimpleNamespace.__name__.__len__
  args: []
  expected: 15
