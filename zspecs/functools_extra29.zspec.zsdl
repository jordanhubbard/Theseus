spec: functools_extra29
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra28.zspec.zsdl."
    - "functools_extra28 covers: partial.__call__, partial.__new__; cached_property.__set_name__, cached_property.__get__; partialmethod.__get__, partialmethod; lru_cache qualname."
    - "functools_extra26 covers: combined __qualname__.__eq__ table for reduce/lru_cache/cache/wraps/total_ordering/singledispatch/cached_property/partialmethod."
    - "No prior functools spec records __qualname__.__eq__ for partial, cached_property, and singledispatch as standalone class-level qualnames in the extra29 namespace."
    - "Focus: class-level __qualname__ values for partial, cached_property, and singledispatch; these confirm module-level class definitions."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — top-level class qualnames
#
# functools.partial, cached_property, and singledispatch are all module-level
# definitions; their qualnames equal their simple names. functools_extra26
# covers singledispatch/cached_property in a combined table but not in the
# extra29 namespace. functools_extra28 covers lru_cache as a standalone.
# This table groups the three class qualnames together for the extra29 namespace.
# No prior functools spec records all three in one table in this namespace.
# ---------------------------------------------------------------------------

table functools_extra29.class_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra29.class_qualnames.partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__ == 'partial'"]
    - [functools_extra29.class_qualnames.cached_property,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__ == 'cached_property'"]
    - [functools_extra29.class_qualnames.singledispatch,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__ == 'singledispatch'"]

# ---------------------------------------------------------------------------
# partial.__qualname__.__eq__ — standalone class qualname
#
# functools.partial is a C-level type defined at module scope. Its qualname
# is 'partial', the same as its __name__, confirming it is not nested inside
# any other class or function.
# No prior functools spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra29.partial.qualname:
  description: "functools.partial.__qualname__ == 'partial'"
  category: qualnames
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

# ---------------------------------------------------------------------------
# cached_property.__qualname__.__eq__ — standalone class qualname
#
# functools.cached_property is a Python-level descriptor class defined at
# module scope in Lib/functools.py. Its qualname is 'cached_property',
# confirming it is a top-level class definition.
# No prior functools spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra29.cached_property.qualname:
  description: "functools.cached_property.__qualname__ == 'cached_property'"
  category: qualnames
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch.__qualname__.__eq__ — standalone function qualname
#
# functools.singledispatch is a Python-level function defined at module scope.
# Its qualname is 'singledispatch', equal to its __name__, confirming it is
# not a nested function or class.
# No prior functools spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra29.singledispatch.qualname:
  description: "functools.singledispatch.__qualname__ == 'singledispatch'"
  category: qualnames
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true
