spec: ctypes_extra3
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
    - "CPython source: Modules/_ctypes/"
  notes:
    - "This spec extends ctypes.zspec.zsdl, ctypes_extra.zspec.zsdl, ctypes_extra2.zspec.zsdl, ctypes_module.zspec.zsdl."
    - "Prior specs cover: __name__ for all listed types; __module__ for c_int/c_char_p/CDLL/Structure/Union/Array/c_float/c_bool/c_double/c_void_p/c_long; CDLL.__module__=='ctypes'."
    - "This spec adds __qualname__ vectors for all major ctypes classes and helpers — not previously covered in any prior ctypes spec."
    - "For top-level (non-nested) classes and functions, __qualname__ == __name__."
    - "CDLL.__qualname__ == 'CDLL' — top-level class in ctypes."
    - "Structure.__qualname__ == 'Structure' — abstract base for C struct types, defined in _ctypes."
    - "Union.__qualname__ == 'Union' — abstract base for C union types, defined in _ctypes."
    - "Array.__qualname__ == 'Array' — abstract base for ctypes array types, defined in _ctypes."
    - "c_int.__qualname__ == 'c_int' — fundamental C int wrapper."
    - "c_long.__qualname__ == 'c_long' — fundamental C long wrapper."
    - "c_char.__qualname__ == 'c_char' — fundamental C char wrapper."
    - "c_char_p.__qualname__ == 'c_char_p' — pointer to null-terminated char array."
    - "c_void_p.__qualname__ == 'c_void_p' — pointer to void."
    - "c_double.__qualname__ == 'c_double' — double-precision float wrapper."
    - "c_float.__qualname__ == 'c_float' — single-precision float wrapper."
    - "c_bool.__qualname__ == 'c_bool' — Boolean wrapper mapping C _Bool."
    - "POINTER.__qualname__ == 'POINTER' — factory function for pointer types."
    - "cast.__qualname__ == 'cast' — builtin helper for type-casting ctypes pointers."
    - "byref.__qualname__ == 'byref' — builtin helper for pass-by-reference."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table for core ctypes type classes
#
# For top-level (non-nested) classes, __qualname__ == __name__.
# Prior specs verified __name__; this spec introduces __qualname__ vectors.
# ---------------------------------------------------------------------------

table ctypes_extra3.type_qualnames:
  description: "Core ctypes type classes have correct __qualname__ (equals __name__ for top-level classes)"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [CDLL,      CDLL.__qualname__.__eq__,      ["CDLL"],      true]
    - [Structure, Structure.__qualname__.__eq__, ["Structure"], true]
    - [Union,     Union.__qualname__.__eq__,     ["Union"],     true]
    - [Array,     Array.__qualname__.__eq__,     ["Array"],     true]
    - [c_int,     c_int.__qualname__.__eq__,     ["c_int"],     true]
    - [c_long,    c_long.__qualname__.__eq__,    ["c_long"],    true]
    - [c_char,    c_char.__qualname__.__eq__,    ["c_char"],    true]
    - [c_char_p,  c_char_p.__qualname__.__eq__,  ["c_char_p"],  true]
    - [c_void_p,  c_void_p.__qualname__.__eq__,  ["c_void_p"],  true]
    - [c_double,  c_double.__qualname__.__eq__,  ["c_double"],  true]
    - [c_float,   c_float.__qualname__.__eq__,   ["c_float"],   true]
    - [c_bool,    c_bool.__qualname__.__eq__,    ["c_bool"],    true]

# ---------------------------------------------------------------------------
# __qualname__ for ctypes helper functions
#
# POINTER, cast, and byref are builtin_function_or_method objects; their
# __qualname__ equals __name__ for module-level callables.
# ---------------------------------------------------------------------------

table ctypes_extra3.helper_qualnames:
  description: "ctypes helper functions have correct __qualname__"
  kind: python_call_eq
  category: helper_qualnames
  id_prefix: hqualname

  columns: [id, function, args, expected]
  rows:
    - [POINTER, POINTER.__qualname__.__eq__, ["POINTER"], true]
    - [cast,    cast.__qualname__.__eq__,    ["cast"],    true]
    - [byref,   byref.__qualname__.__eq__,   ["byref"],   true]

# ---------------------------------------------------------------------------
# CDLL.__module__ — re-verified via __qualname__ context
#
# CDLL is defined at the Python level in ctypes; __module__ == 'ctypes'.
# Prior specs (ctypes.zspec.zsdl, ctypes_extra.zspec.zsdl, ctypes_extra2)
# checked this; included here as a cross-check alongside __qualname__.
# ---------------------------------------------------------------------------

invariant ctypes_extra3.CDLL.module_crosscheck:
  description: "ctypes.CDLL.__module__ == 'ctypes' (cross-check alongside __qualname__ spec)"
  category: module_crosscheck
  kind: python_call_eq
  function: CDLL.__module__.__eq__
  args: ["ctypes"]
  expected: true
