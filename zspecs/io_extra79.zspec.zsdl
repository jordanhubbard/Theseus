spec: io_extra79
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra78."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; RawIOBase/BufferedIOBase/TextIOBase __dict__.__class__.__name__; FileIO/__name__/__module__; BytesIO/__name__; StringIO/__name__."
    - "io_extra78 covers RawIOBase/BufferedIOBase/TextIOBase __dict__ class and membership checks; FileIO/__module__ == '_io'; concrete class names."
    - "This spec covers: FileIO/BytesIO/StringIO concrete class code attributes — __dict__ membership and class hierarchy; FileIO.__bases__[0].__name__ == '_RawIOBase'; BytesIO.__bases__[0].__name__ == '_BufferedIOBase'; StringIO.__bases__[0].__name__ == '_TextIOBase'; MRO length for all three; __dict__.__contains__ checks for read/readinto/write."
    - "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy' — C extension class dict is mappingproxy."
    - "io.FileIO.__dict__.__contains__('read') == True — FileIO has read as a C method."
    - "io.FileIO.__dict__.__contains__('readinto') == True — FileIO has readinto as a C method."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — private C base class name."
    - "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, _RawIOBase, _IOBase, object]."
    - "io.BytesIO.__dict__.__contains__('read') == True."
    - "io.BytesIO.__dict__.__contains__('write') == True."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — private C base class name."
    - "io.StringIO.__dict__.__contains__('read') == True."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — private C base class name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FileIO __dict__ class and method membership
# FileIO is a C extension type in _io; its __dict__ is a mappingproxy.
# read and readinto are present as C methods directly in FileIO.__dict__.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra79.FileIO_dict:
  description: "FileIO.__dict__ is a mappingproxy and contains read/readinto"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore79

  columns: [id, function, args, expected]
  rows:
    - [fileio_dict_class,    FileIO.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [fileio_has_read,      "FileIO.__dict__.__contains__",             ["read"],         true]
    - [fileio_has_readinto,  "FileIO.__dict__.__contains__",             ["readinto"],     true]

# ---------------------------------------------------------------------------
# BytesIO __dict__ method membership
# BytesIO is a C extension type; read and write are present in its __dict__.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra79.BytesIO_dict:
  description: "BytesIO.__dict__ contains read and write C methods"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore79

  columns: [id, function, args, expected]
  rows:
    - [bytesio_has_read,   "BytesIO.__dict__.__contains__", ["read"],  true]
    - [bytesio_has_write,  "BytesIO.__dict__.__contains__", ["write"], true]

# ---------------------------------------------------------------------------
# StringIO __dict__ method membership
# StringIO is a C extension type; read is present in its __dict__.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra79.StringIO_dict:
  description: "StringIO.__dict__ contains read C method"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore79

  columns: [id, function, args, expected]
  rows:
    - [stringio_has_read, "StringIO.__dict__.__contains__", ["read"], true]

# ---------------------------------------------------------------------------
# FileIO, BytesIO, StringIO base class names and MRO lengths
# All three are C extension classes in _io. Their direct base classes are
# private C types: _RawIOBase, _BufferedIOBase, _TextIOBase.
# Function values with [ must be double-quoted.
# ---------------------------------------------------------------------------

table io_extra79.concrete_bases_and_mro:
  description: "FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths"
  kind: python_call_eq
  category: class_bases
  id_prefix: iomore79

  columns: [id, function, args, expected]
  rows:
    - [fileio_base,    "FileIO.__bases__[0].__name__.__eq__",   ["_RawIOBase"],      true]
    - [bytesio_base,   "BytesIO.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true]
    - [stringio_base,  "StringIO.__bases__[0].__name__.__eq__", ["_TextIOBase"],     true]
    - [fileio_mro,     FileIO.__mro__.__len__,                  [],                  4]
    - [bytesio_mro,    BytesIO.__mro__.__len__,                 [],                  4]
    - [stringio_mro,   StringIO.__mro__.__len__,                [],                  4]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra79.FileIO_dict.mappingproxy:
  description: "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: FileIO.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra79.FileIO_dict.has_read:
  description: "io.FileIO.__dict__.__contains__('read') == True"
  category: class_dict
  kind: python_call_eq
  function: "FileIO.__dict__.__contains__"
  args: ["read"]
  expected: true

invariant io_extra79.FileIO.base_is_RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase'"
  category: class_bases
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra79.FileIO.mro_len_4:
  description: "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, _RawIOBase, _IOBase, object]"
  category: class_bases
  kind: python_call_eq
  function: FileIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra79.BytesIO.base_is_BufferedIOBase:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase'"
  category: class_bases
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true
