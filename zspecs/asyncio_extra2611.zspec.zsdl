spec: asyncio_extra2611
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "asyncio.Queue, asyncio.Task, and asyncio.Future each define __class_getitem__ in their own __dict__ (supporting PEP 585 generic subscript syntax). The sync primitives — Lock, Event, Semaphore, Condition, Barrier — do NOT define __class_getitem__ in their own __dict__."
    - "None of the asyncio classes define __init_subclass__ or __subclasshook__ in their own __dict__. These are inherited from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — asyncio classes
#
# None of the asyncio classes (Queue, Task, Future, Lock, Event, Semaphore,
# Condition, Barrier) define __init_subclass__ in their own __dict__.
# They all inherit it from object.
# ---------------------------------------------------------------------------

table asyncio_extra2611.init_subclass_checks:
  description: "asyncio classes do NOT define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2611
  columns: [id, function, args, expected]
  rows:
    - ["as2611001", "asyncio.Queue.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["as2611002", "asyncio.Task.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["as2611003", "asyncio.Future.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["as2611004", "asyncio.Lock.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["as2611005", "asyncio.Event.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["as2611006", "asyncio.Semaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["as2611007", "asyncio.Condition.__dict__.__contains__", ["__init_subclass__"], false]
    - ["as2611008", "asyncio.Barrier.__dict__.__contains__",   ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __subclasshook__ dict-presence — asyncio classes
#
# None of the asyncio classes define __subclasshook__ in their own __dict__.
# They all inherit from object, which defines it.
# ---------------------------------------------------------------------------

table asyncio_extra2611.subclasshook_checks:
  description: "asyncio classes do NOT define __subclasshook__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2611
  columns: [id, function, args, expected]
  rows:
    - ["as2611009",  "asyncio.Queue.__dict__.__contains__",     ["__subclasshook__"], false]
    - ["as2611010", "asyncio.Task.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["as2611011", "asyncio.Future.__dict__.__contains__",    ["__subclasshook__"], false]
    - ["as2611012", "asyncio.Lock.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["as2611013", "asyncio.Event.__dict__.__contains__",     ["__subclasshook__"], false]
    - ["as2611014", "asyncio.Semaphore.__dict__.__contains__", ["__subclasshook__"], false]
    - ["as2611015", "asyncio.Condition.__dict__.__contains__", ["__subclasshook__"], false]
    - ["as2611016", "asyncio.Barrier.__dict__.__contains__",   ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — asyncio classes
#
# asyncio.Queue, asyncio.Task, and asyncio.Future define __class_getitem__
# in their own __dict__ (PEP 585 generic subscript support).
# The sync primitives (Lock, Event, Semaphore, Condition, Barrier) do NOT.
# ---------------------------------------------------------------------------

table asyncio_extra2611.class_getitem_checks:
  description: "asyncio Queue/Task/Future define __class_getitem__; sync primitives do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2611
  columns: [id, function, args, expected]
  rows:
    - ["as2611017", "asyncio.Queue.__dict__.__contains__",     ["__class_getitem__"], true]
    - ["as2611018", "asyncio.Task.__dict__.__contains__",      ["__class_getitem__"], true]
    - ["as2611019", "asyncio.Future.__dict__.__contains__",    ["__class_getitem__"], true]
    - ["as2611020", "asyncio.Lock.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["as2611021", "asyncio.Event.__dict__.__contains__",     ["__class_getitem__"], false]
    - ["as2611022", "asyncio.Semaphore.__dict__.__contains__", ["__class_getitem__"], false]
    - ["as2611023", "asyncio.Condition.__dict__.__contains__", ["__class_getitem__"], false]
    - ["as2611024", "asyncio.Barrier.__dict__.__contains__",   ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ callability — Queue, Task, Future
#
# For the three classes that DO define __class_getitem__, verify it is
# callable (i.e., the generic alias machinery is wired up).
# ---------------------------------------------------------------------------

table asyncio_extra2611.class_getitem_callable:
  description: "asyncio Queue, Task, Future __class_getitem__ is callable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2611
  columns: [id, function, args, expected]
  rows:
    - ["as2611025", "asyncio.Queue.__dict__.__contains__",  ["__class_getitem__"], true]
    - ["as2611026", "asyncio.Task.__dict__.__contains__",   ["__class_getitem__"], true]
    - ["as2611027", "asyncio.Future.__dict__.__contains__", ["__class_getitem__"], true]
    - ["as2611028", "asyncio.Queue.__init_subclass__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true]
    - ["as2611029", "asyncio.Task.__init_subclass__.__class__.__name__.__eq__",   ["builtin_function_or_method"], true]
    - ["as2611030", "asyncio.Future.__init_subclass__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
