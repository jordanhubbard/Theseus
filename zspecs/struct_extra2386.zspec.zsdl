spec: struct_extra2386
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "struct.Struct is a C type; both __repr__ and __str__ are wrapper_descriptor."
    - "struct.error is a Python exception class; both __repr__ and __str__ are wrapper_descriptor (inherited from BaseException)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2386.struct_str_repr:
  description: "struct.Struct __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2386
  columns: [id, function, args, expected]
  rows:
    - ["st2386001", "struct.Struct.__repr__.__class__.__name__", [], "wrapper_descriptor"]
    - ["st2386002", "struct.Struct.__str__.__class__.__name__", [], "wrapper_descriptor"]

table struct_extra2386.struct_error_str_repr:
  description: "struct.error __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2386
  columns: [id, function, args, expected]
  rows:
    - ["st2386003", "struct.error.__repr__.__class__.__name__", [], "wrapper_descriptor"]
    - ["st2386004", "struct.error.__str__.__class__.__name__", [], "wrapper_descriptor"]

table struct_extra2386.struct_repr_is_wrapper_descriptor:
  description: "C-implemented struct.Struct has __repr__ and __str__ of kind wrapper_descriptor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2386
  columns: [id, function, args, expected]
  rows:
    - ["st2386005", "struct.Struct.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2386006", "struct.Struct.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table struct_extra2386.struct_error_repr_is_wrapper_descriptor:
  description: "struct.error inherits __repr__ and __str__ from BaseException → wrapper_descriptor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2386
  columns: [id, function, args, expected]
  rows:
    - ["st2386007", "struct.error.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2386008", "struct.error.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table struct_extra2386.struct_not_function:
  description: "Neither struct.Struct nor struct.error defines __repr__/__str__ in Python; neither is 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2386
  columns: [id, function, args, expected]
  rows:
    - ["st2386009", "struct.Struct.__repr__.__class__.__name__.__eq__", ["function"], false]
    - ["st2386010", "struct.Struct.__str__.__class__.__name__.__eq__", ["function"], false]
    - ["st2386011", "struct.error.__repr__.__class__.__name__.__eq__", ["function"], false]
    - ["st2386012", "struct.error.__str__.__class__.__name__.__eq__", ["function"], false]

table struct_extra2386.struct_consistency:
  description: "Cross-check: struct.Struct and struct.error are consistent — both wrapper_descriptor for __repr__ and __str__"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2386
  columns: [id, function, args, expected]
  rows:
    - ["st2386013", "struct.Struct.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2386014", "struct.Struct.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2386015", "struct.error.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2386016", "struct.error.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table struct_extra2386.struct_repr_str_same_kind:
