spec: numpy_char_rust
version: ">=3.9"
backend: rust_module(numpy_char_rust)

docs: https://numpy.org/doc/stable/reference/routines.char.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/routines.char.html — NumPy char routines documentation"
  not_derived_from:
    - "NumPy source: numpy/char.py"
  notes:
    - "numpy.char string operations on arrays of strings, returning lists."
    - "char_upper(lst) -> list: np.char.upper(lst).tolist()."
    - "char_lower(lst) -> list: np.char.lower(lst).tolist()."
    - "char_strip(lst) -> list: np.char.strip(lst).tolist() — strips whitespace."
    - "char_count(lst, sub) -> list: np.char.count(lst, sub).tolist()."
    - "char_startswith(lst, prefix) -> list: np.char.startswith(lst, prefix).tolist()."
    - "char_endswith(lst, suffix) -> list: np.char.endswith(lst, suffix).tolist()."
    - "All functions return lists (not numpy arrays) for ease of testing."
    - "All test vectors verified against numpy 2.2.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# char_upper — element-wise uppercase
table numpy_char_rust.upper.vectors:
  kind: python_call_eq
  category: upper
  id_prefix: nc_up
  function: char_upper

  columns: [id, args, expected]
  rows:
    - [basic,    [["hello", "world"]],      ["HELLO", "WORLD"]]
    - [mixed,    [["Hello", "World"]],      ["HELLO", "WORLD"]]
    - [already,  [["ABC"]],                 ["ABC"]]
    - [empty,    [[""]],                    [""]]

# char_lower — element-wise lowercase
table numpy_char_rust.lower.vectors:
  kind: python_call_eq
  category: lower
  id_prefix: nc_lo
  function: char_lower

  columns: [id, args, expected]
  rows:
    - [basic,    [["HELLO", "WORLD"]],      ["hello", "world"]]
    - [mixed,    [["Hello", "World"]],      ["hello", "world"]]
    - [already,  [["abc"]],                 ["abc"]]

# char_strip — element-wise strip whitespace
table numpy_char_rust.strip.vectors:
  kind: python_call_eq
  category: strip
  id_prefix: nc_st
  function: char_strip

  columns: [id, args, expected]
  rows:
    - [both_sides, [["  hello  ", "  world  "]], ["hello", "world"]]
    - [left_only,  [["  hi"]],                   ["hi"]]
    - [right_only, [["hi  "]],                   ["hi"]]
    - [no_spaces,  [["hello"]],                  ["hello"]]

# char_count — count substring occurrences per element
table numpy_char_rust.count.vectors:
  kind: python_call_eq
  category: count
  id_prefix: nc_ct
  function: char_count

  columns: [id, args, expected]
  rows:
    - [l_in_hello, [["hello", "world"], "l"],  [2, 1]]
    - [a_count,    [["banana", "apple"], "a"],  [3, 1]]
    - [zero_count, [["hello"], "z"],            [0]]

