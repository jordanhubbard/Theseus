spec: itertools_extra33
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra32.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__, __name__.__len__() for all types, __module__.__len__() for all types (all 9), chain.from_iterable qualname len (19), groupby.__iter__/__next__ qualname len (16), __mro__.__len__() for chain/cycle/islice/product/groupby/accumulate/pairwise/filterfalse (all 2), __bases__[0].__name__.__len__() for chain/cycle/islice/product/dropwhile/filterfalse/repeat/starmap/takewhile/zip_longest/accumulate/permutations (all 6), __dict__.__class__.__name__.__len__() for count/repeat/dropwhile/takewhile/starmap/zip_longest/permutations/combinations/pairwise/cycle/islice/groupby (all 12), __qualname__.__len__() for count(5)/repeat(6)/starmap(7)/dropwhile(9)/takewhile(9)/accumulate(10)/filterfalse(11)/zip_longest(11)/permutations(12)/combinations(12)/compress(8)/islice(6)/groupby(7)/combinations_with_replacement(29), itertools.__name__.__len__() (9), itertools.__spec__.__class__.__name__.__len__() (10)."
    - "This spec covers: chain.__qualname__.__len__() (5 — 'chain'); cycle.__qualname__.__len__() (5 — 'cycle'); pairwise.__qualname__.__len__() (8 — 'pairwise'); product.__qualname__.__len__() (7 — 'product'); chain/__dict__.__class__.__name__.__len__() (12 — 'mappingproxy'); product/__dict__.__class__.__name__.__len__() (12); accumulate/__dict__.__class__.__name__.__len__() (12); count/__dict__.__class__.__name__.__len__() (12); starmap/__mro__.__len__() (2); dropwhile/__mro__.__len__() (2); takewhile/__mro__.__len__() (2); zip_longest/__mro__.__len__() (2); repeat/__mro__.__len__() (2); count/__mro__.__len__() (2); itertools.__package__.__len__() (0 — empty string)."
    - "Key findings: chain.__qualname__ == 'chain' (5 chars) — same as __name__. cycle.__qualname__ == 'cycle' (5 chars). pairwise.__qualname__ == 'pairwise' (8 chars). product.__qualname__ == 'product' (7 chars). All four match their __name__ values confirming none are nested types. chain, product, accumulate, count all have __dict__.__class__.__name__ == 'mappingproxy' (12 chars). starmap/dropwhile/takewhile/zip_longest/repeat/count all have __mro__.__len__() == 2 — flat single-inheritance from object. itertools.__package__ is '' (empty string, len 0) — itertools is a top-level built-in module."
    - "spec version >=3.10 required for pairwise."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain/cycle/pairwise/product __qualname__.__len__() table — extra33 namespace
#
# itertools.chain.__qualname__ is 'chain' (5 chars). itertools.cycle.__qualname__
# is 'cycle' (5 chars). itertools.pairwise.__qualname__ is 'pairwise' (8 chars).
# itertools.product.__qualname__ is 'product' (7 chars). Prior specs covered
# the __qualname__.__len__() for count/repeat/starmap/dropwhile/takewhile/accumulate/
# filterfalse/zip_longest/permutations/combinations/compress/islice/groupby/
# combinations_with_replacement, but not for chain, cycle, pairwise, or product.
# No prior itertools spec records these four __qualname__.__len__() values together
# in a combined table in the extra33 namespace.
# ---------------------------------------------------------------------------

table itertools_extra33.remaining_qualname_lengths:
  description: "itertools type __qualname__.__len__() for chain/cycle/pairwise/product — not covered in prior specs"
  kind: python_call_eq
  category: string_properties
  id_prefix: remqualnamelen33

  columns: [id, function, args, expected, description]
  rows:
    - [chain,
       chain.__qualname__.__len__,
       [],
       5,
       "len(itertools.chain.__qualname__) == 5 — 'chain'"]
    - [cycle,
       cycle.__qualname__.__len__,
       [],
       5,
       "len(itertools.cycle.__qualname__) == 5 — 'cycle'"]
    - [pairwise,
       pairwise.__qualname__.__len__,
       [],
       8,
       "len(itertools.pairwise.__qualname__) == 8 — 'pairwise'"]
    - [product,
       product.__qualname__.__len__,
       [],
       7,
       "len(itertools.product.__qualname__) == 7 — 'product'"]

# ---------------------------------------------------------------------------
# Additional __dict__.__class__.__name__.__len__() table — chain/product/accumulate/count
#
# itertools.chain.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# itertools.product.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# itertools.accumulate.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# itertools.count.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# Prior specs covered this for count/repeat/dropwhile/takewhile/starmap/zip_longest/
# permutations/combinations/pairwise/cycle/islice/groupby/combinations_with_replacement/
# compress. The four remaining types — chain, product, accumulate, count — are added here.
# No prior itertools spec records these four values together in the extra33 namespace.
# ---------------------------------------------------------------------------

table itertools_extra33.remaining_dict_classname_lengths:
  description: "itertools type __dict__.__class__.__name__.__len__() for chain/product/accumulate/count — all 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: remdictnamelen33

  columns: [id, function, args, expected, description]
  rows:
    - [chain,
       chain.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.chain.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [product,
       product.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.product.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [accumulate,
       accumulate.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.accumulate.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [count,
       count.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.count.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]

# ---------------------------------------------------------------------------
# Remaining type __mro__.__len__() table — starmap/dropwhile/takewhile/zip_longest/repeat/count
#
# Prior specs covered __mro__.__len__() for chain/cycle/islice/product/groupby/accumulate/
# pairwise/filterfalse (all 2). The remaining major itertools types — starmap, dropwhile,
# takewhile, zip_longest, repeat, count — each also have __mro__.__len__() == 2,
# confirming they are all flat C-level types inheriting directly from object.
# No prior itertools spec records these six __mro__.__len__() values together in a
# combined table in the extra33 namespace.
# ---------------------------------------------------------------------------

table itertools_extra33.remaining_mro_lengths:
  description: "itertools type __mro__.__len__() for starmap/dropwhile/takewhile/zip_longest/repeat/count — all 2"
  kind: python_call_eq
  category: class_structure
  id_prefix: remmrolen33

  columns: [id, function, args, expected, description]
  rows:
    - [starmap,
       starmap.__mro__.__len__,
       [],
       2,
       "len(itertools.starmap.__mro__) == 2 — [starmap, object]"]
    - [dropwhile,
       dropwhile.__mro__.__len__,
       [],
       2,
       "len(itertools.dropwhile.__mro__) == 2 — [dropwhile, object]"]
    - [takewhile,
       takewhile.__mro__.__len__,
       [],
       2,
       "len(itertools.takewhile.__mro__) == 2 — [takewhile, object]"]
    - [zip_longest,
       zip_longest.__mro__.__len__,
       [],
       2,
       "len(itertools.zip_longest.__mro__) == 2 — [zip_longest, object]"]
    - [repeat,
       repeat.__mro__.__len__,
       [],
       2,
       "len(itertools.repeat.__mro__) == 2 — [repeat, object]"]
    - [count,
       count.__mro__.__len__,
       [],
       2,
       "len(itertools.count.__mro__) == 2 — [count, object]"]

# ---------------------------------------------------------------------------
# itertools.__package__.__len__() — standalone invariant
#
# itertools.__package__ is '' (empty string, length 0). itertools is a top-level
# built-in C extension module with no package namespace. This mirrors the behavior
# of other top-level built-in modules. No prior itertools spec records
# itertools.__package__.__len__() as a standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra33.package_len:
  description: "len(itertools.__package__) == 0 — itertools.__package__ is '' (empty string, top-level module)"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0
