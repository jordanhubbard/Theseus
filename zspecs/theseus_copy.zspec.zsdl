spec: theseus_copy
version: ">=3.9"
backend: python_cleanroom(theseus_copy)
blocks: copy

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html"
  notes:
    - "Clean-room shallow and deep copy utilities. Do NOT import copy."
    - "copy(obj): shallow copy — new container, same element references."
    - "deepcopy(obj): deep copy — new container AND new element objects recursively."
    - "Shallow copy of list: inner lists are shared; deep copy creates new inner lists."
    - "copy_shallow_list(): copy([1,2,3]) returns equal but distinct list."
    - "copy_deep_nested(): inner list modified in deep copy does not affect original."
    - "copy_is_not_same(): copy([1,2]) is not [1,2] (different object)."
    - "Export: copy(obj), deepcopy(obj)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_copy.shallow_equal:
  description: "copy([1,2,3]) == [1,2,3]"
  category: shallow
  kind: python_call_eq
  function: copy_shallow_equal
  args: []
  expected: true

invariant theseus_copy.shallow_not_same:
  description: "copy([1,2]) is not the original list"
  category: shallow
  kind: python_call_eq
  function: copy_is_not_same
  args: []
  expected: true

invariant theseus_copy.deep_independent:
  description: "modifying deep copy inner list does not affect original"
  category: deep
  kind: python_call_eq
  function: copy_deep_independent
  args: []
  expected: true
