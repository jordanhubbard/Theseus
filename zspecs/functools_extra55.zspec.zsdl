spec: functools_extra55
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra54.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for all major functools objects; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths; partial/__class__.__name__; cached_property/__set_name__/__get__/__init__.__qualname__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; reduce with initial value; lru_cache(128).__ne__(None)==True; lru_cache(maxsize=2) behavioral; reduce/__qualname__=='reduce'; lru_cache/__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial/__name__/__qualname__/__module__; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key'/__qualname__/'_functools'; partialmethod/__name__/__qualname__/__module__/__bases__[0].__name__; singledispatchmethod/__name__/__module__/__qualname__; singledispatchmethod/__mro__.__len__()==2; partial/__mro__.__len__()==2; partialmethod/__mro__.__len__()==2; cached_property/__mro__.__len__()==2; reduce/__module__.__len__()==10; cached_property/__bases__[0].__qualname__=='object'; partialmethod/__bases__[0].__qualname__=='object'; partial/__bases__[0].__qualname__=='object'; singledispatchmethod/__bases__[0].__qualname__=='object'; reduce/__class__.__name__=='builtin_function_or_method'; cmp_to_key/__class__.__name__=='builtin_function_or_method'; wraps/__class__.__name__=='function'; lru_cache/__class__.__name__=='function'; update_wrapper/__class__.__name__=='function'; singledispatch/__class__.__name__=='function'; total_ordering/__class__.__name__=='function'; cache/__class__.__name__=='function'; partial/__class__.__name__=='type'; cached_property/__class__.__name__=='type'; partialmethod/__class__.__name__=='type'; singledispatchmethod/__class__.__name__=='type'; reduce/__class__.__qualname__=='builtin_function_or_method'; wraps/__class__.__qualname__=='function'; lru_cache/__class__.__qualname__=='function'; singledispatch/__class__.__qualname__=='function'; total_ordering/__class__.__qualname__=='function'; partial/__class__.__qualname__=='type'; cached_property/__class__.__qualname__=='type'; reduce/__class__.__module__=='builtins'; wraps/__class__.__module__=='builtins'; lru_cache/__class__.__module__=='builtins'; partial/__class__.__module__=='_functools'; cached_property/__class__.__module__=='builtins'; total_ordering/__class__.__module__=='builtins'; singledispatch/__class__.__module__=='builtins'; partial/__call__/__repr__/__reduce__/__setstate__/__new__.__qualname__.__len__(); cached_property/__set_name__/__get__/__init__.__qualname__.__len__()."
    - "This spec covers: functools object __doc__.__class__.__name__ == 'str' for wraps/lru_cache/reduce/partial/cached_property/total_ordering/singledispatch; __doc__.__class__.__qualname__ == 'str' for wraps/lru_cache/reduce; __doc__.__class__.__module__ == 'builtins' for wraps/reduce."
    - "Key findings: Every functools callable that has a non-None __doc__ will return 'str' for __doc__.__class__.__name__. For pure-Python functions (wraps, lru_cache, update_wrapper, singledispatch, total_ordering, cache) the docstring is a Python string literal stored in the function's co_consts. For C-extension callables (reduce, cmp_to_key) and C-extension types (partial), the docstring is created from a C-level static string exposed via PyMethodDef.ml_doc or tp_doc. In all cases the docstring object is a Python str, so __doc__.__class__.__name__ == 'str' (3 chars). The str type is a top-level built-in with __qualname__ == __name__ == 'str' (3 chars) and __module__ == 'builtins' (8 chars). These hold universally across CPython versions. cached_property is a pure-Python class in Lib/functools.py whose __doc__ is set by the class body docstring — also a str. All invariants are new to extra55."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools object __doc__.__class__.__name__ == 'str' — extra55 namespace
#
# Every functools callable with a non-None __doc__ exposes that docstring as
# a Python str object. This holds for pure-Python functions (wraps, lru_cache,
# singledispatch, total_ordering), C-extension built-ins (reduce), and
# C-extension types (partial) and pure-Python classes (cached_property).
# The str class name is 'str' (3 chars). No prior spec recorded
# __doc__.__class__.__name__ for any functools object. All seven are new to extra55.
# ---------------------------------------------------------------------------

table functools_extra55.object_doc_class_names:
  description: "functools object __doc__.__class__.__name__ == 'str' — docstrings of all major functools callables are Python str objects regardless of whether the object is a pure-Python function, C-extension built-in, or C-extension/pure-Python class; 3-char class name"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdoc55

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_doc_class_name,
       wraps.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.wraps.__doc__.__class__.__name__ == 'str' — pure-Python decorator function in Lib/functools.py; convenience wrapper around update_wrapper; docstring is a Python string literal in the function's code object co_consts; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [lru_cache_doc_class_name,
       lru_cache.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__ == 'str' — pure-Python decorator function in Lib/functools.py; memoizes calls using a least-recently-used cache of bounded size; docstring is a Python string literal stored in co_consts; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [reduce_doc_class_name,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__ == 'str' — C-extension built-in function in Modules/_functoolsmodule.c; applies a binary function cumulatively to items of a sequence; docstring comes from PyMethodDef.ml_doc and is exposed as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [partial_doc_class_name,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/_functoolsmodule.c; creates a new callable with partial application of arguments; docstring comes from tp_doc and is exposed as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [cached_property_doc_class_name,
       cached_property.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cached_property.__doc__.__class__.__name__ == 'str' — pure-Python class in Lib/functools.py; non-data descriptor that computes a property value once and caches it in the instance __dict__; docstring is the class body docstring stored as a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [total_ordering_doc_class_name,
       total_ordering.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.total_ordering.__doc__.__class__.__name__ == 'str' — pure-Python decorator function in Lib/functools.py; fills in missing comparison methods from a minimal set (__eq__ and one of __lt__/__le__/__gt__/__ge__); docstring is a Python string literal in co_consts; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [singledispatch_doc_class_name,
       singledispatch.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatch.__doc__.__class__.__name__ == 'str' — pure-Python decorator function in Lib/functools.py; transforms a function into a single-dispatch generic function dispatching on the type of the first argument; docstring is a Python string literal; __doc__.__class__.__name__ == 'str' (3 chars)"]

# ---------------------------------------------------------------------------
# functools object __doc__.__class__.__qualname__ == 'str' — extra55 namespace
#
# The str built-in type is a top-level type with __qualname__ == __name__ == 'str'.
# Therefore for any functools object F whose __doc__ is a str:
#   F.__doc__.__class__.__qualname__ == 'str' (3 chars).
# This is a universal property of str: being a top-level built-in type its
# __qualname__ equals its __name__ with no dotted prefix. Three entries are
# chosen to sample pure-Python functions (wraps, lru_cache) and a C-extension
# built-in (reduce). All three are new to extra55.
# ---------------------------------------------------------------------------

table functools_extra55.object_doc_class_qualnames:
  description: "functools object __doc__.__class__.__qualname__ == 'str' — the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars); holds for pure-Python functions and C-extension built-ins alike"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdoc55

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_doc_class_qualname,
       wraps.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "functools.wraps.__doc__.__class__.__qualname__ == 'str' — pure-Python function; docstring is a str object; the str built-in type is a top-level type so __qualname__ == __name__ == 'str' (3 chars); no dotted-prefix qualification because str is not a nested class"]
    - [lru_cache_doc_class_qualname,
       lru_cache.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__qualname__ == 'str' — pure-Python function; docstring is a str object; the str built-in type has __qualname__ == 'str' (3 chars); __qualname__ equals __name__ for all top-level built-in types"]
    - [reduce_doc_class_qualname,
       reduce.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__qualname__ == 'str' — C-extension built-in function; docstring is a str object created from PyMethodDef.ml_doc; the str built-in type has __qualname__ == 'str' (3 chars); same result as for pure-Python functions because the docstring class is always str"]

# ---------------------------------------------------------------------------
# functools object __doc__.__class__.__module__ == 'builtins' — extra55 namespace
#
# The str built-in type has __module__ == 'builtins' (8 chars). Therefore for
# any functools object F whose __doc__ is a str:
#   F.__doc__.__class__.__module__ == 'builtins'.
# Two entries are chosen: wraps (pure-Python function) and reduce (C-extension).
# Both are new to extra55.
# ---------------------------------------------------------------------------

table functools_extra55.object_doc_class_modules:
  description: "functools object __doc__.__class__.__module__ == 'builtins' — the str type lives in the builtins module; for any functools callable whose __doc__ is a str, __doc__.__class__.__module__ == 'builtins' (8 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdoc55

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_doc_class_module,
       wraps.__doc__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.wraps.__doc__.__class__.__module__ == 'builtins' — pure-Python function; __doc__ is a str; the str built-in type has __module__ == 'builtins' (8 chars); this is universal: all built-in types (int, str, float, list, etc.) set __module__ == 'builtins'"]
    - [reduce_doc_class_module,
       reduce.__doc__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.reduce.__doc__.__class__.__module__ == 'builtins' — C-extension built-in function; __doc__ is a str created from PyMethodDef.ml_doc; the str type's __module__ is 'builtins' (8 chars); same result as pure-Python case because the docstring class is always the built-in str type"]
