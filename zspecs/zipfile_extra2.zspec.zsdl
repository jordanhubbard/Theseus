spec: zipfile_extra2
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipfile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "zipfile.zspec.zsdl — covers primary ZipFile behavior"
    - "zipfile_extra.zspec.zsdl — covers ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path class names, ZipFile __module__, BadZipFile base, is_zipfile __name__, compression constant types and values"
  notes:
    - "This spec provides additional __name__ equality and type checks not in zipfile.zspec.zsdl or zipfile_extra.zspec.zsdl."
    - "zipfile.ZipFile.__name__ == 'ZipFile'."
    - "zipfile.ZipInfo.__name__ == 'ZipInfo'."
    - "zipfile.BadZipFile.__name__ == 'BadZipFile'."
    - "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception' — BadZipFile is a direct subclass of Exception."
    - "zipfile.LargeZipFile.__name__ == 'LargeZipFile'."
    - "zipfile.ZIP_STORED.__class__.__name__ == 'int' — the constant is an int."
    - "zipfile.ZIP_DEFLATED.__class__.__name__ == 'int'."
    - "zipfile.ZIP_BZIP2.__class__.__name__ == 'int'."
    - "zipfile.ZIP_LZMA.__class__.__name__ == 'int'."
    - "zipfile.is_zipfile.__name__ == 'is_zipfile'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — __name__ equality for public classes
# ---------------------------------------------------------------------------

table zipfile_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [ZipFile,      ZipFile.__name__.__eq__,      ["ZipFile"],      true]
    - [ZipInfo,      ZipInfo.__name__.__eq__,       ["ZipInfo"],      true]
    - [BadZipFile,   BadZipFile.__name__.__eq__,    ["BadZipFile"],   true]
    - [LargeZipFile, LargeZipFile.__name__.__eq__,  ["LargeZipFile"], true]

# ---------------------------------------------------------------------------
# Exception hierarchy — BadZipFile is a direct subclass of Exception
# ---------------------------------------------------------------------------

invariant zipfile_extra2.BadZipFile.base_is_Exception:
  description: "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: BadZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Compression constant type checks — all are int
# ---------------------------------------------------------------------------

table zipfile_extra2.constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: consttype

  columns: [id, function, args, expected]
  rows:
    - [ZIP_STORED,   ZIP_STORED.__class__.__name__.__eq__,   ["int"], true]
    - [ZIP_DEFLATED, ZIP_DEFLATED.__class__.__name__.__eq__, ["int"], true]
    - [ZIP_BZIP2,    ZIP_BZIP2.__class__.__name__.__eq__,    ["int"], true]
    - [ZIP_LZMA,     ZIP_LZMA.__class__.__name__.__eq__,     ["int"], true]

# ---------------------------------------------------------------------------
# Function name check — is_zipfile
# ---------------------------------------------------------------------------

invariant zipfile_extra2.is_zipfile.name:
  description: "zipfile.is_zipfile.__name__ == 'is_zipfile'"
  category: function_names
  kind: python_call_eq
  function: is_zipfile.__name__.__eq__
  args: ["is_zipfile"]
  expected: true
