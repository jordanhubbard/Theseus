spec: json_extra25
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json_extra24.zspec.zsdl."
    - "Prior specs covered: JSONDecoder/JSONEncoder/JSONDecodeError __name__/__module__/__qualname__/__bases__[0].__name__, loads/dumps/load/dump __name__/__module__/__qualname__, method qualname lengths for JSONEncoder.encode/default/iterencode and JSONDecoder.decode/raw_decode, class and method __qualname__.__len__()."
    - "This spec covers: __mro__.__len__() for JSONDecodeError, JSONDecoder, JSONEncoder; __bases__[0].__name__.__len__() for JSONDecodeError, JSONDecoder, JSONEncoder; __init__.__qualname__.__len__() for JSONDecodeError, JSONDecoder, JSONEncoder; json.scanner.__name__.__len__()."
    - "No prior json spec checks json.JSONDecodeError.__mro__.__len__()."
    - "No prior json spec checks json.JSONDecoder.__mro__.__len__()."
    - "No prior json spec checks json.JSONEncoder.__mro__.__len__()."
    - "No prior json spec checks json.JSONDecodeError.__bases__[0].__name__.__len__()."
    - "No prior json spec checks json.JSONDecoder.__bases__[0].__name__.__len__()."
    - "No prior json spec checks json.JSONEncoder.__bases__[0].__name__.__len__()."
    - "No prior json spec checks json.JSONDecodeError.__init__.__qualname__.__len__()."
    - "No prior json spec checks json.JSONDecoder.__init__.__qualname__.__len__()."
    - "No prior json spec checks json.JSONEncoder.__init__.__qualname__.__len__()."
    - "No prior json spec checks json.scanner.__name__.__len__()."
    - "json.JSONDecodeError.__mro__ == [JSONDecodeError, ValueError, Exception, BaseException, object] — len 5."
    - "json.JSONDecoder.__mro__ == [JSONDecoder, object] — len 2."
    - "json.JSONEncoder.__mro__ == [JSONEncoder, object] — len 2."
    - "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — len 10."
    - "json.JSONDecoder.__bases__[0].__name__ == 'object' — len 6."
    - "json.JSONEncoder.__bases__[0].__name__ == 'object' — len 6."
    - "json.JSONDecodeError.__init__.__qualname__ == 'JSONDecodeError.__init__' — len 24."
    - "json.JSONDecoder.__init__.__qualname__ == 'JSONDecoder.__init__' — len 20."
    - "json.JSONEncoder.__init__.__qualname__ == 'JSONEncoder.__init__' — len 20."
    - "json.scanner.__name__ == 'json.scanner' — len 12 (submodule name includes package prefix)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for JSONDecodeError, JSONDecoder, JSONEncoder
#
# JSONDecodeError inherits from ValueError (len 5 MRO):
#   JSONDecodeError -> ValueError -> Exception -> BaseException -> object
# JSONDecoder and JSONEncoder inherit directly from object (len 2 MRO):
#   JSONDecoder -> object
#   JSONEncoder -> object
# No prior json spec checks any class's MRO depth.
# ---------------------------------------------------------------------------

invariant json_extra25.JSONDecodeError.mro_len:
  description: "json.JSONDecodeError.__mro__.__len__() == 5 — MRO: JSONDecodeError, ValueError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__mro__.__len__
  args: []
  expected: 5

invariant json_extra25.JSONDecoder.mro_len:
  description: "json.JSONDecoder.__mro__.__len__() == 2 — MRO: JSONDecoder, object (flat hierarchy)"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecoder.__mro__.__len__
  args: []
  expected: 2

invariant json_extra25.JSONEncoder.mro_len:
  description: "json.JSONEncoder.__mro__.__len__() == 2 — MRO: JSONEncoder, object (flat hierarchy)"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONEncoder.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for JSONDecodeError, JSONDecoder, JSONEncoder
#
# JSONDecodeError.__bases__[0] is ValueError (len 10).
# JSONDecoder.__bases__[0] and JSONEncoder.__bases__[0] are both 'object' (len 6).
# No prior json spec checks the string length of any class's first base name.
# ---------------------------------------------------------------------------

invariant json_extra25.JSONDecodeError.bases0_name_len:
  description: "json.JSONDecodeError.__bases__[0].__name__.__len__() == 10 — first base is 'ValueError' (10 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "JSONDecodeError.__bases__[0].__name__.__len__"
  args: []
  expected: 10

invariant json_extra25.JSONDecoder.bases0_name_len:
  description: "json.JSONDecoder.__bases__[0].__name__.__len__() == 6 — first base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "JSONDecoder.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant json_extra25.JSONEncoder.bases0_name_len:
  description: "json.JSONEncoder.__bases__[0].__name__.__len__() == 6 — first base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "JSONEncoder.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# __init__.__qualname__.__len__() for JSONDecodeError, JSONDecoder, JSONEncoder
#
# Each __init__ qualname takes the form 'ClassName.__init__', so the length
# is len(class_name) + len('.__init__') == len(class_name) + 9.
#   JSONDecodeError.__init__ -> 'JSONDecodeError.__init__' -> 15 + 9 = 24
#   JSONDecoder.__init__     -> 'JSONDecoder.__init__'     -> 11 + 9 = 20
#   JSONEncoder.__init__     -> 'JSONEncoder.__init__'     -> 11 + 9 = 20
# No prior json spec checks any class's __init__.__qualname__.__len__().
# ---------------------------------------------------------------------------

invariant json_extra25.JSONDecodeError.init_qualname_len:
  description: "json.JSONDecodeError.__init__.__qualname__.__len__() == 24 — 'JSONDecodeError.__init__' has 24 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONDecodeError.__init__.__qualname__.__len__"
  args: []
  expected: 24

invariant json_extra25.JSONDecoder.init_qualname_len:
  description: "json.JSONDecoder.__init__.__qualname__.__len__() == 20 — 'JSONDecoder.__init__' has 20 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONDecoder.__init__.__qualname__.__len__"
  args: []
  expected: 20

invariant json_extra25.JSONEncoder.init_qualname_len:
  description: "json.JSONEncoder.__init__.__qualname__.__len__() == 20 — 'JSONEncoder.__init__' has 20 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONEncoder.__init__.__qualname__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# json.scanner submodule __name__.__len__()
#
# json.scanner is the pure-Python scanner submodule. Its __name__ attribute
# is 'json.scanner' (includes the package prefix), giving a length of 12.
# No prior json spec checks json.scanner.__name__ length.
# ---------------------------------------------------------------------------

invariant json_extra25.scanner.name_len:
  description: "json.scanner.__name__.__len__() == 12 — submodule name 'json.scanner' has 12 characters"
  category: module_identity
  kind: python_call_eq
  function: scanner.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Consolidated table — MRO depth for all three json classes
#
# JSONDecodeError has depth 5 (deep exception hierarchy).
# JSONDecoder and JSONEncoder have depth 2 (direct object subclasses).
# All are first covered in this spec (json_extra25).
# ---------------------------------------------------------------------------

table json_extra25.class_mro_lengths:
  description: "json class __mro__.__len__() — JSONDecodeError (5), JSONDecoder (2), JSONEncoder (2)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: jfa25a

  columns: [id, function, args, expected]
  rows:
    - [JSONDecodeError_mro_len, JSONDecodeError.__mro__.__len__, [], 5]
    - [JSONDecoder_mro_len,     JSONDecoder.__mro__.__len__,     [], 2]
    - [JSONEncoder_mro_len,     JSONEncoder.__mro__.__len__,     [], 2]

# ---------------------------------------------------------------------------
# Consolidated table — __bases__[0].__name__.__len__() and
# __init__.__qualname__.__len__() for all three json classes
#
# Groups base-name and init-qualname lengths in one table for systematic
# coverage. All values are first introduced in this spec.
# ---------------------------------------------------------------------------

table json_extra25.class_bases_and_init_lengths:
  description: "json class __bases__[0].__name__.__len__() and __init__.__qualname__.__len__() — JSONDecodeError, JSONDecoder, JSONEncoder"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: jfa25b

  columns: [id, function, args, expected]
  rows:
    - [JSONDecodeError_bases0_name_len,  "JSONDecodeError.__bases__[0].__name__.__len__",  [], 10]
    - [JSONDecoder_bases0_name_len,      "JSONDecoder.__bases__[0].__name__.__len__",      [],  6]
    - [JSONEncoder_bases0_name_len,      "JSONEncoder.__bases__[0].__name__.__len__",      [],  6]
    - [JSONDecodeError_init_qualname_len, "JSONDecodeError.__init__.__qualname__.__len__", [], 24]
    - [JSONDecoder_init_qualname_len,    "JSONDecoder.__init__.__qualname__.__len__",      [], 20]
    - [JSONEncoder_init_qualname_len,    "JSONEncoder.__init__.__qualname__.__len__",      [], 20]
    - [scanner_name_len,                 scanner.__name__.__len__,                         [], 12]
