spec: svg_tags
version: ">=1.0.0"
backend: node(svg-tags)

docs: https://github.com/element-io/svg-tags#readme

provenance:
  derived_from:
    - "svg-tags README — https://github.com/element-io/svg-tags#readme"
    - "SVG 1.1 / SVG 2 element list (W3C TR/SVG)"
    - "Test vectors verified with svg-tags via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "svg-tags source"
  notes:
    - "Static array of SVG element names — used by JSX runtimes and HTML parsers to distinguish HTML from SVG namespaces."
    - "Install: npm install svg-tags"
    - "v1 CJS; the module export IS the array (not wrapped in default)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure data; never throws."
  stderr: "null"
  stickiness: "N/A — static module."
  codes: {}

invariant svg_tags.has_80_entries:
  description: "Module is an 80-entry array of SVG tag names"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 80

invariant svg_tags.first_is_a:
  description: "First entry is 'a' (anchor inside SVG)"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: at, args: [0]}
  expected: "a"

invariant svg_tags.contains_svg:
  description: "Includes 'svg' (root element)"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: includes, args: ["svg"]}
  expected: true

invariant svg_tags.contains_circle:
  description: "Includes 'circle'"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: includes, args: ["circle"]}
  expected: true

invariant svg_tags.contains_path:
  description: "Includes 'path'"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: includes, args: ["path"]}
  expected: true

invariant svg_tags.contains_camelCase_animateMotion:
  description: "Includes camelCased 'animateMotion' (SVG preserves case)"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: includes, args: ["animateMotion"]}
  expected: true

invariant svg_tags.does_not_contain_div:
  description: "Does NOT include 'div' (HTML element)"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: includes, args: ["div"]}
  expected: false

invariant svg_tags.does_not_contain_input:
  description: "Does NOT include 'input' (HTML element)"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: includes, args: ["input"]}
  expected: false
