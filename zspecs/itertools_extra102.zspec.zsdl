# ---------------------------------------------------------------------------
# Table 1: itertools C-type __name__ string lengths — group A
#
# Wave 259 theme: itertools C-type __name__ lengths (short types).
#
# itertools.chain.__name__.__len__() == 5
# itertools.cycle.__name__.__len__() == 5
# itertools.count.__name__.__len__() == 5
# itertools.repeat.__name__.__len__() == 6
# itertools.islice.__name__.__len__() == 6
# itertools.compress.__name__.__len__() == 8
# itertools.dropwhile.__name__.__len__() == 9
# itertools.takewhile.__name__.__len__() == 9
#
# The __name__ attribute of each C extension type equals the simple type name
# string. New to extra102.
# ---------------------------------------------------------------------------

table itertools_extra102.name_len_group_a:
  description: "itertools C-type __name__ lengths (chain/cycle/count 5, repeat/islice 6, compress 8, dropwhile/takewhile 9); wave 259; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnamelen102a

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_len_eq_5,
       "chain.__name__.__len__",
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — itertools.chain is a C extension type in itertoolsmodule.c; its __name__ is 'chain'; len('chain') == 5 (c-h-a-i-n); new to extra102"]
    - [cycle_name_len_eq_5,
       "cycle.__name__.__len__",
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — itertools.cycle is a C extension type that endlessly cycles through an iterable; its __name__ is 'cycle'; len('cycle') == 5 (c-y-c-l-e); new to extra102"]
    - [count_name_len_eq_5,
       "count.__name__.__len__",
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — itertools.count is a C extension type that counts from a start value; its __name__ is 'count'; len('count') == 5 (c-o-u-n-t); new to extra102"]
    - [repeat_name_len_eq_6,
       "repeat.__name__.__len__",
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — itertools.repeat is a C extension type that repeats a value indefinitely or N times; its __name__ is 'repeat'; len('repeat') == 6 (r-e-p-e-a-t); new to extra102"]
    - [islice_name_len_eq_6,
       "islice.__name__.__len__",
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — itertools.islice is a C extension type that slices an iterator lazily; its __name__ is 'islice'; len('islice') == 6 (i-s-l-i-c-e); new to extra102"]
    - [compress_name_len_eq_8,
       "compress.__name__.__len__",
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — itertools.compress filters elements using a boolean selector iterable; its __name__ is 'compress'; len('compress') == 8 (c-o-m-p-r-e-s-s); new to extra102"]
    - [dropwhile_name_len_eq_9,
       "dropwhile.__name__.__len__",
       [],
       9,
       "itertools.dropwhile.__name__.__len__() == 9 — itertools.dropwhile drops elements from the iterable while a predicate is True, then returns the remainder; its __name__ is 'dropwhile'; len('dropwhile') == 9 (d-r-o-p-w-h-i-l-e); new to extra102"]
    - [takewhile_name_len_eq_9,
       "takewhile.__name__.__len__",
       [],
       9,
       "itertools.takewhile.__name__.__len__() == 9 — itertools.takewhile returns elements while a predicate is True and stops at the first False; its __name__ is 'takewhile'; len('takewhile') == 9 (t-a-k-e-w-h-i-l-e); new to extra102"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __name__ string lengths — group B (medium types)
#
# Wave 259 theme: itertools C-type __name__ lengths (medium-length names).
#
# itertools.product.__name__.__len__() == 7
# itertools.groupby.__name__.__len__() == 7
# itertools.starmap.__name__.__len__() == 7
# itertools.accumulate.__name__.__len__() == 10
# itertools.zip_longest.__name__.__len__() == 11
# itertools.filterfalse.__name__.__len__() == 11
# itertools.combinations.__name__.__len__() == 12
# itertools.permutations.__name__.__len__() == 12
#
# These C extension types have longer names. New to extra102.
# ---------------------------------------------------------------------------

table itertools_extra102.name_len_group_b:
  description: "itertools C-type __name__ lengths (product/groupby/starmap 7, accumulate 10, zip_longest/filterfalse 11, combinations/permutations 12); wave 259; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnamelen102b

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_len_eq_7,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — itertools.product computes the Cartesian product of input iterables; its __name__ is 'product'; len('product') == 7 (p-r-o-d-u-c-t); new to extra102"]
    - [groupby_name_len_eq_7,
       "groupby.__name__.__len__",
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — itertools.groupby groups consecutive elements by a key function; its __name__ is 'groupby'; len('groupby') == 7 (g-r-o-u-p-b-y); new to extra102"]
    - [starmap_name_len_eq_7,
       "starmap.__name__.__len__",
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — itertools.starmap applies a function to arguments unpacked from tuples in an iterable; its __name__ is 'starmap'; len('starmap') == 7 (s-t-a-r-m-a-p); new to extra102"]
    - [accumulate_name_len_eq_10,
       "accumulate.__name__.__len__",
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — itertools.accumulate returns running totals or accumulated results of a binary function; its __name__ is 'accumulate'; len('accumulate') == 10 (a-c-c-u-m-u-l-a-t-e); new to extra102"]
    - [zip_longest_name_len_eq_11,
       "zip_longest.__name__.__len__",
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — itertools.zip_longest zips iterables of different lengths using a fillvalue for the shorter ones; its __name__ is 'zip_longest'; len('zip_longest') == 11 (z-i-p-_-l-o-n-g-e-s-t); new to extra102"]
    - [filterfalse_name_len_eq_11,
       "filterfalse.__name__.__len__",
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — itertools.filterfalse filters elements for which a predicate returns False (the complement of filter()); its __name__ is 'filterfalse'; len('filterfalse') == 11 (f-i-l-t-e-r-f-a-l-s-e); new to extra102"]
    - [combinations_name_len_eq_12,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — itertools.combinations generates r-length subsequences of elements; its __name__ is 'combinations'; len('combinations') == 12 (c-o-m-b-i-n-a-t-i-o-n-s); new to extra102"]
    - [permutations_name_len_eq_12,
       "permutations.__name__.__len__",
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — itertools.permutations generates r-length permutations of elements; its __name__ is 'permutations'; len('permutations') == 12 (p-e-r-m-u-t-a-t-i-o-n-s); new to extra102"]

# ---------------------------------------------------------------------------
# Table 3: itertools combinations_with_replacement __name__ length
#
# Wave 259 theme: itertools longest C-type __name__ length.
#
# itertools.combinations_with_replacement.__name__.__len__() == 29
#
# combinations_with_replacement has the longest __name__ of all itertools types.
# Note: the name is 29 characters, not 28 as might be assumed. New to extra102.
# ---------------------------------------------------------------------------

table itertools_extra102.cwr_name_len:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — the longest itertools C-type name; wave 259; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnamelen102c

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_name_len_eq_29,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — combinations_with_replacement generates r-length subsequences allowing repeated elements; its __name__ is 'combinations_with_replacement'; len('combinations_with_replacement') == 29 (c-o-m-b-i-n-a-t-i-o-n-s-_-w-i-t-h-_-r-e-p-l-a-c-e-m-e-n-t); new to extra102"]
    - [cwr_name_eq,
       "combinations_with_replacement.__name__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — the __name__ attribute of the C extension type matches the PyTypeObject tp_name string; str.__eq__('combinations_with_replacement') returns True; new to extra102"]
    - [chain_name_len_neq_cwr,
       "chain.__name__.__len__",
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — contrast with combinations_with_replacement (29): chain has the shortest __name__ at 5 characters; itertools type names range from 5 to 29 characters; new to extra102"]

