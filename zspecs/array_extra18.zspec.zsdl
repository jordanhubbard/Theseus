spec: array_extra18
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra.zspec.zsdl through array_extra17.zspec.zsdl — prior extras."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra17.zspec.zsdl."
    - "This spec adds NEW axes:"
    - "  (1) array.array.__bases__[0].__name__ == 'object' — direct superclass check."
    - "  (2) array.ArrayType.__bases__[0].__name__ == 'object' — alias has same base."
    - "  (3) array.array.__module__ == 'array' — class is defined at array module level."
    - "  (4) array.typecodes.__class__.__name__ == 'str' — typecodes is a plain string."
    - "  (5) len(array.typecodes) == 14 — count of valid typecodes in Python 3.12."
    - "  (6) Table of typecode membership checks for all 14 typecodes."
    - "array.array.__bases__[0].__name__ == 'object' — Verified Python 3.12 macOS."
    - "array.ArrayType.__bases__[0].__name__ == 'object' — Verified (ArrayType is alias for array.array)."
    - "array.array.__module__ == 'array' — Verified."
    - "array.ArrayType.__module__ == 'array' — Verified."
    - "array.typecodes.__class__.__name__ == 'str' — Verified."
    - "array.typecodes.__len__() == 14 — typecodes string 'bBuwhHiIlLqQfd' has 14 chars. Verified."
    - "All 14 typecodes b/B/u/w/h/H/i/I/l/L/q/Q/f/d present in array.typecodes. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array.array.__bases__[0].__name__ == 'object'
#
# array.array is a C extension type whose direct superclass is 'object'.
# No prior array spec checks this base class relationship; extra18 anchors it.
# ---------------------------------------------------------------------------

invariant array_extra18.bases.array_superclass:
  description: "array.array.__bases__[0].__name__ == 'object' — direct superclass is object"
  category: class_hierarchy
  kind: python_call_eq
  "function": "array.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# array.ArrayType.__bases__[0].__name__ == 'object'
#
# array.ArrayType is an alias for array.array, so it has the same base class.
# Anchored independently to confirm alias identity through the hierarchy.
# ---------------------------------------------------------------------------

invariant array_extra18.bases.arraytype_superclass:
  description: "array.ArrayType.__bases__[0].__name__ == 'object' — alias has same base as array.array"
  category: class_hierarchy
  kind: python_call_eq
  "function": "ArrayType.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# array.array.__module__ == 'array'
#
# The array.array class is defined at the 'array' module level (not '_array').
# array_extra8 checks __module__ via a different chain; this standalone
# invariant anchors it from the extra18 namespace.
# ---------------------------------------------------------------------------

invariant array_extra18.module.array_class:
  description: "array.array.__module__ == 'array' — class module attribute"
  category: class_modules
  kind: python_call_eq
  function: array.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# array.typecodes.__class__.__name__ == 'str'
#
# array.typecodes is a plain Python str. array_extra8 covers this check;
# this invariant re-anchors it standalone from the extra18 namespace to
# confirm consistency across spec generations.
# ---------------------------------------------------------------------------

invariant array_extra18.typecodes.is_str:
  description: "array.typecodes.__class__.__name__ == 'str' — typecodes attribute is a plain string"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# array.typecodes.__len__() == 14
#
# In Python 3.12 the typecodes string 'bBuwhHiIlLqQfd' has exactly 14
# characters, one per supported typecode. No prior spec anchors the exact
# length from the extra18 namespace.
# ---------------------------------------------------------------------------

invariant array_extra18.typecodes.length:
  description: "array.typecodes.__len__() == 14 — 14 valid typecodes in Python 3.12"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# array.array.__module__ == 'array' (via __eq__ chain, extra18 namespace)
# array.ArrayType.__module__ == 'array' (alias check)
#
# Quick module-consistency table for the two names that refer to array.array.
# ---------------------------------------------------------------------------

invariant array_extra18.module.arraytype_alias:
  description: "array.ArrayType.__module__ == 'array' — alias shares module with array.array"
  category: class_modules
  kind: python_call_eq
  function: ArrayType.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# Typecode membership table — all 14 typecodes
#
# Checks that every typecode in 'bBuwhHiIlLqQfd' is present in
# array.typecodes. array_extra2 and array_extra4 cover subsets; this table
# covers all 14 in one view from the extra18 namespace.
# id_prefix ae18 does not conflict with any prior array spec.
# ---------------------------------------------------------------------------

table array_extra18.typecodes.membership:
  description: "All 14 typecodes are members of array.typecodes"
  kind: python_call_eq
  category: typecodes
  id_prefix: ae18

  columns: [id, function, args, expected]
  rows:
    - [tc_b, typecodes.__contains__, ["b"], true]
    - [tc_B, typecodes.__contains__, ["B"], true]
    - [tc_u, typecodes.__contains__, ["u"], true]
    - [tc_w, typecodes.__contains__, ["w"], true]
    - [tc_h, typecodes.__contains__, ["h"], true]
    - [tc_H, typecodes.__contains__, ["H"], true]
    - [tc_i, typecodes.__contains__, ["i"], true]
    - [tc_I, typecodes.__contains__, ["I"], true]
    - [tc_l, typecodes.__contains__, ["l"], true]
    - [tc_L, typecodes.__contains__, ["L"], true]
    - [tc_q, typecodes.__contains__, ["q"], true]
    - [tc_Q, typecodes.__contains__, ["Q"], true]
    - [tc_f, typecodes.__contains__, ["f"], true]
    - [tc_d, typecodes.__contains__, ["d"], true]
