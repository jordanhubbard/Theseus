invariant concurrent_futures_extra111.Future_set_result_coqualname_len_17:
  description: "concurrent.futures.Future.set_result.__code__.co_qualname.__len__() == 17 — 'Future.set_result' = 'Future.'=7 + 'set_result'=10 = 17; co_qualname is a Python 3.11+ code object attribute (spec requires version >=3.11); for methods defined on module-level classes, co_qualname equals __qualname__; concurrent.futures.Future.set_result.__code__.co_qualname.__eq__('Future.set_result')==True; concurrent.futures.Future.set_result.__code__.co_argcount==2 (self and result — result is the value that future.result() will return); concurrent.futures.Future.set_result.__code__.co_name=='set_result' (len=10); concurrent.futures.Future.__name__=='Future' (len=6); compare co_qualname lengths: set_result=17 vs set_exception=20 (set_exception is 3 chars longer because 'set_exception'=13 > 'set_result'=10); NEW in extra111: first standalone Future.set_result co_qualname length invariant in cfcoq111 namespace; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.set_result.__code__.co_qualname.__len__
  args: []
  expected: 17

