spec: concurrent_futures_extra111
version: ">=3.11"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra110.zspec.zsdl."
    - "This spec covers: wave 255 theme — concurrent.futures.Future method co_qualname attributes (Python 3.11+) not covered in extra100-extra110. NEW in extra111: Future.set_result.__code__.co_qualname=='Future.set_result' (len=17); Future.set_exception.__code__.co_qualname=='Future.set_exception' (len=20); Future.running.__code__.co_qualname=='Future.running' (len=14); Future.__init__.__code__.co_qualname=='Future.__init__' (len=15); Future.add_done_callback.__code__.co_qualname=='Future.add_done_callback' (len=24, longest); Future.done.__code__.co_qualname=='Future.done' (len=11, shortest); Future.cancel.__code__.co_qualname=='Future.cancel' (len=13); Future.cancelled.__code__.co_qualname=='Future.cancelled' (len=16); Future.result.__code__.co_qualname=='Future.result' (len=13); Future.exception.__code__.co_qualname=='Future.exception' (len=16). All co_qualname values match the corresponding __qualname__ for these methods. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "co_qualname is a Python 3.11+ code object attribute that stores the fully qualified name of the function as defined at the point of definition (matching __qualname__). For Future methods, co_qualname == __qualname__ since Future is a module-level class. co_qualname length ordering: done=11 (shortest) < cancel=result=13 (tied) < running=15... wait: Future.running co_qualname len=14, Future.__init__ co_qualname len=15, Future.cancelled=Future.exception=16 (tied), Future.set_result=17, Future.set_exception=20, Future.add_done_callback=24 (longest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future co_qualname for state-mutation methods — extra111
#
# Wave 255 theme: Future.set_result, set_exception, running co_qualname values.
#
# concurrent.futures.Future.set_result.__code__.co_qualname   == 'Future.set_result'   (len=17)
# concurrent.futures.Future.set_exception.__code__.co_qualname == 'Future.set_exception' (len=20)
# concurrent.futures.Future.running.__code__.co_qualname      == 'Future.running'      (len=14)
# concurrent.futures.Future.__init__.__code__.co_qualname     == 'Future.__init__'     (len=15)
# ---------------------------------------------------------------------------

table concurrent_futures_extra111.cf_future_coqualname_mutation:
  description: "concurrent.futures.Future co_qualname checks for state-mutation methods in cfcoq111 namespace — wave 255 theme: co_qualname is a Python 3.11+ code object attribute; for methods on module-level classes, co_qualname equals __qualname__; concurrent.futures.Future.set_result.__code__.co_qualname.__eq__('Future.set_result')==True (len=17: 'Future.'=7+'set_result'=10=17; co_argcount=2: self and result); concurrent.futures.Future.set_result.__code__.co_qualname.__len__()==17; concurrent.futures.Future.set_exception.__code__.co_qualname.__eq__('Future.set_exception')==True (len=20: 'Future.'=7+'set_exception'=13=20; co_argcount=2: self and exception); concurrent.futures.Future.set_exception.__code__.co_qualname.__len__()==20; concurrent.futures.Future.running.__code__.co_qualname.__eq__('Future.running')==True (len=14: 'Future.'=7+'running'=7=14; co_argcount=1: self only — running() returns True when the future is being executed by an executor); concurrent.futures.Future.running.__code__.co_qualname.__len__()==14; concurrent.futures.Future.__init__.__code__.co_qualname.__eq__('Future.__init__')==True (len=15: 'Future.'=7+'__init__'=8=15; co_argcount=1: self only — Future is created by executors with no user arguments); concurrent.futures.Future.__init__.__code__.co_qualname.__len__()==15; compare co_qualname lengths: running=14 < __init__=15 < set_result=17 < set_exception=20; all co_qualname values match the corresponding __qualname__ values from prior specs; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcoq111

  columns: [id, function, args, expected, description]
  rows:
    - [sr_coq_eq,          concurrent.futures.Future.set_result.__code__.co_qualname.__eq__,    ["Future.set_result"],    true, "Future.set_result.__code__.co_qualname == 'Future.set_result' (len=17); verified with Python 3.14.3"]
    - [sr_coq_len,         concurrent.futures.Future.set_result.__code__.co_qualname.__len__,   [],                       17,   "Future.set_result co_qualname.__len__() == 17 ('Future.set_result'=17); verified with Python 3.14.3"]
    - [se_coq_eq,          concurrent.futures.Future.set_exception.__code__.co_qualname.__eq__, ["Future.set_exception"],  true, "Future.set_exception.__code__.co_qualname == 'Future.set_exception' (len=20); verified with Python 3.14.3"]
    - [se_coq_len,         concurrent.futures.Future.set_exception.__code__.co_qualname.__len__, [],                       20,   "Future.set_exception co_qualname.__len__() == 20 ('Future.set_exception'=20); verified with Python 3.14.3"]
    - [run_coq_eq,         concurrent.futures.Future.running.__code__.co_qualname.__eq__,       ["Future.running"],        true, "Future.running.__code__.co_qualname == 'Future.running' (len=14); verified with Python 3.14.3"]
    - [run_coq_len,        concurrent.futures.Future.running.__code__.co_qualname.__len__,      [],                       14,   "Future.running co_qualname.__len__() == 14 ('Future.running'=14); verified with Python 3.14.3"]
    - [init_coq_eq,        concurrent.futures.Future.__init__.__code__.co_qualname.__eq__,      ["Future.__init__"],       true, "Future.__init__.__code__.co_qualname == 'Future.__init__' (len=15); verified with Python 3.14.3"]
    - [init_coq_len,       concurrent.futures.Future.__init__.__code__.co_qualname.__len__,     [],                       15,   "Future.__init__ co_qualname.__len__() == 15 ('Future.__init__'=15); verified with Python 3.14.3"]

