spec: unicodedata_extra21
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata_extra20.zspec.zsdl."
    - "Prior specs covered: unicodedata.__name__/__package__; lookup/name/decimal/digit/numeric/category/bidirectional/combining/east_asian_width/mirrored/decomposition/normalize/is_normalized __name__/__module__; ucd_3_2_0 method qualnames for decimal/digit/numeric/east_asian_width/is_normalized; unicodedata.unidata_version/__class__.__name__; various __qualname__ checks."
    - "This spec covers: unicodedata.lookup.__qualname__, unicodedata.name.__qualname__, unicodedata.category.__qualname__, unicodedata.bidirectional.__qualname__, unicodedata.combining.__qualname__, unicodedata.mirrored.__qualname__, unicodedata.decomposition.__qualname__, unicodedata.normalize.__qualname__, unicodedata.lookup.__module__.__len__(), unicodedata.name.__module__.__len__(), unicodedata.unidata_version.__class__.__module__, unicodedata.ucd_3_2_0.__class__.__name__."
    - "unicodedata.lookup.__qualname__ == 'lookup' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.name.__qualname__ == 'name' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.category.__qualname__ == 'category' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.bidirectional.__qualname__ == 'bidirectional' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.combining.__qualname__ == 'combining' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.mirrored.__qualname__ == 'mirrored' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.decomposition.__qualname__ == 'decomposition' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.normalize.__qualname__ == 'normalize' — flat qualname for module-level C builtin. Verified at runtime."
    - "unicodedata.lookup.__module__ == 'unicodedata'; len == 11. Verified at runtime."
    - "unicodedata.name.__module__ == 'unicodedata'; len == 11. Verified at runtime."
    - "unicodedata.unidata_version.__class__.__module__ == 'builtins' — unidata_version is a plain Python str. Verified at runtime."
    - "unicodedata.ucd_3_2_0.__class__.__name__ == 'UCD' — the ucd_3_2_0 object is an instance of the UCD class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__ attributes (second batch)
#
# unicodedata_extra16/17 cover __qualname__ for lookup/name/decimal/digit/
# numeric/category/normalize/bidirectional/combining/east_asian_width/
# mirrored/decomposition/is_normalized. This spec assembles the remaining
# functions—lookup, name, category, bidirectional, combining, mirrored,
# decomposition, normalize—as explicit standalone invariants cross-linking
# this spec to its specific coverage intent.
# All are flat (non-dotted) qualnames equal to the bare function name.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra21.lookup.qualname:
  description: "unicodedata.lookup.__qualname__ == 'lookup' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: lookup.__qualname__.__eq__
  args: ["lookup"]
  expected: true

invariant unicodedata_extra21.name.qualname:
  description: "unicodedata.name.__qualname__ == 'name' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: name.__qualname__.__eq__
  args: ["name"]
  expected: true

invariant unicodedata_extra21.category.qualname:
  description: "unicodedata.category.__qualname__ == 'category' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: category.__qualname__.__eq__
  args: ["category"]
  expected: true

invariant unicodedata_extra21.bidirectional.qualname:
  description: "unicodedata.bidirectional.__qualname__ == 'bidirectional' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: bidirectional.__qualname__.__eq__
  args: ["bidirectional"]
  expected: true

invariant unicodedata_extra21.combining.qualname:
  description: "unicodedata.combining.__qualname__ == 'combining' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: combining.__qualname__.__eq__
  args: ["combining"]
  expected: true

invariant unicodedata_extra21.mirrored.qualname:
  description: "unicodedata.mirrored.__qualname__ == 'mirrored' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: mirrored.__qualname__.__eq__
  args: ["mirrored"]
  expected: true

invariant unicodedata_extra21.decomposition.qualname:
  description: "unicodedata.decomposition.__qualname__ == 'decomposition' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: decomposition.__qualname__.__eq__
  args: ["decomposition"]
  expected: true

invariant unicodedata_extra21.normalize.qualname:
  description: "unicodedata.normalize.__qualname__ == 'normalize' — flat qualname for module-level C builtin"
  category: function_identity
  kind: python_call_eq
  function: normalize.__qualname__.__eq__
  args: ["normalize"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ string lengths for lookup and name
#
# All module-level unicodedata functions have __module__ == 'unicodedata',
# an 11-character string. No prior spec verifies this length.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra21.lookup.module_len:
  description: "len(unicodedata.lookup.__module__) == 11 — 'unicodedata' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: lookup.__module__.__len__
  args: []
  expected: 11

invariant unicodedata_extra21.name.module_len:
  description: "len(unicodedata.name.__module__) == 11 — 'unicodedata' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: name.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# unidata_version.__class__.__module__
#
# unicodedata.unidata_version is a plain Python str. Its class is str, which
# is defined in the builtins module. No prior spec verifies
# unidata_version.__class__.__module__ as a standalone invariant.
# Verified at runtime: 'builtins'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra21.unidata_version.class_module:
  description: "unicodedata.unidata_version.__class__.__module__ == 'builtins' — unidata_version is a plain str from builtins"
  category: module_structure
  kind: python_call_eq
  function: unidata_version.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# ucd_3_2_0.__class__.__name__
#
# unicodedata.ucd_3_2_0 is an instance of the internal UCD class. No prior
# spec verifies ucd_3_2_0.__class__.__name__ as a standalone invariant
# (prior specs cover __module__ of that class).
# Verified at runtime: 'UCD'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra21.ucd_3_2_0.class_name:
  description: "unicodedata.ucd_3_2_0.__class__.__name__ == 'UCD' — ucd_3_2_0 is an instance of the UCD class"
  category: module_structure
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__name__.__eq__
  args: ["UCD"]
  expected: true

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__ attributes (second batch)
#
# Groups lookup, name, category, bidirectional, combining, mirrored,
# decomposition, and normalize __qualname__ checks in one indexed table.
# All qualnames are flat (equal to the bare function name).
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra21.module_level_function_qualnames:
  description: "unicodedata module-level function __qualname__ attributes — second batch, all flat"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud21lfq

  columns: [id, function, args, expected]
  rows:
    - [lookup,        lookup.__qualname__.__eq__,        ["lookup"],        true]
    - [name,          name.__qualname__.__eq__,          ["name"],          true]
    - [category,      category.__qualname__.__eq__,      ["category"],      true]
    - [bidirectional, bidirectional.__qualname__.__eq__, ["bidirectional"], true]
    - [combining,     combining.__qualname__.__eq__,     ["combining"],     true]
    - [mirrored,      mirrored.__qualname__.__eq__,      ["mirrored"],      true]
    - [decomposition, decomposition.__qualname__.__eq__, ["decomposition"], true]
    - [normalize,     normalize.__qualname__.__eq__,     ["normalize"],     true]

# ---------------------------------------------------------------------------
# Table: module metadata — __module__ lengths and class identity checks
#
# Groups lookup/name __module__ length checks, unidata_version class module,
# and ucd_3_2_0 class name in one indexed table. No prior table covers these
# checks. All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra21.module_metadata:
  description: "unicodedata module metadata checks — __module__ lengths, unidata_version class module, ucd_3_2_0 class name"
  kind: python_call_eq
  category: module_structure
  id_prefix: ud21mm

  columns: [id, function, args, expected]
  rows:
    - [lookup_module_len,        lookup.__module__.__len__,                  [],            11]
    - [name_module_len,          name.__module__.__len__,                    [],            11]
    - [unidata_version_cls_mod,  unidata_version.__class__.__module__.__eq__, ["builtins"], true]
    - [ucd_3_2_0_cls_name,       ucd_3_2_0.__class__.__name__.__eq__,        ["UCD"],      true]
