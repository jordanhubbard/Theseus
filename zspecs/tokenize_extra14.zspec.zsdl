spec: tokenize_extra14
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra13.zspec.zsdl — covers TokenInfo/__qualname__.__len__()==9; TokenError/__qualname__.__len__()==10; COMMENT/__class__.__name__=='int' standalone; NUMBER/__class__.__name__=='int' standalone; tokenize/__qualname__.__len__()==8; detect_encoding/__qualname__.__len__()==15"
    - "tokenize_extra12.zspec.zsdl — covers generate_tokens/open/untokenize __qualname__.__eq__; TokenInfo/__qualname__.__eq__; TokenError/__qualname__.__eq__; qualname __len__() for tokenize/generate_tokens/detect_encoding/open/untokenize"
    - "tokenize_extra11.zspec.zsdl — covers TokenInfo._fields class/len (table); Untokenizer __name__/__qualname__/__module__/base; TokenError base; open/__name__ and untokenize/__name__"
    - "tokenize_extra10.zspec.zsdl — covers COMMENT.__eq__([65]) standalone; TokenInfo._fields class (table); ENCODING/__class__.__name__=='int' (table)"
    - "tokenize_extra9.zspec.zsdl — covers tokenize/__qualname__.__eq__ and detect_encoding/__qualname__.__eq__; TokenInfo._make/_asdict/_replace __qualname__; untokenize/open __module__"
    - "tokenize_extra8.zspec.zsdl — covers NL.__eq__([66]) standalone"
    - "tokenize_extra6.zspec.zsdl — covers COMMENT/__eq__([65]) and NL/__eq__([66]) in table"
  notes:
    - "This spec extends tokenize_extra13.zspec.zsdl."
    - "Focus: TokenInfo._fields class name and length as standalone invariants in tokenize_extra14 namespace; COMMENT exact value standalone; NL/__class__.__name__ standalone; ENCODING/__class__.__name__ standalone; Untokenizer/__qualname__ standalone; Untokenizer.untokenize/__qualname__."
    - "tokenize.TokenInfo._fields.__class__.__name__ == 'tuple' — tokenize_extra10/tokenize_extra11 cover this in prior namespaces; distinct standalone invariant in tokenize_extra14."
    - "tokenize.TokenInfo._fields.__len__() == 5 — tokenize_extra11 covers this; distinct standalone in tokenize_extra14."
    - "tokenize.COMMENT == 65 — tokenize_extra6/tokenize_extra10 cover this; distinct standalone invariant in tokenize_extra14 namespace."
    - "tokenize.NL.__class__.__name__ == 'int' — no prior tokenize spec covers NL.__class__.__name__ as a standalone __eq__ invariant."
    - "tokenize.ENCODING.__class__.__name__ == 'int' — tokenize_extra10 covers this in a table; standalone in tokenize_extra14 namespace."
    - "tokenize.Untokenizer.__qualname__ == 'Untokenizer' — tokenize_extra11 covers this standalone; distinct in tokenize_extra14 namespace."
    - "tokenize.Untokenizer.untokenize.__qualname__ == 'Untokenizer.untokenize' — no prior tokenize spec covers this method __qualname__."
    - "tokenize.TokenInfo.string is a _tuplegetter (a property-like descriptor used by namedtuple); its __class__.__name__ is '_tuplegetter'. This is an implementation detail not tested here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo._fields class name and length — standalone invariants
# (tokenize_extra14 namespace)
#
# tokenize_extra10/tokenize_extra11 cover these in prior namespaces.
# These are distinct standalone invariants in the tokenize_extra14 namespace.
# _fields is a tuple of 5 field name strings: type, string, start, end, line.
# ---------------------------------------------------------------------------

invariant tokenize_extra14.TokenInfo_fields.class_is_tuple:
  description: "tokenize.TokenInfo._fields.__class__.__name__ == 'tuple' — _fields is a tuple of named field strings"
  category: class_names
  kind: python_call_eq
  function: TokenInfo._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant tokenize_extra14.TokenInfo_fields.len_is_5:
  description: "tokenize.TokenInfo._fields.__len__() == 5 — five named fields: type, string, start, end, line"
  category: sequence_lengths
  kind: python_call_eq
  function: TokenInfo._fields.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Token constant exact value and class name — COMMENT, NL, ENCODING
# (tokenize_extra14 namespace)
#
# COMMENT==65: tokenize_extra6/tokenize_extra10 cover this; distinct here.
# NL.__class__.__name__=='int': no prior tokenize spec covers this standalone.
# ENCODING.__class__.__name__=='int': tokenize_extra10 covers in table; standalone here.
# ---------------------------------------------------------------------------

invariant tokenize_extra14.COMMENT.value:
  description: "tokenize.COMMENT == 65 — COMMENT token constant exact value on Python 3.12"
  category: constant_values
  kind: python_call_eq
  function: COMMENT.__eq__
  args: [65]
  expected: true

invariant tokenize_extra14.NL.class_is_int:
  description: "tokenize.NL.__class__.__name__ == 'int' — NL token constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: NL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tokenize_extra14.ENCODING.class_is_int:
  description: "tokenize.ENCODING.__class__.__name__ == 'int' — ENCODING token constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: ENCODING.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Untokenizer class and method __qualname__ — standalone invariants
# (tokenize_extra14 namespace)
#
# tokenize_extra11 covers Untokenizer.__qualname__ standalone.
# No prior tokenize spec covers Untokenizer.untokenize.__qualname__.
# These are distinct standalone invariants in the tokenize_extra14 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra14.Untokenizer.qualname:
  description: "tokenize.Untokenizer.__qualname__ == 'Untokenizer'"
  category: class_qualnames
  kind: python_call_eq
  function: Untokenizer.__qualname__.__eq__
  args: ["Untokenizer"]
  expected: true

invariant tokenize_extra14.Untokenizer_untokenize.qualname:
  description: "tokenize.Untokenizer.untokenize.__qualname__ == 'Untokenizer.untokenize'"
  category: method_qualnames
  kind: python_call_eq
  function: Untokenizer.untokenize.__qualname__.__eq__
  args: ["Untokenizer.untokenize"]
  expected: true
