spec: concurrent_futures_extra1291
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "concurrent.futures standard library documentation — https://docs.python.org/3/library/concurrent.futures.html"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "Test vectors verified with Python 3.13 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any third-party futures or executor library"
  notes:
    - "Wave 533 (_extra1291): focus on __init__ and __new__ method presence and qualname checks."
    - "Future, ThreadPoolExecutor, and ProcessPoolExecutor each define __init__ directly in their own __dict__."
    - "Executor does NOT define __init__ in its own __dict__; it inherits object.__init__."
    - "Executor.__init__.__qualname__ is 'object.__init__' — confirmed no override in Executor."
    - "All __init__.__class__.__name__ values are 'function' for the three concrete classes."
    - "All expected values verified by running Python 3.13 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra1291.init_qualnames:
  description: "concurrent.futures __init__ qualname identity for Future and executor classes"
  kind: python_call_eq
  category: init_qualname
  id_prefix: cf1291
  columns: [id, function, args, expected]
  rows:
    - ["cf1291qi001", "concurrent.futures.Future.__init__.__qualname__.__eq__", ["Future.__init__"], true]
    - ["cf1291qi002", "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__", ["ThreadPoolExecutor.__init__"], true]
    - ["cf1291qi003", "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__", ["ProcessPoolExecutor.__init__"], true]
    - ["cf1291qi004", "concurrent.futures.Executor.__init__.__qualname__.__eq__", ["object.__init__"], true]
    - ["cf1291qi005", "concurrent.futures.Future.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["cf1291qi006", "concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__", ["function"], true]

table concurrent_futures_extra1291.init_class_names:
  description: "concurrent.futures __init__ method type via __class__.__name__"
  kind: python_call_eq
  category: init_class
  id_prefix: cf1291
  columns: [id, function, args, expected]
  rows:
    - ["cf1291ic001", "concurrent.futures.Future.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["cf1291ic002", "concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["cf1291ic003", "concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["cf1291ic004", "concurrent.futures.Executor.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["cf1291ic005", "concurrent.futures.Future.__dict__.__contains__", ["__init__"], true]
    - ["cf1291ic006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__init__"], true]

table concurrent_futures_extra1291.dict_contains_init:
  description: "concurrent.futures classes with __init__ explicitly in their own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: cf1291
  columns: [id, function, args, expected]
  rows:
    - ["cf1291dc001", "concurrent.futures.Future.__dict__.__contains__", ["__init__"], true]
    - ["cf1291dc002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf1291dc003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf1291dc004", "concurrent.futures.Executor.__dict__.__contains__", ["__init__"], false]
    - ["cf1291dc005", "concurrent.futures.Future.__dict__.__contains__", ["cancel"], true]
    - ["cf1291dc006", "concurrent.futures.Future.__dict__.__contains__", ["result"], true]
    - ["cf1291dc007", "concurrent.futures.Future.__dict__.__contains__", ["exception"], true]
    - ["cf1291dc008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["submit"], true]
