spec: dataclasses_extra18
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra17.zspec.zsdl."
    - "dataclasses_extra17 covers: field/__qualname__.__len__; dataclass/__qualname__.__len__; dataclass/__name__.__len__; field/__qualname__.__eq__; FrozenInstanceError/__qualname__.__eq__; FrozenInstanceError/__name__.__eq__; InitVar/__qualname__.__eq__; Field/__qualname__.__eq__; dataclass/__name__.__eq__; fields/__qualname__.__eq__."
    - "dataclasses_extra16 covers: fields/asdict/astuple/replace __qualname__.__len__; FrozenInstanceError MRO[0]; fields/asdict/astuple/make_dataclass/is_dataclass __module__ standalone."
    - "dataclasses_extra15 covers: Field/__name__.__len__, InitVar/__name__.__len__, FrozenInstanceError/__name__.__len__, Field/__qualname__.__len__, InitVar/__qualname__.__len__, is_dataclass/__qualname__.__len__, make_dataclass/__qualname__.__len__; dataclass/__module__; field/__module__."
    - "dataclasses_extra14 covers: Field/__bases__.__len__/__bases__[0]; FrozenInstanceError/__bases__[0]; module/__name__/__eq__; dataclass/__qualname__; replace/__name__/__name__.__len__; is_dataclass/__name__.__len__; table for dataclass/fields/replace/is_dataclass __name__.__len__."
    - "dataclasses_extra12 covers: MISSING/__class__/__module__ and KW_ONLY/__class__/__module__; FrozenInstanceError MRO[0]; function __doc__.__class__.__name__."
    - "dataclasses_extra10 covers: KW_ONLY/__class__/__name__ == '_KW_ONLY_TYPE'; KW_ONLY/__class__/__qualname__; MISSING/__class__/__qualname__."
    - "Focus of this spec: __name__.__len__() for MISSING.__class__ and KW_ONLY.__class__ sentinels — no prior spec checks string lengths; MRO[0].__name__.__len__() for Field and InitVar — no prior spec checks the length of the MRO[0] name string; FrozenInstanceError.__mro__[0].__name__.__len__() — extra16 covers the name eq but not the length; make_dataclass/__qualname__.__eq__ and replace/__qualname__.__eq__ as standalones."
    - "NOT yet covered (entering this spec): MISSING.__class__.__name__.__len__() == 13; KW_ONLY.__class__.__name__.__len__() == 13; Field.__mro__[0].__name__.__len__() == 5; InitVar.__mro__[0].__name__.__len__() == 7; FrozenInstanceError.__mro__[0].__name__.__len__() == 19."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Sentinel class __name__ string lengths
#
# dataclasses.zspec.zsdl and dataclasses_extra7 cover MISSING.__class__.__name__
# == '_MISSING_TYPE'. dataclasses_extra10 covers KW_ONLY.__class__.__name__
# == '_KW_ONLY_TYPE'. No prior spec checks the __len__() of either sentinel
# class name string. Both are 13 characters ('_MISSING_TYPE' and '_KW_ONLY_TYPE').
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.MISSING.class_name_len:
  description: "dataclasses.MISSING.__class__.__name__.__len__() == 13 — '_MISSING_TYPE' is 13 characters"
  category: sentinels
  kind: python_call_eq
  function: MISSING.__class__.__name__.__len__
  args: []
  expected: 13

invariant dataclasses_extra18.KW_ONLY.class_name_len:
  description: "dataclasses.KW_ONLY.__class__.__name__.__len__() == 13 — '_KW_ONLY_TYPE' is 13 characters (Python 3.10+)"
  category: sentinels
  version: ">=3.10"
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# MRO[0].__name__ string lengths for Field, InitVar, FrozenInstanceError
#
# dataclasses_extra10 covers Field.__mro__[0].__name__ == 'Field' (invariant with
# method: __name__). dataclasses_extra16 covers FrozenInstanceError.__mro__[0]
# .__name__ == 'FrozenInstanceError'. No prior spec checks the __len__() of
# these MRO[0] name strings. Because __getitem__ returns a class object and we
# need to chain __name__.__len__, these use invariant form with method_chain.
# Lengths: Field='Field'=5, InitVar='InitVar'=7, FrozenInstanceError=19.
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.Field.mro_first_name_len:
  description: "dataclasses.Field.__mro__[0].__name__.__len__() == 5 — 'Field' is 5 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__mro__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  method_chain_args: []
  expected: 5

invariant dataclasses_extra18.InitVar.mro_first_name_len:
  description: "dataclasses.InitVar.__mro__[0].__name__.__len__() == 7 — 'InitVar' is 7 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__mro__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  method_chain_args: []
  expected: 7

invariant dataclasses_extra18.FrozenInstanceError.mro_first_name_len:
  description: "dataclasses.FrozenInstanceError.__mro__[0].__name__.__len__() == 19 — 'FrozenInstanceError' is 19 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__mro__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  method_chain_args: []
  expected: 19

# ---------------------------------------------------------------------------
# replace.__qualname__.__eq__ standalone
#
# dataclasses_extra7 and dataclasses_extra13 cover replace.__qualname__.__eq__
# only in combined tables (alongside other functions). No prior spec has
# replace.__qualname__.__eq__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.replace.qualname_eq:
  description: "dataclasses.replace.__qualname__ == 'replace' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: replace.__qualname__.__eq__
  args: ["replace"]
  expected: true

# ---------------------------------------------------------------------------
# make_dataclass.__qualname__.__eq__ standalone
#
# dataclasses_extra7 covers make_dataclass.__qualname__ in a combined table.
# No prior spec has make_dataclass.__qualname__.__eq__ as a standalone invariant.
# For a top-level function __qualname__ == __name__ == 'make_dataclass'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.make_dataclass.qualname_eq:
  description: "dataclasses.make_dataclass.__qualname__ == 'make_dataclass' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: make_dataclass.__qualname__.__eq__
  args: ["make_dataclass"]
  expected: true

# ---------------------------------------------------------------------------
# asdict.__qualname__.__len__() standalone
#
# dataclasses_extra16 covers asdict.__qualname__.__len__() == 6 in a table.
# No prior spec has it as a standalone invariant for isolated indexing.
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.asdict.qualname_len:
  description: "dataclasses.asdict.__qualname__.__len__() == 6 — 'asdict' is 6 characters (standalone)"
  category: qualnames
  kind: python_call_eq
  function: asdict.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# astuple.__qualname__.__len__() standalone
#
# dataclasses_extra16 covers astuple.__qualname__.__len__() == 7 in a table.
# No prior spec has this as a standalone invariant for isolated indexing.
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.astuple.qualname_len:
  description: "dataclasses.astuple.__qualname__.__len__() == 7 — 'astuple' is 7 characters (standalone)"
  category: qualnames
  kind: python_call_eq
  function: astuple.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# replace.__qualname__.__len__() standalone
#
# dataclasses_extra16 covers replace.__qualname__.__len__() == 7 in a table.
# No prior spec has it as a standalone invariant. This complements the
# __qualname__.__eq__ standalone above.
# ---------------------------------------------------------------------------

invariant dataclasses_extra18.replace.qualname_len:
  description: "dataclasses.replace.__qualname__.__len__() == 7 — 'replace' is 7 characters (standalone)"
  category: qualnames
  kind: python_call_eq
  function: replace.__qualname__.__len__
  args: []
  expected: 7
