spec: io_extra237
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec covers: io.BytesIO and io.StringIO method __name__ contracts."
    - "io.BytesIO.read.__name__ == 'read' — BytesIO.read method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.write.__name__ == 'write' — BytesIO.write method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.seek.__name__ == 'seek' — BytesIO.seek method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.tell.__name__ == 'tell' — BytesIO.tell method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.getvalue.__name__ == 'getvalue' — BytesIO.getvalue method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.readable.__name__ == 'readable' — BytesIO.readable method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.writable.__name__ == 'writable' — BytesIO.writable method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.seekable.__name__ == 'seekable' — BytesIO.seekable method name; verified Python 3.14.3 macOS."
    - "io.BytesIO.close.__name__ == 'close' — BytesIO.close method name; verified Python 3.14.3 macOS."
    - "io.StringIO.readline.__name__ == 'readline' — StringIO.readline method name; verified Python 3.14.3 macOS."
    - "io.StringIO.getvalue.__name__ == 'getvalue' — StringIO.getvalue method name; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO method __name__ contracts
# All standard BytesIO methods carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra237.BytesIO_method_names:
  description: "io.BytesIO method __name__ contracts — read, write, seek, tell, getvalue, readable, writable, seekable, close; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: iobytesiomnames237

  columns: [id, function, args, expected]
  rows:
    - [bytesio_read_name,      BytesIO.read.__name__.__eq__,      ["read"],      true]
    - [bytesio_write_name,     BytesIO.write.__name__.__eq__,     ["write"],     true]
    - [bytesio_seek_name,      BytesIO.seek.__name__.__eq__,      ["seek"],      true]
    - [bytesio_tell_name,      BytesIO.tell.__name__.__eq__,      ["tell"],      true]
    - [bytesio_getvalue_name,  BytesIO.getvalue.__name__.__eq__,  ["getvalue"],  true]
    - [bytesio_readable_name,  BytesIO.readable.__name__.__eq__,  ["readable"],  true]
    - [bytesio_writable_name,  BytesIO.writable.__name__.__eq__,  ["writable"],  true]
    - [bytesio_seekable_name,  BytesIO.seekable.__name__.__eq__,  ["seekable"],  true]
    - [bytesio_close_name,     BytesIO.close.__name__.__eq__,     ["close"],     true]

# ---------------------------------------------------------------------------
# io.BytesIO method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra237.BytesIO.read.name_length:
  description: "io.BytesIO.read.__name__.__len__() == 4 — 'read' has 4 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: BytesIO.read.__name__.__len__
  args: []
  expected: 4

invariant io_extra237.BytesIO.getvalue.name_length:
  description: "io.BytesIO.getvalue.__name__.__len__() == 8 — 'getvalue' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: BytesIO.getvalue.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# io.StringIO method __name__ contracts
# readline and getvalue from StringIO carry their canonical names.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra237.StringIO.readline.name:
  description: "io.StringIO.readline.__name__ == 'readline' — StringIO.readline method name is 'readline'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: StringIO.readline.__name__.__eq__
  args: ["readline"]
  expected: true

invariant io_extra237.StringIO.readline.name_length:
  description: "io.StringIO.readline.__name__.__len__() == 8 — 'readline' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: StringIO.readline.__name__.__len__
  args: []
  expected: 8

invariant io_extra237.StringIO.getvalue.name:
  description: "io.StringIO.getvalue.__name__ == 'getvalue' — StringIO.getvalue method name is 'getvalue'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: StringIO.getvalue.__name__.__eq__
  args: ["getvalue"]
  expected: true

invariant io_extra237.StringIO.getvalue.name_length:
  description: "io.StringIO.getvalue.__name__.__len__() == 8 — 'getvalue' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: StringIO.getvalue.__name__.__len__
  args: []
  expected: 8
