spec: asyncio_extra17
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task functions"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/timeouts.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl through asyncio_extra16.zspec.zsdl."
    - "asyncio_extra covers: CancelledError/__name__, TimeoutError/__name__, IncompleteReadError/__name__; Task/Future/Queue/Lock/Event/Semaphore __name__."
    - "asyncio_extra12 covers: Task/Future/Lock/Queue __class__.__name__ == 'type'."
    - "asyncio_extra15 covers: Lock/Event/Semaphore/Barrier __qualname__ and __module__; Task/Future/Queue __qualname__; CancelledError/__qualname__ and __module__; InvalidStateError/__module__."
    - "asyncio_extra16 covers: SendfileNotAvailableError/__name__/__class__.__name__/__bases__[0]/__module__/__qualname__; exception class metaclass table; LimitOverrunError/__name__."
    - "NOT yet covered in any prior spec: asyncio.run.__name__ == 'run'."
    - "NOT yet covered: asyncio.run.__module__ == 'asyncio' — the run() function's module attribute."
    - "NOT yet covered: asyncio.sleep.__name__ == 'sleep'."
    - "NOT yet covered: asyncio.gather.__name__ == 'gather'."
    - "NOT yet covered: asyncio.wait.__name__ == 'wait'."
    - "NOT yet covered: asyncio.wait_for.__name__ == 'wait_for'."
    - "NOT yet covered: asyncio.create_task.__name__ == 'create_task'."
    - "NOT yet covered: asyncio.ensure_future.__name__ == 'ensure_future'."
    - "NOT yet covered: asyncio.shield.__name__ == 'shield'."
    - "NOT yet covered: asyncio.current_task.__name__ == 'current_task'."
    - "NOT yet covered: asyncio.all_tasks.__name__ == 'all_tasks'."
    - "NOT yet covered: asyncio.get_event_loop.__name__ == 'get_event_loop'."
    - "NOT yet covered: asyncio.get_running_loop.__name__ == 'get_running_loop'."
    - "NOT yet covered: asyncio.new_event_loop.__name__ == 'new_event_loop'."
    - "asyncio.timeout was added in Python 3.11; this spec targets >= 3.9 so timeout is tested separately with a note."
    - "asyncio.run, sleep, gather, wait, wait_for, create_task, ensure_future, shield are Python functions in asyncio/tasks.py or asyncio/runners.py."
    - "asyncio.get_event_loop, get_running_loop, new_event_loop are defined in asyncio/events.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module-level function __name__ checks
#
# No prior asyncio spec covers __name__ for any of the task/coroutine management
# functions (run, sleep, gather, wait, wait_for, create_task, ensure_future,
# shield, current_task, all_tasks). The event-loop factory functions
# get_event_loop, get_running_loop, and new_event_loop are also uncovered.
# ---------------------------------------------------------------------------

table asyncio_extra17.task_function_names:
  description: "asyncio task and coroutine functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: taskfn17

  columns: [id, function, args, expected]
  rows:
    - [run,           run.__name__.__eq__,           ["run"],           true]
    - [sleep,         sleep.__name__.__eq__,         ["sleep"],         true]
    - [gather,        gather.__name__.__eq__,        ["gather"],        true]
    - [wait,          wait.__name__.__eq__,          ["wait"],          true]
    - [wait_for,      wait_for.__name__.__eq__,      ["wait_for"],      true]
    - [create_task,   create_task.__name__.__eq__,   ["create_task"],   true]
    - [ensure_future, ensure_future.__name__.__eq__, ["ensure_future"], true]
    - [shield,        shield.__name__.__eq__,        ["shield"],        true]
    - [current_task,  current_task.__name__.__eq__,  ["current_task"],  true]
    - [all_tasks,     all_tasks.__name__.__eq__,     ["all_tasks"],     true]

table asyncio_extra17.event_loop_function_names:
  description: "asyncio event-loop factory and accessor functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: elfn17

  columns: [id, function, args, expected]
  rows:
    - [get_event_loop,  get_event_loop.__name__.__eq__,  ["get_event_loop"],  true]
    - [get_running_loop, get_running_loop.__name__.__eq__, ["get_running_loop"], true]
    - [new_event_loop,  new_event_loop.__name__.__eq__,  ["new_event_loop"],  true]

# ---------------------------------------------------------------------------
# asyncio.run __module__ — standalone invariant
#
# asyncio_extra15 covers __module__ for several asyncio classes and exceptions.
# No prior spec checks __module__ for any asyncio module-level function.
# asyncio.run is defined in asyncio/runners.py; its __module__ attribute is
# 'asyncio' because asyncio/__init__.py re-exports it without altering
# __module__.
# ---------------------------------------------------------------------------

invariant asyncio_extra17.run.module:
  description: "asyncio.run.__module__ == 'asyncio'"
  category: function_modules
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["asyncio"]
  expected: true
