#
# Wave 258 theme: as_completed and wait function qualnames and code attributes.
#
# concurrent.futures.as_completed.__qualname__               == 'as_completed'              (len=12)
# concurrent.futures.as_completed.__module__                 == 'concurrent.futures._base'  (len=24)
# concurrent.futures.as_completed.__code__.co_argcount       == 2
# concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9
# ---------------------------------------------------------------------------

table concurrent_futures_extra132.cf_as_completed_attrs:
  description: "concurrent.futures.as_completed function attribute checks in cfasc132 namespace — wave 258 theme: as_completed qualname and code attributes; as_completed is a generator function defined in Lib/concurrent/futures/_base.py; as_completed.__qualname__.__eq__('as_completed')==True (len=12: module-level function, qualname equals name); as_completed.__module__.__eq__('concurrent.futures._base')==True (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5); as_completed.__code__.co_argcount==2 (fs, timeout); as_completed.__code__.co_varnames.__len__()==9 (co_varnames=('fs', 'timeout', 'end_time', 'total_futures', 'finished', 'pending', 'waiter', 'wait_timeout', 'f'): 2 params + 7 locals); co_varnames.__contains__('fs')==True (first param is the iterable of futures); verified with Python 3.14.3"
