    - [qn_len,       "concurrent.futures.wait.__qualname__.__len__",              [],                           4,    "concurrent.futures.wait.__qualname__.__len__() == 4 ('wait'=4); verified with Python 3.14.3"]
    - [mod_eq,       "concurrent.futures.wait.__module__.__eq__",                 ["concurrent.futures._base"], true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [mod_len,      "concurrent.futures.wait.__module__.__len__",                [],                           24,   "concurrent.futures.wait.__module__.__len__() == 24 (same as as_completed); verified with Python 3.14.3"]
    - [co_argc,      "concurrent.futures.wait.__code__.co_argcount.__eq__",       [3],                          true, "concurrent.futures.wait.__code__.co_argcount == 3 (fs, timeout, return_when); verified with Python 3.14.3"]
    - [co_vars_len,  "concurrent.futures.wait.__code__.co_varnames.__len__",      [],                           7,    "concurrent.futures.wait.__code__.co_varnames.__len__() == 7 (3 params + 4 locals); verified with Python 3.14.3"]
    - [co_vars_rw,   "concurrent.futures.wait.__code__.co_varnames.__contains__", ["return_when"],               true, "concurrent.futures.wait.__code__.co_varnames.__contains__('return_when') == True (third param); verified with Python 3.14.3"]

