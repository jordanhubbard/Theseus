  category: identity
  id_prefix: cfasc132

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        "concurrent.futures.as_completed.__qualname__.__eq__",               ["as_completed"],             true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12); verified with Python 3.14.3"]
    - [qn_len,       "concurrent.futures.as_completed.__qualname__.__len__",              [],                           12,   "concurrent.futures.as_completed.__qualname__.__len__() == 12 ('as_completed'=12); verified with Python 3.14.3"]
    - [mod_eq,       "concurrent.futures.as_completed.__module__.__eq__",                 ["concurrent.futures._base"], true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [mod_len,      "concurrent.futures.as_completed.__module__.__len__",                [],                           24,   "concurrent.futures.as_completed.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [co_argc,      "concurrent.futures.as_completed.__code__.co_argcount.__eq__",       [2],                          true, "concurrent.futures.as_completed.__code__.co_argcount == 2 (fs, timeout); verified with Python 3.14.3"]
    - [co_vars_len,  "concurrent.futures.as_completed.__code__.co_varnames.__len__",      [],                           9,    "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9 (2 params + 7 locals); verified with Python 3.14.3"]
    - [co_vars_fs,   "concurrent.futures.as_completed.__code__.co_varnames.__contains__", ["fs"],                       true, "concurrent.futures.as_completed.__code__.co_varnames.__contains__('fs') == True (first param); verified with Python 3.14.3"]

