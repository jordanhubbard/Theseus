# ---------------------------------------------------------------------------
# Standalone invariants — extra132
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra132.as_completed_co_varnames_len_9:
  description: "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9 — co_varnames is ('fs', 'timeout', 'end_time', 'total_futures', 'finished', 'pending', 'waiter', 'wait_timeout', 'f') (9 items); the first 2 are parameters (co_argcount==2: 'fs', 'timeout'); the remaining 7 are local variables used within the generator body; as_completed is a generator function — it yields futures as they complete rather than returning them all at once; as_completed.__qualname__ is 'as_completed' (len=12, module-level function); as_completed.__module__ is 'concurrent.futures._base' (len=24); NEW in extra132: first standalone as_completed co_varnames length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__code__.co_varnames.__len__"
  args: []
  expected: 9

invariant concurrent_futures_extra132.wait_co_argcount_3:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — wait takes (fs, timeout, return_when) where fs is the iterable of futures, timeout is optional float seconds, and return_when is one of ALL_COMPLETED/FIRST_COMPLETED/FIRST_EXCEPTION; wait.__code__.co_varnames.__len__() is 7 (3 params + 4 locals); contrast with as_completed.__code__.co_argcount which is 2 (no return_when parameter); wait.__qualname__ is 'wait' (len=4, shortest function qualname in concurrent.futures module-level API); wait.__module__ is 'concurrent.futures._base' (len=24); NEW in extra132: first standalone wait co_argcount invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.wait.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

invariant concurrent_futures_extra132.as_completed_qualname_len_12:
  description: "concurrent.futures.as_completed.__qualname__.__len__() == 12 — as_completed.__qualname__ is 'as_completed' (12 chars: 'as'=2 + '_'=1 + 'completed'=9 = 12); as a module-level function its qualname equals its name; compare with wait.__qualname__.__len__() which is only 4 ('wait'=4); as_completed is a generator function that yields futures one at a time as they complete, enabling incremental processing; as_completed.__code__.co_argcount is 2 (fs, timeout); as_completed.__module__ is 'concurrent.futures._base' (len=24); NEW in extra132: first standalone as_completed qualname length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__qualname__.__len__"
  args: []
  expected: 12

invariant concurrent_futures_extra132.ProcessPoolExecutor_module_len_26:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 — ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (26 chars: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + 'process'=7 = 26); this is one char longer than ThreadPoolExecutor.__module__ ('concurrent.futures.thread', len=25: 'thread'=6 vs 'process'=7); both share the same 'concurrent.futures.' prefix (19 chars); ProcessPoolExecutor.__qualname__.__len__() is 19 ('ProcessPoolExecutor'=19, one more than ThreadPoolExecutor's 18); ProcessPoolExecutor.__mro__.__len__() is 3 ([ProcessPoolExecutor, Executor, object]); NEW in extra132: first standalone ProcessPoolExecutor module length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__module__.__len__"
  args: []
  expected: 26

invariant concurrent_futures_extra132.ProcessPoolExecutor_init_qualname_len_28:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — ProcessPoolExecutor.__init__.__qualname__ is 'ProcessPoolExecutor.__init__' (28 chars: 'ProcessPoolExecutor'=19 + '.'=1 + '__init__'=8 = 28); this is one char longer than ThreadPoolExecutor.__init__.__qualname__.__len__() which is 27 ('ThreadPoolExecutor'=18 + '.'=1 + '__init__'=8 = 27); ProcessPoolExecutor.__qualname__.__len__() is 19 ('ProcessPoolExecutor'=19); ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (len=26); ProcessPoolExecutor.__mro__.__len__() is 3; NEW in extra132: first standalone ProcessPoolExecutor.__init__ qualname length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__"
  args: []
  expected: 28
