    - [mod_len,      "concurrent.futures.ProcessPoolExecutor.__module__.__len__",              [],                              26,   "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 (one longer than ThreadPoolExecutor's 25); verified with Python 3.14.3"]
    - [base0_eq,     "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__",   ["Executor"],                    true, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
