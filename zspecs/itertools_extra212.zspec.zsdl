spec: itertools_extra212
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra211.zspec.zsdl — covers itertools type and attribute checks prior to extra212"
    - "itertools.zspec.zsdl — covers core itertools function behavior"
  notes:
    - "itertools.chain.__qualname__ == 'chain' — chain is a C-implemented class in itertools; its __qualname__ is simply 'chain' (5 characters). Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' — count is a C-implemented class; its __qualname__ is 'count' (5 characters). Verified with Python 3.14.3."
    - "itertools.cycle.__qualname__ == 'cycle' — cycle is a C-implemented class; its __qualname__ is 'cycle' (5 characters). Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' — product is a C-implemented class; its __qualname__ is 'product' (7 characters). Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations' — combinations is a C-implemented class; its __qualname__ is 'combinations' (12 characters). Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' — permutations is a C-implemented class; its __qualname__ is 'permutations' (12 characters). Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__.__len__() == 12 — 'combinations' has 12 characters. Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__.__len__() == 12 — 'permutations' has 12 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools __qualname__ equality checks — chain, count, cycle
#
# chain.__qualname__.__eq__('chain')   == True
# count.__qualname__.__eq__('count')   == True
# cycle.__qualname__.__eq__('cycle')   == True
# chain.__qualname__.__eq__('Chain')   == False  (case-sensitive)
# ---------------------------------------------------------------------------

table itertools_extra212.qualname_eq_group1:
  description: "itertools __qualname__ equality checks for chain, count, and cycle in iterqualname212g1 namespace — chain.__qualname__ is 'chain' (True), count.__qualname__ is 'count' (True), cycle.__qualname__ is 'cycle' (True), and chain.__qualname__.__eq__('Chain') is False (case-sensitive); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: iterqualname212g1

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C-implemented class in itertools; its __qualname__ is 'chain' (5 characters); __eq__('chain') returns True; verified with Python 3.14.3"]
    - [count_qualname_eq,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C-implemented class in itertools; its __qualname__ is 'count' (5 characters); __eq__('count') returns True; verified with Python 3.14.3"]
    - [cycle_qualname_eq,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C-implemented class in itertools; its __qualname__ is 'cycle' (5 characters); __eq__('cycle') returns True; verified with Python 3.14.3"]
    - [chain_qualname_neq_Chain,
       chain.__qualname__.__eq__,
       ["Chain"],
       false,
       "itertools.chain.__qualname__.__eq__('Chain') == False — __qualname__ is 'chain' (all lowercase); comparing against 'Chain' (capital C) returns False because __eq__ is case-sensitive; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: itertools __qualname__ equality checks — product, combinations, permutations
#
# product.__qualname__.__eq__('product')           == True
# combinations.__qualname__.__eq__('combinations') == True
# permutations.__qualname__.__eq__('permutations') == True
# product.__qualname__.__eq__('products')          == False
# ---------------------------------------------------------------------------

table itertools_extra212.qualname_eq_group2:
  description: "itertools __qualname__ equality checks for product, combinations, and permutations in iterqualname212g2 namespace — product.__qualname__ is 'product' (7 chars, True), combinations.__qualname__ is 'combinations' (12 chars, True), permutations.__qualname__ is 'permutations' (12 chars, True), and product.__qualname__.__eq__('products') is False; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: iterqualname212g2

  columns: [id, function, args, expected, description]
  rows:
    - [product_qualname_eq,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a C-implemented class in itertools; its __qualname__ is 'product' (7 characters); __eq__('product') returns True; verified with Python 3.14.3"]
    - [combinations_qualname_eq,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C-implemented class in itertools; its __qualname__ is 'combinations' (12 characters); __eq__('combinations') returns True; verified with Python 3.14.3"]
    - [permutations_qualname_eq,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C-implemented class in itertools; its __qualname__ is 'permutations' (12 characters); __eq__('permutations') returns True; verified with Python 3.14.3"]
    - [product_qualname_neq_suffix,
       product.__qualname__.__eq__,
       ["products"],
       false,
       "itertools.product.__qualname__.__eq__('products') == False — __qualname__ is 'product'; appending 's' gives 'products' which is not equal; __eq__ returns False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: itertools __qualname__ length checks
#
# chain.__qualname__.__len__()        == 5
# count.__qualname__.__len__()        == 5
# product.__qualname__.__len__()      == 7
# combinations.__qualname__.__len__() == 12
# ---------------------------------------------------------------------------

table itertools_extra212.qualname_len:
  description: "itertools __qualname__ length checks in iterqualname212ln namespace — chain has len 5, count has len 5, product has len 7, combinations has len 12; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: iterqualname212ln

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_len,
       chain.__qualname__.__len__,
       [],
       5,
       "itertools.chain.__qualname__.__len__() == 5 — the string 'chain' has exactly 5 characters; verified with Python 3.14.3"]
    - [count_qualname_len,
       count.__qualname__.__len__,
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — the string 'count' has exactly 5 characters; verified with Python 3.14.3"]
    - [product_qualname_len,
       product.__qualname__.__len__,
       [],
       7,
       "itertools.product.__qualname__.__len__() == 7 — the string 'product' has exactly 7 characters; verified with Python 3.14.3"]
    - [combinations_qualname_len,
       combinations.__qualname__.__len__,
       [],
       12,
       "itertools.combinations.__qualname__.__len__() == 12 — the string 'combinations' has exactly 12 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra212
# ---------------------------------------------------------------------------

invariant itertools_extra212.chain_qualname_eq:
  description: "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C-implemented class in itertools with __qualname__ 'chain'; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra212.count_qualname_eq:
  description: "itertools.count.__qualname__.__eq__('count') == True — count is a C-implemented class in itertools with __qualname__ 'count'; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra212.cycle_qualname_eq:
  description: "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C-implemented class in itertools with __qualname__ 'cycle'; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: cycle.__qualname__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra212.product_qualname_eq:
  description: "itertools.product.__qualname__.__eq__('product') == True — product is a C-implemented class in itertools with __qualname__ 'product' (7 chars); new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: product.__qualname__.__eq__
  args: ["product"]
