invariant itertools_extra212.combinations_qualname_eq:
  description: "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C-implemented class in itertools with __qualname__ 'combinations' (12 chars); new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: combinations.__qualname__.__eq__
