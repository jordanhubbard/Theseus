invariant itertools_extra212.permutations_qualname_eq:
  description: "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C-implemented class in itertools with __qualname__ 'permutations' (12 chars); new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: permutations.__qualname__.__eq__
