spec: ast_extra
version: ">=3.2"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ast.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
  notes:
    - "This spec covers ast behaviors not already captured in ast.zspec.zsdl."
    - "parse.__name__ == 'parse' and parse.__module__ == 'ast' — parse is a public Python function."
    - "dump.__name__ == 'dump' — returns a string representation of an AST tree."
    - "literal_eval.__name__ == 'literal_eval' covered in ast.zspec.zsdl; parse.__name__ and module are new here."
    - "get_docstring.__name__ == 'get_docstring' — extracts the docstring from a FunctionDef, AsyncFunctionDef, ClassDef, or Module node."
    - "fix_missing_locations.__name__ == 'fix_missing_locations' — fills in lineno, col_offset, etc. for nodes that lack them."
    - "NodeVisitor.__name__ == 'NodeVisitor' — base class for tree walkers; uses generic_visit by default."
    - "NodeTransformer.__name__ == 'NodeTransformer' — subclass of NodeVisitor; returns modified tree."
    - "NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — NodeTransformer inherits directly from NodeVisitor."
    - "AST.__name__ == 'AST' — the root base class for all ast node types."
    - "ast.parse('1 + 2') returns a Module node; confirmed via __class__.__name__."
    - "literal_eval('42') == 42 and literal_eval('\"hello\"') == 'hello' also in ast.zspec.zsdl but included here per task spec as standalone invariants."
    - "literal_eval('[1, 2, 3]') == [1, 2, 3] — list container round-trip."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# parse — name and module
# ---------------------------------------------------------------------------

invariant ast_extra.parse.name:
  description: "ast.parse.__name__ == 'parse'"
  category: parse
  kind: python_call_eq
  function: parse.__name__.__eq__
  args: ["parse"]
  expected: true

invariant ast_extra.parse.module:
  description: "ast.parse.__module__ == 'ast'"
  category: parse
  kind: python_call_eq
  function: parse.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra.parse.returns_module_node:
  description: "ast.parse('1 + 2').__class__.__name__ == 'Module'"
  category: parse
  kind: python_call_eq
  function: parse
  args: ["1 + 2"]
  method: __class__.__name__.__eq__
  method_args: ["Module"]
  expected: true

# ---------------------------------------------------------------------------
# dump — name
# ---------------------------------------------------------------------------

invariant ast_extra.dump.name:
  description: "ast.dump.__name__ == 'dump'"
  category: dump
  kind: python_call_eq
  function: dump.__name__.__eq__
  args: ["dump"]
  expected: true

# ---------------------------------------------------------------------------
# literal_eval — standalone value checks (also in ast.zspec.zsdl tables)
# ---------------------------------------------------------------------------

invariant ast_extra.literal_eval.int_42:
  description: "ast.literal_eval('42') == 42"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["42"]
  expected: 42

invariant ast_extra.literal_eval.str_hello:
  description: "ast.literal_eval('\"hello\"') == 'hello'"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["\"hello\""]
  expected: "hello"

invariant ast_extra.literal_eval.list_123:
  description: "ast.literal_eval('[1, 2, 3]') == [1, 2, 3]"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["[1, 2, 3]"]
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# get_docstring — name
# ---------------------------------------------------------------------------

invariant ast_extra.get_docstring.name:
  description: "ast.get_docstring.__name__ == 'get_docstring'"
  category: get_docstring
  kind: python_call_eq
  function: get_docstring.__name__.__eq__
  args: ["get_docstring"]
  expected: true

# ---------------------------------------------------------------------------
# fix_missing_locations — name
# ---------------------------------------------------------------------------

invariant ast_extra.fix_missing_locations.name:
  description: "ast.fix_missing_locations.__name__ == 'fix_missing_locations'"
  category: fix_missing_locations
  kind: python_call_eq
  function: fix_missing_locations.__name__.__eq__
  args: ["fix_missing_locations"]
  expected: true

# ---------------------------------------------------------------------------
# NodeVisitor — name
# ---------------------------------------------------------------------------

invariant ast_extra.NodeVisitor.name:
  description: "ast.NodeVisitor.__name__ == 'NodeVisitor'"
  category: node_visitor
  kind: python_call_eq
  function: NodeVisitor.__name__.__eq__
  args: ["NodeVisitor"]
  expected: true

# ---------------------------------------------------------------------------
# NodeTransformer — name and base class
# ---------------------------------------------------------------------------

invariant ast_extra.NodeTransformer.name:
  description: "ast.NodeTransformer.__name__ == 'NodeTransformer'"
  category: node_transformer
  kind: python_call_eq
  function: NodeTransformer.__name__.__eq__
  args: ["NodeTransformer"]
  expected: true

invariant ast_extra.NodeTransformer.base_is_NodeVisitor:
  description: "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor'"
  category: node_transformer
  kind: python_call_eq
  function: NodeTransformer.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["NodeVisitor"]
  expected: true

# ---------------------------------------------------------------------------
# AST — root base class name
# ---------------------------------------------------------------------------

invariant ast_extra.AST.name:
  description: "ast.AST.__name__ == 'AST'"
  category: ast_class
  kind: python_call_eq
  function: AST.__name__.__eq__
  args: ["AST"]
  expected: true
