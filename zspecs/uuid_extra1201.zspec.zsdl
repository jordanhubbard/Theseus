spec: uuid_extra1201
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID.int member_descriptor name/qualname/class attrs, uuid.UUID.bytes and uuid.UUID.hex property class attrs, and uuid.UUID.__init__/__str__/__repr__ function qualname/class/module attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1201.uuid_int_descriptor_attrs:
  description: "uuid.UUID.int member_descriptor __name__, __qualname__, and __class__ identity attrs"
  kind: python_call_eq
  category: uuid_int_descriptor_attrs
  id_prefix: uu1201id
  columns: [id, function, args, expected]
  rows:
    - [uu1201id001, uuid.UUID.int.__class__.__name__.__eq__,                    ["member_descriptor"],  true]
    - [uu1201id002, uuid.UUID.int.__class__.__qualname__.__eq__,                ["member_descriptor"],  true]
    - [uu1201id003, uuid.UUID.int.__class__.__module__.__eq__,                  ["builtins"],           true]
    - [uu1201id004, uuid.UUID.int.__name__.__eq__,                              ["int"],                true]
    - [uu1201id005, uuid.UUID.int.__qualname__.__eq__,                          ["UUID.int"],           true]
    - [uu1201id006, uuid.UUID.int.__name__.__class__.__name__.__eq__,           ["str"],                true]
    - [uu1201id007, uuid.UUID.int.__qualname__.__class__.__name__.__eq__,       ["str"],                true]
    - [uu1201id008, uuid.UUID.int.__class__.__name__.__class__.__name__.__eq__, ["str"],                true]

table uuid_extra1201.uuid_bytes_hex_property_attrs:
  description: "uuid.UUID.bytes and uuid.UUID.hex property __class__.__name__/__qualname__/__module__ identity"
  kind: python_call_eq
  category: uuid_bytes_hex_property_attrs
  id_prefix: uu1201bp
  columns: [id, function, args, expected]
  rows:
    - [uu1201bp001, uuid.UUID.bytes.__class__.__name__.__eq__,                  ["property"],   true]
    - [uu1201bp002, uuid.UUID.bytes.__class__.__qualname__.__eq__,              ["property"],   true]
    - [uu1201bp003, uuid.UUID.bytes.__class__.__module__.__eq__,                ["builtins"],   true]
    - [uu1201bp004, uuid.UUID.hex.__class__.__name__.__eq__,                    ["property"],   true]
    - [uu1201bp005, uuid.UUID.hex.__class__.__qualname__.__eq__,                ["property"],   true]
    - [uu1201bp006, uuid.UUID.hex.__class__.__module__.__eq__,                  ["builtins"],   true]
    - [uu1201bp007, uuid.UUID.bytes.__class__.__name__.__class__.__name__.__eq__, ["str"],      true]
    - [uu1201bp008, uuid.UUID.hex.__class__.__name__.__class__.__name__.__eq__,   ["str"],      true]
    - [uu1201bp009, uuid.UUID.version.__class__.__name__.__eq__,                ["property"],   true]

table uuid_extra1201.uuid_init_str_repr_method_attrs:
  description: "uuid.UUID __init__, __str__, __repr__ method qualname, class name, and module attrs"
  kind: python_call_eq
  category: uuid_init_str_repr_method_attrs
  id_prefix: uu1201mr
  columns: [id, function, args, expected]
  rows:
    - [uu1201mr001, uuid.UUID.__init__.__qualname__.__eq__,                     ["UUID.__init__"],  true]
    - [uu1201mr002, uuid.UUID.__init__.__class__.__name__.__eq__,               ["function"],       true]
    - [uu1201mr003, uuid.UUID.__init__.__module__.__eq__,                       ["uuid"],           true]
    - [uu1201mr004, uuid.UUID.__str__.__qualname__.__eq__,                      ["UUID.__str__"],   true]
    - [uu1201mr005, uuid.UUID.__str__.__class__.__name__.__eq__,                ["function"],       true]
    - [uu1201mr006, uuid.UUID.__str__.__module__.__eq__,                        ["uuid"],           true]
    - [uu1201mr007, uuid.UUID.__repr__.__qualname__.__eq__,                     ["UUID.__repr__"],  true]
    - [uu1201mr008, uuid.UUID.__repr__.__class__.__name__.__eq__,               ["function"],       true]
    - [uu1201mr009, uuid.UUID.__repr__.__module__.__eq__,                       ["uuid"],           true]
    - [uu1201mr010, uuid.UUID.__module__.__eq__,                                ["uuid"],           true]
    - [uu1201mr011, uuid.UUID.__name__.__eq__,                                  ["UUID"],           true]
