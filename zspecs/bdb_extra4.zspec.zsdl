spec: bdb_extra4
version: ">=3.9"
backend: python_module(bdb)

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bdb.html — Python bdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bdb.py"
  notes:
    - "Extends bdb.zspec.zsdl through bdb_extra3.zspec.zsdl."
    - "bdb (base) covers: Bdb/__name__/__module__, Breakpoint/__name__, BdbQuit/__name__/__bases__[0]/__name__; set_trace/set_break/clear_break/clear_all_breaks/get_breaks/run/runcall/runeval/set_continue/set_quit __name__; Breakpoint.next is int."
    - "bdb_extra covers: Bdb/__name__/__module__, Breakpoint/__name__/__module__, BdbQuit/__name__/__module__/__bases__[0]/__name__/__bases__.__len__; set_trace/set_step/set_next/set_return/set_quit/set_break/run/runcall/runeval/set_continue/clear_break names."
    - "bdb_extra2 covers: Bdb.__bases__[0].__name__=='object', checkfuncname/__name__/__module__, effective/__name__/__module__, class_qualnames table (Bdb, Breakpoint, BdbQuit)."
    - "bdb_extra3 covers: Bdb.__bases__.__len__==1, Breakpoint.__bases__[0].__name__=='object', Breakpoint.__bases__.__len__==1, BdbQuit.__bases__[0].__module__=='builtins', Bdb/__module__/__len__==3 table."
    - "This spec adds: Bdb method names not yet covered (canonic, reset, stop_here, break_here, user_line, user_return, do_clear, runctx, get_stack, format_stack_entry, dispatch_line, dispatch_call), Breakpoint method names (enable, disable, bpprint, bpformat, deleteMe), bdb.set_trace module-level function __name__/__module__."
    - "bdb.Bdb has many hooks and dispatch methods; this spec pins the __name__ attributes of the ones not yet in any prior spec."
    - "bdb.set_trace is the module-level convenience function that calls Bdb().set_trace()."
    - "bdb.Breakpoint.enable/disable/bpprint/bpformat/deleteMe are instance methods on the Breakpoint descriptor class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bdb method names not yet covered in any prior bdb spec
# ---------------------------------------------------------------------------

table bdb_extra4.bdb_new_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: method

  columns: [id, function, args, expected]
  rows:
    - [canonic,            Bdb.canonic.__name__.__eq__,            ["canonic"],            true]
    - [reset,              Bdb.reset.__name__.__eq__,              ["reset"],              true]
    - [stop_here,          Bdb.stop_here.__name__.__eq__,          ["stop_here"],          true]
    - [break_here,         Bdb.break_here.__name__.__eq__,         ["break_here"],         true]
    - [user_line,          Bdb.user_line.__name__.__eq__,          ["user_line"],          true]
    - [user_return,        Bdb.user_return.__name__.__eq__,        ["user_return"],        true]
    - [do_clear,           Bdb.do_clear.__name__.__eq__,           ["do_clear"],           true]
    - [runctx,             Bdb.runctx.__name__.__eq__,             ["runctx"],             true]
    - [get_stack,          Bdb.get_stack.__name__.__eq__,          ["get_stack"],          true]
    - [format_stack_entry, Bdb.format_stack_entry.__name__.__eq__, ["format_stack_entry"], true]
    - [dispatch_line,      Bdb.dispatch_line.__name__.__eq__,      ["dispatch_line"],      true]
    - [dispatch_call,      Bdb.dispatch_call.__name__.__eq__,      ["dispatch_call"],      true]

# ---------------------------------------------------------------------------
# Breakpoint method names — enable, disable, bpprint, bpformat, deleteMe
# No prior bdb spec checks these Breakpoint instance methods.
# ---------------------------------------------------------------------------

table bdb_extra4.breakpoint_method_names:
  kind: python_call_eq
  category: breakpoint_methods
  id_prefix: bpmethod

  columns: [id, function, args, expected]
  rows:
    - [enable,    Breakpoint.enable.__name__.__eq__,    ["enable"],    true]
    - [disable,   Breakpoint.disable.__name__.__eq__,   ["disable"],   true]
    - [bpprint,   Breakpoint.bpprint.__name__.__eq__,   ["bpprint"],   true]
    - [bpformat,  Breakpoint.bpformat.__name__.__eq__,  ["bpformat"],  true]
    - [deleteMe,  Breakpoint.deleteMe.__name__.__eq__,  ["deleteMe"],  true]

# ---------------------------------------------------------------------------
# bdb.set_trace — module-level convenience function
# Distinct from Bdb.set_trace (the instance method).
# No prior spec checks the module-level set_trace symbol.
# ---------------------------------------------------------------------------

invariant bdb_extra4.set_trace.name:
  description: "bdb.set_trace.__name__ == 'set_trace' — module-level set_trace function"
  category: module_functions
  kind: python_call_eq
  function: set_trace.__name__.__eq__
  args: ["set_trace"]
  expected: true

invariant bdb_extra4.set_trace.module:
  description: "bdb.set_trace.__module__ == 'bdb'"
  category: module_functions
  kind: python_call_eq
  function: set_trace.__module__.__eq__
  args: ["bdb"]
  expected: true
