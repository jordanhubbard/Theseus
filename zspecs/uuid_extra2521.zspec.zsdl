spec: uuid_extra2521
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra161.zspec.zsdl — covers uuid.UUID.__dict__.__contains__ for __int__/__hash__/__eq__/__str__; NAMESPACE_DNS/__int__ bound method class name 'method' (table + standalones)."
    - "uuid_extra180.zspec.zsdl — covers additional uuid invariants (see that file for details)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid.zspec.zsdl, uuid_extra.zspec.zsdl, uuid_extra161.zspec.zsdl, or uuid_extra180.zspec.zsdl."
    - "Theme: __bool__, __index__, and __int__ dict-presence for uuid.UUID and uuid.SafeUUID."
    - "uuid.UUID.__dict__.__contains__('__int__') == True — UUID defines __int__ in pure Python (Lib/uuid.py); UUID.__int__ returns self.int (the 128-bit integer value); this makes int(uuid_obj) work as a shorthand. Confirmed Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__bool__') == False — UUID does not define __bool__; bool(uuid_obj) delegates to object.__bool__ (always True for any non-None UUID instance)."
    - "uuid.UUID.__dict__.__contains__('__index__') == False — UUID does not define __index__; UUID objects cannot be used as sequence indices despite defining __int__."
    - "uuid.SafeUUID.__dict__.__contains__('__int__') == False — SafeUUID (an Enum subclass) does not define __int__ in its own __dict__; SafeUUID is not an IntEnum, so int coercion is not directly supported via __int__."
    - "uuid.SafeUUID.__dict__.__contains__('__bool__') == False — SafeUUID does not define __bool__ in its own __dict__."
    - "uuid.SafeUUID.__dict__.__contains__('__index__') == False — SafeUUID does not define __index__ in its own __dict__."
    - "uuid.UUID defines __int__ (True) but not __index__ (False): having __int__ does not automatically grant __index__ — __index__ must be defined separately and implies lossless integer conversion for indexing purposes."
    - "uuid.SafeUUID inherits from Enum (not IntEnum), so it has no integer-coercion support at the class level."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID __bool__ / __int__ / __index__ dict-presence
#
# UUID defines __int__ (True) but not __bool__ or __index__.
# UUID.__int__ is defined in Lib/uuid.py as: return self.int
# It returns the 128-bit integer value, enabling int(uuid_obj).
# __index__ is NOT defined despite __int__ existing — __index__ is a stricter
# protocol implying lossless integer conversion suitable for indices/slices.
# __bool__ is NOT defined — UUID instances are unconditionally truthy.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table uuid_extra2521.UUID_bool_int_index:
  description: "uuid.UUID.__dict__.__contains__('__bool__')==False / UUID.__dict__.__contains__('__int__')==True / UUID.__dict__.__contains__('__index__')==False — UUID does not define __bool__ (no truthiness override; bool(uuid_obj) is always True via object default); UUID DOES define __int__ in its own __dict__ (UUID.__int__(self) returns self.int — the 128-bit integer representation; Lib/uuid.py defines __int__ explicitly; enables int(uuid_obj)); UUID does not define __index__ despite defining __int__ (__index__ is a stricter protocol for lossless integer coercion used in sequence indexing and slice operations — UUID has no meaningful sequence-index semantics so __index__ is intentionally absent); the asymmetry __int__=True/__index__=False is notable: defining __int__ does not imply __index__; first uu2521 anchor for UUID coercion-dunder presence/absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2521

  columns: [id, function, args, expected]
  rows:
    - ["uu2521_uuid_no_bool",   "UUID.__dict__.__contains__", ["__bool__"],  false]
    - ["uu2521_uuid_has_int",   "UUID.__dict__.__contains__", ["__int__"],   true]
    - ["uu2521_uuid_no_index",  "UUID.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# uuid.SafeUUID __bool__ / __int__ / __index__ dict-presence
#
# SafeUUID is an Enum subclass (not IntEnum). It has no integer-coercion support
# in its own __dict__. All three coercion dunders are absent.
# SafeUUID.safe == 1, SafeUUID.unsafe == -1 but these are Enum member values,
# not enabled via __int__ in SafeUUID.__dict__.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table uuid_extra2521.SafeUUID_bool_int_index:
  description: "uuid.SafeUUID.__dict__.__contains__('__bool__')==False / SafeUUID.__dict__.__contains__('__int__')==False / SafeUUID.__dict__.__contains__('__index__')==False — SafeUUID is an Enum subclass (not IntEnum); SafeUUID.__mro__ == [SafeUUID, Enum, object]; SafeUUID.safe==1 and SafeUUID.unsafe==-1 but these integer values are Enum member values, not surfaced via __int__ in SafeUUID.__dict__; SafeUUID does not define __bool__ (__bool__ not in SafeUUID.__dict__); SafeUUID does not define __int__ (__int__ not in SafeUUID.__dict__; contrast with uuid.UUID which DOES define __int__); SafeUUID does not define __index__ (__index__ not in SafeUUID.__dict__); all three coercion dunders absent from SafeUUID; contrast: UUID has __int__=True but SafeUUID has __int__=False — SafeUUID is a value-enum, UUID is a data class; first uu2521 anchor for SafeUUID coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2521

  columns: [id, function, args, expected]
  rows:
    - ["uu2521_safeuuid_no_bool",  "SafeUUID.__dict__.__contains__", ["__bool__"],  false]
    - ["uu2521_safeuuid_no_int",   "SafeUUID.__dict__.__contains__", ["__int__"],   false]
    - ["uu2521_safeuuid_no_index", "SafeUUID.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# Standalone: uuid.UUID.__dict__.__contains__('__bool__') == False
#
# UUID does not define __bool__. bool(uuid_obj) delegates to object.__bool__
# which returns True for any non-None object. All UUID instances are truthy.
# uuid_extra161 anchors __int__/__hash__/__eq__/__str__ membership; this file
# anchors __bool__ and __index__ absence. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra2521.UUID_no_bool_standalone:
  description: "uuid.UUID.__dict__.__contains__('__bool__') == False — UUID does not define __bool__ in its own __dict__; bool(uuid_obj) delegates to object.__bool__ (always True for any non-None UUID instance; UUID instances are always truthy regardless of their content); '__bool__'=8 chars = '__'=2 + 'bool'=4 + '__'=2; absence of __bool__ contrasts with presence of __int__: UUID defines integer coercion (__int__=True) but not truthiness (__bool__=False in __dict__); uuid_extra161 anchors __int__/__hash__/__eq__/__str__ dict membership — this spec anchors __bool__ and __index__ absence; first uu2521 standalone for UUID no-__bool__"
  category: dict_presence
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__bool__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: uuid.UUID.__dict__.__contains__('__int__') == True
#
# UUID defines __int__ in Lib/uuid.py: return self.int
# This is the 128-bit integer representation of the UUID.
# int(uuid_obj) works as a shorthand for uuid_obj.int.
# uuid_extra161 already anchors this; this standalone re-anchors it under uu2521
# as the key True result among the three coercion dunders.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra2521.UUID_has_int_standalone:
  description: "uuid.UUID.__dict__.__contains__('__int__') == True — UUID defines __int__ in its own __dict__ (Lib/uuid.py); UUID.__int__(self) returns self.int — the 128-bit integer representation of the UUID; enables int(uuid_obj) as equivalent to uuid_obj.int; '__int__'=7 chars = '__'=2 + 'int'=3 + '__'=2; UUID.__int__ is the ONLY coercion dunder present in UUID.__dict__ among __bool__/__int__/__index__; uuid_extra161 anchors __int__ presence in a table row — this spec anchors it as a standalone under uu2521; first uu2521 standalone for UUID has-__int__"
  category: dict_presence
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__int__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: uuid.UUID.__dict__.__contains__('__index__') == False
#
# UUID defines __int__ but NOT __index__. This asymmetry is significant:
# __index__ is a stricter protocol for lossless integer coercion, used when
# an object is used as a sequence index (list[x]) or in slice operations.
# UUID's __int__ returns a 128-bit integer but UUID objects are not meaningful
# as sequence indices, so __index__ is intentionally absent.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra2521.UUID_no_index_standalone:
  description: "uuid.UUID.__dict__.__contains__('__index__') == False — UUID does not define __index__ despite defining __int__; __index__ is a stricter integer-coercion protocol: it implies the integer is a lossless representation suitable for sequence indexing (list[x]) and slice operations; UUID's 128-bit integer (from __int__) is not meaningful as a sequence index, so __index__ is intentionally absent; '__index__'=9 chars = '__'=2 + 'index'=5 + '__'=2; dunder length ordering: '__int__'(7) < '__bool__'(8) < '__index__'(9); '__index__' is the longest coercion dunder; the asymmetry UUID.__int__=True / UUID.__index__=False demonstrates that __int__ does not imply __index__; first uu2521 standalone for UUID no-__index__"
  category: dict_presence
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__index__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: uuid.SafeUUID.__dict__.__contains__('__int__') == False
#
# SafeUUID (Enum subclass) has no __int__ in its own __dict__, contrasting with
# uuid.UUID which does define __int__. SafeUUID.safe and SafeUUID.unsafe have
# integer values (1 and -1) but these are enum member values, not accessible
# via __int__ at the class level. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra2521.SafeUUID_no_int_standalone:
  description: "uuid.SafeUUID.__dict__.__contains__('__int__') == False — SafeUUID (Enum subclass, not IntEnum) does not define __int__ in its own __dict__; SafeUUID.safe==1 and SafeUUID.unsafe==-1 are Enum member integer values but __int__ is not defined at the class level; contrasts with uuid.UUID which DOES define __int__ (True); SafeUUID.__mro__ == [SafeUUID, Enum, object] — no int ancestor, unlike socket.AddressFamily which inherits from IntEnum and int; '__int__'=7 chars; first uu2521 standalone for SafeUUID no-__int__"
  category: dict_presence
  kind: python_call_eq
  function: SafeUUID.__dict__.__contains__
  args: ["__int__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: uuid.SafeUUID.__dict__.__contains__('__index__') == False
# ---------------------------------------------------------------------------

invariant uuid_extra2521.SafeUUID_no_index_standalone:
  description: "uuid.SafeUUID.__dict__.__contains__('__index__') == False — SafeUUID does not define __index__; SafeUUID is an Enum subclass with no integer-indexing semantics; '__index__'=9 chars is the longest coercion dunder in this spec; all three coercion dunders (__bool__/__int__/__index__) are absent from SafeUUID.__dict__; this contrasts with UUID where __int__ is present; first uu2521 standalone for SafeUUID no-__index__"
  category: dict_presence
  kind: python_call_eq
  function: SafeUUID.__dict__.__contains__
  args: ["__index__"]
  expected: false

# ---------------------------------------------------------------------------
# uuid generator function class __bool__ / __int__ / __index__ dict-presence
#
# uuid1, uuid3, uuid4, uuid5 are module-level Python functions.
# Their __class__ is the 'function' type. The 'function' type's __dict__
# does not contain __bool__, __int__, or __index__.
# This table confirms that the uuid generator functions' type also lacks
# numeric coercion dunders, consistent with the theme.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table uuid_extra2521.uuid_generators_class_bool_int_index:
  description: "uuid.uuid4.__class__.__dict__.__contains__('__bool__')==False / uuid4.__class__.__dict__.__contains__('__int__')==False / uuid4.__class__.__dict__.__contains__('__index__')==False / uuid1.__class__.__dict__.__contains__('__bool__')==False — uuid1/uuid3/uuid4/uuid5 are module-level Python 'function' objects (uuid4.__class__.__name__=='function'); the 'function' type's own __dict__ does not contain __bool__ (Python function objects have no truthiness protocol beyond the default — all functions are truthy); does not contain __int__ (functions are not integer-coercible); does not contain __index__ (functions cannot serve as sequence indices); all four uuid generator functions share the same 'function' type; contrasts with hashlib constructors (builtin_function_or_method) — uuid functions are pure Python (Lib/uuid.py) while hashlib constructors are C builtins; first uu2521 anchor for uuid generator function class coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2521

  columns: [id, function, args, expected]
  rows:
    - ["uu2521_uuid4_cls_no_bool",  "uuid4.__class__.__dict__.__contains__", ["__bool__"],  false]
    - ["uu2521_uuid4_cls_no_int",   "uuid4.__class__.__dict__.__contains__", ["__int__"],   false]
    - ["uu2521_uuid4_cls_no_index", "uuid4.__class__.__dict__.__contains__", ["__index__"], false]
    - ["uu2521_uuid1_cls_no_bool",  "uuid1.__class__.__dict__.__contains__", ["__bool__"],  false]

# ---------------------------------------------------------------------------
# uuid.UUID ordering dunders present in __dict__
#
# UUID defines comparison operators in Lib/uuid.py:
# __lt__, __gt__, __le__, __ge__ are all present in UUID.__dict__.
# These are True — included here to contrast with __bool__/__index__ (False)
# and to show that __int__ (True) is not the only numeric-adjacent dunder in UUID.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table uuid_extra2521.UUID_ordering_dunders_present:
  description: "uuid.UUID.__dict__.__contains__('__lt__')==True / UUID.__dict__.__contains__('__gt__')==True / UUID.__dict__.__contains__('__le__')==True / UUID.__dict__.__contains__('__ge__')==True — UUID defines all four ordering comparison operators in Lib/uuid.py; __lt__/__gt__/__le__/__ge__ are all present in UUID.__dict__ (True); these enable UUID objects to be sorted (sorted([uuid1, uuid2]) works because UUID defines ordering); this contrasts with __bool__=False / __index__=False — UUID defines ordering (comparison protocol) but not truthiness override or integer indexing; __int__=True and ordering dunders True together show UUID has rich numeric-adjacent behavior while still lacking __bool__ and __index__; '__lt__'=6 chars == '__gt__'=6 chars == '__le__'=6 chars == '__ge__'=6 chars — all four ordering dunders have the same 6-char length; contrasts with '__int__'=7 chars > '__lt__'=6 chars; first uu2521 anchor for UUID ordering dunder presence alongside coercion context"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2521

  columns: [id, function, args, expected]
  rows:
    - ["uu2521_uuid_has_lt", "UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu2521_uuid_has_gt", "UUID.__dict__.__contains__", ["__gt__"], true]
    - ["uu2521_uuid_has_le", "UUID.__dict__.__contains__", ["__le__"], true]
    - ["uu2521_uuid_has_ge", "UUID.__dict__.__contains__", ["__ge__"], true]
