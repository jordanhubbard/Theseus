spec: inspect_extra154
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers __code__.co_name 'getmembers', co_argcount 2; inspect.getfile __code__.co_name 'getfile', co_argcount 1; inspect.getsourcefile __code__.co_name 'getsourcefile'; inspect.getsource __code__.co_name 'getsource'; inspect.getdoc __code__.co_name 'getdoc'; inspect.getmodule __code__.co_name 'getmodule' (Wave 283)."
    - "inspect.getmembers.__code__.co_name == 'getmembers' — getmembers is a Python function in Lib/inspect.py; co_name equals the function name. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2 — getmembers(object, predicate=None) takes 2 positional-or-keyword arguments. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_name == 'getfile' — getfile is a Python function in Lib/inspect.py; co_name equals the function name. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_argcount == 1 — getfile(object) takes 1 argument. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_name == 'getsourcefile' — Python function in Lib/inspect.py; co_name equals the function name. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_name == 'getsource' — Python function in Lib/inspect.py; co_name equals the function name. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_name == 'getdoc' — Python function in Lib/inspect.py; co_name equals the function name. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_name == 'getmodule' — Python function in Lib/inspect.py; co_name equals the function name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers and inspect.getfile code attributes
#
# Wave 283 theme: inspect function __code__ attributes — co_name and co_argcount.
#
# inspect.getmembers.__code__.co_name == 'getmembers'
# inspect.getmembers.__code__.co_argcount == 2
# inspect.getfile.__code__.co_name == 'getfile'
# inspect.getfile.__code__.co_argcount == 1
#
# getmembers(object, predicate=None) is a Python function in Lib/inspect.py
# that returns all members of an object as (name, value) pairs.
# getfile(object) returns the file in which an object was defined.
# New to extra154.
# ---------------------------------------------------------------------------

table inspect_extra154.getmembers_and_getfile_code_attrs:
  description: "inspect.getmembers: co_name 'getmembers', co_argcount 2; inspect.getfile: co_name 'getfile', co_argcount 1; wave 283; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgmgfca154

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_name_eq,
       "getmembers.__code__.co_name.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — getmembers is a Python function in Lib/inspect.py returning all members of an object as (name, value) pairs; its code object co_name is 'getmembers'; str.__eq__('getmembers') returns True; new to extra154"]
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) takes 2 positional-or-keyword arguments; co_argcount is 2; int.__eq__(2) returns True; new to extra154"]
    - [getfile_co_name_eq,
       "getfile.__code__.co_name.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_name.__eq__('getfile') == True — getfile is a Python function in Lib/inspect.py returning the file in which an object was defined; its code object co_name is 'getfile'; str.__eq__('getfile') returns True; new to extra154"]
    - [getfile_co_argcount_eq_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile(object) takes exactly 1 positional-or-keyword argument; co_argcount is 1; int.__eq__(1) returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsourcefile, getsource, getdoc, getmodule code names
#
# Wave 283 theme: inspect utility function __code__.co_name attributes.
#
# inspect.getsourcefile.__code__.co_name == 'getsourcefile'
# inspect.getsource.__code__.co_name == 'getsource'
# inspect.getdoc.__code__.co_name == 'getdoc'
# inspect.getmodule.__code__.co_name == 'getmodule'
#
# All are Python functions in Lib/inspect.py; each code object's co_name
# equals the function's name. New to extra154.
# ---------------------------------------------------------------------------

table inspect_extra154.getsourcefile_getsource_getdoc_getmodule_conames:
  description: "inspect.getsourcefile/getsource/getdoc/getmodule: co_name equals function name; Python functions in Lib/inspect.py; wave 283; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgsggcn154

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_co_name_eq,
       "getsourcefile.__code__.co_name.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__code__.co_name.__eq__('getsourcefile') == True — getsourcefile is a Python function in Lib/inspect.py returning the .py source file for an object; its code object co_name is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra154"]
    - [getsource_co_name_eq,
       "getsource.__code__.co_name.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__code__.co_name.__eq__('getsource') == True — getsource is a Python function in Lib/inspect.py returning the source text of an object; its code object co_name is 'getsource'; str.__eq__('getsource') returns True; new to extra154"]
    - [getdoc_co_name_eq,
       "getdoc.__code__.co_name.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc is a Python function in Lib/inspect.py returning the cleaned-up __doc__ of an object; its code object co_name is 'getdoc'; str.__eq__('getdoc') returns True; new to extra154"]
    - [getmodule_co_name_eq,
       "getmodule.__code__.co_name.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__code__.co_name.__eq__('getmodule') == True — getmodule is a Python function in Lib/inspect.py returning the module in which an object was defined; its code object co_name is 'getmodule'; str.__eq__('getmodule') returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra154
# ---------------------------------------------------------------------------

invariant inspect_extra154.getmembers_co_name_eq:
  description: "inspect.getmembers.__code__.co_name == 'getmembers' — code object name for the getmembers function; wave 283; new to extra154"
  kind: python_call_eq
  function: getmembers.__code__.co_name.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra154.getmembers_co_argcount_2:
  description: "inspect.getmembers.__code__.co_argcount == 2 — getmembers(object, predicate=None) takes 2 args; wave 283; new to extra154"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

