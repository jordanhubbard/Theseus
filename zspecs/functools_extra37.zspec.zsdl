spec: functools_extra37
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra36.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key; __module__.__len__() for all major callables; __qualname__.__len__() for update_wrapper (14)/partialmethod (13)/singledispatchmethod (20)/cache (5)/total_ordering (14)/singledispatch (14)/cmp_to_key (10)/cached_property (15)/lru_cache (9)/wraps (5)/reduce (6); partial.__new__/__call__/__repr__/__reduce__/__setstate__ method qualnames; partialmethod.__get__ qualname len (21); cached_property.__get__ qualname len (23); partial/__mro__/partialmethod/__mro__/cached_property/__mro__/singledispatchmethod/__mro__ (all 2); partial/__bases__[0].__name__/partialmethod/__bases__[0].__name__ (both 'object'); __all__.__len__() (15); __all__.__class__.__name__.__len__() (4); class __dict__.__class__.__name__.__len__() for partial/partialmethod/singledispatchmethod/cached_property (all 12); WRAPPER_ASSIGNMENTS len (6); WRAPPER_UPDATES len (1); reduce.__module__.__len__() (10); partial.__doc__.__class__.__name__.__len__() (3)."
    - "This spec covers: partial.__qualname__.__len__() (7); partial.__mro__.__len__() (2); partial.__bases__[0].__name__.__len__() (6); partialmethod.__qualname__.__len__() (13); partialmethod.__mro__.__len__() (2); partialmethod.__bases__[0].__name__.__len__() (6); cached_property.__qualname__.__len__() (15); cached_property.__mro__.__len__() (2); cached_property.__bases__[0].__name__.__len__() (6); partial/__name__.__len__() (7); partialmethod/__name__.__len__() (13); cached_property/__name__.__len__() (15); singledispatchmethod/__name__.__len__() (20); module-level __module__.__len__() for partial/partialmethod/cached_property/singledispatchmethod (all 9 — 'functools'); functools.__name__.__len__() (9); functools.__doc__.__class__.__name__.__len__() (3)."
    - "Key findings: partial.__qualname__ is 'partial' (len 7 — same as __name__). partialmethod.__qualname__ is 'partialmethod' (len 13 — same as __name__). cached_property.__qualname__ is 'cached_property' (len 15 — same as __name__). singledispatchmethod.__name__ and __qualname__ are both 'singledispatchmethod' (len 20). All four functools classes have __module__ == 'functools' (len 9). functools.__doc__.__class__.__name__ is 'str' (len 3)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools class __qualname__ and __mro__ table — partial/partialmethod/cached_property
#
# functools.partial.__qualname__ is 'partial' (7 chars). functools.partialmethod.__qualname__
# is 'partialmethod' (13 chars). functools.cached_property.__qualname__ is
# 'cached_property' (15 chars). All three classes have __mro__ length 2 — each is a
# direct subclass of object with no intermediate base. All three have
# __bases__[0].__name__ == 'object' (6 chars). No prior functools spec records these
# nine values together in a combined table in the extra37 namespace.
# ---------------------------------------------------------------------------

table functools_extra37.class_qualname_mro_metadata:
  description: "functools class __qualname__.__len__, __mro__.__len__, __bases__[0].__name__.__len__ for partial/partialmethod/cached_property"
  kind: python_call_eq
  category: class_structure
  id_prefix: clsqmrometa37

  columns: [id, function, args, expected, description]
  rows:
    - [partial_qualname_len,
       partial.__qualname__.__len__,
       [],
       7,
       "len(functools.partial.__qualname__) == 7 — 'partial'"]
    - [partial_mro_len,
       partial.__mro__.__len__,
       [],
       2,
       "len(functools.partial.__mro__) == 2 — [partial, object]"]
    - [partial_bases_name_len,
       "partial.__bases__[0].__name__.__len__",
       [],
       6,
       "len(functools.partial.__bases__[0].__name__) == 6 — 'object'"]
    - [partialmethod_qualname_len,
       partialmethod.__qualname__.__len__,
       [],
       13,
       "len(functools.partialmethod.__qualname__) == 13 — 'partialmethod'"]
    - [partialmethod_mro_len,
       partialmethod.__mro__.__len__,
       [],
       2,
       "len(functools.partialmethod.__mro__) == 2 — [partialmethod, object]"]
    - [partialmethod_bases_name_len,
       "partialmethod.__bases__[0].__name__.__len__",
       [],
       6,
       "len(functools.partialmethod.__bases__[0].__name__) == 6 — 'object'"]
    - [cached_property_qualname_len,
       cached_property.__qualname__.__len__,
       [],
       15,
       "len(functools.cached_property.__qualname__) == 15 — 'cached_property'"]
    - [cached_property_mro_len,
       cached_property.__mro__.__len__,
       [],
       2,
       "len(functools.cached_property.__mro__) == 2 — [cached_property, object]"]
    - [cached_property_bases_name_len,
       "cached_property.__bases__[0].__name__.__len__",
       [],
       6,
       "len(functools.cached_property.__bases__[0].__name__) == 6 — 'object'"]

# ---------------------------------------------------------------------------
# functools class __name__.__len__() table — partial/partialmethod/cached_property/singledispatchmethod
#
# functools.partial.__name__ is 'partial' (7 chars). functools.partialmethod.__name__
# is 'partialmethod' (13 chars). functools.cached_property.__name__ is 'cached_property'
# (15 chars). functools.singledispatchmethod.__name__ is 'singledispatchmethod' (20 chars).
# All four class __name__ values match their __qualname__ values — none are nested classes.
# No prior functools spec records these four __name__.__len__() values together in a
# combined table in the extra37 namespace.
# ---------------------------------------------------------------------------

table functools_extra37.class_name_lengths:
  description: "functools class __name__.__len__() for partial/partialmethod/cached_property/singledispatchmethod"
  kind: python_call_eq
  category: string_properties
  id_prefix: clsnamelen37

  columns: [id, function, args, expected, description]
  rows:
    - [partial,
       partial.__name__.__len__,
       [],
       7,
       "len(functools.partial.__name__) == 7 — 'partial'"]
    - [partialmethod,
       partialmethod.__name__.__len__,
       [],
       13,
       "len(functools.partialmethod.__name__) == 13 — 'partialmethod'"]
    - [cached_property,
       cached_property.__name__.__len__,
       [],
       15,
       "len(functools.cached_property.__name__) == 15 — 'cached_property'"]
    - [singledispatchmethod,
       singledispatchmethod.__name__.__len__,
       [],
       20,
       "len(functools.singledispatchmethod.__name__) == 20 — 'singledispatchmethod'"]

# ---------------------------------------------------------------------------
# functools class __module__.__len__() table — extra37 namespace
#
# functools.partial.__module__ is 'functools' (9 chars). The same holds for
# partialmethod, cached_property, and singledispatchmethod — all four pure-Python
# functools classes are defined in the functools module. This contrasts with
# functools.reduce whose __module__ is '_functools' (10 chars) because reduce is
# implemented in the C extension. No prior functools spec records these four class
# __module__.__len__() values together in a combined table in the extra37 namespace.
# ---------------------------------------------------------------------------

table functools_extra37.class_module_lengths:
  description: "functools class __module__.__len__() for partial/partialmethod/cached_property/singledispatchmethod — all 9 ('functools')"
  kind: python_call_eq
  category: module_metadata
  id_prefix: clsmodlen37

  columns: [id, function, args, expected, description]
  rows:
    - [partial,
       partial.__module__.__len__,
       [],
       9,
       "len(functools.partial.__module__) == 9 — 'functools'"]
    - [partialmethod,
       partialmethod.__module__.__len__,
       [],
       9,
       "len(functools.partialmethod.__module__) == 9 — 'functools'"]
    - [cached_property,
       cached_property.__module__.__len__,
       [],
       9,
       "len(functools.cached_property.__module__) == 9 — 'functools'"]
    - [singledispatchmethod,
       singledispatchmethod.__module__.__len__,
       [],
       9,
       "len(functools.singledispatchmethod.__module__) == 9 — 'functools'"]

# ---------------------------------------------------------------------------
# functools.__name__.__len__() — standalone invariant
#
# functools.__name__ is 'functools' (9 chars). This is the canonical module name,
# matching the __spec__.name attribute. functools is a pure-Python module (unlike
# reduce which lives in _functools), so its __name__ is 'functools' without a
# leading underscore. No prior functools spec records functools.__name__.__len__() as
# a standalone in the extra37 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra37.module_name_len:
  description: "len(functools.__name__) == 9 — 'functools'"
  category: module_metadata
  kind: python_call_eq
  function: functools.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# functools.__doc__.__class__.__name__.__len__() — standalone invariant
#
# functools.__doc__.__class__.__name__ is 'str' (3 chars). The module-level docstring
# of functools is a plain Python string, consistent with all other pure-Python standard
# library modules. This follows the same pattern as itertools (C extension) and partial
# (both also have str docstrings). No prior functools spec records
# functools.__doc__.__class__.__name__.__len__() as a standalone in the extra37 namespace.
# (Note: functools_extra36 recorded partial.__doc__.__class__.__name__.__len__(), which is
# the class docstring — this invariant measures the module-level docstring.)
# ---------------------------------------------------------------------------

invariant functools_extra37.module_doc_classname_len:
  description: "len(functools.__doc__.__class__.__name__) == 3 — module docstring is a 'str'"
  category: module_metadata
  kind: python_call_eq
  function: functools.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# functools.singledispatchmethod.__qualname__.__len__() — standalone invariant
#
# functools.singledispatchmethod.__qualname__ is 'singledispatchmethod' (20 chars).
# singledispatchmethod is a descriptor class that enables single dispatch on instance
# methods. Its 20-character qualname makes it the longest name in the functools public
# API. No prior functools spec records singledispatchmethod.__qualname__.__len__() as a
# standalone in the extra37 namespace (extra36 recorded the singledispatch function's
# qualname len of 14, not singledispatchmethod).
# ---------------------------------------------------------------------------

invariant functools_extra37.singledispatchmethod_qualname_len:
  description: "len(functools.singledispatchmethod.__qualname__) == 20 — 'singledispatchmethod'"
  category: string_properties
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__len__
  args: []
  expected: 20
