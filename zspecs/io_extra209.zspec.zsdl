spec: io_extra209
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra208.zspec.zsdl — covers io.__name__, io.__package__, io.__spec__.name, io.__loader__.__class__.__name__, io.__doc__.__class__.__name__"
  notes:
    - "This spec covers io.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, and origin."
    - "io.__spec__.name == 'io'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS."
    - "io.__spec__.has_location == False; io is implemented as a frozen module (thin wrapper around _io); confirmed Python 3.14.3 macOS."
    - "io.__spec__.parent == ''; io is a top-level module with no parent package; confirmed Python 3.14.3 macOS."
    - "io.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS."
    - "io.__spec__.origin == 'frozen'; frozen modules have origin='frozen' rather than a filesystem path; confirmed Python 3.14.3 macOS."
    - "io is special: it is a pure-Python thin wrapper around the C extension _io, but it is loaded as a frozen module, so has_location is False and origin is 'frozen'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.__spec__.name identity
# name == 'io', length == 2
# ---------------------------------------------------------------------------

table io_extra209.spec_name:
  description: "io.__spec__.name attribute identity: value, equality, and length"
  kind: python_call_eq
  category: spec_identity
  id_prefix: iospec209

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        io.__spec__.name.__eq__,   ["io"],  true,  "io.__spec__.name == 'io'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"]
    - [name_len,       io.__spec__.name.__len__,  [],      2,     "io.__spec__.name.__len__() == 2; 'io' has i(1)o(2); confirmed Python 3.14.3 macOS"]
    - [name_not_pio,   io.__spec__.name.__eq__,   ["_io"], false, "io.__spec__.name != '_io'; the public wrapper spec name differs from the C accelerator; confirmed Python 3.14.3 macOS"]
    - [name_not_empty, io.__spec__.name.__eq__,   [""],    false, "io.__spec__.name is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.__spec__.has_location and io.__spec__.parent
# has_location == False (frozen module), parent == '' (top-level)
# ---------------------------------------------------------------------------

table io_extra209.spec_has_location_and_parent:
  description: "io.__spec__.has_location and io.__spec__.parent attribute identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: iospec209

  columns: [id, function, args, expected, description]
  rows:
    - [has_location_false,   io.__spec__.has_location.__eq__,          [false], true,  "io.__spec__.has_location == False; io is a frozen module so no file location; confirmed Python 3.14.3 macOS"]
    - [has_location_not_true, io.__spec__.has_location.__eq__,         [true],  false, "io.__spec__.has_location != True; io is frozen, not a file-based module; confirmed Python 3.14.3 macOS"]
    - [parent_eq,            io.__spec__.parent.__eq__,                [""],    true,  "io.__spec__.parent == ''; io is a top-level module with no parent package; confirmed Python 3.14.3 macOS"]
    - [parent_len,           io.__spec__.parent.__len__,               [],      0,     "io.__spec__.parent.__len__() == 0; empty string has length zero; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.__spec__.__class__.__name__ and io.__spec__.origin
# __class__.__name__ == 'ModuleSpec', origin == 'frozen'
# ---------------------------------------------------------------------------

table io_extra209.spec_class_and_origin:
  description: "io.__spec__.__class__.__name__ and io.__spec__.origin attribute identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: iospec209

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,     io.__spec__.__class__.__name__.__eq__,    ["ModuleSpec"], true,  "io.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"]
    - [class_name_len,    io.__spec__.__class__.__name__.__len__,   [],             10,    "io.__spec__.__class__.__name__.__len__() == 10; 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"]
    - [origin_eq,         io.__spec__.origin.__eq__,                ["frozen"],     true,  "io.__spec__.origin == 'frozen'; frozen modules have origin='frozen' not a file path; confirmed Python 3.14.3 macOS"]
    - [origin_len,        io.__spec__.origin.__len__,               [],             6,     "io.__spec__.origin.__len__() == 6; 'frozen' has f(1)r(2)o(3)z(4)e(5)n(6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra209.spec_name_eq:
  description: "io.__spec__.name == 'io' — the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.name.__eq__
  args: ["io"]
  expected: true

invariant io_extra209.spec_name_len:
  description: "io.__spec__.name.__len__() == 2 — 'io' has i(1)o(2); confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.name.__len__
  args: []
  expected: 2

invariant io_extra209.spec_has_location_false:
  description: "io.__spec__.has_location == False — io is a frozen module with no file-system location; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.has_location.__eq__
  args: [false]
  expected: true

invariant io_extra209.spec_parent_eq:
  description: "io.__spec__.parent == '' — io is a top-level module with no parent package; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.parent.__eq__
  args: [""]
  expected: true

invariant io_extra209.spec_parent_len:
  description: "io.__spec__.parent.__len__() == 0 — empty parent string has length zero; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.parent.__len__
  args: []
  expected: 0

invariant io_extra209.spec_class_name_eq:
  description: "io.__spec__.__class__.__name__ == 'ModuleSpec' — all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant io_extra209.spec_class_name_len:
  description: "io.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.__class__.__name__.__len__
  args: []
  expected: 10

invariant io_extra209.spec_origin_eq:
  description: "io.__spec__.origin == 'frozen' — frozen modules have origin='frozen' rather than a filesystem path; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: io.__spec__.origin.__eq__
  args: ["frozen"]
  expected: true

