spec: braces
version: ">=3.0.0"
backend: node(braces)

docs: https://github.com/micromatch/braces#readme

provenance:
  derived_from:
    - "braces README — https://github.com/micromatch/braces#readme"
    - "Bash brace expansion — POSIX shell §2.6.4"
    - "Test vectors verified with braces via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "braces source"
  notes:
    - "Brace expansion implementation — '{a,b}' or '{1..3}' style; used by micromatch / minimatch."
    - "Install: npm install braces"
    - "v3 CJS; module export IS the compile() entry point; .expand / .parse / .stringify / .compile / .create attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; throw on malformed input only when strict mode is on."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant braces.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant braces.has_expand:
  description: ".expand() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "expand.constructor.name"}
  expected: "Function"

invariant braces.has_parse:
  description: ".parse() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant braces.has_create:
  description: ".create() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "create.constructor.name"}
  expected: "Function"

invariant braces.compile_returns_array:
  description: "braces('{1..3}') returns ['([1-3])'] (range compiled to regex class)"
  category: compile
  kind: node_chain_eq
  entry: module
  entry_args: ["{1..3}"]
  chain: []
  expected: ["([1-3])"]

invariant braces.expand_alternation:
  description: "expand('{a,b}') yields ['a','b']"
  category: expand
  kind: node_chain_eq
  entry: named
  function: expand
  entry_args: ["{a,b}"]
  chain: []
  expected: ["a", "b"]

invariant braces.expand_range:
  description: "expand('{1..3}') yields ['1','2','3']"
  category: expand
  kind: node_chain_eq
  entry: named
  function: expand
  entry_args: ["{1..3}"]
  chain: []
  expected: ["1", "2", "3"]

invariant braces.expand_empty_passthrough:
  description: "expand('plain') without braces returns ['plain']"
  category: edge
  kind: node_chain_eq
  entry: named
  function: expand
  entry_args: ["plain"]
  chain: []
  expected: ["plain"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:02:22Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
