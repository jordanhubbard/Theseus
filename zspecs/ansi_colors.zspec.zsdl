spec: ansi_colors
version: ">=4.1.0"
backend: node(ansi-colors)

docs: https://github.com/doowb/ansi-colors#readme

provenance:
  derived_from:
    - "ansi-colors README — https://github.com/doowb/ansi-colors#readme"
    - "ANSI escape sequences — ECMA-48 / ISO/IEC 6429"
    - "Test vectors verified with ansi-colors via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "ansi-colors source"
  notes:
    - "Drop-in chalk alternative — wraps strings with ANSI color/style codes."
    - "Install: npm install ansi-colors"
    - "v4 CJS; default export is the colors object with named functions and chained styles (red.bold, etc.)."
    - "Has unstyle() to strip codes, and a symbols object with common terminal glyphs."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant ansi_colors.has_red:
  description: "red is callable (returns wrapped string)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: red, args: ["a"]}
    - {method: includes, args: ["a"]}
  expected: true

invariant ansi_colors.has_blue:
  description: "blue is callable (returns wrapped string)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: blue, args: ["b"]}
    - {method: includes, args: ["b"]}
  expected: true

invariant ansi_colors.has_bold:
  description: "bold is callable (returns wrapped string)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: bold, args: ["x"]}
    - {method: includes, args: ["x"]}
  expected: true

invariant ansi_colors.has_unstyle:
  description: "unstyle() is callable"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: unstyle, args: ["x"]}
  expected: "x"

invariant ansi_colors.red_wraps_red_codes:
  description: "red('x') wraps text in \\u001b[31m / \\u001b[39m"
  category: format
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: red, args: ["x"]}
  expected: "\x1b[31mx\x1b[39m"

invariant ansi_colors.red_dot_bold_chains:
  description: "red.bold is callable (chained styles)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: red}
    - {method: bold, args: ["x"]}
    - {method: includes, args: ["x"]}
  expected: true

invariant ansi_colors.unstyle_round_trip:
  description: "unstyle(red('hello')) returns 'hello'"
  category: format
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: unstyle, args: ["\x1b[31mhello\x1b[39m"]}
  expected: "hello"

invariant ansi_colors.symbols_has_heart:
  description: "symbols.heart contains the heart glyph"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "symbols.heart"}
  expected: "❤"

invariant ansi_colors.has_hasAnsi:
  description: "hasAnsi() detects ANSI codes in colored output"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: hasAnsi, args: ["\x1b[31mx\x1b[39m"]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:31:55Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
