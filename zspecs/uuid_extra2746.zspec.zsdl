spec: uuid_extra2746
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/uuid.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "uuid.UUID is a value-object class representing a universally unique identifier; it does not implement __round__, __divmod__, or __pow__ in its own __dict__."
    - "uuid.SafeUUID is an IntEnum subclass representing whether a UUID was generated safely; IntEnum provides arithmetic via the int MRO, but SafeUUID itself does NOT define __round__, __divmod__, or __pow__ in its own __dict__."
    - "None of the uuid public classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2746.round_protocol:
  description: "__round__ is absent from all uuid class __dict__s — none implement numeric rounding in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2746

  columns: [id, function, args, expected]
  rows:
    - ["uu2746001", "uuid.UUID.__dict__.__contains__",     ["__round__"], false]
    - ["uu2746002", "uuid.SafeUUID.__dict__.__contains__", ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2746.divmod_protocol:
  description: "__divmod__ is absent from all uuid class __dict__s — none implement divmod in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2746

  columns: [id, function, args, expected]
  rows:
    - ["uu2746003", "uuid.UUID.__dict__.__contains__",     ["__divmod__"], false]
    - ["uu2746004", "uuid.SafeUUID.__dict__.__contains__", ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2746.pow_protocol:
  description: "__pow__ is absent from all uuid class __dict__s — none implement exponentiation in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2746

  columns: [id, function, args, expected]
  rows:
    - ["uu2746005", "uuid.UUID.__dict__.__contains__",     ["__pow__"], false]
    - ["uu2746006", "uuid.SafeUUID.__dict__.__contains__", ["__pow__"], false]

# ---------------------------------------------------------------------------
# Combined view — UUID and SafeUUID vs. all three arithmetic protocols
# ---------------------------------------------------------------------------

table uuid_extra2746.uuid_arithmetic_combined:
  description: "uuid.UUID and uuid.SafeUUID define none of __round__, __divmod__, __pow__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2746

  columns: [id, function, args, expected]
  rows:
    - ["uu2746007", "uuid.UUID.__dict__.__contains__",     ["__round__"],  false]
    - ["uu2746008", "uuid.UUID.__dict__.__contains__",     ["__divmod__"], false]
    - ["uu2746009", "uuid.UUID.__dict__.__contains__",     ["__pow__"],    false]
    - ["uu2746010", "uuid.SafeUUID.__dict__.__contains__", ["__round__"],  false]
    - ["uu2746011", "uuid.SafeUUID.__dict__.__contains__", ["__divmod__"], false]
    - ["uu2746012", "uuid.SafeUUID.__dict__.__contains__", ["__pow__"],    false]
