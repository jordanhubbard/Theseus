spec: p_locate
version: ">=7.0.0"
backend: node(p-locate)
esm: true

docs: https://github.com/sindresorhus/p-locate#readme

provenance:
  derived_from:
    - "p-locate README — https://github.com/sindresorhus/p-locate#readme"
    - "Test vectors verified with p-locate via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-locate source"
  notes:
    - "Get the first fulfilled promise that satisfies a tester — used by find-up to short-circuit ancestor walks."
    - "Install: npm install p-locate"
    - "v7 ESM only; default export IS the function (input, tester, [options]) → Promise<value>."
    - "Spec covers shape only — JSON entry_args cannot pass async-function testers."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Returned promise rejects if any tester throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant p_locate.default_export_is_function:
  description: "Default export is an async function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "AsyncFunction"

invariant p_locate.default_name:
  description: "Default function name is 'pLocate'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pLocate"

invariant p_locate.default_arity:
  description: "Default function takes 2 args (input, tester)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 2

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:20:09Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
