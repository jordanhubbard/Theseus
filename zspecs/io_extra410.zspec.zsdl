spec: io_extra410
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.TextIOWrapper methods read, write, readline, readlines, writelines, flush, close, detach each report __name__ matching their Python-level name"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper method __name__ identity
# ---------------------------------------------------------------------------

table io_extra410.textiowrapper_method_names:
  description: "io.TextIOWrapper method __name__ identity — read, write, readline, readlines, writelines, flush, close, detach; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iotextiow410

  columns: [id, function, args, expected]
  rows:
    - [read_name,       io.TextIOWrapper.read.__name__.__eq__,       ["read"],       true]
    - [write_name,      io.TextIOWrapper.write.__name__.__eq__,      ["write"],      true]
    - [readline_name,   io.TextIOWrapper.readline.__name__.__eq__,   ["readline"],   true]
    - [readlines_name,  io.TextIOWrapper.readlines.__name__.__eq__,  ["readlines"],  true]
    - [writelines_name, io.TextIOWrapper.writelines.__name__.__eq__, ["writelines"], true]
    - [flush_name,      io.TextIOWrapper.flush.__name__.__eq__,      ["flush"],      true]
    - [close_name,      io.TextIOWrapper.close.__name__.__eq__,      ["close"],      true]
    - [detach_name,     io.TextIOWrapper.detach.__name__.__eq__,     ["detach"],     true]
