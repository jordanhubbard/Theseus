spec: zlib_extra4
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html
rfcs:
  - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
  - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
    - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib.zspec.zsdl — covers C library via ctypes"
    - "zlib_extra.zspec.zsdl — covers function names, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip"
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, method names, DEF_MEM_LEVEL int type, Z_BEST_COMPRESSION/Z_NO_COMPRESSION values, level/strategy tables, error module/MRO"
    - "zlib_extra3.zspec.zsdl — covers DEFLATED/DEF_MEM_LEVEL/DEF_BUF_SIZE/Z_DEFAULT_COMPRESSION/Z_FULL_FLUSH/Z_FILTERED/Z_HUFFMAN_ONLY/Z_DEFAULT_STRATEGY values, compress/decompress __module__"
  notes:
    - "This spec extends zlib_extra3.zspec.zsdl. Does NOT duplicate invariants already present in any prior zlib spec."
    - "zlib.MAX_WBITS == 15 — the maximum window bits value (32 KB window)."
    - "zlib.Z_SYNC_FLUSH == 2 — flush mode that flushes as much output as possible to the output buffer."
    - "zlib.Z_FINISH == 4 — flush mode signalling the end of the stream."
    - "zlib.Z_NO_FLUSH == 0 — flush mode indicating no flushing needed (keep buffering)."
    - "zlib.ZLIB_VERSION is a str (e.g. '1.2.12') — the zlib C library version string."
    - "zlib.adler32(b'hello') == 103547413 — known Adler-32 value; verified Python 3.12."
    - "zlib.crc32(b'hello') == 907060870 — known CRC-32 value; verified Python 3.12."
    - "zlib.adler32(b'hello world') == 436929629 — known Adler-32 value; verified Python 3.12."
    - "zlib.crc32(b'hello world') == 222957957 — known CRC-32 value; verified Python 3.12."
    - "zlib.error.__qualname__ == 'error' — no containing class, so qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zlib.error is raised on invalid compressed data or bad arguments."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# MAX_WBITS — maximum window bits constant
#
# zlib.MAX_WBITS == 15 corresponds to a 32 KB sliding window (2^15 bytes).
# No prior zlib spec covers MAX_WBITS at all.
# ---------------------------------------------------------------------------

invariant zlib_extra4.MAX_WBITS.value:
  description: "zlib.MAX_WBITS == 15 — maximum window bits for a 32 KB window"
  category: constants
  kind: python_call_eq
  function: MAX_WBITS.__eq__
  args: [15]
  expected: true

invariant zlib_extra4.MAX_WBITS.class_is_int:
  description: "zlib.MAX_WBITS.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_WBITS.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Flush-mode constants — Z_NO_FLUSH, Z_SYNC_FLUSH, Z_FINISH
#
# No prior zlib spec covers Z_NO_FLUSH, Z_SYNC_FLUSH, or Z_FINISH.
# zlib_extra3 covers Z_FULL_FLUSH == 3.
# ---------------------------------------------------------------------------

table zlib_extra4.flush_constants:
  kind: python_call_eq
  category: constants
  id_prefix: flush

  columns: [id, function, args, expected]
  rows:
    - [Z_NO_FLUSH,   Z_NO_FLUSH.__eq__,   [0], true]
    - [Z_SYNC_FLUSH, Z_SYNC_FLUSH.__eq__, [2], true]
    - [Z_FINISH,     Z_FINISH.__eq__,     [4], true]

# ---------------------------------------------------------------------------
# ZLIB_VERSION — library version string
#
# zlib.ZLIB_VERSION is a str attribute exposing the compile-time zlib version.
# No prior spec covers it. We check its type (str), not its exact value
# (which is platform-dependent), ensuring portability.
# ---------------------------------------------------------------------------

invariant zlib_extra4.ZLIB_VERSION.class_is_str:
  description: "zlib.ZLIB_VERSION.__class__.__name__ == 'str' — the version attribute is a string"
  category: constants
  kind: python_call_eq
  function: ZLIB_VERSION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# adler32 — known values for non-empty inputs
#
# zlib_extra covers adler32(b'') == 1. No prior spec covers non-empty
# well-known inputs. These anchors pin the Adler-32 algorithm behaviour.
# ---------------------------------------------------------------------------

invariant zlib_extra4.adler32.hello:
  description: "zlib.adler32(b'hello') == 103547413 — known Adler-32 value"
  category: checksum
  kind: python_call_eq
  function: adler32
  args: [!ascii "hello"]
  expected: 103547413

invariant zlib_extra4.adler32.hello_world:
  description: "zlib.adler32(b'hello world') == 436929629 — known Adler-32 value"
  category: checksum
  kind: python_call_eq
  function: adler32
  args: [!ascii "hello world"]
  expected: 436929629

# ---------------------------------------------------------------------------
# crc32 — known values for non-empty inputs
#
# zlib_extra covers crc32(b'') == 0. No prior spec covers non-empty
# well-known inputs.
# ---------------------------------------------------------------------------

invariant zlib_extra4.crc32.hello:
  description: "zlib.crc32(b'hello') == 907060870 — known CRC-32 value"
  category: checksum
  kind: python_call_eq
  function: crc32
  args: [!ascii "hello"]
  expected: 907060870

invariant zlib_extra4.crc32.hello_world:
  description: "zlib.crc32(b'hello world') == 222957957 — known CRC-32 value"
  category: checksum
  kind: python_call_eq
  function: crc32
  args: [!ascii "hello world"]
  expected: 222957957

# ---------------------------------------------------------------------------
# error.__qualname__ — module-level exception has qualname == name
#
# zlib_extra covers error.__name__ == 'error'.
# zlib_extra2 covers error.__module__ == 'zlib' and MRO.
# No prior spec checks error.__qualname__.
# ---------------------------------------------------------------------------

invariant zlib_extra4.error.qualname:
  description: "zlib.error.__qualname__ == 'error' — module-level class has qualname equal to name"
  category: class_names
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true
