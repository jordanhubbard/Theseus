spec: struct_extra193
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (len=17) — size is a C-level getset descriptor, not a property."
    - "struct.Struct.size.__class__.__module__ == 'builtins' (len=8) — getset_descriptor type lives in builtins."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (len=17) — format shares the same descriptor type as size."
    - "struct.Struct.format.__class__.__module__ == 'builtins' (len=8) — same module as size descriptor class."
    - "len('getset_descriptor') == 17 — calling __len__() on the name string yields 17 for both size and format."
    - "struct.Struct.__doc__.__class__.__name__ == 'str' (len=3) — __doc__ is a plain Python string."
    - "struct.Struct.__doc__.__class__.__module__ == 'builtins' (len=8) — str type lives in builtins, same module as getset_descriptor."
    - "size and format descriptors have identical class identity: both getset_descriptor from builtins."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size descriptor class identity
# size is a getset_descriptor from builtins (not a Python property)
# ---------------------------------------------------------------------------

table structdescriptors193.size_class:
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: structdescriptors193

  columns: [id, function, args, expected, description]
  rows:
    - [size_class_name,   Struct.size.__class__.__name__.__eq__,   ["getset_descriptor"], true, "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (C-level descriptor, not a property)"]
    - [size_class_module, Struct.size.__class__.__module__.__eq__,  ["builtins"],          true, "struct.Struct.size.__class__.__module__ == 'builtins' (getset_descriptor type lives in builtins)"]
    - [size_class_name_len, Struct.size.__class__.__name__.__len__, [], 17,                "len(struct.Struct.size.__class__.__name__) == 17 ('getset_descriptor' has 17 characters)"]

# ---------------------------------------------------------------------------
# struct.Struct.format descriptor class identity
# format shares the same getset_descriptor type as size
# ---------------------------------------------------------------------------

table structdescriptors193.format_class:
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: structdescriptors193

  columns: [id, function, args, expected, description]
  rows:
    - [format_class_name,   Struct.format.__class__.__name__.__eq__,   ["getset_descriptor"], true, "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (same descriptor type as size)"]
    - [format_class_module, Struct.format.__class__.__module__.__eq__,  ["builtins"],          true, "struct.Struct.format.__class__.__module__ == 'builtins' (same module as size descriptor class)"]
    - [format_class_name_len, Struct.format.__class__.__name__.__len__, [], 17,                "len(struct.Struct.format.__class__.__name__) == 17 ('getset_descriptor' — same length as size)"]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__ class identity
# __doc__ is a plain str from builtins; module matches size/format descriptors
# ---------------------------------------------------------------------------

table structdescriptors193.doc_class:
  kind: python_call_eq
  category: doc_identity
  id_prefix: structdescriptors193

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_name,   Struct.__doc__.__class__.__name__.__eq__,   ["str"],      true, "struct.Struct.__doc__.__class__.__name__ == 'str' (docstring is a plain Python string)"]
    - [doc_class_module, Struct.__doc__.__class__.__module__.__eq__,  ["builtins"], true, "struct.Struct.__doc__.__class__.__module__ == 'builtins' (str type lives in builtins, same as getset_descriptor)"]
    - [doc_class_name_len, Struct.__doc__.__class__.__name__.__len__, [], 3,        "len(struct.Struct.__doc__.__class__.__name__) == 3 ('str' has 3 characters — much shorter than 'getset_descriptor')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structdescriptors193.Struct.size.class_name:
  description: "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (C-level getset descriptor; not a Python property)"
  category: descriptor_identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant structdescriptors193.Struct.size.class_module:
  description: "struct.Struct.size.__class__.__module__ == 'builtins' (len=8 — getset_descriptor type is defined in builtins)"
  category: descriptor_identity
  kind: python_call_eq
  function: Struct.size.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant structdescriptors193.Struct.format.class_name:
  description: "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (same descriptor type as size; len=17)"
  category: descriptor_identity
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant structdescriptors193.Struct.format.class_module:
  description: "struct.Struct.format.__class__.__module__ == 'builtins' (same module as size; both descriptors share identical class identity)"
  category: descriptor_identity
  kind: python_call_eq
  function: Struct.format.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant structdescriptors193.Struct.size.class_name_len:
  description: "len(struct.Struct.size.__class__.__name__) == 17 ('getset_descriptor' has 17 characters)"
  category: descriptor_identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__len__
  args: []
  expected: 17

invariant structdescriptors193.Struct.format.class_name_len:
  description: "len(struct.Struct.format.__class__.__name__) == 17 ('getset_descriptor' — same length as size class name)"
  category: descriptor_identity
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__len__
  args: []
  expected: 17

invariant structdescriptors193.Struct.doc.class_name:
  description: "struct.Struct.__doc__.__class__.__name__ == 'str' (len=3 — docstring is a plain Python string, not a descriptor)"
  category: doc_identity
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant structdescriptors193.Struct.doc.class_module:
  description: "struct.Struct.__doc__.__class__.__module__ == 'builtins' (str type lives in builtins — same module as getset_descriptor)"
  category: doc_identity
  kind: python_call_eq
  function: Struct.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

