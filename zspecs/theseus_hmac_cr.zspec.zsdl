spec: theseus_hmac_cr
version: ">=3.0"
backend: python_cleanroom(theseus_hmac_cr)
blocks: hmac

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/hmac.html"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
  notes:
    - "Clean-room hmac module. Do NOT import hmac."

error_model: python_exceptions

invariant theseus_hmac_cr.hmac2_basic:
  description: "HMAC-SHA256 produces correct digest"
  category: behavior
  kind: python_call_eq
  function: hmac2_basic
  args: []
  expected: true

invariant theseus_hmac_cr.hmac2_digest:
  description: "digest() shortcut function works"
  category: behavior
  kind: python_call_eq
  function: hmac2_digest
  args: []
  expected: true

invariant theseus_hmac_cr.hmac2_compare:
  description: "compare_digest() is constant-time safe"
  category: behavior
  kind: python_call_eq
  function: hmac2_compare
  args: []
  expected: true
