spec: copy_extra21
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy_extra20.zspec.zsdl."
    - "Prior specs covered: copy.__name__/__package__, copy/deepcopy/Error/replace __name__/__module__, name/module length tables, __qualname__ checks, __qualname__.__eq__ table (extra20), __module__.__len__ for copy/deepcopy/Error (extra20), __name__.__len__ for copy/deepcopy (extra20), Error.__bases__[0].__name__, Error.__init__.__name__."
    - "This spec covers: __name__.__len__() table for all 4 exports (copy, deepcopy, replace, Error); __qualname__.__len__() table for all 4 exports; replace.__module__.__len__() and replace.__name__.__len__() standalone; Error.__name__.__len__() standalone."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "copy.copy.__name__.__len__() == 4. Verified."
    - "copy.deepcopy.__name__.__len__() == 8. Verified."
    - "copy.replace.__name__.__len__() == 7. Verified."
    - "copy.Error.__name__.__len__() == 5. Verified."
    - "copy.copy.__qualname__.__len__() == 4. Verified."
    - "copy.deepcopy.__qualname__.__len__() == 8. Verified."
    - "copy.replace.__qualname__.__len__() == 7. Verified."
    - "copy.Error.__qualname__.__len__() == 5. Verified."
    - "copy.replace.__module__ == 'copy'; len == 4. Verified."
    - "All four copy exports are top-level definitions in Lib/copy.py; __qualname__ equals __name__ for each."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for all 4 copy module exports — extra21 namespace
#
# copy.copy.__name__ == 'copy' (len 4); copy.deepcopy.__name__ == 'deepcopy'
# (len 8); copy.replace.__name__ == 'replace' (len 7); copy.Error.__name__ ==
# 'Error' (len 5). The table captures the four distinct name lengths side by
# side. copy_extra20 checks __name__.__len__() for copy and deepcopy as
# standalone invariants; this table covers all 4 in the extra21 namespace and
# adds replace and Error. id_prefix cpnl21 is novel.
# ---------------------------------------------------------------------------

table copy_extra21.name_lens:
  description: "__name__.__len__() for all 4 copy exports — copy=4, deepcopy=8, replace=7, Error=5"
  kind: python_call_eq
  category: function_name
  id_prefix: cpnl21

  columns: [id, function, method, method_args, expected]
  rows:
    - [copy_nl,    copy.__name__,    __len__, [], 4]
    - [deepcopy_nl, deepcopy.__name__, __len__, [], 8]
    - [replace_nl, replace.__name__, __len__, [], 7]
    - [Error_nl,   Error.__name__,   __len__, [], 5]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for all 4 copy module exports — extra21 namespace
#
# All 4 copy exports are module-level definitions in Lib/copy.py; their
# __qualname__ equals their simple __name__. Therefore __qualname__.__len__()
# yields the same values as __name__.__len__(). This table confirms the
# qualname==name invariant by measuring length directly. No prior copy spec
# checks __qualname__.__len__() in the extra21 namespace. id_prefix cpql21 is
# novel.
# ---------------------------------------------------------------------------

table copy_extra21.qualname_lens:
  description: "__qualname__.__len__() for all 4 copy exports — qualname equals name so lengths match name_lens"
  kind: python_call_eq
  category: function_qualname
  id_prefix: cpql21

  columns: [id, function, method, method_args, expected]
  rows:
    - [copy_ql,    copy.__qualname__,    __len__, [], 4]
    - [deepcopy_ql, deepcopy.__qualname__, __len__, [], 8]
    - [replace_ql, replace.__qualname__, __len__, [], 7]
    - [Error_ql,   Error.__qualname__,   __len__, [], 5]

# ---------------------------------------------------------------------------
# copy.replace.__module__.__len__() — length of 'copy' (4 chars)
#
# copy.replace is a pure-Python function defined in Lib/copy.py. Its
# __module__ == 'copy' (4 characters), the same as copy.copy and copy.deepcopy.
# copy_extra20 covers __module__.__len__() for copy, deepcopy, and Error but
# not replace. This invariant fills that gap in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra21.replace.module_len:
  description: "copy.replace.__module__.__len__() == 4 — len('copy') == 4"
  category: function_module
  kind: python_call_eq
  function: replace.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.replace.__name__.__len__() — length of 'replace' (7 chars)
#
# copy.replace.__name__ == 'replace'; len('replace') == 7. copy_extra20 covers
# __name__.__len__() for copy (4) and deepcopy (8) standalone. This invariant
# adds replace (7) as a standalone anchor in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra21.replace.name_len:
  description: "copy.replace.__name__.__len__() == 7 — len('replace') == 7"
  category: function_name
  kind: python_call_eq
  function: replace.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# copy.Error.__name__.__len__() — length of 'Error' (5 chars)
#
# copy.Error.__name__ == 'Error'; len('Error') == 5. copy_extra20 covers
# __module__.__len__() for copy.Error but not __name__.__len__(). This
# invariant anchors the name length for the exception class in extra21.
# ---------------------------------------------------------------------------

invariant copy_extra21.Error.name_len:
  description: "copy.Error.__name__.__len__() == 5 — len('Error') == 5"
  category: class_name
  kind: python_call_eq
  function: Error.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# copy.Error.__qualname__.__len__() — length of 'Error' (5 chars)
#
# copy.Error is a top-level class in Lib/copy.py; its __qualname__ == 'Error'
# (same as __name__). Therefore __qualname__.__len__() == 5. No prior copy spec
# checks __qualname__.__len__() for copy.Error as a standalone invariant in the
# extra21 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra21.Error.qualname_len:
  description: "copy.Error.__qualname__.__len__() == 5 — len('Error') == 5; qualname equals name for top-level class"
  category: class_qualname
  kind: python_call_eq
  function: Error.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# copy.copy.__qualname__.__len__() — length of 'copy' (4 chars)
#
# copy.copy.__qualname__ == 'copy'; len('copy') == 4. The function name and
# qualname are identical since copy is a top-level function. Standalone
# invariant in extra21 complements the qualname_lens table above.
# ---------------------------------------------------------------------------

invariant copy_extra21.copy.qualname_len:
  description: "copy.copy.__qualname__.__len__() == 4 — len('copy') == 4; top-level function qualname"
  category: function_qualname
  kind: python_call_eq
  function: copy.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.deepcopy.__qualname__.__len__() — length of 'deepcopy' (8 chars)
#
# copy.deepcopy.__qualname__ == 'deepcopy'; len('deepcopy') == 8. Standalone
# invariant in extra21 namespace confirming the qualname length for deepcopy,
# complementing the table above.
# ---------------------------------------------------------------------------

invariant copy_extra21.deepcopy.qualname_len:
  description: "copy.deepcopy.__qualname__.__len__() == 8 — len('deepcopy') == 8"
  category: function_qualname
  kind: python_call_eq
  function: deepcopy.__qualname__.__len__
  args: []
  expected: 8
