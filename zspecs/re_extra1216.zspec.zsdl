spec: re_extra1216
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.Pattern.__dict__.__contains__ checks for methods Pattern defines: match, search, findall, sub, split, fullmatch, finditer, subn; re.Match.__dict__.__contains__ checks for group, groups, groupdict, start, end, span"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern.__dict__.__contains__ for compiled-regex method names; checks re.Match.__dict__.__contains__ for match-object method names; checks re.error.__dict__.__contains__ for exception attribute names; none of these __dict__.__contains__ membership checks were covered in _extra1186, _extra1201, re_extra118, or any prior re_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1216.pattern_dict_contains_present:
  description: "re.Pattern.__dict__.__contains__ checks for compiled-regex methods — match, search, findall, sub, split, fullmatch, finditer, subn all present in Pattern.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1216pd
  columns: [id, function, args, expected]
  rows:
    - [re1216pd001, re.Pattern.__dict__.__contains__, ["match"],     true]
    - [re1216pd002, re.Pattern.__dict__.__contains__, ["search"],    true]
    - [re1216pd003, re.Pattern.__dict__.__contains__, ["findall"],   true]
    - [re1216pd004, re.Pattern.__dict__.__contains__, ["sub"],       true]
    - [re1216pd005, re.Pattern.__dict__.__contains__, ["split"],     true]
    - [re1216pd006, re.Pattern.__dict__.__contains__, ["fullmatch"], true]
    - [re1216pd007, re.Pattern.__dict__.__contains__, ["finditer"],  true]
    - [re1216pd008, re.Pattern.__dict__.__contains__, ["subn"],      true]

table re_extra1216.pattern_dict_contains_absent:
  description: "re.Pattern.__dict__.__contains__ checks for names NOT in Pattern.__dict__ — module-level functions (re.compile, re.escape) and Match-only methods (group, groups) are absent from Pattern"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1216pa
  columns: [id, function, args, expected]
  rows:
    - [re1216pa001, re.Pattern.__dict__.__contains__, ["compile"],   false]
    - [re1216pa002, re.Pattern.__dict__.__contains__, ["escape"],    false]
    - [re1216pa003, re.Pattern.__dict__.__contains__, ["group"],     false]
    - [re1216pa004, re.Pattern.__dict__.__contains__, ["groups"],    false]
    - [re1216pa005, re.Pattern.__dict__.__contains__, ["groupdict"], false]
    - [re1216pa006, re.Pattern.__dict__.__contains__, ["span"],      false]
    - [re1216pa007, re.Pattern.__dict__.__contains__, ["flags"],     true]
    - [re1216pa008, re.Pattern.__dict__.__contains__, ["pattern"],   true]

table re_extra1216.match_dict_contains:
  description: "re.Match.__dict__.__contains__ checks for match-object methods — group, groups, groupdict, start, end, span present; Pattern-only and module-level names absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1216md
  columns: [id, function, args, expected]
  rows:
    - [re1216md001, re.Match.__dict__.__contains__, ["group"],     true]
    - [re1216md002, re.Match.__dict__.__contains__, ["groups"],    true]
    - [re1216md003, re.Match.__dict__.__contains__, ["groupdict"], true]
    - [re1216md004, re.Match.__dict__.__contains__, ["start"],     true]
    - [re1216md005, re.Match.__dict__.__contains__, ["end"],       true]
    - [re1216md006, re.Match.__dict__.__contains__, ["span"],      true]
    - [re1216md007, re.Match.__dict__.__contains__, ["match"],     false]
    - [re1216md008, re.Match.__dict__.__contains__, ["search"],    false]
    - [re1216md009, re.Match.__dict__.__contains__, ["findall"],   false]
    - [re1216md010, re.Match.__dict__.__contains__, ["string"],    true]
