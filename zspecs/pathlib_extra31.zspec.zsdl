spec: pathlib_extra31
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra4.zspec.zsdl — covers __name__ for Path/PurePath methods; not __module__ or PurePath property fget qualnames"
    - "pathlib_extra28.zspec.zsdl — covers __qualname__ for Path.read_text/write_text/resolve/iterdir/is_absolute"
    - "pathlib_extra29.zspec.zsdl — covers __qualname__ for Path.stat/chmod/exists/is_file/is_dir/mkdir/rename/unlink/open"
    - "pathlib_extra30.zspec.zsdl — covers __qualname__ for Path.read_bytes/write_bytes/glob/rglob/absolute"
  notes:
    - "This spec extends pathlib_extra30.zspec.zsdl."
    - "NEW in extra31 — Axis 1: Path.__module__ and PurePath.__module__ — both == 'pathlib'; pins module identity."
    - "NEW in extra31 — Axis 2: PurePosixPath/__qualname__/__module__ and PureWindowsPath/__qualname__/__module__ — platform-specific pure path class identities."
    - "NEW in extra31 — Axis 3: PosixPath/__qualname__/__module__ — concrete POSIX path class identity."
    - "NEW in extra31 — Axis 4: Path.__bases__[0].__name__ == 'PurePath' and PurePath.__bases__[0].__name__ == 'object' — inheritance chain."
    - "NEW in extra31 — Axis 5: PurePath property fget qualnames — parts.fget.__qualname__, name.fget.__qualname__, stem.fget.__qualname__, suffix.fget.__qualname__."
    - "pathlib.Path.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.PurePath.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' — verified Python 3.12."
    - "pathlib.PurePosixPath.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath' — verified Python 3.12."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath' — verified Python 3.12."
    - "pathlib.PosixPath.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — verified Python 3.12."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "pathlib.PurePath.parts.fget.__qualname__ == 'PurePath.parts' — verified Python 3.12."
    - "pathlib.PurePath.name.fget.__qualname__ == 'PurePath.name' — verified Python 3.12."
    - "pathlib.PurePath.stem.fget.__qualname__ == 'PurePath.stem' — verified Python 3.12."
    - "pathlib.PurePath.suffix.fget.__qualname__ == 'PurePath.suffix' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path and PurePath __module__ — class identity
#
# No prior pathlib spec anchors Path.__module__ or PurePath.__module__ as
# standalone invariants. Both are defined in pathlib.py and exported under
# the 'pathlib' module namespace.
# ---------------------------------------------------------------------------

invariant pathlib_extra31.Path.module:
  description: "pathlib.Path.__module__ == 'pathlib' — concrete path class defined in the pathlib module"
  category: class_identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra31.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib' — abstract pure path base class defined in the pathlib module"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# PurePosixPath and PureWindowsPath — qualname and module
#
# No prior pathlib spec checks the __qualname__ or __module__ of these two
# platform-specific pure path classes. Their qualnames are flat (not nested),
# and their module is 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra31.pure_variant_class_identity:
  description: "__qualname__ and __module__ for PurePosixPath and PureWindowsPath"
  kind: python_call_eq
  category: class_identity
  id_prefix: pvci31

  columns: [id, function, args, expected]
  rows:
    - [PurePosixPath_qualname,   PurePosixPath.__qualname__.__eq__,   ["PurePosixPath"],   true]
    - [PurePosixPath_module,     PurePosixPath.__module__.__eq__,     ["pathlib"],         true]
    - [PureWindowsPath_qualname, PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [PureWindowsPath_module,   PureWindowsPath.__module__.__eq__,   ["pathlib"],         true]

# ---------------------------------------------------------------------------
# PosixPath — qualname and module
#
# PosixPath is the concrete instantiable path class on POSIX systems. No
# prior pathlib spec checks its __qualname__ or __module__ as standalone
# extra31-namespace invariants.
# ---------------------------------------------------------------------------

invariant pathlib_extra31.PosixPath.qualname:
  description: "pathlib.PosixPath.__qualname__ == 'PosixPath' — concrete POSIX path class; flat qualname"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__qualname__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra31.PosixPath.module:
  description: "pathlib.PosixPath.__module__ == 'pathlib' — PosixPath is defined in the pathlib module"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# Path and PurePath inheritance chain — __bases__[0].__name__
#
# Path inherits from PurePath; PurePath inherits from object. These two
# invariants pin the single-inheritance chain so that any restructuring of
# the class hierarchy is immediately detected. No prior pathlib spec checks
# these base class names.
# ---------------------------------------------------------------------------

invariant pathlib_extra31.Path.base:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits directly from PurePath"
  category: class_identity
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra31.PurePath.base:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# PurePath property fget __qualname__ values
#
# PurePath exposes several attributes as properties (parts, name, stem,
# suffix). Each property's fget function carries a dotted qualname of the
# form 'PurePath.<attr>'. No prior pathlib spec checks these fget qualnames.
# The fget qualname distinguishes the property getter from a plain method
# and encodes the defining class name.
# ---------------------------------------------------------------------------

table pathlib_extra31.purepath_fget_qualnames:
  description: "fget.__qualname__ for PurePath property descriptors"
  kind: python_call_eq
  category: property_identity
  id_prefix: pfq31

  columns: [id, function, args, expected]
  rows:
    - [parts,  "PurePath.parts.fget.__qualname__.__eq__",  ["PurePath.parts"],  true]
    - [name,   "PurePath.name.fget.__qualname__.__eq__",   ["PurePath.name"],   true]
    - [stem,   "PurePath.stem.fget.__qualname__.__eq__",   ["PurePath.stem"],   true]
    - [suffix, "PurePath.suffix.fget.__qualname__.__eq__", ["PurePath.suffix"], true]
