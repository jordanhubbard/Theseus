spec: hashlib_extra691
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib blake2b and blake2s documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.blake2b and blake2s method __name__ and __doc__ class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra691.blake2_method_names:
  description: "hashlib.blake2b and blake2s method __name__ and __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: blake2_method_names
  id_prefix: hl691bn
  columns: [id, function, args, expected]
  rows:
    - [hl691bn001, hashlib.blake2b.update.__name__.__eq__,                   ["update"],    true]
    - [hl691bn002, hashlib.blake2b.digest.__name__.__eq__,                   ["digest"],    true]
    - [hl691bn003, hashlib.blake2b.hexdigest.__name__.__eq__,                ["hexdigest"], true]
    - [hl691bn004, hashlib.blake2b.copy.__name__.__eq__,                     ["copy"],      true]
    - [hl691bn005, hashlib.blake2s.update.__name__.__eq__,                   ["update"],    true]
    - [hl691bn006, hashlib.blake2s.digest.__name__.__eq__,                   ["digest"],    true]
    - [hl691bn007, hashlib.blake2s.hexdigest.__name__.__eq__,                ["hexdigest"], true]
    - [hl691bn008, hashlib.blake2s.copy.__name__.__eq__,                     ["copy"],      true]
    - [hl691bn009, hashlib.blake2b.update.__doc__.__class__.__name__.__eq__,  ["str"],       true]
    - [hl691bn010, hashlib.blake2b.digest.__doc__.__class__.__name__.__eq__,  ["str"],       true]
    - [hl691bn011, hashlib.blake2b.hexdigest.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [hl691bn012, hashlib.blake2b.copy.__doc__.__class__.__name__.__eq__,    ["str"],       true]
