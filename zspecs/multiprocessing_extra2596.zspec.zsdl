spec: multiprocessing_extra2596
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 2596 theme: __get__, __set__, __delete__ descriptor protocol dict-presence — checking whether multiprocessing classes implement the descriptor protocol."
    - "multiprocessing.Process, multiprocessing.pool.Pool, AsyncResult, IMapIterator, ThreadPool, and multiprocessing.synchronize classes (Lock, Event, Semaphore, Condition, Barrier) do NOT define __get__, __set__, or __delete__ in their own __dict__ on Python 3.14.4."
    - "These classes are process management and inter-process synchronization primitives; none implement the descriptor protocol. Descriptor methods are absent from all class __dict__ namespaces."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table multiprocessing_extra2596.process_descriptor_protocol:
  description: "multiprocessing.Process __get__/__set__/__delete__ dict-presence — all False; not a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2596
  columns: [id, function, args, expected]
  rows:
    - ["mp2596001", "multiprocessing.Process.__dict__.__contains__",              ["__get__"],    false]
    - ["mp2596002", "multiprocessing.Process.__dict__.__contains__",              ["__set__"],    false]
    - ["mp2596003", "multiprocessing.Process.__dict__.__contains__",              ["__delete__"], false]
    - ["mp2596004", "multiprocessing.pool.Pool.__dict__.__contains__",            ["__get__"],    false]
    - ["mp2596005", "multiprocessing.pool.Pool.__dict__.__contains__",            ["__set__"],    false]
    - ["mp2596006", "multiprocessing.pool.Pool.__dict__.__contains__",            ["__delete__"], false]

