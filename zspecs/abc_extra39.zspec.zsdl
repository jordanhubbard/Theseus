spec: abc_extra39
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra38.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod' (extra34), get_cache_token/__module__=='_abc' (extra34), ABC/__name__=='ABC' (extra34), ABC/__bases__[0].__name__=='object' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type' (extra35), ABCMeta.register/__qualname__.__len__()==16 (extra35), ABCMeta/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object' (extra35), ABCMeta MRO entries [0]/'ABCMeta', [1]/'type', [2]/'object', ABC/__mro__[0].__name__=='ABC', abstractmethod/__qualname__.__len__()==14, abstractproperty/__name__=='abstractproperty'/__module__=='abc', abstractclassmethod/__name__=='abstractclassmethod'/__module__=='abc' (extra36), abstractproperty/__qualname__=='abstractproperty', abstractproperty/__qualname__.__len__()==16, abstractproperty/__bases__[0].__name__=='property', abstractclassmethod/__bases__[0].__name__=='classmethod', abstractstaticmethod/__name__=='abstractstaticmethod', abstractstaticmethod/__bases__[0].__name__=='staticmethod', ABC/__qualname__=='ABC', ABC/__qualname__.__len__()==3 (extra37), abstractmethod/__qualname__=='abstractmethod', abstractclassmethod/__qualname__=='abstractclassmethod', abstractstaticmethod/__qualname__=='abstractstaticmethod', ABCMeta.register/__qualname__=='ABCMeta.register', ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta/__call__/__qualname__=='type.__call__' (extra38)."
    - "This spec covers: ABCMeta/__qualname__=='ABCMeta' (7 chars); ABCMeta/__qualname__.__len__()==7; ABC/__qualname__.__len__()==3; abstractmethod/__qualname__.__len__()==14; abstractproperty/__qualname__.__len__()==16; abstractclassmethod/__qualname__.__len__()==19; abstractstaticmethod/__qualname__.__len__()==20; get_cache_token/__qualname__=='get_cache_token' (15 chars); get_cache_token/__qualname__.__len__()==15."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' (7 chars). ABCMeta is a top-level class; __qualname__ equals __name__ for top-level classes. len('ABCMeta') == 7: A-B-C-M-e-t-a = 7. String equality was not explicitly captured in prior specs as a standalone invariant."
    - "abc.ABCMeta.__qualname__.__len__() == 7. ABCMeta.__qualname__ == 'ABCMeta'; len('ABCMeta') == 7."
    - "abc.ABC.__qualname__.__len__() == 3. ABC.__qualname__ == 'ABC' (verified in extra37); len('ABC') == 3. Extra39 captures this length in a comprehensive table alongside other abc class qualname lengths."
    - "abc.abstractmethod.__qualname__.__len__() == 14. abstractmethod.__qualname__ == 'abstractmethod' (verified in extra38); len('abstractmethod') == 14."
    - "abc.abstractproperty.__qualname__.__len__() == 16. abstractproperty.__qualname__ == 'abstractproperty' (verified in extra36); len('abstractproperty') == 16."
    - "abc.abstractclassmethod.__qualname__.__len__() == 19. abstractclassmethod.__qualname__ == 'abstractclassmethod' (verified in extra38); len('abstractclassmethod') == 19."
    - "abc.abstractstaticmethod.__qualname__.__len__() == 20. abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (verified in extra38); len('abstractstaticmethod') == 20. One character longer than abstractclassmethod."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' (15 chars). get_cache_token is a C-extension function in _abc; its __qualname__ equals its __name__ for module-level functions. len('get_cache_token') == 15: g-e-t-_-c-a-c-h-e-_-t-o-k-e-n = 15."
    - "abc.get_cache_token.__qualname__.__len__() == 15. get_cache_token.__qualname__ == 'get_cache_token'; len('get_cache_token') == 15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc class __qualname__.__len__() — extra39 namespace
#
# Comprehensive table of abc public class/function __qualname__ lengths:
#   ABCMeta.__qualname__.__len__()            ==  7  ('ABCMeta')
#   ABC.__qualname__.__len__()                ==  3  ('ABC')
#   abstractmethod.__qualname__.__len__()     == 14  ('abstractmethod')
#   abstractproperty.__qualname__.__len__()   == 16  ('abstractproperty')
#   abstractclassmethod.__qualname__.__len__()== 19  ('abstractclassmethod')
#   abstractstaticmethod.__qualname__.__len__()== 20 ('abstractstaticmethod')
# All are top-level; __qualname__ equals __name__ in each case.
# The three deprecated 'abstract*' classes increase in length:
# abstractmethod(14) < abstractproperty(16) < abstractclassmethod(19) < abstractstaticmethod(20).
# ---------------------------------------------------------------------------

table abc_extra39.class_qualname_lengths:
  description: "abc class __qualname__.__len__() in extra39 namespace — ABCMeta, ABC, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod"
  kind: python_call_eq
  category: class_names
  id_prefix: abcclassqnlen39

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta,             ABCMeta.__qualname__.__len__,             [],  7, "ABCMeta.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters"]
    - [ABC,                 ABC.__qualname__.__len__,                 [],  3, "ABC.__qualname__.__len__() == 3 — 'ABC' has 3 characters"]
    - [abstractmethod,      abstractmethod.__qualname__.__len__,      [], 14, "abstractmethod.__qualname__.__len__() == 14 — 'abstractmethod' has 14 characters"]
    - [abstractproperty,    abstractproperty.__qualname__.__len__,    [], 16, "abstractproperty.__qualname__.__len__() == 16 — 'abstractproperty' has 16 characters"]
    - [abstractclassmethod, abstractclassmethod.__qualname__.__len__, [], 19, "abstractclassmethod.__qualname__.__len__() == 19 — 'abstractclassmethod' has 19 characters"]
    - [abstractstaticmethod, abstractstaticmethod.__qualname__.__len__, [], 20, "abstractstaticmethod.__qualname__.__len__() == 20 — 'abstractstaticmethod' has 20 characters"]

# ---------------------------------------------------------------------------
# abc.ABCMeta __qualname__ string equality — extra39 namespace
#
# ABCMeta.__qualname__ == 'ABCMeta' (7 chars)
# ABCMeta is the metaclass for abstract base classes; it is defined at the
# top level of abc.py. As a top-level class, __qualname__ equals __name__.
# Prior specs captured __name__/'ABCMeta' in extra35; extra39 captures the
# __qualname__ string equality directly as a standalone invariant.
# ---------------------------------------------------------------------------

invariant abc_extra39.ABCMeta_qualname_eq:
  description: "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level metaclass; qualname equals name (7 chars)"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra39.ABCMeta_qualname_len:
  description: "abc.ABCMeta.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# abc.get_cache_token __qualname__ — extra39 namespace
#
# get_cache_token.__qualname__ == 'get_cache_token' (15 chars)
# get_cache_token is a C-extension function from _abc exposed at module level;
# its __qualname__ equals its __name__ (module-level functions have no
# enclosing class scope in their qualname). Prior specs captured __name__ and
# __module__ (extra34); extra39 captures __qualname__ string equality and length.
# len('get_cache_token') == 15: g-e-t-_-c-a-c-h-e-_-t-o-k-e-n = 15.
# ---------------------------------------------------------------------------

table abc_extra39.get_cache_token_qualname:
  description: "abc.get_cache_token __qualname__ string equality and length in extra39 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: abcgctqn39

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,  get_cache_token.__qualname__.__eq__,  ["get_cache_token"], true, "get_cache_token.__qualname__ == 'get_cache_token' — C-extension function; qualname equals name (15 chars)"]
    - [qualname_len, get_cache_token.__qualname__.__len__, [],                  15,   "get_cache_token.__qualname__.__len__() == 15 — 'get_cache_token' has 15 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra39
# ---------------------------------------------------------------------------

invariant abc_extra39.ABCMeta_qualname_len_standalone:
  description: "abc.ABCMeta.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__qualname__.__len__
  args: []
  expected: 7

invariant abc_extra39.ABC_qualname_len:
  description: "abc.ABC.__qualname__.__len__() == 3 — 'ABC' has 3 characters"
  category: class_names
  kind: python_call_eq
  function: ABC.__qualname__.__len__
  args: []
  expected: 3

invariant abc_extra39.abstractmethod_qualname_len:
  description: "abc.abstractmethod.__qualname__.__len__() == 14 — 'abstractmethod' has 14 characters"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__qualname__.__len__
  args: []
  expected: 14

invariant abc_extra39.abstractproperty_qualname_len:
  description: "abc.abstractproperty.__qualname__.__len__() == 16 — 'abstractproperty' has 16 characters"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra39.abstractclassmethod_qualname_len:
  description: "abc.abstractclassmethod.__qualname__.__len__() == 19 — 'abstractclassmethod' has 19 characters"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__qualname__.__len__
  args: []
  expected: 19

invariant abc_extra39.abstractstaticmethod_qualname_len:
  description: "abc.abstractstaticmethod.__qualname__.__len__() == 20 — 'abstractstaticmethod' has 20 characters"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra39.get_cache_token_qualname_eq:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token' — C-extension function in _abc; qualname equals name (15 chars)"
  category: function_names
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra39.get_cache_token_qualname_len:
  description: "abc.get_cache_token.__qualname__.__len__() == 15 — 'get_cache_token' has 15 characters"
  category: function_names
  kind: python_call_eq
  function: get_cache_token.__qualname__.__len__
  args: []
  expected: 15
