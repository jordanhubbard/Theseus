spec: multiprocessing_extra146
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers multiprocessing.__all__ — a list of length 37. multiprocessing.__all__.__class__.__name__=='list'. multiprocessing.__all__.__len__()==37. Key members verified: Process, Pool, Queue, Pipe, Manager, Lock, Event, Semaphore, Value, Array, cpu_count, current_process, active_children, parent_process, JoinableQueue, SimpleQueue. multiprocessing.__spec__.name=='multiprocessing' (len=15). multiprocessing.__package__=='multiprocessing' (len=15). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__all__ contains 37 items including both high-level and lower-level names. The list includes process-management names (Process, active_children, current_process, parent_process), concurrency primitives (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier), queues (Queue, JoinableQueue, SimpleQueue), IPC tools (Pipe, Manager), pool (Pool), shared memory (Value, Array, RawValue, RawArray), utility functions (cpu_count, freeze_support, get_context, get_start_method, set_start_method, etc.), and exception types (ProcessError, AuthenticationError, BufferTooShort, TimeoutError). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__all__ type and size — extra146
#
# multiprocessing.__all__.__class__.__name__ == 'list'
# multiprocessing.__all__.__len__()          == 37
# multiprocessing.__spec__.name.__eq__('multiprocessing') == True (len=15)
# multiprocessing.__package__.__eq__('multiprocessing')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra146.mp_all_type_and_size:
  description: "multiprocessing.__all__ type and size checks in mp_all146 namespace — multiprocessing.__all__.__class__.__name__=='list' (a mutable list); multiprocessing.__all__.__len__()==37 (37 public names covering process management, concurrency primitives, queues, IPC, shared memory, utility functions, and exceptions); multiprocessing.__spec__.name.__eq__('multiprocessing')==True (len=15: 'multiprocessing' is 15 chars — 'm'+'u'+'l'+'t'+'i'+'p'+'r'+'o'+'c'+'e'+'s'+'s'+'i'+'n'+'g'=15); multiprocessing.__spec__.name.__len__()==15; multiprocessing.__name__.__eq__('multiprocessing')==True; multiprocessing.__package__.__eq__('multiprocessing')==True (package is itself, multiprocessing is a package with __init__.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp_all146

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls_eq,    multiprocessing.__all__.__class__.__name__.__eq__,  ["list"],              true,  "multiprocessing.__all__.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [all_len,       multiprocessing.__all__.__len__,                     [],                    37,    "multiprocessing.__all__.__len__() == 37; verified with Python 3.14.3"]
    - [spec_name_eq,  multiprocessing.__spec__.name.__eq__,               ["multiprocessing"],   true,  "multiprocessing.__spec__.name == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [spec_name_len, multiprocessing.__spec__.name.__len__,               [],                    15,    "multiprocessing.__spec__.name.__len__() == 15; verified with Python 3.14.3"]
    - [name_eq,       multiprocessing.__name__.__eq__,                    ["multiprocessing"],   true,  "multiprocessing.__name__ == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [pkg_eq,        multiprocessing.__package__.__eq__,                 ["multiprocessing"],   true,  "multiprocessing.__package__ == 'multiprocessing' (package is itself); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.__all__ membership — process and pool names — extra146
#
# 'Process' in multiprocessing.__all__  == True
# 'Pool' in multiprocessing.__all__     == True
# 'Queue' in multiprocessing.__all__    == True
# 'Pipe' in multiprocessing.__all__     == True
# 'Manager' in multiprocessing.__all__  == True
# 'cpu_count' in multiprocessing.__all__ == True
# ---------------------------------------------------------------------------

table multiprocessing_extra146.mp_all_process_members:
  description: "multiprocessing.__all__ membership checks for process and pool names in mp_all146 namespace — multiprocessing.__all__.__contains__('Process')==True ('Process' is the core class for spawning a new process, analogous to threading.Thread); multiprocessing.__all__.__contains__('Pool')==True ('Pool' is a pool of worker processes, supports map/apply/starmap); multiprocessing.__all__.__contains__('Queue')==True ('Queue' is a process-safe FIFO queue using pipes and semaphores); multiprocessing.__all__.__contains__('Pipe')==True ('Pipe' returns two Connection objects (conn1, conn2) for process-to-process communication); multiprocessing.__all__.__contains__('Manager')==True ('Manager' creates a server process that holds shared objects and returns proxies); multiprocessing.__all__.__contains__('cpu_count')==True ('cpu_count' returns the number of CPUs in the system); all six names confirmed in the 37-item list; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: mp_all146a

  columns: [id, function, args, expected, description]
  rows:
    - [has_process,   multiprocessing.__all__.__contains__,  ["Process"],    true,  "multiprocessing.__all__.__contains__('Process') == True; verified with Python 3.14.3"]
    - [has_pool,      multiprocessing.__all__.__contains__,  ["Pool"],       true,  "multiprocessing.__all__.__contains__('Pool') == True; verified with Python 3.14.3"]
    - [has_queue,     multiprocessing.__all__.__contains__,  ["Queue"],      true,  "multiprocessing.__all__.__contains__('Queue') == True; verified with Python 3.14.3"]
    - [has_pipe,      multiprocessing.__all__.__contains__,  ["Pipe"],       true,  "multiprocessing.__all__.__contains__('Pipe') == True; verified with Python 3.14.3"]
    - [has_manager,   multiprocessing.__all__.__contains__,  ["Manager"],    true,  "multiprocessing.__all__.__contains__('Manager') == True; verified with Python 3.14.3"]
    - [has_cpu_count, multiprocessing.__all__.__contains__,  ["cpu_count"],  true,  "multiprocessing.__all__.__contains__('cpu_count') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
