# 'Value' in multiprocessing.__all__            == True
# 'Array' in multiprocessing.__all__            == True
# 'current_process' in multiprocessing.__all__  == True
# 'active_children' in multiprocessing.__all__  == True
# 'parent_process' in multiprocessing.__all__   == True
# ---------------------------------------------------------------------------

table multiprocessing_extra146.mp_all_sync_members:
  description: "multiprocessing.__all__ membership checks for synchronization and shared-memory names in mp_all146 namespace — multiprocessing.__all__.__contains__('Lock')==True ('Lock' is a process-safe mutex, uses OS-level semaphores); multiprocessing.__all__.__contains__('Event')==True ('Event' is a process-safe event flag for synchronization); multiprocessing.__all__.__contains__('Semaphore')==True ('Semaphore' is a process-safe counting semaphore); multiprocessing.__all__.__contains__('Value')==True ('Value' creates a shared ctypes value in shared memory); multiprocessing.__all__.__contains__('Array')==True ('Array' creates a shared ctypes array in shared memory); multiprocessing.__all__.__contains__('current_process')==True ('current_process' returns the current Process object, analogous to threading.current_thread); multiprocessing.__all__.__contains__('active_children')==True ('active_children' returns a list of currently live child processes); multiprocessing.__all__.__contains__('parent_process')==True ('parent_process' returns the parent Process object, added in Python 3.8); all eight names confirmed in the 37-item list; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: mp_all146b

  columns: [id, function, args, expected, description]
  rows:
    - [has_lock,     multiprocessing.__all__.__contains__,  ["Lock"],            true,  "multiprocessing.__all__.__contains__('Lock') == True; verified with Python 3.14.3"]
    - [has_event,    multiprocessing.__all__.__contains__,  ["Event"],           true,  "multiprocessing.__all__.__contains__('Event') == True; verified with Python 3.14.3"]
    - [has_sema,     multiprocessing.__all__.__contains__,  ["Semaphore"],       true,  "multiprocessing.__all__.__contains__('Semaphore') == True; verified with Python 3.14.3"]
    - [has_value,    multiprocessing.__all__.__contains__,  ["Value"],           true,  "multiprocessing.__all__.__contains__('Value') == True; verified with Python 3.14.3"]
    - [has_array,    multiprocessing.__all__.__contains__,  ["Array"],           true,  "multiprocessing.__all__.__contains__('Array') == True; verified with Python 3.14.3"]
    - [has_cur_proc, multiprocessing.__all__.__contains__,  ["current_process"], true,  "multiprocessing.__all__.__contains__('current_process') == True; verified with Python 3.14.3"]
    - [has_act_chld, multiprocessing.__all__.__contains__,  ["active_children"], true,  "multiprocessing.__all__.__contains__('active_children') == True; verified with Python 3.14.3"]
    - [has_par_proc, multiprocessing.__all__.__contains__,  ["parent_process"],  true,  "multiprocessing.__all__.__contains__('parent_process') == True (added in Python 3.8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra146
# ---------------------------------------------------------------------------

invariant multiprocessing_extra146.mp_all_is_list:
  description: "multiprocessing.__all__.__class__.__name__.__eq__('list') returns True — multiprocessing.__all__ is a list (like concurrent.futures.__all__, unlike asyncio.__all__ which is a tuple); multiprocessing.__all__.__class__.__name__=='list'; multiprocessing.__all__.__len__()==37 (37 public names); this is NEW in extra146: the first spec to verify multiprocessing.__all__.__class__.__name__; the list covers the full multiprocessing API: process management, synchronization primitives, shared memory, IPC, utility functions, and exceptions; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra146.mp_all_len_37:
  description: "multiprocessing.__all__.__len__() == 37 — multiprocessing exports 37 public names through its __all__ list; this is between asyncio (95 items, tuple) and concurrent.futures (14 items, list) in terms of API size; the 37 names include: process management (Process, active_children, current_process, parent_process), pools (Pool), queues (Queue, JoinableQueue, SimpleQueue), IPC (Pipe, Manager), locks and synchronization (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier), shared memory (Value, Array, RawValue, RawArray), utilities (cpu_count, freeze_support, get_context, get_start_method, set_start_method, get_all_start_methods, get_logger, log_to_stderr, set_executable, set_forkserver_preload, allow_connection_pickling, reducer), and exceptions (ProcessError, AuthenticationError, BufferTooShort, TimeoutError); multiprocessing.__all__.__class__.__name__=='list'; NEW in extra146: first standalone multiprocessing.__all__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__all__.__len__
  args: []
  expected: 37

invariant multiprocessing_extra146.mp_spec_name_len_15:
  description: "multiprocessing.__spec__.name.__len__() == 15 — multiprocessing.__spec__.name is 'multiprocessing' (15 chars); compare module name lengths: abc=3, asyncio=7, multiprocessing=15, concurrent.futures=18; multiprocessing.__name__.__len__()==15 and multiprocessing.__package__.__len__()==15 also hold; 'multiprocessing' is the longest single-word stdlib module name in this batch (compared to the dotted 'concurrent.futures' at 18); multiprocessing.__all__.__len__()==37 (list); NEW in extra146: first standalone multiprocessing.__spec__.name length invariant in mp_all146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__spec__.name.__len__
  args: []
  expected: 15

invariant multiprocessing_extra146.mp_all_contains_process:
  description: "multiprocessing.__all__.__contains__('Process') returns True — 'Process' is one of the 37 names in multiprocessing.__all__ (a list); multiprocessing.Process is the central class for creating new processes; it has a similar interface to threading.Thread with methods like start(), join(), terminate(), kill(), is_alive(), and run(); Process.__mro__.__len__()==3 ([Process, BaseProcess, object]); Process inherits from BaseProcess in Lib/multiprocessing/context.py; multiprocessing.__all__.__class__.__name__=='list'; multiprocessing.__all__.__len__()==37; NEW in extra146: first standalone multiprocessing.__all__ 'Process' membership invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__all__.__contains__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra146.mp_all_contains_pool:
  description: "multiprocessing.__all__.__contains__('Pool') returns True — 'Pool' is one of the 37 names in multiprocessing.__all__ (a list); multiprocessing.Pool creates a pool of worker processes that can be used to parallelize function execution across multiple processes; Pool supports map(), apply(), starmap(), apply_async(), map_async(), starmap_async() and related methods; multiprocessing.pool.Pool.__mro__.__len__()==2 ([Pool, object]); Pool is a direct subclass of object; multiprocessing.__all__.__class__.__name__=='list'; multiprocessing.__all__.__len__()==37; NEW in extra146: first standalone multiprocessing.__all__ 'Pool' membership invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__all__.__contains__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra146.mp_spec_name_eq:
  description: "multiprocessing.__spec__.name.__eq__('multiprocessing') returns True — multiprocessing.__spec__.name is 'multiprocessing' (15 chars); the ModuleSpec name is the fully-qualified name used by the Python import system; multiprocessing.__name__=='multiprocessing' and multiprocessing.__package__=='multiprocessing' also hold (all three equal the same 15-char string); multiprocessing is a package (has __init__.py in Lib/multiprocessing/), not a single module; multiprocessing.__all__.__len__()==37 (list); NEW in extra146: first standalone multiprocessing.__spec__.name equality invariant in mp_all146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__spec__.name.__eq__
  args: ["multiprocessing"]
  expected: true

