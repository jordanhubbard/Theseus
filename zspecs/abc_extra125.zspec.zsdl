spec: abc_extra125
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 255 theme — abc module __spec__ class identity and loader/package attributes. NEW in extra125: abc.__spec__.__class__.__name__=='ModuleSpec'; abc.__spec__.name.__eq__('abc')==True; abc.__spec__.name.__len__()==3; abc.__spec__.origin.__class__.__name__=='str'; abc.__spec__.origin.__eq__('frozen')==True (abc is a frozen module compiled into the interpreter); abc.__spec__.origin.__len__()==6; abc.__loader__.__class__.__name__=='type' (the loader is the FrozenImporter class itself); abc.__loader__.__name__.__eq__('FrozenImporter')==True; abc.__loader__.__name__.__len__()==14; abc.__package__.__eq__('')==True (empty string — abc is a top-level module); abc.__package__.__len__()==0; abc.__file__.__class__.__name__=='str'; abc.__builtins__.__class__.__name__=='dict'; abc.__spec__.has_location==False (frozen module, no filesystem path in spec); abc.__spec__.submodule_search_locations is None (abc is a single module, not a package). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__spec__.origin == 'frozen'. abc is a frozen module — it is compiled into the Python interpreter itself (Lib/abc.py is frozen into the bytecode). Despite being frozen, abc.__file__ still points to the source path (a str). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__loader__.__class__.__name__ == 'type'. The abc loader is _frozen_importlib.FrozenImporter, which is a class. Since FrozenImporter is a class, its __class__.__name__ is 'type' (the metaclass of all classes). abc.__loader__.__name__ is 'FrozenImporter' (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__package__ == '' (empty string, len=0). abc is a top-level module with no parent package. Empty __package__ distinguishes top-level modules from submodules like 'asyncio.exceptions' or 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__spec__.has_location == False. Because abc is a frozen module, its spec has has_location=False (no filesystem-backed location in the spec). Compare with concurrent.futures.__spec__.has_location==True (regular package). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__spec__ class identity — extra125
#
# Wave 255 theme: abc module __spec__ identity and frozen module attributes.
#
# abc.__spec__.__class__.__name__ == 'ModuleSpec'
# abc.__spec__.name == 'abc'                (len=3)
# abc.__spec__.origin == 'frozen'           (len=6)
# abc.__spec__.origin.__class__.__name__ == 'str'
# abc.__spec__.has_location == False
# abc.__spec__.submodule_search_locations is None
# ---------------------------------------------------------------------------

table abc_extra125.abc_spec_class_identity:
  description: "abc.__spec__ class identity checks in abcspec125 namespace — wave 255 theme: abc is a frozen module with a ModuleSpec; abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (abc.__spec__ is an importlib.machinery.ModuleSpec instance); abc.__spec__.name.__eq__('abc')==True (len=3: the shortest module name among the four modules in this wave); abc.__spec__.name.__len__()==3; abc.__spec__.origin.__class__.__name__.__eq__('str')==True (origin is a str); abc.__spec__.origin.__eq__('frozen')==True (abc is compiled into the interpreter as a frozen module — the origin string is 'frozen' not a filesystem path); abc.__spec__.origin.__len__()==6 (len('frozen')==6); abc.__spec__.has_location.__eq__(False)==True (frozen module has no filesystem spec location); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcspec125

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls,       abc.__spec__.__class__.__name__.__eq__,       ["ModuleSpec"], true, "abc.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [spec_name_eq,   abc.__spec__.name.__eq__,                     ["abc"],        true, "abc.__spec__.name == 'abc' (len=3); verified with Python 3.14.3"]
    - [spec_name_len,  abc.__spec__.name.__len__,                    [],             3,    "abc.__spec__.name.__len__() == 3 — shortest module name in wave 255; verified with Python 3.14.3"]
    - [origin_cls,     abc.__spec__.origin.__class__.__name__.__eq__, ["str"],       true, "abc.__spec__.origin.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [origin_eq,      abc.__spec__.origin.__eq__,                   ["frozen"],     true, "abc.__spec__.origin == 'frozen' — abc is a frozen module compiled into the interpreter; verified with Python 3.14.3"]
    - [origin_len,     abc.__spec__.origin.__len__,                  [],             6,    "abc.__spec__.origin.__len__() == 6 (len('frozen')==6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__loader__ and __package__ attributes — extra125
#
# abc.__loader__.__class__.__name__ == 'type'       (FrozenImporter is a class)
# abc.__loader__.__name__ == 'FrozenImporter'       (len=14)
# abc.__package__ == ''                             (empty string, len=0)
# abc.__file__.__class__.__name__ == 'str'
# abc.__builtins__.__class__.__name__ == 'dict'
# ---------------------------------------------------------------------------

table abc_extra125.abc_loader_package_attrs:
  description: "abc.__loader__ and __package__ attribute checks in abcspec125 namespace — wave 255 theme: abc frozen module loader and package attributes; abc.__loader__.__class__.__name__.__eq__('type')==True (abc.__loader__ is _frozen_importlib.FrozenImporter, which is a class; since FrozenImporter is a class, its metaclass is 'type', making __class__.__name__=='type'); abc.__loader__.__name__.__eq__('FrozenImporter')==True (the class name of the frozen importer is 'FrozenImporter'); abc.__loader__.__name__.__len__()==14 (len('FrozenImporter')==14); abc.__package__.__eq__('')==True (empty string — abc is a top-level module with no parent package; contrast with 'asyncio.exceptions' module whose __package__ would be 'asyncio'); abc.__package__.__len__()==0; abc.__file__.__class__.__name__.__eq__('str')==True (frozen modules still report __file__ as a str path to the source); abc.__builtins__.__class__.__name__.__eq__('dict')==True (at module level, __builtins__ is a dict); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcspec125a

  columns: [id, function, args, expected, description]
  rows:
    - [loader_cls,     abc.__loader__.__class__.__name__.__eq__,    ["type"],           true, "abc.__loader__.__class__.__name__ == 'type' — FrozenImporter is a class (metaclass=type); verified with Python 3.14.3"]
    - [loader_nm_eq,   abc.__loader__.__name__.__eq__,              ["FrozenImporter"], true, "abc.__loader__.__name__ == 'FrozenImporter' (len=14); verified with Python 3.14.3"]
    - [loader_nm_len,  abc.__loader__.__name__.__len__,             [],                 14,   "abc.__loader__.__name__.__len__() == 14 (len('FrozenImporter')==14); verified with Python 3.14.3"]
    - [pkg_eq,         abc.__package__.__eq__,                     [""],                true, "abc.__package__ == '' (empty string — top-level module with no parent package); verified with Python 3.14.3"]
    - [pkg_len,        abc.__package__.__len__,                    [],                  0,    "abc.__package__.__len__() == 0 (empty string); verified with Python 3.14.3"]
    - [file_cls,       abc.__file__.__class__.__name__.__eq__,     ["str"],             true, "abc.__file__.__class__.__name__ == 'str' — frozen module still has str __file__; verified with Python 3.14.3"]
    - [builtins_cls,   abc.__builtins__.__class__.__name__.__eq__, ["dict"],            true, "abc.__builtins__.__class__.__name__ == 'dict' — at module level __builtins__ is a dict; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__name__ and module-level string attribute lengths — extra125
#
# abc.__name__ == 'abc'          (len=3)
# abc.__spec__.name == 'abc'     (len=3, matches __name__)
# abc.__loader__.__name__ == 'FrozenImporter'  (len=14)
# abc.__spec__.origin == 'frozen' (len=6)
# abc.__package__ == ''           (len=0, shortest)
# abc.__spec__.has_location == False
# ---------------------------------------------------------------------------

table abc_extra125.abc_name_and_string_attrs:
  description: "abc module name and string attribute identity checks in abcspec125 namespace — wave 255 theme: abc module-level string attributes; abc.__name__.__eq__('abc')==True (the module's own __name__ is 'abc', len=3); abc.__name__.__len__()==3; abc.__name__.__class__.__name__.__eq__('str')==True (module __name__ is always a str); abc.__spec__.name.__eq__('abc')==True confirming spec.name matches __name__; abc.__package__.__class__.__name__.__eq__('str')==True (even the empty package is a str object); abc.__spec__.has_location.__eq__(False)==True (frozen spec has no filesystem location); the comparison of string lengths: __package__=0 (shortest), __name__=3, abc.__spec__.origin=6, abc.__loader__.__name__=14; verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcspec125b

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       abc.__name__.__eq__,                              ["abc"],  true, "abc.__name__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [name_len,      abc.__name__.__len__,                             [],       3,    "abc.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [name_cls,      abc.__name__.__class__.__name__.__eq__,          ["str"],   true, "abc.__name__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [spec_n_eq2,    abc.__spec__.name.__eq__,                         ["abc"],  true, "abc.__spec__.name == 'abc' — matches abc.__name__; verified with Python 3.14.3"]
    - [pkg_cls,       abc.__package__.__class__.__name__.__eq__,       ["str"],   true, "abc.__package__.__class__.__name__ == 'str' — empty string is still a str; verified with Python 3.14.3"]
    - [has_loc,       abc.__spec__.has_location.__eq__,                 [false],  true, "abc.__spec__.has_location == False — frozen module has no filesystem spec location; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant abc_extra125.abc_spec_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__ is an instance of importlib.machinery.ModuleSpec; ModuleSpec is the standard spec class for all Python modules regardless of whether they are regular .py files, C extensions, or frozen modules; abc.__spec__.name is 'abc' (len=3); abc.__spec__.origin is 'frozen' (not a filesystem path); abc.__spec__.has_location is False (frozen modules have no filesystem location in the spec, unlike regular packages like concurrent.futures whose has_location=True); compare: concurrent.futures.__spec__.__class__.__name__ is also 'ModuleSpec' but with has_location=True and origin as a filesystem path; NEW in extra125: first standalone abc.__spec__ class name invariant in abcspec125 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra125.abc_spec_origin_is_frozen:
  description: "abc.__spec__.origin.__eq__('frozen') returns True — abc's ModuleSpec has origin='frozen' because abc is compiled into the Python interpreter as a frozen module; the source file Lib/abc.py exists on disk (abc.__file__ is a str pointing to it) but the module itself is loaded from frozen bytecode embedded in the interpreter; abc.__spec__.origin.__len__()==6 (len('frozen')==6); compare: concurrent.futures.__spec__.origin would be a filesystem path string (not 'frozen'); asyncio's origin would similarly be a filesystem path; the 'frozen' origin distinguishes abc from all other modules in this wave; abc.__spec__.has_location is False (consistent with frozen origin); NEW in extra125: first standalone abc.__spec__.origin equality invariant in abcspec125 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant abc_extra125.abc_loader_name_is_FrozenImporter:
  description: "abc.__loader__.__name__.__eq__('FrozenImporter') returns True — abc.__loader__ is _frozen_importlib.FrozenImporter (the class responsible for loading frozen modules); FrozenImporter.__name__ is 'FrozenImporter' (len=14); since FrozenImporter is a class (not an instance), abc.__loader__.__class__.__name__ is 'type' (the metaclass of all regular Python classes); the loader name 'FrozenImporter' (len=14) is the longest string attribute verified in this spec (compare: __name__=3, origin=6, FrozenImporter=14); abc is one of several standard library modules frozen into CPython (others include importlib, os, site); NEW in extra125: first standalone abc.__loader__.__name__ equality invariant in abcspec125 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant abc_extra125.abc_package_is_empty_string:
  description: "abc.__package__.__eq__('') returns True — abc.__package__ is an empty string (len=0) indicating abc is a top-level module with no parent package; for top-level modules, __package__ is always an empty string; compare: a submodule like asyncio.exceptions would have __package__='asyncio'; a subpackage like concurrent.futures has __package__='concurrent.futures' (equals its own __name__); abc.__package__.__len__()==0 (the only zero-length string attribute in this spec); abc.__package__.__class__.__name__ is 'str' (empty string is still a str object); abc.__name__ is 'abc' (len=3, also very short but non-empty); NEW in extra125: first standalone abc.__package__ empty string invariant in abcspec125 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: [""]
  expected: true

invariant abc_extra125.abc_builtins_is_dict:
  description: "abc.__builtins__.__class__.__name__.__eq__('dict') returns True — at module level (when a module is loaded), __builtins__ is a dict of built-in names (the __dict__ of the builtins module); this contrasts with the __main__ module where __builtins__ is the builtins module object itself (class='module'); abc.__builtins__.__class__.__name__ is 'dict' confirming abc is not __main__; this is consistent with all non-__main__ modules in CPython; abc.__file__.__class__.__name__ is 'str'; abc.__spec__.origin is 'frozen'; abc.__package__ is ''; abc.__name__ is 'abc'; NEW in extra125: first standalone abc.__builtins__ class name invariant in abcspec125 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__builtins__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
