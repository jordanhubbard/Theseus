spec: concurrent_futures_extra1111
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — ThreadPoolExecutor.__init__, ProcessPoolExecutor.__init__, Future.__init__/__repr__, Executor class identity, and _base submodule name documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks ThreadPoolExecutor.__init__ qualname/module, ProcessPoolExecutor.__init__ qualname/module, Future.__init__/__repr__/add_done_callback/set_result/set_exception qualnames, Executor class identity, _base.__name__ — behaviors not covered by extra1081 or extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1111.executor_init_qualnames:
  description: "ThreadPoolExecutor.__init__ and ProcessPoolExecutor.__init__ qualname and module identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf1111ei
  columns: [id, function, args, expected]
  rows:
    - [cf1111ei001, concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__,        ["ThreadPoolExecutor.__init__"],    true]
    - [cf1111ei002, concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__,  ["function"],                       true]
    - [cf1111ei003, concurrent.futures.ThreadPoolExecutor.__init__.__module__.__eq__,          ["concurrent.futures.thread"],      true]
    - [cf1111ei004, concurrent.futures.ThreadPoolExecutor.__init__.__name__.__eq__,            ["__init__"],                       true]
    - [cf1111ei005, concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__,       ["ProcessPoolExecutor.__init__"],   true]
    - [cf1111ei006, concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__.__eq__, ["function"],                       true]
    - [cf1111ei007, concurrent.futures.ProcessPoolExecutor.__init__.__module__.__eq__,         ["concurrent.futures.process"],     true]
    - [cf1111ei008, concurrent.futures.ProcessPoolExecutor.__init__.__name__.__eq__,           ["__init__"],                       true]

table concurrent_futures_extra1111.future_method_qualnames:
