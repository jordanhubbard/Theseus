    - [cf1111fm002, concurrent.futures.Future.__init__.__module__.__eq__,               ["concurrent.futures._base"],   true]
    - [cf1111fm003, concurrent.futures.Future.__init__.__class__.__name__.__eq__,       ["function"],                   true]
    - [cf1111fm004, concurrent.futures.Future.__repr__.__qualname__.__eq__,             ["Future.__repr__"],            true]
    - [cf1111fm005, concurrent.futures.Future.__repr__.__class__.__name__.__eq__,       ["function"],                   true]
    - [cf1111fm006, concurrent.futures.Future.add_done_callback.__qualname__.__eq__,    ["Future.add_done_callback"],   true]
    - [cf1111fm007, concurrent.futures.Future.set_result.__qualname__.__eq__,           ["Future.set_result"],          true]
    - [cf1111fm008, concurrent.futures.Future.set_exception.__qualname__.__eq__,        ["Future.set_exception"],       true]

