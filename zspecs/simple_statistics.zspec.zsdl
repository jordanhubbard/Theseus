spec: simple_statistics
version: ">=7.0.0"
backend: node(simple-statistics)

docs: https://simplestatistics.org/

provenance:
  derived_from:
    - "simple-statistics README — https://github.com/simple-statistics/simple-statistics#readme"
    - "Test vectors verified with simple-statistics@7.8.8 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "simple-statistics source"
  notes:
    - "simple-statistics exports many statistical functions as named exports."
    - "mean, median, sum, min, max, variance are basic descriptive statistics."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns numbers. No errors for non-empty numeric array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table simple_statistics.descriptive:
  kind: node_module_call_eq
  category: descriptive
  id_prefix: stat

  columns: [id, function, args, expected]
  rows:
    - [mean,      mean,      [[2, 4, 6]],      4]
    - [median,    median,    [[1, 2, 3]],       2]
    - [sum,       sum,       [[1, 2, 3]],       6]
    - [min,       min,       [[5, 3, 1]],       1]
    - [max,       max,       [[5, 3, 1]],       5]
    - [variance,  variance,  [[2, 4]],          1]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:53:11Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
