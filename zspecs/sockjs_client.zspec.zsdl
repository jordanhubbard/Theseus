spec: sockjs_client
version: ">=1.0.0"
backend: node(sockjs-client)

docs: https://github.com/sockjs/sockjs-client#readme

provenance:
  derived_from:
    - "SockJS-client README — https://github.com/sockjs/sockjs-client#readme"
    - "RFC 6455 (WebSocket) readyState values — SockJS mirrors them"
    - "Test vectors verified with sockjs-client via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "sockjs-client source"
  notes:
    - "WebSocket-emulating client with HTTP fallback transports — used by webpack-dev-server, etc."
    - "Install: npm install sockjs-client"
    - "v1 CJS; module export IS the SockJS constructor; readyState constants attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor throws on missing URL; methods may emit error events."
  stderr: "null"
  stickiness: "N/A — each instance independent."
  codes: {}

invariant sockjs_client.CONNECTING_zero:
  description: "SockJS.CONNECTING is 0 (mirrors WebSocket constants)"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: CONNECTING}
  expected: 0

invariant sockjs_client.OPEN_one:
  description: "SockJS.OPEN is 1"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: OPEN}
  expected: 1

invariant sockjs_client.CLOSING_two:
  description: "SockJS.CLOSING is 2"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: CLOSING}
  expected: 2

invariant sockjs_client.CLOSED_three:
  description: "SockJS.CLOSED is 3"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: CLOSED}
  expected: 3

invariant sockjs_client.module_is_constructor:
  description: "Module export is a function (the SockJS constructor)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant sockjs_client.has_version:
  description: "Module exposes .version string"
  category: meta
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "version.constructor.name"}
  expected: "String"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:06:13Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
