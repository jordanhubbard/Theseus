spec: uuid_extra2326
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
    - "RFC 4122"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attribute checks."
    - "Covers the four RFC 4122 predefined UUID namespace constants and SafeUUID enum values."
    - "NAMESPACE_DNS = 6ba7b810-9dad-11d1-80b4-00c04fd430c8 (RFC 4122 Appendix C)."
    - "NAMESPACE_URL = 6ba7b811-9dad-11d1-80b4-00c04fd430c8."
    - "NAMESPACE_OID = 6ba7b812-9dad-11d1-80b4-00c04fd430c8."
    - "NAMESPACE_X500 = 6ba7b814-9dad-11d1-80b4-00c04fd430c8."
    - "uuid.SafeUUID.safe.value == 0; uuid.SafeUUID.unsafe.value == -1."
    - "SafeUUID.__int__ is not defined; integer values accessed via .value attribute."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: UUID namespace constant class names
# ---------------------------------------------------------------------------

table uuid_extra2326.namespace_class_names:
  description: "uuid namespace constants are UUID instances — __class__.__name__ == 'UUID'"
  kind: python_call_eq
  category: constants
  id_prefix: uu2326

  columns: [id, function, args, expected]
  rows:
    - ["uu2326001", "uuid.NAMESPACE_DNS.__class__.__name__",  [], "UUID"]
    - ["uu2326002", "uuid.NAMESPACE_URL.__class__.__name__",  [], "UUID"]
    - ["uu2326003", "uuid.NAMESPACE_OID.__class__.__name__",  [], "UUID"]
    - ["uu2326004", "uuid.NAMESPACE_X500.__class__.__name__", [], "UUID"]

# ---------------------------------------------------------------------------
# Table 2: UUID namespace constant string representations
#
# RFC 4122 Appendix C defines these exact UUIDs.  The string form is the
# canonical 8-4-4-4-12 hex representation returned by UUID.__str__.
# ---------------------------------------------------------------------------

table uuid_extra2326.namespace_string_values:
  description: "uuid namespace constant canonical string representations (RFC 4122)"
  kind: python_call_eq
  category: constants
  id_prefix: uu2326

  columns: [id, function, args, expected]
  rows:
    - ["uu2326005", "uuid.NAMESPACE_DNS.__str__",  [], "6ba7b810-9dad-11d1-80b4-00c04fd430c8"]
    - ["uu2326006", "uuid.NAMESPACE_URL.__str__",  [], "6ba7b811-9dad-11d1-80b4-00c04fd430c8"]
    - ["uu2326007", "uuid.NAMESPACE_OID.__str__",  [], "6ba7b812-9dad-11d1-80b4-00c04fd430c8"]
    - ["uu2326008", "uuid.NAMESPACE_X500.__str__", [], "6ba7b814-9dad-11d1-80b4-00c04fd430c8"]

# ---------------------------------------------------------------------------
# Table 3: UUID namespace constant version and variant attributes
#
# These namespaces were defined before RFC 4122 version numbering;
# uuid.UUID objects expose .version (None for these) and .variant.
# We check the integer representation of the UUID (its .int attribute).
# ---------------------------------------------------------------------------

table uuid_extra2326.namespace_int_values:
  description: "uuid namespace constant .int attribute (128-bit integer representation)"
  kind: python_call_eq
  category: constants
  id_prefix: uu2326

  columns: [id, function, args, expected]
  rows:
    - ["uu2326009",  "uuid.NAMESPACE_DNS.int.__eq__",   [143098242404177361603877621312831893704], true]
    - ["uu2326010",  "uuid.NAMESPACE_URL.int.__eq__",   [143098242483405524118141958906375844040], true]
    - ["uu2326011",  "uuid.NAMESPACE_OID.int.__eq__",   [143098242562633686632406296499919794376], true]
    - ["uu2326012",  "uuid.NAMESPACE_X500.int.__eq__",  [143098242721090011660934971687007695048], true]

# ---------------------------------------------------------------------------
# Table 4: SafeUUID enum values
#
# SafeUUID is an IntEnum-like enum but does not support int() directly.
# Integer values are accessed via the .value attribute.
# safe == 0 (UUID generated safely without multiprocessing hazards).
# unsafe == -1 (UUID generation safety unknown).
# ---------------------------------------------------------------------------

table uuid_extra2326.safe_uuid_values:
  description: "uuid.SafeUUID enum member .value integer constants"
  kind: python_call_eq
  category: constants
  id_prefix: uu2326

  columns: [id, function, args, expected]
  rows:
    - ["uu2326013", "uuid.SafeUUID.safe.value",           [], 0]
    - ["uu2326014", "uuid.SafeUUID.unsafe.value",         [], -1]
    - ["uu2326015", "uuid.SafeUUID.safe.value.__eq__",    [0],  true]
    - ["uu2326016", "uuid.SafeUUID.unsafe.value.__eq__",  [-1], true]
    - ["uu2326017", "uuid.SafeUUID.safe.__class__.__name__",   [], "SafeUUID"]
    - ["uu2326018", "uuid.SafeUUID.unsafe.__class__.__name__", [], "SafeUUID"]
    - ["uu2326019", "uuid.SafeUUID.safe.name",   [], "safe"]
    - ["uu2326020", "uuid.SafeUUID.unsafe.name", [], "unsafe"]
