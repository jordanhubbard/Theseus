spec: socket_extra114
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra113.zspec.zsdl — covers socket.socket.send/recv/listen/accept/setsockopt/getsockopt qualname equality and type identity (table + invariants)."
    - "socket_extra112.zspec.zsdl — covers AddressFamily/SocketKind enum .name equality and lengths / socket.socket MRO structure / socket.socket.bind and connect qualname lengths (table + invariants)."
    - "socket_extra111.zspec.zsdl — covers socket module-level __name__/__package__/__spec__/__all__/__loader__ dunder attributes (table + invariants)."
    - "socket_extra110.zspec.zsdl — covers socket.socket context manager methods / socket.__repr__ qualname / socket.socket.__module__/__qualname__ equality (table + invariants)."
    - "socket_extra109.zspec.zsdl — covers socket.socket Python-defined method co_argcount values and qualnames (table + invariants)."
    - "socket_extra108.zspec.zsdl — covers gethostname/gethostbyname/getnameinfo/getaddrinfo/getfqdn function identities — class names and __module__ equality / setdefaulttimeout/getdefaulttimeout/create_connection type identity / getfqdn code attributes (table + invariants)."
    - "socket_extra107.zspec.zsdl — covers SO_* option constants and socket.error/timeout class identity and MRO (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types and qualname lengths (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra113; it does NOT duplicate invariants present in those files."
    - "Wave 274 theme: socket module-level function __name__ equality not yet individually anchored as __eq__ calls — gethostname/gethostbyname/getnameinfo (C-level) and getfqdn/getaddrinfo (Python-level) / getaddrinfo co_argcount==6 / gethostbyname __name__ length / module equality as length for C vs Python distinction."
    - "socket.gethostname.__name__ == 'gethostname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__name__ == 'gethostbyname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__name__ == 'getnameinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__name__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_argcount == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_name == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.gethostbyname.__name__) == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.gethostname.__name__) == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.getfqdn.__name__) == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__ == socket.gethostname.__name__ (both 'gethostname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket_extra108 anchored the type names (builtin_function_or_method vs function) and __module__ equality for gethostname/gethostbyname/getnameinfo/getaddrinfo/getfqdn. This spec anchors the __name__ equality for the same functions as a new angle: confirming that __name__ == __qualname__ for all of them (both C-level and Python-level module functions have __name__ == __qualname__ when they are top-level, not methods)."
    - "Note: getaddrinfo.__code__.co_argcount == 6 is notable: getaddrinfo(host, port, family=0, type=0, proto=0, flags=0) — it takes 2 required and 4 optional positional arguments (co_argcount counts all positional args). This is the highest co_argcount among the socket name-resolution functions (getfqdn=1, getaddrinfo=6). socket_extra108 anchors getfqdn co_argcount==1; this spec anchors getaddrinfo co_argcount==6 for the first time."
    - "Note: gethostbyname.__name__.__len__() == 13 (longest among the name-resolution functions covered in this spec). gethostname and getnameinfo and getaddrinfo are all 11 chars. getfqdn is 7 chars (shortest). gethostbyname at 13 chars parallels socket.gethostbyname (resolves a hostname to an IPv4 address) being a conceptually 'fuller' operation than gethostname."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostname.__name__.__eq__('gethostname')
# socket.gethostbyname.__name__.__eq__('gethostbyname')
# socket.getnameinfo.__name__.__eq__('getnameinfo')
# socket.gethostname.__name__.__len__() == 11
# socket.gethostbyname.__name__.__len__() == 13
#
# Wave 274 theme: C-level name-resolution function __name__ equality.
#
# gethostname, gethostbyname, getnameinfo are C-level functions from _socket.
# socket_extra108 anchors their class names and __module__ equality. This spec
# anchors __name__ equality for the first time as individual __eq__ calls.
# All three have __name__ == __qualname__ (no class prefix for module-level C
# functions). gethostname and getnameinfo share length 11; gethostbyname is 13.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra114.C_level_name_resolution_function_name_equality:
  description: "gethostname.__name__.__eq__('gethostname')==True / gethostbyname.__name__.__eq__('gethostbyname')==True / getnameinfo.__name__.__eq__('getnameinfo')==True / gethostname.__name__.__len__()==11 / gethostbyname.__name__.__len__()==13 — gethostname and getnameinfo both 11 chars; gethostbyname is 13 chars (longest in this group); all are C-level builtin_function_or_method with __module__=='_socket'; __name__==__qualname__ for module-level C functions; extra108 anchors class names and __module__; first sockname114 anchor for __name__ equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockname114

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_name_eq,   "gethostname.__name__.__eq__",   ["gethostname"],   true, "socket.gethostname.__name__ is 'gethostname' (11 chars; C-level from _socket; returns local machine hostname)"]
    - [gethostbyname_name_eq, "gethostbyname.__name__.__eq__", ["gethostbyname"], true, "socket.gethostbyname.__name__ is 'gethostbyname' (13 chars; C-level from _socket; resolves hostname to IPv4 address)"]
    - [getnameinfo_name_eq,   "getnameinfo.__name__.__eq__",   ["getnameinfo"],   true, "socket.getnameinfo.__name__ is 'getnameinfo' (11 chars; C-level from _socket; reverse resolves address to hostname/service)"]
    - [gethostname_name_len,  "gethostname.__name__.__len__",  [],                11,   "socket.gethostname.__name__.__len__() is 11 (same length as getnameinfo and getaddrinfo in this spec)"]
    - [gethostbyname_name_len,"gethostbyname.__name__.__len__",[],                13,   "socket.gethostbyname.__name__.__len__() is 13 (longest in this group; 2 more than gethostname/getnameinfo/getaddrinfo)"]

# ---------------------------------------------------------------------------
# socket.getfqdn.__name__.__eq__('getfqdn')
# socket.getaddrinfo.__name__.__eq__('getaddrinfo')
# socket.getaddrinfo.__code__.co_argcount == 6
# socket.getaddrinfo.__code__.co_name.__eq__('getaddrinfo')
# socket.getfqdn.__name__.__len__() == 7
#
# Wave 274 theme: Python-level name-resolution function __name__ and getaddrinfo code attrs.
#
# getfqdn and getaddrinfo are Python-level functions (Lib/socket.py). Their __name__
# values are 'getfqdn' (7 chars) and 'getaddrinfo' (11 chars). getaddrinfo has
# co_argcount==6 (host, port, family, type, proto, flags) — the highest among
# socket name-resolution functions. socket_extra108 anchors getfqdn co_argcount==1;
# this spec anchors getaddrinfo co_argcount==6 for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra114.Python_level_name_resolution_function_name_and_code:
  description: "getfqdn.__name__.__eq__('getfqdn')==True / getaddrinfo.__name__.__eq__('getaddrinfo')==True / getaddrinfo.__code__.co_argcount==6 / getaddrinfo.__code__.co_name.__eq__('getaddrinfo')==True / getfqdn.__name__.__len__()==7 — getfqdn is 7 chars (shortest name-resolution function); getaddrinfo is 11 chars; getaddrinfo co_argcount==6 (host, port, family=0, type=0, proto=0, flags=0); extra108 anchors getfqdn co_argcount==1; first sockname114 anchor for getaddrinfo co_argcount and these __name__ equalities"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockname114

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_name_eq,         "getfqdn.__name__.__eq__",          ["getfqdn"],     true, "socket.getfqdn.__name__ is 'getfqdn' (7 chars; Python-level function in Lib/socket.py; returns fully qualified domain name)"]
    - [getaddrinfo_name_eq,     "getaddrinfo.__name__.__eq__",      ["getaddrinfo"], true, "socket.getaddrinfo.__name__ is 'getaddrinfo' (11 chars; Python-level function; supports IPv4 and IPv6)"]
    - [getaddrinfo_co_argcount, "getaddrinfo.__code__.co_argcount", [],              6,    "socket.getaddrinfo.__code__.co_argcount is 6 (host, port, family=0, type=0, proto=0, flags=0; highest among name-resolution functions)"]
    - [getaddrinfo_co_name_eq,  "getaddrinfo.__code__.co_name.__eq__",["getaddrinfo"],true, "socket.getaddrinfo.__code__.co_name is 'getaddrinfo' (matches __name__; Python def statement name)"]
    - [getfqdn_name_len,        "getfqdn.__name__.__len__",         [],              7,    "socket.getfqdn.__name__.__len__() is 7 (shortest among name-resolution functions; 'getfqdn'='get'=3+'fqdn'=4)"]

# ---------------------------------------------------------------------------
# socket.gethostname.__qualname__.__eq__('gethostname')
# socket.gethostbyname.__qualname__.__eq__('gethostbyname')
# socket.getaddrinfo.__qualname__.__eq__('getaddrinfo')
# socket.getfqdn.__qualname__.__eq__('getfqdn')
# socket.getnameinfo.__name__.__len__() == 11
#
# Wave 274 theme: name-resolution function __qualname__ equality.
#
# For all socket name-resolution functions (both C-level and Python-level),
# __qualname__ == __name__ (no class prefix; all are module-level functions).
# socket_extra99 anchors qualname lengths; socket_extra108 anchors type and module.
# This spec anchors __qualname__ equality as __eq__ calls for the first time for
# gethostname, gethostbyname, getaddrinfo, and getfqdn.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra114.name_resolution_function_qualname_equality:
  description: "gethostname.__qualname__.__eq__('gethostname')==True / gethostbyname.__qualname__.__eq__('gethostbyname')==True / getaddrinfo.__qualname__.__eq__('getaddrinfo')==True / getfqdn.__qualname__.__eq__('getfqdn')==True / getnameinfo.__name__.__len__()==11 — all name-resolution functions have __qualname__==__name__ (module-level; no class prefix); applies to both C-level (gethostname/gethostbyname) and Python-level (getaddrinfo/getfqdn); getnameinfo is 11 chars; extra99 anchors qualname lengths; first sockname114 anchor for __qualname__ equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockname114

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_qualname_eq,   "gethostname.__qualname__.__eq__",   ["gethostname"],   true, "socket.gethostname.__qualname__ is 'gethostname' (same as __name__; C-level module function; no class prefix)"]
    - [gethostbyname_qualname_eq, "gethostbyname.__qualname__.__eq__", ["gethostbyname"], true, "socket.gethostbyname.__qualname__ is 'gethostbyname' (same as __name__; C-level from _socket; no class prefix)"]
    - [getaddrinfo_qualname_eq,   "getaddrinfo.__qualname__.__eq__",   ["getaddrinfo"],   true, "socket.getaddrinfo.__qualname__ is 'getaddrinfo' (same as __name__; Python-level module function; no class prefix)"]
    - [getfqdn_qualname_eq,       "getfqdn.__qualname__.__eq__",       ["getfqdn"],       true, "socket.getfqdn.__qualname__ is 'getfqdn' (same as __name__; Python-level module function; no class prefix)"]
    - [getnameinfo_name_len,      "getnameinfo.__name__.__len__",      [],                11,   "socket.getnameinfo.__name__.__len__() is 11 (same length as gethostname and getaddrinfo; gethostbyname at 13 is longest)"]

# ---------------------------------------------------------------------------
# socket.gethostname.__name__.__eq__('gethostname') — standalone
#
# socket.gethostname.__name__ is 'gethostname' (11 chars). gethostname is the
# simplest socket name-resolution function — it takes no arguments and returns
# the standard hostname of the local machine. It is a C-level function from
# _socket (builtin_function_or_method). socket_extra108 anchors gethostname's
# type and __module__; no prior socket spec anchors gethostname __name__ equality
# as a standalone under sockname114. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra114.gethostname_name_eq:
  description: "socket.gethostname.__name__.__eq__('gethostname') == True — __name__ is 'gethostname' (11 chars; 'get'=3 + 'hostname'=8); C-level from _socket; takes no arguments; __name__==__qualname__; extra108 anchors gethostname type and module; first standalone for gethostname __name__ equality under sockname114"
  category: function_identity
  kind: python_call_eq
  function: "gethostname.__name__.__eq__"
  args: ["gethostname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostbyname.__name__.__eq__('gethostbyname') — standalone
#
# socket.gethostbyname.__name__ is 'gethostbyname' (13 chars). gethostbyname
# is the longest-named function in this spec. It resolves a hostname string
# to an IPv4 address string (e.g., 'example.com' -> '93.184.216.34'). It is
# a C-level function from _socket (type 'builtin_function_or_method'), so it
# has no __code__ attribute. socket_extra108 anchors its type and __module__;
# no prior socket spec anchors gethostbyname __name__ equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra114.gethostbyname_name_eq:
  description: "socket.gethostbyname.__name__.__eq__('gethostbyname') == True — __name__ is 'gethostbyname' (13 chars; longest among name-resolution functions in this spec; 'get'=3 + 'host'=4 + 'byname'=6); C-level from _socket; resolves hostname to IPv4 address string; no __code__ attribute; extra108 anchors type and __module__; first standalone under sockname114"
  category: function_identity
  kind: python_call_eq
  function: "gethostbyname.__name__.__eq__"
  args: ["gethostbyname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_argcount == 6 — standalone
#
# socket.getaddrinfo.__code__.co_argcount is 6. getaddrinfo takes:
# host (required), port (required), family=0, type=0, proto=0, flags=0.
# The 4 optional keyword-capable positional args bring the total to 6.
# This is the highest co_argcount among the socket name-resolution functions:
# getfqdn=1 (from socket_extra108), create_connection=3 (from socket_extra108),
# getaddrinfo=6 (first anchored here). getaddrinfo is Python-level (Lib/socket.py),
# so it has a __code__ attribute (unlike C-level gethostname/gethostbyname).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra114.getaddrinfo_co_argcount_6:
  description: "socket.getaddrinfo.__code__.co_argcount == 6 — takes host, port, family=0, type=0, proto=0, flags=0; highest co_argcount among name-resolution functions (getfqdn=1, create_connection=3, getaddrinfo=6); Python-level function (has __code__; module=='socket'); supports IPv4 and IPv6; extra108 anchors getfqdn co_argcount==1; first standalone for getaddrinfo co_argcount under sockname114"
  category: function_identity
  kind: python_call_eq
  function: "getaddrinfo.__code__.co_argcount"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__name__.__eq__('getaddrinfo') — standalone
#
# socket.getaddrinfo.__name__ is 'getaddrinfo' (11 chars). getaddrinfo is the
# most general-purpose address lookup function in the socket module. It is a
# Python-level function (module == 'socket'), unlike C-level gethostbyname
# (module == '_socket'). Both gethostname and getnameinfo also have 11-char
# __name__ values, so getaddrinfo joins that group despite being Python-level
# vs their C-level implementation. No prior socket spec anchors getaddrinfo
# __name__ equality as a standalone under sockname114.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra114.getaddrinfo_name_eq:
  description: "socket.getaddrinfo.__name__.__eq__('getaddrinfo') == True — __name__ is 'getaddrinfo' (11 chars; same length as gethostname and getnameinfo; despite being Python-level while those are C-level); supports IPv4/IPv6 and returns list of (family, type, proto, canonname, sockaddr) tuples; extra108 anchors getaddrinfo type and module; first standalone for getaddrinfo __name__ equality under sockname114"
  category: function_identity
  kind: python_call_eq
  function: "getaddrinfo.__name__.__eq__"
  args: ["getaddrinfo"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__name__.__eq__('getfqdn') — standalone
#
# socket.getfqdn.__name__ is 'getfqdn' (7 chars: 'get'=3 + 'fqdn'=4). getfqdn
# is the shortest-named socket name-resolution function. It is a Python-level
# function (module == 'socket') that returns the fully qualified domain name
# (FQDN) for a given hostname. socket_extra108 anchors getfqdn type, module,
# and co_argcount (==1); this spec anchors getfqdn __name__ equality as a
# standalone for the first time under sockname114.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra114.getfqdn_name_eq:
  description: "socket.getfqdn.__name__.__eq__('getfqdn') == True — __name__ is 'getfqdn' (7 chars; 'get'=3 + 'fqdn'=4; FQDN = fully qualified domain name; shortest name-resolution function name); Python-level (module=='socket'); extra108 anchors getfqdn type/module/co_argcount; first standalone for getfqdn __name__ equality under sockname114"
  category: function_identity
  kind: python_call_eq
  function: "getfqdn.__name__.__eq__"
  args: ["getfqdn"]
  expected: true
