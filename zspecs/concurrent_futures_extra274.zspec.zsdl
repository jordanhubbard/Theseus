spec: concurrent_futures_extra274
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures._base internal state string constants and Future/Executor class identity. NEW in extra274: concurrent.futures._base.PENDING=='PENDING' (len=7); concurrent.futures._base.RUNNING=='RUNNING' (len=7); concurrent.futures._base.CANCELLED=='CANCELLED' (len=9); concurrent.futures._base.FINISHED=='FINISHED' (len=8); concurrent.futures._base.CANCELLED_AND_NOTIFIED=='CANCELLED_AND_NOTIFIED' (len=22); concurrent.futures.Future.__name__=='Future'; concurrent.futures.Future.__module__=='concurrent.futures._base'; concurrent.futures.Future.__bases__[0].__name__=='object'; concurrent.futures.Future.__mro__.__len__()==2; concurrent.futures.Executor.__name__=='Executor'; concurrent.futures.Executor.__module__=='concurrent.futures._base'; concurrent.futures.Executor.__bases__[0].__name__=='object'; concurrent.futures.Executor.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.PENDING == 'PENDING'. The five internal state constants (PENDING, RUNNING, CANCELLED, CANCELLED_AND_NOTIFIED, FINISHED) are plain string sentinels defined in Lib/concurrent/futures/_base.py; they are used to track Future lifecycle state. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED' (len=22). This is the longest state constant string: 'CANCELLED_AND_NOTIFIED' = 'CANCELLED'=9 + '_AND_NOTIFIED'=13 = 22. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base'. Future is a pure-Python class defined in Lib/concurrent/futures/_base.py, not in the C extension. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures has no __version__ attribute. Unlike some stdlib modules, concurrent.futures does not expose a __version__ string. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures._base internal state string constants — extra274
#
# concurrent.futures._base.PENDING                == 'PENDING'                (len=7)
# concurrent.futures._base.RUNNING                == 'RUNNING'                (len=7)
# concurrent.futures._base.CANCELLED              == 'CANCELLED'              (len=9)
# concurrent.futures._base.FINISHED               == 'FINISHED'               (len=8)
# concurrent.futures._base.CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED' (len=22)
# ---------------------------------------------------------------------------

table concurrent_futures_extra274.cf_state_constants:
  description: "concurrent.futures._base internal state string constant checks in cfstate274 namespace — the five state constants in Lib/concurrent/futures/_base.py track Future lifecycle: PENDING (initial state, not yet running), RUNNING (currently executing), CANCELLED (cancel() called before completion), CANCELLED_AND_NOTIFIED (cancellation notified to done callbacks), FINISHED (execution completed, either result or exception set); all constants are plain Python str values; concurrent.futures._base.PENDING.__eq__('PENDING')==True (len=7); concurrent.futures._base.RUNNING.__eq__('RUNNING')==True (len=7, equal length to PENDING); concurrent.futures._base.CANCELLED.__eq__('CANCELLED')==True (len=9); concurrent.futures._base.FINISHED.__eq__('FINISHED')==True (len=8); concurrent.futures._base.CANCELLED_AND_NOTIFIED.__eq__('CANCELLED_AND_NOTIFIED')==True (len=22, longest — 'CANCELLED'=9 + '_AND_NOTIFIED'=13); PENDING.__len__()==7; CANCELLED.__len__()==9; CANCELLED_AND_NOTIFIED.__len__()==22; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: cfstate274

  columns: [id, function, args, expected, description]
  rows:
    - [pending_eq,    "concurrent.futures._base.PENDING.__eq__",                    ["PENDING"],                true, "concurrent.futures._base.PENDING == 'PENDING'; verified with Python 3.14.3"]
    - [pending_len,   "concurrent.futures._base.PENDING.__len__",                   [],                         7,    "concurrent.futures._base.PENDING.__len__() == 7; verified with Python 3.14.3"]
    - [running_eq,    "concurrent.futures._base.RUNNING.__eq__",                    ["RUNNING"],                true, "concurrent.futures._base.RUNNING == 'RUNNING'; verified with Python 3.14.3"]
    - [running_len,   "concurrent.futures._base.RUNNING.__len__",                   [],                         7,    "concurrent.futures._base.RUNNING.__len__() == 7 (equal to PENDING); verified with Python 3.14.3"]
    - [cancelled_eq,  "concurrent.futures._base.CANCELLED.__eq__",                  ["CANCELLED"],              true, "concurrent.futures._base.CANCELLED == 'CANCELLED'; verified with Python 3.14.3"]
    - [cancelled_len, "concurrent.futures._base.CANCELLED.__len__",                 [],                         9,    "concurrent.futures._base.CANCELLED.__len__() == 9; verified with Python 3.14.3"]
    - [finished_eq,   "concurrent.futures._base.FINISHED.__eq__",                   ["FINISHED"],               true, "concurrent.futures._base.FINISHED == 'FINISHED'; verified with Python 3.14.3"]
    - [finished_len,  "concurrent.futures._base.FINISHED.__len__",                  [],                         8,    "concurrent.futures._base.FINISHED.__len__() == 8; verified with Python 3.14.3"]
    - [can_eq,        "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__eq__",     ["CANCELLED_AND_NOTIFIED"], true, "concurrent.futures._base.CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED'; verified with Python 3.14.3"]
    - [can_len,       "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__",    [],                         22,   "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__() == 22 (longest state constant); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future and Executor class identity — extra274
#
# concurrent.futures.Future.__name__               == 'Future'
# concurrent.futures.Future.__module__             == 'concurrent.futures._base'
# concurrent.futures.Future.__bases__[0].__name__  == 'object'
# concurrent.futures.Future.__mro__.__len__()      == 2
# concurrent.futures.Executor.__name__             == 'Executor'
# concurrent.futures.Executor.__module__           == 'concurrent.futures._base'
# concurrent.futures.Executor.__bases__[0].__name__ == 'object'
# concurrent.futures.Executor.__mro__.__len__()    == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra274.cf_future_executor_identity:
  description: "concurrent.futures.Future and Executor class identity checks in cfstate274 namespace — both Future and Executor are pure-Python classes defined in Lib/concurrent/futures/_base.py; Future.__name__.__eq__('Future')==True; Future.__module__.__eq__('concurrent.futures._base')==True (len=26: 'concurrent.futures.'=19 + '_base'=7; note the leading underscore); Future.__bases__[0].__name__.__eq__('object')==True (Future inherits directly from object); Future.__mro__.__len__()==2 ([Future, object], minimal 2-element chain); Future.__qualname__.__eq__('Future')==True (module-level class); Executor.__name__.__eq__('Executor')==True; Executor.__module__.__eq__('concurrent.futures._base')==True (same module as Future); Executor.__bases__[0].__name__.__eq__('object')==True; Executor.__mro__.__len__()==2 ([Executor, object]); Executor.__qualname__.__eq__('Executor')==True; contrast: ThreadPoolExecutor.__module__=='concurrent.futures.thread' and ProcessPoolExecutor.__module__=='concurrent.futures.process' (different submodules); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfstate274a

  columns: [id, function, args, expected, description]
  rows:
    - [fut_name_eq,   "concurrent.futures.Future.__name__.__eq__",                   ["Future"],                      true, "concurrent.futures.Future.__name__ == 'Future'; verified with Python 3.14.3"]
    - [fut_mod_eq,    "concurrent.futures.Future.__module__.__eq__",                 ["concurrent.futures._base"],    true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base' (len=26); verified with Python 3.14.3"]
    - [fut_base0_eq,  "concurrent.futures.Future.__bases__[0].__name__.__eq__",      ["object"],                      true, "concurrent.futures.Future.__bases__[0].__name__ == 'object' — direct subclass; verified with Python 3.14.3"]
    - [fut_mro_len,   "concurrent.futures.Future.__mro__.__len__",                   [],                              2,    "concurrent.futures.Future.__mro__.__len__() == 2 — [Future, object]; verified with Python 3.14.3"]
    - [fut_qn_eq,     "concurrent.futures.Future.__qualname__.__eq__",               ["Future"],                      true, "concurrent.futures.Future.__qualname__ == 'Future' (module-level class); verified with Python 3.14.3"]
    - [exc_name_eq,   "concurrent.futures.Executor.__name__.__eq__",                 ["Executor"],                    true, "concurrent.futures.Executor.__name__ == 'Executor'; verified with Python 3.14.3"]
    - [exc_mod_eq,    "concurrent.futures.Executor.__module__.__eq__",               ["concurrent.futures._base"],    true, "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' (same as Future); verified with Python 3.14.3"]
    - [exc_base0_eq,  "concurrent.futures.Executor.__bases__[0].__name__.__eq__",    ["object"],                      true, "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — direct subclass; verified with Python 3.14.3"]
    - [exc_mro_len,   "concurrent.futures.Executor.__mro__.__len__",                 [],                              2,    "concurrent.futures.Executor.__mro__.__len__() == 2 — [Executor, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra274
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra274.PENDING_eq_str_PENDING:
  description: "concurrent.futures._base.PENDING.__eq__('PENDING') returns True — PENDING is a plain Python str sentinel used to indicate that a Future has been submitted but not yet begun executing; the five state constants (PENDING, RUNNING, CANCELLED, CANCELLED_AND_NOTIFIED, FINISHED) are defined at module level in Lib/concurrent/futures/_base.py; they are string values (not enums) because they predate Python's enum module in the cpython timeline; PENDING.__len__() is 7; RUNNING.__len__() is also 7 (equal to PENDING); CANCELLED.__len__() is 9; FINISHED.__len__() is 8; CANCELLED_AND_NOTIFIED.__len__() is 22 (longest, 'CANCELLED'=9+'_AND_NOTIFIED'=13); NEW in extra274: first standalone PENDING string value invariant in cfstate274 namespace; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: "concurrent.futures._base.PENDING.__eq__"
  args: ["PENDING"]
  expected: true

invariant concurrent_futures_extra274.CANCELLED_AND_NOTIFIED_len_22:
  description: "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__() == 22 — CANCELLED_AND_NOTIFIED is the longest of the five state constants; 'CANCELLED_AND_NOTIFIED' is 22 chars: 'CANCELLED'=9 + '_AND_NOTIFIED'=13; it represents the state where a Future's cancellation has been recorded and all done callbacks have been notified; compare state constant lengths: PENDING=7, RUNNING=7, FINISHED=8, CANCELLED=9, CANCELLED_AND_NOTIFIED=22; the gap between CANCELLED (9) and CANCELLED_AND_NOTIFIED (22) is 13 chars ('_AND_NOTIFIED'=13); concurrent.futures._base.CANCELLED_AND_NOTIFIED.__class__.__name__ is 'str'; NEW in extra274: first standalone CANCELLED_AND_NOTIFIED length invariant in cfstate274 namespace; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__"
  args: []
  expected: 22

invariant concurrent_futures_extra274.Future_module_is_base:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.Future is a pure-Python class defined in Lib/concurrent/futures/_base.py; unlike asyncio.Future whose __module__ is '_asyncio' (C extension), concurrent.futures.Future lives in the Python-level '_base' submodule; the module name 'concurrent.futures._base' has len=26 ('concurrent.futures.'=19 + '_base'=7); Future is the central class coordinating submitted callables and their results; Future.__mro__.__len__() is 2 ([Future, object]); the Executor class shares the same __module__; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' and ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (different submodules); NEW in extra274: first standalone Future.__module__ invariant in cfstate274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra274.CANCELLED_len_9:
  description: "concurrent.futures._base.CANCELLED.__len__() == 9 — 'CANCELLED' is 9 characters; CANCELLED is the state set when Future.cancel() is called and the future is successfully cancelled before it begins execution; distinct from CANCELLED_AND_NOTIFIED which indicates callbacks have also been fired; compare: PENDING=7, RUNNING=7, FINISHED=8, CANCELLED=9; CANCELLED is longer than FINISHED by 1 char ('CANCELLED'=9 vs 'FINISHED'=8); concurrent.futures._base.CANCELLED.__eq__('CANCELLED') returns True; concurrent.futures._base.CANCELLED.__class__.__name__ is 'str'; NEW in extra274: first standalone CANCELLED length invariant in cfstate274 namespace; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: "concurrent.futures._base.CANCELLED.__len__"
  args: []
  expected: 9

invariant concurrent_futures_extra274.Executor_module_equals_Future_module:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.Executor and concurrent.futures.Future are both defined in Lib/concurrent/futures/_base.py and share the same __module__ 'concurrent.futures._base'; Executor is the abstract base class for ThreadPoolExecutor and ProcessPoolExecutor; Executor.__mro__.__len__() is 2 ([Executor, object]); Executor.__bases__[0].__name__ is 'object'; Executor defines submit(), map(), and shutdown() as the public interface; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' and ProcessPoolExecutor.__module__ is 'concurrent.futures.process', showing that concrete executors live in separate submodules from the abstract base; NEW in extra274: first standalone Executor.__module__ invariant in cfstate274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true
