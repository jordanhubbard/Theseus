spec: struct_extra209
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack.__doc__ contains 'string', 'values', 'Return', 'packed', 'according'."
    - "struct.unpack.__doc__ contains 'string', 'values', 'tuple', 'buffer', 'calcsize'."
    - "struct.calcsize.__doc__ contains 'format', 'size', 'Return', 'described'."
    - "struct.Struct.__doc__ contains 'Struct', 'compiled', 'fmt', '-->'."
    - "struct.pack_into.__doc__ contains 'buffer', 'offset', 'writable', 'required', 'packed'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack and struct.unpack — __doc__ contains checks (different words from wave 379)
#
# struct.pack.__doc__ contains 'string', 'values', 'Return', 'packed', 'according'
# struct.unpack.__doc__ contains 'string', 'values', 'calcsize'
# ---------------------------------------------------------------------------

table struct_extra209.pack_unpack_doc_contains_extra:
  description: "struct.pack and struct.unpack __doc__ contains checks in structdoc209 namespace — wave 209 theme: struct.pack.__doc__.__contains__('string')==True; struct.pack.__doc__.__contains__('values')==True; struct.pack.__doc__.__contains__('Return')==True; struct.pack.__doc__.__contains__('packed')==True; struct.pack.__doc__.__contains__('according')==True; struct.unpack.__doc__.__contains__('string')==True; struct.unpack.__doc__.__contains__('values')==True; struct.unpack.__doc__.__contains__('calcsize')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc209

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_has_string,    struct.pack.__doc__.__contains__,   ["string"],   true, "struct.pack.__doc__ contains 'string'; takes a format string argument; verified with Python 3.14.3"]
    - [pack_doc_has_values,    struct.pack.__doc__.__contains__,   ["values"],   true, "struct.pack.__doc__ contains 'values'; packs values v1, v2, ...; verified with Python 3.14.3"]
    - [pack_doc_has_Return,    struct.pack.__doc__.__contains__,   ["Return"],   true, "struct.pack.__doc__ contains 'Return'; doc reads 'Return a bytes object'; verified with Python 3.14.3"]
    - [pack_doc_has_packed,    struct.pack.__doc__.__contains__,   ["packed"],   true, "struct.pack.__doc__ contains 'packed'; values are packed according to format; verified with Python 3.14.3"]
    - [pack_doc_has_according, struct.pack.__doc__.__contains__,   ["according"], true, "struct.pack.__doc__ contains 'according'; packed according to the format string; verified with Python 3.14.3"]
    - [unpack_doc_has_string,  struct.unpack.__doc__.__contains__, ["string"],   true, "struct.unpack.__doc__ contains 'string'; takes a format string argument; verified with Python 3.14.3"]
    - [unpack_doc_has_values,  struct.unpack.__doc__.__contains__, ["values"],   true, "struct.unpack.__doc__ contains 'values'; returns tuple containing unpacked values; verified with Python 3.14.3"]
    - [unpack_doc_has_calcsize, struct.unpack.__doc__.__contains__, ["calcsize"], true, "struct.unpack.__doc__ contains 'calcsize'; references calcsize(format) for buffer size; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.calcsize and struct.Struct — __doc__ contains checks (different words from wave 379)
#
# struct.calcsize.__doc__ contains 'Return', 'described', 'format'
# struct.Struct.__doc__ contains 'Struct', 'compiled', 'fmt', '-->'
# ---------------------------------------------------------------------------

table struct_extra209.calcsize_Struct_doc_contains_extra:
  description: "struct.calcsize and struct.Struct __doc__ contains checks in structdoc209a namespace — wave 209 theme: struct.calcsize.__doc__.__contains__('Return')==True; struct.calcsize.__doc__.__contains__('described')==True; struct.calcsize.__doc__.__contains__('format')==True; struct.Struct.__doc__.__contains__('Struct')==True; struct.Struct.__doc__.__contains__('compiled')==True; struct.Struct.__doc__.__contains__('fmt')==True; struct.Struct.__doc__.__contains__('-->')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc209a

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_doc_has_Return,    struct.calcsize.__doc__.__contains__, ["Return"],    true, "struct.calcsize.__doc__ contains 'Return'; doc reads 'Return size in bytes'; verified with Python 3.14.3"]
    - [calcsize_doc_has_described, struct.calcsize.__doc__.__contains__, ["described"], true, "struct.calcsize.__doc__ contains 'described'; struct described by format string; verified with Python 3.14.3"]
    - [calcsize_doc_has_format,    struct.calcsize.__doc__.__contains__, ["format"],    true, "struct.calcsize.__doc__ contains 'format'; takes a format string argument; verified with Python 3.14.3"]
    - [Struct_doc_has_Struct,      struct.Struct.__doc__.__contains__,   ["Struct"],    true, "struct.Struct.__doc__ contains 'Struct'; class name in signature; verified with Python 3.14.3"]
    - [Struct_doc_has_compiled,    struct.Struct.__doc__.__contains__,   ["compiled"],  true, "struct.Struct.__doc__ contains 'compiled'; Struct(fmt) yields a compiled struct object; verified with Python 3.14.3"]
    - [Struct_doc_has_fmt,         struct.Struct.__doc__.__contains__,   ["fmt"],       true, "struct.Struct.__doc__ contains 'fmt'; fmt is the format parameter in the constructor signature; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack_into — __doc__ contains checks (different words from wave 379)
#
# struct.pack_into.__doc__ contains 'buffer', 'offset', 'writable', 'required', 'packed'
# ---------------------------------------------------------------------------

table struct_extra209.pack_into_doc_contains_extra:
  description: "struct.pack_into __doc__ contains checks in structdoc209b namespace — wave 209 theme: struct.pack_into.__doc__.__contains__('buffer')==True; struct.pack_into.__doc__.__contains__('offset')==True; struct.pack_into.__doc__.__contains__('writable')==True; struct.pack_into.__doc__.__contains__('required')==True; struct.pack_into.__doc__.__contains__('packed')==True; pack_into writes into a writable buffer at a required offset; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc209b

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_doc_has_buffer,   struct.pack_into.__doc__.__contains__, ["buffer"],   true, "struct.pack_into.__doc__ contains 'buffer'; writes into a writable buffer; verified with Python 3.14.3"]
    - [pack_into_doc_has_offset,   struct.pack_into.__doc__.__contains__, ["offset"],   true, "struct.pack_into.__doc__ contains 'offset'; writes at byte offset in the buffer; verified with Python 3.14.3"]
    - [pack_into_doc_has_writable, struct.pack_into.__doc__.__contains__, ["writable"], true, "struct.pack_into.__doc__ contains 'writable'; buffer must be a writable buffer; verified with Python 3.14.3"]
    - [pack_into_doc_has_required, struct.pack_into.__doc__.__contains__, ["required"], true, "struct.pack_into.__doc__ contains 'required'; doc notes offset is a required argument; verified with Python 3.14.3"]
    - [pack_into_doc_has_packed,   struct.pack_into.__doc__.__contains__, ["packed"],   true, "struct.pack_into.__doc__ contains 'packed'; writes the packed bytes into the buffer; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct_extra209
# ---------------------------------------------------------------------------

invariant struct_extra209.pack_doc_contains_string:
  description: "struct.pack.__doc__.__contains__('string') returns True — struct.pack's docstring reads 'pack(format, v1, v2, ...) -> bytes — Return a bytes object containing the values v1, v2, ... packed according to the format string. See help(struct) for more on format strings'; the word 'string' appears twice as part of 'format string'; the format string is the first argument to struct.pack and controls the binary layout; it consists of characters like '>' (big-endian), 'H' (unsigned short), 'I' (unsigned int); 'string' is used in preference to 'str' in C-extension docstrings; NEW in struct_extra209: first standalone pack.__doc__.__contains__('string') invariant in structdoc209 namespace; wave 209; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack.__doc__.__contains__
  args: ["string"]
  expected: true

invariant struct_extra209.unpack_doc_contains_calcsize:
  description: "struct.unpack.__doc__.__contains__('calcsize') returns True — struct.unpack's docstring reads 'Return a tuple containing values unpacked according to the format string. The buffer's size in bytes must be calcsize(format). See help(struct) for more on format strings'; the word 'calcsize' appears as the function name in the constraint 'the buffer's size in bytes must be calcsize(format)'; this cross-reference to calcsize tells users how to determine the required buffer size before unpacking; struct.unpack will raise struct.error if the buffer size does not match calcsize(format); NEW in struct_extra209: first standalone unpack.__doc__.__contains__('calcsize') invariant; wave 209; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.unpack.__doc__.__contains__
  args: ["calcsize"]
  expected: true

invariant struct_extra209.Struct_doc_contains_fmt:
  description: "struct.Struct.__doc__.__contains__('fmt') returns True — struct.Struct's docstring reads 'Struct(fmt) --> compiled struct object'; 'fmt' is the abbreviated parameter name for the format string in the Struct constructor's signature header; the use of 'fmt' (rather than 'format') in the signature is consistent with Python's convention of using abbreviated parameter names in low-level C-extension signatures; struct.Struct(fmt) pre-compiles the format string for repeated use; this is more efficient than struct.pack/unpack which recompile the format on every call; NEW in struct_extra209: first standalone Struct.__doc__.__contains__('fmt') invariant; wave 209; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__doc__.__contains__
  args: ["fmt"]
  expected: true

invariant struct_extra209.pack_into_doc_contains_writable:
  description: "struct.pack_into.__doc__.__contains__('writable') returns True — struct.pack_into's docstring reads 'Pack the values v1, v2, ... according to the format string and write the packed bytes into the writable buffer buf starting at offset'; the word 'writable' constrains the buffer argument: it must be a writable (mutable) bytes-like object such as bytearray or a writable memoryview; bytes objects are not writable and cannot be used; the distinction between writable and read-only buffers is critical for struct.pack_into; compare: struct.unpack takes a read-only buffer; NEW in struct_extra209: first standalone pack_into.__doc__.__contains__('writable') invariant; wave 209; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack_into.__doc__.__contains__
  args: ["writable"]
  expected: true
