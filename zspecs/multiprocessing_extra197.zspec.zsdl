spec: multiprocessing_extra197
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: multiprocessing module-level attributes — __name__, __package__, __spec__.name, __file__.__class__.__name__, and __name__.__len__() for Process, AuthenticationError, ProcessError, TimeoutError."
    - "multiprocessing.__name__ == 'multiprocessing' — the module is registered under 'multiprocessing'. Verified with Python 3.14.3."
    - "multiprocessing.__package__ == 'multiprocessing' — multiprocessing is a package; __package__ equals 'multiprocessing'. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.name == 'multiprocessing' — the ModuleSpec name matches the import name. Verified with Python 3.14.3."
    - "multiprocessing.__file__.__class__.__name__ == 'str' — __file__ is a plain Python str path to __init__.py. Verified with Python 3.14.3."
    - "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has 7 characters. Verified with Python 3.14.3."
    - "multiprocessing.AuthenticationError.__name__.__len__() == 19 — 'AuthenticationError' has 19 characters. Verified with Python 3.14.3."
    - "multiprocessing.ProcessError.__name__.__len__() == 12 — 'ProcessError' has 12 characters. Verified with Python 3.14.3."
    - "multiprocessing.TimeoutError.__name__.__len__() == 12 — 'TimeoutError' has 12 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing module identity — __name__, __package__, __spec__.name
#
# multiprocessing.__name__.__eq__('multiprocessing') == True
# multiprocessing.__package__.__eq__('multiprocessing') == True
# multiprocessing.__spec__.name.__eq__('multiprocessing') == True
#
# multiprocessing is a standard-library package. Its __name__, __package__,
# and __spec__.name are all 'multiprocessing'. New to extra197.
# ---------------------------------------------------------------------------

table multiprocessing_extra197.module_identity:
  description: "multiprocessing __name__, __package__, __spec__.name all equal 'multiprocessing'; stdlib package; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: mpmodule197

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_multiprocessing,
       __name__.__eq__,
       ["multiprocessing"],
       true,
       "multiprocessing.__name__.__eq__('multiprocessing') == True — the module is registered under 'multiprocessing'; str.__eq__('multiprocessing') returns True; new to extra197"]
    - [module_package_eq_multiprocessing,
       __package__.__eq__,
       ["multiprocessing"],
       true,
       "multiprocessing.__package__.__eq__('multiprocessing') == True — multiprocessing is a package; __package__ equals 'multiprocessing'; str.__eq__('multiprocessing') returns True; new to extra197"]
    - [module_spec_name_eq_multiprocessing,
       __spec__.name.__eq__,
       ["multiprocessing"],
       true,
       "multiprocessing.__spec__.name.__eq__('multiprocessing') == True — the ModuleSpec name matches the import name 'multiprocessing'; str.__eq__('multiprocessing') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.__file__ class and Process name length
#
# multiprocessing.__file__.__class__.__name__.__eq__('str') == True
# multiprocessing.Process.__name__.__len__() == 7
# multiprocessing.AuthenticationError.__name__.__len__() == 19
#
# __file__ is a plain str. Process is the primary public class. New to extra197.
# ---------------------------------------------------------------------------

table multiprocessing_extra197.file_class_and_process_lens:
  description: "multiprocessing __file__.__class__.__name__=='str'; Process len==7; AuthenticationError len==19; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: mpmodule197

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_name_eq_str,
       "__file__.__class__.__name__.__eq__",
       ["str"],
       true,
       "multiprocessing.__file__.__class__.__name__.__eq__('str') == True — __file__ holds the path to multiprocessing/__init__.py as a plain Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra197"]
    - [process_name_len_eq_7,
       "Process.__name__.__len__",
       [],
       7,
       "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has 7 characters; int.__eq__(7) is True; new to extra197"]
    - [authentication_error_name_len_eq_19,
       "AuthenticationError.__name__.__len__",
       [],
       19,
       "multiprocessing.AuthenticationError.__name__.__len__() == 19 — 'AuthenticationError' has 19 characters; int.__eq__(19) is True; new to extra197"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.ProcessError and TimeoutError name lengths
#
# multiprocessing.ProcessError.__name__.__len__() == 12
# multiprocessing.TimeoutError.__name__.__len__() == 12
#
# ProcessError and TimeoutError are exception classes in multiprocessing.
# Both happen to have 12-character names. New to extra197.
# ---------------------------------------------------------------------------

table multiprocessing_extra197.error_class_name_lens:
  description: "multiprocessing ProcessError len==12; TimeoutError len==12; both exception classes have 12-character names; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: mpmodule197

  columns: [id, function, args, expected, description]
  rows:
    - [process_error_name_len_eq_12,
       "ProcessError.__name__.__len__",
       [],
       12,
       "multiprocessing.ProcessError.__name__.__len__() == 12 — 'ProcessError' has 12 characters; int.__eq__(12) is True; new to extra197"]
    - [timeout_error_name_len_eq_12,
       "TimeoutError.__name__.__len__",
       [],
       12,
       "multiprocessing.TimeoutError.__name__.__len__() == 12 — 'TimeoutError' has 12 characters; int.__eq__(12) is True; new to extra197"]

