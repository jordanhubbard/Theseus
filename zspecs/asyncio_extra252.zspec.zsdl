spec: asyncio_extra252
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop handles documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c (C-level Task/Future implementation)"
    - "CPython source: Lib/asyncio/events.py (Handle/TimerHandle implementation)"
  notes:
    - "asyncio.Task.__name__ == 'Task' (len=4); __module__ == '_asyncio' (len=8, C extension)."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' (len=6) — Task inherits from Future."
    - "asyncio.Future.__name__ == 'Future' (len=6); __module__ == '_asyncio' (len=8, C extension)."
    - "asyncio.Future.__bases__[0].__name__ == 'object' (len=6) — Future inherits directly from object."
    - "asyncio.Handle.__name__ == 'Handle' (len=6); __module__ == 'asyncio.events' (len=14)."
    - "asyncio.Handle.__bases__[0].__name__ == 'object' (len=6) — Handle inherits directly from object."
    - "asyncio.TimerHandle.__name__ == 'TimerHandle' (len=11); __module__ == 'asyncio.events' (len=14)."
    - "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle' (len=6) — TimerHandle inherits from Handle."
    - "Task and Future are C-extension types from _asyncio; Handle and TimerHandle are pure Python from asyncio.events."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task and asyncio.Future class identity
#
# Task.__name__ == 'Task' (len=4)
# Task.__module__ == '_asyncio' (len=8) — C extension, not 'asyncio.tasks'
# Task.__bases__[0].__name__ == 'Future' (len=6)
# Future.__name__ == 'Future' (len=6)
# Future.__module__ == '_asyncio' (len=8)
# Future.__bases__[0].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table asyncio_extra252.task_future_class_identity:
  description: "asyncio Task and Future class identity — Task(len=4) subclasses Future(len=6); Future subclasses object(len=6); both have __module__=='_asyncio'(len=8, C extension not 'asyncio.tasks'); Task.__bases__[0].__name__=='Future' confirms the Task->Future->object inheritance chain; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async252tf

  columns: [id, function, args, expected, description]
  rows:
    - [tf_task_name_eq,    Task.__name__.__eq__,                    ["Task"],     true, "asyncio.Task.__name__ == 'Task'; verified with Python 3.14.3"]
    - [tf_task_name_len,   Task.__name__.__len__,                   [],           4,    "asyncio.Task.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [tf_task_mod_eq,     Task.__module__.__eq__,                  ["_asyncio"], true, "asyncio.Task.__module__ == '_asyncio' (C extension); verified with Python 3.14.3"]
    - [tf_task_mod_len,    Task.__module__.__len__,                  [],           8,    "asyncio.Task.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [tf_task_base_eq,    "Task.__bases__[0].__name__.__eq__",     ["Future"],   true, "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits from Future; verified with Python 3.14.3"]
    - [tf_task_base_len,   "Task.__bases__[0].__name__.__len__",    [],           6,    "asyncio.Task.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [tf_fut_name_eq,     Future.__name__.__eq__,                  ["Future"],   true, "asyncio.Future.__name__ == 'Future'; verified with Python 3.14.3"]
    - [tf_fut_name_len,    Future.__name__.__len__,                 [],           6,    "asyncio.Future.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [tf_fut_mod_eq,      Future.__module__.__eq__,                ["_asyncio"], true, "asyncio.Future.__module__ == '_asyncio' (C extension); verified with Python 3.14.3"]
    - [tf_fut_mod_len,     Future.__module__.__len__,               [],           8,    "asyncio.Future.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [tf_fut_base_eq,     "Future.__bases__[0].__name__.__eq__",   ["object"],   true, "asyncio.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object; verified with Python 3.14.3"]
    - [tf_fut_base_len,    "Future.__bases__[0].__name__.__len__",  [],           6,    "asyncio.Future.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Handle and asyncio.TimerHandle class identity
#
# Handle.__name__ == 'Handle' (len=6)
# Handle.__module__ == 'asyncio.events' (len=14)
# Handle.__bases__[0].__name__ == 'object' (len=6)
# TimerHandle.__name__ == 'TimerHandle' (len=11)
# TimerHandle.__module__ == 'asyncio.events' (len=14)
# TimerHandle.__bases__[0].__name__ == 'Handle' (len=6)
# ---------------------------------------------------------------------------

table asyncio_extra252.handle_timerhandle_class_identity:
  description: "asyncio Handle and TimerHandle class identity — Handle(len=6) subclasses object(len=6); TimerHandle(len=11) subclasses Handle(len=6); both have __module__=='asyncio.events'(len=14, pure Python unlike Task/Future which use '_asyncio'); TimerHandle.__bases__[0].__name__=='Handle' confirms the TimerHandle->Handle->object inheritance chain; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async252hth

  columns: [id, function, args, expected, description]
  rows:
    - [hth_h_name_eq,     Handle.__name__.__eq__,                      ["Handle"],         true, "asyncio.Handle.__name__ == 'Handle'; verified with Python 3.14.3"]
    - [hth_h_name_len,    Handle.__name__.__len__,                     [],                 6,    "asyncio.Handle.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [hth_h_mod_eq,      Handle.__module__.__eq__,                    ["asyncio.events"], true, "asyncio.Handle.__module__ == 'asyncio.events' (pure Python); verified with Python 3.14.3"]
    - [hth_h_mod_len,     Handle.__module__.__len__,                   [],                 14,   "asyncio.Handle.__module__.__len__() == 14; verified with Python 3.14.3"]
    - [hth_h_base_eq,     "Handle.__bases__[0].__name__.__eq__",       ["object"],         true, "asyncio.Handle.__bases__[0].__name__ == 'object' — Handle inherits directly from object; verified with Python 3.14.3"]
    - [hth_h_base_len,    "Handle.__bases__[0].__name__.__len__",      [],                 6,    "asyncio.Handle.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [hth_th_name_eq,    TimerHandle.__name__.__eq__,                 ["TimerHandle"],    true, "asyncio.TimerHandle.__name__ == 'TimerHandle'; verified with Python 3.14.3"]
    - [hth_th_name_len,   TimerHandle.__name__.__len__,                [],                 11,   "asyncio.TimerHandle.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [hth_th_mod_eq,     TimerHandle.__module__.__eq__,               ["asyncio.events"], true, "asyncio.TimerHandle.__module__ == 'asyncio.events'; verified with Python 3.14.3"]
    - [hth_th_mod_len,    TimerHandle.__module__.__len__,              [],                 14,   "asyncio.TimerHandle.__module__.__len__() == 14; verified with Python 3.14.3"]
    - [hth_th_base_eq,    "TimerHandle.__bases__[0].__name__.__eq__",  ["Handle"],         true, "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle' — TimerHandle inherits from Handle; verified with Python 3.14.3"]
    - [hth_th_base_len,   "TimerHandle.__bases__[0].__name__.__len__", [],                 6,    "asyncio.TimerHandle.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra252
# ---------------------------------------------------------------------------

invariant asyncio_extra252.task_inherits_future:
  description: "asyncio.Task.__bases__[0].__name__.__eq__('Future') returns True — Task inherits from Future (not directly from object); this contrasts with Future.__bases__[0].__name__=='object' and Handle.__bases__[0].__name__=='object'; Task.__name__=='Task'(len=4); Task.__module__=='_asyncio'(len=8, C extension); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra252.timerhandle_inherits_handle:
  description: "asyncio.TimerHandle.__bases__[0].__name__.__eq__('Handle') returns True — TimerHandle inherits from Handle (not directly from object); this contrasts with Handle.__bases__[0].__name__=='object'; TimerHandle.__module__=='asyncio.events'(len=14) same as Handle, both pure Python unlike Task/Future which use '_asyncio'(len=8); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "TimerHandle.__bases__[0].__name__.__eq__"
  args: ["Handle"]
  expected: true
