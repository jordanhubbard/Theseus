spec: copy_extra17
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra16.zspec.zsdl — covers __qualname__/__module__ table for copy/deepcopy/Error in extra16 namespace."
    - "copy_extra15.zspec.zsdl — covers module __name__/__package__ and copy.error.__qualname__ alias."
    - "copy_extra6.zspec.zsdl — covers Error.__bases__[0].__name__ and Error.__class__.__name__ in extra6 namespace."
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra16.zspec.zsdl."
    - "Focus: copy.__spec__.__class__.__name__; __qualname__.__len__() for copy/deepcopy/Error; copy.__name__ re-anchored in extra17 namespace."
    - "copy.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance from importlib. Verified Python 3.12 macOS."
    - "copy.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec') == 10. Verified."
    - "copy.copy.__qualname__.__len__() == 4 — len('copy') == 4. Verified."
    - "copy.deepcopy.__qualname__.__len__() == 8 — len('deepcopy') == 8. Verified."
    - "copy.Error.__qualname__.__len__() == 5 — len('Error') == 5. Verified."
    - "copy.__name__ == 'copy' confirmed; copy_extra15 covers it — re-anchored here in extra17 namespace standalone."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.__spec__.__class__.__name__ — module spec type identity
#
# No prior copy spec checks copy.__spec__. The module's __spec__ is a
# ModuleSpec object from importlib.machinery. Its __class__.__name__ is
# 'ModuleSpec'. Under python_module(copy), the function chain
# __spec__.__class__.__name__.__eq__ accesses the attribute chain on the
# copy module object.
# ---------------------------------------------------------------------------

invariant copy_extra17.spec.class_name:
  description: "copy.__spec__.__class__.__name__ == 'ModuleSpec' — module spec is a ModuleSpec instance"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# copy.__name__ — module name, extra17 namespace standalone
#
# copy_extra15 covers copy.__name__ == 'copy' as a standalone invariant.
# Re-anchored here in the extra17 namespace as an independent invariant.
# Under python_module(copy), function: __name__.__eq__ accesses the
# module-level __name__ attribute.
# ---------------------------------------------------------------------------

invariant copy_extra17.module.name:
  description: "copy.__name__ == 'copy' — module self-identifies with its own name (extra17 anchor)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__.__len__() for copy.copy, copy.deepcopy, and copy.Error
#
# copy_extra16 covers __qualname__.__eq__ for these three. No prior copy spec
# checks the length of their __qualname__ strings. For top-level functions and
# classes, __qualname__ equals the simple name, so these lengths equal the
# __name__ lengths: len('copy')==4, len('deepcopy')==8, len('Error')==5.
# id_prefix cpqlen17 does not conflict with any prior copy spec.
# ---------------------------------------------------------------------------

table copy_extra17.qualname_lengths:
  description: "__qualname__.__len__() for copy.copy, copy.deepcopy, and copy.Error"
  kind: python_call_eq
  category: function_qualname
  id_prefix: cpqlen17

  columns: [id, function, args, expected]
  rows:
    - [copy_qualname_len,    copy.__qualname__.__len__,    [], 4]
    - [deepcopy_qualname_len, deepcopy.__qualname__.__len__, [], 8]
    - [Error_qualname_len,   Error.__qualname__.__len__,   [], 5]

# ---------------------------------------------------------------------------
# copy.__spec__.__class__.__name__.__len__() — spec type name length
#
# Complements the __eq__ invariant above with the length of 'ModuleSpec'.
# len('ModuleSpec') == 10. No prior copy spec covers this path.
# ---------------------------------------------------------------------------

invariant copy_extra17.spec.class_name_len:
  description: "copy.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec') == 10"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10
