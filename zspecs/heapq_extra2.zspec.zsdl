spec: heapq_extra2
version: ">=3.2"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "Python heapq documentation — https://docs.python.org/3/library/heapq.html"
    - "Test vectors verified by running Python 3.14.3 heapq module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
    - "heapq.zspec.zsdl — covers heappush/heappop heap correctness, heapify, nlargest(3)/nsmallest(3)"
    - "heapq_extra.zspec.zsdl — covers __name__ checks for heappush/heappop/heapify/heapreplace/heappushpop/merge/nlargest/nsmallest; __module__ checks; nlargest(3)/nsmallest(3) result ordering"
  notes:
    - "This spec adds function-name identity checks and two-element nlargest/nsmallest results not present in heapq_extra.zspec.zsdl."
    - "nsmallest(2, [5,1,3,2,4]) == [1,2] — two smallest elements in ascending order."
    - "nlargest(2, [5,1,3,2,4]) == [5,4] — two largest elements in descending order."
    - "All expected values verified by running Python 3.14.3 heapq module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name identity — orthogonal coverage of __name__ checks
# (heapq_extra uses heapq_extra.<fn>.name IDs; here we use heapq_extra2.<fn>.fname)
# ---------------------------------------------------------------------------

table heapq_extra2.function_names:
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__name__.__eq__,    ["heappush"],    true]
    - [heappop,     heappop.__name__.__eq__,     ["heappop"],     true]
    - [heapify,     heapify.__name__.__eq__,     ["heapify"],     true]
    - [heapreplace, heapreplace.__name__.__eq__, ["heapreplace"], true]
    - [nlargest,    nlargest.__name__.__eq__,    ["nlargest"],    true]
    - [nsmallest,   nsmallest.__name__.__eq__,   ["nsmallest"],   true]

# ---------------------------------------------------------------------------
# Behavioral invariants — nsmallest and nlargest with n=2
# ---------------------------------------------------------------------------

invariant heapq_extra2.nsmallest.top2:
  description: "heapq.nsmallest(2, [5,1,3,2,4]) == [1, 2] — two smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [2, [5, 1, 3, 2, 4]]
  expected: [1, 2]

invariant heapq_extra2.nlargest.top2:
  description: "heapq.nlargest(2, [5,1,3,2,4]) == [5, 4] — two largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [2, [5, 1, 3, 2, 4]]
  expected: [5, 4]
