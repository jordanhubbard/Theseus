    - [close_qualname_socket_close,   "socket.close.__qualname__.__eq__",   ["socket.close"],   true, "socket.socket.close.__qualname__ == 'socket.close' (12 chars = 'socket.'=7 + 'close'=5; Python 'function' override; performs Python-level cleanup)"]

# ---------------------------------------------------------------------------
# socket.socket method qualname length ordering
#
# Wave 342 theme: qualname lengths for bind/listen/accept/close methods.
#
# socket.bind.__qualname__.__len__() == 11.
# socket.close.__qualname__.__len__() == 12.
