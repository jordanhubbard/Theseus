    - [close_qualname_len_12,   "socket.close.__qualname__.__len__",   [], 12, "socket.socket.close.__qualname__.__len__() is 12 ('socket.close' = 'socket.'=7 + 'close'=5; between bind(11) and listen(13))"]
    - [listen_qualname_len_13,  "socket.listen.__qualname__.__len__",  [], 13, "socket.socket.listen.__qualname__.__len__() is 13 ('socket.listen' = 'socket.'=7 + 'listen'=6; ties accept at 13)"]
    - [accept_qualname_len_13,  "socket.accept.__qualname__.__len__",  [], 13, "socket.socket.accept.__qualname__.__len__() is 13 ('socket.accept' = 'socket.'=7 + 'accept'=6; ties listen despite being 'function' not 'method_descriptor')"]

# ---------------------------------------------------------------------------
# socket.socket method types: bind and listen are method_descriptor, accept and close are function
#
# Wave 342 theme: method type contrast between inherited C methods and Python overrides.
#
# socket.bind.__class__.__name__ == 'method_descriptor' (inherited from _socket.socket).
# socket.listen.__class__.__name__ == 'method_descriptor' (inherited from _socket.socket).
# socket.accept.__class__.__name__ == 'function' (Python override in Lib/socket.py).
# socket.close.__class__.__name__ == 'function' (Python override in Lib/socket.py).
# No prior socket spec anchors bind/listen/accept/close __class__.__name__ as a table
# under socknet160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra160.socket_networking_method_types:
  description: "socket.socket.bind.__class__.__name__.__eq__('method_descriptor')==True / socket.listen.__class__.__name__.__eq__('method_descriptor')==True / socket.accept.__class__.__name__.__eq__('function')==True / socket.close.__class__.__name__.__eq__('function')==True — bind.__class__.__name__ is 'method_descriptor' (17 chars; inherited from _socket.socket C class; same type as connect from extra159); listen.__class__.__name__ is 'method_descriptor' (17 chars; inherited from _socket.socket; same type as bind); accept.__class__.__name__ is 'function' (8 chars; pure Python override in Lib/socket.py; overrides C _socket.socket.accept to return socket.socket wrapper instead of _socket.socket); close.__class__.__name__ is 'function' (8 chars; pure Python override; performs Python-level cleanup before calling C-level close); type contrast: method_descriptor(bind/listen) vs function(accept/close); first socknet160 anchor for these four method types"
  kind: python_call_eq
  category: identity
  id_prefix: socknet160

  columns: [id, function, args, expected, description]
  rows:
    - [bind_class_method_desc,    "socket.bind.__class__.__name__.__eq__",    ["method_descriptor"], true, "socket.socket.bind.__class__.__name__ == 'method_descriptor' (17 chars; inherited from _socket.socket; same type as connect)"]
    - [listen_class_method_desc,  "socket.listen.__class__.__name__.__eq__",  ["method_descriptor"], true, "socket.socket.listen.__class__.__name__ == 'method_descriptor' (17 chars; inherited from _socket.socket; same type as bind)"]
    - [accept_class_function,     "socket.accept.__class__.__name__.__eq__",  ["function"],          true, "socket.socket.accept.__class__.__name__ == 'function' (8 chars; Python override; returns socket.socket wrapper instead of _socket.socket)"]
    - [close_class_function,      "socket.close.__class__.__name__.__eq__",   ["function"],          true, "socket.socket.close.__class__.__name__ == 'function' (8 chars; Python override; performs cleanup; same type as accept and __init__)"]

# ---------------------------------------------------------------------------
# socket.socket.bind.__qualname__.__eq__('socket.bind') — standalone
#
# socket.socket.bind.__qualname__ is 'socket.bind' (11 chars = 'socket.'=7 + 'bind'=4).
# socket.socket.bind is a method_descriptor inherited from the C base class _socket.socket.
# bind(address) binds the socket to a local address. For AF_INET sockets, address is a
# (host, port) tuple. For AF_UNIX sockets, address is a filesystem path string. Binding
# is required before a server socket can call listen() and accept(). 'bind' (4 chars) is
# the shortest method name in this spec, giving 'socket.bind' (11 chars) the shortest
# qualname. Length ordering: bind(11) < close(12) < listen==accept(13) < connect(14).
# extra159 anchors connect.__qualname__=='socket.connect' (14 chars); no prior socket spec
# anchors socket.bind.__qualname__ as a standalone under socknet160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra160.sock_bind_qualname_eq:
  description: "socket.socket.bind.__qualname__.__eq__('socket.bind') == True — 11 chars = 'socket.'=7 + 'bind'=4; method_descriptor inherited from _socket.socket (same type as connect from extra159); bind(address) binds to local address; for AF_INET: address is (host, port) tuple; server setup: bind() then listen() then accept(); 'bind'=4 chars (shortest method name in this spec); qualname length ordering: bind(11) < close(12) < listen==accept(13) < connect(14; extra159); extra159 anchors connect qualname; no prior socket spec anchors bind qualname as a standalone; first standalone under socknet160"
  category: identity
  kind: python_call_eq
  function: socket.bind.__qualname__.__eq__
  args: ["socket.bind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.listen.__qualname__.__eq__('socket.listen') — standalone
#
# socket.socket.listen.__qualname__ is 'socket.listen' (13 chars = 'socket.'=7 + 'listen'=6).
# socket.socket.listen is a method_descriptor inherited from _socket.socket. listen(backlog)
# marks the socket as a passive socket that will accept incoming connections. The backlog
# parameter specifies the maximum length of the queue of pending connections. After calling
# listen(), the socket can call accept() to accept connections. 'listen' (6 chars) gives
# 'socket.listen' (13 chars), which ties 'socket.accept' (13 chars) despite accept being
# a pure Python 'function' while listen is a 'method_descriptor'. No prior socket spec
# anchors socket.listen.__qualname__ as a standalone under socknet160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra160.sock_listen_qualname_eq:
  description: "socket.socket.listen.__qualname__.__eq__('socket.listen') == True — 13 chars = 'socket.'=7 + 'listen'=6; method_descriptor inherited from _socket.socket; listen(backlog) marks socket as passive accepting incoming connections; backlog specifies max queue length; server flow: bind() -> listen() -> accept(); 'listen'=6 chars (ties 'accept'=6; both give 13-char qualnames); listen is method_descriptor while accept is 'function' (different types, same qualname length); no prior socket spec anchors this as a standalone; first standalone under socknet160"
  category: identity
  kind: python_call_eq
  function: socket.listen.__qualname__.__eq__
  args: ["socket.listen"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept') — standalone
#
# socket.socket.accept.__qualname__ is 'socket.accept' (13 chars = 'socket.'=7 + 'accept'=6).
# socket.socket.accept is a pure Python function (not a method_descriptor). The Python
# socket.socket class overrides the inherited _socket.socket.accept method to return a
# socket.socket instance (the Python wrapper) instead of a raw _socket.socket object.
# This ensures that accepted connections are wrapped in the Python socket.socket class
# with all its Python-level methods (makefile, setblocking, etc.). accept().__class__.__name__
# == 'function' (8 chars; same type as socket.__init__). 'accept' (6 chars) ties 'listen' (6 chars).
# No prior socket spec anchors socket.accept.__qualname__ as a standalone under socknet160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra160.sock_accept_qualname_eq:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — 13 chars = 'socket.'=7 + 'accept'=6; pure Python 'function' override in Lib/socket.py; overrides _socket.socket.accept to return socket.socket wrapper (not raw _socket.socket); ensures accepted connections are Python socket objects with full socket.socket API; 'accept'=6 chars (ties 'listen'=6; both give 13-char qualnames); accept is 'function' while listen is 'method_descriptor' (same qualname length, different types); no prior socket spec anchors this as a standalone; first standalone under socknet160"
  category: identity
  kind: python_call_eq
  function: socket.accept.__qualname__.__eq__
  args: ["socket.accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.close.__qualname__.__eq__('socket.close') — standalone
#
# socket.socket.close.__qualname__ is 'socket.close' (12 chars = 'socket.'=7 + 'close'=5).
# socket.socket.close is a pure Python function (not a method_descriptor). The Python
# socket.socket class overrides the inherited _socket.socket.close to perform Python-level
# cleanup (e.g., closing the file-descriptor-like object) before delegating to the C-level
# close. close.__class__.__name__ == 'function' (8 chars; same type as accept and __init__).
# 'close' (5 chars) gives 'socket.close' (12 chars), which falls between 'socket.bind'
# (11 chars) and 'socket.listen'/'socket.accept' (13 chars each). Length ordering:
# bind(11) < close(12) < listen==accept(13) < connect(14; extra159) < __init__(15; extra159).
# No prior socket spec anchors socket.close.__qualname__ as a standalone under socknet160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra160.sock_close_qualname_eq:
  description: "socket.socket.close.__qualname__.__eq__('socket.close') == True — 12 chars = 'socket.'=7 + 'close'=5; pure Python 'function' override in Lib/socket.py; performs Python-level cleanup before C-level close; close.__class__.__name__=='function' (8 chars; same type as accept and __init__); 'close'=5 chars (between 'bind'=4 and 'listen'/'accept'=6); qualname length ordering: bind(11) < close(12) < listen==accept(13) < connect(14; extra159) < __init__(15; extra159); no prior socket spec anchors this as a standalone; first standalone under socknet160"
  category: identity
  kind: python_call_eq
  function: socket.close.__qualname__.__eq__
  args: ["socket.close"]
  expected: true

