spec: multiprocessing_extra2266
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.queues.Queue has __getstate__ and __setstate__; multiprocessing.pool.Pool has __reduce__."
  created_at: "2026-04-12"

table multiprocessing_extra2266.process_pickle:
  description: "multiprocessing.Process pickle/copy protocol dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2266
  columns: [id, function, args, expected]
  rows:
    - ["mp2266001", "multiprocessing.Process.__dict__.__contains__", ["__reduce__"], false]
    - ["mp2266002", "multiprocessing.Process.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["mp2266003", "multiprocessing.Process.__dict__.__contains__", ["__getstate__"], false]
    - ["mp2266004", "multiprocessing.Process.__dict__.__contains__", ["__setstate__"], false]
    - ["mp2266005", "multiprocessing.Process.__dict__.__contains__", ["__getnewargs__"], false]
    - ["mp2266006", "multiprocessing.Process.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["mp2266007", "multiprocessing.Process.__dict__.__contains__", ["__copy__"], false]
    - ["mp2266008", "multiprocessing.Process.__dict__.__contains__", ["__deepcopy__"], false]

