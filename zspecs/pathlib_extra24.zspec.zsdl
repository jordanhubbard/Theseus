spec: pathlib_extra24
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra23.zspec.zsdl — covers Path/PurePath/PosixPath/PurePosixPath/PureWindowsPath __name__ table; Path('/tmp').__class__.__name__; Path('/tmp').name; Path('/tmp/foo').parent.__str__()"
  notes:
    - "This spec extends pathlib.zspec.zsdl and all prior pathlib_extra specs through pathlib_extra23.zspec.zsdl."
    - "pathlib.Path('/a/b/c').parts == ('/', 'a', 'b', 'c') — tuple of path components; no prior spec covers parts with this exact argument in extra24 namespace."
    - "pathlib.Path('/a/b/c').stem == 'c' — final component without suffix; no prior spec covers stem with '/a/b/c' in extra24 namespace."
    - "pathlib.Path('/a/b/c.txt').suffix == '.txt' — last suffix including leading dot; no prior spec covers suffix with '/a/b/c.txt' in extra24 namespace."
    - "pathlib.Path('/a/b/c.tar.gz').suffixes == ['.tar', '.gz'] — all suffixes as a list; no prior spec covers suffixes with a multi-suffix path in extra24 namespace."
    - "pathlib.Path('/a/b').joinpath('c', 'd').__str__() == '/a/b/c/d' — join produces correct posix path string; no prior spec covers joinpath with two positional args in extra24 namespace."
    - "pathlib.PurePosixPath('/a/b').root == '/' — root attribute on a PurePosixPath; no prior spec covers root with '/a/b' in extra24 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path('/a/b/c').parts == ('/', 'a', 'b', 'c')
#
# The .parts property decomposes a path into a tuple of its components.
# For an absolute path the first element is the root '/'. Verified at runtime:
# pathlib.Path('/a/b/c').parts == ('/', 'a', 'b', 'c').
# No prior pathlib spec covers parts with this exact argument.
# ---------------------------------------------------------------------------

invariant pathlib_extra24.Path.abc_parts:
  description: "pathlib.Path('/a/b/c').parts == ('/', 'a', 'b', 'c') — parts decomposes absolute path into tuple"
  category: path_parts
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: parts.__eq__
  method_args: [["/" , "a", "b", "c"]]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path('/a/b/c').stem == 'c'
#
# The .stem property is the final path component without its suffix.
# For Path('/a/b/c'), there is no suffix so stem == 'c'. Verified at runtime.
# No prior pathlib spec covers stem with '/a/b/c' in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant pathlib_extra24.Path.abc_stem:
  description: "pathlib.Path('/a/b/c').stem == 'c' — stem of suffix-free path is the final component"
  category: path_parts
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: stem.__eq__
  method_args: ["c"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path('/a/b/c.txt').suffix == '.txt'
#
# The .suffix property returns the file extension including the leading dot.
# For Path('/a/b/c.txt'), suffix == '.txt'. Verified at runtime.
# No prior pathlib spec covers suffix with '/a/b/c.txt' in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant pathlib_extra24.Path.txt_suffix:
  description: "pathlib.Path('/a/b/c.txt').suffix == '.txt' — suffix includes leading dot"
  category: path_parts
  kind: python_call_eq
  function: Path
  args: ["/a/b/c.txt"]
  method: suffix.__eq__
  method_args: [".txt"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path('/a/b/c.tar.gz').suffixes == ['.tar', '.gz']
#
# The .suffixes property returns a list of all extensions. For a path ending
# in '.tar.gz', both suffixes are returned in order. Verified at runtime:
# suffixes == ['.tar', '.gz']. No prior pathlib spec covers suffixes with a
# multi-suffix path in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant pathlib_extra24.Path.targz_suffixes:
  description: "pathlib.Path('/a/b/c.tar.gz').suffixes == ['.tar', '.gz'] — all extensions returned as list"
  category: path_parts
  kind: python_call_eq
  function: Path
  args: ["/a/b/c.tar.gz"]
  method: suffixes.__eq__
  method_args: [[".tar", ".gz"]]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path('/a/b').joinpath('c', 'd').__str__() == '/a/b/c/d'
#
# joinpath accepts multiple positional arguments and appends each as a path
# segment. The result stringifies to the expected POSIX string. Verified at
# runtime. No prior pathlib spec covers joinpath with two args in extra24.
# ---------------------------------------------------------------------------

invariant pathlib_extra24.Path.joinpath_two_args:
  description: "pathlib.Path('/a/b').joinpath('c', 'd').__str__() == '/a/b/c/d' — joinpath with multiple segments"
  category: path_construction
  kind: python_call_eq
  function: Path
  args: ["/a/b"]
  method: joinpath.__str__
  method_args: ["c", "d"]
  expected: "/a/b/c/d"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath('/a/b').root == '/'
#
# The .root attribute of an absolute PurePosixPath is always '/'.
# Verified at runtime: PurePosixPath('/a/b').root == '/'.
# No prior pathlib spec covers root with PurePosixPath('/a/b') in extra24.
# ---------------------------------------------------------------------------

invariant pathlib_extra24.PurePosixPath.ab_root:
  description: "pathlib.PurePosixPath('/a/b').root == '/' — root of absolute PurePosixPath is forward slash"
  category: path_parts
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: root.__eq__
  method_args: ["/"]
  expected: true
