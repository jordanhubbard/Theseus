spec: inspect_extra146
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers (Python function) — co_argcount 2, co_varnames len 2, __qualname__ 'getmembers' len 10; inspect.getfile (Python function) — co_argcount 1, co_varnames len 2, __qualname__ 'getfile' len 7; inspect.getsource (Python function) — co_argcount 1, co_varnames len 3, __qualname__ 'getsource' len 9; inspect.getsourcelines (Python function) — co_argcount 1, co_varnames len 3, __qualname__ 'getsourcelines' len 14, __doc__ len 399; inspect.getmodule (Python function) — co_argcount 2, co_varnames len 10, __qualname__ 'getmodule' len 9, __doc__ len 65; inspect.isfunction (Python function) — co_argcount 1, co_varnames len 1, __qualname__ 'isfunction' len 10, __doc__ len 817; inspect.isclass (Python function) — co_argcount 1, co_varnames len 1, __qualname__ 'isclass' len 7 (Wave 274)."
    - "inspect.getmembers: co_argcount == 2 (object, predicate); co_varnames len == 2; __qualname__ == 'getmembers' (len 10). Verified with Python 3.14.3."
    - "inspect.getfile: co_argcount == 1; co_varnames len == 2; __qualname__ == 'getfile' (len 7). Verified with Python 3.14.3."
    - "inspect.getsource: co_argcount == 1; co_varnames len == 3; __qualname__ == 'getsource' (len 9). Verified with Python 3.14.3."
    - "inspect.getsourcelines: co_argcount == 1; co_varnames len == 3; __qualname__ == 'getsourcelines' (len 14); __doc__ len == 399. Verified with Python 3.14.3."
    - "inspect.getmodule: co_argcount == 2; co_varnames len == 10; __qualname__ == 'getmodule' (len 9); __doc__ len == 65. Verified with Python 3.14.3."
    - "inspect.isfunction: co_argcount == 1; co_varnames len == 1; __qualname__ == 'isfunction' (len 10); __doc__ len == 817. Verified with Python 3.14.3."
    - "inspect.isclass: co_argcount == 1; co_varnames len == 1; __qualname__ == 'isclass' (len 7); __doc__ len == 37. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers and inspect.getfile — code object attributes
#
# Wave 274 theme: inspect introspection function code-level attributes.
#
# inspect.getmembers.__code__.co_argcount == 2
# len(inspect.getmembers.__code__.co_varnames) == 2
# inspect.getmembers.__qualname__ == 'getmembers' (len 10)
# inspect.getfile.__code__.co_argcount == 1
# len(inspect.getfile.__code__.co_varnames) == 2
# inspect.getfile.__qualname__ == 'getfile' (len 7)
#
# getmembers(object, predicate=None) returns all members of object as (name, value)
# pairs; getfile(object) returns the file in which object was defined.
# New to extra146.
# ---------------------------------------------------------------------------

table inspect_extra146.getmembers_getfile_code_attrs:
  description: "inspect.getmembers (co_argcount 2, co_varnames len 2, qualname len 10) and getfile (co_argcount 1, co_varnames len 2, qualname len 7); code object attributes; wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetmembersfile146

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_qualname_eq,
       "getmembers.__qualname__.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — getmembers is a Python function in Lib/inspect.py; its __qualname__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra146"]
    - [getmembers_qualname_len_eq_10,
       "getmembers.__qualname__.__len__",
       [],
       10,
       "inspect.getmembers.__qualname__.__len__() == 10 — __qualname__ is 'getmembers' which has 10 characters; len('getmembers') == 10; new to extra146"]
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers takes 2 positional-or-keyword arguments: object and predicate; co_argcount is 2; int.__eq__(2) returns True; new to extra146"]
    - [getmembers_co_varnames_len_eq_2,
       "getmembers.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getmembers.__code__.co_varnames.__len__() == 2 — co_varnames has 2 entries: object and predicate; len() == 2; verified with Python 3.14.3; new to extra146"]
    - [getfile_qualname_len_eq_7,
       "getfile.__qualname__.__len__",
       [],
       7,
       "inspect.getfile.__qualname__.__len__() == 7 — __qualname__ is 'getfile' which has 7 characters; len('getfile') == 7; new to extra146"]
    - [getfile_co_argcount_eq_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra146"]
    - [getfile_co_varnames_len_eq_2,
       "getfile.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getfile.__code__.co_varnames.__len__() == 2 — co_varnames has 2 entries: object and module; len() == 2; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsource and inspect.getsourcelines — code object attributes
#
# Wave 274 theme: inspect source retrieval functions code-level attributes.
#
# inspect.getsource.__code__.co_argcount == 1
# len(inspect.getsource.__code__.co_varnames) == 3
# inspect.getsource.__qualname__ == 'getsource' (len 9)
# inspect.getsourcelines.__code__.co_argcount == 1
# len(inspect.getsourcelines.__code__.co_varnames) == 3
# inspect.getsourcelines.__qualname__ == 'getsourcelines' (len 14)
# len(inspect.getsourcelines.__doc__) == 399
#
# getsource(object) returns the text of the source code for an object;
# getsourcelines(object) returns the source code as a list of lines with
# the starting line number. New to extra146.
# ---------------------------------------------------------------------------

table inspect_extra146.getsource_getsourcelines_code_attrs:
  description: "inspect.getsource (co_argcount 1, co_varnames len 3, qualname len 9) and getsourcelines (co_argcount 1, co_varnames len 3, qualname len 14, doc len 399); wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetsrc146

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_qualname_eq,
       "getsource.__qualname__.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__qualname__.__eq__('getsource') == True — getsource is a Python function in Lib/inspect.py; its __qualname__ is 'getsource'; str.__eq__('getsource') returns True; new to extra146"]
    - [getsource_qualname_len_eq_9,
       "getsource.__qualname__.__len__",
       [],
       9,
       "inspect.getsource.__qualname__.__len__() == 9 — __qualname__ is 'getsource' which has 9 characters; len('getsource') == 9; new to extra146"]
    - [getsource_co_argcount_eq_1,
       "getsource.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra146"]
    - [getsource_co_varnames_len_eq_3,
       "getsource.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.getsource.__code__.co_varnames.__len__() == 3 — co_varnames has 3 entries: object, lines, lnum; len() == 3; verified with Python 3.14.3; new to extra146"]
    - [getsourcelines_qualname_len_eq_14,
       "getsourcelines.__qualname__.__len__",
       [],
       14,
       "inspect.getsourcelines.__qualname__.__len__() == 14 — __qualname__ is 'getsourcelines' which has 14 characters; len('getsourcelines') == 14; new to extra146"]
    - [getsourcelines_co_argcount_eq_1,
       "getsourcelines.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcelines.__code__.co_argcount.__eq__(1) == True — getsourcelines takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra146"]
    - [getsourcelines_co_varnames_len_eq_3,
       "getsourcelines.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.getsourcelines.__code__.co_varnames.__len__() == 3 — co_varnames has 3 entries: object, lines, lnum; len() == 3; verified with Python 3.14.3; new to extra146"]
    - [getsourcelines_doc_len_eq_399,
       "getsourcelines.__doc__.__len__",
       [],
       399,
       "inspect.getsourcelines.__doc__.__len__() == 399 — the getsourcelines docstring has 399 characters; getsourcelines returns (list_of_source_lines, starting_lineno); len(__doc__) == 399; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getmodule — code object and doc attributes
#
# Wave 274 theme: inspect.getmodule — retrieves the module containing a Python object.
#
# inspect.getmodule.__code__.co_argcount == 2
# len(inspect.getmodule.__code__.co_varnames) == 10
# inspect.getmodule.__qualname__ == 'getmodule' (len 9)
# len(inspect.getmodule.__doc__) == 65
#
# getmodule(object, _filename=None) tries to determine the module in which
# an object was defined, checking both __module__ attributes and file paths.
# It has many local variables (10 in co_varnames). New to extra146.
# ---------------------------------------------------------------------------

table inspect_extra146.getmodule_code_attrs:
  description: "inspect.getmodule: co_argcount 2, co_varnames len 10, qualname 'getmodule' len 9, __doc__ len 65; wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetmodule146

  columns: [id, function, args, expected, description]
  rows:
    - [getmodule_qualname_eq,
       "getmodule.__qualname__.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__qualname__.__eq__('getmodule') == True — getmodule is a Python function in Lib/inspect.py; its __qualname__ is 'getmodule'; str.__eq__('getmodule') returns True; new to extra146"]
    - [getmodule_qualname_len_eq_9,
       "getmodule.__qualname__.__len__",
       [],
       9,
       "inspect.getmodule.__qualname__.__len__() == 9 — __qualname__ is 'getmodule' which has 9 characters; len('getmodule') == 9; new to extra146"]
    - [getmodule_co_argcount_eq_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule takes 2 positional-or-keyword arguments: object and _filename; co_argcount is 2; int.__eq__(2) returns True; new to extra146"]
    - [getmodule_co_varnames_len_eq_10,
       "getmodule.__code__.co_varnames.__len__",
       [],
       10,
       "inspect.getmodule.__code__.co_varnames.__len__() == 10 — getmodule has 10 local variable names in co_varnames; it checks __module__, file paths, and sys.modules; len() == 10; verified with Python 3.14.3; new to extra146"]
    - [getmodule_doc_len_eq_65,
       "getmodule.__doc__.__len__",
       [],
       65,
       "inspect.getmodule.__doc__.__len__() == 65 — the getmodule docstring has 65 characters; getmodule returns the module containing an object; len(__doc__) == 65; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Table 4: inspect.isfunction and inspect.isclass — predicate function attrs
#
# Wave 274 theme: inspect predicate functions (is* family) code attributes.
#
# inspect.isfunction.__code__.co_argcount == 1
# len(inspect.isfunction.__code__.co_varnames) == 1
# inspect.isfunction.__qualname__ == 'isfunction' (len 10)
# len(inspect.isfunction.__doc__) == 817
# inspect.isclass.__code__.co_argcount == 1
# len(inspect.isclass.__code__.co_varnames) == 1
# inspect.isclass.__qualname__ == 'isclass' (len 7)
# len(inspect.isclass.__doc__) == 37
#
# isfunction/isclass are simple predicate functions; each takes one arg (object)
# and has only one local variable in co_varnames. New to extra146.
# ---------------------------------------------------------------------------

table inspect_extra146.isfunction_isclass_attrs:
  description: "inspect.isfunction (co_argcount 1, co_varnames len 1, qualname len 10, doc len 817) and isclass (co_argcount 1, co_varnames len 1, qualname len 7, doc len 37); wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectisfunisclass146

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_qualname_eq,
       "isfunction.__qualname__.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — isfunction is a Python function in Lib/inspect.py; its __qualname__ is 'isfunction'; str.__eq__('isfunction') returns True; new to extra146"]
    - [isfunction_qualname_len_eq_10,
       "isfunction.__qualname__.__len__",
       [],
       10,
       "inspect.isfunction.__qualname__.__len__() == 10 — __qualname__ is 'isfunction' which has 10 characters; len('isfunction') == 10; new to extra146"]
    - [isfunction_co_argcount_eq_1,
       "isfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra146"]
    - [isfunction_co_varnames_len_eq_1,
       "isfunction.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isfunction.__code__.co_varnames.__len__() == 1 — isfunction has exactly 1 entry in co_varnames: object; simple predicate with no local temporaries; len() == 1; verified with Python 3.14.3; new to extra146"]
    - [isfunction_doc_len_eq_817,
       "isfunction.__doc__.__len__",
       [],
       817,
       "inspect.isfunction.__doc__.__len__() == 817 — the isfunction docstring has 817 characters; it documents all the criteria for a Python function; len(__doc__) == 817; verified with Python 3.14.3; new to extra146"]
    - [isclass_qualname_eq,
       "isclass.__qualname__.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__qualname__.__eq__('isclass') == True — isclass is a Python function in Lib/inspect.py; its __qualname__ is 'isclass'; str.__eq__('isclass') returns True; new to extra146"]
    - [isclass_qualname_len_eq_7,
       "isclass.__qualname__.__len__",
       [],
       7,
       "inspect.isclass.__qualname__.__len__() == 7 — __qualname__ is 'isclass' which has 7 characters; len('isclass') == 7; new to extra146"]
    - [isclass_co_varnames_len_eq_1,
       "isclass.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isclass.__code__.co_varnames.__len__() == 1 — isclass has exactly 1 entry in co_varnames: object; simple predicate with no local temporaries; len() == 1; verified with Python 3.14.3; new to extra146"]
    - [isclass_doc_len_eq_37,
       "isclass.__doc__.__len__",
       [],
       37,
       "inspect.isclass.__doc__.__len__() == 37 — the isclass docstring 'Return true if the object is a class.' has 37 characters; len(__doc__) == 37; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra146
# ---------------------------------------------------------------------------

invariant inspect_extra146.getmembers_qualname_len:
  description: "len(inspect.getmembers.__qualname__) == 10 — __qualname__ is 'getmembers'; wave 274; new to extra146"
  kind: python_call_eq
  function: getmembers.__qualname__.__len__
  args: []
  expected: 10

invariant inspect_extra146.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount == 2 — takes object and predicate; wave 274; new to extra146"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra146.getmembers_co_varnames_len:
  description: "len(inspect.getmembers.__code__.co_varnames) == 2 — co_varnames has 2 entries: object, predicate; wave 274; new to extra146"
  kind: python_call_eq
  function: getmembers.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant inspect_extra146.getfile_co_argcount:
  description: "inspect.getfile.__code__.co_argcount == 1 — takes object; wave 274; new to extra146"
  kind: python_call_eq
  function: getfile.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra146.getsource_co_argcount:
  description: "inspect.getsource.__code__.co_argcount == 1 — takes object; wave 274; new to extra146"
  kind: python_call_eq
  function: getsource.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra146.getsourcelines_qualname_len:
  description: "len(inspect.getsourcelines.__qualname__) == 14 — __qualname__ is 'getsourcelines'; wave 274; new to extra146"
  kind: python_call_eq
  function: getsourcelines.__qualname__.__len__
  args: []
  expected: 14

invariant inspect_extra146.getsourcelines_doc_len:
  description: "len(inspect.getsourcelines.__doc__) == 399 — getsourcelines docstring has 399 characters; wave 274; new to extra146"
  kind: python_call_eq
  function: getsourcelines.__doc__.__len__
  args: []
  expected: 399

invariant inspect_extra146.getmodule_co_argcount:
  description: "inspect.getmodule.__code__.co_argcount == 2 — takes object and _filename; wave 274; new to extra146"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra146.getmodule_co_varnames_len:
  description: "len(inspect.getmodule.__code__.co_varnames) == 10 — getmodule has 10 local variables; wave 274; new to extra146"
  kind: python_call_eq
  function: getmodule.__code__.co_varnames.__len__
  args: []
  expected: 10

invariant inspect_extra146.isfunction_doc_len:
  description: "len(inspect.isfunction.__doc__) == 817 — isfunction docstring has 817 characters; wave 274; new to extra146"
  kind: python_call_eq
  function: isfunction.__doc__.__len__
  args: []
  expected: 817

invariant inspect_extra146.isfunction_co_varnames_len:
  description: "len(inspect.isfunction.__code__.co_varnames) == 1 — isfunction has 1 local variable: object; wave 274; new to extra146"
  kind: python_call_eq
  function: isfunction.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant inspect_extra146.isclass_doc_len:
  description: "len(inspect.isclass.__doc__) == 37 — isclass docstring has 37 characters; wave 274; new to extra146"
  kind: python_call_eq
  function: isclass.__doc__.__len__
  args: []
  expected: 37
