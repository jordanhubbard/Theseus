spec: io_extra2461
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl"
    - "io_extra2.zspec.zsdl"
    - "_io_extra.zspec.zsdl"
  notes:
    - "Wave 2461, theme: __len__ and __length_hint__ dict-presence — io classes do not define length protocol."
    - "io stream classes are not containers and define neither __len__ nor __length_hint__ in their own __dict__."
    - "io.IOBase.__dict__ contains only _abc_impl and __doc__ — no length protocol methods."
    - "All concrete subclasses (BytesIO, StringIO, FileIO) also lack __len__ and __length_hint__ in their own __dict__."
    - "BufferedReader and TextIOWrapper similarly have no length protocol in their own __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# io.IOBase — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table io_extra2461.iobase_length_protocol:
  description: "io.IOBase.__dict__ does not define __len__ or __length_hint__ directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2461

  columns: [id, function, args, expected]
  rows:
    - ["io2461001", "io.IOBase.__dict__.__contains__", ["__len__"],         false]
    - ["io2461002", "io.IOBase.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# io abstract base classes — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table io_extra2461.abstract_bases_length_protocol:
  description: "io.RawIOBase, BufferedIOBase, TextIOBase do not define __len__ or __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2461

  columns: [id, function, args, expected]
  rows:
    - ["io2461003", "io.RawIOBase.__dict__.__contains__",      ["__len__"],         false]
    - ["io2461004", "io.RawIOBase.__dict__.__contains__",      ["__length_hint__"], false]
    - ["io2461005", "io.BufferedIOBase.__dict__.__contains__", ["__len__"],         false]
    - ["io2461006", "io.BufferedIOBase.__dict__.__contains__", ["__length_hint__"], false]
    - ["io2461007", "io.TextIOBase.__dict__.__contains__",     ["__len__"],         false]
    - ["io2461008", "io.TextIOBase.__dict__.__contains__",     ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# io concrete classes — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table io_extra2461.concrete_classes_length_protocol:
  description: "io.BytesIO, StringIO, FileIO, BufferedReader, TextIOWrapper do not define __len__ or __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2461

  columns: [id, function, args, expected]
  rows:
    - ["io2461009", "io.BytesIO.__dict__.__contains__",        ["__len__"],         false]
    - ["io2461010", "io.BytesIO.__dict__.__contains__",        ["__length_hint__"], false]
    - ["io2461011", "io.StringIO.__dict__.__contains__",       ["__len__"],         false]
    - ["io2461012", "io.StringIO.__dict__.__contains__",       ["__length_hint__"], false]
    - ["io2461013", "io.FileIO.__dict__.__contains__",         ["__len__"],         false]
    - ["io2461014", "io.FileIO.__dict__.__contains__",         ["__length_hint__"], false]
    - ["io2461015", "io.BufferedReader.__dict__.__contains__", ["__len__"],         false]
    - ["io2461016", "io.BufferedReader.__dict__.__contains__", ["__length_hint__"], false]
    - ["io2461017", "io.TextIOWrapper.__dict__.__contains__",  ["__len__"],         false]
    - ["io2461018", "io.TextIOWrapper.__dict__.__contains__",  ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Complementary: methods that ARE in concrete class __dict__
# ---------------------------------------------------------------------------

table io_extra2461.concrete_class_own_methods:
  description: "Own methods that ARE present in concrete io class __dict__ (not length protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2461

  columns: [id, function, args, expected]
  rows:
    - ["io2461019", "io.BytesIO.__dict__.__contains__",        ["readable"],  true]
    - ["io2461020", "io.BytesIO.__dict__.__contains__",        ["writable"],  true]
    - ["io2461021", "io.BytesIO.__dict__.__contains__",        ["seekable"],  true]
    - ["io2461022", "io.StringIO.__dict__.__contains__",       ["read"],      true]
    - ["io2461023", "io.StringIO.__dict__.__contains__",       ["write"],     true]
    - ["io2461024", "io.StringIO.__dict__.__contains__",       ["getvalue"],  true]
    - ["io2461025", "io.FileIO.__dict__.__contains__",         ["read"],      true]
    - ["io2461026", "io.FileIO.__dict__.__contains__",         ["write"],     true]
    - ["io2461027", "io.BufferedReader.__dict__.__contains__", ["read"],      true]
    - ["io2461028", "io.BufferedReader.__dict__.__contains__", ["read1"],     true]
    - ["io2461029", "io.BufferedReader.__dict__.__contains__", ["peek"],      true]
    - ["io2461030", "io.TextIOWrapper.__dict__.__contains__",  ["read"],      true]
