spec: ctypes_extra
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
  notes:
    - "Extends ctypes.zspec.zsdl and ctypes_module.zspec.zsdl with module affiliation and additional type name invariants."
    - "c_int.__module__ == 'ctypes' — fundamental C type wrappers report 'ctypes' as their module."
    - "c_char_p.__module__ == 'ctypes' — pointer types also report 'ctypes' as their module."
    - "Structure.__module__ == '_ctypes' — Structure is defined in the C extension module _ctypes, not the Python-level ctypes."
    - "CDLL.__module__ == 'ctypes' — CDLL is defined in the Python-level ctypes package."
    - "byref.__name__ == 'byref' — byref is a C builtin_function_or_method."
    - "POINTER.__name__ == 'POINTER' — POINTER is a function that returns a new pointer type class."
    - "cast.__name__ == 'cast' — cast is a C builtin_function_or_method."
    - "cdll is a LibraryLoader instance; cdll.__class__.__name__ == 'LibraryLoader'."
    - "All expected values verified by running Python 3.12 ctypes module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# c_int — name and module
# ---------------------------------------------------------------------------

invariant ctypes_extra.c_int.name:
  description: "ctypes.c_int.__name__ == 'c_int'"
  category: class_names
  kind: python_call_eq
  function: c_int.__name__.__eq__
  args: ["c_int"]
  expected: true

invariant ctypes_extra.c_int.module:
  description: "ctypes.c_int.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_int.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# c_char_p — name and module
# ---------------------------------------------------------------------------

invariant ctypes_extra.c_char_p.name:
  description: "ctypes.c_char_p.__name__ == 'c_char_p'"
  category: class_names
  kind: python_call_eq
  function: c_char_p.__name__.__eq__
  args: ["c_char_p"]
  expected: true

invariant ctypes_extra.c_char_p.module:
  description: "ctypes.c_char_p.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_char_p.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# CDLL — class name and module
# ---------------------------------------------------------------------------

invariant ctypes_extra.CDLL.name:
  description: "ctypes.CDLL.__name__ == 'CDLL'"
  category: class_names
  kind: python_call_eq
  function: CDLL.__name__.__eq__
  args: ["CDLL"]
  expected: true

invariant ctypes_extra.CDLL.module:
  description: "ctypes.CDLL.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: CDLL.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# Structure — class name and module
#
# Structure is defined in the C extension _ctypes, so its __module__ is '_ctypes'.
# ---------------------------------------------------------------------------

invariant ctypes_extra.Structure.name:
  description: "ctypes.Structure.__name__ == 'Structure'"
  category: class_names
  kind: python_call_eq
  function: Structure.__name__.__eq__
  args: ["Structure"]
  expected: true

invariant ctypes_extra.Structure.module:
  description: "ctypes.Structure.__module__ == '_ctypes' — Structure is defined in the C extension module"
  category: class_modules
  kind: python_call_eq
  function: Structure.__module__.__eq__
  args: ["_ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# cdll — the global LibraryLoader instance
#
# ctypes.cdll is a pre-built LibraryLoader instance for cdecl-convention libs.
# ---------------------------------------------------------------------------

invariant ctypes_extra.cdll.loader_class_name:
  description: "ctypes.cdll.__class__.__name__ == 'LibraryLoader'"
  category: class_names
  kind: python_call_eq
  function: cdll.__class__.__name__.__eq__
  args: ["LibraryLoader"]
  expected: true

# ---------------------------------------------------------------------------
# byref — helper function name
# ---------------------------------------------------------------------------

invariant ctypes_extra.byref.name:
  description: "ctypes.byref.__name__ == 'byref'"
  category: function_names
  kind: python_call_eq
  function: byref.__name__.__eq__
  args: ["byref"]
  expected: true

# ---------------------------------------------------------------------------
# POINTER — factory function name
# ---------------------------------------------------------------------------

invariant ctypes_extra.POINTER.name:
  description: "ctypes.POINTER.__name__ == 'POINTER'"
  category: function_names
  kind: python_call_eq
  function: POINTER.__name__.__eq__
  args: ["POINTER"]
  expected: true

# ---------------------------------------------------------------------------
# cast — helper function name
# ---------------------------------------------------------------------------

invariant ctypes_extra.cast.name:
  description: "ctypes.cast.__name__ == 'cast'"
  category: function_names
  kind: python_call_eq
  function: cast.__name__.__eq__
  args: ["cast"]
  expected: true

# ---------------------------------------------------------------------------
# Additional type aliases — fixed-width integer types map to canonical names
#
# On 64-bit platforms: c_int32.__name__ == 'c_int', c_int64.__name__ == 'c_long'.
# ---------------------------------------------------------------------------

table ctypes_extra.fixed_width_aliases:
  kind: python_call_eq
  category: class_names
  id_prefix: fwa

  columns: [id, function, args, expected]
  rows:
    - [c_int32,  c_int32.__name__.__eq__,  ["c_int"],   true]
    - [c_uint32, c_uint32.__name__.__eq__, ["c_uint"],  true]
    - [c_int16,  c_int16.__name__.__eq__,  ["c_short"], true]
    - [c_uint16, c_uint16.__name__.__eq__, ["c_ushort"], true]
    - [c_int8,   c_int8.__name__.__eq__,   ["c_byte"],  true]
    - [c_uint8,  c_uint8.__name__.__eq__,  ["c_ubyte"], true]
