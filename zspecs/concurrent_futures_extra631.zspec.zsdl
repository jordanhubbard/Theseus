spec: concurrent_futures_extra631
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __doc__ class name identity and module/qualname checks for executors and utilities"
  created_at: "2026-04-12T00:00:00Z"

table concurrent_futures_extra631.doc_class_identity:
  description: "concurrent.futures class __doc__ type identity checks"
  kind: python_call_eq
  category: doc_identity
  id_prefix: cf631dc
  columns: [id, function, args, expected]
  rows:
    - [cf631dc001, concurrent.futures.Future.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf631dc002, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf631dc003, concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf631dc004, concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf631dc005, concurrent.futures.BrokenExecutor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf631dc006, concurrent.futures.CancelledError.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf631dc007, concurrent.futures.TimeoutError.__doc__.__class__.__name__.__eq__, ["str"], true]

table concurrent_futures_extra631.qualname_and_module:
  description: "concurrent.futures executor method qualname and module identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: cf631qn
  columns: [id, function, args, expected]
  rows:
    - [cf631qn001, concurrent.futures.ThreadPoolExecutor.submit.__module__.__eq__, ["concurrent.futures.thread"], true]
    - [cf631qn002, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true]
    - [cf631qn003, concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"], true]
    - [cf631qn004, concurrent.futures.wait.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf631qn005, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true]
