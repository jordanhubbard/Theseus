spec: abc_extra282
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Awaitable, Coroutine, AsyncIterable, AsyncIterator, AsyncGenerator ABCs"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "Awaitable has 1 abstract method: __await__"
    - "Coroutine has 3 abstract methods: send, throw, __await__"
    - "AsyncIterable has 1 abstract method: __aiter__"
    - "AsyncIterator has 1 abstract method: __anext__"
    - "AsyncGenerator has 2 abstract methods: asend, athrow"
    - "Coroutine.__bases__[0] is Awaitable; AsyncIterator.__bases__[0] is AsyncIterable; AsyncGenerator.__bases__[0] is AsyncIterator"
    - "collections.abc.Buffer is available in Python 3.12+"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra282.async_abc_names:
  description: "__name__ attribute of async-related abstract base classes in collections.abc"
  kind: python_call_eq
  category: identity
  id_prefix: abcnames

  columns: [id, function, args, expected, description]
  rows:
    - [abcnames001, collections.abc.Awaitable.__name__.__eq__, ["Awaitable"], true, "Awaitable __name__"]
    - [abcnames002, collections.abc.Coroutine.__name__.__eq__, ["Coroutine"], true, "Coroutine __name__"]
    - [abcnames003, collections.abc.AsyncIterable.__name__.__eq__, ["AsyncIterable"], true, "AsyncIterable __name__"]
    - [abcnames004, collections.abc.AsyncIterator.__name__.__eq__, ["AsyncIterator"], true, "AsyncIterator __name__"]
    - [abcnames005, collections.abc.AsyncGenerator.__name__.__eq__, ["AsyncGenerator"], true, "AsyncGenerator __name__"]

table abc_extra282.async_abc_abstractmethods_counts:
  description: "__abstractmethods__.__len__ counts for async ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abcabst

  columns: [id, function, args, expected, description]
  rows:
    - [abcabst001, collections.abc.Awaitable.__abstractmethods__.__len__, [], 1, "Awaitable has 1 abstract method (__await__)"]
    - [abcabst002, collections.abc.Coroutine.__abstractmethods__.__len__, [], 3, "Coroutine has 3 abstract methods (send, throw, __await__)"]
    - [abcabst003, collections.abc.AsyncIterable.__abstractmethods__.__len__, [], 1, "AsyncIterable has 1 abstract method (__aiter__)"]
    - [abcabst004, collections.abc.AsyncIterator.__abstractmethods__.__len__, [], 1, "AsyncIterator has 1 abstract method (__anext__)"]
    - [abcabst005, collections.abc.AsyncGenerator.__abstractmethods__.__len__, [], 2, "AsyncGenerator has 2 abstract methods (asend, athrow)"]

invariant abc_extra282.coroutine_base_is_awaitable:
  description: "Coroutine's first base class is Awaitable"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Coroutine.__bases__[0].__name__.__eq__"
  args: ["Awaitable"]
  expected: true

invariant abc_extra282.asynciterator_base_is_asynciterable:
  description: "AsyncIterator's first base class is AsyncIterable"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterable"]
  expected: true

invariant abc_extra282.asyncgenerator_base_is_asynciterator:
  description: "AsyncGenerator's first base class is AsyncIterator"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncGenerator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterator"]
  expected: true

invariant abc_extra282.awaitable_module:
  description: "Awaitable is defined in collections.abc"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra282.buffer_name:
  description: "collections.abc.Buffer __name__ is 'Buffer' (Python 3.12+)"
  category: identity
  kind: python_call_eq
  function: collections.abc.Buffer.__name__.__eq__
  args: ["Buffer"]
  expected: true
