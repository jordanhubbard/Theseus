spec: textwrap_extra9
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
    - "textwrap.zspec.zsdl — covers wrap/fill/dedent/indent/shorten basic vectors; TextWrapper(width=40).width."
    - "textwrap_extra.zspec.zsdl — covers wrap/fill/dedent/indent/shorten __name__; TextWrapper __name__/__module__; additional behavioral vectors."
    - "textwrap_extra2.zspec.zsdl — covers TextWrapper __name__/__module__/__qualname__/is_type; function_names/qualnames/modules; TextWrapper defaults (width=70, break_long_words=True, width=120); fill/dedent return type."
    - "textwrap_extra3.zspec.zsdl — covers function __module__ table; wrap/fill behavioral vectors; indent with angle prefix; dedent blank_first_line; shorten truncated/fits vectors."
    - "textwrap_extra4.zspec.zsdl — covers function_names/function_modules tables; TextWrapper __name__/__module__; TextWrapper defaults (width, expand_tabs); wrap/fill/dedent basic invariants."
    - "textwrap_extra5.zspec.zsdl — covers TextWrapper.__bases__[0].__name__=='object'; TextWrapper defaults (drop_whitespace, fix_sentence_endings, placeholder); shorten exact-fit/default-placeholder/short-input; wrap.__qualname__; shorten.__class__.__name__=='function'."
    - "textwrap_extra6.zspec.zsdl — covers TextWrapper __name__/__module__/__qualname__/__bases__ as extra6 anchors; function_names table (wrap/fill/dedent/indent/shorten) as extra6 anchors."
    - "textwrap_extra7.zspec.zsdl — covers TextWrapper defaults (break_on_hyphens, max_lines, tabsize); function __class__.__name__=='function' for wrap/fill/dedent/indent; indent hash prefix with trailing newline; TextWrapper.wrap with initial_indent; shorten custom unicode placeholder; fill three-line output."
    - "textwrap_extra8.zspec.zsdl — covers function __module__ standalone invariants (wrap/fill/shorten/dedent/indent); TextWrapper __module__/__name__ anchors; TextWrapper width=40/width=80; TextWrapper initial_indent/subsequent_indent/break_long_words/break_on_hyphens defaults."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior textwrap spec."
    - "textwrap.wrap.__name__ == 'wrap' — extra9-namespace anchor; covered in extra and extra4 namespaces."
    - "textwrap.fill.__name__ == 'fill' — extra9-namespace anchor; covered in extra and extra4 namespaces."
    - "textwrap.dedent.__name__ == 'dedent' — extra9-namespace anchor; covered in extra and extra4 namespaces."
    - "textwrap.shorten.__name__ == 'shorten' — extra9-namespace anchor; covered in extra and extra4 namespaces."
    - "textwrap.indent.__name__ == 'indent' — extra9-namespace anchor; covered in extra and extra4 namespaces."
    - "textwrap.wrap('hello world', width=5) == ['hello', 'world'] — no prior spec uses width=5 with this input."
    - "textwrap.fill('hello world', width=5) == 'hello\\nworld' — no prior spec checks fill output with width=5."
    - "textwrap.dedent('  hello\\n  world') == 'hello\\nworld' — two-line dedent not covered as a standalone invariant."
    - "textwrap.shorten('The quick brown fox', width=15) == 'The quick [...]' — specific width/input combo not in prior specs."
    - "textwrap.TextWrapper().width == 70 — covered in extra2 and extra4; extra9-namespace anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — extra9-namespace grouped table
#
# textwrap_extra and textwrap_extra4 cover these in table rows.
# This table provides extra9-namespace anchors for all five public functions.
# ---------------------------------------------------------------------------

table textwrap_extra9.name_attrs:
  kind: python_call_eq
  category: function_identity
  id_prefix: tname

  columns: [id, function, args, expected]
  rows:
    - [wrap,    wrap.__name__.__eq__,    ["wrap"],    true]
    - [fill,    fill.__name__.__eq__,    ["fill"],    true]
    - [dedent,  dedent.__name__.__eq__,  ["dedent"],  true]
    - [shorten, shorten.__name__.__eq__, ["shorten"], true]
    - [indent,  indent.__name__.__eq__,  ["indent"],  true]

# ---------------------------------------------------------------------------
# wrap — behavioral vector with width=5
#
# Prior specs use wrap with default or larger widths.
# wrap('hello world', width=5) splits at word boundaries: ['hello', 'world'].
# ---------------------------------------------------------------------------

invariant textwrap_extra9.wrap.width_5:
  description: "textwrap.wrap('hello world', width=5) == ['hello', 'world'] — splits at word boundary"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world"]
  kwargs: {width: 5}
  method: __eq__
  method_args: [["hello", "world"]]
  expected: true

# ---------------------------------------------------------------------------
# fill — behavioral vector with width=5
#
# No prior spec checks fill('hello world', width=5).
# fill joins wrap result with newlines: 'hello\nworld'.
# ---------------------------------------------------------------------------

invariant textwrap_extra9.fill.width_5:
  description: "textwrap.fill('hello world', width=5) == 'hello\\nworld' — wraps and joins with newline"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world"]
  kwargs: {width: 5}
  method: __eq__
  method_args: ["hello\nworld"]
  expected: true

# ---------------------------------------------------------------------------
# dedent — two-line uniform indent
#
# textwrap_extra3 covers dedent with a blank first line.
# No prior spec checks dedent('  hello\n  world') as a standalone invariant.
# Both lines have two leading spaces removed uniformly.
# ---------------------------------------------------------------------------

invariant textwrap_extra9.dedent.two_lines:
  description: "textwrap.dedent('  hello\\n  world') == 'hello\\nworld' — strips common two-space indent"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  hello\n  world"]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# shorten — truncated output with default placeholder
#
# textwrap_extra3 covers shorten with truncated/fits vectors at different widths.
# No prior spec checks shorten('The quick brown fox', width=15) specifically.
# Result is 'The quick [...]' — default placeholder is ' [...]'.
# ---------------------------------------------------------------------------

invariant textwrap_extra9.shorten.width_15:
  description: "textwrap.shorten('The quick brown fox', width=15) == 'The quick [...]'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["The quick brown fox"]
  kwargs: {width: 15}
  expected: "The quick [...]"

# ---------------------------------------------------------------------------
# TextWrapper default width — extra9-namespace anchor
#
# textwrap_extra2 and extra4 cover TextWrapper().width == 70.
# This is the extra9-namespace standalone anchor for the same fact.
# ---------------------------------------------------------------------------

invariant textwrap_extra9.TextWrapper.default_width:
  description: "textwrap.TextWrapper().width == 70 — default wrapping width"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: width.__eq__
  method_args: [70]
  expected: true
