spec: abc_extra2071
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod is a plain function decorator."
    - "None of these abc constructs define numeric unary, attribute-lookup, pickle, or copy protocols in their own __dict__."
    - "ABCMeta defines some special methods (e.g. __instancecheck__, __subclasscheck__) but not the protocols checked here."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2071.unary_sign_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2071

  columns: [id, function, args, expected]
  rows:
    - ["ab2071001", "abc.ABCMeta.__dict__.__contains__", ["__pos__"], false]
    - ["ab2071002", "abc.ABCMeta.__dict__.__contains__", ["__neg__"], false]
    - ["ab2071003", "abc.ABC.__dict__.__contains__", ["__pos__"], false]
    - ["ab2071004", "abc.ABC.__dict__.__contains__", ["__neg__"], false]
    - ["ab2071005", "abc.abstractmethod.__dict__.__contains__", ["__pos__"], false]
    - ["ab2071006", "abc.abstractmethod.__dict__.__contains__", ["__neg__"], false]

