spec: functools_extra195
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.partial.__init__.__name__ == '__init__' (len=8); partial.__init__ is a wrapper_descriptor; verified with Python 3.14.3."
    - "functools.partial.__call__.__name__ == '__call__' (len=8); partial.__call__ is a wrapper_descriptor; verified with Python 3.14.3."
    - "functools.partial.__repr__.__name__ == '__repr__' (len=8); partial.__repr__ is a wrapper_descriptor; verified with Python 3.14.3."
    - "functools.partial.__reduce__.__name__ == '__reduce__' (len=10); partial.__reduce__ is a method_descriptor; verified with Python 3.14.3."
    - "functools.partial.__setstate__.__name__ == '__setstate__' (len=12); partial.__setstate__ is a method_descriptor; verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str'; the docstring is a Python str; verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2; MRO is [partial, object]; verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object'; partial inherits directly from object; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial wrapper_descriptor __name__ lengths
#
# functools.partial.__init__.__name__  == '__init__' (len=8)
# functools.partial.__call__.__name__  == '__call__' (len=8)
# functools.partial.__repr__.__name__  == '__repr__' (len=8)
#
# __init__, __call__, and __repr__ are wrapper_descriptors on the C-level
# partial type. All three have __name__ of length 8 (double-underscore + 4
# chars + double-underscore). New to extra195.
# ---------------------------------------------------------------------------

table functools_extra195.partial_wrapper_dunder_names:
  description: "functools.partial wrapper_descriptor dunder __name__ values: __init__=='__init__'(len=8); __call__=='__call__'(len=8); __repr__=='__repr__'(len=8); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialdunder195

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,
       "partial.__init__.__name__.__eq__",
       ["__init__"],
       true,
       "functools.partial.__init__.__name__.__eq__('__init__') == True — __init__ is a wrapper_descriptor; __name__ is '__init__' (len=8: __+init+__); str.__eq__('__init__') returns True; verified with Python 3.14.3; new to extra195"]
    - [init_name_len,
       "partial.__init__.__name__.__len__",
       [],
       8,
       "functools.partial.__init__.__name__.__len__() == 8 — '__init__' has 8 characters: _-_-i-n-i-t-_-_; str.__len__() returns 8; verified with Python 3.14.3; new to extra195"]
    - [call_name_eq,
       "partial.__call__.__name__.__eq__",
       ["__call__"],
       true,
       "functools.partial.__call__.__name__.__eq__('__call__') == True — __call__ is a wrapper_descriptor; __name__ is '__call__' (len=8: __+call+__); str.__eq__('__call__') returns True; verified with Python 3.14.3; new to extra195"]
    - [call_name_len,
       "partial.__call__.__name__.__len__",
       [],
       8,
       "functools.partial.__call__.__name__.__len__() == 8 — '__call__' has 8 characters: _-_-c-a-l-l-_-_; str.__len__() returns 8; verified with Python 3.14.3; new to extra195"]
    - [repr_name_eq,
       "partial.__repr__.__name__.__eq__",
       ["__repr__"],
       true,
       "functools.partial.__repr__.__name__.__eq__('__repr__') == True — __repr__ is a wrapper_descriptor; __name__ is '__repr__' (len=8: __+repr+__); str.__eq__('__repr__') returns True; verified with Python 3.14.3; new to extra195"]
    - [repr_name_len,
       "partial.__repr__.__name__.__len__",
       [],
       8,
       "functools.partial.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters: _-_-r-e-p-r-_-_; str.__len__() returns 8; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial method_descriptor __name__ lengths
#
# functools.partial.__reduce__.__name__    == '__reduce__' (len=10)
# functools.partial.__setstate__.__name__  == '__setstate__' (len=12)
#
# __reduce__ and __setstate__ are method_descriptors (not wrapper_descriptors).
# __reduce__ has length 10 (__+reduce+__), __setstate__ has length 12
# (__+setstate+__). New to extra195.
# ---------------------------------------------------------------------------

table functools_extra195.partial_method_descriptor_dunder_names:
  description: "functools.partial method_descriptor dunder __name__ values: __reduce__=='__reduce__'(len=10); __setstate__=='__setstate__'(len=12); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialdunder195

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       "partial.__reduce__.__name__.__eq__",
       ["__reduce__"],
       true,
       "functools.partial.__reduce__.__name__.__eq__('__reduce__') == True — __reduce__ is a method_descriptor; __name__ is '__reduce__' (len=10: __+reduce+__); str.__eq__('__reduce__') returns True; verified with Python 3.14.3; new to extra195"]
    - [reduce_name_len,
       "partial.__reduce__.__name__.__len__",
       [],
       10,
       "functools.partial.__reduce__.__name__.__len__() == 10 — '__reduce__' has 10 characters: _-_-r-e-d-u-c-e-_-_; str.__len__() returns 10; verified with Python 3.14.3; new to extra195"]
    - [setstate_name_eq,
       "partial.__setstate__.__name__.__eq__",
       ["__setstate__"],
       true,
       "functools.partial.__setstate__.__name__.__eq__('__setstate__') == True — __setstate__ is a method_descriptor; __name__ is '__setstate__' (len=12: __+setstate+__); str.__eq__('__setstate__') returns True; verified with Python 3.14.3; new to extra195"]
    - [setstate_name_len,
       "partial.__setstate__.__name__.__len__",
       [],
       12,
       "functools.partial.__setstate__.__name__.__len__() == 12 — '__setstate__' has 12 characters: _-_-s-e-t-s-t-a-t-e-_-_; str.__len__() returns 12; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial class identity — __doc__, __mro__, __bases__
#
# functools.partial.__doc__.__class__.__name__  == 'str'
# functools.partial.__mro__.__len__()           == 2  (partial, object)
# functools.partial.__bases__[0].__name__       == 'object'
#
# partial is a C extension type that inherits directly from object.
# Its docstring is a plain Python str. MRO has exactly 2 entries.
# New to extra195.
# ---------------------------------------------------------------------------

table functools_extra195.partial_class_identity:
  description: "functools.partial class-level identity: __doc__.__class__.__name__=='str'; __mro__.__len__()==2; __bases__[0].__name__=='object'; new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialdunder195

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_name,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — the partial docstring is a Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; verified with Python 3.14.3; new to extra195"]
    - [mro_len,
       partial.__mro__.__len__,
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — MRO is (partial, object); exactly 2 entries because partial inherits directly from object with no intermediary; tuple.__len__() returns 2; verified with Python 3.14.3; new to extra195"]
    - [bases_first_name,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial's only base is object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra195
# ---------------------------------------------------------------------------

invariant functools_extra195.partial_init_name_eq:
  description: "functools.partial.__init__.__name__.__eq__('__init__') == True — __init__ is a wrapper_descriptor on the C-level partial type; __name__ is '__init__' (len=8); verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant functools_extra195.partial_call_name_eq:
  description: "functools.partial.__call__.__name__.__eq__('__call__') == True — __call__ is a wrapper_descriptor; __name__ is '__call__' (len=8); verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__call__.__name__.__eq__"
  args: ["__call__"]
  expected: true

invariant functools_extra195.partial_repr_name_eq:
  description: "functools.partial.__repr__.__name__.__eq__('__repr__') == True — __repr__ is a wrapper_descriptor; __name__ is '__repr__' (len=8); verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__repr__.__name__.__eq__"
  args: ["__repr__"]
  expected: true

invariant functools_extra195.partial_reduce_name_eq:
  description: "functools.partial.__reduce__.__name__.__eq__('__reduce__') == True — __reduce__ is a method_descriptor; __name__ is '__reduce__' (len=10); verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__reduce__.__name__.__eq__"
  args: ["__reduce__"]
  expected: true

invariant functools_extra195.partial_setstate_name_eq:
  description: "functools.partial.__setstate__.__name__.__eq__('__setstate__') == True — __setstate__ is a method_descriptor; __name__ is '__setstate__' (len=12); verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__setstate__.__name__.__eq__"
  args: ["__setstate__"]
  expected: true

invariant functools_extra195.partial_doc_class_name_str:
  description: "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial's docstring is a plain Python str object; __class__.__name__ is 'str'; verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra195.partial_mro_len_two:
  description: "functools.partial.__mro__.__len__() == 2 — MRO is (partial, object); only 2 entries since partial inherits directly from object; verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra195.partial_bases_first_object:
  description: "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial's only base class is object; __bases__[0].__name__ is 'object'; verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra195.partial_reduce_name_len_ten:
  description: "functools.partial.__reduce__.__name__.__len__() == 10 — '__reduce__' has 10 characters: _-_-r-e-d-u-c-e-_-_; str.__len__() returns 10; verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__reduce__.__name__.__len__"
  args: []
  expected: 10

invariant functools_extra195.partial_setstate_name_len_twelve:
  description: "functools.partial.__setstate__.__name__.__len__() == 12 — '__setstate__' has 12 characters: _-_-s-e-t-s-t-a-t-e-_-_; str.__len__() returns 12; verified with Python 3.14.3; new to extra195"
  category: identity
  kind: python_call_eq
  function: "partial.__setstate__.__name__.__len__"
