spec: decimal_extra126
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal exception class MRO lengths and __bases__ contents."
    - "The decimal module has no __all__ attribute in Python 3.14 — public names are determined by convention."
    - "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException directly extends ArithmeticError."
    - "decimal.Inexact.__mro__.__len__() == 6 — MRO is [Inexact, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Rounded.__mro__.__len__() == 6 — MRO is [Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Subnormal.__mro__.__len__() == 6 — same structure as Inexact and Rounded."
    - "decimal.InvalidOperation.__mro__.__len__() == 6 — same structure as Inexact."
    - "decimal.DivisionByZero.__mro__.__len__() == 7 — MRO includes ZeroDivisionError: [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Overflow.__mro__.__len__() == 8 — Overflow extends both Inexact and Rounded (two direct bases), giving MRO [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Underflow.__mro__.__len__() == 9 — longest MRO; Underflow extends Inexact, Rounded, Subnormal."
    - "decimal.Overflow.__bases__.__len__() == 2 — Overflow has two direct bases: Inexact and Rounded."
    - "decimal.DivisionByZero.__bases__.__len__() == 2 — DivisionByZero has two direct bases: DecimalException and ZeroDivisionError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.DecimalException MRO and bases
# DecimalException.__mro__.__len__() == 5.
# MRO: [DecimalException, ArithmeticError, Exception, BaseException, object].
# DecimalException.__bases__[0].__name__ == 'ArithmeticError' (single direct base).
# ---------------------------------------------------------------------------

table decimal_extra126.DecimalException_mro_and_bases:
  description: "decimal.DecimalException MRO length (5) and direct base name ('ArithmeticError')"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decexcmro126

  columns: [id, function, args, expected]
  rows:
    - [de_mro_len,       DecimalException.__mro__.__len__,                      [], 5]
    - [de_base_eq,       "DecimalException.__bases__[0].__name__.__eq__",        ["ArithmeticError"], true]
    - [de_base_not_exc,  "DecimalException.__bases__[0].__name__.__eq__",        ["Exception"],       false]
    - [de_bases_len,     DecimalException.__bases__.__len__,                     [], 1]
    - [de_name_len,      DecimalException.__name__.__len__,                      [], 16]
    - [de_mro_not_6,     DecimalException.__mro__.__len__,                       [], 5]

# ---------------------------------------------------------------------------
# decimal single-base direct subclasses of DecimalException
# Inexact, Rounded, Subnormal, InvalidOperation all extend DecimalException
# directly. MRO length == 6 for all four.
# ---------------------------------------------------------------------------

table decimal_extra126.single_base_subclasses_mro:
  description: "decimal.Inexact, Rounded, Subnormal, InvalidOperation all extend DecimalException directly; __mro__.__len__() == 6 for all"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decexcmro126

  columns: [id, function, args, expected]
  rows:
    - [inx_mro_len,    Inexact.__mro__.__len__,          [], 6]
    - [rnd_mro_len,    Rounded.__mro__.__len__,           [], 6]
    - [sub_mro_len,    Subnormal.__mro__.__len__,         [], 6]
    - [io_mro_len,     InvalidOperation.__mro__.__len__,  [], 6]
    - [inx_base_eq,    "Inexact.__bases__[0].__name__.__eq__",         ["DecimalException"], true]
    - [rnd_base_eq,    "Rounded.__bases__[0].__name__.__eq__",         ["DecimalException"], true]
    - [sub_base_eq,    "Subnormal.__bases__[0].__name__.__eq__",       ["DecimalException"], true]
    - [io_base_eq,     "InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [inx_bases_len,  Inexact.__bases__.__len__,         [], 1]

# ---------------------------------------------------------------------------
# decimal multi-base subclasses: Overflow (mro=8), DivisionByZero (mro=7),
# Underflow (mro=9).
# Overflow.__bases__ == (Inexact, Rounded) — two direct bases.
# DivisionByZero.__bases__ == (DecimalException, ZeroDivisionError) — two direct bases.
# Underflow.__bases__ == (Inexact, Rounded, Subnormal) — three direct bases.
# ---------------------------------------------------------------------------

table decimal_extra126.multi_base_subclasses_mro:
  description: "decimal.Overflow (mro=8, bases=2), DivisionByZero (mro=7, bases=2), Underflow (mro=9, bases=3) — multi-base subclasses with longer MROs"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decexcmro126

  columns: [id, function, args, expected]
  rows:
    - [ov_mro_len,        Overflow.__mro__.__len__,                        [], 8]
    - [ov_bases_len,      Overflow.__bases__.__len__,                      [], 2]
    - [ov_base0_eq,       "Overflow.__bases__[0].__name__.__eq__",          ["Inexact"],          true]
    - [ov_base1_eq,       "Overflow.__bases__[1].__name__.__eq__",          ["Rounded"],          true]
    - [dbz_mro_len,       DivisionByZero.__mro__.__len__,                  [], 7]
    - [dbz_bases_len,     DivisionByZero.__bases__.__len__,                [], 2]
    - [dbz_base0_eq,      "DivisionByZero.__bases__[0].__name__.__eq__",    ["DecimalException"], true]
    - [dbz_base1_eq,      "DivisionByZero.__bases__[1].__name__.__eq__",    ["ZeroDivisionError"], true]
    - [uf_mro_len,        Underflow.__mro__.__len__,                        [], 9]
    - [uf_bases_len,      Underflow.__bases__.__len__,                      [], 3]
    - [uf_base0_eq,       "Underflow.__bases__[0].__name__.__eq__",         ["Inexact"],          true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra126.DecimalException.mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 (MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; DecimalException is the root of all decimal-specific exceptions)"
  category: exception_hierarchy
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra126.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException extends ArithmeticError, which is a built-in exception for arithmetic errors; DecimalException has exactly one direct base)"
  category: exception_hierarchy
  kind: python_call_eq
  function: DecimalException.__bases__[0].__name__.__eq__
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra126.Overflow.mro_len_8:
  description: "decimal.Overflow.__mro__.__len__() == 8 (Overflow extends Inexact and Rounded simultaneously; C3 linearization gives MRO [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object])"
  category: exception_hierarchy
  kind: python_call_eq
  function: Overflow.__mro__.__len__
  args: []
  expected: 8

invariant decimal_extra126.DivisionByZero.base1_is_ZeroDivisionError:
  description: "decimal.DivisionByZero.__bases__[1].__name__ == 'ZeroDivisionError' (DivisionByZero extends both DecimalException and the built-in ZeroDivisionError, so it is catchable as either)"
  category: exception_hierarchy
  kind: python_call_eq
  function: DivisionByZero.__bases__[1].__name__.__eq__
  args: ["ZeroDivisionError"]
  expected: true

invariant decimal_extra126.Underflow.mro_len_9:
  description: "decimal.Underflow.__mro__.__len__() == 9 (Underflow extends Inexact, Rounded, and Subnormal — three direct bases — giving the longest MRO of all decimal exceptions; MRO is [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object])"
  category: exception_hierarchy
  kind: python_call_eq
  function: Underflow.__mro__.__len__
  args: []
  expected: 9

