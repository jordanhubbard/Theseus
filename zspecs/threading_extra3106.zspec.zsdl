spec: th3106
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (th3106): __lt__, __le__, __gt__ dict-presence checks for threading types."
    - "None of the threading types define __lt__, __le__, or __gt__ in their own __dict__."
    - "threading synchronization types do not support ordering comparisons; none define ordering operators in their own __dict__."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3106.lt:
  description: "threading types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3106
  columns: [id, function, args, expected]
  rows:
    - ["th3106001", operator.contains, [threading.Thread.__dict__,           "__lt__"], false]
    - ["th3106002", operator.contains, [type(threading.Lock()).__dict__,     "__lt__"], false]
    - ["th3106003", operator.contains, [type(threading.RLock()).__dict__,    "__lt__"], false]
    - ["th3106004", operator.contains, [threading.Event.__dict__,            "__lt__"], false]
    - ["th3106005", operator.contains, [threading.Condition.__dict__,        "__lt__"], false]
    - ["th3106006", operator.contains, [threading.Semaphore.__dict__,        "__lt__"], false]
    - ["th3106007", operator.contains, [threading.BoundedSemaphore.__dict__, "__lt__"], false]
    - ["th3106008", operator.contains, [threading.Timer.__dict__,            "__lt__"], false]
    - ["th3106009", operator.contains, [threading.Barrier.__dict__,          "__lt__"], false]
    - ["th3106010", operator.contains, [threading.local.__dict__,            "__lt__"], false]

