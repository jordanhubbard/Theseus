    - ["cf1891-ai-001", "concurrent.futures.Future.__dict__.__contains__", ["__aiter__"], false]
    - ["cf1891-ai-002", "concurrent.futures.Future.__dict__.__contains__", ["__anext__"], false]
    - ["cf1891-ai-003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__aiter__"], false]
    - ["cf1891-ai-004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__aiter__"], false]
    - ["cf1891-ai-005", "concurrent.futures.Executor.__dict__.__contains__", ["__aiter__"], false]
    - ["cf1891-ai-006", "concurrent.futures.Future.__dict__.__contains__", ["__length_hint__"], false]
    - ["cf1891-ai-007", "concurrent.futures.Future.__dict__.__contains__", ["__fspath__"], false]
    - ["cf1891-ai-008", "concurrent.futures.Executor.__dict__.__contains__", ["__length_hint__"], false]

table concurrent_futures_extra1891.cf_wait_result_attrs:
  columns: [id, function, args, expected]
