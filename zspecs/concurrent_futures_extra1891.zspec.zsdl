spec: concurrent_futures_extra1891
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "concurrent.futures module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party concurrent.futures extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in concurrent.futures types"
    - "None of the concurrent.futures types implement unary arithmetic dunder methods"
    - "concurrent.futures.Future is not async-iterable and has no async iteration protocol methods"
    - "set_running_or_notify_cancel is part of the internal executor interface"
  created_at: "2026-04-12"

table concurrent_futures_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["cf1891-ua-001", "concurrent.futures.Future.__dict__.__contains__", ["__abs__"], false]
    - ["cf1891-ua-002", "concurrent.futures.Future.__dict__.__contains__", ["__neg__"], false]
    - ["cf1891-ua-003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__abs__"], false]
    - ["cf1891-ua-004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__abs__"], false]
    - ["cf1891-ua-005", "concurrent.futures.Executor.__dict__.__contains__", ["__abs__"], false]
    - ["cf1891-ua-006", "concurrent.futures.Future.__dict__.__contains__", ["__pos__"], false]
    - ["cf1891-ua-007", "concurrent.futures.Future.__dict__.__contains__", ["__round__"], false]
    - ["cf1891-ua-008", "concurrent.futures.Future.__dict__.__contains__", ["__trunc__"], false]

table concurrent_futures_extra1891.async_iteration_protocol:
