spec: itertools_extra96
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra95

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra95.zspec.zsdl."
    - "This spec covers: itertools C-type __dict__ membership — what methods are in each type's __dict__ (Wave 254)."
    - "itertools.chain.__dict__.__contains__('__new__') == True. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__iter__') == True. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__next__') == True. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('from_iterable') == True. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__reduce__') == False — not in chain's __dict__ in Python 3.14.3. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__doc__') == True. Verified with Python 3.14.3."
    - "itertools.cycle.__dict__.__contains__('__iter__') == True. Verified with Python 3.14.3."
    - "itertools.cycle.__dict__.__contains__('__next__') == True. Verified with Python 3.14.3."
    - "itertools.cycle.__dict__.__contains__('__reduce__') == False — not in cycle's __dict__ in Python 3.14.3. Verified with Python 3.14.3."
    - "itertools.count.__dict__.__contains__('__repr__') == True. Verified with Python 3.14.3."
    - "itertools.count.__dict__.__contains__('__reduce__') == False. Verified with Python 3.14.3."
    - "itertools.repeat.__dict__.__contains__('__length_hint__') == True. Verified with Python 3.14.3."
    - "itertools.repeat.__dict__.__contains__('__reduce__') == False. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__contains__('__iter__') == True. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__contains__('__reduce__') == False. Verified with Python 3.14.3."
    - "All itertools type __dict__.__class__.__name__ == 'mappingproxy'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: chain.__dict__ membership
#
# Wave 254 theme: itertools.chain type __dict__ membership.
#
# itertools.chain.__dict__.__contains__('__new__') == True
# itertools.chain.__dict__.__contains__('__iter__') == True
# itertools.chain.__dict__.__contains__('__next__') == True
# itertools.chain.__dict__.__contains__('from_iterable') == True
# itertools.chain.__dict__.__contains__('__reduce__') == False
# itertools.chain.__dict__.__contains__('__doc__') == True
#
# chain.__dict__ keys: __new__, __getattribute__, __iter__, __next__,
# from_iterable, __class_getitem__, __doc__, __module__.
# __reduce__ is NOT in chain's own __dict__ in Python 3.14.3. New to extra96.
# ---------------------------------------------------------------------------

table itertools_extra96.chain_dict_membership:
  description: "itertools.chain.__dict__ membership: __new__/True, __iter__/True, __next__/True, from_iterable/True, __reduce__/False, __doc__/True; C type mappingproxy; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdictmem96

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_contains_new,
       "chain.__dict__.__contains__",
       ["__new__"],
       true,
       "itertools.chain.__dict__.__contains__('__new__') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; it defines its own tp_new slot which appears as '__new__' in the type __dict__; mappingproxy.__contains__('__new__') returns True; new to extra96"]
    - [chain_dict_contains_iter,
       "chain.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.chain.__dict__.__contains__('__iter__') == True — chain implements the iterator protocol; its tp_iter slot appears as '__iter__' in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra96"]
    - [chain_dict_contains_next,
       "chain.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.chain.__dict__.__contains__('__next__') == True — chain implements the iterator protocol; its tp_iternext slot appears as '__next__' in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra96"]
    - [chain_dict_contains_from_iterable,
       "chain.__dict__.__contains__",
       ["from_iterable"],
       true,
       "itertools.chain.__dict__.__contains__('from_iterable') == True — chain.from_iterable is a classmethod alternative constructor defined in Modules/itertoolsmodule.c; it appears in the type __dict__; mappingproxy.__contains__('from_iterable') returns True; new to extra96"]
    - [chain_dict_not_contains_reduce,
       "chain.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.chain.__dict__.__contains__('__reduce__') == False — chain does not define its own __reduce__ in Python 3.14.3; the method is not present in chain's type __dict__; mappingproxy.__contains__('__reduce__') returns False; new to extra96"]
    - [chain_dict_contains_doc,
       "chain.__dict__.__contains__",
       ["__doc__"],
       true,
       "itertools.chain.__dict__.__contains__('__doc__') == True — chain has a C-defined docstring stored as '__doc__' in its type __dict__; mappingproxy.__contains__('__doc__') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Table 2: cycle and count __dict__ membership
#
# Wave 254 theme: itertools.cycle and count type __dict__ membership.
#
# itertools.cycle.__dict__.__contains__('__iter__') == True
# itertools.cycle.__dict__.__contains__('__next__') == True
# itertools.cycle.__dict__.__contains__('__reduce__') == False
# itertools.cycle.__dict__.__contains__('__setstate__') == False
# itertools.count.__dict__.__contains__('__iter__') == True
# itertools.count.__dict__.__contains__('__next__') == True
# itertools.count.__dict__.__contains__('__reduce__') == False
# itertools.count.__dict__.__contains__('__repr__') == True
#
# cycle and count both have __iter__/__next__ but not __reduce__ in Python 3.14.3.
# count additionally has __repr__. New to extra96.
# ---------------------------------------------------------------------------

table itertools_extra96.cycle_count_dict_membership:
  description: "itertools.cycle and count __dict__ membership: __iter__/True, __next__/True, __reduce__/False; count also has __repr__/True; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdictmem96

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_dict_contains_iter,
       "cycle.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.cycle.__dict__.__contains__('__iter__') == True — cycle is a C extension type implementing the iterator protocol; __iter__ appears in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra96"]
    - [cycle_dict_contains_next,
       "cycle.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.cycle.__dict__.__contains__('__next__') == True — cycle implements tp_iternext; '__next__' appears in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra96"]
    - [cycle_dict_not_contains_reduce,
       "cycle.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.cycle.__dict__.__contains__('__reduce__') == False — cycle does not define its own __reduce__ in Python 3.14.3; mappingproxy.__contains__('__reduce__') returns False; new to extra96"]
    - [cycle_dict_not_contains_setstate,
       "cycle.__dict__.__contains__",
       ["__setstate__"],
       false,
       "itertools.cycle.__dict__.__contains__('__setstate__') == False — cycle does not define __setstate__ in Python 3.14.3; mappingproxy.__contains__('__setstate__') returns False; new to extra96"]
    - [count_dict_contains_iter,
       "count.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.count.__dict__.__contains__('__iter__') == True — count is a C extension type; __iter__ appears in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra96"]
    - [count_dict_contains_next,
       "count.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.count.__dict__.__contains__('__next__') == True — count implements tp_iternext; '__next__' appears in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra96"]
    - [count_dict_not_contains_reduce,
       "count.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.count.__dict__.__contains__('__reduce__') == False — count does not define its own __reduce__ in Python 3.14.3; mappingproxy.__contains__('__reduce__') returns False; new to extra96"]
    - [count_dict_contains_repr,
       "count.__dict__.__contains__",
       ["__repr__"],
       true,
       "itertools.count.__dict__.__contains__('__repr__') == True — count defines its own __repr__ to show current state (e.g. 'count(0)'); '__repr__' appears in the type __dict__; mappingproxy.__contains__('__repr__') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Table 3: repeat and islice __dict__ membership
#
# Wave 254 theme: itertools.repeat and islice type __dict__ membership.
#
# itertools.repeat.__dict__.__contains__('__iter__') == True
# itertools.repeat.__dict__.__contains__('__next__') == True
# itertools.repeat.__dict__.__contains__('__reduce__') == False
# itertools.repeat.__dict__.__contains__('__length_hint__') == True
# itertools.islice.__dict__.__contains__('__iter__') == True
# itertools.islice.__dict__.__contains__('__next__') == True
# itertools.islice.__dict__.__contains__('__reduce__') == False
#
# repeat uniquely has __length_hint__; islice has only the iterator protocol methods.
# New to extra96.
# ---------------------------------------------------------------------------

table itertools_extra96.repeat_islice_dict_membership:
  description: "itertools.repeat and islice __dict__ membership: __iter__/True, __next__/True, __reduce__/False; repeat has __length_hint__/True; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdictmem96

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_dict_contains_iter,
       "repeat.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.repeat.__dict__.__contains__('__iter__') == True — repeat is a C extension type; __iter__ appears in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra96"]
    - [repeat_dict_contains_next,
       "repeat.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.repeat.__dict__.__contains__('__next__') == True — repeat implements tp_iternext; '__next__' appears in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra96"]
    - [repeat_dict_not_contains_reduce,
       "repeat.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.repeat.__dict__.__contains__('__reduce__') == False — repeat does not define its own __reduce__ in Python 3.14.3; mappingproxy.__contains__('__reduce__') returns False; new to extra96"]
    - [repeat_dict_contains_length_hint,
       "repeat.__dict__.__contains__",
       ["__length_hint__"],
       true,
       "itertools.repeat.__dict__.__contains__('__length_hint__') == True — repeat(x, n) supports length hinting (n repetitions remaining); '__length_hint__' is defined in the type __dict__; mappingproxy.__contains__('__length_hint__') returns True; new to extra96"]
    - [islice_dict_contains_iter,
       "islice.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.islice.__dict__.__contains__('__iter__') == True — islice is a C extension type; __iter__ appears in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra96"]
    - [islice_dict_contains_next,
       "islice.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.islice.__dict__.__contains__('__next__') == True — islice implements tp_iternext; '__next__' appears in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra96"]
    - [islice_dict_not_contains_reduce,
       "islice.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.islice.__dict__.__contains__('__reduce__') == False — islice does not define its own __reduce__ in Python 3.14.3; mappingproxy.__contains__('__reduce__') returns False; new to extra96"]

# ---------------------------------------------------------------------------
# Table 4: All itertools type __dict__.__class__.__name__ == 'mappingproxy'
#
# Wave 254 theme: itertools C-type __dict__ is always a mappingproxy.
#
# itertools.chain.__dict__.__class__.__name__ == 'mappingproxy'
# itertools.cycle.__dict__.__class__.__name__ == 'mappingproxy'
# itertools.count.__dict__.__class__.__name__ == 'mappingproxy'
# itertools.repeat.__dict__.__class__.__name__ == 'mappingproxy'
# itertools.islice.__dict__.__class__.__name__ == 'mappingproxy'
# itertools.starmap.__dict__.__class__.__name__ == 'mappingproxy'
# itertools.product.__dict__.__class__.__name__ == 'mappingproxy'
#
# All C extension type __dict__ attributes are read-only mappingproxy objects.
# New to extra96.
# ---------------------------------------------------------------------------

table itertools_extra96.all_types_dict_class_name:
  description: "itertools chain/cycle/count/repeat/islice/starmap/product __dict__.__class__.__name__ == 'mappingproxy'; C extension type namespaces; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdictmem96

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_class_name_eq_mappingproxy,
       "chain.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy') == True — chain is a C extension type; its __dict__ is a read-only mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]
    - [cycle_dict_class_name_eq_mappingproxy,
       "cycle.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.cycle.__dict__.__class__.__name__.__eq__('mappingproxy') == True — cycle is a C extension type; __dict__ is a mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]
    - [count_dict_class_name_eq_mappingproxy,
       "count.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.count.__dict__.__class__.__name__.__eq__('mappingproxy') == True — count is a C extension type; __dict__ is a mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]
    - [repeat_dict_class_name_eq_mappingproxy,
       "repeat.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.repeat.__dict__.__class__.__name__.__eq__('mappingproxy') == True — repeat is a C extension type; __dict__ is a mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]
    - [islice_dict_class_name_eq_mappingproxy,
       "islice.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.islice.__dict__.__class__.__name__.__eq__('mappingproxy') == True — islice is a C extension type; __dict__ is a mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]
    - [starmap_dict_class_name_eq_mappingproxy,
       "starmap.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.starmap.__dict__.__class__.__name__.__eq__('mappingproxy') == True — starmap is a C extension type; __dict__ is a mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]
    - [product_dict_class_name_eq_mappingproxy,
       "product.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.product.__dict__.__class__.__name__.__eq__('mappingproxy') == True — product is a C extension type; __dict__ is a mappingproxy; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant itertools_extra96.chain_dict_contains_from_iterable:
  description: "itertools.chain.__dict__.__contains__('from_iterable') == True — alternative constructor classmethod in type __dict__; wave 254; new to extra96"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra96.chain_dict_not_contains_reduce:
  description: "itertools.chain.__dict__.__contains__('__reduce__') == False — __reduce__ not in chain's own __dict__ in Python 3.14.3; wave 254; new to extra96"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__reduce__"]
  expected: false

invariant itertools_extra96.repeat_dict_contains_length_hint:
  description: "itertools.repeat.__dict__.__contains__('__length_hint__') == True — repeat supports length hinting when given a count; wave 254; new to extra96"
  kind: python_call_eq
  function: repeat.__dict__.__contains__
  args: ["__length_hint__"]
  expected: true

invariant itertools_extra96.count_dict_contains_repr:
  description: "itertools.count.__dict__.__contains__('__repr__') == True — count defines its own __repr__ for state display; wave 254; new to extra96"
  kind: python_call_eq
  function: count.__dict__.__contains__
  args: ["__repr__"]
  expected: true

invariant itertools_extra96.product_dict_class_name_eq_mappingproxy:
  description: "itertools.product.__dict__.__class__.__name__ == 'mappingproxy' — C extension type namespace is always mappingproxy; wave 254; new to extra96"
  kind: python_call_eq
  function: product.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
