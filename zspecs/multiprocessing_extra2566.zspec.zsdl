spec: multiprocessing_extra2566
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "multiprocessing.queues.Queue, SimpleQueue, and JoinableQueue define NONE of __getattr__, __setattr__, or __delattr__ in their class __dict__."
    - "multiprocessing.pool.Pool likewise defines none of these three dunders."
    - "multiprocessing.Process (the platform-specific subclass) has almost nothing in its own __dict__; all core methods live in BaseProcess, which also defines none of the three dunders."
    - "multiprocessing.queues.Queue.__dict__ contains __init__, put, get, qsize, empty, full, join_thread."
    - "multiprocessing.queues.SimpleQueue.__dict__ contains __init__, put, get, empty, close."
    - "multiprocessing.queues.JoinableQueue.__dict__ contains __init__, put, join, task_done (no get — inherited from Queue)."
    - "multiprocessing.pool.Pool.__dict__ contains __init__, __repr__, apply, map, starmap, close, terminate, join."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue — attribute access protocol absent
# ---------------------------------------------------------------------------

table multiprocessing_extra2566.queue_attr_protocol:
  description: "multiprocessing.queues.Queue defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2566

  columns: [id, function, args, expected]
  rows:
    - ["mp2566001", "multiprocessing.queues.Queue.__dict__.__contains__", ["__getattr__"], false]
    - ["mp2566002", "multiprocessing.queues.Queue.__dict__.__contains__", ["__setattr__"], false]
    - ["mp2566003", "multiprocessing.queues.Queue.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue — positive presence of core API in __dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra2566.queue_dict_positive:
  description: "multiprocessing.queues.Queue core methods are defined directly in the class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2566

  columns: [id, function, args, expected]
  rows:
    - ["mp2566004", "multiprocessing.queues.Queue.__dict__.__contains__", ["__init__"],    true]
    - ["mp2566005", "multiprocessing.queues.Queue.__dict__.__contains__", ["put"],         true]
    - ["mp2566006", "multiprocessing.queues.Queue.__dict__.__contains__", ["get"],         true]
    - ["mp2566007", "multiprocessing.queues.Queue.__dict__.__contains__", ["qsize"],       true]
    - ["mp2566008", "multiprocessing.queues.Queue.__dict__.__contains__", ["empty"],       true]
    - ["mp2566009", "multiprocessing.queues.Queue.__dict__.__contains__", ["full"],        true]
    - ["mp2566010", "multiprocessing.queues.Queue.__dict__.__contains__", ["join_thread"], true]

