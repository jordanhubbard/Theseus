spec: asyncio_extra242
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers asyncio.Event class identity and method name contracts."
    - "asyncio.Event.__name__ == 'Event' — 5 characters."
    - "asyncio.Event.__module__ == 'asyncio.locks' — defined in the locks submodule (13 chars)."
    - "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' — Event inherits from _LoopBoundMixin, not object."
    - "Event.set.__name__ == 'set'; __qualname__ == 'Event.set' (9 chars)."
    - "Event.clear.__name__ == 'clear'; __qualname__ == 'Event.clear' (11 chars)."
    - "Event.is_set.__name__ == 'is_set'; __qualname__ == 'Event.is_set' (13 chars)."
    - "Event.wait.__name__ == 'wait'; __qualname__ == 'Event.wait' (10 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Event class identity contracts
#
# Verifies __name__, __module__ to confirm the class is defined in
# asyncio.locks and carries the expected identity attributes.
# ---------------------------------------------------------------------------

table asyncio_extra242.event_class_identity:
  description: "asyncio.Event class identity: name, module; new to extra242"
  kind: python_call_eq
  category: class_identity
  id_prefix: aioevent242

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "asyncio.Event.__name__.__eq__('Event') == True — class carries unqualified name 'Event'; new to extra242"]
    - [event_module_eq,
       Event.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Event.__module__.__eq__('asyncio.locks') == True — Event defined in asyncio.locks submodule; new to extra242"]
    - [event_name_len_5,
       Event.__name__.__len__,
       [],
       5,
       "asyncio.Event.__name__.__len__() == 5 — 'Event' has exactly 5 characters; new to extra242"]
    - [event_module_len_13,
       Event.__module__.__len__,
       [],
       13,
       "asyncio.Event.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; new to extra242"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Event base class contract
#
# Event.__bases__[0].__name__ == '_LoopBoundMixin' — inherits from _LoopBoundMixin.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table asyncio_extra242.event_base_class:
  description: "asyncio.Event base class identity; new to extra242"
  kind: python_call_eq
  category: class_identity
  id_prefix: aioevent242b

  columns: [id, function, args, expected, description]
  rows:
    - [event_base_name_eq,
       "Event.__bases__[0].__name__.__eq__",
       ["_LoopBoundMixin"],
       true,
       "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') == True — Event inherits from _LoopBoundMixin; new to extra242"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Event method __name__ contracts
#
# set, clear, is_set, wait each carry their simple __name__.
# ---------------------------------------------------------------------------

table asyncio_extra242.event_method_names:
  description: "asyncio.Event method __name__ contracts; new to extra242"
  kind: python_call_eq
  category: method_names
  id_prefix: aioevtm242

  columns: [id, function, args, expected, description]
  rows:
    - [set_name_eq,
       Event.set.__name__.__eq__,
       ["set"],
       true,
       "asyncio.Event.set.__name__.__eq__('set') == True — method carries its simple name; new to extra242"]
    - [clear_name_eq,
       Event.clear.__name__.__eq__,
       ["clear"],
       true,
       "asyncio.Event.clear.__name__.__eq__('clear') == True — method carries its simple name; new to extra242"]
    - [is_set_name_eq,
       Event.is_set.__name__.__eq__,
       ["is_set"],
       true,
       "asyncio.Event.is_set.__name__.__eq__('is_set') == True — method carries its simple name; new to extra242"]
    - [wait_name_eq,
       Event.wait.__name__.__eq__,
       ["wait"],
       true,
       "asyncio.Event.wait.__name__.__eq__('wait') == True — method carries its simple name; new to extra242"]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Event method __qualname__ contracts
#
# set, clear, is_set, wait carry qualname 'Event.<method>'.
# ---------------------------------------------------------------------------

table asyncio_extra242.event_method_qualnames:
  description: "asyncio.Event method __qualname__ contracts; new to extra242"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aioevtm242

  columns: [id, function, args, expected, description]
  rows:
    - [set_qualname_eq,
       Event.set.__qualname__.__eq__,
       ["Event.set"],
       true,
       "asyncio.Event.set.__qualname__ == 'Event.set' (9 chars); new to extra242"]
    - [clear_qualname_eq,
       Event.clear.__qualname__.__eq__,
       ["Event.clear"],
       true,
       "asyncio.Event.clear.__qualname__ == 'Event.clear' (11 chars); new to extra242"]
    - [is_set_qualname_eq,
       Event.is_set.__qualname__.__eq__,
       ["Event.is_set"],
       true,
       "asyncio.Event.is_set.__qualname__ == 'Event.is_set' (13 chars); new to extra242"]
    - [wait_qualname_eq,
       Event.wait.__qualname__.__eq__,
       ["Event.wait"],
       true,
       "asyncio.Event.wait.__qualname__ == 'Event.wait' (10 chars); new to extra242"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra242
# ---------------------------------------------------------------------------

invariant asyncio_extra242.Event.name:
  description: "asyncio.Event.__name__ == 'Event'; new to extra242"
  category: class_identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant asyncio_extra242.Event.module:
  description: "asyncio.Event.__module__ == 'asyncio.locks'; new to extra242"
  category: class_identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra242.Event.name_len:
  description: "asyncio.Event.__name__.__len__() == 5 — 'Event' has 5 characters; new to extra242"
  category: class_identity
  kind: python_call_eq
  function: Event.__name__.__len__
  args: []
  expected: 5

invariant asyncio_extra242.Event.module_len:
  description: "asyncio.Event.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; new to extra242"
  category: class_identity
  kind: python_call_eq
  function: Event.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra242.Event.base_name:
  description: "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' — inherits from _LoopBoundMixin; new to extra242"
  category: class_identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra242.Event.set_name:
  description: "asyncio.Event.set.__name__ == 'set'; new to extra242"
  category: method_names
  kind: python_call_eq
  function: Event.set.__name__.__eq__
  args: ["set"]
  expected: true

invariant asyncio_extra242.Event.set_qualname:
  description: "asyncio.Event.set.__qualname__ == 'Event.set'; new to extra242"
  category: method_qualnames
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant asyncio_extra242.Event.clear_name:
  description: "asyncio.Event.clear.__name__ == 'clear'; new to extra242"
  category: method_names
  kind: python_call_eq
  function: Event.clear.__name__.__eq__
  args: ["clear"]
  expected: true

invariant asyncio_extra242.Event.clear_qualname:
  description: "asyncio.Event.clear.__qualname__ == 'Event.clear'; new to extra242"
  category: method_qualnames
  kind: python_call_eq
  function: Event.clear.__qualname__.__eq__
  args: ["Event.clear"]
  expected: true

invariant asyncio_extra242.Event.is_set_name:
  description: "asyncio.Event.is_set.__name__ == 'is_set'; new to extra242"
  category: method_names
  kind: python_call_eq
  function: Event.is_set.__name__.__eq__
  args: ["is_set"]
  expected: true

invariant asyncio_extra242.Event.is_set_qualname:
  description: "asyncio.Event.is_set.__qualname__ == 'Event.is_set'; new to extra242"
  category: method_qualnames
  kind: python_call_eq
  function: Event.is_set.__qualname__.__eq__
  args: ["Event.is_set"]
  expected: true

invariant asyncio_extra242.Event.wait_name:
  description: "asyncio.Event.wait.__name__ == 'wait'; new to extra242"
  category: method_names
  kind: python_call_eq
  function: Event.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant asyncio_extra242.Event.wait_qualname:
  description: "asyncio.Event.wait.__qualname__ == 'Event.wait'; new to extra242"
  category: method_qualnames
  kind: python_call_eq
  function: Event.wait.__qualname__.__eq__
  args: ["Event.wait"]
  expected: true
