spec: threading_extra736
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers threading.Thread and Barrier property qualnames"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra736.thread_property_qualnames:
  description: "Qualname checks for threading.Thread properties"
  kind: python_call_eq
  category: identity
  id_prefix: th736tp
  columns: [id, function, args, expected]
  rows:
    - [th736tp001, threading.Thread.name.__qualname__.__eq__, ["Thread.name"], true]
    - [th736tp002, threading.Thread.daemon.__qualname__.__eq__, ["Thread.daemon"], true]
    - [th736tp003, threading.Thread.ident.__qualname__.__eq__, ["Thread.ident"], true]
    - [th736tp004, threading.Thread.native_id.__qualname__.__eq__, ["Thread.native_id"], true]

table threading_extra736.thread_class_identity:
  description: "Class-level identity checks for threading.Thread"
  kind: python_call_eq
  category: identity
  id_prefix: th736tc
  columns: [id, function, args, expected]
  rows:
    - [th736tc001, threading.Thread.__qualname__.__eq__, ["Thread"], true]
    - [th736tc002, threading.Thread.__module__.__eq__, ["threading"], true]
    - [th736tc003, threading.Thread.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra736.barrier_property_qualnames:
  description: "Qualname checks for threading.Barrier properties"
  kind: python_call_eq
  category: identity
  id_prefix: th736bp
  columns: [id, function, args, expected]
  rows:
    - [th736bp001, threading.Barrier.parties.__qualname__.__eq__, ["Barrier.parties"], true]
    - [th736bp002, threading.Barrier.n_waiting.__qualname__.__eq__, ["Barrier.n_waiting"], true]
    - [th736bp003, threading.Barrier.broken.__qualname__.__eq__, ["Barrier.broken"], true]

table threading_extra736.barrier_class_identity:
  description: "Class-level identity checks for threading.Barrier"
  kind: python_call_eq
  category: identity
  id_prefix: th736bc
  columns: [id, function, args, expected]
  rows:
    - [th736bc001, threading.Barrier.__qualname__.__eq__, ["Barrier"], true]
    - [th736bc002, threading.Barrier.__module__.__eq__, ["threading"], true]
