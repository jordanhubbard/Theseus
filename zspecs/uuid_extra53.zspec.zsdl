spec: uuid_extra53
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra52.zspec.zsdl — covers UUID.__setattr__/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__.__eq__ string values (table + invariants)."
    - "uuid_extra51.zspec.zsdl — covers uuid.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / UUID.__ne__.__qualname__.__eq__('object.__ne__') (table + invariants)."
    - "uuid_extra50.zspec.zsdl — covers uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version .fget.__qualname__.__eq__."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values for time/node/clock_seq/time_hi_version/clock_seq_hi_variant."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__.__qualname__.__eq__ and __qualname__.__len__()."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra52; it does NOT duplicate invariants present in those files."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "uuid4, uuid1, uuid3, uuid5 are pure Python functions defined in Lib/uuid.py. All four have __annotations__ attributes that are empty dicts — none define type annotations. uuid_extra41 checks __doc__.__class__.__name__.__eq__('str') for uuid4/uuid1/uuid3/uuid5 (doc type identity); no prior uuid spec checks __annotations__.__class__.__name__.__eq__('dict') or __annotations__.__len__() for any uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__annotations__ == {} (empty dict, len 0). uuid1, uuid3, uuid5 also have empty __annotations__ dicts. This is expected: uuid module functions are written without type annotations. The __annotations__.__class__.__name__.__eq__('dict') chain confirms the dict type identity; __annotations__.__len__()==0 confirms emptiness. No prior uuid spec checks any of these chains. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__globals__ is the uuid module's global namespace dict. It contains 'UUID' (the class), 'uuid4', 'uuid1', 'uuid3', 'uuid5', and many other uuid module-level names. No prior uuid spec checks uuid4.__globals__.__class__.__name__.__eq__('dict') or uuid4.__globals__.__contains__('UUID'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__ is a multi-line docstring starting 'Instances of the UUID class represent UUIDs as specified in RFC 4122.' The string 'UUID' appears in the very first word of the docstring. uuid_extra41 checks UUID.__doc__.__class__.__name__.__eq__('str') (type identity axis); no prior uuid spec checks UUID.__doc__.__contains__('UUID') for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4/uuid1/uuid3/uuid5 __annotations__ class identity
#
# Wave 228 theme: __annotations__ class identity checks.
#
# uuid4, uuid1, uuid3, uuid5 are pure Python functions in Lib/uuid.py.
# All have __annotations__ attributes that are empty dicts.
# uuid_extra41 checks __doc__.__class__.__name__.__eq__('str') for these
# functions (doc type identity axis), but no prior uuid spec checks
# __annotations__.__class__.__name__.__eq__('dict') for any uuid function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra53.uuid_func_annotations_class_name:
  description: "uuid4/uuid1/uuid3/uuid5 __annotations__.__class__.__name__.__eq__('dict') — all four are pure Python functions in Lib/uuid.py with empty dict annotations; uuid_extra41 covers __doc__.__class__.__name__.__eq__('str') for these functions; no prior uuid spec checks __annotations__.__class__.__name__.__eq__('dict') for any uuid function"
  kind: python_call_eq
  category: annotations
  id_prefix: uuidann53

  columns: [id, function, args, expected]
  rows:
    - [uuid4_annotations_class_name_eq, uuid4.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [uuid1_annotations_class_name_eq, uuid1.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [uuid3_annotations_class_name_eq, uuid3.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [uuid5_annotations_class_name_eq, uuid5.__annotations__.__class__.__name__.__eq__, ["dict"], true]

# ---------------------------------------------------------------------------
# uuid4/uuid1/uuid3/uuid5 __annotations__ emptiness
#
# All four uuid generator functions have zero-entry __annotations__ dicts.
# __len__()==0 confirms the dict is empty (no type annotations present).
# No prior uuid spec checks __annotations__.__len__() for any uuid function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra53.uuid_func_annotations_len:
  description: "uuid4/uuid1/uuid3/uuid5 __annotations__.__len__()==0 — empty annotation dicts; Python functions in Lib/uuid.py define no type annotations; no prior uuid spec checks __annotations__.__len__() for any uuid function"
  kind: python_call_eq
  category: annotations
  id_prefix: uuidann53

  columns: [id, function, args, expected]
  rows:
    - [uuid4_annotations_len, uuid4.__annotations__.__len__, [], 0]
    - [uuid1_annotations_len, uuid1.__annotations__.__len__, [], 0]
    - [uuid3_annotations_len, uuid3.__annotations__.__len__, [], 0]
    - [uuid5_annotations_len, uuid5.__annotations__.__len__, [], 0]

# ---------------------------------------------------------------------------
# uuid4.__globals__ class identity and key membership
#
# Wave 228 theme: __globals__ dict keys.
#
# uuid4.__globals__ is the uuid module's global namespace dict. It is a dict
# and contains 'UUID' (the central class of the module). No prior uuid spec
# checks uuid4.__globals__.__class__.__name__.__eq__('dict') or
# uuid4.__globals__.__contains__('UUID'). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra53.uuid4_globals_class_and_contains:
  description: "uuid4.__globals__.__class__.__name__.__eq__('dict') and __contains__('UUID') — uuid4.__globals__ is the uuid module namespace dict; 'UUID' is present as a top-level class name; no prior uuid spec checks uuid4.__globals__ in any form"
  kind: python_call_eq
  category: globals
  id_prefix: uuidann53

  columns: [id, function, args, expected]
  rows:
    - [uuid4_globals_class_name_eq,   uuid4.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [uuid4_globals_contains_UUID,   uuid4.__globals__.__contains__,              ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__ content check
#
# Wave 228 theme: __doc__.__contains__ content checks.
#
# uuid.UUID.__doc__ starts with 'Instances of the UUID class represent UUIDs
# as specified in RFC 4122.' The string 'UUID' appears at multiple points.
# uuid_extra41 checks UUID.__doc__.__class__.__name__.__eq__('str') (type
# identity axis). No prior uuid spec checks UUID.__doc__.__contains__ for any
# keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra53.UUID_doc_contains:
  description: "uuid.UUID.__doc__.__contains__('UUID') — class docstring begins 'Instances of the UUID class represent UUIDs as specified in RFC 4122.'; uuid_extra41 covers UUID.__doc__.__class__.__name__.__eq__('str') (type identity axis); no prior uuid spec checks UUID.__doc__.__contains__ for any keyword; first doc content check for UUID"
  kind: python_call_eq
  category: docstrings
  id_prefix: uuidann53

  columns: [id, function, args, expected]
  rows:
    - [UUID_doc_contains_UUID, "UUID.__doc__.__contains__", ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid4.__annotations__.__class__.__name__.__eq__('dict') — standalone
#
# uuid4 is the most commonly used uuid generator function. Its __annotations__
# attribute is an empty dict — uuid4 defines no type annotations. The attribute
# chain __annotations__.__class__.__name__.__eq__('dict') confirms the dict
# type identity of the annotations object. No prior uuid spec checks
# uuid4.__annotations__ in any form. First annotations anchor for any uuid
# function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra53.uuid4_annotations_class_name_dict:
  description: "uuid.uuid4.__annotations__.__class__.__name__.__eq__('dict') == True — uuid4 is a pure Python function in Lib/uuid.py; __annotations__ is an empty dict with no type annotations; no prior uuid spec checks uuid4.__annotations__.__class__.__name__.__eq__('dict'); first __annotations__ class identity anchor for any uuid function"
  category: annotations
  kind: python_call_eq
  function: uuid4.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__globals__.__contains__('UUID') — standalone
#
# uuid4.__globals__ is the uuid module's global namespace. The key 'UUID'
# is present there — UUID is the central class defined at module level.
# This is the first check confirming a specific key membership in
# uuid4.__globals__. No prior uuid spec checks __globals__.__contains__
# for any uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra53.uuid4_globals_contains_UUID_key:
  description: "uuid.uuid4.__globals__.__contains__('UUID') == True — uuid4.__globals__ is the uuid module namespace dict; 'UUID' is present as the central class confirming it is bound at module level in uuid4's defining scope; no prior uuid spec checks __globals__.__contains__ for any uuid function; first globals membership anchor for uuid"
  category: globals
  kind: python_call_eq
  function: uuid4.__globals__.__contains__
  args: ["UUID"]
  expected: true
