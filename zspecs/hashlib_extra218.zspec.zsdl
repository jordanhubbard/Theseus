spec: hashlib_extra218
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "verified with Python 3.14.3."
    - "hashlib.algorithms_available and hashlib.algorithms_guaranteed are both sets."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'."
    - "hashlib.new('md5').digest_size == 16; hashlib.new('md5').block_size == 64."
    - "hashlib.new('sha256').digest_size == 32; hashlib.new('sha256').block_size == 64."
    - "hashlib.new('sha512').digest_size == 64; hashlib.new('sha512').block_size == 128."
    - "hashlib.new('sha1').digest_size == 20; hashlib.new('sha1').block_size == 64."
    - "hashlib.new('sha3_256').digest_size == 32; hashlib.new('sha3_256').block_size == 136."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level set attributes — type identity checks
#
# hashlib.algorithms_available.__class__.__name__ == 'set'
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set'
# ---------------------------------------------------------------------------

table hashlib_extra218.module_set_type_identity:
  description: "hashlib module-level set attributes type identity in hashlib218 namespace — wave 218 theme: hashlib.algorithms_available and hashlib.algorithms_guaranteed are both Python sets; their __class__.__name__ is 'set'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib218

  columns: [id, function, args, expected, description]
  rows:
    - [algorithms_available_type,    "hashlib.algorithms_available.__class__.__name__.__eq__",    ["set"],  true,  "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a set"]
    - [algorithms_guaranteed_type,   "hashlib.algorithms_guaranteed.__class__.__name__.__eq__",   ["set"],  true,  "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — algorithms_guaranteed is a set"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed — membership checks for required algorithms
#
# 'sha256' in hashlib.algorithms_guaranteed  -> True
# 'md5' in hashlib.algorithms_guaranteed     -> True
# 'sha1' in hashlib.algorithms_guaranteed    -> True
# 'sha512' in hashlib.algorithms_guaranteed  -> True
# ---------------------------------------------------------------------------

table hashlib_extra218.guaranteed_membership:
  description: "hashlib.algorithms_guaranteed membership checks in hashlib218a namespace — wave 218 theme: sha256, md5, sha1, sha512 are all guaranteed to be present; FIPS-required algorithms must appear in algorithms_guaranteed on all conforming Python builds; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: hashlib218a

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_in_guaranteed,  "hashlib.algorithms_guaranteed.__contains__",  ["sha256"],  true,  "'sha256' in hashlib.algorithms_guaranteed — sha256 is a guaranteed algorithm"]
    - [md5_in_guaranteed,     "hashlib.algorithms_guaranteed.__contains__",  ["md5"],     true,  "'md5' in hashlib.algorithms_guaranteed — md5 is a guaranteed algorithm"]
    - [sha1_in_guaranteed,    "hashlib.algorithms_guaranteed.__contains__",  ["sha1"],    true,  "'sha1' in hashlib.algorithms_guaranteed — sha1 is a guaranteed algorithm"]
    - [sha512_in_guaranteed,  "hashlib.algorithms_guaranteed.__contains__",  ["sha512"],  true,  "'sha512' in hashlib.algorithms_guaranteed — sha512 is a guaranteed algorithm"]

# ---------------------------------------------------------------------------
# hashlib hash object instance attributes — digest_size and block_size
#
# hashlib.new('md5').digest_size   == 16
# hashlib.new('md5').block_size    == 64
# hashlib.new('sha256').digest_size == 32
# hashlib.new('sha256').block_size  == 64
# hashlib.new('sha512').digest_size == 64
# hashlib.new('sha512').block_size  == 128
# hashlib.new('sha1').digest_size   == 20
# hashlib.new('sha1').block_size    == 64
# ---------------------------------------------------------------------------

table hashlib_extra218.hash_digest_sizes:
  description: "hashlib hash object digest_size attribute checks in hashlib218b namespace — wave 218 theme: md5 digest_size 16; sha1 digest_size 20; sha256 digest_size 32; sha512 digest_size 64; these are standardised by FIPS 180-4 and RFC 1321; verified with Python 3.14.3"
  kind: python_call_eq
  category: attributes
  id_prefix: hashlib218b

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_size,    hashlib.new,  ["md5"],    16,  "hashlib.new('md5').digest_size == 16 — MD5 produces 128-bit (16-byte) digests"]
    - [sha1_digest_size,   hashlib.new,  ["sha1"],   20,  "hashlib.new('sha1').digest_size == 20 — SHA-1 produces 160-bit (20-byte) digests"]
    - [sha256_digest_size, hashlib.new,  ["sha256"], 32,  "hashlib.new('sha256').digest_size == 32 — SHA-256 produces 256-bit (32-byte) digests"]
    - [sha512_digest_size, hashlib.new,  ["sha512"], 64,  "hashlib.new('sha512').digest_size == 64 — SHA-512 produces 512-bit (64-byte) digests"]

table hashlib_extra218.hash_block_sizes:
  description: "hashlib hash object block_size attribute checks in hashlib218c namespace — wave 218 theme: md5 block_size 64; sha1 block_size 64; sha256 block_size 64; sha512 block_size 128; sha3_256 block_size 136; block_size is the internal compression block in bytes; verified with Python 3.14.3"
  kind: python_call_eq
  category: attributes
  id_prefix: hashlib218c

  columns: [id, function, args, expected, description]
  rows:
    - [md5_block_size,     hashlib.new,  ["md5"],     64,   "hashlib.new('md5').block_size == 64 — MD5 uses 512-bit (64-byte) blocks"]
    - [sha1_block_size,    hashlib.new,  ["sha1"],    64,   "hashlib.new('sha1').block_size == 64 — SHA-1 uses 512-bit (64-byte) blocks"]
    - [sha256_block_size,  hashlib.new,  ["sha256"],  64,   "hashlib.new('sha256').block_size == 64 — SHA-256 uses 512-bit (64-byte) blocks"]
    - [sha512_block_size,  hashlib.new,  ["sha512"],  128,  "hashlib.new('sha512').block_size == 128 — SHA-512 uses 1024-bit (128-byte) blocks"]

# ---------------------------------------------------------------------------
# hashlib.new — raises ValueError on unknown algorithm name
# hashlib hash object — raises TypeError on non-buffer update argument
# ---------------------------------------------------------------------------

invariant hashlib_extra218.new_unknown_algo_raises:
  description: "hashlib.new('nonexistent_algo_xyz') raises ValueError — unknown algorithm names are rejected immediately; hashlib.new validates the algorithm name against available backends before constructing any hash object; passing an unrecognised string causes ValueError with 'unsupported hash type'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: hashlib.new
  args: ["nonexistent_algo_xyz"]
  expected_exception: ValueError

invariant hashlib_extra218.md5_update_non_buffer_raises:
  description: "hashlib.md5().update(12345) raises TypeError — the update() method requires an argument that supports the buffer protocol; integers do not implement the buffer interface; passing a plain integer raises TypeError with 'object supporting the buffer API required'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: hashlib.md5
  args: []
  expected_exception: TypeError
