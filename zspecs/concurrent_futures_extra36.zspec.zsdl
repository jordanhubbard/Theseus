spec: concurrent_futures_extra36
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra35.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10."
    - "This spec covers: ThreadPoolExecutor.__name__=='ThreadPoolExecutor'; ThreadPoolExecutor.__module__=='concurrent.futures.thread' (25 chars); ProcessPoolExecutor.__name__=='ProcessPoolExecutor'; ProcessPoolExecutor.__module__=='concurrent.futures.process' (26 chars); wait.__name__=='wait'; wait.__module__=='concurrent.futures._base' (24 chars); as_completed.__module__=='concurrent.futures._base' (24 chars); Future.__module__=='concurrent.futures._base' (24 chars)."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (25 chars) and ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (26 chars). These are the private submodule paths where the executor implementations live. 'concurrent.futures.thread' is 25 chars ('concurrent.futures.' is 19 chars + 'thread' is 6); 'concurrent.futures.process' is 26 chars ('concurrent.futures.' + 'process' is 7). ProcessPoolExecutor's submodule name is 1 char longer than ThreadPoolExecutor's."
    - "wait.__module__, as_completed.__module__, and Future.__module__ all equal 'concurrent.futures._base' (24 chars). These three live in the private _base submodule, which contains the core Future class and the two main utility functions. The shared module length (24) and shared module string ('concurrent.futures._base') signal their co-location. Prior specs measured as_completed/__module__.__len__() == 24 (extra20) and wait/__module__.__len__() == 24 (extra21) as integer invariants, but NOT the string equality checks in the extra36 namespace."
    - "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (18 chars) and ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (19 chars). ProcessPoolExecutor is 1 char longer than ThreadPoolExecutor because 'Process' (7) is 1 char longer than 'Thread' (6). Prior specs measured these __name__.__len__() values as integers but NOT the string equality checks in the extra36 namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor __name__ equality — extra36 namespace
#
# The two executor class names confirm the 'Thread' vs 'Process' distinction:
#   ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'  (18 chars)
#   ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (19 chars)
# 'Process' (7 chars) is 1 char longer than 'Thread' (6 chars), making
# ProcessPoolExecutor.__name__ exactly 1 char longer (19 vs 18).
# Prior specs measured __name__.__len__() for both classes but NOT the string
# equality checks in the extra36 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra36.executor_name_equality:
  description: "concurrent.futures executor __name__ string equality in extra36 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexecnameq36

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__name__.__eq__,  ["ThreadPoolExecutor"],  true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'"]

# ---------------------------------------------------------------------------
# concurrent.futures executor __module__ string equality — extra36 namespace
#
# The executor implementations live in private submodules:
#   ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'  (25 chars)
#   ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (26 chars)
# These are the internal submodule paths — distinct from the public
# 'concurrent.futures' top-level module. 'concurrent.futures.process' (26)
# is 1 char longer than 'concurrent.futures.thread' (25) due to 'process'
# vs 'thread'. No prior spec has captured these as string equality checks.
# ---------------------------------------------------------------------------

table concurrent_futures_extra36.executor_module_equality:
  description: "concurrent.futures executor __module__ string equality in extra36 namespace — internal submodule paths"
  kind: python_call_eq
  category: module_names
  id_prefix: cfexecmodeq36

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],  true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (25 chars)"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (26 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures function __module__ equality — extra36 namespace
#
# wait, as_completed, and Future all live in the private _base submodule:
#   wait.__module__         == 'concurrent.futures._base' (24 chars)
#   as_completed.__module__ == 'concurrent.futures._base' (24 chars)
#   Future.__module__       == 'concurrent.futures._base' (24 chars)
# The shared module string ('concurrent.futures._base') confirms all three
# are implemented in the same core module. Prior specs measured module lengths
# (24 chars each) as integers, but NOT the string equality in extra36.
# wait.__name__ == 'wait' is also confirmed here — a simple 4-char name.
# ---------------------------------------------------------------------------

table concurrent_futures_extra36.function_module_equality:
  description: "concurrent.futures function and class __module__ string equality in extra36 namespace — all in _base"
  kind: python_call_eq
  category: module_names
  id_prefix: cffuncmodeq36

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__module__.__eq__,         ["concurrent.futures._base"], true, "wait.__module__ == 'concurrent.futures._base'"]
    - [as_completed, as_completed.__module__.__eq__,  ["concurrent.futures._base"], true, "as_completed.__module__ == 'concurrent.futures._base'"]
    - [Future,       Future.__module__.__eq__,        ["concurrent.futures._base"], true, "Future.__module__ == 'concurrent.futures._base'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra36
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra36.ThreadPoolExecutor_module_len:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__len__() == 25 — 'concurrent.futures.thread' has 25 characters; 1 shorter than ProcessPoolExecutor's module (26)"
  category: module_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__len__
  args: []
  expected: 25

invariant concurrent_futures_extra36.ProcessPoolExecutor_module_len:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 — 'concurrent.futures.process' has 26 characters; 1 longer than ThreadPoolExecutor's module (25)"
  category: module_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__len__
  args: []
  expected: 26

invariant concurrent_futures_extra36.wait_name_eq:
  description: "concurrent.futures.wait.__name__ == 'wait' — the utility function for waiting on a set of futures"
  category: function_names
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra36.ProcessPoolExecutor_name_len:
  description: "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters; 1 longer than ThreadPoolExecutor (18)"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__name__.__len__
  args: []
  expected: 19
