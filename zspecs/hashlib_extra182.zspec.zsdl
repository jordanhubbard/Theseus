spec: hashlib_extra182
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_sha3.c"
  notes:
    - "This spec covers: hashlib SHA-3 digest sizes — hashlib.sha3_224().digest_size.__eq__(28); hashlib.sha3_256().digest_size.__eq__(32); hashlib.sha3_384().digest_size.__eq__(48); hashlib.sha3_512().digest_size.__eq__(64); hashlib.sha3_224().__class__.__name__=='sha3_224'; hashlib.sha3_256().__class__.__name__=='sha3_256'; hashlib.shake_128().digest_size.__eq__(0) (SHAKE has variable output; digest_size is 0); hashlib.shake_256().digest_size.__eq__(0); hashlib.sha3_256().__class__.__module__=='_sha3'."
    - "SHA-3 digest_size values: sha3_224 → 28 bytes; sha3_256 → 32 bytes; sha3_384 → 48 bytes; sha3_512 → 64 bytes. These are fixed-output lengths defined by NIST FIPS 202."
    - "SHAKE-128 and SHAKE-256 are extendable-output functions (XOF); they do not have a fixed output length, so digest_size is 0 on their hash objects."
    - "SHA-3 hash objects' __class__.__module__ is '_sha3' (the C extension module that implements SHA-3), not 'hashlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: SHA-3 fixed-output digest_size values
#
# hashlib.sha3_224().digest_size == 28
# hashlib.sha3_256().digest_size == 32
# hashlib.sha3_384().digest_size == 48
# hashlib.sha3_512().digest_size == 64
#
# Each SHA-3 hash object exposes a digest_size attribute equal to the number
# of bytes in its fixed-length output, as mandated by NIST FIPS 202.
# New to extra182.
# ---------------------------------------------------------------------------

table hashlib_extra182.sha3_digest_sizes:
  description: "sha3_224 digest_size=28; sha3_256 digest_size=32; sha3_384 digest_size=48; sha3_512 digest_size=64; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3182

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_digest_size_28,
       "sha3_224().digest_size.__eq__",
       [28],
       true,
       "hashlib.sha3_224().digest_size.__eq__(28) == True — sha3_224 produces a 224-bit (28-byte) fixed-length digest per NIST FIPS 202; the digest_size attribute equals 28; int.__eq__(28) returns True; new to extra182"]
    - [sha3_256_digest_size_32,
       "sha3_256().digest_size.__eq__",
       [32],
       true,
       "hashlib.sha3_256().digest_size.__eq__(32) == True — sha3_256 produces a 256-bit (32-byte) fixed-length digest per NIST FIPS 202; the digest_size attribute equals 32; int.__eq__(32) returns True; new to extra182"]
    - [sha3_384_digest_size_48,
       "sha3_384().digest_size.__eq__",
       [48],
       true,
       "hashlib.sha3_384().digest_size.__eq__(48) == True — sha3_384 produces a 384-bit (48-byte) fixed-length digest per NIST FIPS 202; the digest_size attribute equals 48; int.__eq__(48) returns True; new to extra182"]
    - [sha3_512_digest_size_64,
       "sha3_512().digest_size.__eq__",
       [64],
       true,
       "hashlib.sha3_512().digest_size.__eq__(64) == True — sha3_512 produces a 512-bit (64-byte) fixed-length digest per NIST FIPS 202; the digest_size attribute equals 64; int.__eq__(64) returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Table 2: SHAKE extendable-output digest_size is 0
#
# hashlib.shake_128().digest_size == 0
# hashlib.shake_256().digest_size == 0
# hashlib.shake_128().digest_size.__eq__(0) == True
# hashlib.shake_256().digest_size.__eq__(0) == True
#
# SHAKE-128 and SHAKE-256 are extendable-output functions (XOF) defined in
# NIST FIPS 202.  Unlike fixed-output SHA-3 variants, their output length is
# caller-specified at digest() time.  CPython sets digest_size = 0 on XOF
# hash objects to signal the absence of a fixed output length.
# New to extra182.
# ---------------------------------------------------------------------------

table hashlib_extra182.shake_digest_size_zero:
  description: "shake_128 and shake_256 digest_size==0 (variable-output XOF; no fixed length); new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3182

  columns: [id, function, args, expected, description]
  rows:
    - [shake_128_digest_size_0,
       "shake_128().digest_size.__eq__",
       [0],
       true,
       "hashlib.shake_128().digest_size.__eq__(0) == True — SHAKE-128 is an XOF (extendable-output function); it has no fixed output length, so CPython sets digest_size=0 on the hash object; int.__eq__(0) returns True; new to extra182"]
    - [shake_256_digest_size_0,
       "shake_256().digest_size.__eq__",
       [0],
       true,
       "hashlib.shake_256().digest_size.__eq__(0) == True — SHAKE-256 is an XOF (extendable-output function); it has no fixed output length, so CPython sets digest_size=0 on the hash object; int.__eq__(0) returns True; new to extra182"]
    - [shake_128_digest_size_not_16,
       "shake_128().digest_size.__eq__",
       [16],
       false,
       "hashlib.shake_128().digest_size.__eq__(16) == False — SHAKE-128's digest_size is 0 (not 16, the security strength in bytes); digest_size reflects fixed output length, not security level; int.__eq__(16) returns False; new to extra182"]
    - [shake_256_digest_size_not_32,
       "shake_256().digest_size.__eq__",
       [32],
       false,
       "hashlib.shake_256().digest_size.__eq__(32) == False — SHAKE-256's digest_size is 0 (not 32, the security strength in bytes); the XOF has no fixed output length; int.__eq__(32) returns False; new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: SHA-3 hash object __class__.__name__ and __class__.__module__
#
# hashlib.sha3_224().__class__.__name__ == 'sha3_224'
# hashlib.sha3_256().__class__.__name__ == 'sha3_256'
# hashlib.sha3_256().__class__.__module__ == '_sha3'
# hashlib.sha3_224().__class__.__module__ == '_sha3'
#
# SHA-3 hash objects are instances of C-level types defined in the _sha3
# extension module.  Their __class__.__name__ matches the algorithm name;
# their __class__.__module__ is '_sha3', not 'hashlib'.
# New to extra182.
# ---------------------------------------------------------------------------

table hashlib_extra182.sha3_class_identity:
  description: "sha3_224 and sha3_256 hash objects: __class__.__name__ matches algorithm; __class__.__module__=='_sha3'; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3182

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_class_name,
       "sha3_224().__class__.__name__.__eq__",
       ["sha3_224"],
       true,
       "hashlib.sha3_224().__class__.__name__.__eq__('sha3_224') == True — sha3_224() returns a hash object whose type is the C-level sha3_224 type defined in _sha3; its __class__.__name__ is 'sha3_224'; str.__eq__('sha3_224') returns True; new to extra182"]
    - [sha3_256_class_name,
       "sha3_256().__class__.__name__.__eq__",
       ["sha3_256"],
       true,
       "hashlib.sha3_256().__class__.__name__.__eq__('sha3_256') == True — sha3_256() returns a hash object whose type is the C-level sha3_256 type defined in _sha3; its __class__.__name__ is 'sha3_256'; str.__eq__('sha3_256') returns True; new to extra182"]
    - [sha3_256_class_module_sha3,
       "sha3_256().__class__.__module__.__eq__",
       ["_sha3"],
       true,
       "hashlib.sha3_256().__class__.__module__.__eq__('_sha3') == True — the sha3_256 type is defined in the _sha3 C extension, not in the hashlib Python wrapper; __class__.__module__ is '_sha3'; str.__eq__('_sha3') returns True; new to extra182"]
    - [sha3_224_class_module_sha3,
       "sha3_224().__class__.__module__.__eq__",
       ["_sha3"],
       true,
       "hashlib.sha3_224().__class__.__module__.__eq__('_sha3') == True — the sha3_224 type is defined in the _sha3 C extension module; __class__.__module__ is '_sha3', not 'hashlib'; str.__eq__('_sha3') returns True; new to extra182"]
    - [sha3_256_class_not_hashlib,
       "sha3_256().__class__.__module__.__eq__",
       ["hashlib"],
       false,
       "hashlib.sha3_256().__class__.__module__.__eq__('hashlib') == False — the sha3_256 type lives in the _sha3 C extension, not in the hashlib module; __class__.__module__ is '_sha3'; str.__eq__('hashlib') returns False; new to extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra182
# ---------------------------------------------------------------------------

invariant hashlib_extra182.sha3_224_digest_size_28:
  description: "hashlib.sha3_224().digest_size == 28 — SHA-3/224 produces a 224-bit (28-byte) fixed-length digest per NIST FIPS 202; new to extra182"
  kind: python_call_eq
  function: sha3_224().digest_size.__eq__
  args: [28]
  expected: true

invariant hashlib_extra182.sha3_256_digest_size_32:
  description: "hashlib.sha3_256().digest_size == 32 — SHA-3/256 produces a 256-bit (32-byte) fixed-length digest per NIST FIPS 202; new to extra182"
  kind: python_call_eq
  function: sha3_256().digest_size.__eq__
  args: [32]
  expected: true

invariant hashlib_extra182.sha3_384_digest_size_48:
  description: "hashlib.sha3_384().digest_size == 48 — SHA-3/384 produces a 384-bit (48-byte) fixed-length digest per NIST FIPS 202; new to extra182"
  kind: python_call_eq
  function: sha3_384().digest_size.__eq__
  args: [48]
  expected: true

invariant hashlib_extra182.sha3_512_digest_size_64:
  description: "hashlib.sha3_512().digest_size == 64 — SHA-3/512 produces a 512-bit (64-byte) fixed-length digest per NIST FIPS 202; new to extra182"
  kind: python_call_eq
  function: sha3_512().digest_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra182.shake_128_digest_size_0:
  description: "hashlib.shake_128().digest_size == 0 — SHAKE-128 is an XOF with no fixed output length; CPython sets digest_size=0; new to extra182"
  kind: python_call_eq
  function: shake_128().digest_size.__eq__
  args: [0]
  expected: true

invariant hashlib_extra182.shake_256_digest_size_0:
  description: "hashlib.shake_256().digest_size == 0 — SHAKE-256 is an XOF with no fixed output length; CPython sets digest_size=0; new to extra182"
  kind: python_call_eq
  function: shake_256().digest_size.__eq__
  args: [0]
  expected: true

invariant hashlib_extra182.sha3_256_class_module_sha3:
  description: "hashlib.sha3_256().__class__.__module__ == '_sha3' — SHA-3 types are defined in the _sha3 C extension, not in the hashlib wrapper module; new to extra182"
  kind: python_call_eq
  function: sha3_256().__class__.__module__.__eq__
  args: ["_sha3"]
  expected: true

