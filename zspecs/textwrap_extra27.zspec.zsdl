spec: textwrap_extra27
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap_extra26.zspec.zsdl."
    - "Prior specs covered: TextWrapper/__name__/__module__/__qualname__/__bases__[0].__name__, wrap/fill/shorten/dedent/indent __name__/__module__/__qualname__, TextWrapper.wrap/fill/__name__/__qualname__, TextWrapper.__init__.__name__/__qualname__, TextWrapper.wrap.__qualname__.__len__()==16."
    - "This spec covers: textwrap.TextWrapper.__module__.__len__(), textwrap.TextWrapper.__name__.__len__(), textwrap.TextWrapper.__qualname__.__len__(), textwrap.wrap.__module__.__len__(), textwrap.fill.__module__.__len__(), textwrap.shorten.__module__.__len__(), textwrap.dedent.__module__.__len__(), textwrap.indent.__module__.__len__(), textwrap.wrap.__name__.__len__(), textwrap.fill.__name__.__len__(), textwrap.shorten.__name__.__len__(), textwrap.dedent.__name__.__len__()."
    - "textwrap.TextWrapper.__module__ == 'textwrap' — length 8. Verified at runtime."
    - "textwrap.TextWrapper.__name__ == 'TextWrapper' — length 11. Verified at runtime."
    - "textwrap.TextWrapper.__qualname__ == 'TextWrapper' — length 11. Verified at runtime."
    - "textwrap.wrap.__module__ == 'textwrap' — length 8. Verified at runtime."
    - "textwrap.fill.__module__ == 'textwrap' — length 8. Verified at runtime."
    - "textwrap.shorten.__module__ == 'textwrap' — length 8. Verified at runtime."
    - "textwrap.dedent.__module__ == 'textwrap' — length 8. Verified at runtime."
    - "textwrap.indent.__module__ == 'textwrap' — length 8. Verified at runtime."
    - "textwrap.wrap.__name__ == 'wrap' — length 4. Verified at runtime."
    - "textwrap.fill.__name__ == 'fill' — length 4. Verified at runtime."
    - "textwrap.shorten.__name__ == 'shorten' — length 7. Verified at runtime."
    - "textwrap.dedent.__name__ == 'dedent' — length 6. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.__module__ — __len__()
#
# Prior specs verify TextWrapper.__module__ == 'textwrap'. No prior spec verifies
# the length of TextWrapper.__module__ as a standalone invariant.
# len('textwrap') == 8. Verified at runtime: 8.
# ---------------------------------------------------------------------------

invariant textwrap_extra27.TextWrapper.module_len:
  description: "len(textwrap.TextWrapper.__module__) == 8 — 'textwrap' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.__name__ — __len__()
#
# Prior specs verify TextWrapper.__name__ == 'TextWrapper'. No prior spec verifies
# the length of TextWrapper.__name__ as a standalone invariant.
# len('TextWrapper') == 11. Verified at runtime: 11.
# ---------------------------------------------------------------------------

