# ---------------------------------------------------------------------------
# Table: TextWrapper class identifier __len__() values
#
# No prior spec groups TextWrapper.__module__.__len__, __name__.__len__, and
# __qualname__.__len__ into a single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra27.TextWrapper_identifier_lengths:
  description: "textwrap.TextWrapper __module__, __name__, __qualname__ lengths"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [module_len,
       TextWrapper.__module__.__len__,
       [],
       8,
       "len(TextWrapper.__module__) == 8"]
    - [name_len,
       TextWrapper.__name__.__len__,
       [],
       11,
       "len(TextWrapper.__name__) == 11"]
    - [qualname_len,
       TextWrapper.__qualname__.__len__,
       [],
       11,
       "len(TextWrapper.__qualname__) == 11"]

