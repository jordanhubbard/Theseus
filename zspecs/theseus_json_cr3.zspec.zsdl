spec: theseus_json_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_json_cr3)
blocks: json

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
  notes:
    - "Clean-room extended JSON utilities. Do NOT import json."
    - "JSONDecoder: class with decode(s) method."
    - "JSONEncoder: class with encode(obj) and iterencode(obj) methods."
    - "JSONDecoder().decode(s): same as loads(s)."
    - "JSONEncoder(sort_keys=True).encode(obj): serialize with sorted keys."
    - "json3_decoder(): JSONDecoder().decode('{\"a\":1}') == {'a': 1}."
    - "json3_encoder_sort_keys(): JSONEncoder(sort_keys=True).encode({'b':2,'a':1}) starts with '{\"a\"'."
    - "json3_encoder_indent(): JSONEncoder(indent=2).encode({'x':1}) contains newline."
    - "Export: JSONDecoder, JSONEncoder (extending theseus_json implementation)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_json_cr3.decoder:
  description: "JSONDecoder().decode('{\"a\":1}') == {'a': 1}"
  category: decoder
  kind: python_call_eq
  function: json3_decoder
  args: []
  expected: true

invariant theseus_json_cr3.encoder_sort_keys:
  description: "JSONEncoder(sort_keys=True).encode({'b':2,'a':1}) starts with '{\"a\"'"
  category: encoder
  kind: python_call_eq
  function: json3_encoder_sort_keys
  args: []
  expected: true

invariant theseus_json_cr3.encoder_indent:
  description: "JSONEncoder(indent=2).encode({'x':1}) contains newline"
  category: encoder
  kind: python_call_eq
  function: json3_encoder_indent
  args: []
  expected: true
