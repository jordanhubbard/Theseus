spec: http_client_extra20
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra19.zspec.zsdl — covers __all__.__len__()==19 and __all__.__class__.__name__=='list'; HTTP_PORT/HTTPS_PORT values and __class__.__name__=='int'; responses.__class__.__name__=='dict' and __len__()==62; HTTPConnection/HTTPResponse/HTTPException __dict__.__class__.__name__.__len__()==12; HTTPConnection.getresponse/__qualname__/__len__()==26/__name__.__len__()==11; HTTPConnection.set_debuglevel/__qualname__.__len__()==29/__name__.__len__()==14; HTTPConnection.putheader/__qualname__.__len__()==24/__name__.__len__()==9"
    - "http_client_extra18.zspec.zsdl — covers HTTPConnection/__mro__.__len__()==2; HTTPException/__mro__.__len__()==4; HTTPSConnection/__mro__.__len__()==3; HTTPResponse/__mro__.__len__()==6; all __bases__[0].__name__ for four main classes"
    - "http_client_extra17.zspec.zsdl — covers HTTPSConnection/HTTPResponse/HTTPException __qualname__.__len__(); HTTPConnection.request/connect/close/send __qualname__/__name__ __len__(); HTTPResponse.read/close/geturl/info __name__.__len__()"
    - "http_client_extra16.zspec.zsdl — covers __module__.__len__()==11; __name__.__len__(); HTTPConnection.__qualname__.__len__()==14"
  notes:
    - "This spec extends http_client_extra19.zspec.zsdl."
    - "Focus: HTTPSConnection.__dict__.__class__.__name__.__len__()==12; HTTPResponse.getheader/__qualname__/__len__()==22/__name__.__len__()==9; HTTPResponse.getheaders/__qualname__/__len__()==23/__name__.__len__()==10; HTTPResponse.close/__qualname__/__len__()==18/__name__.__len__()==5; HTTPConnection.request/__qualname__.__len__()==22/__name__.__len__()==7; HTTPConnection.connect/__qualname__.__len__()==22/__name__.__len__()==7; HTTPSConnection.__bases__[0].__name__.__len__()==14."
    - "http.client.HTTPSConnection.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern as other classes, not covered by extra19 for HTTPSConnection. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.getheader.__qualname__ == 'HTTPResponse.getheader' (len 22); __name__ == 'getheader' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.getheaders.__qualname__ == 'HTTPResponse.getheaders' (len 23); __name__ == 'getheaders' (len 10). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.close.__qualname__ == 'HTTPResponse.close' (len 18); __name__ == 'close' (len 5). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.request.__qualname__ == 'HTTPConnection.request' (len 22); __name__ == 'request' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.connect.__qualname__ == 'HTTPConnection.connect' (len 22); __name__ == 'connect' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPSConnection.__dict__.__class__.__name__.__len__() == 12
#
# http_client_extra19 checks __dict__.__class__.__name__.__len__() for
# HTTPConnection, HTTPResponse, and HTTPException. HTTPSConnection was not
# included in that table. All four classes use mappingproxy (len 12).
# ---------------------------------------------------------------------------

invariant http_client_extra20.HTTPSConnection_dict_class_name_len:
  description: "http.client.HTTPSConnection.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "HTTPSConnection.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# HTTPResponse.getheader and getheaders __qualname__ and __name__ lengths
#
# http_client_extra17 checks HTTPResponse.read/close/geturl/info __name__.__len__().
# No prior spec checks __qualname__ or __name__ lengths for getheader/getheaders.
# getheader.__qualname__ == 'HTTPResponse.getheader' (len 22); __name__ == 'getheader' (len 9).
# getheaders.__qualname__ == 'HTTPResponse.getheaders' (len 23); __name__ == 'getheaders' (len 10).
# ---------------------------------------------------------------------------

table http_client_extra20.HTTPResponse_getheader_attrs:
  description: "HTTPResponse.getheader and getheaders __qualname__.__len__() and __name__.__len__()"
  kind: python_call_eq
  category: function_attrs
  id_prefix: hcga20

  columns: [id, function, args, expected, description]
  rows:
    - [getheader_qualname,
       HTTPResponse.getheader.__qualname__.__eq__,
       ["HTTPResponse.getheader"],
       true,
       "http.client.HTTPResponse.getheader.__qualname__ == 'HTTPResponse.getheader'"]
    - [getheader_qualname_len,
       HTTPResponse.getheader.__qualname__.__len__,
       [],
       22,
       "len('HTTPResponse.getheader') == 22"]
    - [getheader_name_len,
       HTTPResponse.getheader.__name__.__len__,
       [],
       9,
       "len('getheader') == 9"]
    - [getheaders_qualname,
       HTTPResponse.getheaders.__qualname__.__eq__,
       ["HTTPResponse.getheaders"],
       true,
       "http.client.HTTPResponse.getheaders.__qualname__ == 'HTTPResponse.getheaders'"]
    - [getheaders_qualname_len,
       HTTPResponse.getheaders.__qualname__.__len__,
       [],
       23,
       "len('HTTPResponse.getheaders') == 23"]
    - [getheaders_name_len,
       HTTPResponse.getheaders.__name__.__len__,
       [],
       10,
       "len('getheaders') == 10"]

# ---------------------------------------------------------------------------
# HTTPResponse.close __qualname__ and __name__
#
# http_client_extra17 checks HTTPResponse.close.__name__.__len__() == 5.
# No prior spec checks __qualname__ or __qualname__.__len__() for close.
# close.__qualname__ == 'HTTPResponse.close' (len 18).
# ---------------------------------------------------------------------------

invariant http_client_extra20.HTTPResponse.close_qualname:
  description: "http.client.HTTPResponse.close.__qualname__ == 'HTTPResponse.close'"
  category: function_attrs
  kind: python_call_eq
  function: HTTPResponse.close.__qualname__.__eq__
  args: ["HTTPResponse.close"]
  expected: true

invariant http_client_extra20.HTTPResponse.close_qualname_len:
  description: "http.client.HTTPResponse.close.__qualname__.__len__() == 18 — len('HTTPResponse.close') == 18"
  category: function_attrs
  kind: python_call_eq
  function: HTTPResponse.close.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# HTTPConnection.request and connect __qualname__ and __name__ lengths
#
# http_client_extra17 checks __qualname__ and __name__ lengths for
# HTTPConnection.request/connect/close/send. That spec covers the __len__()
# values; no prior spec checks the __qualname__.__eq__ values directly.
# request.__qualname__ == 'HTTPConnection.request' (len 22); __name__ == 'request' (len 7).
# connect.__qualname__ == 'HTTPConnection.connect' (len 22); __name__ == 'connect' (len 7).
# ---------------------------------------------------------------------------

table http_client_extra20.HTTPConnection_request_connect_qualnames:
  description: "HTTPConnection.request and connect __qualname__.__eq__ and __name__.__len__()"
  kind: python_call_eq
  category: function_attrs
  id_prefix: hcrcq20

  columns: [id, function, args, expected, description]
  rows:
    - [request_qualname,
       HTTPConnection.request.__qualname__.__eq__,
       ["HTTPConnection.request"],
       true,
       "http.client.HTTPConnection.request.__qualname__ == 'HTTPConnection.request'"]
    - [request_qualname_len,
       HTTPConnection.request.__qualname__.__len__,
       [],
       22,
       "len('HTTPConnection.request') == 22"]
    - [request_name_len,
       HTTPConnection.request.__name__.__len__,
       [],
       7,
       "len('request') == 7"]
    - [connect_qualname,
       HTTPConnection.connect.__qualname__.__eq__,
       ["HTTPConnection.connect"],
       true,
       "http.client.HTTPConnection.connect.__qualname__ == 'HTTPConnection.connect'"]
    - [connect_qualname_len,
       HTTPConnection.connect.__qualname__.__len__,
       [],
       22,
       "len('HTTPConnection.connect') == 22"]
    - [connect_name_len,
       HTTPConnection.connect.__name__.__len__,
       [],
       7,
       "len('connect') == 7"]

# ---------------------------------------------------------------------------
# HTTPSConnection.__bases__[0].__name__.__len__() == 14
#
# http_client_extra18 checks HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection'.
# No prior spec checks the string length (14) of that base class name.
# ---------------------------------------------------------------------------

invariant http_client_extra20.HTTPSConnection.base_name_len:
  description: "http.client.HTTPSConnection.__bases__[0].__name__.__len__() == 14 — len('HTTPConnection') == 14"
  category: class_hierarchy
  kind: python_call_eq
  function: HTTPSConnection.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 14
