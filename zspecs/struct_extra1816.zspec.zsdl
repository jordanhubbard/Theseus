spec: struct_extra1816
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "struct module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party struct library"
  notes:
    - "Tests __format__, __repr__, __str__ presence in struct.Struct and struct.error __dict__"
    - "Tests __reduce__, __copy__, __deepcopy__, __getstate__ for copy/pickle protocol"
    - "Tests struct module-level pack/unpack functions"
    - "struct.Struct is a C type; it defines __reduce__ for pickle support"
  created_at: "2026-04-12"

table struct_extra1816.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1816-fp-001", "struct.Struct.__dict__.__contains__", ["__format__"], false]
    - ["st1816-fp-002", "struct.Struct.__dict__.__contains__", ["__repr__"], false]
    - ["st1816-fp-003", "struct.Struct.__dict__.__contains__", ["__str__"], false]
    - ["st1816-fp-004", "struct.error.__dict__.__contains__", ["__format__"], false]
    - ["st1816-fp-005", "struct.error.__dict__.__contains__", ["__repr__"], false]
    - ["st1816-fp-006", "struct.error.__dict__.__contains__", ["__str__"], false]

table struct_extra1816.copy_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1816-cp-001", "struct.Struct.__dict__.__contains__", ["__reduce__"], true]
    - ["st1816-cp-002", "struct.Struct.__dict__.__contains__", ["__copy__"], false]
    - ["st1816-cp-003", "struct.Struct.__dict__.__contains__", ["__deepcopy__"], false]
    - ["st1816-cp-004", "struct.Struct.__dict__.__contains__", ["__getstate__"], false]
    - ["st1816-cp-005", "struct.error.__dict__.__contains__", ["__reduce__"], false]
    - ["st1816-cp-006", "struct.error.__dict__.__contains__", ["__copy__"], false]
    - ["st1816-cp-007", "struct.error.__dict__.__contains__", ["__deepcopy__"], false]
    - ["st1816-cp-008", "struct.__dict__.__contains__", ["pack"], true]

table struct_extra1816.struct_module_functions:
  columns: [id, function, args, expected]
  rows:
    - ["st1816-mf-001", "struct.__dict__.__contains__", ["pack"], true]
    - ["st1816-mf-002", "struct.__dict__.__contains__", ["unpack"], true]
    - ["st1816-mf-003", "struct.__dict__.__contains__", ["pack_into"], true]
    - ["st1816-mf-004", "struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1816-mf-005", "struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1816-mf-006", "struct.__dict__.__contains__", ["calcsize"], true]
    - ["st1816-mf-007", "struct.__dict__.__contains__", ["Struct"], true]
    - ["st1816-mf-008", "struct.__dict__.__contains__", ["error"], true]
    - ["st1816-mf-009", "struct.__dict__.__contains__", ["__doc__"], true]
    - ["st1816-mf-010", "struct.__dict__.__contains__", ["__version__"], false]
