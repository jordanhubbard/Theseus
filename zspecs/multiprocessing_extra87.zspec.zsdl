invariant multiprocessing_extra87.BaseManager_base_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') returns True — BaseManager directly subclasses object; it is the base class for all multiprocessing managers; NEW in extra87: first standalone __bases__ hierarchy invariant for BaseManager in mpmanagerhier87 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra87.SyncManager_base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager directly subclasses BaseManager; it provides synchronized proxies for common data types; NEW in extra87: first standalone __bases__ hierarchy invariant for SyncManager in mpmanagerhier87 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra87.SyncManager_mro_len:
  description: "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 — MRO is [SyncManager, BaseManager, object]; SyncManager subclasses BaseManager which subclasses object; NEW in extra87: first standalone MRO length invariant for SyncManager in mpmanagerhier87 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra87.BaseProxy_qualname:
  description: "multiprocessing.managers.BaseProxy.__qualname__.__eq__('BaseProxy') returns True — BaseProxy is a top-level class so its __qualname__ equals its __name__; it is the base class for all proxy objects returned by managers; NEW in extra87: first standalone __qualname__ equality invariant for BaseProxy in mpmanagerhier87 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.BaseProxy.__qualname__.__eq__
  args: ["BaseProxy"]
  expected: true

invariant multiprocessing_extra87.BaseManager_qualname:
  description: "multiprocessing.managers.BaseManager.__qualname__.__eq__('BaseManager') returns True — BaseManager is a top-level class so its __qualname__ equals its __name__; it provides the base interface for creating shared-state manager servers; NEW in extra87: first standalone __qualname__ equality invariant for BaseManager in mpmanagerhier87 namespace; wave 249; verified with Python 3.14.3"
