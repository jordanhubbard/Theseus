spec: socket_extra65
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra64.zspec.zsdl — covers socket.socket.accept.__code__.co_varnames.__class__.__name__=='tuple' / makefile.__code__.co_varnames.__class__.__name__=='tuple' / accept.__code__.co_varnames[0]=='self' / makefile.__code__.co_varnames[0]=='self' / accept.__code__.co_filename.__contains__('.py') / makefile.__code__.co_filename.__contains__('.py') / AF_INET.__class__.__name__=='AddressFamily' / SOCK_STREAM.__class__.__name__=='SocketKind' (table + invariants)."
    - "socket_extra63.zspec.zsdl — covers socket.socket.accept.__code__.co_name ('accept') / makefile.__code__.co_name ('makefile') / accept.__code__.co_argcount==1 / makefile.__code__.co_argcount==3 / gethostbyname.__doc__.__contains__('host') / getfqdn.__doc__.__contains__('hostname') (table + invariants)."
    - "socket_extra62.zspec.zsdl — covers socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') / makefile.__defaults__.__class__.__name__.__eq__('tuple') / accept.__code__.__class__.__name__.__eq__('code') / makefile.__code__.__class__.__name__.__eq__('code') (table + invariants)."
    - "socket_extra61.zspec.zsdl — covers socket.socket.accept/close/detach/makefile __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra64; it does NOT duplicate invariants present in those files."
    - "Wave 232 theme: __code__.co_consts / co_nlocals / co_stacksize chains for Python socket.socket methods + socket integer constant equality checks."
    - "In python_module(socket) backend, 'socket' in the module namespace refers to the socket.socket class (the class named 'socket' within the socket module's __dict__). So 'socket.accept' means 'socket.socket.accept', the Python method defined in Lib/socket.py. This is consistent with prior socket specs."
    - "socket.socket.accept.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple for Python code objects; accept is a pure Python method in Lib/socket.py. No prior socket spec checks accept.__code__.co_consts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_consts.__class__.__name__ == 'tuple' — makefile is a pure Python method in Lib/socket.py. No prior socket spec checks makefile.__code__.co_consts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is an integer count of local variables for a Python code object. No prior socket spec checks accept.__code__.co_nlocals. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_nlocals.__class__.__name__ == 'int' — same reasoning. No prior socket spec checks makefile.__code__.co_nlocals. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an integer indicating the required VM stack space for the code object. No prior socket spec checks accept.__code__.co_stacksize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_stacksize.__class__.__name__ == 'int' — same reasoning. No prior socket spec checks makefile.__code__.co_stacksize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__eq__(2) == True — AF_INET is the IPv4 address family constant with integer value 2 on all platforms. socket_extra64 checks AF_INET.__class__.__name__=='AddressFamily' (type axis). No prior socket spec checks AF_INET.__eq__(2). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM is the stream socket type with integer value 1 on all platforms. socket_extra64 checks SOCK_STREAM.__class__.__name__=='SocketKind' (type axis). No prior socket spec checks SOCK_STREAM.__eq__(1). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM is the datagram socket type with integer value 2 on all platforms. socket_extra64 does not check SOCK_DGRAM in any form. No prior socket spec checks SOCK_DGRAM.__eq__(2). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_consts class name
#
# Wave 232 theme: __code__.co_consts chains for Python socket methods.
#
# co_consts is a tuple of constants used in the bytecode of a Python code
# object. Both accept and makefile are pure Python methods in Lib/socket.py
# so their co_consts is a tuple. socket_extra64 checks co_varnames (wave 231).
# No prior socket spec checks co_consts for any socket.socket method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra65.co_consts_class_name:
  description: "socket.socket.accept.__code__.co_consts.__class__.__name__=='tuple' and makefile.__code__.co_consts.__class__.__name__=='tuple' — co_consts is always a tuple of constants for Python code objects; both accept and makefile are pure Python methods in Lib/socket.py; socket_extra64 checks co_varnames (wave 231); no prior socket spec checks co_consts for any socket.socket method; first co_consts anchor for socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode4_65

  columns: [id, function, args, expected]
  rows:
    - [socket_accept_co_consts_class_name,   socket.accept.__code__.co_consts.__class__.__name__.__eq__,   ["tuple"], true]
    - [socket_makefile_co_consts_class_name, socket.makefile.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_nlocals class name
#
# Wave 232 theme: __code__.co_nlocals chains for Python socket methods.
#
# co_nlocals is an integer count of local variables (parameters plus locals)
# used by the code object. Both accept and makefile are pure Python methods so
# co_nlocals is an int. No prior socket spec checks co_nlocals for any method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra65.co_nlocals_class_name:
  description: "socket.socket.accept.__code__.co_nlocals.__class__.__name__=='int' and makefile.__code__.co_nlocals.__class__.__name__=='int' — co_nlocals is always an integer count of local variables for Python code objects; both accept and makefile are pure Python methods in Lib/socket.py; no prior socket spec checks co_nlocals for any socket.socket method; first co_nlocals anchor for socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode4_65

  columns: [id, function, args, expected]
  rows:
    - [socket_accept_co_nlocals_class_name,   socket.accept.__code__.co_nlocals.__class__.__name__.__eq__,   ["int"], true]
    - [socket_makefile_co_nlocals_class_name, socket.makefile.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_stacksize class name
#
# Wave 232 theme: __code__.co_stacksize chains for Python socket methods.
#
# co_stacksize is an integer indicating the required virtual machine stack
# space for the code object. Both accept and makefile are pure Python methods
# so co_stacksize is an int. No prior socket spec checks co_stacksize for any
# socket.socket method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra65.co_stacksize_class_name:
  description: "socket.socket.accept.__code__.co_stacksize.__class__.__name__=='int' and makefile.__code__.co_stacksize.__class__.__name__=='int' — co_stacksize is always an integer indicating required VM stack space for Python code objects; both accept and makefile are pure Python methods in Lib/socket.py; no prior socket spec checks co_stacksize for any socket.socket method; first co_stacksize anchor for socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode4_65

  columns: [id, function, args, expected]
  rows:
    - [socket_accept_co_stacksize_class_name,   socket.accept.__code__.co_stacksize.__class__.__name__.__eq__,   ["int"], true]
    - [socket_makefile_co_stacksize_class_name, socket.makefile.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET, SOCK_STREAM, SOCK_DGRAM integer equality checks
#
# Wave 232 theme: socket constant integer value equality checks.
#
# AF_INET is the IPv4 address family constant with value 2 on all platforms.
# SOCK_STREAM is the stream socket type with value 1 on all platforms.
# SOCK_DGRAM is the datagram socket type with value 2 on all platforms.
# socket_extra64 checks AF_INET and SOCK_STREAM on the __class__.__name__
# axis (AddressFamily/SocketKind) but not on the integer equality axis.
# No prior socket spec checks AF_INET.__eq__(2), SOCK_STREAM.__eq__(1),
# or SOCK_DGRAM.__eq__(2). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra65.socket_int_constants:
  description: "socket.AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True / SOCK_DGRAM.__eq__(2)==True — AF_INET is the IPv4 address family (value 2) on all platforms; SOCK_STREAM is the stream socket type (value 1) on all platforms; SOCK_DGRAM is the datagram socket type (value 2) on all platforms; socket_extra64 checks AF_INET and SOCK_STREAM on __class__.__name__ axis; no prior socket spec checks integer equality for any socket constant; first integer value anchor for socket constants"
  kind: python_call_eq
  category: module_constants
  id_prefix: socketcode4_65

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_eq_2,      AF_INET.__eq__,      [2], true]
    - [SOCK_STREAM_eq_1,  SOCK_STREAM.__eq__,  [1], true]
    - [SOCK_DGRAM_eq_2,   SOCK_DGRAM.__eq__,   [2], true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_consts.__class__.__name__=='tuple' — standalone
#
# socket.socket.accept is a pure Python method in Lib/socket.py. Its code
# object's co_consts is a tuple — the standard type for code object constant
# sequences in Python. socket_extra64 checks co_varnames (wave 231). No prior
# socket spec checks accept.__code__.co_consts. First co_consts anchor for
# any socket.socket method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra65.socket_accept_co_consts_tuple:
  description: "socket.socket.accept.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple for Python code objects containing literal constants; accept is a pure Python method in Lib/socket.py; socket_extra64 checks co_varnames (wave 231); no prior socket spec checks accept.__code__.co_consts; first co_consts anchor for any socket.socket method"
  category: code_objects
  kind: python_call_eq
  function: socket.accept.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

