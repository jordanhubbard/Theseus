# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET is the address family constant for IPv4. Its integer value is
# 2 on all Python platforms (POSIX and Windows). socket_extra64 checks
# AF_INET.__class__.__name__=='AddressFamily' (type axis). No prior socket spec
# checks AF_INET.__eq__(2). First integer equality anchor for socket.AF_INET.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra65.AF_INET_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET is the IPv4 address family constant with integer value 2 on all platforms; socket_extra64 checks AF_INET.__class__.__name__=='AddressFamily' (type axis); no prior socket spec checks AF_INET.__eq__(2); first integer equality anchor for socket.AF_INET"
  category: module_constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

