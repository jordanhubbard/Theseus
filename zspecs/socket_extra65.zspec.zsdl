invariant socket_extra65.socket_accept_co_nlocals_int:
  description: "socket.socket.accept.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is always an integer count of local variables for Python code objects; accept is a pure Python method in Lib/socket.py; no prior socket spec checks accept.__code__.co_nlocals; first co_nlocals anchor for any socket.socket method"
  category: code_objects
  kind: python_call_eq
  function: socket.accept.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

