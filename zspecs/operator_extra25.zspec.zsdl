spec: operator_extra25
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra24.zspec.zsdl."
    - "operator_extra24 covers: attrgetter.__call__, itemgetter.__call__, methodcaller.__call__; not_/truth/is_/is_not/contains qualnames."
    - "operator_extra23 covers: arithmetic functions (add/sub/mul/truediv/floordiv/mod) and callable classes (attrgetter/itemgetter/methodcaller) class-level qualnames."
    - "operator_extra22 covers: comparison functions (lt/gt/eq/ne/le/ge)."
    - "No prior operator spec records __qualname__.__eq__ for length_hint and bitwise operators (and_/or_/xor/invert/lshift/rshift) together in the extra25 namespace."
    - "Focus: __qualname__ for operator.length_hint and six bitwise/shift operator functions."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — bitwise operator function qualnames
#
# operator.and_, or_, xor, invert, lshift, and rshift are C-level functions
# in _operator. Each has a simple qualname equal to its attribute name.
# operator_extra22 covers comparison functions; operator_extra24 covers logical
# functions; no prior spec covers these six bitwise functions together in the
# extra25 namespace.
# ---------------------------------------------------------------------------

table operator_extra25.bitwise_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra25.bitwise_qualnames.and_,
       and_.__qualname__.__eq__,
       ["and_"],
       true,
       "operator.and_.__qualname__ == 'and_'"]
    - [operator_extra25.bitwise_qualnames.or_,
       or_.__qualname__.__eq__,
       ["or_"],
       true,
       "operator.or_.__qualname__ == 'or_'"]
    - [operator_extra25.bitwise_qualnames.xor,
       xor.__qualname__.__eq__,
       ["xor"],
       true,
       "operator.xor.__qualname__ == 'xor'"]
    - [operator_extra25.bitwise_qualnames.invert,
       invert.__qualname__.__eq__,
       ["invert"],
       true,
       "operator.invert.__qualname__ == 'invert'"]
    - [operator_extra25.bitwise_qualnames.lshift,
       lshift.__qualname__.__eq__,
       ["lshift"],
       true,
       "operator.lshift.__qualname__ == 'lshift'"]
    - [operator_extra25.bitwise_qualnames.rshift,
       rshift.__qualname__.__eq__,
       ["rshift"],
       true,
       "operator.rshift.__qualname__ == 'rshift'"]

# ---------------------------------------------------------------------------
# length_hint.__qualname__.__eq__ — standalone function qualname
#
# operator.length_hint is a C-level function in _operator that returns an
# estimated length of an object. Its qualname is 'length_hint', a simple name
# with no enclosing class scope, confirming module-level definition.
# No prior operator spec records this in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra25.length_hint.qualname:
  description: "operator.length_hint.__qualname__ == 'length_hint'"
  category: qualnames
  kind: python_call_eq
  function: length_hint.__qualname__.__eq__
  args: ["length_hint"]
  expected: true

# ---------------------------------------------------------------------------
# and_.__qualname__.__eq__ — standalone bitwise function qualname
#
# operator.and_ is a C-level function that computes the bitwise AND of two
# values. Its qualname is 'and_', a simple name with no enclosing class scope.
# No prior operator spec records this standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra25.and_.qualname:
  description: "operator.and_.__qualname__ == 'and_'"
  category: qualnames
  kind: python_call_eq
  function: and_.__qualname__.__eq__
  args: ["and_"]
  expected: true

# ---------------------------------------------------------------------------
# invert.__qualname__.__eq__ — standalone bitwise function qualname
#
# operator.invert is a C-level unary function that computes the bitwise NOT
# of its argument. Its qualname is 'invert', confirming module-level definition.
# No prior operator spec records this standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra25.invert.qualname:
  description: "operator.invert.__qualname__ == 'invert'"
  category: qualnames
  kind: python_call_eq
  function: invert.__qualname__.__eq__
  args: ["invert"]
  expected: true
