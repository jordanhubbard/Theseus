spec: decimal_extra336
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.__name__ == 'decimal' — the module name attribute."
    - "decimal.__package__ == '' — decimal is a plain module, not a package; verified with Python 3.14.3."
    - "decimal.__spec__.name == 'decimal' — the ModuleSpec name matches the module name."
    - "decimal has no __all__ attribute; verified with Python 3.14.3 — hasattr(decimal, '__all__') is False."
    - "decimal.MAX_EMAX == 999999999999999999 — maximum exponent for a Decimal value."
    - "decimal.MIN_EMIN == -999999999999999999 — minimum exponent for a Decimal value."
    - "decimal.MIN_ETINY == -1999999999999999997 — minimum possible exponent when considering subnormals."
    - "decimal.MAX_PREC == 999999999999999999 — maximum precision (significant digits) for a context."
    - "All four constants are plain int objects; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__name__ — module identity
# ---------------------------------------------------------------------------

invariant decimal_extra336.module_name:
  description: "decimal.__name__ == 'decimal'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.__package__ — not a package; package attribute is the empty string
# ---------------------------------------------------------------------------

invariant decimal_extra336.module_package:
  description: "decimal.__package__ == '' — decimal is a plain module, not a package"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# decimal.__spec__.name — ModuleSpec name
# ---------------------------------------------------------------------------

invariant decimal_extra336.spec_name:
  description: "decimal.__spec__.name == 'decimal'"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Numeric limit constants — type checks
# decimal has no __all__; these constants are the canonical boundary values
# for Decimal arithmetic contexts.
# ---------------------------------------------------------------------------

invariant decimal_extra336.MAX_EMAX.is_int:
  description: "decimal.MAX_EMAX.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_EMAX.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra336.MIN_EMIN.is_int:
  description: "decimal.MIN_EMIN.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MIN_EMIN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra336.MIN_ETINY.is_int:
  description: "decimal.MIN_ETINY.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MIN_ETINY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra336.MAX_PREC.is_int:
  description: "decimal.MAX_PREC.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Numeric limit constants — exact values
# ---------------------------------------------------------------------------

invariant decimal_extra336.MAX_EMAX.value:
  description: "decimal.MAX_EMAX == 999999999999999999"
  category: constants
  kind: python_call_eq
  function: MAX_EMAX.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra336.MIN_EMIN.value:
  description: "decimal.MIN_EMIN == -999999999999999999"
  category: constants
  kind: python_call_eq
  function: MIN_EMIN.__eq__
  args: [-999999999999999999]
  expected: true

invariant decimal_extra336.MIN_ETINY.value:
  description: "decimal.MIN_ETINY == -1999999999999999997"
  category: constants
  kind: python_call_eq
  function: MIN_ETINY.__eq__
  args: [-1999999999999999997]
  expected: true

invariant decimal_extra336.MAX_PREC.value:
  description: "decimal.MAX_PREC == 999999999999999999"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true
