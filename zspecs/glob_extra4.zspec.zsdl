spec: glob_extra4
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
  notes:
    - "This spec extends glob.zspec.zsdl, glob_extra.zspec.zsdl, glob_extra2.zspec.zsdl, and glob_extra3.zspec.zsdl."
    - "glob.zspec.zsdl covers: glob/iglob/escape __name__ (table); glob no-match/exact-match cases; escape special-char table (hello*, [a-z], a?b, normal, test[1], ''); iglob generator type check."
    - "glob_extra.zspec.zsdl covers: glob.__module__; glob/iglob/escape __name__ standalone; escape('[abc]'), escape('a?b'), escape('a*b')."
    - "glob_extra2.zspec.zsdl covers: glob/iglob/escape/has_magic __name__ standalone; module checks table (glob/escape/iglob/has_magic); has_magic vectors; escape('normal.txt') and escape('')."
    - "glob_extra3.zspec.zsdl covers: function_names table (glob/iglob/escape); glob.__module__ standalone; escape.__class__.__name__ and iglob.__class__.__name__; escape('/path/with[brackets]'); escape('normal/path')."
    - "This spec adds: __qualname__ checks for glob, iglob, and escape (not covered in any prior spec); escape('/path/to/[file].txt') — a new path vector distinct from all existing escape vectors; glob.__class__.__name__ == 'function' (not covered; only escape and iglob class names appear in extra3)."
    - "glob.escape() escapes only '[', '?', and '*' using bracket notation. It does NOT escape ']'. The '[' in '[file]' becomes '[[]', leaving the rest unchanged: '/path/to/[file].txt' -> '/path/to/[[]file].txt'."
    - "Module-level functions defined in glob have __qualname__ equal to __name__ (no enclosing class)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks — glob, iglob, escape
# No prior spec covers __qualname__ for any glob callable.
# Module-level functions have __qualname__ == __name__.
# ---------------------------------------------------------------------------

table glob_extra4.function_qualnames:
  description: "glob module functions have __qualname__ equal to their unqualified name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [glob,   glob.__qualname__.__eq__,   ["glob"],   true]
    - [iglob,  iglob.__qualname__.__eq__,  ["iglob"],  true]
    - [escape, escape.__qualname__.__eq__, ["escape"], true]

# ---------------------------------------------------------------------------
# glob.__class__.__name__ == 'function'
# glob_extra3 covers escape and iglob class names; glob itself is not covered.
# ---------------------------------------------------------------------------

invariant glob_extra4.glob.class_name:
  description: "glob.glob.__class__.__name__ == 'function' — glob is a plain Python function"
  category: function_identity
  kind: python_call_eq
  function: glob.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# escape('/path/to/[file].txt')
# glob.escape only escapes '[' (to '[[]'), '?' (to '[?]'), and '*' (to '[*]').
# The closing ']' in '[file]' is NOT a glob special character and is left alone.
# Result: '/path/to/[[]file].txt'
# Existing vectors:
#   glob.zspec.zsdl: 'hello*', '[a-z]', 'a?b', 'normal', 'test[1]', ''
#   glob_extra: '[abc]', 'a?b', 'a*b'
#   glob_extra2: 'normal.txt', ''
#   glob_extra3: '/path/with[brackets]', 'normal/path'
# This vector is a new distinct path with a bracket in the filename segment.
# ---------------------------------------------------------------------------

invariant glob_extra4.escape.path_with_file_bracket:
  description: "glob.escape('/path/to/[file].txt') == '/path/to/[[]file].txt' — '[' is bracket-escaped"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["/path/to/[file].txt"]
  expected: "/path/to/[[]file].txt"
