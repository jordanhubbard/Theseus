spec: socket_extra42
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra41.zspec.zsdl — covers socket.socket setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__ string values; socket.gethostname __name__/__module__.__eq__."
    - "socket_extra40.zspec.zsdl — covers socket.getdefaulttimeout.__qualname__.__eq__('getdefaulttimeout'); socket.socket fileno/close/setsockopt/getsockopt __name__.__eq__ string values."
    - "socket_extra39.zspec.zsdl — covers socket.socket connect/bind/accept/listen/send/recv __name__.__eq__ string values."
    - "socket_extra37.zspec.zsdl — covers socket.socket recvfrom/sendto/makefile/connect_ex/recv_into/recvfrom_into/dup/get_inheritable/set_inheritable __name__.__len__() (length checks only, NOT string eq values)."
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__() (length checks only, NOT string eq values)."
    - "socket_extra31.zspec.zsdl — covers socket.socket close/setblocking/getsockname __qualname__.__eq__ and __len__(); sendall __qualname__.__len__() (length checks only, NOT __qualname__.__eq__ for sendall)."
    - "socket_extra23.zspec.zsdl — covers setsockopt/getsockopt/getsockname/getpeername/setblocking/settimeout/gettimeout/fileno __qualname__.__eq__ string values."
    - "socket_extra22.zspec.zsdl — covers socket.socket connect/bind/listen/accept/recv/send/close __qualname__.__eq__ string values."
  notes:
    - "This spec extends socket through socket_extra41; it does NOT duplicate invariants present in those files."
    - "Coverage gap: socket_extra22 covers connect/bind/listen/accept/recv/send/close __qualname__.__eq__. socket_extra23 covers setsockopt/getsockopt/getsockname/getpeername/setblocking/settimeout/gettimeout/fileno __qualname__.__eq__. socket_extra31 covers close/setblocking/getsockname __qualname__.__eq__ and sendall/__qualname__.__len__ (length only). But NO prior spec checks __qualname__.__eq__ string values for socket.socket.shutdown, sendall, recvfrom, sendto, connect_ex, dup, makefile, or detach. Prior specs cover __name__.__len__() (length checks) or __name__.__eq__ for these, but NOT __qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__qualname__ == 'socket.shutdown'. The socket class is named 'socket'; method qualnames take the form 'socket.<method>'. extra34 covers __name__.__len__()==8 (length only). No prior spec checks shutdown.__qualname__.__eq__('socket.shutdown'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__qualname__ == 'socket.sendall'. extra34 covers __name__.__len__()==7; extra31 covers __qualname__.__len__()==14 (length only). No prior spec checks sendall.__qualname__.__eq__('socket.sendall'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom'. extra37 covers __name__.__len__()==8 (length only). No prior spec checks recvfrom.__qualname__.__eq__('socket.recvfrom'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__qualname__ == 'socket.sendto'. extra37 covers __name__.__len__()==6 (length only). No prior spec checks sendto.__qualname__.__eq__('socket.sendto'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.connect_ex.__qualname__ == 'socket.connect_ex'. extra37 covers __name__.__len__()==10 (length only). No prior spec checks connect_ex.__qualname__.__eq__('socket.connect_ex'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__qualname__ == 'socket.dup'. extra37 covers __name__.__len__()==3; extra41 covers __name__.__eq__('dup'). No prior spec checks dup.__qualname__.__eq__('socket.dup'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__qualname__ == 'socket.makefile'. extra37 covers __name__.__len__()==8; extra41 covers __name__.__eq__('makefile'). No prior spec checks makefile.__qualname__.__eq__('socket.makefile'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__qualname__ == 'socket.detach'. extra34 covers __name__.__len__()==6; extra41 covers __name__.__eq__('detach'). No prior spec checks detach.__qualname__.__eq__('socket.detach'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __qualname__ string eq values:
# shutdown, sendall, recvfrom, sendto, connect_ex, dup, makefile, detach
#
# socket_extra22 covers connect/bind/listen/accept/recv/send/close __qualname__.__eq__.
# socket_extra23 covers setsockopt/getsockopt/getsockname/getpeername/setblocking/
#   settimeout/gettimeout/fileno __qualname__.__eq__.
# socket_extra31 covers close/setblocking/getsockname __qualname__.__eq__ and
#   sendall/__qualname__.__len__ (length only, NOT __qualname__.__eq__).
# Prior specs cover __name__.__len__() or __name__.__eq__ for these methods,
# but NO prior spec checks __qualname__.__eq__ string values for any of:
# shutdown, sendall, recvfrom, sendto, connect_ex, dup, makefile, detach.
# ---------------------------------------------------------------------------

table socket_extra42.socket_method_qualname_eqs:
  description: "socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values — novel: extra22 covers connect/bind/listen/accept/recv/send/close; extra23 covers setsockopt/getsockopt/getsockname/getpeername/setblocking/settimeout/gettimeout/fileno; extra31 covers sendall qualname len only; no prior spec checks __qualname__.__eq__ for any of these eight methods"
  kind: python_call_eq
  category: function_names
  id_prefix: ssmqe42

  columns: [id, function, args, expected]
  rows:
    - [shutdown_qualname_eq,   "socket.shutdown.__qualname__.__eq__",   ["socket.shutdown"],   true]
    - [sendall_qualname_eq,    "socket.sendall.__qualname__.__eq__",    ["socket.sendall"],    true]
    - [recvfrom_qualname_eq,   "socket.recvfrom.__qualname__.__eq__",   ["socket.recvfrom"],   true]
    - [sendto_qualname_eq,     "socket.sendto.__qualname__.__eq__",     ["socket.sendto"],     true]
    - [connect_ex_qualname_eq, "socket.connect_ex.__qualname__.__eq__", ["socket.connect_ex"], true]
    - [dup_qualname_eq,        "socket.dup.__qualname__.__eq__",        ["socket.dup"],        true]
    - [makefile_qualname_eq,   "socket.makefile.__qualname__.__eq__",   ["socket.makefile"],   true]
    - [detach_qualname_eq,     "socket.detach.__qualname__.__eq__",     ["socket.detach"],     true]
