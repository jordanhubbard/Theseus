spec: itertools_extra1681
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers classnames and first_element checks"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain/repeat/islice length hints"
    - "itertools_extra1666.zspec.zsdl — covers __new__/__init__ presence for all public C types"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which types define __call__ in their own __dict__."
    - "All public itertools types are C extension types (iterator objects, not factory callables)."
    - "Iterator C types implement tp_iternext, not tp_call — they do NOT define __call__ in their own __dict__."
    - "chain, count, cycle, repeat, islice, product, permutations, combinations are all iterator types → __call__ not in __dict__ → False."
    - "None of the public itertools C types expose __call__ in their class __dict__."
    - "The absence of __call__ confirms these are pure iterator objects, not callable factory types."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: no_call_in_dict
#
# Confirms that every public itertools C iterator type does NOT define
# __call__ in its own __dict__.  These types implement tp_iternext (the
# __next__ slot), not tp_call, so __call__ is absent.
# ---------------------------------------------------------------------------

table itertools_extra1681.no_call_in_dict:
  description: "itertools C iterator types do not define __call__ in their own __dict__"
  kind: python_call_eq
  category: no_call_in_dict
  id_prefix: it1681

  columns: [id, function, args, expected]
  rows:
    - ["it1681001", "itertools.chain.__dict__.__contains__",                       ["__call__"], false]
    - ["it1681002", "itertools.count.__dict__.__contains__",                       ["__call__"], false]
    - ["it1681003", "itertools.cycle.__dict__.__contains__",                       ["__call__"], false]
    - ["it1681004", "itertools.repeat.__dict__.__contains__",                      ["__call__"], false]
    - ["it1681005", "itertools.islice.__dict__.__contains__",                      ["__call__"], false]
    - ["it1681006", "itertools.product.__dict__.__contains__",                     ["__call__"], false]
    - ["it1681007", "itertools.permutations.__dict__.__contains__",                ["__call__"], false]
    - ["it1681008", "itertools.combinations.__dict__.__contains__",                ["__call__"], false]
    - ["it1681009", "itertools.combinations_with_replacement.__dict__.__contains__", ["__call__"], false]
    - ["it1681010", "itertools.accumulate.__dict__.__contains__",                  ["__call__"], false]
    - ["it1681011", "itertools.compress.__dict__.__contains__",                    ["__call__"], false]
    - ["it1681012", "itertools.dropwhile.__dict__.__contains__",                   ["__call__"], false]
    - ["it1681013", "itertools.filterfalse.__dict__.__contains__",                 ["__call__"], false]
    - ["it1681014", "itertools.groupby.__dict__.__contains__,",                    ["__call__"], false]
    - ["it1681015", "itertools.starmap.__dict__.__contains__",                     ["__call__"], false]
    - ["it1681016", "itertools.takewhile.__dict__.__contains__",                   ["__call__"], false]
    - ["it1681017", "itertools.zip_longest.__dict__.__contains__",                 ["__call__"], false]
    - ["it1681018", "itertools.pairwise.__dict__.__contains__",                    ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: iterator_protocol_present
#
# Confirms that the same C iterator types DO define __next__ and __iter__
# in their own __dict__ — the iterator protocol slots (tp_iternext,
# tp_iter) that distinguish them from callable types.
# ---------------------------------------------------------------------------

table itertools_extra1681.iterator_protocol_present:
  description: "itertools C types define __iter__ and __next__ (iterator protocol)"
  kind: python_call_eq
  category: iterator_protocol_present
  id_prefix: it1681

  columns: [id, function, args, expected]
  rows:
    - ["it1681020", "itertools.chain.__dict__.__contains__",           ["__iter__"],  true]
    - ["it1681021", "itertools.chain.__dict__.__contains__",           ["__next__"],  true]
    - ["it1681022", "itertools.count.__dict__.__contains__",           ["__iter__"],  true]
    - ["it1681023", "itertools.count.__dict__.__contains__",           ["__next__"],  true]
    - ["it1681024", "itertools.cycle.__dict__.__contains__",           ["__iter__"],  true]
    - ["it1681025", "itertools.cycle.__dict__.__contains__",           ["__next__"],  true]
    - ["it1681026", "itertools.repeat.__dict__.__contains__",          ["__iter__"],  true]
    - ["it1681027", "itertools.repeat.__dict__.__contains__",          ["__next__"],  true]
    - ["it1681028", "itertools.islice.__dict__.__contains__",          ["__iter__"],  true]
    - ["it1681029", "itertools.islice.__dict__.__contains__",          ["__next__"],  true]
    - ["it1681030", "itertools.product.__dict__.__contains__",         ["__iter__"],  true]
    - ["it1681031", "itertools.product.__dict__.__contains__",         ["__next__"],  true]
    - ["it1681032", "itertools.permutations.__dict__.__contains__",    ["__iter__"],  true]
    - ["it1681033", "itertools.permutations.__dict__.__contains__",    ["__next__"],  true]
    - ["it1681034", "itertools.combinations.__dict__.__contains__",    ["__iter__"],  true]
    - ["it1681035", "itertools.combinations.__dict__.__contains__",    ["__next__"],  true]

# ---------------------------------------------------------------------------
# Table 3: module_and_type_identity
#
# Spot-checks __module__ and __class__.__name__ for representative
# itertools types to confirm all are C extension types from itertools.
# ---------------------------------------------------------------------------

table itertools_extra1681.module_and_type_identity:
  description: "Module and metatype identity for itertools types"
  kind: python_call_eq
  category: module_and_type_identity
  id_prefix: it1681

  columns: [id, function, args, expected]
  rows:
    - ["it1681040", "itertools.chain.__module__.__eq__",                    ["itertools"], true]
    - ["it1681041", "itertools.count.__module__.__eq__",                    ["itertools"], true]
    - ["it1681042", "itertools.cycle.__module__.__eq__",                    ["itertools"], true]
    - ["it1681043", "itertools.repeat.__module__.__eq__",                   ["itertools"], true]
    - ["it1681044", "itertools.product.__module__.__eq__",                  ["itertools"], true]
    - ["it1681045", "itertools.permutations.__module__.__eq__",             ["itertools"], true]
    - ["it1681046", "itertools.combinations.__module__.__eq__",             ["itertools"], true]
    - ["it1681047", "itertools.chain.__class__.__name__.__eq__",            ["type"],      true]
    - ["it1681048", "itertools.count.__class__.__name__.__eq__",            ["type"],      true]
    - ["it1681049", "itertools.cycle.__class__.__name__.__eq__",            ["type"],      true]
    - ["it1681050", "itertools.repeat.__class__.__name__.__eq__",           ["type"],      true]
    - ["it1681051", "itertools.product.__class__.__name__.__eq__",          ["type"],      true]
