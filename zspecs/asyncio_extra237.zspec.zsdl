spec: asyncio_extra237
version: ">=3.9"
backend: python_module(asyncio.transports)

docs: https://docs.python.org/3/library/asyncio-protocol.html#transports

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html#transports — asyncio transport class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/transports.py"
  notes:
    - "asyncio.BaseTransport.__name__ == 'BaseTransport' — 13 characters; module is 'asyncio.transports'; verified with Python 3.14.3."
    - "asyncio.ReadTransport.__name__ == 'ReadTransport' — 13 characters; module is 'asyncio.transports'; verified with Python 3.14.3."
    - "asyncio.WriteTransport.__name__ == 'WriteTransport' — 14 characters; module is 'asyncio.transports'; verified with Python 3.14.3."
    - "asyncio.Transport.__name__ == 'Transport' — 9 characters; module is 'asyncio.transports'; verified with Python 3.14.3."
    - "asyncio.BaseTransport.__bases__[0].__name__ == 'object' — BaseTransport inherits directly from object; verified with Python 3.14.3."
    - "asyncio.ReadTransport.__bases__[0].__name__ == 'BaseTransport' — ReadTransport inherits directly from BaseTransport; verified with Python 3.14.3."
    - "asyncio.WriteTransport.__bases__[0].__name__ == 'BaseTransport' — WriteTransport inherits directly from BaseTransport; verified with Python 3.14.3."
    - "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' — Transport's first base is ReadTransport (multiple inheritance); verified with Python 3.14.3."
    - "asyncio.Transport.__bases__[1].__name__ == 'WriteTransport' — Transport's second base is WriteTransport (multiple inheritance); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio transport class identity contracts — extra237 namespace
#
# BaseTransport.__name__ == 'BaseTransport' (13 chars); module 'asyncio.transports'.
# ReadTransport.__name__ == 'ReadTransport' (13 chars); module 'asyncio.transports'.
# WriteTransport.__name__ == 'WriteTransport' (14 chars); module 'asyncio.transports'.
# Transport.__name__ == 'Transport' (9 chars); module 'asyncio.transports'.
# ---------------------------------------------------------------------------

table asyncio_extra237.transport_class_names:
  description: "asyncio transport class __name__ and __module__ contracts in aio237tcn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio237tcn

  columns: [id, function, args, expected, description]
  rows:
    - [bt_name_eq,        BaseTransport.__name__.__eq__,     ["BaseTransport"],       true, "asyncio.BaseTransport.__name__ == 'BaseTransport'; verified with Python 3.14.3"]
    - [bt_name_len_13,    BaseTransport.__name__.__len__,    [],                      13,   "asyncio.BaseTransport.__name__.__len__() == 13 — 'BaseTransport' has 13 characters; verified with Python 3.14.3"]
    - [bt_module_eq,      BaseTransport.__module__.__eq__,   ["asyncio.transports"],  true, "asyncio.BaseTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [rt_name_eq,        ReadTransport.__name__.__eq__,     ["ReadTransport"],       true, "asyncio.ReadTransport.__name__ == 'ReadTransport'; verified with Python 3.14.3"]
    - [rt_name_len_13,    ReadTransport.__name__.__len__,    [],                      13,   "asyncio.ReadTransport.__name__.__len__() == 13 — 'ReadTransport' has 13 characters; verified with Python 3.14.3"]
    - [rt_module_eq,      ReadTransport.__module__.__eq__,   ["asyncio.transports"],  true, "asyncio.ReadTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [wt_name_eq,        WriteTransport.__name__.__eq__,    ["WriteTransport"],      true, "asyncio.WriteTransport.__name__ == 'WriteTransport'; verified with Python 3.14.3"]
    - [wt_name_len_14,    WriteTransport.__name__.__len__,   [],                      14,   "asyncio.WriteTransport.__name__.__len__() == 14 — 'WriteTransport' has 14 characters; verified with Python 3.14.3"]
    - [wt_module_eq,      WriteTransport.__module__.__eq__,  ["asyncio.transports"],  true, "asyncio.WriteTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [t_name_eq,         Transport.__name__.__eq__,         ["Transport"],           true, "asyncio.Transport.__name__ == 'Transport'; verified with Python 3.14.3"]
    - [t_name_len_9,      Transport.__name__.__len__,        [],                      9,    "asyncio.Transport.__name__.__len__() == 9 — 'Transport' has 9 characters; verified with Python 3.14.3"]
    - [t_module_eq,       Transport.__module__.__eq__,       ["asyncio.transports"],  true, "asyncio.Transport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio transport class inheritance contracts — extra237 namespace
#
# BaseTransport.__bases__[0].__name__ == 'object'.
# ReadTransport.__bases__[0].__name__ == 'BaseTransport'.
# WriteTransport.__bases__[0].__name__ == 'BaseTransport'.
# Transport.__bases__[0].__name__ == 'ReadTransport'.
# Transport.__bases__[1].__name__ == 'WriteTransport'.
# ---------------------------------------------------------------------------

invariant asyncio_extra237.base_transport_base_is_object:
  description: "asyncio.BaseTransport.__bases__[0].__name__ == 'object' — BaseTransport inherits directly from object"
  category: identity
  kind: python_call_eq
  function: BaseTransport.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant asyncio_extra237.read_transport_base_is_base_transport:
  description: "asyncio.ReadTransport.__bases__[0].__name__ == 'BaseTransport' — ReadTransport inherits directly from BaseTransport"
  category: identity
  kind: python_call_eq
  function: ReadTransport.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseTransport"

invariant asyncio_extra237.write_transport_base_is_base_transport:
  description: "asyncio.WriteTransport.__bases__[0].__name__ == 'BaseTransport' — WriteTransport inherits directly from BaseTransport"
  category: identity
  kind: python_call_eq
  function: WriteTransport.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseTransport"

invariant asyncio_extra237.transport_first_base_is_read_transport:
  description: "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' — Transport's first base is ReadTransport (multiple inheritance)"
  category: identity
  kind: python_call_eq
  function: Transport.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ReadTransport"

invariant asyncio_extra237.transport_second_base_is_write_transport:
  description: "asyncio.Transport.__bases__[1].__name__ == 'WriteTransport' — Transport's second base is WriteTransport (multiple inheritance)"
  category: identity
  kind: python_call_eq
  function: Transport.__bases__.__getitem__
  args: [1]
  method: __name__
  method_args: []
  expected: "WriteTransport"
