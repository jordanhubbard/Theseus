# ---------------------------------------------------------------------------
# Parameter kind constants
#
# inspect.Parameter defines five kind constants as ParameterKind enum members.
# Their integer values are fixed by the language spec: POSITIONAL_ONLY=0,
# POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4.
# ---------------------------------------------------------------------------

invariant inspect.parameter.POSITIONAL_ONLY_value:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect.parameter.POSITIONAL_OR_KEYWORD_value:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.value.__eq__
  args: [1]
  expected: true

invariant inspect.parameter.VAR_POSITIONAL_value:
  description: "inspect.Parameter.VAR_POSITIONAL.value == 2"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.value.__eq__
  args: [2]
  expected: true

invariant inspect.parameter.KEYWORD_ONLY_value:
  description: "inspect.Parameter.KEYWORD_ONLY.value == 3"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.value.__eq__
  args: [3]
  expected: true

invariant inspect.parameter.VAR_KEYWORD_value:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# Parameter kind name checks
# ---------------------------------------------------------------------------

invariant inspect.parameter.POSITIONAL_ONLY_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.name.__eq__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect.parameter.VAR_POSITIONAL_name:
  description: "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.name.__eq__
  args: ["VAR_POSITIONAL"]
  expected: true

# ---------------------------------------------------------------------------
# CO_* code flag constants
#
# These integer bit-flags are used in code object co_flags fields.
# Values are fixed constants defined in CPython's code object interface.
# ---------------------------------------------------------------------------

invariant inspect.co_flags.CO_OPTIMIZED:
  description: "inspect.CO_OPTIMIZED == 1"
  category: co_flags
  kind: python_call_eq
  function: CO_OPTIMIZED.__eq__
  args: [1]
  expected: true

invariant inspect.co_flags.CO_NEWLOCALS:
  description: "inspect.CO_NEWLOCALS == 2"
  category: co_flags
  kind: python_call_eq
  function: CO_NEWLOCALS.__eq__
  args: [2]
  expected: true

invariant inspect.co_flags.CO_VARARGS:
  description: "inspect.CO_VARARGS == 4"
  category: co_flags
  kind: python_call_eq
  function: CO_VARARGS.__eq__
  args: [4]
  expected: true

invariant inspect.co_flags.CO_VARKEYWORDS:
  description: "inspect.CO_VARKEYWORDS == 8"
  category: co_flags
  kind: python_call_eq
  function: CO_VARKEYWORDS.__eq__
  args: [8]
  expected: true

invariant inspect.co_flags.CO_GENERATOR:
  description: "inspect.CO_GENERATOR == 32"
  category: co_flags
  kind: python_call_eq
  function: CO_GENERATOR.__eq__
  args: [32]
  expected: true

