spec: inspect
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "inspect source: inspect.py (PSF; source inspection permitted)"
  not_derived_from:
    - "inspect source: internal CPython frame/code object implementation details"
  notes:
    - "inspect.isfunction returns True only for Python functions (def/lambda), not for built-in functions."
    - "inspect.isbuiltin returns True for C-level built-in functions such as len, print, etc."
    - "inspect.isclass returns True for any class object (type instances), False for all non-class values."
    - "inspect.isroutine returns True for any callable that is a function, method, or built-in; False for non-callables."
    - "inspect.isgeneratorfunction and inspect.iscoroutinefunction inspect the CO_GENERATOR/CO_COROUTINE code flags."
    - "inspect.Parameter.POSITIONAL_ONLY.value == 0, POSITIONAL_OR_KEYWORD == 1, VAR_POSITIONAL == 2, KEYWORD_ONLY == 3, VAR_KEYWORD == 4."
    - "inspect.CO_OPTIMIZED == 1, CO_NEWLOCALS == 2, CO_VARARGS == 4, CO_VARKEYWORDS == 8, CO_GENERATOR == 32."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
#
# All public inspect predicates and utilities are Python functions.
# Verify each exports under its expected name.
# ---------------------------------------------------------------------------

invariant inspect.names.isfunction:
  description: "inspect.isfunction.__name__ == 'isfunction'"
  category: names
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect.names.isbuiltin:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin'"
  category: names
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect.names.isclass:
  description: "inspect.isclass.__name__ == 'isclass'"
  category: names
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect.names.ismodule:
  description: "inspect.ismodule.__name__ == 'ismodule'"
  category: names
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect.names.isroutine:
  description: "inspect.isroutine.__name__ == 'isroutine'"
  category: names
  kind: python_call_eq
  function: isroutine.__name__.__eq__
  args: ["isroutine"]
  expected: true

invariant inspect.names.isgeneratorfunction:
  description: "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction'"
  category: names
  kind: python_call_eq
  function: isgeneratorfunction.__name__.__eq__
  args: ["isgeneratorfunction"]
  expected: true

invariant inspect.names.iscoroutinefunction:
  description: "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction'"
  category: names
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect.names.isasyncgenfunction:
  description: "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction'"
  category: names
  kind: python_call_eq
  function: isasyncgenfunction.__name__.__eq__
  args: ["isasyncgenfunction"]
  expected: true

invariant inspect.names.signature:
  description: "inspect.signature.__name__ == 'signature'"
  category: names
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect.names.getmembers:
  description: "inspect.getmembers.__name__ == 'getmembers'"
  category: names
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect.names.getdoc:
  description: "inspect.getdoc.__name__ == 'getdoc'"
  category: names
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

# ---------------------------------------------------------------------------
# Class name checks
#
# inspect exports several namedtuple/class types used in its return values.
# ---------------------------------------------------------------------------

invariant inspect.classnames.Signature:
  description: "inspect.Signature.__name__ == 'Signature'"
  category: classnames
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect.classnames.Parameter:
  description: "inspect.Parameter.__name__ == 'Parameter'"
  category: classnames
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect.classnames.FullArgSpec:
  description: "inspect.FullArgSpec.__name__ == 'FullArgSpec'"
  category: classnames
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect.classnames.FrameInfo:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo'"
  category: classnames
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

# ---------------------------------------------------------------------------
# is* predicate false cases — JSON-primitive arguments
#
# All is* predicates return False when passed plain integers, strings, or
# other non-matching JSON-serializable values. These test vectors exercise
# the rejection paths without requiring Python object references.
# ---------------------------------------------------------------------------

table inspect.isfunction.false_cases:
  description: "inspect.isfunction returns False for non-function values"
  kind: python_call_eq
  category: isfunction
  id_prefix: isf_false
  function: isfunction

  columns: [id, args, expected]
  rows:
    - [int,    [42],       false]
    - [str,    ["hello"],  false]
    - [list,   [[]],       false]
    - [none,   [null],     false]

table inspect.isbuiltin.false_cases:
  description: "inspect.isbuiltin returns False for non-builtin values"
  kind: python_call_eq
  category: isbuiltin
  id_prefix: isb_false
  function: isbuiltin

  columns: [id, args, expected]
  rows:
    - [int,    [42],       false]
    - [str,    ["hello"],  false]
    - [none,   [null],     false]

table inspect.isclass.false_cases:
