spec: abc_extra272
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "This spec covers: collections.abc.Awaitable, collections.abc.Coroutine, and collections.abc.AsyncIterable abstract base class identity. NEW in extra272: collections.abc.Awaitable.__name__=='Awaitable'; collections.abc.Awaitable.__module__=='collections.abc'; collections.abc.Awaitable.__bases__[0].__name__=='object'; collections.abc.Awaitable.__mro__.__len__()==2; collections.abc.Coroutine.__name__=='Coroutine'; collections.abc.Coroutine.__module__=='collections.abc'; collections.abc.Coroutine.__bases__[0].__name__=='Awaitable'; collections.abc.Coroutine.__mro__.__len__()==3 ([Coroutine, Awaitable, object]); collections.abc.AsyncIterable.__name__=='AsyncIterable'; collections.abc.AsyncIterable.__module__=='collections.abc'; collections.abc.AsyncIterable.__bases__[0].__name__=='object'; collections.abc.AsyncIterable.__mro__.__len__()==2; collections.abc.AsyncIterator.__bases__[0].__name__=='AsyncIterable'; collections.abc.AsyncIterator.__mro__.__len__()==3; collections.abc.AsyncGenerator.__bases__[0].__name__=='AsyncIterator'; collections.abc.AsyncGenerator.__mro__.__len__()==4. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable'. Coroutine extends Awaitable in the async ABC hierarchy; Coroutine's MRO is [Coroutine, Awaitable, object] (length=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.AsyncGenerator.__mro__.__len__() == 4. The async generator hierarchy is AsyncGenerator→AsyncIterator→AsyncIterable→object (length=4), the deepest in the async ABC hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc module name has len=15. 'collections.abc' is 15 chars: 'collections'=11 + '.'=1 + 'abc'=3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Awaitable and Coroutine class identity — extra272
#
# collections.abc.Awaitable.__name__               == 'Awaitable'
# collections.abc.Awaitable.__module__             == 'collections.abc'
# collections.abc.Awaitable.__bases__[0].__name__  == 'object'
# collections.abc.Awaitable.__mro__.__len__()      == 2
# collections.abc.Coroutine.__name__               == 'Coroutine'
# collections.abc.Coroutine.__module__             == 'collections.abc'
# collections.abc.Coroutine.__bases__[0].__name__  == 'Awaitable'
# collections.abc.Coroutine.__mro__.__len__()      == 3
# ---------------------------------------------------------------------------

table abc_extra272.cabc_awaitable_coroutine_identity:
  description: "collections.abc.Awaitable and Coroutine class identity checks in cabcasync272 namespace — collections.abc.Awaitable is the abstract base class for awaitable objects (those with __await__); Awaitable.__name__.__eq__('Awaitable')==True; Awaitable.__module__.__eq__('collections.abc')==True (len=15: 'collections'=11 + '.abc'=4); Awaitable.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, root of the async ABC sub-hierarchy); Awaitable.__mro__.__len__()==2 ([Awaitable, object]); Awaitable.__qualname__.__eq__('Awaitable')==True; collections.abc.Coroutine extends Awaitable; Coroutine.__name__.__eq__('Coroutine')==True; Coroutine.__module__.__eq__('collections.abc')==True (same module as Awaitable); Coroutine.__bases__[0].__name__.__eq__('Awaitable')==True (Coroutine inherits from Awaitable as sole direct base); Coroutine.__mro__.__len__()==3 ([Coroutine, Awaitable, object]); Coroutine.__qualname__.__eq__('Coroutine')==True; Awaitable.__name__.__len__()==9; Coroutine.__name__.__len__()==9 (equal length to Awaitable); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcasync272

  columns: [id, function, args, expected, description]
  rows:
    - [aw_name_eq,     collections.abc.Awaitable.__name__.__eq__,                   ["Awaitable"],        true, "collections.abc.Awaitable.__name__ == 'Awaitable'; verified with Python 3.14.3"]
    - [aw_mod_eq,      collections.abc.Awaitable.__module__.__eq__,                 ["collections.abc"],  true, "collections.abc.Awaitable.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [aw_base0_eq,    "collections.abc.Awaitable.__bases__[0].__name__.__eq__",    ["object"],           true, "collections.abc.Awaitable.__bases__[0].__name__ == 'object' — direct subclass; verified with Python 3.14.3"]
    - [aw_mro_len,     collections.abc.Awaitable.__mro__.__len__,                   [],                   2,    "collections.abc.Awaitable.__mro__.__len__() == 2 — [Awaitable, object]; verified with Python 3.14.3"]
    - [aw_qn_eq,       collections.abc.Awaitable.__qualname__.__eq__,               ["Awaitable"],        true, "collections.abc.Awaitable.__qualname__ == 'Awaitable'; verified with Python 3.14.3"]
    - [co_name_eq,     collections.abc.Coroutine.__name__.__eq__,                   ["Coroutine"],        true, "collections.abc.Coroutine.__name__ == 'Coroutine'; verified with Python 3.14.3"]
    - [co_mod_eq,      collections.abc.Coroutine.__module__.__eq__,                 ["collections.abc"],  true, "collections.abc.Coroutine.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [co_base0_eq,    "collections.abc.Coroutine.__bases__[0].__name__.__eq__",    ["Awaitable"],        true, "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable' — Coroutine extends Awaitable; verified with Python 3.14.3"]
    - [co_mro_len,     collections.abc.Coroutine.__mro__.__len__,                   [],                   3,    "collections.abc.Coroutine.__mro__.__len__() == 3 — [Coroutine, Awaitable, object]; verified with Python 3.14.3"]
    - [co_qn_eq,       collections.abc.Coroutine.__qualname__.__eq__,               ["Coroutine"],        true, "collections.abc.Coroutine.__qualname__ == 'Coroutine'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc.AsyncIterable, AsyncIterator, and AsyncGenerator — extra272
#
# collections.abc.AsyncIterable.__name__               == 'AsyncIterable'
# collections.abc.AsyncIterable.__module__             == 'collections.abc'
# collections.abc.AsyncIterable.__bases__[0].__name__  == 'object'
# collections.abc.AsyncIterable.__mro__.__len__()      == 2
# collections.abc.AsyncIterator.__bases__[0].__name__  == 'AsyncIterable'
# collections.abc.AsyncIterator.__mro__.__len__()      == 3
# collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'
# collections.abc.AsyncGenerator.__mro__.__len__()     == 4
# ---------------------------------------------------------------------------

table abc_extra272.cabc_asynciterable_iterator_generator:
  description: "collections.abc.AsyncIterable, AsyncIterator, and AsyncGenerator class identity checks in cabcasync272 namespace — the async iteration hierarchy: AsyncIterable→object (depth=2), AsyncIterator→AsyncIterable→object (depth=3), AsyncGenerator→AsyncIterator→AsyncIterable→object (depth=4); AsyncIterable.__name__.__eq__('AsyncIterable')==True; AsyncIterable.__module__.__eq__('collections.abc')==True; AsyncIterable.__bases__[0].__name__.__eq__('object')==True (root of async iteration hierarchy, direct subclass of object); AsyncIterable.__mro__.__len__()==2; AsyncIterable.__name__.__len__()==13; collections.abc.AsyncIterator.__name__.__eq__('AsyncIterator')==True; AsyncIterator.__module__.__eq__('collections.abc')==True; AsyncIterator.__bases__[0].__name__.__eq__('AsyncIterable')==True; AsyncIterator.__mro__.__len__()==3; AsyncIterator.__name__.__len__()==13 (equal to AsyncIterable); collections.abc.AsyncGenerator.__name__.__eq__('AsyncGenerator')==True; AsyncGenerator.__module__.__eq__('collections.abc')==True; AsyncGenerator.__bases__[0].__name__.__eq__('AsyncIterator')==True; AsyncGenerator.__mro__.__len__()==4 (deepest in async ABC hierarchy); AsyncGenerator.__name__.__len__()==14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcasync272a

  columns: [id, function, args, expected, description]
  rows:
    - [ai_name_eq,     collections.abc.AsyncIterable.__name__.__eq__,                  ["AsyncIterable"],   true, "collections.abc.AsyncIterable.__name__ == 'AsyncIterable'; verified with Python 3.14.3"]
    - [ai_mod_eq,      collections.abc.AsyncIterable.__module__.__eq__,                ["collections.abc"], true, "collections.abc.AsyncIterable.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [ai_base0_eq,    "collections.abc.AsyncIterable.__bases__[0].__name__.__eq__",   ["object"],          true, "collections.abc.AsyncIterable.__bases__[0].__name__ == 'object' — root of async iteration hierarchy; verified with Python 3.14.3"]
    - [ai_mro_len,     collections.abc.AsyncIterable.__mro__.__len__,                  [],                  2,    "collections.abc.AsyncIterable.__mro__.__len__() == 2 — [AsyncIterable, object]; verified with Python 3.14.3"]
    - [ai_name_len,    collections.abc.AsyncIterable.__name__.__len__,                 [],                  13,   "collections.abc.AsyncIterable.__name__.__len__() == 13 ('AsyncIterable'=13); verified with Python 3.14.3"]
    - [ait_name_eq,    collections.abc.AsyncIterator.__name__.__eq__,                  ["AsyncIterator"],   true, "collections.abc.AsyncIterator.__name__ == 'AsyncIterator'; verified with Python 3.14.3"]
    - [ait_base0_eq,   "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__",   ["AsyncIterable"],   true, "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable'; verified with Python 3.14.3"]
    - [ait_mro_len,    collections.abc.AsyncIterator.__mro__.__len__,                  [],                  3,    "collections.abc.AsyncIterator.__mro__.__len__() == 3 — [AsyncIterator, AsyncIterable, object]; verified with Python 3.14.3"]
    - [ag_name_eq,     collections.abc.AsyncGenerator.__name__.__eq__,                 ["AsyncGenerator"],  true, "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator'; verified with Python 3.14.3"]
    - [ag_mod_eq,      collections.abc.AsyncGenerator.__module__.__eq__,               ["collections.abc"], true, "collections.abc.AsyncGenerator.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [ag_base0_eq,    "collections.abc.AsyncGenerator.__bases__[0].__name__.__eq__",  ["AsyncIterator"],   true, "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'; verified with Python 3.14.3"]
    - [ag_mro_len,     collections.abc.AsyncGenerator.__mro__.__len__,                 [],                  4,    "collections.abc.AsyncGenerator.__mro__.__len__() == 4 — deepest in async ABC hierarchy [AsyncGenerator, AsyncIterator, AsyncIterable, object]; verified with Python 3.14.3"]
    - [ag_name_len,    collections.abc.AsyncGenerator.__name__.__len__,                [],                  14,   "collections.abc.AsyncGenerator.__name__.__len__() == 14 ('AsyncGenerator'=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra272
# ---------------------------------------------------------------------------

invariant abc_extra272.Awaitable_module_is_collections_abc:
  description: "collections.abc.Awaitable.__module__.__eq__('collections.abc') returns True — collections.abc.Awaitable is defined in Lib/_collections_abc.py; its __module__ is 'collections.abc' (len=15: 'collections'=11 + '.'=1 + 'abc'=3); all async abstract base classes in this spec (Awaitable, Coroutine, AsyncIterable, AsyncIterator, AsyncGenerator) share __module__ 'collections.abc'; this contrasts with asyncio.protocols classes (asyncio.Protocol, asyncio.BaseProtocol, asyncio.DatagramProtocol) whose __module__ is 'asyncio.protocols'; Awaitable is the simplest async ABC — it requires only __await__(); Awaitable.__mro__.__len__() is 2 ([Awaitable, object]); Awaitable.__bases__[0].__name__ is 'object'; NEW in extra272: first standalone Awaitable.__module__ invariant in cabcasync272 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra272.Coroutine_base_is_Awaitable:
  description: "collections.abc.Coroutine.__bases__[0].__name__.__eq__('Awaitable') returns True — collections.abc.Coroutine inherits from collections.abc.Awaitable as its sole direct base; Coroutine's MRO is [Coroutine, Awaitable, object] (length=3); this parallels asyncio.Protocol→BaseProtocol→object and asyncio.Task→Future→object; Coroutine requires __await__() (inherited from Awaitable) plus send(), throw(), and close() abstract methods; Coroutine.__module__ is 'collections.abc'; Coroutine.__qualname__ is 'Coroutine'; Coroutine.__name__.__len__() is 9 (equal to Awaitable.__name__.__len__() == 9); NEW in extra272: first standalone Coroutine base class invariant in cabcasync272 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Coroutine.__bases__[0].__name__.__eq__"
  args: ["Awaitable"]
  expected: true

invariant abc_extra272.AsyncGenerator_mro_len_is_4:
  description: "collections.abc.AsyncGenerator.__mro__.__len__() == 4 — AsyncGenerator's MRO is [AsyncGenerator, AsyncIterator, AsyncIterable, object] (length=4); this is the deepest hierarchy among the async ABCs in this spec; compare async ABC MRO depths: Awaitable=2, AsyncIterable=2, Coroutine=3, AsyncIterator=3, AsyncGenerator=4; the 4-element chain means AsyncGenerator inherits abstract methods from three levels: AsyncIterator (__anext__, __aiter__), AsyncIterable (__aiter__), and Awaitable-like semantics; AsyncGenerator.__bases__[0].__name__ is 'AsyncIterator'; AsyncGenerator.__module__ is 'collections.abc'; AsyncGenerator.__name__.__len__() is 14 ('AsyncGenerator'=14, the longest async ABC name in this spec); NEW in extra272: first standalone AsyncGenerator MRO length invariant in cabcasync272 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__mro__.__len__
  args: []
  expected: 4

invariant abc_extra272.AsyncIterable_mro_len_is_2:
  description: "collections.abc.AsyncIterable.__mro__.__len__() == 2 — AsyncIterable's MRO is [AsyncIterable, object] (length=2); AsyncIterable is the root of the async iteration hierarchy — both AsyncIterator and AsyncGenerator ultimately inherit from it; AsyncIterable requires only one abstract method: __aiter__(); AsyncIterable.__bases__[0].__name__ is 'object' (direct subclass); AsyncIterable.__module__ is 'collections.abc'; AsyncIterable.__name__.__len__() is 13 ('AsyncIterable'=13, equal to AsyncIterator's length); the async iteration hierarchy depths: AsyncIterable=2, AsyncIterator=3, AsyncGenerator=4; compare with Awaitable (also depth=2, root of async awaitable hierarchy); NEW in extra272: first standalone AsyncIterable MRO length invariant in cabcasync272 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterable.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra272.AsyncIterator_base_is_AsyncIterable:
  description: "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__('AsyncIterable') returns True — AsyncIterator inherits from AsyncIterable as its sole direct base; AsyncIterator's MRO is [AsyncIterator, AsyncIterable, object] (length=3); AsyncIterator adds __anext__() as an additional abstract method on top of AsyncIterable's __aiter__(); AsyncGenerator in turn inherits from AsyncIterator; AsyncIterator.__module__ is 'collections.abc'; AsyncIterator.__name__ is 'AsyncIterator' (len=13, equal to AsyncIterable's len=13); the AsyncIterable→AsyncIterator→AsyncGenerator chain exactly mirrors the synchronous Iterable→Iterator→Generator chain in collections.abc; NEW in extra272: first standalone AsyncIterator base class invariant in cabcasync272 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterable"]
  expected: true

invariant abc_extra272.Coroutine_mro_len_is_3:
  description: "collections.abc.Coroutine.__mro__.__len__() == 3 — Coroutine's MRO is [Coroutine, Awaitable, object] (length=3); Coroutine extends Awaitable, adding send(), throw(), and close() abstract methods; this 3-element chain parallels asyncio.Protocol→BaseProtocol→object and AsyncIterator→AsyncIterable→object; Coroutine.__module__ is 'collections.abc'; Coroutine.__name__.__len__() is 9 ('Coroutine'=9, equal to Awaitable.__name__.__len__()==9); compare async ABC MRO depths in this spec: Awaitable=2, AsyncIterable=2, Coroutine=3, AsyncIterator=3, AsyncGenerator=4 (deepest); NEW in extra272: first standalone Coroutine MRO length invariant in cabcasync272 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__mro__.__len__
  args: []
  expected: 3
