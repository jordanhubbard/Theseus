spec: inspect_extra147
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature — __name__ 'Signature' len 9, __module__ 'inspect', __doc__ len 970, __bases__[0].__name__ 'object', MRO len 2; inspect.Signature.from_callable — __qualname__ 'Signature.from_callable' len 23, __class__.__name__ 'method'; inspect.Signature.bind — __qualname__ 'Signature.bind' len 14; inspect.Signature.__init__ — __qualname__ 'Signature.__init__' len 18; inspect.Parameter — __name__ 'Parameter' len 9, __module__ 'inspect', __doc__ len 708, __bases__[0].__name__ 'object', MRO len 2; inspect.Parameter kind constants — POSITIONAL_ONLY.value 0, POSITIONAL_OR_KEYWORD.value 1, VAR_POSITIONAL.value 2, KEYWORD_ONLY.value 3, VAR_KEYWORD.value 4 (Wave 270)."
    - "inspect.Signature is a Python class defined in Lib/inspect.py; __name__ == 'Signature' (len 9); __module__ == 'inspect'; len(__doc__) == 970; __bases__[0].__name__ == 'object'; len(__mro__) == 2. Verified with Python 3.14.3."
    - "inspect.Signature.from_callable is a classmethod; __class__.__name__ == 'method'; __qualname__ == 'Signature.from_callable' (len 23). Verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' (len 14). Verified with Python 3.14.3."
    - "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' (len 18). Verified with Python 3.14.3."
    - "inspect.Parameter is a Python class; __name__ == 'Parameter' (len 9); __module__ == 'inspect'; len(__doc__) == 708; __bases__[0].__name__ == 'object'; len(__mro__) == 2. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.value == 0; POSITIONAL_OR_KEYWORD.value == 1; VAR_POSITIONAL.value == 2; KEYWORD_ONLY.value == 3; VAR_KEYWORD.value == 4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature — Python class identity and method qualnames
#
# Wave 270 theme: inspect.Signature — represents the call signature of a callable;
# its class identity, docstring length, and method qualnames.
#
# inspect.Signature.__name__ == 'Signature' (len 9)
# inspect.Signature.__module__ == 'inspect'
# len(inspect.Signature.__doc__) == 970
# inspect.Signature.__bases__[0].__name__ == 'object'
# len(inspect.Signature.__mro__) == 2
# inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable' (len 23)
# inspect.Signature.from_callable.__class__.__name__ == 'method'
# inspect.Signature.bind.__qualname__ == 'Signature.bind' (len 14)
# inspect.Signature.__init__.__qualname__ == 'Signature.__init__' (len 18)
#
# inspect.Signature is a Python class with class methods (from_callable) and
# regular methods (bind, bind_partial, __init__). New to extra147.
# ---------------------------------------------------------------------------

table inspect_extra147.signature_identity:
  description: "inspect.Signature: __name__ 'Signature' len 9, __module__ 'inspect', __doc__ len 970, __bases__[0]=='object', MRO len 2; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsig147

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — inspect.Signature is a Python class defined in Lib/inspect.py; its __name__ attribute is 'Signature'; str.__eq__('Signature') returns True; new to extra147"]
    - [signature_name_len_eq_9,
       "Signature.__name__.__len__",
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — __name__ is 'Signature' which has 9 characters; len('Signature') == 9; new to extra147"]
    - [signature_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra147"]
    - [signature_doc_len_eq_970,
       "Signature.__doc__.__len__",
       [],
       970,
       "inspect.Signature.__doc__.__len__() == 970 — the Signature class docstring has 970 characters; it describes the overall signature of a function with its parameters and return annotation; len(__doc__) == 970; verified with Python 3.14.3; new to extra147"]
    - [signature_bases_first_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]
    - [signature_mro_len_eq_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — the MRO of Signature is [Signature, object]; MRO length is 2; new to extra147"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature method qualnames
#
# Wave 270 theme: qualnames of key methods on inspect.Signature.
#
# inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable' (len 23)
# inspect.Signature.from_callable.__class__.__name__ == 'method'
# inspect.Signature.bind.__qualname__ == 'Signature.bind' (len 14)
# inspect.Signature.bind.__class__.__name__ == 'function'
# inspect.Signature.__init__.__qualname__ == 'Signature.__init__' (len 18)
#
# from_callable is a classmethod (appears as 'method'); bind and __init__
# are ordinary methods (appear as 'function' when accessed on the class).
# New to extra147.
# ---------------------------------------------------------------------------

table inspect_extra147.signature_method_qualnames:
  description: "inspect.Signature.from_callable.__qualname__ len 23 (classmethod); bind.__qualname__ len 14; __init__.__qualname__ len 18; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsig147

  columns: [id, function, args, expected, description]
  rows:
    - [from_callable_class_eq_method,
       "Signature.from_callable.__class__.__name__.__eq__",
       ["method"],
       true,
       "inspect.Signature.from_callable.__class__.__name__.__eq__('method') == True — from_callable is defined as a @classmethod in Lib/inspect.py; when accessed on the class, classmethods appear as bound method objects; __class__.__name__ is 'method'; str.__eq__('method') returns True; new to extra147"]
    - [from_callable_qualname_eq,
       "Signature.from_callable.__qualname__.__eq__",
       ["Signature.from_callable"],
       true,
       "inspect.Signature.from_callable.__qualname__.__eq__('Signature.from_callable') == True — the classmethod qualname includes the class prefix; __qualname__ is 'Signature.from_callable'; str.__eq__ returns True; new to extra147"]
    - [from_callable_qualname_len_eq_23,
       "Signature.from_callable.__qualname__.__len__",
       [],
       23,
       "inspect.Signature.from_callable.__qualname__.__len__() == 23 — __qualname__ is 'Signature.from_callable' which has 23 characters; len('Signature.from_callable') == 23; new to extra147"]
    - [bind_qualname_eq,
       "Signature.bind.__qualname__.__eq__",
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — bind is an ordinary method on Signature; accessed on the class it is a function; __qualname__ is 'Signature.bind'; str.__eq__ returns True; new to extra147"]
    - [bind_qualname_len_eq_14,
       "Signature.bind.__qualname__.__len__",
       [],
       14,
       "inspect.Signature.bind.__qualname__.__len__() == 14 — __qualname__ is 'Signature.bind' which has 14 characters; len('Signature.bind') == 14; new to extra147"]
    - [init_qualname_eq,
       "Signature.__init__.__qualname__.__eq__",
       ["Signature.__init__"],
       true,
       "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — the Signature initializer's __qualname__ is 'Signature.__init__'; str.__eq__ returns True; new to extra147"]
    - [init_qualname_len_eq_18,
       "Signature.__init__.__qualname__.__len__",
       [],
       18,
       "inspect.Signature.__init__.__qualname__.__len__() == 18 — __qualname__ is 'Signature.__init__' which has 18 characters; len('Signature.__init__') == 18; new to extra147"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter — Python class identity
#
# Wave 270 theme: inspect.Parameter represents a parameter in a callable's
# signature, with attributes like name, default, annotation, kind.
#
# inspect.Parameter.__name__ == 'Parameter' (len 9)
# inspect.Parameter.__module__ == 'inspect'
# len(inspect.Parameter.__doc__) == 708
# inspect.Parameter.__bases__[0].__name__ == 'object'
# len(inspect.Parameter.__mro__) == 2
#
# Parameter is a Python class defined in Lib/inspect.py with an inner enum
# class _ParameterKind for the kind constants. New to extra147.
# ---------------------------------------------------------------------------

table inspect_extra147.parameter_identity:
  description: "inspect.Parameter: __name__ 'Parameter' len 9, __module__ 'inspect', __doc__ len 708, __bases__[0]=='object', MRO len 2; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam147

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — inspect.Parameter is a Python class defined in Lib/inspect.py; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra147"]
    - [parameter_name_len_eq_9,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — __name__ is 'Parameter' which has 9 characters; len('Parameter') == 9; new to extra147"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra147"]
    - [parameter_doc_len_eq_708,
       "Parameter.__doc__.__len__",
       [],
       708,
       "inspect.Parameter.__doc__.__len__() == 708 — the Parameter class docstring has 708 characters; it describes the parameter object attributes (name, default, annotation, kind); len(__doc__) == 708; verified with Python 3.14.3; new to extra147"]
    - [parameter_bases_first_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — the MRO of Parameter is [Parameter, object]; MRO length is 2; new to extra147"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Parameter kind constants (enum values)
#
# Wave 270 theme: inspect.Parameter defines five kind constants as members of
# the _ParameterKind enum, with integer values 0-4.
#
# inspect.Parameter.POSITIONAL_ONLY.value == 0
# inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1
# inspect.Parameter.VAR_POSITIONAL.value == 2
# inspect.Parameter.KEYWORD_ONLY.value == 3
# inspect.Parameter.VAR_KEYWORD.value == 4
#
# The kind constants are _ParameterKind enum members. Their integer values
# establish the ordering used internally. New to extra147.
# ---------------------------------------------------------------------------

table inspect_extra147.parameter_kind_values:
  description: "inspect.Parameter kind constants: POSITIONAL_ONLY==0, POSITIONAL_OR_KEYWORD==1, VAR_POSITIONAL==2, KEYWORD_ONLY==3, VAR_KEYWORD==4; wave 270; new to extra147"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam147

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_value_eq_0,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY is the first _ParameterKind enum member; its integer value is 0; int.__eq__(0) returns True; new to extra147"]
    - [positional_or_keyword_value_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD has enum value 1; int.__eq__(1) returns True; new to extra147"]
    - [var_positional_value_eq_2,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL (*args) has enum value 2; int.__eq__(2) returns True; new to extra147"]
    - [keyword_only_value_eq_3,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY has enum value 3; int.__eq__(3) returns True; new to extra147"]
    - [var_keyword_value_eq_4,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD (**kwargs) has enum value 4; int.__eq__(4) returns True; new to extra147"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra147
# ---------------------------------------------------------------------------

invariant inspect_extra147.signature_name_len:
  description: "len(inspect.Signature.__name__) == 9 — __name__ is 'Signature'; wave 270; new to extra147"
  kind: python_call_eq
  function: Signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra147.signature_doc_len:
  description: "len(inspect.Signature.__doc__) == 970 — the Signature class docstring has 970 characters; wave 270; new to extra147"
  kind: python_call_eq
  function: Signature.__doc__.__len__
  args: []
  expected: 970

invariant inspect_extra147.signature_bases_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits only from object; wave 270; new to extra147"
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra147.from_callable_qualname_len:
  description: "len(inspect.Signature.from_callable.__qualname__) == 23 — __qualname__ is 'Signature.from_callable'; wave 270; new to extra147"
  kind: python_call_eq
  function: Signature.from_callable.__qualname__.__len__
  args: []
  expected: 23

invariant inspect_extra147.bind_qualname_len:
  description: "len(inspect.Signature.bind.__qualname__) == 14 — __qualname__ is 'Signature.bind'; wave 270; new to extra147"
  kind: python_call_eq
  function: Signature.bind.__qualname__.__len__
  args: []
  expected: 14

invariant inspect_extra147.parameter_doc_len:
  description: "len(inspect.Parameter.__doc__) == 708 — the Parameter class docstring has 708 characters; wave 270; new to extra147"
  kind: python_call_eq
  function: Parameter.__doc__.__len__
  args: []
  expected: 708

invariant inspect_extra147.parameter_bases_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits only from object; wave 270; new to extra147"
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra147.positional_only_value:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0 — first _ParameterKind enum member; wave 270; new to extra147"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra147.var_keyword_value:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4 — VAR_KEYWORD (**kwargs) is the last _ParameterKind enum member with value 4; wave 270; new to extra147"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true
