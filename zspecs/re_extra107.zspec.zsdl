spec: re_extra107
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra106.zspec.zsdl."
    - "This spec covers: re module function __code__.co_name and __code__.co_argcount values, and re.Pattern method __qualname__ values."
    - "re.match.__code__.co_name = 'match', co_argcount = 3."
    - "re.search.__code__.co_name = 'search', co_argcount = 3."
    - "re.findall.__code__.co_name = 'findall', co_argcount = 3."
    - "re.compile.__code__.co_name = 'compile', co_argcount = 2."
    - "re.sub.__code__.co_name = 'sub', co_argcount = 3."
    - "re.fullmatch.__code__.co_name = 'fullmatch', co_argcount = 3."
    - "re.split.__code__.co_name = 'split', co_argcount = 2."
    - "re.subn.__code__.co_name = 'subn', co_argcount = 3."
    - "re.finditer.__code__.co_name = 'finditer', co_argcount = 3."
    - "re.Pattern.match.__qualname__ = 'Pattern.match'."
    - "re.Pattern.search.__qualname__ = 'Pattern.search'."
    - "re.Pattern.findall.__qualname__ = 'Pattern.findall', re.Pattern.split.__qualname__ = 'Pattern.split'."
    - "re.Pattern.fullmatch.__qualname__ = 'Pattern.fullmatch'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __code__.co_name values
# re.match, re.search, re.findall, re.compile, re.sub, re.fullmatch are all
# Python-level wrapper functions in Lib/re/__init__.py.
# Each function's __code__.co_name equals the function's own name.
# ---------------------------------------------------------------------------

table re_extra107.function_co_names:
  description: "re module function __code__.co_name values: match='match', search='search', findall='findall', compile='compile', sub='sub', fullmatch='fullmatch', split='split', subn='subn'"
  kind: python_call_eq
  category: code_attributes
  id_prefix: reconame107a

  columns: [id, function, args, expected, description]
  rows:
    - [match_co_name,     match.__code__.co_name.__eq__,     ["match"],     true,  "re.match.__code__.co_name == 'match'"]
    - [search_co_name,    search.__code__.co_name.__eq__,    ["search"],    true,  "re.search.__code__.co_name == 'search'"]
    - [findall_co_name,   findall.__code__.co_name.__eq__,   ["findall"],   true,  "re.findall.__code__.co_name == 'findall'"]
    - [compile_co_name,   compile.__code__.co_name.__eq__,   ["compile"],   true,  "re.compile.__code__.co_name == 'compile'"]
    - [sub_co_name,       sub.__code__.co_name.__eq__,       ["sub"],       true,  "re.sub.__code__.co_name == 'sub'"]
    - [fullmatch_co_name, fullmatch.__code__.co_name.__eq__, ["fullmatch"], true,  "re.fullmatch.__code__.co_name == 'fullmatch'"]
    - [split_co_name,     split.__code__.co_name.__eq__,     ["split"],     true,  "re.split.__code__.co_name == 'split'"]
    - [subn_co_name,      subn.__code__.co_name.__eq__,      ["subn"],      true,  "re.subn.__code__.co_name == 'subn'"]
    - [match_not_search,  match.__code__.co_name.__eq__,     ["search"],    false, "re.match.__code__.co_name != 'search' (match and search are distinct functions)"]

# ---------------------------------------------------------------------------
# re module function __code__.co_argcount values
# match/search/findall/sub/fullmatch/subn/finditer: co_argcount=3
# compile/split: co_argcount=2
# ---------------------------------------------------------------------------

table re_extra107.function_co_argcounts:
  description: "re module function __code__.co_argcount values: match/search/findall/sub/fullmatch/subn/finditer=3, compile/split=2"
  kind: python_call_eq
  category: code_attributes
  id_prefix: reconame107b

  columns: [id, function, args, expected, description]
  rows:
    - [match_argc,     match.__code__.co_argcount.__eq__,     [3], true,  "re.match.__code__.co_argcount == 3"]
    - [search_argc,    search.__code__.co_argcount.__eq__,    [3], true,  "re.search.__code__.co_argcount == 3"]
    - [findall_argc,   findall.__code__.co_argcount.__eq__,   [3], true,  "re.findall.__code__.co_argcount == 3"]
    - [compile_argc,   compile.__code__.co_argcount.__eq__,   [2], true,  "re.compile.__code__.co_argcount == 2 (pattern and flags only)"]
    - [sub_argc,       sub.__code__.co_argcount.__eq__,       [3], true,  "re.sub.__code__.co_argcount == 3"]
    - [fullmatch_argc, fullmatch.__code__.co_argcount.__eq__, [3], true,  "re.fullmatch.__code__.co_argcount == 3"]
    - [split_argc,     split.__code__.co_argcount.__eq__,     [2], true,  "re.split.__code__.co_argcount == 2 (pattern and string, maxsplit is keyword)"]
    - [subn_argc,      subn.__code__.co_argcount.__eq__,      [3], true,  "re.subn.__code__.co_argcount == 3"]
    - [finditer_argc,  finditer.__code__.co_argcount.__eq__,  [3], true,  "re.finditer.__code__.co_argcount == 3"]

# ---------------------------------------------------------------------------
# Compiled re.Pattern method type names
# Pattern.match, Pattern.search, Pattern.fullmatch, Pattern.sub are builtin_method.
# Pattern.findall and Pattern.split are builtin_function_or_method.
# Pattern.finditer is builtin_method.
# ---------------------------------------------------------------------------

table re_extra107.Pattern_method_qualnames:
  description: "re.Pattern class method __qualname__ values: match='Pattern.match', search='Pattern.search', findall='Pattern.findall', split='Pattern.split', fullmatch='Pattern.fullmatch'"
  kind: python_call_eq
  category: code_attributes
  id_prefix: reconame107c

  columns: [id, function, args, expected, description]
  rows:
    - [pat_match_qn,     Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true,  "re.Pattern.match.__qualname__ == 'Pattern.match'"]
    - [pat_search_qn,    Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true,  "re.Pattern.search.__qualname__ == 'Pattern.search'"]
    - [pat_findall_qn,   Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true,  "re.Pattern.findall.__qualname__ == 'Pattern.findall'"]
    - [pat_split_qn,     Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true,  "re.Pattern.split.__qualname__ == 'Pattern.split'"]
    - [pat_fullmatch_qn, Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true,  "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch'"]
    - [pat_match_not_s,  Pattern.match.__qualname__.__eq__,     ["Pattern.search"],    false, "re.Pattern.match.__qualname__ != 'Pattern.search' (match and search are distinct methods)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra107.match.co_name_is_match:
  description: "re.match.__code__.co_name == 'match' (the Python wrapper function in Lib/re/__init__.py; co_name records the function name as written in source)"
  category: code_attributes
  kind: python_call_eq
  function: match.__code__.co_name.__eq__
  args: ["match"]
  expected: true

invariant re_extra107.compile.co_argcount_is_2:
  description: "re.compile.__code__.co_argcount == 2 (re.compile takes 'pattern' and 'flags' as positional-or-keyword arguments; the remaining two-argument wrapper functions are compile and split)"
  category: code_attributes
  kind: python_call_eq
  function: compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra107.fullmatch.co_name_is_fullmatch:
  description: "re.fullmatch.__code__.co_name == 'fullmatch' (introduced in Python 3.4; matches pattern against the entire string; co_name equals 'fullmatch')"
  category: code_attributes
  kind: python_call_eq
  function: fullmatch.__code__.co_name.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra107.sub.co_argcount_is_3:
  description: "re.sub.__code__.co_argcount == 3 (re.sub takes 'pattern', 'repl', 'string' as positional-or-keyword args; count and flags are additional keyword args not counted in co_argcount)"
  category: code_attributes
  kind: python_call_eq
  function: sub.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra107.findall.co_name_is_findall:
  description: "re.findall.__code__.co_name == 'findall' (returns all non-overlapping matches as a list; Python wrapper function with co_name == 'findall' and co_argcount == 3)"
  category: code_attributes
  kind: python_call_eq
  function: findall.__code__.co_name.__eq__
  args: ["findall"]
  expected: true

