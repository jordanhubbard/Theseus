spec: abc_extra2521
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc (Abstract Base Classes) documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __bool__, __index__, __int__ dict-presence checks — truthiness, integer coercion, and indexing protocol."
    - "abc.ABC and abc.ABCMeta define none of these dunder methods in their own __dict__."
    - "abc.ABCMeta is a metaclass (type: type); abc.ABC is a plain helper class using ABCMeta as metaclass."
    - "__dict__.__contains__ returns False for __bool__, __index__, __int__ on both classes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC — bool/index/int dict-presence
# ---------------------------------------------------------------------------

table abc_extra2521.abc_bool_int_index:
  description: "abc.ABC.__dict__ contains no __bool__, __index__, or __int__; all __dict__.__contains__ calls return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab2521

  columns: [id, function, args, expected]
  rows:
    - ["ab2521001", abc.ABC.__dict__.__contains__, ["__bool__"], false]
    - ["ab2521002", abc.ABC.__dict__.__contains__, ["__index__"], false]
    - ["ab2521003", abc.ABC.__dict__.__contains__, ["__int__"], false]

