invariant struct_extra169.Struct_name_eq:
  description: "struct.Struct.__name__.__eq__('Struct') == True — 'Struct' (6 chars, CamelCase; struct.Struct is the compiled C class from Modules/_struct.c that represents a compiled struct format; creating a Struct instance pre-compiles the format string for repeated use, which is faster than calling pack/unpack each time; 'Struct'(6 chars) = 6 letters in CamelCase; 'Struct'(6) < '_struct'(7) by 1: the class name is 1 char shorter than the C extension module name; struct_extra166 anchors Struct.__name__.__eq__('Struct') as a table row; this spec provides a fresh anchor under structclass169 as a standalone; first structclass169 standalone for Struct.__name__.__eq__('Struct')"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct' (7 chars). The Struct class lives in the
# C extension module _struct. struct_extra166 anchors this; fresh anchor here.
# '_struct'(7) = '_'=1 + 'struct'=6: the underscore prefix marks a private C extension.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra169.Struct_module_eq:
  description: "struct.Struct.__module__.__eq__('_struct') == True — '_struct' (7 chars = '_'=1 + 'struct'=6; struct.Struct is defined in the C extension module _struct (Modules/_struct.c); the underscore prefix conventionally marks a private or internal C extension module that provides the optimized implementation for the public Python module; '_struct'(7) > 'Struct'(6) by 1: the C module name is 1 char longer than the class name due to the leading underscore; struct_extra166 anchors Struct.__module__.__eq__('_struct') as a table row; this spec provides a fresh standalone anchor under structclass169; first structclass169 standalone for Struct.__module__.__eq__('_struct')"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error' (5 chars, all lowercase). Lowercase class name
# is unusual in Python; struct.error follows the older CPython convention.
# struct_extra161 anchors this; fresh anchor here under structclass169.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra169.error_name_eq:
  description: "struct.error.__name__.__eq__('error') == True — 'error' (5 chars, all lowercase; struct.error is the exception raised when packing or unpacking fails — e.g., wrong number of values for format or value out of range; the lowercase class name 'error' follows an older CPython convention (shared with re.error, csv.Error, etc.) where exception names were not yet standardized to CamelCase; 'error'(5 chars) < 'Struct'(6 chars) by 1: the exception class name is 1 char shorter than the data class name; struct_extra161 anchors error.__name__=='error' as a table row; this spec provides a fresh standalone anchor under structclass169; first structclass169 standalone for error.__name__.__eq__('error')"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct' (6 chars). struct.error lives in the Python-level
# struct module (Lib/struct.py), not in _struct.c. struct_extra161 anchors this.
# struct.error.__module__.__len__()==6 == struct.Struct.__name__.__len__()==6: coincidental tie.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra169.error_module_eq:
  description: "struct.error.__module__.__eq__('struct') == True — 'struct' (6 chars; struct.error is defined in the Python-level struct module (Lib/struct.py) — not in the C extension _struct; this contrasts with struct.Struct whose __module__ is '_struct'; struct.error.__module__=='struct'(6) while struct.Struct.__module__=='_struct'(7): the error class lives in the Python wrapper while the Struct class lives in the C extension; struct.error.__module__.__len__()==6 == struct.Struct.__name__.__len__()==6 — coincidental: error's module name length equals Struct's class name length; struct_extra161 anchors error.__module__=='struct' as a table row; this spec provides a fresh standalone anchor under structclass169; first structclass169 standalone for error.__module__.__eq__('struct')"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

