spec: struct_extra169
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra168.zspec.zsdl — covers struct.Struct.__mro__.__len__()==2 / struct.error.__mro__.__len__()==4 / module-level function __qualname__ attributes for pack/unpack/pack_into/calcsize/iter_unpack (table + invariants)."
    - "struct_extra167.zspec.zsdl — covers struct.__name__/__package__/__spec__/__loader__/__doc__ module-level identity and Struct.__dict__ __doc__/__repr__ membership (table + invariants)."
    - "struct_extra166.zspec.zsdl — covers struct.Struct.__name__/__module__ via __eq__ calls and Struct.__dict__.__sizeof__ membership (table + invariants)."
    - "struct_extra165.zspec.zsdl — covers struct.Struct.__dict__.__contains__ for __init__/__new__ and struct.error class identity (table + invariants)."
    - "struct_extra164.zspec.zsdl — covers struct module-level function __name__.__len__() integer values for all six functions (table + invariants)."
    - "struct_extra162.zspec.zsdl — covers struct.pack/__unpack/__pack_into/__unpack_from/__iter_unpack/__calcsize .__name__/__module__ (table + invariants)."
    - "struct_extra161.zspec.zsdl — covers struct.error/__Struct class identity (__name__/__module__/__bases__) (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__=='struct' and struct.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra168."
    - "Wave 354 theme: struct.Struct class identity — struct.Struct.__name__=='Struct' (len=6); struct.Struct.__module__=='_struct' (len=7); struct.Struct.__mro__.__len__()==2; struct.error.__name__=='error' (len=5); struct.error.__module__=='struct' (len=6); struct.error.__bases__[0].__name__=='Exception'; struct.pack.__name__=='pack'; struct.calcsize.__name__=='calcsize'. struct_extra161 anchors Struct class identity and error.__bases__; struct_extra162 anchors pack/calcsize __name__; struct_extra166 anchors Struct.__name__/__module__ via __eq__ calls; struct_extra168 anchors Struct.__mro__.__len__()==2 and error.__mro__.__len__()==4 and pack/calcsize __qualname__. This spec anchors __name__/__module__ length values and the error.__bases__ and pack/calcsize __name__ as fresh anchors under structclass169."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'Struct'=6 chars."
    - "struct.Struct.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0. '_struct'=7 chars; the C extension module."
    - "struct.Struct.__module__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct MRO: (_struct.Struct, object). struct_extra168 anchors this."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'error'=5 chars, all lowercase."
    - "struct.error.__name__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'struct'=6 chars. struct_extra161 anchors this."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0. struct_extra161 anchors this."
    - "struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'pack'=4 chars. struct_extra162 anchors."
    - "struct.calcsize.__name__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'calcsize'=8 chars. struct_extra162 anchors."
    - "Note: struct.Struct.__name__ == 'Struct' (6 chars) and struct.Struct.__module__ == '_struct' (7 chars). '__module__'(7) > '__name__'(6) by 1: the C module name is 1 char longer than the class name. 'Struct'(6) < '_struct'(7): class name is 1 char shorter than its module name."
    - "Note: struct.error.__name__ == 'error' (5 chars, all lowercase). Unusually, struct.error uses a lowercase name instead of the PEP 8 CamelCase convention. 'error'(5) < 'Struct'(6) < '_struct'(7) in name length ordering."
    - "Note: struct.error.__module__ == 'struct' (6 chars). error lives in the Python-level struct module (Lib/struct.py), while struct.Struct lives in the C extension _struct. struct.error.__module__=='struct'(6) == struct.Struct.__name__.__len__()==6 — coincidental: error's module name length equals Struct's class name length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct')
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__name__.__len__() == 6
# struct.Struct.__module__.__len__() == 7
#
# Wave 354 theme: Struct class name and module name — 6 and 7 chars.
#
# Struct.__name__ is 'Struct' (6 chars; CamelCase class name).
# Struct.__module__ is '_struct' (7 chars; C extension with underscore prefix).
# 'Struct'(6) < '_struct'(7) by 1: module name is 1 char longer than class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra169.Struct_name_and_module:
  description: "struct.Struct.__name__.__eq__('Struct')==True / struct.Struct.__module__.__eq__('_struct')==True / struct.Struct.__name__.__len__()==6 / struct.Struct.__module__.__len__()==7 — Struct.__name__ is 'Struct' (6 chars; struct.Struct is the compiled C class for packing/unpacking binary data; its __name__ is 'Struct' with a capital S; 'Struct'(6 chars) = 6 letters; struct_extra166 anchors Struct.__name__.__eq__('Struct'); confirmed here under structclass169 as a fresh anchor combining with module length); Struct.__module__ is '_struct' (7 chars; struct.Struct is defined in the C extension module _struct (Modules/_struct.c), not in the Python-level struct module; '_struct'(7 chars) = '_'=1 + 'struct'=6; struct_extra166 anchors Struct.__module__.__eq__('_struct'); confirmed here under structclass169); Struct.__name__.__len__() is 6 ('Struct' = 6 chars; struct_extra164 anchors related length values; this spec anchors Struct.__name__.__len__() as a fresh integer anchor under structclass169); Struct.__module__.__len__() is 7 ('_struct' = 7 chars; '_struct'(7) > 'Struct'(6) by 1: C module name has extra underscore; novel anchor via __len__() call; first structclass169 anchor for Struct name and module)"
  kind: python_call_eq
  category: identity
  id_prefix: structclass169

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,    "Struct.__name__.__eq__",    ["Struct"],  true, "struct.Struct.__name__ == 'Struct' (6 chars; CamelCase; struct_extra166 anchors; confirmed under structclass169)"]
    - [struct_mod_eq,     "Struct.__module__.__eq__",  ["_struct"], true, "struct.Struct.__module__ == '_struct' (7 chars; C extension; struct_extra166 anchors; confirmed under structclass169)"]
    - [struct_name_len_6, "Struct.__name__.__len__",   [],          6,    "struct.Struct.__name__.__len__() is 6 ('Struct'=6; 'Struct'(6)<'_struct'(7) by 1; novel __len__ anchor)"]
    - [struct_mod_len_7,  "Struct.__module__.__len__", [],          7,    "struct.Struct.__module__.__len__() is 7 ('_struct'=7; '_struct'(7)>'Struct'(6) by 1; underscore prefix adds 1; novel anchor)"]

