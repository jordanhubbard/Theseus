  kind: python_call_eq
  category: identity
  id_prefix: structclass169

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,    "error.__name__.__eq__",    ["error"],  true, "struct.error.__name__ == 'error' (5 chars; lowercase class name; struct_extra161 anchors; confirmed under structclass169)"]
    - [error_mod_eq,     "error.__module__.__eq__",  ["struct"], true, "struct.error.__module__ == 'struct' (6 chars; Python-level module; struct_extra161 anchors; confirmed under structclass169)"]
    - [error_name_len_5, "error.__name__.__len__",   [],         5,    "struct.error.__name__.__len__() is 5 ('error'=5; 'error'(5)<'struct'(6) by 1; novel __len__ anchor under structclass169)"]
