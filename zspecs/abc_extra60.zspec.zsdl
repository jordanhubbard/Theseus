spec: abc_extra60
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_varnames, co_filename, and co_flags documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra59.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53), __loader__.__class__.__name__.__eq__('type') (extra54), __loader__.__name__.__eq__('FrozenImporter') (extra54), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra54), __file__.__class__.__name__.__eq__('str') (extra54), ABCMeta.__instancecheck__.__qualname__.__len__()==25 (extra54), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__name__.__len__() (extra55), ABCMeta.register/__instancecheck__/__subclasscheck__/update_abstractmethods __qualname__.__eq__ (extra56), abstractproperty.__init__.__qualname__.__eq__('property.__init__') (extra56), abstractmethod/__annotations__/__globals__ class identity, ABCMeta/__doc__.__contains__('Abstract'), get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') (extra57), abstractmethod/__defaults__/__code__/__closure__/__class__.__name__ checks, update_abstractmethods/__defaults__/__code__/__class__.__name__ checks (extra58), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ __code__.co_name equality and co_argcount values (extra59)."
    - "This spec covers (abccode3_60 namespace): wave 231 theme — __code__.co_varnames, co_filename, co_flags attribute chains. NEW in extra60: abstractmethod.__code__.co_varnames.__class__.__name__=='tuple' — co_varnames is always a tuple; update_abstractmethods.__code__.co_varnames.__class__.__name__=='tuple'; ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__=='tuple'; abstractmethod.__code__.co_varnames[0]=='funcobj' — abstractmethod(funcobj) so first co_varnames entry is 'funcobj'; update_abstractmethods.__code__.co_varnames[0]=='cls' — update_abstractmethods(cls) so first is 'cls'; ABCMeta.__instancecheck__.__code__.co_varnames[0]=='cls' — ABCMeta.__instancecheck__(cls, instance) so first is 'cls'; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_filename.__contains__('.py')==True; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_flags.__class__.__name__=='int'."
    - "abc.abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is a tuple of strings naming all local variables in definition order. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_varnames[0] == 'funcobj'. abstractmethod is defined as 'def abstractmethod(funcobj)' — funcobj is the first (only) parameter so co_varnames[0]=='funcobj'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_varnames[0] == 'cls'. update_abstractmethods is defined as 'def update_abstractmethods(cls)' — cls is the first parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_varnames[0] == 'cls'. ABCMeta.__instancecheck__ is defined as 'def __instancecheck__(cls, instance)' in Lib/abc.py — cls is the first parameter (it is a regular method on a metaclass). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_filename.__contains__('.py') == True. co_filename stores the absolute path to the pure-Python source file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_flags.__class__.__name__ == 'int'. co_flags is a bitmask integer encoding code-object properties. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc __code__.co_varnames.__class__.__name__ checks — extra60
#
# Wave 231 theme: co_varnames type identity.
#
# co_varnames is always a tuple of strings on every code object.
# tuple.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table abc_extra60.co_varnames_class_name:
  description: "abc __code__.co_varnames.__class__.__name__.__eq__('tuple') checks in abccode3_60 namespace — wave 231 theme: co_varnames type identity; co_varnames is always a tuple on all code objects; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_varnames.__class__.__name__=='tuple'; NEW in extra60: no prior abc spec has checked __code__.co_varnames.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode3_60

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_varnames_class,  abstractmethod.__code__.co_varnames.__class__.__name__.__eq__,              ["tuple"], true, "abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of strings naming all local variables in the code object; abstractmethod.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra60: first co_varnames.__class__.__name__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_varnames_class,             update_abstractmethods.__code__.co_varnames.__class__.__name__.__eq__,       ["tuple"], true, "update_abstractmethods.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; update_abstractmethods.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra60: first co_varnames.__class__.__name__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_varnames_class,   ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"], true, "ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; ABCMeta.__instancecheck__.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra60: first co_varnames.__class__.__name__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_varnames[0] first-argument checks — extra60
#
# Wave 231 theme: first entry in co_varnames.
#
# co_varnames lists arguments first, in definition order:
#   abstractmethod(funcobj) → co_varnames[0] == 'funcobj'
#   update_abstractmethods(cls) → co_varnames[0] == 'cls'
#   ABCMeta.__instancecheck__(cls, instance) → co_varnames[0] == 'cls'
#
# Table row function values containing '[' MUST be double-quoted in YAML.
# ---------------------------------------------------------------------------

table abc_extra60.co_varnames_first_arg:
  description: "abc __code__.co_varnames[0].__eq__ checks in abccode3_60 namespace — wave 231 theme: first co_varnames entry; abstractmethod co_varnames[0]=='funcobj', update_abstractmethods co_varnames[0]=='cls', ABCMeta.__instancecheck__ co_varnames[0]=='cls'; arguments appear in co_varnames in definition order; NEW in extra60: no prior abc spec has checked co_varnames[0].__eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode3_60a

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_varnames_first,  "abstractmethod.__code__.co_varnames[0].__eq__",            ["funcobj"], true, "abstractmethod.__code__.co_varnames[0] == 'funcobj' — abstractmethod is defined as 'def abstractmethod(funcobj)'; funcobj is the first (only) positional-or-keyword parameter; co_varnames lists arguments first in definition order; co_varnames[0] is 'funcobj'; __eq__('funcobj') returns True; NEW in extra60: first co_varnames[0] check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_varnames_first,             "update_abstractmethods.__code__.co_varnames[0].__eq__",    ["cls"],     true, "update_abstractmethods.__code__.co_varnames[0] == 'cls' — update_abstractmethods is defined as 'def update_abstractmethods(cls)'; cls is the first parameter; co_varnames[0] is 'cls'; __eq__('cls') returns True; NEW in extra60: first co_varnames[0] check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_varnames_first,   "ABCMeta.__instancecheck__.__code__.co_varnames[0].__eq__", ["cls"],     true, "ABCMeta.__instancecheck__.__code__.co_varnames[0] == 'cls' — ABCMeta.__instancecheck__ is defined as 'def __instancecheck__(cls, instance)' in Lib/abc.py; cls is the first parameter (it is a regular method on a metaclass where self is spelled cls by convention); co_varnames[0] is 'cls'; __eq__('cls') returns True; NEW in extra60: first co_varnames[0] check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_filename.__contains__('.py') checks — extra60
#
# Wave 231 theme: co_filename membership check.
#
# co_filename stores the absolute path to the .py source file. All abc
# Python-implemented functions are in Lib/abc.py, so co_filename always
# contains '.py'.
# ---------------------------------------------------------------------------

table abc_extra60.co_filename_contains_py:
  description: "abc __code__.co_filename.__contains__('.py') checks in abccode3_60 namespace — wave 231 theme: co_filename membership; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_filename containing '.py'; co_filename is the absolute path to the pure-Python source file Lib/abc.py; NEW in extra60: no prior abc spec has checked __code__.co_filename.__contains__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode3_60b

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_filename_py,  abstractmethod.__code__.co_filename.__contains__,            [".py"], true, "abstractmethod.__code__.co_filename.__contains__('.py') == True — co_filename stores the absolute path to the source .py file; abc.abstractmethod is implemented in Lib/abc.py; the filename contains '.py'; NEW in extra60: first co_filename membership check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_filename_py,             update_abstractmethods.__code__.co_filename.__contains__,    [".py"], true, "update_abstractmethods.__code__.co_filename.__contains__('.py') == True — abc.update_abstractmethods is implemented in Lib/abc.py; the filename contains '.py'; NEW in extra60: first co_filename membership check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_filename_py,   ABCMeta.__instancecheck__.__code__.co_filename.__contains__, [".py"], true, "ABCMeta.__instancecheck__.__code__.co_filename.__contains__('.py') == True — abc.ABCMeta.__instancecheck__ is implemented as a Python method in Lib/abc.py; the filename contains '.py'; NEW in extra60: first co_filename membership check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_flags.__class__.__name__ checks — extra60
#
# Wave 231 theme: co_flags type identity.
#
# co_flags is a bitmask integer encoding properties of the code object
# (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, etc.).
# It is always a plain Python int. int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table abc_extra60.co_flags_class_name:
  description: "abc __code__.co_flags.__class__.__name__.__eq__('int') checks in abccode3_60 namespace — wave 231 theme: co_flags type identity; co_flags is a bitmask int encoding code-object properties; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_flags.__class__.__name__=='int'; NEW in extra60: no prior abc spec has checked __code__.co_flags.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode3_60c

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_flags_class,  abstractmethod.__code__.co_flags.__class__.__name__.__eq__,            ["int"], true, "abstractmethod.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a bitmask integer encoding properties of the code object; abstractmethod.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra60: first co_flags.__class__.__name__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_flags_class,             update_abstractmethods.__code__.co_flags.__class__.__name__.__eq__,    ["int"], true, "update_abstractmethods.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int; update_abstractmethods.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra60: first co_flags.__class__.__name__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_flags_class,   ABCMeta.__instancecheck__.__code__.co_flags.__class__.__name__.__eq__, ["int"], true, "ABCMeta.__instancecheck__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int; ABCMeta.__instancecheck__.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra60: first co_flags.__class__.__name__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra60
# ---------------------------------------------------------------------------

invariant abc_extra60.abstractmethod_co_varnames_tuple:
  description: "abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is a tuple of strings naming all local variables in the code object; abstractmethod.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra60: no prior abc spec has checked abstractmethod.__code__.co_varnames.__class__.__name__ via __eq__; wave 231 first co_varnames type identity invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra60.abstractmethod_co_varnames_first_funcobj:
  description: "abc.abstractmethod.__code__.co_varnames[0].__eq__('funcobj') returns True — abstractmethod is defined as 'def abstractmethod(funcobj)'; funcobj is the first (only) positional-or-keyword parameter; co_varnames lists arguments first so co_varnames[0]=='funcobj'; NEW in extra60: no prior abc spec has checked abstractmethod.__code__.co_varnames[0] via __eq__; wave 231 first co_varnames first-entry invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: "abstractmethod.__code__.co_varnames[0].__eq__"
  args: ["funcobj"]
  expected: true

invariant abc_extra60.update_abstractmethods_co_varnames_first_cls:
  description: "abc.update_abstractmethods.__code__.co_varnames[0].__eq__('cls') returns True — update_abstractmethods is defined as 'def update_abstractmethods(cls)'; cls is the first parameter; co_varnames[0]=='cls'; __eq__('cls') returns True; NEW in extra60: no prior abc spec has checked update_abstractmethods.__code__.co_varnames[0] via __eq__; wave 231 first co_varnames first-entry invariant for update_abstractmethods; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: "update_abstractmethods.__code__.co_varnames[0].__eq__"
  args: ["cls"]
  expected: true

invariant abc_extra60.abstractmethod_co_filename_contains_py:
  description: "abc.abstractmethod.__code__.co_filename.__contains__('.py') returns True — co_filename stores the absolute path to the source .py file; abc.abstractmethod is implemented in Lib/abc.py; the filename contains '.py'; NEW in extra60: no prior abc spec has checked abstractmethod.__code__.co_filename.__contains__ via invariant; wave 231 first co_filename membership invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant abc_extra60.abstractmethod_co_flags_int:
  description: "abc.abstractmethod.__code__.co_flags.__class__.__name__.__eq__('int') returns True — co_flags is a bitmask integer encoding code-object properties (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, etc.); abstractmethod.__code__.co_flags is a plain Python int; int.__class__.__name__ is 'int'; NEW in extra60: no prior abc spec has checked abstractmethod.__code__.co_flags.__class__.__name__ via __eq__; wave 231 first co_flags type identity invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
