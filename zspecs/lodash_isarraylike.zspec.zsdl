spec: lodash_isarraylike
version: ">=4.0.0"
backend: node(lodash.isarraylike)

docs: https://lodash.com/docs/#isArrayLike

provenance:
  derived_from:
    - "lodash.isarraylike README — https://www.npmjs.com/package/lodash.isarraylike"
    - "Test vectors verified with lodash.isarraylike@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isarraylike exports the _.isArrayLike function directly as module.exports."
    - "isArrayLike returns true if value has a length property and length is between 0 and MAX_SAFE_INTEGER."
    - "Strings are array-like."
    - "null and plain numbers are not array-like."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isarraylike.isarraylike:
  kind: node_module_call_eq
  function: ~
  category: isarraylike
  id_prefix: lial

  columns: [id, args, expected]
  rows:
    - [array,   [[1, 2, 3]],   true]
    - [string,  ["abc"],       true]
    - [number,  [42],          false]
    - [null_v,  [null],        false]
