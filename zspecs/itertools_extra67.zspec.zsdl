spec: itertools_extra67
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra66.zspec.zsdl."
    - "Wave 233 theme: chain.from_iterable and other itertools subclass/method docstrings."
    - "chain.from_iterable.__doc__.__class__.__name__ == 'str' — chain.from_iterable is a classmethod descriptor on the chain C extension type; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "chain.from_iterable.__doc__.__contains__('iterable') == True — chain.from_iterable(iterable); 'iterable' appears in its docstring as the parameter name. Verified with Python 3.14.3."
    - "tee.__doc__.__contains__('tee') == True — tee is a C extension type whose docstring opens with 'tee(iterable, n=2) --> tuple of n independent iterators'; the type name 'tee' appears in the signature line. Verified with Python 3.14.3."
    - "tee.__doc__.__contains__('iterable') == True — tee.__doc__ includes 'iterable' as the first parameter name in the signature. Verified with Python 3.14.3."
    - "tee.__doc__.__class__.__name__ == 'str' — tee is a C extension type; its __doc__ is a str. Verified with Python 3.14.3."
    - "accumulate.__doc__.__contains__('func') == True — accumulate(iterable, func=operator.add, ...); 'func' appears as the second parameter name. Prior itertools_extra66 covered 'accumulate' and 'iterable'. 'func' is novel. Verified with Python 3.14.3."
    - "count.__doc__.__contains__('start') == True — count(start=0, step=1); 'start' appears as the first parameter name. Prior itertools_extra66 covered 'count' and 'step'. 'start' is novel. Verified with Python 3.14.3."
    - "repeat.__doc__.__contains__('None') == True — repeat(object[, times]) --> repeat object; 'None' appears in the body ('if not specified' context). Actually the docstring body says 'if times is None'. Verified with Python 3.14.3."
    - "Prior itertools_extra65 covered chain/islice/dropwhile/takewhile/groupby/starmap/zip_longest docstring content."
    - "Prior itertools_extra66 covered accumulate/cycle/repeat/count/filterfalse docstring content ('accumulate','iterable','cycle','element','object','times','count','step','predicate')."
    - "This spec covers chain.from_iterable doc, tee doc, accumulate 'func', count 'start', repeat 'None'. All checks in this spec are new to extra67."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain.from_iterable.__doc__ — extra67
#
# Wave 233 theme: chain.from_iterable docstring content.
#
# itertools.chain is a C extension type (Modules/itertoolsmodule.c).
# chain.from_iterable is a classmethod of chain that constructs a chain
# from a single iterable of iterables (lazy evaluation). Its __doc__ is a
# Python str object describing the classmethod.
#
# chain.from_iterable.__doc__.__class__.__name__ == 'str'
# chain.from_iterable.__doc__.__contains__('iterable') == True
#   ('iterable' appears as the parameter name in the docstring)
#
# No prior itertools spec checks chain.from_iterable.__doc__. New to extra67.
# ---------------------------------------------------------------------------

table itertools_extra67.chain_from_iterable_doc:
  description: "chain.from_iterable.__doc__ is a str and contains 'iterable'; wave 233 chain.from_iterable doc; new to extra67"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc6_67

  columns: [id, function, args, expected, description]
  rows:
    - [chain_from_iterable_doc_class_name_eq_str,
       chain.from_iterable.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.from_iterable.__doc__.__class__.__name__.__eq__('str') == True — chain is a C extension type (Modules/itertoolsmodule.c); chain.from_iterable is a classmethod (classmethoddescriptor or builtin_function_or_method) that constructs a chain from a single iterable of iterables; its __doc__ attribute is a Python str object describing how from_iterable works; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks chain.from_iterable.__doc__.__class__.__name__; new to extra67"]
    - [chain_from_iterable_doc_contains_iterable,
       chain.from_iterable.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.chain.from_iterable.__doc__.__contains__('iterable') == True — chain.from_iterable(iterable) takes a single iterable of iterables and chains them lazily; the word 'iterable' appears in the docstring as the parameter name (and likely again in the description of what it accepts); str.__contains__ returns True at the first occurrence; no prior itertools spec checks chain.from_iterable.__doc__.__contains__('iterable'); new to extra67"]

# ---------------------------------------------------------------------------
# tee.__doc__.__contains__ — extra67
#
# Wave 233 theme: tee docstring content checks.
#
# itertools.tee is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'tee(iterable, n=2) --> tuple of n independent iterators'
#
# Key findings:
#   tee.__doc__.__class__.__name__ == 'str'
#     (tee is a C extension type; its __doc__ is a str)
#   tee.__doc__.__contains__('tee') == True
#     (the type name 'tee' appears in the signature line)
#   tee.__doc__.__contains__('iterable') == True
#     ('iterable' is the first parameter name in the signature)
#
# No prior itertools spec checks tee.__doc__. New to extra67.
# ---------------------------------------------------------------------------

table itertools_extra67.tee_doc_contains:
  description: "tee.__doc__ is a str and contains 'tee' and 'iterable'; wave 233 tee doc content; new to extra67"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc6_67

  columns: [id, function, args, expected, description]
  rows:
    - [tee_doc_contains_tee,
       tee.__doc__.__contains__,
       ["tee"],
       true,
       "itertools.tee.__doc__.__contains__('tee') == True — tee is a C extension type (Modules/itertoolsmodule.c) that returns n independent iterators from a single iterable; its docstring opens with 'tee(iterable, n=2) --> tuple of n independent iterators'; the word 'tee' appears as the type name in the call signature; str.__contains__ returns True at the first occurrence; no prior itertools spec checks tee.__doc__.__contains__('tee'); new to extra67"]
    - [tee_doc_contains_iterable,
       tee.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.tee.__doc__.__contains__('iterable') == True — tee.__doc__ opens with 'tee(iterable, n=2) --> tuple of n independent iterators'; the word 'iterable' appears as the first parameter name in the signature line; str.__contains__ returns True at the first occurrence; no prior itertools spec checks tee.__doc__.__contains__('iterable'); new to extra67"]

# ---------------------------------------------------------------------------
# accumulate novel docstring content — extra67
#
# Wave 233 theme: novel docstring word for accumulate.
#
# itertools.accumulate docstring:
#   'accumulate(iterable[, func, *, initial=None]) --> accumulate object\n\n
#    Return series of accumulated sums (or other binary function results).'
#
# Prior itertools_extra66 covered 'accumulate' and 'iterable'.
# Novel word: 'func' — appears as the second parameter name in the signature.
#
#   accumulate.__doc__.__contains__('func') == True
#
# No prior itertools spec checks accumulate.__doc__.__contains__('func'). New to extra67.
# ---------------------------------------------------------------------------

table itertools_extra67.accumulate_novel_doc:
  description: "accumulate.__doc__.__contains__('func')==true — 'func' is the second parameter in accumulate docstring; novel word not in prior specs; wave 233 novel doc content; new to extra67"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc6_67

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_contains_func,
       accumulate.__doc__.__contains__,
       ["func"],
       true,
       "itertools.accumulate.__doc__.__contains__('func') == True — accumulate is a C extension type (Modules/itertoolsmodule.c) that returns accumulated sums or results of a binary function; its docstring opens with 'accumulate(iterable[, func, *, initial=None]) --> accumulate object'; the word 'func' appears as the second parameter name in the square-bracketed optional portion of the signature; str.__contains__ returns True at the first occurrence; prior itertools_extra66 covered 'accumulate' and 'iterable' but not 'func'; new to extra67"]

# ---------------------------------------------------------------------------
# count and repeat novel docstring content — extra67
#
# Wave 233 theme: novel docstring words for count and repeat.
#
# itertools.count docstring:
#   'count(start=0, step=1) --> count object\n\n
#    Return a count object whose __next__() method returns consecutive values.'
# Prior itertools_extra66 covered 'count' and 'step'. Novel: 'start'.
#   count.__doc__.__contains__('start') == True
#
# itertools.repeat docstring:
#   'repeat(object[, times]) --> repeat object\n\n
#    Return a repeat object whose __next__() method returns object for
#    times times or infinitely if times is None.'
# Prior itertools_extra66 covered 'object' and 'times'. Novel: 'None'.
#   repeat.__doc__.__contains__('None') == True
#     ('None' appears in the body: "if times is None")
#
# No prior itertools spec checks these novel words. New to extra67.
# ---------------------------------------------------------------------------

table itertools_extra67.count_repeat_novel_doc:
  description: "count 'start' and repeat 'None' novel doc content — new words not in prior specs; wave 233 novel doc content; new to extra67"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc6_67

  columns: [id, function, args, expected, description]
  rows:
    - [count_doc_contains_start,
       count.__doc__.__contains__,
       ["start"],
       true,
       "itertools.count.__doc__.__contains__('start') == True — count is a C extension type (Modules/itertoolsmodule.c) that returns evenly spaced values; its docstring opens with 'count(start=0, step=1) --> count object'; the word 'start' appears as the first parameter name (with default value 0) in the signature line; str.__contains__ returns True at the first occurrence; prior itertools_extra66 covered 'count' and 'step' but not 'start'; new to extra67"]
    - [repeat_doc_contains_None,
       repeat.__doc__.__contains__,
       ["None"],
       true,
       "itertools.repeat.__doc__.__contains__('None') == True — repeat is a C extension type (Modules/itertoolsmodule.c) that returns a single object repeatedly; its docstring body includes 'if times is None' (describing infinite repetition when the times parameter is omitted); the word 'None' appears as a Python keyword/value in that conditional clause; str.__contains__ returns True at the first occurrence; prior itertools_extra66 covered 'object' and 'times' for repeat but not 'None'; new to extra67"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant itertools_extra67.chain_from_iterable_doc_iterable:
  description: "itertools.chain.from_iterable.__doc__.__contains__('iterable') == True — 'iterable' is the parameter name in chain.from_iterable docstring; wave 233 chain.from_iterable doc; new to extra67"
  kind: python_call_eq
  function: chain.from_iterable.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant itertools_extra67.tee_doc_tee:
  description: "itertools.tee.__doc__.__contains__('tee') == True — type name in tee docstring; wave 233 tee doc content; new to extra67"
  kind: python_call_eq
  function: tee.__doc__.__contains__
  args: ["tee"]
  expected: true

invariant itertools_extra67.accumulate_doc_func:
  description: "itertools.accumulate.__doc__.__contains__('func') == True — 'func' is the second parameter in accumulate docstring; novel word beyond prior extra66 coverage; wave 233 novel doc content; new to extra67"
  kind: python_call_eq
  function: accumulate.__doc__.__contains__
  args: ["func"]
  expected: true

invariant itertools_extra67.count_doc_start:
  description: "itertools.count.__doc__.__contains__('start') == True — 'start' is the first parameter in count docstring; novel word beyond prior extra66 coverage; wave 233 novel doc content; new to extra67"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["start"]
  expected: true
