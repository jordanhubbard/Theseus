spec: contextlib_extra25
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
    - "contextlib_extra24.zspec.zsdl — covers combined __qualname__ table and __qualname__.__len__ table for contextmanager/asynccontextmanager/suppress/redirect_stdout/redirect_stderr/closing/nullcontext/ExitStack (eight items; AsyncExitStack is absent)."
    - "contextlib_extra23.zspec.zsdl — covers AbstractContextManager/__module__; AbstractAsyncContextManager/__module__; nullcontext/__bases__[0].__name__; contextmanager/__module__; asynccontextmanager/__module__."
    - "contextlib_extra21.zspec.zsdl — covers nullcontext/__name__/__qualname__/__module__; AbstractContextManager/__name__/__qualname__; AbstractAsyncContextManager/__name__/__qualname__."
    - "contextlib_extra18.zspec.zsdl — covers __qualname__ for contextmanager/asynccontextmanager/nullcontext/AsyncExitStack/redirect_stdout/redirect_stderr."
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra24.zspec.zsdl."
    - "Focus: (1) combined __qualname__ table for ten contextlib members including AsyncExitStack and the Abstract base classes — not previously combined in one table in the extra25 namespace; (2) combined __qualname__.__len__ table for AbstractContextManager (22) and AbstractAsyncContextManager (27) — no prior spec covers these lengths in a combined table; (3) AsyncExitStack.__qualname__.__len__ == 14 standalone; (4) closing.__mro__.__len__ == 4 standalone; (5) suppress.__mro__.__len__ == 4 standalone."
    - "contextlib_extra24 covers: qualname table and qualname_len table for eight members but omits AsyncExitStack, AbstractContextManager, and AbstractAsyncContextManager."
    - "No prior spec records __qualname__.__len__() for AbstractContextManager (22) or AbstractAsyncContextManager (27)."
    - "contextlib.AsyncExitStack.__qualname__.__len__() == 14 — len('AsyncExitStack') == 14."
    - "contextlib.closing.__mro__.__len__() == 4 — [closing, AbstractContextManager, ABC, object]."
    - "contextlib.suppress.__mro__.__len__() == 4 — [suppress, AbstractContextManager, ABC, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__ for AbstractContextManager and AbstractAsyncContextManager
#
# contextlib_extra24 covers __qualname__.__len__ for eight items but omits both
# Abstract base classes. No prior spec records these two lengths in any
# combined table. AbstractContextManager qualname length == 22;
# AbstractAsyncContextManager qualname length == 27.
# ---------------------------------------------------------------------------

table contextlib_extra25.abstract_qualname_lens:
  description: "__qualname__.__len__ for AbstractContextManager and AbstractAsyncContextManager"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [AbstractContextManager,      AbstractContextManager.__qualname__.__len__,      [], 22]
    - [AbstractAsyncContextManager, AbstractAsyncContextManager.__qualname__.__len__, [], 27]

# ---------------------------------------------------------------------------
# __qualname__ for ten contextlib members — combined table in extra25 namespace
#
# contextlib_extra24 covers eight members in a combined table but omits
# AsyncExitStack and the two Abstract base classes. No prior spec combines
# all ten — contextmanager/asynccontextmanager/suppress/redirect_stdout/
# redirect_stderr/closing/nullcontext/ExitStack/AsyncExitStack/
# AbstractContextManager — into one table in the extra25 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra25.all_qualnames:
  description: "__qualname__ for ten contextlib members in the extra25 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,            contextmanager.__qualname__.__eq__,            ["contextmanager"],            true]
    - [asynccontextmanager,       asynccontextmanager.__qualname__.__eq__,       ["asynccontextmanager"],       true]
    - [suppress,                  suppress.__qualname__.__eq__,                  ["suppress"],                  true]
    - [closing,                   closing.__qualname__.__eq__,                   ["closing"],                   true]
    - [nullcontext,               nullcontext.__qualname__.__eq__,               ["nullcontext"],               true]
    - [ExitStack,                 ExitStack.__qualname__.__eq__,                 ["ExitStack"],                 true]
    - [AsyncExitStack,            AsyncExitStack.__qualname__.__eq__,            ["AsyncExitStack"],            true]
    - [AbstractContextManager,    AbstractContextManager.__qualname__.__eq__,    ["AbstractContextManager"],    true]

# ---------------------------------------------------------------------------
# AsyncExitStack.__qualname__.__len__() == 14
#
# contextlib_extra24 covers ExitStack/__qualname__.__len__() == 9 but omits
# AsyncExitStack from the qualname_len table. No prior spec records
# AsyncExitStack.__qualname__.__len__() == 14 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra25.AsyncExitStack.qualname_len:
  description: "contextlib.AsyncExitStack.__qualname__.__len__() == 14 — len('AsyncExitStack') == 14"
  category: qualnames
  kind: python_call_eq
  function: AsyncExitStack.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# closing.__mro__.__len__() == 4
#
# closing's MRO is [closing, AbstractContextManager, ABC, object].
# contextlib_extra24 covers ExitStack/redirect_stdout/redirect_stderr
# __mro__.__len__() == 5. No prior spec covers closing.__mro__.__len__() == 4
# as a standalone invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra25.closing.mro_len:
  description: "contextlib.closing.__mro__.__len__() == 4 — MRO is [closing, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: closing.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# suppress.__mro__.__len__() == 4
#
# suppress's MRO is [suppress, AbstractContextManager, ABC, object].
# No prior spec covers suppress.__mro__.__len__() == 4 as a standalone
# invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra25.suppress.mro_len:
  description: "contextlib.suppress.__mro__.__len__() == 4 — MRO is [suppress, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: suppress.__mro__.__len__
  args: []
  expected: 4
