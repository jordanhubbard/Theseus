spec: socket_extra128
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra127.zspec.zsdl — covers socket.socket.sendto/recvfrom/recvfrom_into/recv_into/shutdown/getsockname __qualname__.__eq__ string equality and __len__() values (table + invariants)."
    - "socket_extra126.zspec.zsdl — covers socket.socket/__name__/__module__/__qualname__ equality / socket.socket/__bases__[0]/__name__ / socket.socket/__mro__/__len__()==3 / socket.error/timeout alias identity (table + invariants)."
    - "socket_extra125.zspec.zsdl — covers socket.socket Python-level method __code__ attributes — co_name/co_argcount/co_varnames[0] for accept/__init__/close/makefile/detach/dup (table + invariants)."
    - "socket_extra124.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/recv/close/setsockopt __qualname__.__eq__ string equality (table + invariants)."
    - "socket_extra116.zspec.zsdl — covers socket.socket.fileno/setblocking/settimeout/gettimeout/makefile __qualname__.__eq__ and __len__() / fileno/setblocking/settimeout/gettimeout/__class__.__name__=='method_descriptor' / makefile.__class__.__name__=='function' / settimeout.__name__.__len__()==10 (table + invariants)."
    - "socket_extra100.zspec.zsdl — covers socket.socket method __name__ equality for sendall/setsockopt/getsockopt/settimeout/gettimeout/fileno (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / socket.SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket method __qualname__.__len__() for connect/bind/listen/send/recv/__init__/accept/close/makefile/settimeout/gettimeout (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier socket specs."
    - "Wave 303 theme: socket.socket.setblocking/settimeout/gettimeout C-level method_descriptor __objclass__ attributes — __objclass__.__name__, __objclass__.__module__, __objclass__.__qualname__ equality."
    - "socket.socket.setblocking.__objclass__.__name__ == 'socket'. The C-extension base class is _socket.socket whose __name__ is 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__objclass__.__module__ == '_socket'. The C-extension socket class is defined in the _socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__objclass__.__qualname__ == 'socket'. The C-extension socket class qualname is 'socket' (same as __name__; no enclosing scope). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__objclass__.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__objclass__.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__objclass__.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__objclass__.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__objclass__.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__objclass__.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All three methods (setblocking, settimeout, gettimeout) are C-level method_descriptor objects defined in the _socket C extension. Their __objclass__ is the C-level _socket.socket class (not the Python-level socket.socket). The C class has __name__=='socket', __module__=='_socket', and __qualname__=='socket'."
    - "Note: extra116 anchors setblocking/settimeout/gettimeout __qualname__.__eq__ and __class__.__name__=='method_descriptor'. extra100 anchors settimeout/gettimeout __name__.__eq__. No prior socket spec anchors __objclass__.__name__, __objclass__.__module__, or __objclass__.__qualname__ for any of these three methods."
    - "Note: __objclass__.__name__=='socket' — this is the C-extension class name, same string as the Python wrapper class name. The qualname values in __qualname__ format are 'socket.settimeout' (using 'socket.' as the class prefix), derived from this __objclass__ name 'socket'. So __objclass__.__name__ explains the 'socket.' prefix in the qualname string."
    - "Note: __objclass__.__module__=='_socket' (7 chars: '_' + 'socket'). The underscore prefix follows CPython convention for private C extension modules that back public Python modules. Same pattern as _struct backing struct, _hashlib backing hashlib."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.setblocking.__objclass__.__name__.__eq__('socket')
# socket.socket.setblocking.__objclass__.__module__.__eq__('_socket')
# socket.socket.setblocking.__objclass__.__qualname__.__eq__('socket')
#
# Wave 303 theme: setblocking __objclass__ identity.
#
# setblocking is a C-level method_descriptor from _socket.c. Its __objclass__
# is the _socket.socket C class. The C class has __name__=='socket' (same string
# as the Python wrapper class name), __module__=='_socket' (the C extension),
# and __qualname__=='socket' (equals __name__; no enclosing scope for a top-level
# C class). extra116 anchors setblocking __qualname__.__eq__('socket.setblocking')
# and __class__.__name__=='method_descriptor'; no prior socket spec anchors
# setblocking __objclass__ attributes under sockobj128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

