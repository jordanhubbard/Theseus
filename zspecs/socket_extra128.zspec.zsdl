    - [setblocking_objcls_name,  "socket.setblocking.__objclass__.__name__.__eq__",    ["socket"],  true, "setblocking.__objclass__.__name__ is 'socket' (the C-extension _socket.socket class; same name as the Python wrapper)"]
    - [setblocking_objcls_mod,   "socket.setblocking.__objclass__.__module__.__eq__",   ["_socket"], true, "setblocking.__objclass__.__module__ is '_socket' (the C extension module; underscore-prefix convention for backing C modules)"]
    - [setblocking_objcls_qname, "socket.setblocking.__objclass__.__qualname__.__eq__", ["socket"],  true, "setblocking.__objclass__.__qualname__ is 'socket' (equals __name__; top-level C class has __qualname__==__name__)"]

