# ---------------------------------------------------------------------------

table socket_extra153.socket_accept_fileno_close_qualnames:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept')==True / socket.socket.fileno.__qualname__.__eq__('socket.fileno')==True / socket.socket.close.__qualname__.__eq__('socket.close')==True / socket.socket.close.__qualname__.__len__()==12 — accept and fileno both 13 chars (6-char method names; tied with 'socket.listen' from extra152); close is 12 chars ('close'=5 chars; one less than accept/fileno); accept() returns (conn, address) tuple; fileno() returns file descriptor int; close() releases file descriptor; first sockmq153 anchor for accept/fileno/close qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: sockmq153

  columns: [id, function, args, expected, description]
  rows:
    - [socket_accept_qualname,  "socket.accept.__qualname__.__eq__",  ["socket.accept"], true, "socket.socket.accept.__qualname__ == 'socket.accept' (13 chars; 'socket.'=7 + 'accept'=6; returns (conn, addr) tuple)"]
    - [socket_fileno_qualname,  "socket.fileno.__qualname__.__eq__",  ["socket.fileno"], true, "socket.socket.fileno.__qualname__ == 'socket.fileno' (13 chars; 'socket.'=7 + 'fileno'=6; returns file descriptor int)"]
    - [socket_close_qualname,   "socket.close.__qualname__.__eq__",   ["socket.close"],  true, "socket.socket.close.__qualname__ == 'socket.close' (12 chars; 'socket.'=7 + 'close'=5; releases file descriptor)"]
