# ---------------------------------------------------------------------------
# socket.socket method qualname length ordering
#
# Wave 335 theme: qualname length ordering across all eight socket methods.
#
# All eight socket methods follow 'socket.' prefix (7 chars).
# Length ordering: send==recv==bind(11) < close(12) < fileno==accept==listen(13) < connect(14).
# This table anchors the lengths for accept/fileno (13 chars) and the comparison with close (12).
# No prior socket spec anchors these length comparisons as a combined table under sockmq153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra153.socket_method_qualname_lengths:
  description: "socket.socket.accept.__qualname__.__len__()==13 / socket.socket.fileno.__qualname__.__len__()==13 / socket.socket.send.__qualname__.__len__()==11 / socket.socket.recv.__qualname__.__len__()==11 — length ordering: send==recv==bind(11) < close(12) < fileno==accept==listen(13) < connect(14); all follow 'socket.' prefix (7 chars); bind(4)+send(4)+recv(4)=11; close(5)=12; fileno(6)+accept(6)+listen(6)=13; connect(7)=14; first sockmq153 anchor for these four length values in a combined table"
  kind: python_call_eq
  category: identity
  id_prefix: sockmq153

  columns: [id, function, args, expected, description]
  rows:
    - [socket_accept_qualname_len, "socket.accept.__qualname__.__len__", [], 13, "socket.socket.accept.__qualname__.__len__() is 13 ('socket.accept' = 7+6 = 13 chars; tied with listen and fileno)"]
    - [socket_fileno_qualname_len, "socket.fileno.__qualname__.__len__", [], 13, "socket.socket.fileno.__qualname__.__len__() is 13 ('socket.fileno' = 7+6 = 13 chars; tied with listen and accept)"]
    - [socket_send_qualname_len2,  "socket.send.__qualname__.__len__",  [], 11, "socket.socket.send.__qualname__.__len__() is 11 ('socket.send' = 7+4 = 11 chars; tied with recv and bind)"]
    - [socket_recv_qualname_len2,  "socket.recv.__qualname__.__len__",  [], 11, "socket.socket.recv.__qualname__.__len__() is 11 ('socket.recv' = 7+4 = 11 chars; tied with send and bind)"]

# ---------------------------------------------------------------------------
# socket.socket.send.__qualname__.__eq__('socket.send') — standalone
#
# socket.socket.send.__qualname__ is 'socket.send' (11 chars). send() is the method
# for transmitting data through a connected socket. It requires the socket to already be
# connected (via connect()). For TCP sockets, send() transmits the bytes and returns the
# number of bytes actually sent (which may be less than the total if the buffer is full).
# The qualname 'socket.send' (11 chars) is tied with 'socket.recv' and 'socket.bind'
# (both 11 chars from extra152) as the shortest socket method qualnames. No prior socket
# spec anchors socket.socket.send.__qualname__ as a standalone under sockmq153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra153.socket_send_qualname_eq:
  description: "socket.socket.send.__qualname__.__eq__('socket.send') == True — 11 chars (tied shortest with recv and bind); 'socket.'=7 + 'send'=4; transmits data on connected socket; returns bytes-sent count (may be less than total for TCP); extra152 anchors connect(14)/bind(11)/listen(13) qualnames; no prior socket spec anchors send qualname as a standalone; first standalone under sockmq153"
  category: identity
  kind: python_call_eq
  function: socket.send.__qualname__.__eq__
  args: ["socket.send"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept') — standalone
#
# socket.socket.accept.__qualname__ is 'socket.accept' (13 chars). accept() is the
# server-side method that blocks until a client connects to the server socket (which must
# have been bound and set to listen mode). It returns a (connection_socket, address) tuple
# where connection_socket is a new socket for communicating with the connected client.
# The qualname 'socket.accept' (13 chars) is tied with 'socket.listen' (extra152) and
# 'socket.fileno' at 13 chars — all have 6-char method names. No prior socket spec
# anchors socket.socket.accept.__qualname__ as a standalone under sockmq153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra153.socket_accept_qualname_eq:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — 13 chars (tied with listen and fileno; 6-char method names); 'socket.'=7 + 'accept'=6; server-side; blocks until client connects (after bind()+listen()); returns (conn_socket, address) tuple; extra152 anchors listen(13) qualname; no prior socket spec anchors accept qualname as a standalone; first standalone under sockmq153"
  category: identity
  kind: python_call_eq
  function: socket.accept.__qualname__.__eq__
  args: ["socket.accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.fileno.__qualname__.__eq__('socket.fileno') — standalone
#
# socket.socket.fileno.__qualname__ is 'socket.fileno' (13 chars). fileno() returns the
# integer file descriptor for the socket. This file descriptor can be used with low-level
# I/O multiplexing functions like select.select(), select.poll(), or the epoll/kqueue
# interfaces. File descriptors returned by fileno() can also be passed to os.read() and
# os.write(). The qualname 'socket.fileno' (13 chars) is tied with 'socket.accept' and
# 'socket.listen' — all three have 6-char method names giving a total of 13 chars.
# No prior socket spec anchors socket.socket.fileno.__qualname__ as a standalone under
# sockmq153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra153.socket_fileno_qualname_eq:
  description: "socket.socket.fileno.__qualname__.__eq__('socket.fileno') == True — 13 chars (tied with accept and listen; 6-char method names); 'socket.'=7 + 'fileno'=6; returns integer file descriptor for use with select/poll/epoll/kqueue; enables low-level I/O multiplexing; qualname length ordering: send==recv==bind(11) < close(12) < fileno==accept==listen(13) < connect(14); no prior socket spec anchors fileno qualname as a standalone; first standalone under sockmq153"
  category: identity
  kind: python_call_eq
  function: socket.fileno.__qualname__.__eq__
  args: ["socket.fileno"]
  expected: true

