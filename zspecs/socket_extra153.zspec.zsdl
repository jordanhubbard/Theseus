spec: socket_extra153
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra152.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ / socket.socket.connect/__bind__/listen qualnames / socket.error.__name__/__eq__('OSError') / socket.gaierror.__name__/__module__ (table + invariants)."
    - "socket_extra151.zspec.zsdl — covers socket.AF_INET/__eq__(2) / AF_INET6/__eq__(30) / AF_UNIX/__eq__(1) / SOCK_STREAM/__eq__(1) / SOCK_DGRAM/__eq__(2) / AF_* class names (table + invariants)."
    - "socket_extra150.zspec.zsdl — covers _socket.__dict__.__len__()==235 / _socket.socket.__dict__.__len__()==37 (table + invariants)."
    - "socket_extra149.zspec.zsdl — covers socket.__dict__.__len__()==267 / socket.socket.__dict__.__len__()==28 (table + invariants)."
    - "socket_extra144.zspec.zsdl — covers socket.socket.__module__/__qualname__/__eq__('socket') / __mro__.__len__()==3 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra152."
    - "Wave 335 theme: socket.socket method qualnames for send/recv/accept/close/fileno — socket.socket.send.__qualname__.__eq__('socket.send') / socket.socket.recv.__qualname__.__eq__('socket.recv') / socket.socket.accept.__qualname__.__eq__('socket.accept') / socket.socket.close.__qualname__.__eq__('socket.close') / socket.socket.fileno.__qualname__.__eq__('socket.fileno')."
    - "socket.socket.send.__qualname__ == 'socket.send'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All socket.socket method qualnames follow the 'socket.' prefix (7 chars) pattern from the C extension class name (_socket.socket.__name__ == 'socket'). This is consistent with what extra152 anchors for connect/bind/listen. The 'socket.' prefix is 7 chars (same length as 'Struct.' for struct.Struct methods). The method name lengths: send(4), recv(4), close(5), fileno(6), accept(6), listen(6), connect(7), bind(4). Qualname total lengths: send==recv(11), close(12), fileno==accept==listen(13), connect(14)."
    - "Note: socket.socket.send.__qualname__ == 'socket.send' (11 chars). send() transmits data to a connected socket. socket.socket.recv.__qualname__ == 'socket.recv' (11 chars). recv() receives data from a socket. Both send and recv have 4-char method names: 7+'send'=4=11 and 7+'recv'=4=11. They are tied as the shortest socket method qualnames (along with 'socket.bind' from extra152)."
    - "Note: socket.socket.accept.__qualname__ == 'socket.accept' (13 chars). accept() blocks until an incoming connection is received on a listening socket, then returns a (conn, address) tuple. socket.socket.fileno.__qualname__ == 'socket.fileno' (13 chars). fileno() returns the integer file descriptor for the socket, enabling use with select/poll/epoll. Both accept and fileno have 6-char method names: 7+'accept'=6=13 and 7+'fileno'=6=13."
    - "Note: socket.socket.close.__qualname__ == 'socket.close' (12 chars). close() marks the socket as closed and releases the file descriptor. 'socket.close' (12 chars) is between the 11-char (send/recv) and 13-char (accept/fileno/listen) qualnames. 'close' is 5 chars: 7+5=12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.send.__qualname__.__eq__('socket.send')
# socket.socket.recv.__qualname__.__eq__('socket.recv')
# socket.socket.send.__qualname__.__len__()==11
# socket.socket.recv.__qualname__.__len__()==11
#
# Wave 335 theme: send and recv method qualnames (both 11 chars).
#
# send and recv both have 4-char method names: 'socket.' (7) + 'send'/'recv' (4) = 11.
# extra152 anchors connect/bind/listen qualnames; no prior socket spec anchors send or recv
# qualnames as a table under sockmq153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra153.socket_send_recv_qualnames:
  description: "socket.socket.send.__qualname__.__eq__('socket.send')==True / socket.socket.recv.__qualname__.__eq__('socket.recv')==True / socket.socket.send.__qualname__.__len__()==11 / socket.socket.recv.__qualname__.__len__()==11 — both send and recv have 4-char method names; 'socket.'=7 + 'send'/'recv'=4 = 11 chars each; tied with 'socket.bind' (extra152) as shortest socket method qualnames; send() transmits data to connected socket; recv() receives data from socket; first sockmq153 anchor for send/recv qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: sockmq153

  columns: [id, function, args, expected, description]
  rows:
    - [socket_send_qualname,     "socket.send.__qualname__.__eq__",  ["socket.send"], true, "socket.socket.send.__qualname__ == 'socket.send' (11 chars; 'socket.'=7 + 'send'=4; transmits data to connected socket)"]
    - [socket_recv_qualname,     "socket.recv.__qualname__.__eq__",  ["socket.recv"], true, "socket.socket.recv.__qualname__ == 'socket.recv' (11 chars; 'socket.'=7 + 'recv'=4; receives data from socket)"]
    - [socket_send_qualname_len, "socket.send.__qualname__.__len__", [],              11,   "socket.socket.send.__qualname__.__len__() is 11 ('socket.send' = 7+4 = 11 chars; tied shortest with recv and bind)"]
    - [socket_recv_qualname_len, "socket.recv.__qualname__.__len__", [],              11,   "socket.socket.recv.__qualname__.__len__() is 11 ('socket.recv' = 7+4 = 11 chars; tied shortest with send and bind)"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept')
# socket.socket.fileno.__qualname__.__eq__('socket.fileno')
# socket.socket.close.__qualname__.__eq__('socket.close')
#
# Wave 335 theme: accept/fileno (13 chars) and close (12 chars) qualnames.
#
# accept.__qualname__ == 'socket.accept' (13 chars; tied with listen from extra152).
# fileno.__qualname__ == 'socket.fileno' (13 chars; tied with accept and listen).
# close.__qualname__ == 'socket.close' (12 chars; between send/recv (11) and accept/fileno (13)).
# No prior socket spec anchors accept/fileno/close qualnames as a table under sockmq153.
