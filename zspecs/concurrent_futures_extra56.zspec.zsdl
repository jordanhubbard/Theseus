spec: concurrent_futures_extra56
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/_bootstrap_external.py"
    - "CPython source: Lib/importlib/_bootstrap_external.py"
  notes:
    - "This spec extends concurrent_futures_extra55.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__/__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52), class __repr__.__class__.__name__ tables (extra53), class __weakref__.__class__.__name__ tables (extra53), exception __repr__.__class__.__name__ tables (extra53), cf.__all__.__class__.__name__.__eq__('list') (extra54), cf.__all__.__len__()==14 (extra54), ThreadPoolExecutor/ProcessPoolExecutor/Future/CancelledError/TimeoutError/BrokenExecutor __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra54), cf.__all__.__contains__ membership checks (extra55), cf.__package__.__eq__('concurrent.futures') (extra55), Future/Executor __doc__.__class__.__name__.__eq__('str') (extra55)."
    - "This spec covers (cfload56 namespace): wave 225 theme — __loader__ identity + __spec__ attribute chains + __file__/__cached__ checks. concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader') — concurrent.futures is a pure Python subpackage loaded from Lib/concurrent/futures/__init__.py; its loader is a SourceFileLoader instance; __loader__.__class__.__name__ == 'SourceFileLoader'. concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') — Python's import machinery wraps module metadata in a ModuleSpec object; __spec__.__class__.__name__ == 'ModuleSpec'. concurrent.futures.__file__.__class__.__name__.__eq__('str') — cf has a file path (__init__.py at Lib/concurrent/futures/__init__.py); the path is a plain Python str; __file__.__class__.__name__ == 'str'. concurrent.futures.__cached__.__class__.__name__.__eq__('str') — cf has a cached bytecode path (__pycache__/__init__.cpython-314.pyc); the path is a plain Python str; __cached__.__class__.__name__ == 'str'. No prior concurrent.futures spec has captured __loader__.__class__.__name__, __spec__.__class__.__name__, __file__.__class__.__name__, or __cached__.__class__.__name__ as string equality checks."
    - "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'. concurrent.futures is a pure Python subpackage (directory Lib/concurrent/futures/ with __init__.py). Python's import machinery uses a SourceFileLoader instance to load it. The loader is an instance of importlib.machinery.SourceFileLoader; __loader__.__class__.__name__ == 'SourceFileLoader'. __eq__('SourceFileLoader') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'. Every loaded module has a __spec__ attribute containing a ModuleSpec object describing the module's import configuration. __spec__.__class__.__name__ == 'ModuleSpec'. __eq__('ModuleSpec') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__file__.__class__.__name__ == 'str'. concurrent.futures has a file path pointing to Lib/concurrent/futures/__init__.py. This path is a plain Python str; __file__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__cached__.__class__.__name__ == 'str'. concurrent.futures has a cached bytecode path pointing to the __pycache__/__init__.cpython-314.pyc file. This path is a plain Python str; __cached__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures __loader__/__spec__/__file__/__cached__ class name checks
# — extra56
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ checks.
#
# concurrent.futures is a pure Python subpackage loaded from
# Lib/concurrent/futures/__init__.py. Its loader is a SourceFileLoader instance:
#   concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'
#
# Its module spec is a ModuleSpec object:
#   concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'
#
# Its file path is a plain Python str:
#   concurrent.futures.__file__.__class__.__name__ == 'str'
#
# Its cached bytecode path is a plain Python str:
#   concurrent.futures.__cached__.__class__.__name__ == 'str'
#
# No prior concurrent.futures spec has captured any of these checks.
# Extra56 introduces this wave 225 theme in the cfload56 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra56.loader_spec_file_cached:
  description: "concurrent.futures __loader__/__spec__/__file__/__cached__ class name checks in cfload56 namespace — cf is a pure Python subpackage (Lib/concurrent/futures/__init__.py); __loader__ is a SourceFileLoader instance; __spec__ is a ModuleSpec object; __file__ and __cached__ are plain Python str paths; all four __class__.__name__.__eq__ checks return True; wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ checks; first loader/spec/file/cached class name checks in any concurrent.futures spec"
  kind: python_call_eq
  category: loader_identity
  id_prefix: cfload56

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name, concurrent.futures.__loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true, "cf.__loader__.__class__.__name__ == 'SourceFileLoader' — concurrent.futures is a pure Python subpackage (Lib/concurrent/futures/__init__.py); Python's import machinery uses a SourceFileLoader instance to load it; SourceFileLoader is defined in importlib._bootstrap_external; __loader__.__class__.__name__.__eq__('SourceFileLoader') returns True; wave 225 first __loader__.__class__.__name__ check in any concurrent.futures spec"]
    - [spec_class_name,   concurrent.futures.__spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true, "cf.__spec__.__class__.__name__ == 'ModuleSpec' — Python's import machinery stores module metadata in a ModuleSpec object; __spec__ is a ModuleSpec instance; __spec__.__class__.__name__.__eq__('ModuleSpec') returns True; wave 225 first __spec__.__class__.__name__ check in any concurrent.futures spec"]
    - [file_class_name,   concurrent.futures.__file__.__class__.__name__.__eq__,    ["str"],              true, "cf.__file__.__class__.__name__ == 'str' — concurrent.futures has a file path (Lib/concurrent/futures/__init__.py); the path is a plain Python str; __file__.__class__.__name__.__eq__('str') returns True; wave 225 first __file__.__class__.__name__ check in any concurrent.futures spec"]
    - [cached_class_name, concurrent.futures.__cached__.__class__.__name__.__eq__,  ["str"],              true, "cf.__cached__.__class__.__name__ == 'str' — concurrent.futures has a cached bytecode path (__pycache__/__init__.cpython-314.pyc); the path is a plain Python str; __cached__.__class__.__name__.__eq__('str') returns True; wave 225 first __cached__.__class__.__name__ check in any concurrent.futures spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra56
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra56.loader_class_name_eq:
  description: "cf.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — concurrent.futures is a pure Python subpackage (Lib/concurrent/futures/__init__.py); its loader is a SourceFileLoader instance from importlib._bootstrap_external; __loader__.__class__.__name__ == 'SourceFileLoader'; wave 225 first __loader__.__class__.__name__ invariant in any concurrent.futures spec"
  category: loader_identity
  kind: python_call_eq
  function: concurrent.futures.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant concurrent_futures_extra56.spec_class_name_eq:
  description: "cf.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — concurrent.futures module spec is a ModuleSpec object; __spec__.__class__.__name__ == 'ModuleSpec'; wave 225 first __spec__.__class__.__name__ invariant in any concurrent.futures spec"
  category: loader_identity
  kind: python_call_eq
  function: concurrent.futures.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra56.file_class_name_eq:
  description: "cf.__file__.__class__.__name__.__eq__('str') returns True — concurrent.futures has a file path (Lib/concurrent/futures/__init__.py) which is a plain Python str; __file__.__class__.__name__ == 'str'; wave 225 first __file__.__class__.__name__ invariant in any concurrent.futures spec"
  category: loader_identity
  kind: python_call_eq
  function: concurrent.futures.__file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra56.cached_class_name_eq:
  description: "cf.__cached__.__class__.__name__.__eq__('str') returns True — concurrent.futures has a cached bytecode path (__pycache__/__init__.cpython-314.pyc) which is a plain Python str; __cached__.__class__.__name__ == 'str'; wave 225 first __cached__.__class__.__name__ invariant in any concurrent.futures spec"
  category: loader_identity
  kind: python_call_eq
  function: concurrent.futures.__cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
