spec: functools_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library functools module"
    - "CPython source: Lib/functools.py"
  not_derived_from:
    - "any third-party functools extension"
    - "functools backport packages"
  notes:
    - "Covers __annotations__ and __globals__ dict type checks for functools public functions"
    - "All covered functions are pure Python callables with inspectable dunder attributes"
    - "functools.cache is an alias for lru_cache(maxsize=None) introduced in 3.9"
  created_at: "2026-04-12"

table functools_extra886.annotations_dict_checks:
  description: "Verify that __annotations__ on functools public functions is of type dict"
  kind: python_call_eq
  category: type_introspection
  id_prefix: ft886an
  columns: [id, function, args, expected]
  rows:
    - [ft886an001, functools.wraps.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886an002, functools.update_wrapper.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886an003, functools.singledispatch.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886an004, functools.total_ordering.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886an005, functools.lru_cache.__annotations__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886an006, functools.cache.__annotations__.__class__.__name__.__eq__, ["dict"], true]

table functools_extra886.globals_dict_checks:
  description: "Verify that __globals__ on functools public functions is of type dict"
  kind: python_call_eq
  category: type_introspection
  id_prefix: ft886gl
  columns: [id, function, args, expected]
  rows:
    - [ft886gl001, functools.wraps.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886gl002, functools.update_wrapper.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886gl003, functools.singledispatch.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886gl004, functools.total_ordering.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886gl005, functools.lru_cache.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [ft886gl006, functools.cache.__globals__.__class__.__name__.__eq__, ["dict"], true]
