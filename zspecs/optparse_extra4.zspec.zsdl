spec: optparse_extra4
version: ">=3.9"
backend: python_module(optparse)

docs: https://docs.python.org/3/library/optparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/optparse.html — Python optparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/optparse.py"
  notes:
    - "Extends optparse.zspec.zsdl, optparse_extra.zspec.zsdl, optparse_extra2.zspec.zsdl, and optparse_extra3.zspec.zsdl with new axes."
    - "optparse.zspec.zsdl covers: class_names table (__name__ for OptionParser/Option/OptionGroup/Values/OptionError/OptionConflictError/OptionValueError/BadOptionError/AmbiguousOptionError/IndentedHelpFormatter/TitledHelpFormatter); OptionParser().allow_interspersed_args; OptionParser().version; MRO checks for OptionConflictError/OptionValueError/AmbiguousOptionError."
    - "optparse_extra.zspec.zsdl covers: OptionParser/Option/OptionGroup __name__/__module__; OptParseError __name__/__bases__[0].__name__=='Exception'; OptionError/OptionValueError/BadOptionError/AmbiguousOptionError/OptionConflictError __name__/__bases__[0].__name__."
    - "optparse_extra2.zspec.zsdl covers: __qualname__ table for all public classes (OptionParser/Option/OptionGroup/Values/HelpFormatter/IndentedHelpFormatter/TitledHelpFormatter/OptionError/OptionConflictError/OptionValueError/BadOptionError/AmbiguousOptionError/OptParseError); Values/__module__; IndentedHelpFormatter/__module__/__bases__[0].__name__; TitledHelpFormatter/__module__/__bases__[0].__name__; OptionParser().description default."
    - "optparse_extra3.zspec.zsdl covers: OptionContainer/__name__/__module__/__qualname__; exception and formatter __module__ table; OptionParser/__bases__[0].__name__=='OptionContainer'; OptionGroup/__bases__[0].__name__=='OptionContainer'; Option/__bases__[0].__name__=='object'; HelpFormatter/__bases__[0].__name__=='object'; OptionParser().usage default."
    - "This spec adds: __bases__.__len__()==1 for OptionParser/Option/OptionGroup/OptionError/OptionValueError/OptParseError/OptionConflictError/BadOptionError/AmbiguousOptionError (no prior spec checks __bases__.__len__ for any optparse class); OptionParser method names add_option/parse_args/get_option/remove_option/has_option/print_help/format_help/set_defaults (no prior spec checks OptionParser method __name__ attributes); Values.__bases__[0].__name__=='object' (optparse_extra2 covers Values/__module__ but not its base class)."
    - "optparse.OptionParser.__bases__.__len__() == 1 — no prior optparse spec checks __bases__.__len__ for any class."
    - "optparse.OptionParser.add_option.__name__ == 'add_option' — no prior spec checks OptionParser method names."
    - "optparse.OptionParser.parse_args.__name__ == 'parse_args' — same gap."
    - "optparse.OptionParser.get_option.__name__ == 'get_option' — same gap."
    - "optparse.OptionParser.remove_option.__name__ == 'remove_option' — same gap."
    - "optparse.OptionParser.has_option.__name__ == 'has_option' — same gap."
    - "optparse.OptionParser.print_help.__name__ == 'print_help' — same gap."
    - "optparse.OptionParser.format_help.__name__ == 'format_help' — same gap."
    - "optparse.OptionParser.set_defaults.__name__ == 'set_defaults' — same gap."
    - "optparse.Values.__bases__[0].__name__ == 'object' — Values inherits directly from object; optparse_extra2 covers __module__ but not base class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for all optparse classes.
#
# No prior optparse spec checks __bases__.__len__ for any class.
# Every public optparse class has a single direct base class:
# OptionParser and OptionGroup inherit from OptionContainer;
# Option, HelpFormatter, Values, and OptParseError inherit from object;
# OptionError inherits from OptParseError;
# OptionConflictError inherits from OptionError;
# BadOptionError inherits from OptParseError;
# AmbiguousOptionError inherits from BadOptionError.
# ---------------------------------------------------------------------------

table optparse_extra4.bases_len:
  kind: python_call_eq
  category: hierarchy
  id_prefix: baselen4

  columns: [id, function, args, expected]
  rows:
    - [OptionParser,         OptionParser.__bases__.__len__,         [], 1]
    - [Option,               Option.__bases__.__len__,               [], 1]
    - [OptionGroup,          OptionGroup.__bases__.__len__,          [], 1]
    - [OptionError,          OptionError.__bases__.__len__,          [], 1]
    - [OptionValueError,     OptionValueError.__bases__.__len__,     [], 1]
    - [OptParseError,        OptParseError.__bases__.__len__,        [], 1]
    - [OptionConflictError,  OptionConflictError.__bases__.__len__,  [], 1]
    - [BadOptionError,       BadOptionError.__bases__.__len__,       [], 1]
    - [AmbiguousOptionError, AmbiguousOptionError.__bases__.__len__, [], 1]

# ---------------------------------------------------------------------------
# OptionParser method names.
#
# No prior optparse spec checks the __name__ attribute of any OptionParser
# method. These are the primary public methods of the OptionParser class.
# ---------------------------------------------------------------------------

table optparse_extra4.OptionParser.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: opmeth4

  columns: [id, function, args, expected]
  rows:
    - [add_option,    OptionParser.add_option.__name__.__eq__,    ["add_option"],    true]
    - [parse_args,    OptionParser.parse_args.__name__.__eq__,    ["parse_args"],    true]
    - [get_option,    OptionParser.get_option.__name__.__eq__,    ["get_option"],    true]
    - [remove_option, OptionParser.remove_option.__name__.__eq__, ["remove_option"], true]
    - [has_option,    OptionParser.has_option.__name__.__eq__,    ["has_option"],    true]
    - [print_help,    OptionParser.print_help.__name__.__eq__,    ["print_help"],    true]
    - [format_help,   OptionParser.format_help.__name__.__eq__,   ["format_help"],   true]
    - [set_defaults,  OptionParser.set_defaults.__name__.__eq__,  ["set_defaults"],  true]

# ---------------------------------------------------------------------------
# Values.__bases__[0].__name__ == 'object'
#
# optparse_extra2 covers Values.__module__ == 'optparse'.
# No prior spec checks the base class of Values.
# Values inherits directly from object.
# ---------------------------------------------------------------------------

invariant optparse_extra4.Values.base_name:
  description: "optparse.Values.__bases__[0].__name__ == 'object' — Values inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Values.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
