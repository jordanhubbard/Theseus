spec: sort_array
version: ">=5.1.1"
backend: node(sort-array)

docs: https://www.npmjs.com/package/sort-array

provenance:
  derived_from:
    - "sort-array README — https://www.npmjs.com/package/sort-array"
    - "Test vectors verified with sort-array via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "sort-array source"
  notes:
    - "sort-array is an npm package. Install: npm install sort-array"
    - "Sorts an array in place (mutates the input) and returns it."
    - "Defaults to ascending order for both numbers and strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the sorted array (mutation in-place)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sort_array.sort:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: sarr

  columns: [id, args, expected]
  rows:
    - [numbers,  [[3, 1, 2]],                      [1, 2, 3]]
    - [mixed,    [[10, 3, 7, 1, 5]],               [1, 3, 5, 7, 10]]
    - [strings,  [["banana", "apple", "cherry"]],  ["apple", "banana", "cherry"]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:07:27Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
