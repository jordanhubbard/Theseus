spec: dbm_extra
version: ">=3.9"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dbm.html — Python dbm module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
  notes:
    - "The dbm module is a generic interface to Unix dbm-style database files."
    - "dbm.open may be a C builtin or a Python function depending on the platform/backend; __name__ == 'open' on CPython."
    - "dbm.whichdb is a Python function; __name__ == 'whichdb' and __module__ == 'dbm'."
    - "dbm.error is an exception class that inherits from OSError; __name__ == 'error', __module__ == 'dbm'."
    - "dbm.error.__bases__[0].__name__ == 'OSError' — error is a direct subclass of OSError."
    - "The submodules dbm.dumb, dbm.gnu, and dbm.ndbm may or may not be available depending on platform and build."
    - "dbm.dumb is always available (pure Python fallback); its __name__ == 'dbm.dumb'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dbm.open — function name
#
# dbm.open is the primary entry point. On CPython it is a built-in function
# or a Python function depending on the build; __name__ == 'open'.
# ---------------------------------------------------------------------------

invariant dbm_extra.open.name:
  description: "dbm.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.whichdb — function name and module affiliation
# ---------------------------------------------------------------------------

invariant dbm_extra.whichdb.name:
  description: "dbm.whichdb.__name__ == 'whichdb'"
  category: functions
  kind: python_call_eq
  function: whichdb.__name__.__eq__
  args: ["whichdb"]
  expected: true

invariant dbm_extra.whichdb.module:
  description: "dbm.whichdb.__module__ == 'dbm'"
  category: functions
  kind: python_call_eq
  function: whichdb.__module__.__eq__
  args: ["dbm"]
  expected: true

invariant dbm_extra.whichdb.is_function:
  description: "dbm.whichdb is a plain Python function"
  category: functions
  kind: python_call_eq
  function: whichdb.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.error — exception class name, module, and base class
# ---------------------------------------------------------------------------

invariant dbm_extra.error.name:
  description: "dbm.error.__name__ == 'error'"
  category: classes
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant dbm_extra.error.module:
  description: "dbm.error.__module__ == 'dbm'"
  category: classes
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["dbm"]
  expected: true

invariant dbm_extra.error.is_type:
  description: "dbm.error is a class (type)"
  category: classes
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant dbm_extra.error.base_is_OSError:
  description: "dbm.error.__bases__[0].__name__ == 'OSError' — error inherits directly from OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

invariant dbm_extra.error.bases_len:
  description: "len(dbm.error.__bases__) == 1 — error has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# dbm.dumb submodule — always available as pure-Python fallback
# ---------------------------------------------------------------------------

invariant dbm_extra.dumb.name:
  description: "dbm.dumb.__name__ == 'dbm.dumb'"
  category: submodules
  kind: python_call_eq
  function: dumb.__name__.__eq__
  args: ["dbm.dumb"]
  expected: true

invariant dbm_extra.dumb.open_name:
  description: "dbm.dumb.open.__name__ == 'open'"
  category: submodules
  kind: python_call_eq
  function: dumb.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant dbm_extra.dumb.error_name:
  description: "dbm.dumb.error.__name__ == 'error'"
  category: submodules
  kind: python_call_eq
  function: dumb.error.__name__.__eq__
  args: ["error"]
  expected: true
