spec: importlib_extra9
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
    - "importlib_machinery.zspec.zsdl — covers importlib.machinery classes via python_module(importlib.machinery) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra8.zspec.zsdl."
    - "Prior extras cover through extra8: __name__/__qualname__/__module__ for import_module/reload/invalidate_caches; __spec__ name/class/origin/has_location/submodule_search_locations; __loader__.__class__.__name__; __file__ class/endswith; util.LazyLoader attrs; util.decode_source attrs; util.source_hash attrs; util.resolve_name attrs; util.cache_from_source attrs; machinery.__name__/__package__/SOURCE_SUFFIXES/BYTECODE_SUFFIXES; abc.__package__; util submodule __name__/__package__; util function __name__/__qualname__/__module__ for find_spec/module_from_spec/spec_from_file_location/spec_from_loader."
    - "This spec adds new axes not covered in any prior importlib spec."
    - "importlib.resources submodule __name__ == 'importlib.resources' — resources is a subpackage accessible as an attribute of importlib."
    - "importlib.resources submodule __package__ == 'importlib.resources' — resources is itself a package."
    - "importlib.abc.__spec__.name == 'importlib.abc' — the abc submodule spec name."
    - "importlib.util.__spec__.name == 'importlib.util' — the util submodule spec name (via dotted attr from importlib)."
    - "importlib.import_module.__doc__.__class__.__name__ == 'str' — import_module has a docstring."
    - "importlib.reload.__doc__.__class__.__name__ == 'str' — reload has a docstring."
    - "importlib.invalidate_caches.__doc__.__class__.__name__ == 'str' — invalidate_caches has a docstring."
    - "importlib.abc.MetaPathFinder.__name__ == 'MetaPathFinder' — accessible as importlib.abc.MetaPathFinder."
    - "importlib.abc.MetaPathFinder.__module__ == 'importlib.abc' — MetaPathFinder is defined in importlib.abc."
    - "importlib.abc.PathEntryFinder.__name__ == 'PathEntryFinder' — accessible as importlib.abc.PathEntryFinder."
    - "importlib.abc.PathEntryFinder.__module__ == 'importlib.abc' — PathEntryFinder is defined in importlib.abc."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib.resources submodule — __name__ and __package__
#
# Prior importlib specs access importlib.resources only indirectly.
# No prior spec checks resources.__name__ or resources.__package__ as
# dotted attributes of importlib (the python_module(importlib) backend).
# ---------------------------------------------------------------------------

invariant importlib_extra9.resources_name:
  description: "importlib.resources.__name__ == 'importlib.resources'"
  category: submodules
  kind: python_call_eq
  function: resources.__name__.__eq__
  args: ["importlib.resources"]
  expected: true

invariant importlib_extra9.resources_package:
  description: "importlib.resources.__package__ == 'importlib.resources'"
  category: submodules
  kind: python_call_eq
  function: resources.__package__.__eq__
  args: ["importlib.resources"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.abc.__spec__.name and importlib.util.__spec__.name
#
# importlib_extra8 checks importlib.machinery.__name__ and __package__ as
# dotted attrs. No prior spec checks abc.__spec__.name or util.__spec__.name
# via the python_module(importlib) backend.
# ---------------------------------------------------------------------------

invariant importlib_extra9.abc_spec_name:
  description: "importlib.abc.__spec__.name == 'importlib.abc'"
  category: submodules
  kind: python_call_eq
  function: abc.__spec__.name.__eq__
  args: ["importlib.abc"]
  expected: true

invariant importlib_extra9.util_spec_name:
  description: "importlib.util.__spec__.name == 'importlib.util'"
  category: submodules
  kind: python_call_eq
  function: util.__spec__.name.__eq__
  args: ["importlib.util"]
  expected: true

# ---------------------------------------------------------------------------
# import_module, reload, invalidate_caches — docstring class check
#
# Prior specs check __doc__ existence indirectly but no spec checks
# __doc__.__class__.__name__ == 'str' for these three core functions via
# the python_module(importlib) backend.
# ---------------------------------------------------------------------------

table importlib_extra9.core_functions_doc_class:
  kind: python_call_eq
  category: function_attrs
  id_prefix: doc_class

  columns: [id, function, args, expected]
  rows:
    - [import_module,      import_module.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [reload,             reload.__doc__.__class__.__name__.__eq__,             ["str"], true]
    - [invalidate_caches,  invalidate_caches.__doc__.__class__.__name__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# importlib.abc.MetaPathFinder — __name__ and __module__
#
# importlib_abc.zspec.zsdl tests abc via python_module(importlib.abc).
# importlib_extra5 covers abc.Loader.__qualname__ via python_module(importlib).
# No prior importlib extra spec covers MetaPathFinder or PathEntryFinder
# via dotted attribute chains from the importlib module root.
# ---------------------------------------------------------------------------

invariant importlib_extra9.abc_MetaPathFinder_name:
  description: "importlib.abc.MetaPathFinder.__name__ == 'MetaPathFinder'"
  category: abc_classes
  kind: python_call_eq
  function: abc.MetaPathFinder.__name__.__eq__
  args: ["MetaPathFinder"]
  expected: true

invariant importlib_extra9.abc_MetaPathFinder_module:
  description: "importlib.abc.MetaPathFinder.__module__ == 'importlib.abc'"
  category: abc_classes
  kind: python_call_eq
  function: abc.MetaPathFinder.__module__.__eq__
  args: ["importlib.abc"]
  expected: true

invariant importlib_extra9.abc_MetaPathFinder_qualname:
  description: "importlib.abc.MetaPathFinder.__qualname__ == 'MetaPathFinder'"
  category: abc_classes
  kind: python_call_eq
  function: abc.MetaPathFinder.__qualname__.__eq__
  args: ["MetaPathFinder"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.abc.PathEntryFinder — __name__ and __module__
#
# No prior importlib extra spec covers PathEntryFinder via the
# python_module(importlib) backend.
# ---------------------------------------------------------------------------

invariant importlib_extra9.abc_PathEntryFinder_name:
  description: "importlib.abc.PathEntryFinder.__name__ == 'PathEntryFinder'"
  category: abc_classes
  kind: python_call_eq
  function: abc.PathEntryFinder.__name__.__eq__
  args: ["PathEntryFinder"]
  expected: true

invariant importlib_extra9.abc_PathEntryFinder_module:
  description: "importlib.abc.PathEntryFinder.__module__ == 'importlib.abc'"
  category: abc_classes
  kind: python_call_eq
  function: abc.PathEntryFinder.__module__.__eq__
  args: ["importlib.abc"]
  expected: true

invariant importlib_extra9.abc_PathEntryFinder_qualname:
  description: "importlib.abc.PathEntryFinder.__qualname__ == 'PathEntryFinder'"
  category: abc_classes
  kind: python_call_eq
  function: abc.PathEntryFinder.__qualname__.__eq__
  args: ["PathEntryFinder"]
  expected: true
