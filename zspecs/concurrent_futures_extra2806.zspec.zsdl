spec: concurrent_futures_extra2806
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra.zspec.zsdl — covers class names, module checks, function names, constant type checks"
    - "concurrent_futures_extra2.zspec.zsdl — covers module checks, constant values, method names"
    - "concurrent_futures_extra2791.zspec.zsdl — covers __iand__, __ior__, __ixor__ dict-presence checks"
  notes:
    - "Wave 634 theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place shift/power operators)."
    - "None of the concurrent.futures public classes define __ilshift__, __irshift__, or __ipow__ in their __dict__."
    - "Future is a pure-Python result container; ThreadPoolExecutor and ProcessPoolExecutor are executor pool classes."
    - "'__ilshift__' in Future.__dict__ == False; likewise for __irshift__ and __ipow__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — __ilshift__/__irshift__/__ipow__
# dict-presence checks
#
# Future is a pure-Python result container (Lib/concurrent/futures/_base.py).
# It wraps the result of an async computation. It does not define in-place
# shift or power operator dunders: __ilshift__, __irshift__, or __ipow__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2806.future_operator_dict:
  description: "concurrent.futures.Future __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2806f

  columns: [id, function, args, expected]
  rows:
    - ["cf2806f_ils",  Future.__dict__.__contains__, ["__ilshift__"],  false]
    - ["cf2806f_irs",  Future.__dict__.__contains__, ["__irshift__"],  false]
    - ["cf2806f_ipo",  Future.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor — __ilshift__/__irshift__/__ipow__
# dict-presence checks
#
# ThreadPoolExecutor manages a pool of threads and dispatches callables to them.
# It does not implement in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2806.threadpoolexecutor_operator_dict:
  description: "concurrent.futures.ThreadPoolExecutor __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2806tpe

  columns: [id, function, args, expected]
  rows:
    - ["cf2806tpe_ils",  ThreadPoolExecutor.__dict__.__contains__, ["__ilshift__"],  false]
    - ["cf2806tpe_irs",  ThreadPoolExecutor.__dict__.__contains__, ["__irshift__"],  false]
    - ["cf2806tpe_ipo",  ThreadPoolExecutor.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor — __ilshift__/__irshift__/__ipow__
# dict-presence checks
#
# ProcessPoolExecutor manages a pool of worker processes. Like ThreadPoolExecutor,
# it is a task dispatching class and does not define in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2806.processpoolexecutor_operator_dict:
  description: "concurrent.futures.ProcessPoolExecutor __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2806ppe

  columns: [id, function, args, expected]
  rows:
    - ["cf2806ppe_ils",  ProcessPoolExecutor.__dict__.__contains__, ["__ilshift__"],  false]
    - ["cf2806ppe_irs",  ProcessPoolExecutor.__dict__.__contains__, ["__irshift__"],  false]
    - ["cf2806ppe_ipo",  ProcessPoolExecutor.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — all concurrent.futures types, all three in-place shift/power operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Future, ThreadPoolExecutor, and ProcessPoolExecutor
# do not define <<=, >>=, or **= operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2806.all_types_ilshift_irshift_ipow_matrix:
  description: "Full 3×3 dict-presence matrix for concurrent.futures types vs __ilshift__/__irshift__/__ipow__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2806mx

  columns: [id, function, args, expected]
  rows:
    - ["cf2806mx_f_ils",   Future.__dict__.__contains__,              ["__ilshift__"],  false]
    - ["cf2806mx_f_irs",   Future.__dict__.__contains__,              ["__irshift__"],  false]
    - ["cf2806mx_f_ipo",   Future.__dict__.__contains__,              ["__ipow__"],     false]
    - ["cf2806mx_tpe_ils", ThreadPoolExecutor.__dict__.__contains__,  ["__ilshift__"],  false]
    - ["cf2806mx_tpe_irs", ThreadPoolExecutor.__dict__.__contains__,  ["__irshift__"],  false]
    - ["cf2806mx_tpe_ipo", ThreadPoolExecutor.__dict__.__contains__,  ["__ipow__"],     false]
    - ["cf2806mx_ppe_ils", ProcessPoolExecutor.__dict__.__contains__, ["__ilshift__"],  false]
    - ["cf2806mx_ppe_irs", ProcessPoolExecutor.__dict__.__contains__, ["__irshift__"],  false]
    - ["cf2806mx_ppe_ipo", ProcessPoolExecutor.__dict__.__contains__, ["__ipow__"],     false]
