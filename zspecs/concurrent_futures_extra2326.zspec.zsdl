spec: concurrent_futures_extra2326
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attributes — class __name__ and module-level string constant checks."
    - "Covers executor classes, exception classes, wait-condition string constants, and internal future-state string constants."
    - "PENDING/RUNNING/CANCELLED/CANCELLED_AND_NOTIFIED/FINISHED live in concurrent.futures._base, not the public namespace."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2326.class_names:
  description: "concurrent.futures executor and future class __name__ attribute checks"
  kind: python_call_eq
  category: class_name
  id_prefix: cf2326

  columns: [id, function, args, expected]
  rows:
    - ["cf2326001", "concurrent.futures.Future.__name__", [], "Future"]
    - ["cf2326002", "concurrent.futures.ThreadPoolExecutor.__name__", [], "ThreadPoolExecutor"]
    - ["cf2326003", "concurrent.futures.ProcessPoolExecutor.__name__", [], "ProcessPoolExecutor"]
    - ["cf2326004", "concurrent.futures.Executor.__name__", [], "Executor"]

table concurrent_futures_extra2326.exception_names:
  description: "concurrent.futures exception class __name__ attribute checks"
  kind: python_call_eq
  category: class_name
  id_prefix: cf2326

  columns: [id, function, args, expected]
  rows:
    - ["cf2326005", "concurrent.futures.CancelledError.__name__", [], "CancelledError"]
    - ["cf2326006", "concurrent.futures.TimeoutError.__name__", [], "TimeoutError"]
    - ["cf2326007", "concurrent.futures.BrokenExecutor.__name__", [], "BrokenExecutor"]

table concurrent_futures_extra2326.wait_condition_constants:
  description: "concurrent.futures module-level wait-condition string constants"
  kind: python_call_eq
  category: module_constant
  id_prefix: cf2326

  columns: [id, function, args, expected]
  rows:
    - ["cf2326008", "concurrent.futures.FIRST_COMPLETED", [], "FIRST_COMPLETED"]
    - ["cf2326009", "concurrent.futures.FIRST_EXCEPTION", [], "FIRST_EXCEPTION"]
    - ["cf2326010", "concurrent.futures.ALL_COMPLETED", [], "ALL_COMPLETED"]

table concurrent_futures_extra2326.future_state_constants:
  description: "concurrent.futures._base internal future-state string constants"
  kind: python_call_eq
  category: module_constant
  id_prefix: cf2326

  columns: [id, function, args, expected]
  rows:
    - ["cf2326011", "concurrent.futures._base.PENDING", [], "PENDING"]
    - ["cf2326012", "concurrent.futures._base.RUNNING", [], "RUNNING"]
    - ["cf2326013", "concurrent.futures._base.CANCELLED", [], "CANCELLED"]
    - ["cf2326014", "concurrent.futures._base.CANCELLED_AND_NOTIFIED", [], "CANCELLED_AND_NOTIFIED"]
    - ["cf2326015", "concurrent.futures._base.FINISHED", [], "FINISHED"]

table concurrent_futures_extra2326.wait_condition_types:
  description: "concurrent.futures wait-condition constants are strings — type name checks"
  kind: python_call_eq
  category: type_name
  id_prefix: cf2326

  columns: [id, function, args, expected]
  rows:
    - ["cf2326016", "concurrent.futures.FIRST_COMPLETED.__class__.__name__", [], "str"]
    - ["cf2326017", "concurrent.futures.FIRST_EXCEPTION.__class__.__name__", [], "str"]
    - ["cf2326018", "concurrent.futures.ALL_COMPLETED.__class__.__name__", [], "str"]
    - ["cf2326019", "concurrent.futures._base.PENDING.__class__.__name__", [], "str"]
    - ["cf2326020", "concurrent.futures._base.RUNNING.__class__.__name__", [], "str"]
    - ["cf2326021", "concurrent.futures._base.CANCELLED.__class__.__name__", [], "str"]
    - ["cf2326022", "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__class__.__name__", [], "str"]
    - ["cf2326023", "concurrent.futures._base.FINISHED.__class__.__name__", [], "str"]
