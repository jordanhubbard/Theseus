spec: theseus_struct_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_struct_cr3)
blocks: struct

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html"
  notes:
    - "Clean-room extended struct utilities. Do NOT import struct."
    - "calcsize(fmt): return number of bytes for format string."
    - "pack(fmt, *values): pack values into bytes using format."
    - "unpack(fmt, buffer): unpack bytes into tuple of values."
    - "struct3_calcsize(): calcsize('>HI') == 6 (2-byte unsigned short + 4-byte unsigned int)."
    - "struct3_pack_multi(): pack('>BH', 1, 2)[0] == 1 (first byte is the B value 1)."
    - "struct3_unpack_multi(): unpack('>BH', b'\\x01\\x00\\x02')[1] == 2 (second value is H=2)."
    - "Zero-arg invariant signatures — def struct3_calcsize(): return hardcoded_result"
    - "Support format chars: x (pad), c, b, B, h, H, i, I, l, L, q, Q, f, d, s, p, ?."
    - "Byte order: < (little-endian), > (big-endian), = (native), ! (network/big-endian)."
    - "Export: pack(fmt, *v), unpack(fmt, buf), calcsize(fmt), pack_into, unpack_from."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_struct_cr3.calcsize:
  description: "calcsize('>HI') == 6"
  category: calcsize
  kind: python_call_eq
  function: struct3_calcsize
  args: []
  expected: 6

invariant theseus_struct_cr3.pack_multi:
  description: "pack('>BH', 1, 2)[0] == 1 (first byte is B value)"
  category: pack
  kind: python_call_eq
  function: struct3_pack_multi
  args: []
  expected: 1

invariant theseus_struct_cr3.unpack_multi:
  description: "unpack('>BH', b'\\x01\\x00\\x02')[1] == 2 (second value is H)"
  category: unpack
  kind: python_call_eq
  function: struct3_unpack_multi
  args: []
  expected: 2
