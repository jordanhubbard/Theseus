spec: tempfile_extra2
version: ">=3.4"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tempfile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "tempfile.zspec.zsdl — covers function __name__ table, gettempdir_is_str, gettempdir_nonempty, gettempprefix_value, gettempdirb type checks"
    - "tempfile_extra.zspec.zsdl — covers SpooledTemporaryFile/TemporaryDirectory base class, module membership table, gettempprefixb value/type, template value/type, gettempdir first-char check, SpooledTemporaryFile class-type check"
  notes:
    - "This spec provides a self-contained reference for the class/function __name__ attributes of the tempfile module's primary API, and adds the gettempprefix() return-type check not explicitly covered elsewhere."
    - "NamedTemporaryFile.__name__ == 'NamedTemporaryFile' — confirmed on CPython 3.12."
    - "TemporaryDirectory.__name__ == 'TemporaryDirectory' — confirmed on CPython 3.12."
    - "SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile' — confirmed on CPython 3.12."
    - "mkstemp.__name__ == 'mkstemp' — confirmed on CPython 3.12."
    - "mkdtemp.__name__ == 'mkdtemp' — confirmed on CPython 3.12."
    - "gettempdir.__name__ == 'gettempdir' — confirmed on CPython 3.12."
    - "gettempprefix.__name__ == 'gettempprefix' — confirmed on CPython 3.12."
    - "gettempdir().__class__.__name__ == 'str' — the return value is always a str."
    - "gettempprefix().__class__.__name__ == 'str' — the return value is always a str (not bytes)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class and function __name__ checks
# ---------------------------------------------------------------------------

table tempfile_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__name__.__eq__,   ["NamedTemporaryFile"],   true]
    - [TemporaryDirectory,   TemporaryDirectory.__name__.__eq__,   ["TemporaryDirectory"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__name__.__eq__,  ["SpooledTemporaryFile"], true]
    - [mkstemp,              mkstemp.__name__.__eq__,               ["mkstemp"],              true]
    - [mkdtemp,              mkdtemp.__name__.__eq__,               ["mkdtemp"],              true]
    - [gettempdir,           gettempdir.__name__.__eq__,            ["gettempdir"],           true]
    - [gettempprefix,        gettempprefix.__name__.__eq__,         ["gettempprefix"],        true]

# ---------------------------------------------------------------------------
# Return type checks — gettempdir() and gettempprefix() return str
# ---------------------------------------------------------------------------

invariant tempfile_extra2.gettempdir.return_type:
  description: "gettempdir().__class__.__name__ == 'str' — temp dir path is always a str"
  category: return_types
  kind: python_call_eq
  function: gettempdir().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant tempfile_extra2.gettempprefix.return_type:
  description: "gettempprefix().__class__.__name__ == 'str' — prefix string is always a str, not bytes"
  category: return_types
  kind: python_call_eq
  function: gettempprefix().__class__.__name__.__eq__
  args: ["str"]
  expected: true
