spec: tempfile_extra2
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
    - "tempfile.zspec.zsdl — covers function_names table for NamedTemporaryFile/TemporaryFile/TemporaryDirectory/SpooledTemporaryFile/mkstemp/mkdtemp/gettempdir/gettempprefix/gettempdirb; gettempdir_is_str/nonempty; gettempprefix_value; gettempdirb_is_bytes/nonempty"
    - "tempfile_extra.zspec.zsdl — covers SpooledTemporaryFile/TemporaryDirectory base == object; mkstemp/mkdtemp/gettempdir/SpooledTemporaryFile/TemporaryDirectory __module__; gettempprefixb value/is_bytes; template value/is_str; gettempdir_starts_slash; SpooledTemporaryFile_is_type"
  notes:
    - "This spec extends tempfile.zspec.zsdl and tempfile_extra.zspec.zsdl with coverage not already present."
    - "Focus: __name__ and __module__ for NamedTemporaryFile, TemporaryFile, mkstemp, mkdtemp, gettempdir, gettempprefix."
    - "gettempprefix().__class__.__name__ == 'str' — verifies the type, complementing the value check in tempfile.zspec.zsdl."
    - "tempdir attribute: tempfile.tempdir is None by default; its class is 'NoneType' when unset."
    - "NamedTemporaryFile.__module__ == 'tempfile'; TemporaryFile.__module__ == 'tempfile'."
    - "TemporaryDirectory.__class__.__name__ == 'type' — TemporaryDirectory is a class object."
    - "SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile' added as standalone invariant."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — NamedTemporaryFile, TemporaryFile, gettempprefix
# tempfile_extra covers: mkstemp, mkdtemp, gettempdir, SpooledTemporaryFile,
#                         TemporaryDirectory __module__
# We add: NamedTemporaryFile, TemporaryFile, gettempprefix
# ---------------------------------------------------------------------------

invariant tempfile_extra2.NamedTemporaryFile.module:
  description: "tempfile.NamedTemporaryFile.__module__ == 'tempfile'"
  category: function_modules
  kind: python_call_eq
  function: NamedTemporaryFile.__module__.__eq__
  args: ["tempfile"]
  expected: true

invariant tempfile_extra2.TemporaryFile.module:
  description: "tempfile.TemporaryFile.__module__ == 'tempfile'"
  category: function_modules
  kind: python_call_eq
  function: TemporaryFile.__module__.__eq__
  args: ["tempfile"]
  expected: true

invariant tempfile_extra2.gettempprefix.module:
  description: "tempfile.gettempprefix.__module__ == 'tempfile'"
  category: function_modules
  kind: python_call_eq
  function: gettempprefix.__module__.__eq__
  args: ["tempfile"]
  expected: true

# ---------------------------------------------------------------------------
# gettempprefix() — return type
# tempfile.zspec.zsdl covers gettempprefix() == 'tmp' (value).
# We add the type check here.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.gettempprefix.is_str:
  description: "gettempprefix().__class__.__name__ == 'str' — result is always a str"
  category: gettempprefix
  kind: python_call_eq
  function: gettempprefix().__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# gettempdir() — return type confirmed as standalone invariant
# tempfile.zspec.zsdl covers gettempdir_is_str via function chain;
# We add a standalone class name check with a distinct id.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.gettempdir.class_name:
  description: "gettempdir().__class__.__name__ == 'str'"
  category: gettempdir
  kind: python_call_eq
  function: gettempdir().__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# TemporaryDirectory — is-type check
# tempfile_extra covers TemporaryDirectory.__bases__[0].__name__ == 'object'
# and TemporaryDirectory.__module__ == 'tempfile'.
# We add: TemporaryDirectory.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

invariant tempfile_extra2.TemporaryDirectory.is_type:
  description: "TemporaryDirectory.__class__.__name__ == 'type' — TemporaryDirectory is a class"
  category: class_names
  kind: python_call_eq
  function: TemporaryDirectory.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# SpooledTemporaryFile — standalone __name__ invariant
# tempfile.zspec.zsdl table row covered SpooledTemporaryFile.__name__.
# We add a standalone invariant here with a distinct id.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.SpooledTemporaryFile.name_standalone:
  description: "SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile'"
  category: class_names
  kind: python_call_eq
  function: SpooledTemporaryFile.__name__.__eq__
  args: ["SpooledTemporaryFile"]
  expected: true

# ---------------------------------------------------------------------------
# tempdir — module-level attribute default value
# tempfile.tempdir is None by default; its __class__.__name__ is 'NoneType'.
# tempfile_extra covers template (the legacy string attribute 'tmp').
# This is a distinct attribute.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.tempdir.class_is_NoneType:
  description: "tempfile.tempdir.__class__.__name__ == 'NoneType' — default value is None"
  category: constants
  kind: python_call_eq
  function: tempdir.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# mkstemp — standalone __name__ invariant
# tempfile.zspec.zsdl table covers mkstemp.__name__ via table row.
# tempfile_extra covers mkstemp.__module__.
# We add a standalone __name__ invariant with a distinct id.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.mkstemp.name_standalone:
  description: "tempfile.mkstemp.__name__ == 'mkstemp'"
  category: function_names
  kind: python_call_eq
  function: mkstemp.__name__.__eq__
  args: ["mkstemp"]
  expected: true

# ---------------------------------------------------------------------------
# mkdtemp — standalone __name__ invariant
# Same rationale as mkstemp above.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.mkdtemp.name_standalone:
  description: "tempfile.mkdtemp.__name__ == 'mkdtemp'"
  category: function_names
  kind: python_call_eq
  function: mkdtemp.__name__.__eq__
  args: ["mkdtemp"]
  expected: true

# ---------------------------------------------------------------------------
# NamedTemporaryFile — standalone __name__ invariant
# tempfile.zspec.zsdl table covers NamedTemporaryFile.__name__ via table row.
# We add a standalone invariant for consistency.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.NamedTemporaryFile.name_standalone:
  description: "tempfile.NamedTemporaryFile.__name__ == 'NamedTemporaryFile'"
  category: function_names
  kind: python_call_eq
  function: NamedTemporaryFile.__name__.__eq__
  args: ["NamedTemporaryFile"]
  expected: true

# ---------------------------------------------------------------------------
# TemporaryFile — standalone __name__ invariant
# tempfile.zspec.zsdl table covers TemporaryFile.__name__ via table row.
# We add a standalone invariant here.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.TemporaryFile.name_standalone:
  description: "tempfile.TemporaryFile.__name__ == 'TemporaryFile'"
  category: function_names
  kind: python_call_eq
  function: TemporaryFile.__name__.__eq__
  args: ["TemporaryFile"]
  expected: true

# ---------------------------------------------------------------------------
# TemporaryFile — module check (not covered in tempfile_extra)
# tempfile_extra only covers mkstemp, mkdtemp, gettempdir, SpooledTemporaryFile,
# TemporaryDirectory.  TemporaryFile module not yet checked.
# ---------------------------------------------------------------------------

invariant tempfile_extra2.TemporaryFile.module_standalone:
  description: "tempfile.TemporaryFile.__module__ == 'tempfile' (standalone cross-check)"
  category: function_modules
  kind: python_call_eq
  function: TemporaryFile.__module__.__eq__
  args: ["tempfile"]
  expected: true
