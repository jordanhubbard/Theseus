spec: struct_extra2116
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "struct.Struct is a C-implemented class for packing/unpacking binary data; it has no set/dict merge operators."
    - "struct.error is a subclass of Exception; exception classes do not define set/dict merge or set-intersection operators."
    - "Neither struct.Struct nor struct.error define __or__, __ror__, or __ior__ in their own __dict__."
    - "Neither struct.Struct nor struct.error define __and__, __rand__, or __iand__ in their own __dict__."
    - "Neither struct.Struct nor struct.error define __xor__, __rxor__, or __ixor__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# struct.Struct and struct.error do not define these operators
# ---------------------------------------------------------------------------

table struct_extra2116.or_protocol:
  description: "struct types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2116

  columns: [id, function, args, expected]
  rows:
    - ["st2116001", "struct.Struct.__dict__.__contains__", ["__or__"],  false]
    - ["st2116002", "struct.Struct.__dict__.__contains__", ["__ror__"], false]
    - ["st2116003", "struct.Struct.__dict__.__contains__", ["__ior__"], false]
    - ["st2116004", "struct.error.__dict__.__contains__",  ["__or__"],  false]
    - ["st2116005", "struct.error.__dict__.__contains__",  ["__ror__"], false]
    - ["st2116006", "struct.error.__dict__.__contains__",  ["__ior__"], false]

