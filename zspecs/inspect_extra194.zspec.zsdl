spec: inspect_extra194
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.isfunction.__name__ == 'isfunction' (len=10); isfunction is a Python function that returns True if the object is a Python function; verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect' (len=7); defined at top level in inspect.py; verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction' (len=10); top-level function so qualname equals name; verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' (len=9); isbuiltin returns True if the object is a built-in function or bound built-in method; verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' (len=7); defined at top level in inspect.py; verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' (len=7); isclass returns True if the object is a class; verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' (len=7); defined at top level in inspect.py; verified with Python 3.14.3."
    - "inspect.ismethod.__name__ == 'ismethod' (len=8); ismethod returns True if the object is a bound method; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isfunction identity — name, module, qualname
#
# inspect.isfunction.__name__    == 'isfunction' (len=10)
# inspect.isfunction.__module__  == 'inspect' (len=7)
# inspect.isfunction.__qualname__ == 'isfunction' (len=10)
#
# isfunction is a predicate function defined at top level in inspect.py
# that returns True when the object is a Python function (not a built-in).
# New to extra194.
# ---------------------------------------------------------------------------

table inspect_extra194.isfunction_identity:
  description: "inspect.isfunction identity: __name__=='isfunction'(len=10); __module__=='inspect'(len=7); __qualname__=='isfunction'(len=10); new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: inspectis194

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a Python function that returns True when the argument is a Python function; __name__ is 'isfunction' (len=10); str.__eq__('isfunction') returns True; verified with Python 3.14.3; new to extra194"]
    - [isfunction_name_len,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters: i-s-f-u-n-c-t-i-o-n; str.__len__() returns 10; verified with Python 3.14.3; new to extra194"]
    - [isfunction_module_eq,
       isfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra194"]
    - [isfunction_module_len,
       isfunction.__module__.__len__,
       [],
       7,
       "inspect.isfunction.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra194"]
    - [isfunction_qualname_eq,
       isfunction.__qualname__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — isfunction is a top-level function so its qualname equals its name; __qualname__ is 'isfunction' (len=10); str.__eq__('isfunction') returns True; verified with Python 3.14.3; new to extra194"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isbuiltin and inspect.isclass identity
#
# inspect.isbuiltin.__name__   == 'isbuiltin' (len=9)
# inspect.isbuiltin.__module__ == 'inspect' (len=7)
# inspect.isclass.__name__     == 'isclass' (len=7)
# inspect.isclass.__module__   == 'inspect' (len=7)
#
# isbuiltin returns True for C-level built-in functions and bound built-in
# methods. isclass returns True for any class object. New to extra194.
# ---------------------------------------------------------------------------

table inspect_extra194.isbuiltin_isclass_identity:
  description: "inspect.isbuiltin and isclass identity: isbuiltin.__name__=='isbuiltin'(len=9); isbuiltin.__module__=='inspect'(len=7); isclass.__name__=='isclass'(len=7); isclass.__module__=='inspect'(len=7); new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: inspectis194

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin returns True for C-level built-in functions and bound built-in methods; __name__ is 'isbuiltin' (len=9); str.__eq__('isbuiltin') returns True; verified with Python 3.14.3; new to extra194"]
    - [isbuiltin_name_len,
       isbuiltin.__name__.__len__,
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters: i-s-b-u-i-l-t-i-n; str.__len__() returns 9; verified with Python 3.14.3; new to extra194"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra194"]
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass returns True for any class object including built-in types; __name__ is 'isclass' (len=7); str.__eq__('isclass') returns True; verified with Python 3.14.3; new to extra194"]
    - [isclass_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra194"]

# ---------------------------------------------------------------------------
# Table 3: inspect.ismethod identity
#
# inspect.ismethod.__name__    == 'ismethod' (len=8)
# inspect.ismethod.__module__  == 'inspect' (len=7)
#
# ismethod returns True when the object is a bound method (an instance
# method bound to a class instance). New to extra194.
# ---------------------------------------------------------------------------

table inspect_extra194.ismethod_identity:
  description: "inspect.ismethod identity: __name__=='ismethod'(len=8); __module__=='inspect'(len=7); new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: inspectis194

  columns: [id, function, args, expected, description]
  rows:
    - [ismethod_name_eq,
       ismethod.__name__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — ismethod returns True when the object is a bound method bound to a class instance; __name__ is 'ismethod' (len=8); str.__eq__('ismethod') returns True; verified with Python 3.14.3; new to extra194"]
    - [ismethod_name_len,
       ismethod.__name__.__len__,
       [],
       8,
       "inspect.ismethod.__name__.__len__() == 8 — 'ismethod' has 8 characters: i-s-m-e-t-h-o-d; str.__len__() returns 8; verified with Python 3.14.3; new to extra194"]
    - [ismethod_module_eq,
       ismethod.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — ismethod is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra194"]
    - [isclass_module_len,
       isclass.__module__.__len__,
       [],
       7,
       "inspect.isclass.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra194"]
    - [isbuiltin_module_len,
       isbuiltin.__module__.__len__,
       [],
       7,
       "inspect.isbuiltin.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra194"]

