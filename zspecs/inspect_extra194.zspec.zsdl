invariant inspect_extra194.isfunction_name_eq:
  description: "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a Python function that returns True when the argument is a Python function; __name__ is 'isfunction' (len=10); verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

