spec: re_extra2701
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2686.zspec.zsdl — covers __and__/__or__/__xor__ dict-presence"
  notes:
    - "Wave 627 (re_extra2701) theme: __lshift__, __rshift__, and __invert__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __lshift__, __rshift__, or __invert__ in its own __dict__."
    - "__lshift__ is the left-shift operator (<<); regex objects are pattern-matching types, not integers."
    - "__rshift__ is the right-shift operator (>>); regex objects do not implement bit-shift semantics."
    - "__invert__ is the bitwise NOT operator (~); regex objects do not implement bitwise inversion."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2701.no_lshift_in_re_classes:
  description: "__lshift__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the left-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2701

  columns: [id, function, args, expected]
  rows:
    - ["re2701001", "re.Pattern.__dict__.__contains__", ["__lshift__"], false]
    - ["re2701002", "re.Match.__dict__.__contains__",   ["__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2701.no_rshift_in_re_classes:
  description: "__rshift__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the right-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2701

  columns: [id, function, args, expected]
  rows:
    - ["re2701003", "re.Pattern.__dict__.__contains__", ["__rshift__"], false]
    - ["re2701004", "re.Match.__dict__.__contains__",   ["__rshift__"], false]

# ---------------------------------------------------------------------------
# __invert__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2701.no_invert_in_re_classes:
  description: "__invert__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the bitwise NOT protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2701

  columns: [id, function, args, expected]
  rows:
    - ["re2701005", "re.Pattern.__dict__.__contains__", ["__invert__"], false]
    - ["re2701006", "re.Match.__dict__.__contains__",   ["__invert__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not bit-shift or bitwise-NOT hooks
# Confirms that regex objects are pattern-matching types, not integer types
# ---------------------------------------------------------------------------

table re_extra2701.re_has_regex_methods_not_shift_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __lshift__/__rshift__/__invert__; re.Match defines group/groups/start/end but NOT __lshift__/__rshift__/__invert__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2701

  columns: [id, function, args, expected]
  rows:
    - ["re2701007", "re.Pattern.__dict__.__contains__", ["match"],     true]
    - ["re2701008", "re.Pattern.__dict__.__contains__", ["search"],    true]
    - ["re2701009", "re.Pattern.__dict__.__contains__", ["sub"],       true]
    - ["re2701010", "re.Pattern.__dict__.__contains__", ["findall"],   true]
    - ["re2701011", "re.Pattern.__dict__.__contains__", ["__lshift__"], false]
    - ["re2701012", "re.Pattern.__dict__.__contains__", ["__rshift__"], false]
    - ["re2701013", "re.Pattern.__dict__.__contains__", ["__invert__"], false]
    - ["re2701014", "re.Match.__dict__.__contains__",   ["group"],     true]
    - ["re2701015", "re.Match.__dict__.__contains__",   ["groups"],    true]
    - ["re2701016", "re.Match.__dict__.__contains__",   ["start"],     true]
    - ["re2701017", "re.Match.__dict__.__contains__",   ["end"],       true]
    - ["re2701018", "re.Match.__dict__.__contains__",   ["__lshift__"], false]
    - ["re2701019", "re.Match.__dict__.__contains__",   ["__rshift__"], false]
    - ["re2701020", "re.Match.__dict__.__contains__",   ["__invert__"], false]
