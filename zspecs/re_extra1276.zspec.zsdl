provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 532 _extra1276: checks __subclasses__(), __mro__, and __bases__ type names for re.error, re.Pattern, re.Match"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1276.error_inheritance_types:
  description: "re.error __subclasses__, __mro__, and __bases__ type name checks"
  kind: python_call_eq
  category: error_inheritance_types
  id_prefix: re1276er
  columns: [id, function, args, expected]
  rows:
    - [re1276er001, re.error.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [re1276er002, re.error.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [re1276er003, re.error.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [re1276er004, re.error.__class__.__name__.__eq__,                 ["type"],  true]
    - [re1276er005, re.error.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [re1276er006, re.error.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [re1276er007, re.error.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [re1276er008, re.error.__class__.__name__.__eq__,                 ["type"],  true]

