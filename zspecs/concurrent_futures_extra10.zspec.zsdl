spec: concurrent_futures_extra10
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra9.zspec.zsdl."
    - "extra9 covers: Future additional method __name__ (cancelled/running/done/exception/set_result); InvalidStateError.__qualname__/__module__/__bases__[0].__name__; ThreadPoolExecutor/__class__.__name__=='type'; ProcessPoolExecutor/__class__.__name__=='type'; ThreadPoolExecutor/ProcessPoolExecutor __mro__[2].__name__=='object'."
    - "extra6 covers: __qualname__ for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/TimeoutError/BrokenExecutor/as_completed/wait."
    - "extra2 covers: __name__/__module__ for ThreadPoolExecutor/ProcessPoolExecutor/Future/as_completed; ThreadPoolExecutor.submit/__name__ and .map/__name__."
    - "base spec covers: Future.cancel/__name__; Future.result/__name__; Future.add_done_callback/__name__."
    - "NOT yet covered in any prior spec: Future method __qualname__ for cancel/result/done/cancelled/running/exception."
    - "NOT yet covered: ThreadPoolExecutor.submit/__qualname__ and ThreadPoolExecutor.shutdown/__qualname__."
    - "NOT yet covered: ProcessPoolExecutor.submit/__qualname__."
    - "NOT yet covered: Executor.submit/__qualname__."
    - "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel'."
    - "concurrent.futures.Future.result.__qualname__ == 'Future.result'."
    - "concurrent.futures.Future.done.__qualname__ == 'Future.done'."
    - "concurrent.futures.Future.cancelled.__qualname__ == 'Future.cancelled'."
    - "concurrent.futures.Future.running.__qualname__ == 'Future.running'."
    - "concurrent.futures.Future.exception.__qualname__ == 'Future.exception'."
    - "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'."
    - "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'."
    - "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'."
    - "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future method __qualname__ checks
#
# extra9 covers Future method __name__ (cancelled/running/done/exception/
# set_result). The base spec covers cancel/result/add_done_callback __name__.
# No prior concurrent_futures spec checks __qualname__ for any Future method.
# For methods defined in _base.Future, __qualname__ is 'Future.<method>'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra10.Future_method_qualnames:
  description: "concurrent.futures.Future methods have __qualname__ == 'Future.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: futqname

  columns: [id, function, args, expected]
  rows:
    - [cancel,    Future.cancel.__qualname__.__eq__,    ["Future.cancel"],    true]
    - [result,    Future.result.__qualname__.__eq__,    ["Future.result"],    true]
    - [done,      Future.done.__qualname__.__eq__,      ["Future.done"],      true]
    - [cancelled, Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
    - [running,   Future.running.__qualname__.__eq__,   ["Future.running"],   true]
    - [exception, Future.exception.__qualname__.__eq__, ["Future.exception"], true]

# ---------------------------------------------------------------------------
# Executor and concrete executor method __qualname__ checks
#
# extra2 covers ThreadPoolExecutor.submit.__name__ == 'submit' and
# ThreadPoolExecutor.map.__name__ == 'map'. extra3 covers
# Executor.submit.__name__ == 'submit'. No prior spec checks __qualname__
# for submit on any executor class, or for ThreadPoolExecutor.shutdown or
# ProcessPoolExecutor.submit. The __qualname__ of a method defined in class C
# is 'C.<method>'; overrides keep their defining class's prefix.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra10.ThreadPoolExecutor_submit.qualname:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'"
  category: method_qualnames
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra10.ThreadPoolExecutor_shutdown.qualname:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"
  category: method_qualnames
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

invariant concurrent_futures_extra10.ProcessPoolExecutor_submit.qualname:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'"
  category: method_qualnames
  kind: python_call_eq
  function: ProcessPoolExecutor.submit.__qualname__.__eq__
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra10.Executor_submit.qualname:
  description: "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'"
  category: method_qualnames
  kind: python_call_eq
  function: Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true
