spec: re_extra221
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.compile() Pattern object __class__.__name__ and __class__.__module__; pattern and groups attributes; compiled pattern match() result; re.error (PatternError) class metadata."
    - "re.compile('hello').__class__.__name__ == 'Pattern' — the compiled pattern is a Pattern object."
    - "re.compile('hello').__class__.__module__ == 're' — Pattern is reported as being in the re module."
    - "re.compile('hello').pattern == 'hello' — the source pattern string is preserved."
    - "re.compile('hello').flags.__class__.__name__ == 'int' — flags is a plain int in Python 3.14."
    - "re.compile('hello').groups == 0 — no capture groups."
    - "re.compile('(a)(b)').groups == 2 — two capture groups."
    - "re.compile('hello').match('hello world').group() == 'hello' — match anchors at start."
    - "re.compile(r'\\d+').match('123abc').group() == '123' — digits match at start."
    - "re.error.__name__ == 'PatternError' — in Python 3.14 re.error was renamed to PatternError (re.error is an alias)."
    - "re.error.__module__ == 're'."
    - "re.error.__bases__[0].__name__ == 'Exception' — PatternError directly subclasses Exception."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Compiled Pattern object class metadata
# re.compile() returns a re.Pattern (C type). Its __class__.__name__ is
# 'Pattern' and __class__.__module__ is 're'.
# ---------------------------------------------------------------------------

table re_extra221.compiled_pattern_class_meta:
  description: "re.compile() result __class__.__name__ and __class__.__module__"
  kind: python_call_eq
  category: class_metadata
  id_prefix: repatclsmeta221

  columns: [id, function, args, expected]
  rows:
    - [cls_name,   "compile('hello').__class__.__name__.__eq__",   ["Pattern"], true]
    - [cls_module, "compile('hello').__class__.__module__.__eq__", ["re"],      true]

# ---------------------------------------------------------------------------
# Pattern .pattern and .groups attributes
# pattern stores the source regex string; groups counts capture groups.
# ---------------------------------------------------------------------------

table re_extra221.compiled_pattern_attrs:
  description: "re.compile() result .pattern value and .groups count"
  kind: python_call_eq
  category: pattern_attrs
  id_prefix: repatattrs221

  columns: [id, function, args, expected]
  rows:
    - [pattern_eq,       "compile('hello').pattern.__eq__",          ["hello"], true]
    - [groups_zero,      "compile('hello').groups.__eq__",           [0],       true]
    - [groups_two,       "compile('(a)(b)').groups.__eq__",          [2],       true]
    - [flags_is_int,     "compile('hello').flags.__class__.__name__.__eq__", ["int"], true]

# ---------------------------------------------------------------------------
# re.error (PatternError) class metadata
# In Python 3.14, re.error is an alias for re.PatternError.
# __name__ == 'PatternError', __module__ == 're', base is Exception.
# ---------------------------------------------------------------------------

table re_extra221.re_error_class_meta:
  description: "re.error class metadata: __name__, __module__, base class"
  kind: python_call_eq
  category: class_metadata
  id_prefix: reerrmeta221

  columns: [id, function, args, expected]
  rows:
    - [error_name,      "error.__name__.__eq__",              ["PatternError"], true]
    - [error_module,    "error.__module__.__eq__",            ["re"],           true]
    - [error_base_name, "error.__bases__[0].__name__.__eq__", ["Exception"],    true]

# ---------------------------------------------------------------------------
# Compiled pattern match() and group() chained calls
# ---------------------------------------------------------------------------

invariant re_extra221.compile.hello.match.group:
  description: "re.compile('hello').match('hello world').group() == 'hello' — Pattern.match anchors at position 0"
  category: match
  kind: python_call_eq
  function: "compile('hello').match('hello world').group.__call__"
  args: []
  expected: "hello"

invariant re_extra221.compile.digits.match.group:
  description: "re.compile(r'\\d+').match('123abc').group() == '123' — digits matched at start"
  category: match
  kind: python_call_eq
  function: "compile('\\\\d+').match('123abc').group.__call__"
  args: []
  expected: "123"

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra221.compile.class_name:
  description: "re.compile('hello').__class__.__name__ == 'Pattern'"
  category: class_metadata
  kind: python_call_eq
  function: "compile('hello').__class__.__name__.__eq__"
  args: ["Pattern"]
  expected: true

invariant re_extra221.compile.pattern_attr:
  description: "re.compile('hello').pattern == 'hello' — source regex string is preserved"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('hello').pattern.__eq__"
  args: ["hello"]
  expected: true

invariant re_extra221.compile.groups_zero:
  description: "re.compile('hello').groups == 0 — no capture groups in plain literal pattern"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('hello').groups.__eq__"
  args: [0]
  expected: true

invariant re_extra221.compile.groups_two:
  description: "re.compile('(a)(b)').groups == 2 — two capturing groups"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('(a)(b)').groups.__eq__"
  args: [2]
  expected: true

invariant re_extra221.error.name:
  description: "re.error.__name__ == 'PatternError' — re.error is an alias for PatternError in Python 3.14"
  category: class_metadata
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra221.error.base:
  description: "re.error.__bases__[0].__name__ == 'Exception' — PatternError directly subclasses Exception"
  category: class_metadata
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
