spec: colorsys_extra5
version: ">=3.9"
backend: python_module(colorsys)

docs: https://docs.python.org/3/library/colorsys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/colorsys.html — Python colorsys documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/colorsys.py"
  notes:
    - "This spec extends colorsys.zspec.zsdl and colorsys_extra through colorsys_extra4.zspec.zsdl."
    - "colorsys covers: all 6 __name__ (table); rgb_to_yiq.__module__; red HSV hue/sat/val; hsv_to_rgb(0,1,1)[0]; rgb_to_hls red hue and white lightness."
    - "colorsys_extra covers: all 6 __name__ invariants; rgb_to_hsv.__module__; return type tuple; rgb_to_hsv red full tuple; hsv_to_rgb red full tuple."
    - "colorsys_extra2 covers: function_names table; __module__ for hsv_to_rgb/rgb_to_hls/hls_to_rgb/yiq_to_rgb; rgb_to_hls red full/lightness/saturation; hls_to_rgb red all channels; hsv_to_rgb red green/blue; rgb_to_yiq return type; rgb_to_hsv black return type."
    - "colorsys_extra3 covers: rgb_to_hsv red sat/val; green value/sat; hsv_to_rgb red[0]; rgb_to_hls red hue; hls_to_rgb blue; black hue/sat/val."
    - "colorsys_extra4 covers: rgb_to_yiq/yiq_to_rgb __name__ standalone; rgb_to_yiq(1,0,0) I/Q components; rgb_to_hsv blue hue/sat/val."
    - "This spec adds: rgb_to_hsv(1,1,1) white components (hue=0, sat=0, val=1); rgb_to_hls(0,0,0) black (0,0,0); rgb_to_hls(1,1,1) sat==0.0; rgb_to_yiq(0,0,0) black (0,0,0); rgb_to_yiq(1,1,1)[0]==1.0; hsv_to_rgb(0,0,0) black; hsv_to_rgb(0,0,1) white; hls_to_rgb(0,0,0) black; hls_to_rgb(0,1,0) white; yiq_to_rgb(0,0,0) black; rgb_to_hsv/__qualname__, hsv_to_rgb/__qualname__."
    - "colorsys.rgb_to_hsv(1.0, 1.0, 1.0) returns (0.0, 0.0, 1.0): white has hue=0 (undefined), saturation=0, value=1."
    - "colorsys.rgb_to_hls(0.0, 0.0, 0.0) returns (0.0, 0.0, 0.0): black has hue=0, lightness=0, saturation=0."
    - "colorsys.rgb_to_hls(1.0, 1.0, 1.0)[2] == 0.0: white has saturation=0 in HLS (already covers lightness=1 in colorsys)."
    - "colorsys.rgb_to_yiq(0.0, 0.0, 0.0) returns (0.0, 0.0, 0.0): black maps to YIQ origin."
    - "colorsys.rgb_to_yiq(1.0, 1.0, 1.0)[0] == 1.0: white has Y (luma) == 1.0."
    - "colorsys.hsv_to_rgb(0.0, 0.0, 0.0) returns (0.0, 0.0, 0.0): zero value means black."
    - "colorsys.hsv_to_rgb(0.0, 0.0, 1.0) returns (1.0, 1.0, 1.0): zero saturation with full value means white."
    - "colorsys.hls_to_rgb(0.0, 0.0, 0.0) returns (0.0, 0.0, 0.0): zero lightness means black regardless of hue/sat."
    - "colorsys.hls_to_rgb(0.0, 1.0, 0.0) returns (1.0, 1.0, 1.0): full lightness with zero saturation means white."
    - "colorsys.yiq_to_rgb(0.0, 0.0, 0.0) returns (0.0, 0.0, 0.0): YIQ origin maps to black."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# rgb_to_hsv(1.0, 1.0, 1.0) — white: hue=0.0, saturation=0.0, value=1.0
# colorsys_extra checks the return type for white but NOT the component values.
# No prior spec covers white's HSV components.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.rgb_to_hsv.white_hue:
  description: "colorsys.rgb_to_hsv(1.0, 1.0, 1.0)[0] == 0.0 — hue of white is 0.0 (undefined, defaults to 0)"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_extra5.rgb_to_hsv.white_saturation:
  description: "colorsys.rgb_to_hsv(1.0, 1.0, 1.0)[1] == 0.0 — saturation of white is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

invariant colorsys_extra5.rgb_to_hsv.white_value:
  description: "colorsys.rgb_to_hsv(1.0, 1.0, 1.0)[2] == 1.0 — value of white is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0

# ---------------------------------------------------------------------------
# rgb_to_hls(0.0, 0.0, 0.0) — black: hue=0.0, lightness=0.0, saturation=0.0
# No prior spec covers rgb_to_hls with a black input.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.rgb_to_hls.black_hue:
  description: "colorsys.rgb_to_hls(0.0, 0.0, 0.0)[0] == 0.0 — hue of black is 0.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_extra5.rgb_to_hls.black_lightness:
  description: "colorsys.rgb_to_hls(0.0, 0.0, 0.0)[1] == 0.0 — lightness of black is 0.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# rgb_to_hls(1.0, 1.0, 1.0) — white saturation
# colorsys.zspec.zsdl already covers white lightness [1] == 1.0.
# White saturation [2] == 0.0 is NOT covered anywhere.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.rgb_to_hls.white_saturation:
  description: "colorsys.rgb_to_hls(1.0, 1.0, 1.0)[2] == 0.0 — saturation of white is 0.0 in HLS"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [2]
  expected: 0.0

# ---------------------------------------------------------------------------
# rgb_to_yiq(0.0, 0.0, 0.0) — black: Y=0.0, I=0.0, Q=0.0
# No prior spec covers rgb_to_yiq with a black input.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.rgb_to_yiq.black_y:
  description: "colorsys.rgb_to_yiq(0.0, 0.0, 0.0)[0] == 0.0 — Y (luma) of black is 0.0"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_extra5.rgb_to_yiq.black_i:
  description: "colorsys.rgb_to_yiq(0.0, 0.0, 0.0)[1] == 0.0 — I (in-phase) of black is 0.0"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# rgb_to_yiq(1.0, 1.0, 1.0) — white: Y=1.0 (I and Q are 0.0 for achromatic)
# No prior spec covers rgb_to_yiq with a white input.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.rgb_to_yiq.white_y:
  description: "colorsys.rgb_to_yiq(1.0, 1.0, 1.0)[0] == 1.0 — Y (luma) of white is 1.0"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

# ---------------------------------------------------------------------------
# hsv_to_rgb(0.0, 0.0, 0.0) — black: all channels 0.0
# No prior spec covers hsv_to_rgb with a zero-value (black) input.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.hsv_to_rgb.black_red_channel:
  description: "colorsys.hsv_to_rgb(0.0, 0.0, 0.0)[0] == 0.0 — red channel of black is 0.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_extra5.hsv_to_rgb.black_green_channel:
  description: "colorsys.hsv_to_rgb(0.0, 0.0, 0.0)[1] == 0.0 — green channel of black is 0.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# hsv_to_rgb(0.0, 0.0, 1.0) — white (zero saturation, full value)
# No prior spec covers this input. Full value with zero saturation gives white.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.hsv_to_rgb.white_red_channel:
  description: "colorsys.hsv_to_rgb(0.0, 0.0, 1.0)[0] == 1.0 — red channel of white is 1.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 0.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

invariant colorsys_extra5.hsv_to_rgb.white_green_channel:
  description: "colorsys.hsv_to_rgb(0.0, 0.0, 1.0)[1] == 1.0 — green channel of white is 1.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 0.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

# ---------------------------------------------------------------------------
# hls_to_rgb(0.0, 0.0, 0.0) — black: zero lightness gives black regardless of hue/sat
# No prior spec covers hls_to_rgb with a black (zero-lightness) input.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.hls_to_rgb.black_red_channel:
  description: "colorsys.hls_to_rgb(0.0, 0.0, 0.0)[0] == 0.0 — red channel of black is 0.0"
  category: hls
  kind: python_call_eq
  function: hls_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# hls_to_rgb(0.0, 1.0, 0.0) — white: full lightness with zero saturation gives white
# No prior spec covers hls_to_rgb with a white (full-lightness) input.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.hls_to_rgb.white_red_channel:
  description: "colorsys.hls_to_rgb(0.0, 1.0, 0.0)[0] == 1.0 — red channel of white is 1.0"
  category: hls
  kind: python_call_eq
  function: hls_to_rgb
  args: [0.0, 1.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

invariant colorsys_extra5.hls_to_rgb.white_blue_channel:
  description: "colorsys.hls_to_rgb(0.0, 1.0, 0.0)[2] == 1.0 — blue channel of white is 1.0"
  category: hls
  kind: python_call_eq
  function: hls_to_rgb
  args: [0.0, 1.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0

# ---------------------------------------------------------------------------
# yiq_to_rgb(0.0, 0.0, 0.0) — black: YIQ origin maps back to black
# No prior spec covers yiq_to_rgb return values.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.yiq_to_rgb.black_red_channel:
  description: "colorsys.yiq_to_rgb(0.0, 0.0, 0.0)[0] == 0.0 — red channel of YIQ black is 0.0"
  category: yiq
  kind: python_call_eq
  function: yiq_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_extra5.yiq_to_rgb.black_green_channel:
  description: "colorsys.yiq_to_rgb(0.0, 0.0, 0.0)[1] == 0.0 — green channel of YIQ black is 0.0"
  category: yiq
  kind: python_call_eq
  function: yiq_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# __qualname__ checks — colorsys functions are Python functions with
# __qualname__ == __name__ (no class nesting). No prior colorsys spec checks
# __qualname__ for any function.
# ---------------------------------------------------------------------------

invariant colorsys_extra5.rgb_to_hsv.qualname:
  description: "colorsys.rgb_to_hsv.__qualname__ == 'rgb_to_hsv'"
  category: function_names
  kind: python_call_eq
  function: rgb_to_hsv.__qualname__.__eq__
  args: ["rgb_to_hsv"]
  expected: true

invariant colorsys_extra5.hsv_to_rgb.qualname:
  description: "colorsys.hsv_to_rgb.__qualname__ == 'hsv_to_rgb'"
  category: function_names
  kind: python_call_eq
  function: hsv_to_rgb.__qualname__.__eq__
  args: ["hsv_to_rgb"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __qualname__ checks for all six colorsys functions
# ---------------------------------------------------------------------------

table colorsys_extra5.all_functions.qualnames:
  kind: python_call_eq
  category: function_names
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [rgb_to_hsv, rgb_to_hsv.__qualname__.__eq__, ["rgb_to_hsv"], true]
    - [hsv_to_rgb, hsv_to_rgb.__qualname__.__eq__, ["hsv_to_rgb"], true]
    - [rgb_to_hls, rgb_to_hls.__qualname__.__eq__, ["rgb_to_hls"], true]
    - [hls_to_rgb, hls_to_rgb.__qualname__.__eq__, ["hls_to_rgb"], true]
    - [rgb_to_yiq, rgb_to_yiq.__qualname__.__eq__, ["rgb_to_yiq"], true]
    - [yiq_to_rgb, yiq_to_rgb.__qualname__.__eq__, ["yiq_to_rgb"], true]
