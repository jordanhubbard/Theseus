spec: typing_extra18
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 612 — Parameter Specification Variables"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra17.zspec.zsdl."
    - "typing_extra17 covers: TypeVar/ParamSpec/TypeVarTuple/Protocol __name__.__len__; TypeVarTuple __mro__/__bases__ lengths; TypeVarTuple/ParamSpec __mro__ entries; Protocol.__bases__[0]; get_type_hints.__qualname__.__len__."
    - "typing_extra16 covers: Literal/__name__; Final/__name__; Annotated/__name__; TypeGuard/__name__; special form __module__ table; special form __qualname__ table; runtime_checkable/__qualname__."
    - "typing_extra10 covers: assert_never/__qualname__/__module__; assert_type/__qualname__/__module__; no_type_check/__qualname__/__module__; final/__qualname__/__module__; ParamSpec/__bases__; TypeVarTuple/__bases__; Never/Self/LiteralString __class__.__name__."
    - "Focus of this spec: __qualname__.__len__ for typing helper functions not yet measured — no_type_check, no_type_check_decorator, final, assert_never, assert_type, is_typeddict, get_overloads, overload, cast, runtime_checkable."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for typing helper functions — batch 1
#
# typing_extra17 covers get_type_hints.__qualname__.__len__() == 14.
# typing_extra16 covers runtime_checkable/__qualname__.__eq__.
# typing_extra10 covers no_type_check/__qualname__/__eq__, final/__qualname__/__eq__,
# assert_never/__qualname__/__eq__, assert_type/__qualname__/__eq__.
# No prior spec checks __qualname__.__len__() for any of these functions.
# Lengths: no_type_check=13, no_type_check_decorator=23, final=5,
#          assert_never=12, assert_type=11.
# ---------------------------------------------------------------------------

table typing_extra18.helper_qualname_lengths_1:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualnamelen

  columns: [id, function, args, expected]
  rows:
    - [no_type_check,           no_type_check.__qualname__.__len__,           [], 13]
    - [no_type_check_decorator, no_type_check_decorator.__qualname__.__len__, [], 23]
    - [final,                   final.__qualname__.__len__,                   [], 5]
    - [assert_never,            assert_never.__qualname__.__len__,            [], 12]
    - [assert_type,             assert_type.__qualname__.__len__,             [], 11]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for typing helper functions — batch 2
#
# typing_extra15 covers cast/__qualname__.__eq__ and get_args/__qualname__.__eq__
# and get_origin/__qualname__.__eq__. typing_extra9 covers is_typeddict/__qualname__
# and get_overloads/__qualname__.
# typing_extra13 covers overload/__qualname__.__eq__.
# typing_extra16 covers runtime_checkable/__qualname__.__eq__.
# No prior spec checks __qualname__.__len__() for these functions.
# Lengths: is_typeddict=12, get_overloads=13, overload=8, cast=4,
#          runtime_checkable=17.
# ---------------------------------------------------------------------------

table typing_extra18.helper_qualname_lengths_2:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualnamelen2

  columns: [id, function, args, expected]
  rows:
    - [is_typeddict,      is_typeddict.__qualname__.__len__,      [], 12]
    - [get_overloads,     get_overloads.__qualname__.__len__,     [], 13]
    - [overload,          overload.__qualname__.__len__,          [], 8]
    - [cast,              cast.__qualname__.__len__,              [], 4]
    - [runtime_checkable, runtime_checkable.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# no_type_check_decorator.__qualname__.__eq__ standalone
#
# typing_extra11 covers no_type_check_decorator.__qualname__.__eq__ as a
# standalone invariant. This spec also checks __qualname__.__len__ above.
# Verify the string identity of no_type_check_decorator.__qualname__ as a
# standalone boolean invariant separate from the length check.
# ---------------------------------------------------------------------------

invariant typing_extra18.no_type_check_decorator.qualname_eq:
  description: "typing.no_type_check_decorator.__qualname__ == 'no_type_check_decorator' — decorator qualname"
  category: qualnames
  kind: python_call_eq
  function: no_type_check_decorator.__qualname__.__eq__
  args: ["no_type_check_decorator"]
  expected: true

# ---------------------------------------------------------------------------
# get_overloads.__qualname__.__eq__ standalone
#
# typing_extra9 covers get_overloads.__qualname__.__eq__ as a standalone.
# This spec verifies the length (13) in a table above. As a complementary
# standalone boolean, confirm the exact string value.
# ---------------------------------------------------------------------------

invariant typing_extra18.get_overloads.qualname_eq:
  description: "typing.get_overloads.__qualname__ == 'get_overloads' — module-level function qualname"
  category: qualnames
  kind: python_call_eq
  function: get_overloads.__qualname__.__eq__
  args: ["get_overloads"]
  expected: true

# ---------------------------------------------------------------------------
# is_typeddict.__qualname__.__eq__ standalone
#
# typing_extra9 covers is_typeddict.__qualname__.__eq__. This invariant
# verifies the length (12) in the table above and the string value here.
# ---------------------------------------------------------------------------

invariant typing_extra18.is_typeddict.qualname_eq:
  description: "typing.is_typeddict.__qualname__ == 'is_typeddict' — module-level function qualname"
  category: qualnames
  kind: python_call_eq
  function: is_typeddict.__qualname__.__eq__
  args: ["is_typeddict"]
  expected: true
