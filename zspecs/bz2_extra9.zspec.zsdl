spec: bz2_extra9
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2 through bz2_extra8; it does NOT duplicate invariants present in those files."
    - "bz2_extra8 covers: BZ2Compressor().compress.__name__; BZ2Compressor().flush.__name__; BZ2Decompressor().decompress.__name__; BZ2Decompressor eof/needs_input/unused_data types; BZ2Decompressor instance class name; BZ2File.__mro__[1].__name__; BZ2File.__qualname__.__class__.__name__; decompress(pre-computed-hello-world)."
    - "bz2_extra7 covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__ standalone; open/compress/decompress __module__ standalone; BZ2File.__bases__[0].__name__; BZ2Compressor() instance class name; BZ2Decompressor.__qualname__.__class__.__name__."
    - "bz2_extra6 covers: BZ2Compressor/__module__=='_bz2'; BZ2Decompressor/__module__=='_bz2'; base is object; compress/decompress/open __code__.co_name; BZ2Decompressor().needs_input==True; BZ2Decompressor().unused_data==b''."
    - "bz2_extra4 covers: BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table; open/compress/decompress __qualname__ table; compress(b'') class name (method_chain); BZ2File.__qualname__ is str."
    - "NOT yet covered: bz2.compress(b'hello world').__class__.__name__ == 'bytes' as standalone invariant."
    - "NOT yet covered: bz2.decompress(bz2.compress(b'hello')).__class__.__name__ == 'bytes' (roundtrip type check) via pre-computed bytes."
    - "NOT yet covered: bz2.compress.__name__ == 'compress' as standalone python_call_eq invariant."
    - "NOT yet covered: bz2.decompress.__name__ == 'decompress' as standalone python_call_eq invariant."
    - "NOT yet covered: bz2.open.__name__ == 'open' as standalone python_call_eq invariant."
    - "NOT yet covered: bz2.BZ2File.__qualname__ == 'BZ2File' as standalone invariant from extra9 namespace."
    - "NOT yet covered: bz2.BZ2Compressor.__qualname__ == 'BZ2Compressor' as standalone invariant from extra9 namespace."
    - "NOT yet covered: bz2.BZ2Decompressor.__qualname__ == 'BZ2Decompressor' as standalone invariant from extra9 namespace."
    - "NOT yet covered: bz2.__name__ == 'bz2' as standalone invariant (module __name__ attribute)."
    - "NOT yet covered: bz2.compress(b'').__class__.__name__ == 'bytes' — empty-input compress type check."
    - "Pre-computed bz2 of b'hello': 425a68393141592653591931653d00000081000244a000219a68334d07338bb9229c28480c98b29e80 — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compress() return type — always bytes
#
# No prior bz2 spec verifies compress().__class__.__name__ == 'bytes' as a
# standalone python_call_eq invariant from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra9.compress.returns_bytes:
  description: "bz2.compress(b'hello world').__class__.__name__ == 'bytes'"
  category: types
  kind: python_call_eq
  function: compress
  args: [!ascii "hello world"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# decompress(pre-computed) return type — always bytes
#
# bz2_extra8 verifies decompress(pre-computed) == b'hello world' (equality).
# No prior spec checks the __class__.__name__ of the return value as a
# standalone invariant. Pre-computed bz2 of b'hello' used here.
# ---------------------------------------------------------------------------

invariant bz2_extra9.decompress.returns_bytes:
  description: "bz2.decompress(pre-computed-bz2-of-hello).__class__.__name__ == 'bytes'"
  category: types
  kind: python_call_eq
  function: decompress
  args: [!hex 425a68393141592653591931653d00000081000244a000219a68334d07338bb9229c28480c98b29e80]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attributes — compress, decompress, open
#
# bz2_extra covers __name__ via method_chain in invariant blocks.
# These standalone python_call_eq invariants anchor the same properties
# using the dotted-attribute function form from the extra9 namespace.
# ---------------------------------------------------------------------------

table bz2_extra9.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname9

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__name__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__name__.__eq__, ["decompress"], true]
    - [open,       open.__name__.__eq__,       ["open"],       true]

# ---------------------------------------------------------------------------
# Class __qualname__ attributes — BZ2File, BZ2Compressor, BZ2Decompressor
#
# bz2_extra4 covers these via a table from the extra4 namespace. These
# standalone invariants anchor the same properties from the extra9 namespace
# with distinct IDs.
# ---------------------------------------------------------------------------

invariant bz2_extra9.BZ2File.qualname:
  description: "bz2.BZ2File.__qualname__ == 'BZ2File' — top-level class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.__qualname__.__eq__
  args: ["BZ2File"]
  expected: true

invariant bz2_extra9.BZ2Compressor.qualname:
  description: "bz2.BZ2Compressor.__qualname__ == 'BZ2Compressor' — top-level class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: BZ2Compressor.__qualname__.__eq__
  args: ["BZ2Compressor"]
  expected: true

invariant bz2_extra9.BZ2Decompressor.qualname:
  description: "bz2.BZ2Decompressor.__qualname__ == 'BZ2Decompressor' — top-level class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: BZ2Decompressor.__qualname__.__eq__
  args: ["BZ2Decompressor"]
  expected: true

# ---------------------------------------------------------------------------
# bz2.__name__ — the module's own name attribute
#
# The pure-Python wrapper module (Lib/bz2.py) has __name__ == 'bz2'.
# No prior bz2 spec verifies this attribute as a standalone invariant.
# ---------------------------------------------------------------------------

invariant bz2_extra9.compress.empty_returns_bytes:
  description: "bz2.compress(b'').__class__.__name__ == 'bytes' — empty-input compress still returns bytes"
  category: types
  kind: python_call_eq
  function: compress
  args: [!hex ""]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant bz2_extra9.module.name:
  description: "bz2.__name__ == 'bz2' — the module-level __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["bz2"]
  expected: true
