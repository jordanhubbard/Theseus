spec: concurrent_futures_extra52
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ThreadPoolExecutor — ThreadPoolExecutor documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Future — Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra51.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__.__module__=='builtins' tables (extra47/extra49)."
    - "This spec covers: concurrent.futures class __class__.__module__.__eq__('builtins') for ProcessPoolExecutor/Future/Executor — these three classes are not yet covered by prior specs (extra45 only covered ThreadPoolExecutor); their metaclass is 'type' from builtins. Also: as_completed/__class__.__module__.__eq__('builtins') — extra45 covered wait but not as_completed. Also: ThreadPoolExecutor/__init__.__class__.__name__.__eq__('function'), ProcessPoolExecutor/__init__.__class__.__name__.__eq__('function'), Future/__init__.__class__.__name__.__eq__('function') — Python class __init__ methods are plain functions; no prior concurrent.futures spec has captured any __init__.__class__ attribute. Note: Executor.__init__ is a wrapper_descriptor (C-level), not a function, so it is excluded from the __init__.__class__.__name__=='function' table."
    - "concurrent.futures.ProcessPoolExecutor.__class__.__module__ == 'builtins'. ProcessPoolExecutor is a standard Python class with metaclass 'type' from builtins; __class__.__module__ == 'builtins' (8 chars). Prior extra45 covered ThreadPoolExecutor but not ProcessPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__class__.__module__ == 'builtins'. Future is a standard Python class defined in Lib/concurrent/futures/_base.py with metaclass 'type' from builtins; __class__.__module__ == 'builtins'. Prior extra45 covered ThreadPoolExecutor but not Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__class__.__module__ == 'builtins'. Executor is the abstract base class defined in Lib/concurrent/futures/_base.py with metaclass 'type' from builtins; __class__.__module__ == 'builtins'. Novel check not in prior specs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__class__.__module__ == 'builtins'. as_completed is a module-level generator function (plain Python function object); its __class__ is the built-in 'function' type, whose __module__ is 'builtins'. Prior extra45 covered wait but not as_completed. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__ == 'function'. ThreadPoolExecutor.__init__ is a plain Python function defined in Lib/concurrent/futures/thread.py; its __class__.__name__ == 'function'. No prior concurrent.futures spec has captured any __init__.__class__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__ == 'function'. ProcessPoolExecutor.__init__ is a plain Python function defined in Lib/concurrent/futures/process.py; its __class__.__name__ == 'function'. Novel __init__.__class__.__name__ check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__class__.__name__ == 'function'. Future.__init__ is a plain Python function defined in Lib/concurrent/futures/_base.py; its __class__.__name__ == 'function'. Novel __init__.__class__.__name__ check for Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Note: Executor.__init__.__class__.__name__ == 'wrapper_descriptor' (a C-level slot wrapper), not 'function', because Executor inherits object.__init__ as a C slot. This is why Executor is excluded from the __init__.__class__.__name__=='function' table. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __class__.__module__ string equality — extra52
#
# Three classes not yet covered by prior extra45:
#   ProcessPoolExecutor.__class__.__module__ == 'builtins'
#   Future.__class__.__module__              == 'builtins'
#   Executor.__class__.__module__            == 'builtins'
# All have metaclass 'type', which is defined in the builtins module.
# Also: as_completed.__class__.__module__ == 'builtins' (extra45 covered wait only).
#
# Prior extra45 covered: wait/__class__.__module__ and ThreadPoolExecutor/__class__.__module__
# Extra52 covers the remaining objects in the cfmod52 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra52.class_module_eq:
  description: "concurrent.futures class __class__.__module__ string equality in cfmod52 namespace — ProcessPoolExecutor/Future/Executor not covered by prior extra45; all have metaclass 'type' from builtins"
  kind: python_call_eq
  category: class_names
  id_prefix: cfmod52clsmodule

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessPoolExecutor, ProcessPoolExecutor.__class__.__module__.__eq__, ["builtins"], true, "ProcessPoolExecutor.__class__.__module__ == 'builtins' — metaclass is built-in 'type' from builtins (8 chars); prior extra45 covered ThreadPoolExecutor but not ProcessPoolExecutor"]
    - [Future,              Future.__class__.__module__.__eq__,              ["builtins"], true, "Future.__class__.__module__ == 'builtins' — defined in _base.py with metaclass 'type' from builtins; prior extra45 did not cover Future"]
    - [Executor,            Executor.__class__.__module__.__eq__,            ["builtins"], true, "Executor.__class__.__module__ == 'builtins' — abstract base class with metaclass 'type' from builtins; novel check not in prior specs"]

# ---------------------------------------------------------------------------
# concurrent.futures function __class__.__module__ — extra52
#
# as_completed is a module-level generator function whose __class__ is the
# built-in 'function' type. Prior extra45 covered wait.__class__.__module__
# but not as_completed. Extra52 fills this gap.
#   as_completed.__class__.__module__ == 'builtins'  (8 chars)
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra52.as_completed_class_module_eq:
  description: "concurrent.futures.as_completed.__class__.__module__ == 'builtins' — as_completed is a module-level function; its __class__ is the built-in 'function' type from builtins; prior extra45 covered wait but not as_completed"
  category: module_identity
  kind: python_call_eq
  function: as_completed.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures class __init__.__class__.__name__ string equality — extra52
#
# Python class __init__ methods defined in pure Python source are plain
# function objects. The built-in 'function' type has __name__ == 'function'.
# ThreadPoolExecutor, ProcessPoolExecutor, and Future all have Python-defined
# __init__ methods.
#
# NOTE: Executor.__init__ is a wrapper_descriptor (C slot inherited from
# object), not a plain function, so Executor is excluded from this table.
#
# No prior concurrent.futures spec has captured any __init__.__class__ attribute.
# ---------------------------------------------------------------------------

table concurrent_futures_extra52.init_class_name_eq:
  description: "concurrent.futures class __init__.__class__.__name__ string equality in cfmod52 namespace — Python-defined __init__ methods are 'function' type; Executor excluded (its __init__ is a wrapper_descriptor from object)"
  kind: python_call_eq
  category: class_names
  id_prefix: cfmod52initclsname

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__init__.__class__.__name__.__eq__,  ["function"], true, "ThreadPoolExecutor.__init__.__class__.__name__ == 'function' — defined in Lib/concurrent/futures/thread.py; plain Python function; first __init__.__class__.__name__ check in any concurrent.futures spec"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__init__.__class__.__name__.__eq__, ["function"], true, "ProcessPoolExecutor.__init__.__class__.__name__ == 'function' — defined in Lib/concurrent/futures/process.py; plain Python function; novel __init__.__class__.__name__ check"]
    - [Future,              Future.__init__.__class__.__name__.__eq__,              ["function"], true, "Future.__init__.__class__.__name__ == 'function' — defined in Lib/concurrent/futures/_base.py; plain Python function; novel __init__.__class__.__name__ check for Future"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra52
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra52.ProcessPoolExecutor_class_module_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__class__.__module__ == 'builtins' — metaclass is built-in 'type' from builtins (8 chars); prior extra45 covered ThreadPoolExecutor but not ProcessPoolExecutor"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra52.Future_class_module_eq:
  description: "concurrent.futures.Future.__class__.__module__ == 'builtins' — defined in _base.py with metaclass 'type' from builtins; prior extra45 covered ThreadPoolExecutor but not Future"
  category: class_names
  kind: python_call_eq
  function: Future.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra52.Executor_class_module_eq:
  description: "concurrent.futures.Executor.__class__.__module__ == 'builtins' — abstract base class with metaclass 'type' from builtins; novel __class__.__module__ check for Executor"
  category: class_names
  kind: python_call_eq
  function: Executor.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra52.ThreadPoolExecutor_init_class_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__ == 'function' — ThreadPoolExecutor.__init__ is a plain Python function; the 'function' type has __name__ == 'function'; first __init__.__class__.__name__ check in any concurrent.futures spec"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra52.ProcessPoolExecutor_init_class_name_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__ == 'function' — ProcessPoolExecutor.__init__ is a plain Python function; the 'function' type has __name__ == 'function'; novel __init__.__class__.__name__ check"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra52.Future_init_class_name_eq:
  description: "concurrent.futures.Future.__init__.__class__.__name__ == 'function' — Future.__init__ is a plain Python function defined in _base.py; the 'function' type has __name__ == 'function'; novel __init__.__class__.__name__ check for Future"
  category: class_names
  kind: python_call_eq
  function: Future.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true
