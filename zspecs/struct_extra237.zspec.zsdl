spec: struct_extra237
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
  - "RFC 1700 — Assigned Numbers (network byte order = big-endian)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "RFC 1700 — Assigned Numbers (defines network byte order as big-endian)"
    - "Test vectors verified by running Python 3.14.3 struct on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — covers pack/unpack integer formats (B/b/H/h/I/i/Q/q) and half-float ('!e') via !hex tag; calcsize for H/I/Q/HI/HIQ/q/h/b/bool/half-float; struct_roundtrip kind for int64/uint64/uint16/uint32/mixed_BHI."
    - "struct_extra24.zspec.zsdl — covers pack/unpack/calcsize __module__.__len__ and __qualname__ equality."
  notes:
    - "This spec covers struct.pack and struct.unpack with IEEE 754 single-precision ('!f') and double-precision ('!d') float formats."
    - "struct.zspec.zsdl covers the half-float ('!e') format; this spec covers '!f' (float32) and '!d' (float64) — the other two floating-point formats."
    - "struct.pack('!f', 1.0) == b'\\x3f\\x80\\x00\\x00' — IEEE 754 single-precision 1.0: sign=0, exponent=127 (0x7f), mantissa=0. Hex: 3f800000. Verified Python 3.14.3."
    - "struct.pack('!d', 1.0) == b'\\x3f\\xf0\\x00\\x00\\x00\\x00\\x00\\x00' — IEEE 754 double-precision 1.0: sign=0, exponent=1023 (0x3ff), mantissa=0. Hex: 3ff0000000000000. Verified Python 3.14.3."
    - "struct.pack('!f', 0.0) == b'\\x00\\x00\\x00\\x00' — IEEE 754 positive zero is all-zero bits. Hex: 00000000. Verified Python 3.14.3."
    - "struct.pack('!d', 0.0) == b'\\x00\\x00\\x00\\x00\\x00\\x00\\x00\\x00' — IEEE 754 double-precision positive zero is all-zero bits. Hex: 0000000000000000. Verified Python 3.14.3."
    - "struct.pack('!f', -1.0) == b'\\xbf\\x80\\x00\\x00' — IEEE 754 single-precision -1.0: sign=1, exponent=127, mantissa=0. Hex: bf800000. Verified Python 3.14.3."
    - "struct.pack('!f', 2.0) == b'\\x40\\x00\\x00\\x00' — IEEE 754 single-precision 2.0: sign=0, exponent=128, mantissa=0. Hex: 40000000. Verified Python 3.14.3."
    - "struct.unpack('!f', b'\\x3f\\x80\\x00\\x00') == (1.0,) — inverse of pack for single-precision 1.0. Verified Python 3.14.3."
    - "struct.unpack('!d', b'\\x3f\\xf0\\x00\\x00\\x00\\x00\\x00\\x00') == (1.0,) — inverse of pack for double-precision 1.0. Verified Python 3.14.3."
    - "struct.calcsize('!f') == 4 — single-precision float is 4 bytes. struct.calcsize('!d') == 8 — double-precision float is 8 bytes."
    - "unpack result type is tuple; unpack('!f',...)[0].__class__.__name__ == 'float' — the unpacked value is a Python float."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct raises struct.error for wrong buffer size or invalid format strings. Float pack/unpack with valid '!f'/'!d' format and matching buffer size never raises."
  stderr: "null"
  stickiness: "N/A — struct functions are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# struct.pack with float formats — IEEE 754 known vectors
# Format '!f' = network-byte-order single-precision float (4 bytes).
# Format '!d' = network-byte-order double-precision float (8 bytes).
# struct.zspec.zsdl covers half-float ('!e'); this covers '!f' and '!d'.
# ---------------------------------------------------------------------------

table struct237f.pack_float_vectors:
  description: "struct.pack IEEE 754 float/double known vectors — '!f' single-precision and '!d' double-precision in network byte order"
  kind: python_call_eq
  category: pack_vector
  id_prefix: struct237f
  function: pack

  columns: [id, args, expected]
  rows:
    - [float_one,       ["!f", 1.0],  !hex 3f800000        ]
    - [float_zero,      ["!f", 0.0],  !hex 00000000        ]
    - [float_neg_one,   ["!f", -1.0], !hex bf800000        ]
    - [float_two,       ["!f", 2.0],  !hex 40000000        ]
    - [double_one,      ["!d", 1.0],  !hex 3ff0000000000000]
    - [double_zero,     ["!d", 0.0],  !hex 0000000000000000]

# ---------------------------------------------------------------------------
# struct.unpack with float formats — inverse vectors
# struct.unpack returns a tuple; the first element is the float value.
# ---------------------------------------------------------------------------

table struct237f.unpack_float_vectors:
  description: "struct.unpack IEEE 754 float/double inverse vectors — unpack is the left-inverse of pack for '!f' and '!d'"
  kind: python_call_eq
  category: unpack_vector
  id_prefix: struct237f
  function: unpack

  columns: [id, args, expected]
  rows:
    - [float_one,   ["!f", !hex 3f800000],         [1.0]]
    - [float_zero,  ["!f", !hex 00000000],          [0.0]]
    - [double_one,  ["!d", !hex 3ff0000000000000],  [1.0]]
    - [double_zero, ["!d", !hex 0000000000000000],  [0.0]]

# ---------------------------------------------------------------------------
# struct.calcsize for float formats
# '!f' is 4 bytes (32-bit single-precision); '!d' is 8 bytes (64-bit double).
# ---------------------------------------------------------------------------

table struct237f.calcsize_float:
  description: "struct.calcsize for '!f' and '!d' — single-precision=4 bytes, double-precision=8 bytes"
  kind: python_call_eq
  category: calcsize
  id_prefix: struct237f
  function: calcsize

  columns: [id, args, expected]
  rows:
    - [single_float,  ["!f"], 4]
    - [double_float,  ["!d"], 8]

# ---------------------------------------------------------------------------
# unpack result type checks — the unpacked float value is a Python float
# struct.unpack('!f',...) returns a tuple whose first element is a Python float.
# ---------------------------------------------------------------------------

invariant struct237f.unpack_float_result_type:
  description: "struct.unpack('!f', b'\\x3f\\x80\\x00\\x00')[0].__class__.__name__ == 'float' — unpacked single-precision value is a Python float"
  category: result_type
  kind: python_call_eq
  function: unpack
  args: ["!f", !hex 3f800000]
  method: __getitem__.__func__
  method_args: []
  expected: "float"

invariant struct237f.unpack_float_tuple_class:
  description: "struct.unpack('!f', b'\\x3f\\x80\\x00\\x00').__class__.__name__ == 'tuple' — unpack always returns a tuple"
  category: result_type
  kind: python_call_eq
  function: unpack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack result type — pack always returns bytes
# ---------------------------------------------------------------------------

invariant struct237f.pack_result_class:
  description: "struct.pack('!f', 1.0).__class__.__name__ == 'bytes' — pack always returns a bytes object"
  category: result_type
  kind: python_call_eq
  function: pack
  args: ["!f", 1.0]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack result length — pack('!f',...) is always 4 bytes
# ---------------------------------------------------------------------------

invariant struct237f.pack_float_len:
  description: "len(struct.pack('!f', 1.0)) == 4 — single-precision float pack always produces 4 bytes"
  category: result_length
  kind: python_call_eq
  function: pack
  args: ["!f", 1.0]
  method: __len__
  method_args: []
  expected: 4

invariant struct237f.pack_double_len:
  description: "len(struct.pack('!d', 1.0)) == 8 — double-precision float pack always produces 8 bytes"
  category: result_length
  kind: python_call_eq
  function: pack
  args: ["!d", 1.0]
  method: __len__
  method_args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.unpack wrong-size buffer raises struct.error
# '!f' requires exactly 4 bytes; providing fewer raises struct.error.
# ---------------------------------------------------------------------------

invariant struct237f.unpack_short_buffer_raises:
  description: "struct.unpack('!f', b'\\x3f') raises struct.error — '!f' requires exactly 4 bytes but only 1 provided"
  category: error
  kind: python_call_raises
  function: unpack
  args: ["!f", !hex 3f]
  raises: struct.error
