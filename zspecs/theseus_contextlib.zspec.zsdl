spec: theseus_contextlib
version: ">=3.9"
backend: python_cleanroom(theseus_contextlib)
blocks: contextlib

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html"
  notes:
    - "Clean-room contextlib utilities. Do NOT import contextlib."
    - "contextmanager decorator: turns a generator into a context manager."
    - "suppress(*exceptions): context manager that silently ignores specified exceptions."
    - "closing(thing): context manager that calls thing.close() on exit."
    - "contextlib_suppress(): using suppress(ZeroDivisionError) does not raise."
    - "contextlib_contextmanager(): custom context manager via @contextmanager works."
    - "contextlib_nullcontext(): nullcontext() passes through its enter value."
    - "Export: contextmanager, suppress, closing, nullcontext."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_contextlib.suppress:
  description: "suppress(ZeroDivisionError) silently ignores division by zero"
  category: suppress
  kind: python_call_eq
  function: contextlib_suppress
  args: []
  expected: true

invariant theseus_contextlib.contextmanager:
  description: "@contextmanager decorator works"
  category: contextmanager
  kind: python_call_eq
  function: contextlib_contextmanager
  args: []
  expected: "entered"

invariant theseus_contextlib.nullcontext:
  description: "nullcontext() passes enter value through"
  category: nullcontext
  kind: python_call_eq
  function: contextlib_nullcontext
  args: []
  expected: 42
