spec: secrets_extra3
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
  notes:
    - "This spec extends secrets.zspec.zsdl, secrets_extra.zspec.zsdl, and secrets_extra2.zspec.zsdl."
    - "secrets.zspec.zsdl covers: token_bytes/token_hex/token_urlsafe lengths; choice single-element; randbelow(1)==0; SystemRandom.__name__."
    - "secrets_extra.zspec.zsdl covers: token_bytes/__name__, token_hex/__name__, token_urlsafe/__name__, choice/__name__, randbelow/__name__, randbits/__name__, token_bytes/__module__, SystemRandom/__name__; return-type class checks."
    - "secrets_extra2.zspec.zsdl covers: token_bytes/__name__/__module__, token_hex/__name__/__module__, token_urlsafe/__name__/__module__, SystemRandom/__name__/__module__/__bases__, token_bytes len32, token_hex len 2*n; return-type checks (table + invariants)."
    - "This spec adds: token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__ — multi-module coverage not yet complete in prior specs."
    - "Also adds: DEFAULT_ENTROPY.__class__.__name__ == 'int' and DEFAULT_ENTROPY >= 16."
    - "secrets.token_hex.__module__ == 'secrets' — confirmed: token_hex is defined in secrets."
    - "secrets.token_urlsafe.__module__ == 'secrets' — confirmed: token_urlsafe is defined in secrets."
    - "secrets.choice.__module__ == 'random' — choice is a bound method on a SystemRandom instance; its __module__ is 'random'."
    - "secrets.randbelow.__module__ == 'random' — randbelow is a bound method; its __module__ is 'random'."
    - "secrets.randbits.__module__ == 'random' — randbits is a bound method; its __module__ is 'random'."
    - "secrets.SystemRandom.__module__ == 'random' — already in secrets_extra2; repeated for completeness."
    - "secrets.DEFAULT_ENTROPY == 32 on CPython 3.9+; PEP 506 specifies a minimum of 32 bytes (256 bits)."
    - "secrets.DEFAULT_ENTROPY >= 16 — the spec requires at least 16 bytes of entropy (128 bits minimum)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — token_bytes, token_hex, token_urlsafe
#
# secrets_extra.zspec.zsdl covers token_bytes.__module__ == 'secrets'.
# secrets_extra2.zspec.zsdl covers token_bytes, token_hex, token_urlsafe __module__.
# Here we confirm these in the secrets_extra3 namespace for consistency.
# ---------------------------------------------------------------------------

invariant secrets_extra3.token_bytes.module:
  description: "secrets.token_bytes.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_bytes.__module__.__eq__
  args: ["secrets"]
  expected: true

invariant secrets_extra3.token_hex.module:
  description: "secrets.token_hex.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_hex.__module__.__eq__
  args: ["secrets"]
  expected: true

invariant secrets_extra3.token_urlsafe.module:
  description: "secrets.token_urlsafe.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_urlsafe.__module__.__eq__
  args: ["secrets"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ checks — choice, randbelow, randbits
#
# These are bound methods on the module-level SystemRandom instance.
# Their __module__ reflects 'random', not 'secrets'.
# This is NEW coverage — not in any prior secrets_extra* spec.
# ---------------------------------------------------------------------------

invariant secrets_extra3.choice.module:
  description: "secrets.choice.__module__ == 'random' — choice is a bound method on SystemRandom"
  category: modules
  kind: python_call_eq
  function: choice.__module__.__eq__
  args: ["random"]
  expected: true

invariant secrets_extra3.randbelow.module:
  description: "secrets.randbelow.__module__ == 'random' — randbelow is a bound method on SystemRandom"
  category: modules
  kind: python_call_eq
  function: randbelow.__module__.__eq__
  args: ["random"]
  expected: true

invariant secrets_extra3.randbits.module:
  description: "secrets.randbits.__module__ == 'random' — randbits is a bound method on SystemRandom"
  category: modules
  kind: python_call_eq
  function: randbits.__module__.__eq__
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks — standalone invariants
#
# secrets_extra.zspec.zsdl covers these as standalone invariants.
# secrets_extra2.zspec.zsdl covers token_bytes/token_hex/token_urlsafe/choice/randbits in a table.
# Here we add standalone invariants for the secrets_extra3 namespace.
# ---------------------------------------------------------------------------

invariant secrets_extra3.token_bytes.name:
  description: "secrets.token_bytes.__name__ == 'token_bytes'"
  category: functions
  kind: python_call_eq
  function: token_bytes.__name__.__eq__
  args: ["token_bytes"]
  expected: true

invariant secrets_extra3.token_hex.name:
  description: "secrets.token_hex.__name__ == 'token_hex'"
  category: functions
  kind: python_call_eq
  function: token_hex.__name__.__eq__
  args: ["token_hex"]
  expected: true

invariant secrets_extra3.token_urlsafe.name:
  description: "secrets.token_urlsafe.__name__ == 'token_urlsafe'"
  category: functions
  kind: python_call_eq
  function: token_urlsafe.__name__.__eq__
  args: ["token_urlsafe"]
  expected: true

invariant secrets_extra3.choice.name:
  description: "secrets.choice.__name__ == 'choice'"
  category: functions
  kind: python_call_eq
  function: choice.__name__.__eq__
  args: ["choice"]
  expected: true

invariant secrets_extra3.randbelow.name:
  description: "secrets.randbelow.__name__ == 'randbelow'"
  category: functions
  kind: python_call_eq
  function: randbelow.__name__.__eq__
  args: ["randbelow"]
  expected: true

invariant secrets_extra3.randbits.name:
  description: "secrets.randbits.__name__ == 'randbits'"
  category: functions
  kind: python_call_eq
  function: randbits.__name__.__eq__
  args: ["randbits"]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom — __module__ (already in secrets_extra2; included here for
# namespace completeness and cross-reference)
# ---------------------------------------------------------------------------

invariant secrets_extra3.SystemRandom.module:
  description: "secrets.SystemRandom.__module__ == 'random' — SystemRandom is defined in the random module"
  category: classes
  kind: python_call_eq
  function: SystemRandom.__module__.__eq__
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_ENTROPY — type and minimum value
#
# secrets.DEFAULT_ENTROPY is a module-level int constant specifying the
# default number of bytes for token generation. PEP 506 sets it to 32.
# This is NEW coverage — not in any prior secrets* spec.
# ---------------------------------------------------------------------------

invariant secrets_extra3.DEFAULT_ENTROPY.class_is_int:
  description: "secrets.DEFAULT_ENTROPY.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant secrets_extra3.DEFAULT_ENTROPY.ge_16:
  description: "secrets.DEFAULT_ENTROPY >= 16 — minimum of 16 bytes (128 bits) of entropy"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__ge__
  args: [16]
  expected: true
