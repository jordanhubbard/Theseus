spec: functools_extra2581
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2581 (_extra2581): __call__ dict-presence checks — callable functor classification."
    - "functools.partial is a C extension type that defines __call__ in its own __dict__, making it a true callable functor (not just callable via type.__call__)."
    - "functools._lru_cache_wrapper is a C extension type wrapping a decorated function; it defines __call__ directly so calls bypass the descriptor protocol overhead."
    - "functools._singledispatchmethod_get is a pure-Python descriptor; it defines __call__ to dispatch on the first argument type when invoked as a bound method."
    - "functools.itemgetter is actually operator.itemgetter (re-exported); it defines __call__ in its own __dict__."
    - "functools.GenericAlias is actually types.GenericAlias (re-exported); it defines __call__ in its own __dict__."
    - "functools.MethodType is actually types.MethodType (re-exported); it defines __call__ in its own __dict__."
    - "functools.partialmethod is a pure-Python descriptor, not a callable functor — no __call__ in its own __dict__."
    - "functools.cached_property is a pure-Python descriptor (getter-only), not a callable — no __call__ in its own __dict__."
    - "functools.lru_cache is a Python function (decorator factory), not a type with __call__ in __dict__."
    - "functools.singledispatchmethod is a pure-Python descriptor class — no __call__ in its own __dict__."
    - "functools.MappingProxyType is types.MappingProxyType (re-exported); no __call__ in its __dict__."
    - "functools._CacheInfo is a namedtuple subclass; no __call__ in its __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — callable functors in functools
#
# The types below define __call__ directly in their own __dict__, making
# them true callable functors whose call dispatch does not fall through to
# the inherited type.__call__ slot.  functools.partial is the canonical
# example: it stores the wrapped callable and frozen arguments and
# implements __call__ in C.
# ---------------------------------------------------------------------------

table functools_extra2581.call_present:
  description: "functools types that define __call__ in their own __dict__ — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2581

  columns: [id, function, args, expected]
  rows:
    - ["ft2581001", "functools.partial.__dict__.__contains__", ["__call__"], true]
    - ["ft2581002", "functools._lru_cache_wrapper.__dict__.__contains__", ["__call__"], true]
    - ["ft2581003", "functools._singledispatchmethod_get.__dict__.__contains__", ["__call__"], true]
    - ["ft2581004", "functools.itemgetter.__dict__.__contains__", ["__call__"], true]
    - ["ft2581005", "functools.GenericAlias.__dict__.__contains__", ["__call__"], true]
    - ["ft2581006", "functools.MethodType.__dict__.__contains__", ["__call__"], true]

# ---------------------------------------------------------------------------
# Table 2: __call__ dict-presence — descriptors and non-functors in functools
#
# These functools types are callable via Python's normal call machinery
# (type.__call__ inherited from their metaclass) but do NOT define __call__
# in their own __dict__.  They are not callable functors in the strict sense.
# ---------------------------------------------------------------------------

table functools_extra2581.call_absent:
  description: "functools types that do NOT define __call__ in their own __dict__ — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2581

  columns: [id, function, args, expected]
  rows:
    - ["ft2581007", "functools.partialmethod.__dict__.__contains__", ["__call__"], false]
    - ["ft2581008", "functools.cached_property.__dict__.__contains__", ["__call__"], false]
    - ["ft2581009", "functools.lru_cache.__dict__.__contains__", ["__call__"], false]
    - ["ft2581010", "functools.singledispatchmethod.__dict__.__contains__", ["__call__"], false]
    - ["ft2581011", "functools.MappingProxyType.__dict__.__contains__", ["__call__"], false]
    - ["ft2581012", "functools._CacheInfo.__dict__.__contains__", ["__call__"], false]
    - ["ft2581013", "functools._PlaceholderType.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 3: functools.partial __call__ contrast with sibling attributes
#
# functools.partial defines __call__ alongside __new__, __repr__,
# __getattribute__, __setattr__, __delattr__, and __get__.  This table
# cross-checks __call__ presence against the two mutation-blocking
# dunder methods that partial also defines, confirming the full functor
# profile: callable (__call__) + mutation-resistant (__setattr__, __delattr__).
# ---------------------------------------------------------------------------

table functools_extra2581.partial_functor_profile:
  description: "functools.partial functor profile: __call__ alongside __setattr__ and __delattr__ — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2581

  columns: [id, function, args, expected]
  rows:
    - ["ft2581014", "functools.partial.__dict__.__contains__", ["__call__"], true]
    - ["ft2581015", "functools.partial.__dict__.__contains__", ["__setattr__"], true]
    - ["ft2581016", "functools.partial.__dict__.__contains__", ["__delattr__"], true]
    - ["ft2581017", "functools.partialmethod.__dict__.__contains__", ["__call__"], false]
    - ["ft2581018", "functools.partialmethod.__dict__.__contains__", ["__setattr__"], false]
    - ["ft2581019", "functools.partialmethod.__dict__.__contains__", ["__delattr__"], false]
    - ["ft2581020", "functools._lru_cache_wrapper.__dict__.__contains__", ["__call__"], true]
