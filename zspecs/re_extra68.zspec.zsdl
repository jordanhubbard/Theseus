spec: re_extra68
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_consts, co_nlocals, co_stacksize documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra67.zspec.zsdl — covers re.search/compile/match __code__.co_varnames.__class__.__name__.__eq__('tuple'); co_varnames[0].__eq__('pattern'); co_filename.__contains__('.py'); co_flags.__class__.__name__.__eq__('int')."
    - "re_extra66.zspec.zsdl — covers re.search/__code__.co_name.__eq__('search'); compile/__code__.co_name.__eq__('compile'); match/__code__.co_name.__eq__('match'); sub/__code__.co_name.__eq__('sub'); search/__code__.co_argcount.__eq__(3); compile/__code__.co_argcount.__eq__(2)."
  notes:
    - "This spec extends re_extra67.zspec.zsdl."
    - "Theme: co_consts/co_nlocals/co_stacksize class name checks for re.search/compile/match, plus re.error exception hierarchy."
    - "re module is pure Python (Lib/re/__init__.py). re.search, re.compile, re.match are Python functions with __code__ objects."
    - "Prior specs covered: co_name/co_argcount (extra66), co_varnames/co_filename/co_flags (extra67)."
    - "This spec covers (recode4_68 namespace): co_consts/__class__.__name__=='tuple', co_nlocals/__class__.__name__=='int', co_stacksize/__class__.__name__=='int' for search/compile/match; plus re.error hierarchy."
    - "re.search.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple in CPython code objects. No prior re spec checks co_consts.__class__.__name__ for any re function. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals counts the number of local variables. Its type is always int. No prior re spec checks co_nlocals.__class__.__name__ for any re function. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required VM stack space. Its type is always int. No prior re spec checks co_stacksize.__class__.__name__ for any re function. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__bases__[0].__name__ == 'Exception' — re.error is a Python exception class that subclasses Exception directly. No prior re spec checks re.error.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__mro__.__len__() == 4 — the MRO for re.error is [error, Exception, BaseException, object] with 4 entries. No prior re spec checks re.error.__mro__.__len__(). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__module__ == 're' — re.error is defined in the re module (Lib/re/__init__.py). No prior re spec checks re.error.__module__ in recode4_68 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__qualname__ == 'error' — re.error is a top-level class in the re module so its __qualname__ equals its simple name. No prior re spec checks re.error.__qualname__ in recode4_68 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match __code__.co_consts class name
#
# co_consts (PyCodeObject.co_consts) is a tuple of constants used by the
# bytecode (literals, None, docstrings, nested code objects, etc.). In CPython
# this attribute is always stored as a Python tuple.
#
#   re.search.__code__.co_consts.__class__.__name__  == 'tuple'
#   re.compile.__code__.co_consts.__class__.__name__ == 'tuple'
#   re.match.__code__.co_consts.__class__.__name__   == 'tuple'
#
# No prior re spec checks co_consts.__class__.__name__ for any re function
# in the recode4_68 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra68.co_consts_class_name:
  description: "re.search/compile/match __code__.co_consts.__class__.__name__.__eq__('tuple') — co_consts is always a tuple in CPython code objects; re is pure Python; no prior re spec checks co_consts.__class__.__name__ for any re function in recode4_68 namespace; novel co_consts class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coconsts
  id_prefix: recode4_68consts

  columns: [id, function, args, expected]
  rows:
    - [search_co_consts_class,  search.__code__.co_consts.__class__.__name__.__eq__,  ["tuple"], true]
    - [compile_co_consts_class, compile.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true]
    - [match_co_consts_class,   match.__code__.co_consts.__class__.__name__.__eq__,   ["tuple"], true]

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match __code__.co_nlocals class name
#
# co_nlocals counts the number of local variables (including arguments) used
# by the function. Its type is always int in CPython.
#
#   re.search.__code__.co_nlocals.__class__.__name__  == 'int'
#   re.compile.__code__.co_nlocals.__class__.__name__ == 'int'
#   re.match.__code__.co_nlocals.__class__.__name__   == 'int'
#
# No prior re spec checks co_nlocals.__class__.__name__ for any re function
# in the recode4_68 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra68.co_nlocals_class_name:
  description: "re.search/compile/match __code__.co_nlocals.__class__.__name__.__eq__('int') — co_nlocals is an integer count of local variables in CPython code objects; re is pure Python; no prior re spec checks co_nlocals.__class__.__name__ for any re function in recode4_68 namespace; novel co_nlocals class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_conlocals
  id_prefix: recode4_68nlocals

  columns: [id, function, args, expected]
  rows:
    - [search_co_nlocals_class,  search.__code__.co_nlocals.__class__.__name__.__eq__,  ["int"], true]
    - [compile_co_nlocals_class, compile.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true]
    - [match_co_nlocals_class,   match.__code__.co_nlocals.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match __code__.co_stacksize class name
#
# co_stacksize is the required virtual machine stack space for the code object.
# Its type is always int in CPython.
#
#   re.search.__code__.co_stacksize.__class__.__name__  == 'int'
#   re.compile.__code__.co_stacksize.__class__.__name__ == 'int'
#   re.match.__code__.co_stacksize.__class__.__name__   == 'int'
#
# No prior re spec checks co_stacksize.__class__.__name__ for any re function
# in the recode4_68 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra68.co_stacksize_class_name:
  description: "re.search/compile/match __code__.co_stacksize.__class__.__name__.__eq__('int') — co_stacksize is an integer encoding required VM stack space in CPython code objects; re is pure Python; no prior re spec checks co_stacksize.__class__.__name__ for any re function in recode4_68 namespace; novel co_stacksize class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_costacksize
  id_prefix: recode4_68stack

  columns: [id, function, args, expected]
  rows:
    - [search_co_stacksize_class,  search.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true]
    - [compile_co_stacksize_class, compile.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true]
    - [match_co_stacksize_class,   match.__code__.co_stacksize.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# re.error exception class hierarchy and identity
#
# re.error is a Python exception class defined in Lib/re/__init__.py.
# It subclasses Exception directly. Its MRO is:
#   [error, Exception, BaseException, object] — length 4
#
# re.error.__module__ == 're' (defined in the re module)
# re.error.__qualname__ == 'error' (top-level class, simple name)
#
# No prior re spec checks error.__bases__[0].__name__, error.__mro__.__len__(),
# error.__module__, or error.__qualname__ in the recode4_68 namespace.
# Table function values containing '[' must be double-quoted per ZSDL rules.
# Novel hierarchy and identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra68.re_error_hierarchy:
  description: "re.error.__bases__[0].__name__=='Exception', __mro__.__len__()==4, __module__=='re', __qualname__=='error' — re.error subclasses Exception; MRO is [error, Exception, BaseException, object] with 4 entries; module is 're'; qualname is 'error' (top-level class); no prior re spec checks these hierarchy/identity attributes for error in recode4_68 namespace; function value with '[' is double-quoted; novel anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: recode4_68error

  columns: [id, function, args, expected]
  rows:
    - [error_bases_exception,  "error.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [error_mro_len_4,        error.__mro__.__len__,                [],             4]
    - [error_module_re,        error.__module__.__eq__,              ["re"],         true]
    - [error_qualname_error,   error.__qualname__.__eq__,            ["error"],      true]

invariant re_extra68.search_co_consts_tuple:
  description: "re.search.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple in CPython code objects; re.search is a pure Python function; no prior re spec checks co_consts.__class__.__name__ for search in recode4_68 namespace; novel co_consts class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coconsts
  kind: python_call_eq
  function: search.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra68.search_co_nlocals_int:
  description: "re.search.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is an integer count of local variables; re.search is a pure Python function; no prior re spec checks co_nlocals.__class__.__name__ for search in recode4_68 namespace; novel co_nlocals class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_conlocals
  kind: python_call_eq
  function: search.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra68.search_co_stacksize_int:
  description: "re.search.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is an integer encoding required VM stack space; re.search is a pure Python function; no prior re spec checks co_stacksize.__class__.__name__ for search in recode4_68 namespace; novel co_stacksize class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_costacksize
  kind: python_call_eq
  function: search.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra68.re_error_exception_base:
  description: "re.error.__bases__[0].__name__.__eq__('Exception') == True — re.error subclasses Exception directly; __bases__[0] is Exception; Exception.__name__ is 'Exception'; no prior re spec checks re.error.__bases__[0].__name__ in recode4_68 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra68.re_error_mro_4:
  description: "re.error.__mro__.__len__() == 4 — the MRO for re.error is [error, Exception, BaseException, object] with 4 entries; no prior re spec checks re.error.__mro__.__len__() in recode4_68 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4
