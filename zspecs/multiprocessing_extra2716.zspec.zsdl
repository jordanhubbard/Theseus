spec: multiprocessing_extra2716
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 628 (_extra2716): __neg__, __pos__, __abs__ dict-presence checks (unary arithmetic operators)."
    - "multiprocessing.Process, multiprocessing.pool.Pool, and multiprocessing.pool.AsyncResult are process/IPC primitives, not numeric types."
    - "None of these types define unary minus, unary plus, or absolute value protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __neg__ dict-presence checks
#
# Wave 628 theme: multiprocessing process and pool types do not implement
# the unary minus operator. __neg__ does not appear in any of these
# classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2716.neg_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __neg__ dict-presence checks — none define unary minus in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2716

  columns: [id, function, args, expected]
  rows:
    - ["mp2716001", "multiprocessing.Process.__dict__.__contains__",          ["__neg__"], false]
    - ["mp2716002", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__neg__"], false]
    - ["mp2716003", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: __pos__ dict-presence checks
#
# Wave 628 theme: multiprocessing process and pool types do not implement
# the unary plus operator. __pos__ does not appear in any of these
# classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2716.pos_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __pos__ dict-presence checks — none define unary plus in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2716

  columns: [id, function, args, expected]
  rows:
    - ["mp2716004", "multiprocessing.Process.__dict__.__contains__",          ["__pos__"], false]
    - ["mp2716005", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__pos__"], false]
    - ["mp2716006", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__pos__"], false]

# ---------------------------------------------------------------------------
# Table 3: __abs__ dict-presence checks
#
# Wave 628 theme: multiprocessing process and pool types do not implement
# the absolute value operator. __abs__ does not appear in any of these
# classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2716.abs_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __abs__ dict-presence checks — none define absolute value in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2716

  columns: [id, function, args, expected]
  rows:
    - ["mp2716007", "multiprocessing.Process.__dict__.__contains__",          ["__abs__"], false]
    - ["mp2716008", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__abs__"], false]
    - ["mp2716009", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__abs__"], false]

# ---------------------------------------------------------------------------
# Table 4: synchronize types __neg__/__pos__/__abs__ checks
#
# Wave 628 theme: multiprocessing.synchronize Lock, RLock, Semaphore, and
# Event are IPC synchronization primitives. None define any unary arithmetic
# operator protocol in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2716.synchronize_unary:
  description: "multiprocessing.synchronize types __neg__/__pos__/__abs__ dict-presence checks — IPC sync primitives define none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2716

  columns: [id, function, args, expected]
  rows:
    - ["mp2716010", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__neg__"], false]
    - ["mp2716011", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__pos__"], false]
    - ["mp2716012", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__abs__"], false]
    - ["mp2716013", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__neg__"], false]
    - ["mp2716014", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__pos__"], false]
    - ["mp2716015", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__abs__"], false]
    - ["mp2716016", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__neg__"], false]
    - ["mp2716017", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__pos__"], false]
    - ["mp2716018", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__abs__"], false]
    - ["mp2716019", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__neg__"], false]
    - ["mp2716020", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__pos__"], false]
    - ["mp2716021", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__abs__"], false]
