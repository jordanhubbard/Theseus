spec: is_lower_case
version: ">=2.0.2"
backend: node(is-lower-case)

docs: https://www.npmjs.com/package/is-lower-case

provenance:
  derived_from:
    - "is-lower-case README — https://www.npmjs.com/package/is-lower-case"
    - "Test vectors verified with is-lower-case via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-lower-case source"
  notes:
    - "is-lower-case is an npm package. Install: npm install is-lower-case"
    - "Returns true if the string is entirely lowercase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_lower_case.check:
  kind: node_module_call_eq
  function: isLowerCase
  category: string
  id_prefix: islc

  columns: [id, args, expected]
  rows:
    - [lower,  ["hello"],  true]
    - [mixed,  ["Hello"],  false]
    - [upper,  ["HELLO"],  false]

