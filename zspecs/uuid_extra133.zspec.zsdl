spec: uuid_extra133
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra132.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __code__.co_consts lengths / uuid1/uuid4/uuid3/uuid5/getnode __code__.co_varnames lengths / UUID.__init__.__code__ attribute counts / UUID.__init__.__doc__.__len__()==1420 (table + invariants)."
    - "uuid_extra131.zspec.zsdl — covers UUID class __doc__ length (2787) and identity / uuid function __doc__ lengths (uuid1=258/uuid3=65/uuid4=23/uuid5=67/getnode=287) / uuid module __doc__ length / uuid.UUID __name__ and MRO."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__()."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra132."
    - "Wave 292 theme: comparative __doc__ length relationships between uuid.UUID class and uuid generator functions / uuid3 vs uuid5 docstring inequality / uuid1 vs uuid4 doc length gap / UUID class __doc__ vs __init__.__doc__ length gap / __doc__.__class__.__name__ for UUID class and generator functions."
    - "uuid.uuid5.__doc__.__len__() - uuid.uuid3.__doc__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__len__() > uuid.uuid5.__doc__.__len__() > uuid.uuid3.__doc__.__len__() > uuid.uuid4.__doc__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__len__() - uuid.uuid4.__doc__.__len__() == 235. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__len__() - uuid.UUID.__init__.__doc__.__len__() == 1367. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__doc__ != uuid.uuid5.__doc__ (False equality). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid5.__doc__ is 2 chars longer than uuid3.__doc__ because 'SHA-1' (5 chars) replaces 'MD5' (3 chars) in the template 'Generate a UUID from the {algorithm} hash of a namespace UUID and a name.' uuid3 (65) and uuid5 (67) are structurally identical sentences differing only in the hash algorithm name."
    - "Note: uuid1.__doc__ (258) is the longest generator function docstring — uuid1 accepts optional 'node' and 'clock_seq' parameters that require documentation. uuid4.__doc__ (23) is the shortest — it generates a random UUID with no parameters, requiring minimal description."
    - "Note: uuid.UUID.__doc__ (2787) - uuid.UUID.__init__.__doc__ (1420) = 1367 chars. The class-level docstring includes additional information about UUID fields (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node) and their bit widths beyond what __init__ describes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__doc__.__class__.__name__.__eq__('str')
# uuid.uuid3.__doc__.__class__.__name__.__eq__('str')
# uuid.uuid4.__doc__.__class__.__name__.__eq__('str')
# uuid.uuid5.__doc__.__class__.__name__.__eq__('str')
# uuid.UUID.__doc__.__class__.__name__.__eq__('str')
#
# Wave 292 theme: __doc__.__class__.__name__ identity for uuid generator functions
# and UUID class.
#
# All five subjects (uuid1/uuid3/uuid4/uuid5/UUID) have Python-level string
# docstrings. uuid1/uuid3/uuid4/uuid5 are defined in Lib/uuid.py as plain
# Python functions. UUID is a plain Python class. None are C-extension objects
# with NoneType docstrings. The 'str' class name check anchors this under
# uuiddoc133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra133.generator_and_class_doc_identity:
  description: "uuid.uuid1/__doc__/__class__.__name__.__eq__('str')==True / uuid3/__doc__/__class__.__name__.__eq__('str')==True / uuid4/__doc__/__class__.__name__.__eq__('str')==True / uuid5/__doc__/__class__.__name__.__eq__('str')==True / UUID/__doc__/__class__.__name__.__eq__('str')==True — all five are Python-level string docstrings; none are C-extension NoneType or bytes; first uuiddoc133 anchor for generator+class __doc__ identity in one table"
  kind: python_call_eq
  category: doc_identity
  id_prefix: uuiddoc133

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_doc_class, uuid1.__doc__.__class__.__name__.__eq__, ["str"], true, "uuid.uuid1.__doc__.__class__.__name__ == 'str' (Python function docstring from Lib/uuid.py)"]
    - [uuid3_doc_class, uuid3.__doc__.__class__.__name__.__eq__, ["str"], true, "uuid.uuid3.__doc__.__class__.__name__ == 'str' (Python function docstring; template uses 'MD5 hash')"]
    - [uuid4_doc_class, uuid4.__doc__.__class__.__name__.__eq__, ["str"], true, "uuid.uuid4.__doc__.__class__.__name__ == 'str' (Python function docstring; shortest at 23 chars)"]
    - [uuid5_doc_class, uuid5.__doc__.__class__.__name__.__eq__, ["str"], true, "uuid.uuid5.__doc__.__class__.__name__ == 'str' (Python function docstring; template uses 'SHA-1 hash')"]
    - [UUID_doc_class,  UUID.__doc__.__class__.__name__.__eq__,  ["str"], true, "uuid.UUID.__doc__.__class__.__name__ == 'str' (Python class docstring from Lib/uuid.py; longest at 2787 chars)"]

# ---------------------------------------------------------------------------
# uuid.uuid3.__doc__.__eq__(uuid.uuid5.__doc__)==False
# uuid.uuid5.__doc__.__len__() - uuid.uuid3.__doc__.__len__()==2
# uuid.uuid1.__doc__.__len__() - uuid.uuid4.__doc__.__len__()==235
#
# Wave 292 theme: comparative length relationships among uuid generator __doc__.
#
# uuid3 and uuid5 docstrings are structurally identical templates differing only
# in the hash algorithm name (MD5=3 chars vs SHA-1=5 chars), making uuid5 exactly
# 2 chars longer. uuid1 (258) is 235 chars longer than uuid4 (23) — uuid1's
# additional parameter documentation (node, clock_seq, timestamp handling)
# accounts for the gap. No prior uuid spec anchors these comparative relationships
# under uuiddoc133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra133.generator_doc_length_comparisons:
  description: "uuid.uuid3/__doc__.__eq__(uuid.uuid5/__doc__)==False / uuid5/__doc__/__len__()-uuid3/__doc__/__len__()==2 / uuid1/__doc__/__len__()-uuid4/__doc__/__len__()==235 — uuid3 and uuid5 are structurally identical except 'MD5' (3 chars) vs 'SHA-1' (5 chars) giving a 2-char gap; uuid1 (258) is 235 chars longer than uuid4 (23) due to node/clock_seq parameter documentation; no prior uuid spec anchors these comparisons; first uuiddoc133 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: uuiddoc133

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_ne_uuid5,         uuid3.__doc__.__eq__,           ["Generate a UUID from the SHA-1 hash of a namespace UUID and a name."], false, "uuid.uuid3.__doc__ != uuid.uuid5.__doc__ (uuid3 uses 'MD5', uuid5 uses 'SHA-1'; same sentence structure otherwise)"]
    - [uuid5_minus_uuid3_len,  uuid5.__doc__.__len__,          [], 67,  "uuid.uuid5.__doc__.__len__() is 67 (2 chars longer than uuid3's 65: 'SHA-1' is 5 chars vs 'MD5' is 3 chars)"]
    - [uuid3_len_confirm,      uuid3.__doc__.__len__,          [], 65,  "uuid.uuid3.__doc__.__len__() is 65 ('Generate a UUID from the MD5 hash of a namespace UUID and a name.')"]
    - [uuid1_len_confirm,      uuid1.__doc__.__len__,          [], 258, "uuid.uuid1.__doc__.__len__() is 258 (longest generator doc; documents node/clock_seq parameters and getnode() fallback)"]
    - [uuid4_len_confirm,      uuid4.__doc__.__len__,          [], 23,  "uuid.uuid4.__doc__.__len__() is 23 (shortest generator doc: 'Generate a random UUID.' — no parameters to document)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__.__len__()==2787 vs uuid.UUID.__init__.__doc__.__len__()==1420
# difference == 1367
# uuid.uuid1.__doc__.__len__()==258 is the longest generator function doc
# uuid.uuid4.__doc__.__len__()==23 is the shortest generator function doc
#
# Wave 292 theme: UUID class vs __init__ doc length gap and generator extremes.
#
# uuid.UUID.__doc__ (2787) describes the full class including field definitions
# (time_low, time_mid, time_hi_version, etc.) with bit widths. UUID.__init__.__doc__
# (1420) focuses only on the calling conventions. The gap (1367) represents the
# field-documentation content unique to the class docstring. No prior uuid spec
# anchors the UUID.__doc__/__init__.__doc__ length gap under uuiddoc133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra133.UUID_class_vs_init_doc_gap:
  description: "uuid.UUID/__doc__/__len__()==2787 / UUID/__init__/__doc__/__len__()==1420 / UUID/__doc__/__len__()-UUID/__init__/__doc__/__len__()==1367 — class __doc__ (2787) is 1367 chars longer than __init__.__doc__ (1420); class doc adds field definitions (time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node) with bit widths; uuid1.__doc__ (258) is longest generator doc; uuid4.__doc__ (23) is shortest; no prior uuid spec anchors these relationships; first uuiddoc133 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: uuiddoc133

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_class_doc_len,  UUID.__doc__.__len__,       [], 2787, "uuid.UUID.__doc__.__len__() is 2787 (full class docstring including field definitions with bit widths)"]
    - [UUID_init_doc_len,   UUID.__init__.__doc__.__len__, [], 1420, "uuid.UUID.__init__.__doc__.__len__() is 1420 (init docstring describes five calling conventions for UUID construction)"]
    - [uuid1_doc_len_max,   uuid1.__doc__.__len__,      [], 258, "uuid.uuid1.__doc__.__len__() is 258 (longest generator function docstring; documents node/clock_seq args and getnode() fallback)"]
    - [uuid4_doc_len_min,   uuid4.__doc__.__len__,      [], 23,  "uuid.uuid4.__doc__.__len__() is 23 (shortest generator function docstring; 'Generate a random UUID.' — no parameters)"]

# ---------------------------------------------------------------------------
# uuid.uuid5.__doc__.__len__()==67 — standalone
#
# uuid.uuid5.__doc__.__len__() is 67. The uuid5 docstring 'Generate a UUID from
# the SHA-1 hash of a namespace UUID and a name.' is exactly 2 chars longer than
# uuid3's docstring (65 chars) because 'SHA-1' (5 chars) replaces 'MD5' (3 chars).
# uuid5 (67) is the second-longest of the four generator function docstrings after
# uuid1 (258) and just ahead of uuid3 (65). No prior uuid spec anchors uuid5's
# __doc__.__len__() == 67 as a standalone under uuiddoc133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra133.uuid5_doc_len_67:
  description: "uuid.uuid5.__doc__.__len__() == 67 — 'Generate a UUID from the SHA-1 hash of a namespace UUID and a name.' (67 chars); 2 chars longer than uuid3 (65) because 'SHA-1' replaces 'MD5'; second-longest generator doc after uuid1 (258); no prior uuid spec anchors this as a standalone; first standalone under uuiddoc133"
  category: doc_lengths
  kind: python_call_eq
  function: uuid5.__doc__.__len__
  args: []
  expected: 67

# ---------------------------------------------------------------------------
# uuid.uuid3.__doc__.__len__()==65 — standalone
#
# uuid.uuid3.__doc__.__len__() is 65. The uuid3 docstring 'Generate a UUID from
# the MD5 hash of a namespace UUID and a name.' is 65 chars. uuid3 (65) is the
# third-longest of the four generator function docstrings, ahead of only uuid4 (23).
# The docstring is structurally identical to uuid5's but 2 chars shorter.
# No prior uuid spec anchors uuid3.__doc__.__len__()==65 as a standalone under
# uuiddoc133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra133.uuid3_doc_len_65:
  description: "uuid.uuid3.__doc__.__len__() == 65 — 'Generate a UUID from the MD5 hash of a namespace UUID and a name.' (65 chars); structurally identical to uuid5 except 'MD5' (3 chars) vs 'SHA-1' (5 chars); third-longest generator doc; no prior uuid spec anchors this as a standalone; first standalone under uuiddoc133"
  category: doc_lengths
  kind: python_call_eq
  function: uuid3.__doc__.__len__
  args: []
  expected: 65

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__.__len__()==2787 — standalone
#
# uuid.UUID.__doc__.__len__() is 2787. The UUID class docstring is the longest
# docstring in the uuid module by a wide margin. It documents: the RFC 4122
# specification reference, all constructor argument forms (hex/bytes/bytes_le/
# fields/int/version/is_safe), the UUID field structure with bit widths
# (time_low=32 bits, time_mid=16 bits, time_hi_version=12+4 bits, etc.),
# and attributes accessible on UUID instances. No prior uuid spec anchors
# UUID.__doc__.__len__()==2787 as a standalone under uuiddoc133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra133.UUID_doc_len_2787:
  description: "uuid.UUID.__doc__.__len__() == 2787 — longest docstring in the uuid module; documents RFC 4122 specification, all constructor forms (hex/bytes/bytes_le/fields/int/version/is_safe), UUID field structure with bit widths, and instance attributes; no prior uuid spec anchors this as a standalone under uuiddoc133; first standalone under uuiddoc133"
  category: doc_lengths
  kind: python_call_eq
  function: UUID.__doc__.__len__
  args: []
  expected: 2787

# ---------------------------------------------------------------------------
# uuid.uuid4.__doc__.__len__()==23 — standalone
#
# uuid.uuid4.__doc__.__len__() is 23. The full docstring is 'Generate a random UUID.'
# (23 chars) — a single short sentence. This is the minimum length needed to
# describe uuid4's behavior: it takes no arguments and simply generates a UUID
# from random bytes (via os.urandom). No prior uuid spec anchors uuid4's
# __doc__.__len__()==23 as a standalone under uuiddoc133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra133.uuid4_doc_len_23:
  description: "uuid.uuid4.__doc__.__len__() == 23 — 'Generate a random UUID.' (23 chars); shortest generator function docstring; takes no arguments; uses os.urandom for randomness; no prior uuid spec anchors this as a standalone under uuiddoc133; first standalone under uuiddoc133"
  category: doc_lengths
  kind: python_call_eq
  function: uuid4.__doc__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# uuid.uuid1.__doc__.__len__()==258 — standalone
#
# uuid.uuid1.__doc__.__len__() is 258. The uuid1 docstring is the longest of the
# four generator function docstrings by a wide margin. It documents: the optional
# 'node' parameter (hardware address), the getnode() fallback when node is not
# given, the optional 'clock_seq' parameter, and the fallback to a random 14-bit
# sequence number. The complexity of uuid1 (involving hardware addresses, sequence
# numbers, and timestamps) explains the much longer documentation. No prior uuid
# spec anchors uuid1.__doc__.__len__()==258 as a standalone under uuiddoc133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra133.uuid1_doc_len_258:
  description: "uuid.uuid1.__doc__.__len__() == 258 — longest generator function docstring (258 chars); documents optional 'node' parameter with getnode() fallback and optional 'clock_seq' with random 14-bit fallback; uuid1 complexity (hardware address, sequence, timestamp) explains verbose doc; no prior uuid spec anchors this as a standalone under uuiddoc133; first standalone under uuiddoc133"
  category: doc_lengths
  kind: python_call_eq
  function: uuid1.__doc__.__len__
  args: []
  expected: 258

