spec: concurrent_futures_extra250
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ProcessPoolExecutor — ProcessPoolExecutor documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Executor — Executor base class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py (ProcessPoolExecutor implementation)"
    - "CPython source: Lib/concurrent/futures/_base.py (Executor base class implementation)"
  notes:
    - "ProcessPoolExecutor.submit.__name__ == 'submit' (len=6); __qualname__ == 'ProcessPoolExecutor.submit' (len=26); __module__ == 'concurrent.futures.process' (len=26)."
    - "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23) — unlike ThreadPoolExecutor.map which has qualname 'Executor.map'(len=12), ProcessPoolExecutor overrides map directly."
    - "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28) — same length as __init__.__qualname__."
    - "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28); same length as shutdown.__qualname__."
    - "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27) — one shorter than ProcessPoolExecutor.__init__.__qualname__(len=28) because 'ProcessPoolExecutor' is one char longer than 'ThreadPoolExecutor'."
    - "concurrent.futures._base.Executor.submit.__qualname__ == 'Executor.submit' (len=15)."
    - "All ProcessPoolExecutor methods have __module__=='concurrent.futures.process'(len=26)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor method identity
#
# submit.__name__ == 'submit' (len=6)
# submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26)
# submit.__module__ == 'concurrent.futures.process' (len=26)
# map.__qualname__ == 'ProcessPoolExecutor.map' (len=23) — overridden (unlike ThreadPoolExecutor)
# shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28)
# __init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28)
# ---------------------------------------------------------------------------

table concurrent_futures_extra250.processpoolexecutor_method_identity:
  description: "concurrent.futures.ProcessPoolExecutor method identity — submit(len=6) has qualname 'ProcessPoolExecutor.submit'(len=26) and module 'concurrent.futures.process'(len=26); map has qualname 'ProcessPoolExecutor.map'(len=23, overridden unlike ThreadPoolExecutor which inherits 'Executor.map'); shutdown and __init__ both have qualname len=28 ('ProcessPoolExecutor.shutdown' and 'ProcessPoolExecutor.__init__'); all have module 'concurrent.futures.process'(len=26); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe250ppe

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_sub_name_eq,   ProcessPoolExecutor.submit.__name__.__eq__,       ["submit"],                        true, "ProcessPoolExecutor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [ppe_sub_name_len,  ProcessPoolExecutor.submit.__name__.__len__,      [],                                6,    "ProcessPoolExecutor.submit.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [ppe_sub_qual_eq,   ProcessPoolExecutor.submit.__qualname__.__eq__,   ["ProcessPoolExecutor.submit"],    true, "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'; verified with Python 3.14.3"]
    - [ppe_sub_qual_len,  ProcessPoolExecutor.submit.__qualname__.__len__,  [],                                26,   "ProcessPoolExecutor.submit.__qualname__.__len__() == 26; verified with Python 3.14.3"]
    - [ppe_sub_mod_eq,    ProcessPoolExecutor.submit.__module__.__eq__,     ["concurrent.futures.process"],    true, "ProcessPoolExecutor.submit.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [ppe_sub_mod_len,   ProcessPoolExecutor.submit.__module__.__len__,    [],                                26,   "ProcessPoolExecutor.submit.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [ppe_map_qual_eq,   ProcessPoolExecutor.map.__qualname__.__eq__,      ["ProcessPoolExecutor.map"],       true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (overridden, not inherited); verified with Python 3.14.3"]
    - [ppe_map_qual_len,  ProcessPoolExecutor.map.__qualname__.__len__,     [],                                23,   "ProcessPoolExecutor.map.__qualname__.__len__() == 23; verified with Python 3.14.3"]
    - [ppe_sdn_qual_eq,   ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"],  true, "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'; verified with Python 3.14.3"]
    - [ppe_sdn_qual_len,  ProcessPoolExecutor.shutdown.__qualname__.__len__,[],                                28,   "ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28; verified with Python 3.14.3"]
    - [ppe_ini_name_eq,   ProcessPoolExecutor.__init__.__name__.__eq__,     ["__init__"],                      true, "ProcessPoolExecutor.__init__.__name__ == '__init__'; verified with Python 3.14.3"]
    - [ppe_ini_name_len,  ProcessPoolExecutor.__init__.__name__.__len__,    [],                                8,    "ProcessPoolExecutor.__init__.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ppe_ini_qual_eq,   ProcessPoolExecutor.__init__.__qualname__.__eq__, ["ProcessPoolExecutor.__init__"],  true, "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__'; verified with Python 3.14.3"]
    - [ppe_ini_qual_len,  ProcessPoolExecutor.__init__.__qualname__.__len__,[],                                28,   "ProcessPoolExecutor.__init__.__qualname__.__len__() == 28; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__init__ and Executor.submit qualnames for contrast
#
# ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27)
# Executor.submit.__qualname__ == 'Executor.submit' (len=15)
# ---------------------------------------------------------------------------

table concurrent_futures_extra250.init_submit_qualname_contrast:
  description: "ThreadPoolExecutor.__init__ and Executor.submit qualname contrast — ThreadPoolExecutor.__init__.__qualname__(len=27) is one shorter than ProcessPoolExecutor.__init__.__qualname__(len=28) because 'ThreadPoolExecutor' is one char shorter than 'ProcessPoolExecutor'; Executor.submit.__qualname__=='Executor.submit'(len=15) is the shortest submit qualname, contrasting with ProcessPoolExecutor.submit's len=26; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe250ctr

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_ini_qual_eq,   ThreadPoolExecutor.__init__.__qualname__.__eq__,  ["ThreadPoolExecutor.__init__"],  true, "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__'; verified with Python 3.14.3"]
    - [tpe_ini_qual_len,  ThreadPoolExecutor.__init__.__qualname__.__len__, [],                               27,   "ThreadPoolExecutor.__init__.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [ex_sub_qual_eq,    Executor.submit.__qualname__.__eq__,              ["Executor.submit"],              true, "Executor.submit.__qualname__ == 'Executor.submit'; verified with Python 3.14.3"]
    - [ex_sub_qual_len,   Executor.submit.__qualname__.__len__,             [],                               15,   "Executor.submit.__qualname__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra250
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra250.ppe_map_overrides_executor:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map') returns True — ProcessPoolExecutor.map is overridden (qualname 'ProcessPoolExecutor.map', len=23), unlike ThreadPoolExecutor.map which inherits from Executor (qualname 'Executor.map', len=12); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.map.__qualname__.__eq__
  args: ["ProcessPoolExecutor.map"]
  expected: true

invariant concurrent_futures_extra250.ppe_init_qualname_longest:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.__init__'(len=28) is the longest qualname in this spec, tied with 'ProcessPoolExecutor.shutdown'(len=28); ThreadPoolExecutor.__init__.__qualname__ has len=27; Executor.submit.__qualname__ has len=15; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__qualname__.__len__
  args: []
  expected: 28
