spec: asyncio_extra378
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-eventloop.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.AbstractEventLoop lives in module asyncio.events and derives from object"
    - "asyncio.BaseEventLoop lives in module asyncio.base_events and derives from AbstractEventLoop"
    - "asyncio.Handle lives in module asyncio.events and derives from object"
    - "asyncio.TimerHandle lives in module asyncio.events and derives from Handle"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra378.class_names:
  description: "Verify __name__ attribute of asyncio event loop and handle classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio378n

  columns: [id, function, args, expected]
  rows:
    - [aio378n001, asyncio.AbstractEventLoop.__name__.__eq__, ["AbstractEventLoop"], true]
    - [aio378n002, asyncio.BaseEventLoop.__name__.__eq__, ["BaseEventLoop"], true]
    - [aio378n003, asyncio.Handle.__name__.__eq__, ["Handle"], true]
    - [aio378n004, asyncio.TimerHandle.__name__.__eq__, ["TimerHandle"], true]

table asyncio_extra378.class_modules:
  description: "Verify __module__ attribute of asyncio event loop and handle classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio378m

  columns: [id, function, args, expected]
  rows:
    - [aio378m001, asyncio.AbstractEventLoop.__module__.__eq__, ["asyncio.events"], true]
    - [aio378m002, asyncio.BaseEventLoop.__module__.__eq__, ["asyncio.base_events"], true]
    - [aio378m003, asyncio.Handle.__module__.__eq__, ["asyncio.events"], true]
    - [aio378m004, asyncio.TimerHandle.__module__.__eq__, ["asyncio.events"], true]

table asyncio_extra378.class_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of asyncio event loop and handle classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio378b

  columns: [id, function, args, expected]
  rows:
    - ["aio378b001", "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__", ["object"], true]
    - ["aio378b002", "asyncio.BaseEventLoop.__bases__[0].__name__.__eq__", ["AbstractEventLoop"], true]
    - ["aio378b003", "asyncio.Handle.__bases__[0].__name__.__eq__", ["object"], true]
    - ["aio378b004", "asyncio.TimerHandle.__bases__[0].__name__.__eq__", ["Handle"], true]
