spec: xml_extra
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "xml_etree_extra.zspec.zsdl — covers Element/SubElement/parse/fromstring/tostring/indent/iterparse/register_namespace/ParseError name checks"
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError class names, module checks, ParseError base hierarchy"
    - "elementtree.zspec.zsdl — covers fromstring behavior, Element constructor, tostring, ParseError raise behavior"
  notes:
    - "This spec provides additional __name__-equality and base-class coverage for xml.etree.ElementTree."
    - "xml.etree.ElementTree.Element.__name__ == 'Element'."
    - "xml.etree.ElementTree.ElementTree.__name__ == 'ElementTree'."
    - "xml.etree.ElementTree.parse.__name__ == 'parse'."
    - "xml.etree.ElementTree.fromstring.__name__ == 'XML' — the C-level alias is named 'XML', not 'fromstring'."
    - "xml.etree.ElementTree.tostring.__name__ == 'tostring'."
    - "xml.etree.ElementTree.SubElement.__name__ == 'SubElement'."
    - "xml.etree.ElementTree.ParseError.__name__ == 'ParseError'."
    - "xml.etree.ElementTree.ParseError.__bases__[0].__name__ == 'SyntaxError'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — __name__ equality for public types
# ---------------------------------------------------------------------------

table xml_extra.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Element,      Element.__name__.__eq__,      ["Element"],      true]
    - [ElementTree,  ElementTree.__name__.__eq__,  ["ElementTree"],  true]
    - [SubElement,   SubElement.__name__.__eq__,   ["SubElement"],   true]
    - [ParseError,   ParseError.__name__.__eq__,   ["ParseError"],   true]

# ---------------------------------------------------------------------------
# Function name checks — module-level functions
#
# NOTE: fromstring.__name__ == 'XML' — on CPython, xml.etree.ElementTree.fromstring
# is the same object as xml.etree.ElementTree.XML (a C-level builtin); its
# __name__ attribute is 'XML'.
# ---------------------------------------------------------------------------

table xml_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fnname

  columns: [id, function, args, expected]
  rows:
    - [parse,      parse.__name__.__eq__,      ["parse"],    true]
    - [fromstring, fromstring.__name__.__eq__,  ["XML"],     true]
    - [tostring,   tostring.__name__.__eq__,    ["tostring"], true]

# ---------------------------------------------------------------------------
# Exception hierarchy — ParseError.__bases__[0].__name__ == 'SyntaxError'
# ---------------------------------------------------------------------------

invariant xml_extra.ParseError.base_is_SyntaxError:
  description: "xml.etree.ElementTree.ParseError.__bases__[0].__name__ == 'SyntaxError'"
  category: hierarchy
  kind: python_call_eq
  function: ParseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SyntaxError"
