spec: functools_extra2071
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial defines __getattribute__ (True) and __reduce__ (True) in its __dict__ — it is a C extension type with custom attribute lookup and pickle support."
    - "functools.partial does NOT define __reduce_ex__, __copy__, or __deepcopy__ in its __dict__."
    - "functools.partialmethod is a pure-Python class; it defines none of the 7 target dunders in its __dict__."
    - "functools.cached_property is a pure-Python descriptor class; it defines none of the 7 target dunders in its __dict__."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __pos__ / __neg__ dict-presence for functools types
#
# None of partial, partialmethod, cached_property are numeric types;
# they define neither __pos__ nor __neg__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2071.unary_sign_protocol:
  description: "functools types __pos__/__neg__ dict-presence checks — none are numeric"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2071

  columns: [id, function, args, expected]
  rows:
    - ["ft2071001", "functools.partial.__dict__.__contains__", ["__pos__"], false]
    - ["ft2071002", "functools.partial.__dict__.__contains__", ["__neg__"], false]
    - ["ft2071003", "functools.partialmethod.__dict__.__contains__", ["__pos__"], false]
    - ["ft2071004", "functools.partialmethod.__dict__.__contains__", ["__neg__"], false]
    - ["ft2071005", "functools.cached_property.__dict__.__contains__", ["__pos__"], false]
    - ["ft2071006", "functools.cached_property.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getattribute__ dict-presence for functools types
#
# functools.partial is a C extension type and defines __getattribute__ in
# its own __dict__. partialmethod and cached_property are pure-Python
# classes and do not override __getattribute__.
# ---------------------------------------------------------------------------

table functools_extra2071.getattribute_protocol:
  description: "functools types __getattribute__ dict-presence — partial True, others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2071

  columns: [id, function, args, expected]
  rows:
    - ["ft2071007", "functools.partial.__dict__.__contains__", ["__getattribute__"], true]
    - ["ft2071008", "functools.partialmethod.__dict__.__contains__", ["__getattribute__"], false]
    - ["ft2071009", "functools.cached_property.__dict__.__contains__", ["__getattribute__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reduce__ / __reduce_ex__ dict-presence for functools types
#
# functools.partial defines __reduce__ (True) for pickle support because it
# is a C extension type that must implement custom pickling. It does NOT
# define __reduce_ex__. partialmethod and cached_property define neither.
# ---------------------------------------------------------------------------

table functools_extra2071.pickle_protocol:
  description: "functools types __reduce__/__reduce_ex__ dict-presence — partial.__reduce__ True only"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2071

  columns: [id, function, args, expected]
  rows:
    - ["ft2071010", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["ft2071011", "functools.partial.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2071012", "functools.partialmethod.__dict__.__contains__", ["__reduce__"], false]
    - ["ft2071013", "functools.partialmethod.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2071014", "functools.cached_property.__dict__.__contains__", ["__reduce__"], false]
    - ["ft2071015", "functools.cached_property.__dict__.__contains__", ["__reduce_ex__"], false]

# ---------------------------------------------------------------------------
# Table 4: __copy__ / __deepcopy__ dict-presence for functools types
#
# None of partial, partialmethod, or cached_property define __copy__ or
# __deepcopy__ in their own __dict__. The copy module handles them via
# the generic fallback path (using __reduce__ for partial).
# ---------------------------------------------------------------------------

table functools_extra2071.copy_protocol:
  description: "functools types __copy__/__deepcopy__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2071

  columns: [id, function, args, expected]
  rows:
    - ["ft2071016", "functools.partial.__dict__.__contains__", ["__copy__"], false]
    - ["ft2071017", "functools.partial.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ft2071018", "functools.partialmethod.__dict__.__contains__", ["__copy__"], false]
    - ["ft2071019", "functools.partialmethod.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ft2071020", "functools.cached_property.__dict__.__contains__", ["__copy__"], false]
    - ["ft2071021", "functools.cached_property.__dict__.__contains__", ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 5: Cross-check — partial defines __reduce__ but not its siblings
#
# Confirms that __reduce__ presence is an isolated C-level addition;
# __reduce_ex__, __copy__, __deepcopy__ are all absent from partial.__dict__.
# Also confirms __pos__ and __neg__ are absent.
# ---------------------------------------------------------------------------

table functools_extra2071.partial_dict_cross_check:
  description: "functools.partial __dict__ cross-check: __reduce__ True, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2071

  columns: [id, function, args, expected]
  rows:
    - ["ft2071022", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["ft2071023", "functools.partial.__dict__.__contains__", ["__getattribute__"], true]
    - ["ft2071024", "functools.partial.__dict__.__contains__", ["__pos__"], false]
    - ["ft2071025", "functools.partial.__dict__.__contains__", ["__neg__"], false]
    - ["ft2071026", "functools.partial.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2071027", "functools.partial.__dict__.__contains__", ["__copy__"], false]
    - ["ft2071028", "functools.partial.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ft2071029", "functools.partialmethod.__dict__.__contains__", ["__reduce__"], false]
    - ["ft2071030", "functools.cached_property.__dict__.__contains__", ["__reduce__"], false]
