spec: io_extra2521
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/*.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "Wave 2521 theme: __bool__, __index__, __int__ dict-presence in io classes."
    - "None of the io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO) define __bool__, __int__, or __index__ in their own __dict__."
    - "io stream objects are truthy by default (via object.__bool__) — truthiness is NOT overridden at the io level."
    - "IO streams cannot be used as integers or sequence indices — no __int__ or __index__ defined."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are ABCs implemented in C; their __dict__ contains only __module__, __doc__, __abstractmethods__, and internal ABC state."
    - "io.BytesIO and io.StringIO are concrete classes; their __dict__ contains I/O methods but NOT numeric protocol methods."
    - "io.FileIO wraps a raw OS file descriptor; its __dict__ contains I/O methods but NOT numeric protocol methods."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __bool__ dict-presence — no io class defines truthiness override
# ---------------------------------------------------------------------------

table io_extra2521.bool_protocol:
  description: "__bool__ is absent from all io class __dict__s — io types rely on default object truthiness"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2521

  columns: [id, function, args, expected]
  rows:
    - ["io2521001", "io.IOBase.__dict__.__contains__",       ["__bool__"], false]
    - ["io2521002", "io.RawIOBase.__dict__.__contains__",    ["__bool__"], false]
    - ["io2521003", "io.BufferedIOBase.__dict__.__contains__", ["__bool__"], false]
    - ["io2521004", "io.TextIOBase.__dict__.__contains__",   ["__bool__"], false]
    - ["io2521005", "io.BytesIO.__dict__.__contains__",      ["__bool__"], false]
    - ["io2521006", "io.StringIO.__dict__.__contains__",     ["__bool__"], false]
    - ["io2521007", "io.FileIO.__dict__.__contains__",       ["__bool__"], false]

# ---------------------------------------------------------------------------
# __int__ dict-presence — no io class defines integer coercion
# ---------------------------------------------------------------------------

table io_extra2521.int_protocol:
  description: "__int__ is absent from all io class __dict__s — io streams cannot be coerced to int"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2521

  columns: [id, function, args, expected]
  rows:
    - ["io2521008", "io.IOBase.__dict__.__contains__",       ["__int__"], false]
    - ["io2521009", "io.RawIOBase.__dict__.__contains__",    ["__int__"], false]
    - ["io2521010", "io.BufferedIOBase.__dict__.__contains__", ["__int__"], false]
    - ["io2521011", "io.TextIOBase.__dict__.__contains__",   ["__int__"], false]
    - ["io2521012", "io.BytesIO.__dict__.__contains__",      ["__int__"], false]
    - ["io2521013", "io.StringIO.__dict__.__contains__",     ["__int__"], false]
    - ["io2521014", "io.FileIO.__dict__.__contains__",       ["__int__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — no io class defines the indexing protocol
# ---------------------------------------------------------------------------

table io_extra2521.index_protocol:
  description: "__index__ is absent from all io class __dict__s — io streams cannot be used as sequence indices"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2521

  columns: [id, function, args, expected]
  rows:
    - ["io2521015", "io.IOBase.__dict__.__contains__",       ["__index__"], false]
    - ["io2521016", "io.RawIOBase.__dict__.__contains__",    ["__index__"], false]
    - ["io2521017", "io.BufferedIOBase.__dict__.__contains__", ["__index__"], false]
    - ["io2521018", "io.TextIOBase.__dict__.__contains__",   ["__index__"], false]
    - ["io2521019", "io.BytesIO.__dict__.__contains__",      ["__index__"], false]
    - ["io2521020", "io.StringIO.__dict__.__contains__",     ["__index__"], false]
    - ["io2521021", "io.FileIO.__dict__.__contains__",       ["__index__"], false]
