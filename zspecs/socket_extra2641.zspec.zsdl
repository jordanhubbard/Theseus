spec: socket_extra2641
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 623: checks socket.socket, socket.AddressFamily, socket.SocketKind __dict__ for __copy__, __deepcopy__, __sizeof__ presence. socket.socket is not copyable. All three classes return False for all three dunders — none defines __copy__, __deepcopy__, or __sizeof__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table socket_extra2641.socket_dict_presence:
  description: "socket.socket __dict__ does not contain __copy__, __deepcopy__, or __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2641sc
  columns: [id, function, args, expected]
  rows:
    - ["sk2641sc001", socket.socket.__dict__.__contains__, ["__copy__"],     false]
    - ["sk2641sc002", socket.socket.__dict__.__contains__, ["__deepcopy__"], false]
    - ["sk2641sc003", socket.socket.__dict__.__contains__, ["__sizeof__"],   false]

