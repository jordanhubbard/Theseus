spec: re_extra114
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra113.zspec.zsdl."
    - "This spec covers: re module function __qualname__ string equality for match, search, findall, sub, compile, fullmatch, split, finditer, subn, escape, purge."
    - "All eleven functions are pure Python functions (type 'function'); their __qualname__ equals their bare name (no class prefix)."
    - "re.match.__qualname__ == 'match' (len 5)."
    - "re.search.__qualname__ == 'search' (len 6)."
    - "re.findall.__qualname__ == 'findall' (len 7)."
    - "re.sub.__qualname__ == 'sub' (len 3)."
    - "re.compile.__qualname__ == 'compile' (len 7)."
    - "re.fullmatch.__qualname__ == 'fullmatch' (len 9)."
    - "re.split.__qualname__ == 'split' (len 5)."
    - "re.finditer.__qualname__ == 'finditer' (len 8)."
    - "re.subn.__qualname__ == 'subn' (len 4)."
    - "re.escape.__qualname__ == 'escape' (len 6)."
    - "re.purge.__qualname__ == 'purge' (len 5)."
    - "re.sub.__qualname__ is the shortest at 3 chars; re.fullmatch.__qualname__ is the longest at 9 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.match, re.search, re.findall __qualname__ string equality
# All are pure Python functions (type 'function'); qualname equals bare name.
# match: 'match' (5 chars).
# search: 'search' (6 chars).
# findall: 'findall' (7 chars).
# ---------------------------------------------------------------------------

table re_extra114.match_search_findall_qualnames:
  description: "re.match qualname='match'(5), re.search qualname='search'(6), re.findall qualname='findall'(7); all type 'function'; qualname equals bare function name"
  kind: python_call_eq
  category: qualnames
  id_prefix: reqn114a

  columns: [id, function, args, expected, description]
  rows:
    - [match_type,          "match.__class__.__name__.__eq__",      ["function"],  true,  "type(re.match).__name__ == 'function' (pure Python function defined in re/__init__.py)"]
    - [match_qn_eq,         "match.__qualname__.__eq__",            ["match"],     true,  "re.match.__qualname__ == 'match' (qualname equals bare function name; no class prefix)"]
    - [match_qn_len,        "match.__qualname__.__len__",           [],            5,     "re.match.__qualname__.__len__() == 5 ('match' has 5 chars)"]
    - [search_type,         "search.__class__.__name__.__eq__",     ["function"],  true,  "type(re.search).__name__ == 'function' (pure Python function; scans through string for first match of pattern)"]
    - [search_qn_eq,        "search.__qualname__.__eq__",           ["search"],    true,  "re.search.__qualname__ == 'search' (qualname equals bare function name)"]
    - [search_qn_len,       "search.__qualname__.__len__",          [],            6,     "re.search.__qualname__.__len__() == 6 ('search' has 6 chars)"]
    - [findall_qn_eq,       "findall.__qualname__.__eq__",          ["findall"],   true,  "re.findall.__qualname__ == 'findall' (returns list of all non-overlapping matches)"]
    - [findall_qn_len,      "findall.__qualname__.__len__",         [],            7,     "re.findall.__qualname__.__len__() == 7 ('findall' has 7 chars; one longer than search)"]
    - [findall_gt_match,    "findall.__qualname__.__len__.__gt__",  [5],           true,  "len('findall') > len('match') (7 > 5; findall is two chars longer than match)"]

# ---------------------------------------------------------------------------
# re.sub, re.compile, re.fullmatch __qualname__ string equality
# All are pure Python functions (type 'function'); qualname equals bare name.
# sub: 'sub' (3 chars; shortest of all eleven functions).
# compile: 'compile' (7 chars; same length as findall).
# fullmatch: 'fullmatch' (9 chars; longest of all eleven functions).
# ---------------------------------------------------------------------------

table re_extra114.sub_compile_fullmatch_qualnames:
  description: "re.sub qualname='sub'(3), re.compile qualname='compile'(7), re.fullmatch qualname='fullmatch'(9); sub is shortest; fullmatch is longest of all eleven functions"
  kind: python_call_eq
  category: qualnames
  id_prefix: reqn114b

  columns: [id, function, args, expected, description]
  rows:
    - [sub_type,            "sub.__class__.__name__.__eq__",         ["function"],   true,  "type(re.sub).__name__ == 'function' (pure Python function; replaces occurrences of pattern in string)"]
    - [sub_qn_eq,           "sub.__qualname__.__eq__",               ["sub"],        true,  "re.sub.__qualname__ == 'sub' (qualname equals bare name; sub is the shortest among all eleven re functions)"]
    - [sub_qn_len,          "sub.__qualname__.__len__",              [],             3,     "re.sub.__qualname__.__len__() == 3 ('sub' has 3 chars; shortest __qualname__ among all eleven re module functions)"]
    - [compile_type,        "compile.__class__.__name__.__eq__",     ["function"],   true,  "type(re.compile).__name__ == 'function' (pure Python function; compiles a pattern into a RegexObject)"]
    - [compile_qn_eq,       "compile.__qualname__.__eq__",           ["compile"],    true,  "re.compile.__qualname__ == 'compile' (qualname equals bare function name)"]
    - [compile_qn_len,      "compile.__qualname__.__len__",          [],             7,     "re.compile.__qualname__.__len__() == 7 ('compile' has 7 chars; same length as findall)"]
    - [fullmatch_type,      "fullmatch.__class__.__name__.__eq__",   ["function"],   true,  "type(re.fullmatch).__name__ == 'function' (pure Python function; matches pattern against entire string)"]
    - [fullmatch_qn_eq,     "fullmatch.__qualname__.__eq__",         ["fullmatch"],  true,  "re.fullmatch.__qualname__ == 'fullmatch' (qualname equals bare name; fullmatch is the longest of all eleven)"]
    - [fullmatch_qn_len,    "fullmatch.__qualname__.__len__",        [],             9,     "re.fullmatch.__qualname__.__len__() == 9 ('fullmatch' has 9 chars; longest __qualname__ among all eleven re module functions)"]
    - [fullmatch_gt_compile, "fullmatch.__qualname__.__len__.__gt__", [7],           true,  "len('fullmatch') > len('compile') (9 > 7; fullmatch is two chars longer than compile)"]

# ---------------------------------------------------------------------------
# re.split, re.finditer, re.subn, re.escape, re.purge __qualname__ string equality
# All are pure Python functions (type 'function'); qualname equals bare name.
# split: 'split' (5 chars; same length as match and purge).
# finditer: 'finditer' (8 chars).
# subn: 'subn' (4 chars).
# escape: 'escape' (6 chars; same length as search).
# purge: 'purge' (5 chars; same length as match and split).
# ---------------------------------------------------------------------------

table re_extra114.split_finditer_subn_escape_purge_qualnames:
  description: "re.split qualname='split'(5), re.finditer qualname='finditer'(8), re.subn qualname='subn'(4), re.escape qualname='escape'(6), re.purge qualname='purge'(5)"
  kind: python_call_eq
  category: qualnames
  id_prefix: reqn114c

  columns: [id, function, args, expected, description]
  rows:
    - [split_qn_eq,         "split.__qualname__.__eq__",     ["split"],    true,  "re.split.__qualname__ == 'split' (splits string at each match of pattern; returns list)"]
    - [split_qn_len,        "split.__qualname__.__len__",    [],           5,     "re.split.__qualname__.__len__() == 5 ('split' has 5 chars; same length as match and purge)"]
    - [finditer_qn_eq,      "finditer.__qualname__.__eq__",  ["finditer"], true,  "re.finditer.__qualname__ == 'finditer' (returns iterator of match objects for all non-overlapping matches)"]
    - [finditer_qn_len,     "finditer.__qualname__.__len__", [],           8,     "re.finditer.__qualname__.__len__() == 8 ('finditer' has 8 chars; second longest after fullmatch at 9)"]
    - [subn_qn_eq,          "subn.__qualname__.__eq__",      ["subn"],     true,  "re.subn.__qualname__ == 'subn' (like sub but also returns count of substitutions made)"]
    - [subn_qn_len,         "subn.__qualname__.__len__",     [],           4,     "re.subn.__qualname__.__len__() == 4 ('subn' has 4 chars; second shortest after sub at 3)"]
    - [escape_qn_eq,        "escape.__qualname__.__eq__",    ["escape"],   true,  "re.escape.__qualname__ == 'escape' (escapes special regex characters in a string)"]
    - [escape_qn_len,       "escape.__qualname__.__len__",   [],           6,     "re.escape.__qualname__.__len__() == 6 ('escape' has 6 chars; same length as search)"]
    - [purge_qn_eq,         "purge.__qualname__.__eq__",     ["purge"],    true,  "re.purge.__qualname__ == 'purge' (clears the regular expression cache)"]
    - [purge_qn_len,        "purge.__qualname__.__len__",    [],           5,     "re.purge.__qualname__.__len__() == 5 ('purge' has 5 chars; same length as match and split)"]
    - [finditer_gt_split,   "finditer.__qualname__.__len__.__gt__", [5],   true,  "len('finditer') > len('split') (8 > 5; finditer is three chars longer than split)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra114.match_qualname:
  description: "re.match.__qualname__ == 'match' (length 5; type is 'function'; match is a pure Python function defined in re/__init__.py; its __qualname__ equals its bare name with no class prefix because it is a module-level function; match attempts to match the pattern at the beginning of the string)"
  category: qualnames
  kind: python_call_eq
  function: "match.__qualname__.__eq__"
  args: ["match"]
  expected: true

invariant re_extra114.sub_qualname_len:
  description: "re.sub.__qualname__.__len__() == 3 ('sub' has 3 characters; it is the shortest __qualname__ among all eleven re module functions examined — sub(3) < subn(4) < match/split/purge(5) < search/escape(6) < findall/compile(7) < finditer(8) < fullmatch(9); sub replaces occurrences of a pattern with a replacement string)"
  category: qualnames
  kind: python_call_eq
  function: "sub.__qualname__.__len__"
  args: []
  expected: 3

invariant re_extra114.fullmatch_qualname_len:
  description: "re.fullmatch.__qualname__.__len__() == 9 ('fullmatch' has 9 characters; it is the longest __qualname__ among all eleven re module functions examined; fullmatch requires the pattern to match the entire string, not just a prefix or substring; added in Python 3.4)"
  category: qualnames
  kind: python_call_eq
  function: "fullmatch.__qualname__.__len__"
  args: []
  expected: 9

invariant re_extra114.compile_qualname:
  description: "re.compile.__qualname__ == 'compile' (length 7; type is 'function'; compile is a pure Python wrapper in re/__init__.py that compiles a regex pattern string into a re.Pattern (RegexObject) for repeated use; its __qualname__ equals its bare name 'compile' with no class or module prefix)"
  category: qualnames
  kind: python_call_eq
  function: "compile.__qualname__.__eq__"
  args: ["compile"]
  expected: true

invariant re_extra114.finditer_qualname_len:
  description: "re.finditer.__qualname__.__len__() == 8 ('finditer' has 8 characters; second longest among all eleven re functions after fullmatch(9); finditer returns an iterator yielding match objects for all non-overlapping matches of pattern in string, which is more memory-efficient than findall which returns a list)"
  category: qualnames
  kind: python_call_eq
  function: "finditer.__qualname__.__len__"
  args: []
  expected: 8

