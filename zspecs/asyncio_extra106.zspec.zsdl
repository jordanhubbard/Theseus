spec: asyncio_extra106
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
  notes:
    - "This spec extends asyncio_extra105.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio Queue subclass hierarchy and synchronization primitive class identity. NEW in extra106: asyncio.LifoQueue.__bases__[0].__name__=='Queue' (LifoQueue and PriorityQueue both inherit directly from Queue; their MRO length is 4: [LifoQueue/PriorityQueue, Queue, _LoopBoundMixin, object]); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue MRO length is 3); asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (Semaphore MRO length is 4); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore MRO length is 5, the longest); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (Condition MRO length is 4); asyncio.TaskGroup.__bases__[0].__name__=='object' (TaskGroup MRO length is 2, the shortest); all queue classes have __module__=='asyncio.queues'; Semaphore/BoundedSemaphore/Condition have __module__=='asyncio.locks'; TaskGroup has __module__=='asyncio.taskgroups'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'. LifoQueue and PriorityQueue both inherit directly from asyncio.Queue (not from object). Their MRO is [LifoQueue, Queue, _LoopBoundMixin, object] (length=4), one step deeper than Queue's MRO of [Queue, _LoopBoundMixin, object] (length=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'. BoundedSemaphore inherits from Semaphore, giving MRO [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=5), the longest MRO of any class in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__bases__[0].__name__ == 'object'. TaskGroup inherits directly from object with MRO [TaskGroup, object] (length=2), the shortest MRO in this spec. TaskGroup is defined in Lib/asyncio/taskgroups.py (__module__=='asyncio.taskgroups'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue subclass __bases__[0].__name__ — extra106
#
# Wave 254 theme: asyncio Queue subclass hierarchy.
#
# asyncio.Queue.__bases__[0].__name__         == '_LoopBoundMixin'  (mro len=3)
# asyncio.LifoQueue.__bases__[0].__name__     == 'Queue'            (mro len=4)
# asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'            (mro len=4)
# ---------------------------------------------------------------------------

table asyncio_extra106.asyncio_queue_subclass_bases:
  description: "asyncio Queue subclass __bases__[0].__name__ checks in asyncioqueue106 namespace — wave 254 theme: asyncio.Queue inherits from _LoopBoundMixin (MRO=[Queue, _LoopBoundMixin, object], length=3); asyncio.LifoQueue and asyncio.PriorityQueue both inherit directly from Queue (MRO=[LifoQueue/PriorityQueue, Queue, _LoopBoundMixin, object], length=4); all three queue classes have __module__=='asyncio.queues'; LifoQueue.__bases__[0].__name__.__eq__('Queue')==True; PriorityQueue.__bases__[0].__name__.__eq__('Queue')==True; Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True; LifoQueue.__mro__.__len__()==4; PriorityQueue.__mro__.__len__()==4; Queue.__mro__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asyncioqueue106

  columns: [id, function, args, expected, description]
  rows:
    - [lifoq_base_eq,   "asyncio.LifoQueue.__bases__[0].__name__.__eq__",     ["Queue"],           true, "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' (LifoQueue inherits directly from Queue); verified with Python 3.14.3"]
    - [lifoq_mro_len,   asyncio.LifoQueue.__mro__.__len__,                    [],                  4,    "asyncio.LifoQueue.__mro__.__len__() == 4 ([LifoQueue, Queue, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [priQ_base_eq,    "asyncio.PriorityQueue.__bases__[0].__name__.__eq__", ["Queue"],           true, "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' (PriorityQueue inherits directly from Queue); verified with Python 3.14.3"]
    - [priQ_mro_len,    asyncio.PriorityQueue.__mro__.__len__,                [],                  4,    "asyncio.PriorityQueue.__mro__.__len__() == 4 ([PriorityQueue, Queue, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [queue_base_eq,   "asyncio.Queue.__bases__[0].__name__.__eq__",         ["_LoopBoundMixin"], true, "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (Queue inherits from _LoopBoundMixin, not object); verified with Python 3.14.3"]
    - [queue_mro_len,   asyncio.Queue.__mro__.__len__,                        [],                  3,    "asyncio.Queue.__mro__.__len__() == 3 ([Queue, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [lifoq_module,    asyncio.LifoQueue.__module__.__eq__,                  ["asyncio.queues"],  true, "asyncio.LifoQueue.__module__ == 'asyncio.queues' (defined in Lib/asyncio/queues.py); verified with Python 3.14.3"]
    - [priQ_module,     asyncio.PriorityQueue.__module__.__eq__,              ["asyncio.queues"],  true, "asyncio.PriorityQueue.__module__ == 'asyncio.queues' (defined in Lib/asyncio/queues.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Semaphore/BoundedSemaphore/Condition __bases__[0].__name__ — extra106
#
# Wave 254 theme: asyncio lock synchronization primitive hierarchy.
#
# asyncio.Semaphore.__bases__[0].__name__        == '_ContextManagerMixin'  (mro len=4)
# asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'             (mro len=5, longest)
# asyncio.Condition.__bases__[0].__name__        == '_ContextManagerMixin'  (mro len=4)
# ---------------------------------------------------------------------------

table asyncio_extra106.asyncio_lock_bases:
  description: "asyncio Semaphore, BoundedSemaphore, and Condition __bases__[0].__name__ checks in asyncioqueue106 namespace — wave 254 theme: asyncio.Semaphore inherits from _ContextManagerMixin (MRO=[Semaphore, _ContextManagerMixin, _LoopBoundMixin, object], length=4); asyncio.BoundedSemaphore inherits from Semaphore (MRO=[BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object], length=5 — the longest in this spec); asyncio.Condition also inherits from _ContextManagerMixin (MRO length=4); all three have __module__=='asyncio.locks'; Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True; BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')==True; BoundedSemaphore.__mro__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asyncioqueue106a

  columns: [id, function, args, expected, description]
  rows:
    - [sem_base_eq,    "asyncio.Semaphore.__bases__[0].__name__.__eq__",        ["_ContextManagerMixin"], true, "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]
    - [sem_mro_len,    asyncio.Semaphore.__mro__.__len__,                       [],                       4,    "asyncio.Semaphore.__mro__.__len__() == 4 ([Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [sem_module,     asyncio.Semaphore.__module__.__eq__,                     ["asyncio.locks"],        true, "asyncio.Semaphore.__module__ == 'asyncio.locks' (defined in Lib/asyncio/locks.py); verified with Python 3.14.3"]
    - [bsem_base_eq,   "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"],            true, "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (BoundedSemaphore inherits from Semaphore); verified with Python 3.14.3"]
    - [bsem_mro_len,   asyncio.BoundedSemaphore.__mro__.__len__,                [],                       5,    "asyncio.BoundedSemaphore.__mro__.__len__() == 5 ([BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); longest MRO in spec; verified with Python 3.14.3"]
    - [bsem_module,    asyncio.BoundedSemaphore.__module__.__eq__,              ["asyncio.locks"],        true, "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [cond_base_eq,   "asyncio.Condition.__bases__[0].__name__.__eq__",        ["_ContextManagerMixin"], true, "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]
    - [cond_mro_len,   asyncio.Condition.__mro__.__len__,                       [],                       4,    "asyncio.Condition.__mro__.__len__() == 4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio TaskGroup class identity — extra106
#
# Wave 254 theme: asyncio.TaskGroup hierarchy and module.
#
# asyncio.TaskGroup.__bases__[0].__name__ == 'object'             (mro len=2, shortest)
# asyncio.TaskGroup.__module__            == 'asyncio.taskgroups'
# asyncio.TaskGroup.__qualname__          == 'TaskGroup'          (len=9)
# ---------------------------------------------------------------------------

table asyncio_extra106.asyncio_taskgroup_identity:
  description: "asyncio.TaskGroup class identity checks in asyncioqueue106 namespace — wave 254 theme: asyncio.TaskGroup inherits directly from object (MRO=[TaskGroup, object], length=2 — the shortest in this spec); asyncio.TaskGroup.__module__=='asyncio.taskgroups' (defined in Lib/asyncio/taskgroups.py); TaskGroup.__bases__[0].__name__.__eq__('object')==True; TaskGroup.__mro__.__len__()==2; compare MRO lengths in this spec: TaskGroup=2 (shortest), Queue=3, LifoQueue=4, PriorityQueue=4, Semaphore=4, Condition=4, BoundedSemaphore=5 (longest); TaskGroup was added in Python 3.11 as a structured concurrency primitive; TaskGroup.__qualname__.__eq__('TaskGroup')==True (len=9); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asyncioqueue106b

  columns: [id, function, args, expected, description]
  rows:
    - [tg_base_eq,    "asyncio.TaskGroup.__bases__[0].__name__.__eq__", ["object"],              true, "asyncio.TaskGroup.__bases__[0].__name__ == 'object' (inherits directly from object); verified with Python 3.14.3"]
    - [tg_mro_len,    asyncio.TaskGroup.__mro__.__len__,                [],                      2,    "asyncio.TaskGroup.__mro__.__len__() == 2 ([TaskGroup, object]); shortest MRO in spec; verified with Python 3.14.3"]
    - [tg_module,     asyncio.TaskGroup.__module__.__eq__,              ["asyncio.taskgroups"],  true, "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' (defined in Lib/asyncio/taskgroups.py); verified with Python 3.14.3"]
    - [tg_qn_eq,      asyncio.TaskGroup.__qualname__.__eq__,            ["TaskGroup"],           true, "asyncio.TaskGroup.__qualname__ == 'TaskGroup' (len=9); verified with Python 3.14.3"]
    - [tg_qn_len,     asyncio.TaskGroup.__qualname__.__len__,           [],                      9,    "asyncio.TaskGroup.__qualname__.__len__() == 9 ('TaskGroup'=9); verified with Python 3.14.3"]
    - [cond_module,   asyncio.Condition.__module__.__eq__,              ["asyncio.locks"],       true, "asyncio.Condition.__module__ == 'asyncio.locks' (defined in Lib/asyncio/locks.py); verified with Python 3.14.3"]
    - [queue_module,  asyncio.Queue.__module__.__eq__,                  ["asyncio.queues"],      true, "asyncio.Queue.__module__ == 'asyncio.queues' (defined in Lib/asyncio/queues.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra106
# ---------------------------------------------------------------------------

invariant asyncio_extra106.LifoQueue_base_is_Queue:
  description: "asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue') returns True — LifoQueue inherits directly from asyncio.Queue; its MRO is [LifoQueue, Queue, _LoopBoundMixin, object] (length=4); compare: asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue's own direct base); LifoQueue and PriorityQueue are the two subclasses of Queue in asyncio; LifoQueue.__module__=='asyncio.queues'; LifoQueue.__qualname__=='LifoQueue' (len=9, same as TaskGroup); LifoQueue stores items in LIFO (last-in, first-out) order — it is a stack-like queue; NEW in extra106: first standalone LifoQueue base invariant in asyncioqueue106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra106.BoundedSemaphore_mro_len_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — BoundedSemaphore has the longest MRO in this spec: [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (5 elements); BoundedSemaphore.__bases__[0].__name__=='Semaphore' (inherits from Semaphore); compare MRO lengths: TaskGroup=2, Queue=3, LifoQueue=4, PriorityQueue=4, Semaphore=4, Condition=4, BoundedSemaphore=5 (longest); BoundedSemaphore.__module__=='asyncio.locks'; BoundedSemaphore is a Semaphore that disallows releasing beyond its initial value; NEW in extra106: first standalone BoundedSemaphore MRO length invariant in asyncioqueue106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5

invariant asyncio_extra106.TaskGroup_mro_len_2:
  description: "asyncio.TaskGroup.__mro__.__len__() == 2 — TaskGroup has the shortest MRO in this spec: [TaskGroup, object] (2 elements); TaskGroup.__bases__[0].__name__=='object' (inherits directly from object, no intermediate mixin); compare MRO lengths: TaskGroup=2 (shortest), Queue=3, LifoQueue=4, BoundedSemaphore=5 (longest); TaskGroup.__module__=='asyncio.taskgroups' (unique module in this spec — all other classes are in asyncio.queues or asyncio.locks); TaskGroup is a structured concurrency context manager for spawning and awaiting groups of tasks; added in Python 3.11; NEW in extra106: first standalone TaskGroup MRO length invariant in asyncioqueue106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.TaskGroup.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra106.PriorityQueue_base_is_Queue:
  description: "asyncio.PriorityQueue.__bases__[0].__name__.__eq__('Queue') returns True — PriorityQueue inherits directly from asyncio.Queue; its MRO is [PriorityQueue, Queue, _LoopBoundMixin, object] (length=4); both LifoQueue and PriorityQueue share the same MRO structure (differing only in the first element) and the same direct base class Queue; PriorityQueue.__module__=='asyncio.queues'; PriorityQueue.__qualname__=='PriorityQueue' (len=13, the longest class qualname in this spec); PriorityQueue stores items sorted by priority; NEW in extra106: first standalone PriorityQueue base invariant in asyncioqueue106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.PriorityQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra106.Semaphore_base_is_ContextManagerMixin:
  description: "asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — Semaphore's direct base is _ContextManagerMixin (not object), giving MRO [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); compare: asyncio.Condition.__bases__[0].__name__ is also '_ContextManagerMixin' (same direct base, same MRO length=4); asyncio.BoundedSemaphore.__bases__[0].__name__ is 'Semaphore' (BoundedSemaphore inherits from Semaphore, one level deeper, MRO length=5); Semaphore.__module__=='asyncio.locks'; Semaphore is an asyncio synchronization primitive that limits concurrent access to a resource; NEW in extra106: first standalone Semaphore base invariant in asyncioqueue106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true
