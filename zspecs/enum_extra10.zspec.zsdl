spec: enum_extra10
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra9.zspec.zsdl."
    - "enum_extra4 covers: Flag/__qualname__, IntFlag/__qualname__, StrEnum/__qualname__ (3.11+), EnumType/__qualname__, EnumMeta/__qualname__."
    - "enum_extra8 covers: unique/__qualname__, Enum/__module__, IntEnum/__module__."
    - "enum_extra6 covers: auto/__module__, Flag/__module__, IntFlag/__module__, EnumMeta/__module__, EnumType/__module__."
    - "NOT YET COVERED: Enum/__qualname__, IntEnum/__qualname__, auto/__qualname__."
    - "enum.Enum.__qualname__ == 'Enum' — top-level class; qualname equals name."
    - "enum.IntEnum.__qualname__ == 'IntEnum' — top-level class; qualname equals name."
    - "enum.auto.__qualname__ == 'auto' — top-level class; qualname equals name."
    - "Also NEW: enum.Enum.__mro__[0].__name__ == 'Enum' — the class itself is first in its own MRO."
    - "Also NEW: enum.auto.__bases__[0].__name__ — auto's first base is 'int' (auto is an int subclass)."
    - "Also NEW: len(enum.Enum.__bases__) == 1 — Enum has exactly one direct base (object)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Enum, IntEnum, auto
#
# enum_extra4 covers Flag/__qualname__, IntFlag/__qualname__,
# StrEnum/__qualname__, EnumType/__qualname__, EnumMeta/__qualname__.
# enum_extra8 covers unique/__qualname__.
# The three below are genuinely not yet covered in any prior spec.
# ---------------------------------------------------------------------------

table enum_extra10.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__qualname__.__eq__,    ["Enum"],    true]
    - [IntEnum, IntEnum.__qualname__.__eq__, ["IntEnum"], true]
    - [auto,    auto.__qualname__.__eq__,    ["auto"],    true]

# ---------------------------------------------------------------------------
# enum.Enum.__mro__[0].__name__ == 'Enum'
#
# enum_extra5 verified MRO length and that object is in MRO.
# enum_extra8 verified MRO length >= 2.
# Not yet verified: the first MRO entry is Enum itself.
# ---------------------------------------------------------------------------

invariant enum_extra10.Enum.mro_first_is_Enum:
  description: "enum.Enum.__mro__[0].__name__ == 'Enum' — the class itself is first in its MRO"
  category: hierarchy
  kind: python_call_eq
  function: Enum.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Enum"

# ---------------------------------------------------------------------------
# enum.auto.__bases__ — auto's base class
#
# enum.auto is a subclass of int (its values are integers). The first base
# is 'int'. This has not been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant enum_extra10.auto.bases_first:
  description: "enum.auto.__bases__[0].__name__ == 'int' — auto is an int subclass"
  category: auto
  kind: python_call_eq
  function: auto.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# enum.Enum.__bases__ — exactly one direct base
#
# enum_extra.zspec.zsdl verified Enum.__bases__[0].__name__ == 'object'.
# Not yet verified: that Enum has exactly one direct base (len == 1).
# ---------------------------------------------------------------------------

invariant enum_extra10.Enum.bases_len:
  description: "len(enum.Enum.__bases__) == 1 — Enum has exactly one direct base class (object)"
  category: hierarchy
  kind: python_call_eq
  function: Enum.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# enum.unique — class check
#
# enum_extra8 covers unique.__qualname__. Not yet covered: unique.__module__.
# unique is a module-level decorator function defined in the enum module.
# ---------------------------------------------------------------------------

invariant enum_extra10.unique.module:
  description: "enum.unique.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: unique.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# enum.IntEnum.__mro__[0].__name__ == 'IntEnum'
#
# enum_extra5 verified IntEnum MRO length and mro[1].__name__ == 'int'.
# Not yet verified: that the first MRO entry is IntEnum itself.
# ---------------------------------------------------------------------------

invariant enum_extra10.IntEnum.mro_first_is_IntEnum:
  description: "enum.IntEnum.__mro__[0].__name__ == 'IntEnum' — IntEnum is first in its own MRO"
  category: hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"
