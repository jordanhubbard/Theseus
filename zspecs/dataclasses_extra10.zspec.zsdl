spec: dataclasses_extra10
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra9."
    - "dataclasses_extra9 covers Field.__bases__[0]/__len__, FrozenInstanceError.__bases__.__len__, InitVar.__bases__[0]/__len__."
    - "NOT yet covered: Field MRO length and MRO[0].__name__; InitVar MRO length and MRO[0].__name__."
    - "NOT yet covered: FrozenInstanceError MRO length and specific MRO entries."
    - "NOT yet covered: KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE'; KW_ONLY class qualname."
    - "NOT yet covered: MISSING.__class__.__qualname__ == '_MISSING_TYPE'."
    - "dataclasses.Field.__mro__.__len__() == 2 — [Field, object]."
    - "dataclasses.Field.__mro__[0].__name__ == 'Field' — Field is first in its own MRO."
    - "dataclasses.InitVar.__mro__.__len__() == 2 — [InitVar, object]."
    - "dataclasses.InitVar.__mro__[0].__name__ == 'InitVar' — InitVar is first in its own MRO."
    - "dataclasses.FrozenInstanceError.__mro__.__len__() == 5 — FrozenInstanceError, AttributeError, Exception, BaseException, object."
    - "dataclasses.FrozenInstanceError.__mro__[1].__name__ == 'AttributeError' — second MRO entry."
    - "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — sentinel object class name."
    - "dataclasses.KW_ONLY.__class__.__qualname__ == '_KW_ONLY_TYPE'."
    - "dataclasses.MISSING.__class__.__qualname__ == '_MISSING_TYPE' — sentinel qualname (not just __name__)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Field.__mro__ — MRO length and first entry
#
# dataclasses_extra9 verified Field.__bases__[0].__name__ == 'object' and
# Field.__bases__.__len__() == 1. Not yet verified: the MRO tuple itself.
# Field's MRO is [Field, object] — length 2.
# ---------------------------------------------------------------------------

invariant dataclasses_extra10.Field.mro_len:
  description: "dataclasses.Field.__mro__.__len__() == 2 — MRO is [Field, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__mro__.__len__
  args: []
  expected: 2

invariant dataclasses_extra10.Field.mro_first:
  description: "dataclasses.Field.__mro__[0].__name__ == 'Field' — Field is first in its own MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Field"

# ---------------------------------------------------------------------------
# InitVar.__mro__ — MRO length and first entry
#
# dataclasses_extra9 verified InitVar.__bases__[0].__name__ == 'object' and
# InitVar.__bases__.__len__() == 1. Not yet verified: the MRO itself.
# InitVar's MRO is [InitVar, object] — length 2.
# ---------------------------------------------------------------------------

invariant dataclasses_extra10.InitVar.mro_len:
  description: "dataclasses.InitVar.__mro__.__len__() == 2 — MRO is [InitVar, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__mro__.__len__
  args: []
  expected: 2

invariant dataclasses_extra10.InitVar.mro_first:
  description: "dataclasses.InitVar.__mro__[0].__name__ == 'InitVar' — InitVar is first in its own MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "InitVar"

# ---------------------------------------------------------------------------
# FrozenInstanceError.__mro__ — MRO length and second entry
#
# Prior specs verified FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'
# (extra5) and __bases__.__len__ == 1 (extra9). Not yet verified: the full MRO.
# FrozenInstanceError inherits from AttributeError which inherits from Exception,
# BaseException, and object — giving a MRO length of 5.
# ---------------------------------------------------------------------------

invariant dataclasses_extra10.FrozenInstanceError.mro_len:
  description: "dataclasses.FrozenInstanceError.__mro__.__len__() == 5 — FrozenInstanceError, AttributeError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__mro__.__len__
  args: []
  expected: 5

invariant dataclasses_extra10.FrozenInstanceError.mro_second:
  description: "dataclasses.FrozenInstanceError.__mro__[1].__name__ == 'AttributeError'"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "AttributeError"

# ---------------------------------------------------------------------------
# KW_ONLY sentinel — class name and qualname
#
# dataclasses.KW_ONLY is a sentinel added in Python 3.10 to mark keyword-only
# fields. dataclasses.zspec.zsdl covered MISSING.__class__.__name__; no spec
# has covered KW_ONLY.__class__.__name__ or __class__.__qualname__.
# ---------------------------------------------------------------------------

invariant dataclasses_extra10.KW_ONLY.class_name:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — sentinel object class name"
  category: sentinels
  version: ">=3.10"
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true

invariant dataclasses_extra10.KW_ONLY.class_qualname:
  description: "dataclasses.KW_ONLY.__class__.__qualname__ == '_KW_ONLY_TYPE'"
  category: sentinels
  version: ">=3.10"
  kind: python_call_eq
  function: KW_ONLY.__class__.__qualname__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true

# ---------------------------------------------------------------------------
# MISSING sentinel — __class__.__qualname__
#
# dataclasses.zspec.zsdl and dataclasses_extra7 covered MISSING.__class__.__name__
# == '_MISSING_TYPE'. No prior spec checks MISSING.__class__.__qualname__.
# As a top-level class the qualname equals the name.
# ---------------------------------------------------------------------------

invariant dataclasses_extra10.MISSING.class_qualname:
  description: "dataclasses.MISSING.__class__.__qualname__ == '_MISSING_TYPE'"
  category: sentinels
  kind: python_call_eq
  function: MISSING.__class__.__qualname__.__eq__
  args: ["_MISSING_TYPE"]
  expected: true
