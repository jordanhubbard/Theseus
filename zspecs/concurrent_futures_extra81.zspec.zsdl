    - [ppe_base_cross,  "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra81
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra81.ThreadPoolExecutor_base_name:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor directly subclasses Executor, which is the abstract base for all executors; NEW in extra81: first standalone __bases__[0].__name__ invariant for ThreadPoolExecutor in cfextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__bases__[0].__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra81.ThreadPoolExecutor_mro_len:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object], length 3; NEW in extra81: first standalone __mro__.__len__ invariant for ThreadPoolExecutor in cfextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra81.Executor_mro_len:
  description: "concurrent.futures.Executor.__mro__.__len__() == 2 — MRO is [Executor, object], length 2; Executor directly subclasses object with no intermediate bases; NEW in extra81: first standalone __mro__.__len__ invariant for Executor in cfextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra81.ProcessPoolExecutor_base_name:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ProcessPoolExecutor directly subclasses Executor, sharing the same base as ThreadPoolExecutor; NEW in extra81: first standalone __bases__[0].__name__ invariant for ProcessPoolExecutor in cfextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__bases__[0].__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra81.CancelledError_mro_len:
  description: "concurrent.futures.CancelledError.__mro__.__len__() == 5 — CancelledError has a 5-level MRO reflecting inheritance through the exception hierarchy; NEW in extra81: first standalone __mro__.__len__ invariant for CancelledError in cfextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__mro__.__len__
  args: []
  expected: 5
