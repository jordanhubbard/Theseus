spec: concurrent_futures_extra81
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra80.zspec.zsdl."
    - "This spec covers: wave 246 theme — concurrent.futures ThreadPoolExecutor/ProcessPoolExecutor __bases__[0].__name__ and __mro__ structure. NEW in extra81: ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ThreadPoolExecutor.__mro__.__len__()==3 (TPE, Executor, object); ProcessPoolExecutor.__bases__[0].__name__=='Executor'; ProcessPoolExecutor.__mro__.__len__()==3; Executor.__bases__[0].__name__=='object'; Executor.__mro__.__len__()==2; Future.__bases__[0].__name__=='object'; Future.__mro__.__len__()==2; CancelledError.__mro__.__len__()==5; BrokenExecutor.__mro__.__len__()==5; InvalidStateError.__mro__.__len__()==5; ThreadPoolExecutor.__name__.__len__()==18; ProcessPoolExecutor.__name__.__len__()==19; Executor.__name__.__len__()==8. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'. ThreadPoolExecutor directly subclasses Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3. MRO is [ThreadPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'. ProcessPoolExecutor directly subclasses Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3. MRO is [ProcessPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__bases__[0].__name__ == 'object'. Executor directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__mro__.__len__() == 2. MRO is [Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object'. Future directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__mro__.__len__() == 2. MRO is [Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__mro__.__len__() == 5. CancelledError inherits from concurrent.futures._base.CancelledError -> builtins.CancelledError -> builtins.BaseException -> object (5 total). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5. BrokenExecutor inherits through RuntimeError -> Exception -> BaseException -> object (5 total). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5. InvalidStateError has a 5-level MRO. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18. 'ThreadPoolExecutor' has 18 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19. 'ProcessPoolExecutor' has 19 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__name__.__len__() == 8. 'Executor' has 8 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor __bases__[0].__name__ checks — extra81
#
# Wave 246 theme: concurrent.futures TPE/PPE __bases__[0].__name__ and __mro__ structure.
#
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# Executor.__bases__[0].__name__ == 'object'
# Future.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table concurrent_futures_extra81.executor_base_names:
  description: "concurrent.futures executor __bases__[0].__name__ checks in cfextra81 namespace — wave 246 theme: concurrent.futures TPE/PPE __bases__[0].__name__ and __mro__ structure; ThreadPoolExecutor.__bases__[0].__name__=='Executor' (TPE directly subclasses Executor); ProcessPoolExecutor.__bases__[0].__name__=='Executor' (PPE directly subclasses Executor); Executor.__bases__[0].__name__=='object' (Executor directly subclasses object); Future.__bases__[0].__name__=='object' (Future directly subclasses object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra81

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_base_name,  "ThreadPoolExecutor.__bases__[0].__name__.__eq__",  ["Executor"], true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — TPE directly subclasses Executor; verified with Python 3.14.3"]
    - [ppe_base_name,  "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — PPE directly subclasses Executor; verified with Python 3.14.3"]
    - [exec_base_name, "Executor.__bases__[0].__name__.__eq__",            ["object"],   true, "Executor.__bases__[0].__name__ == 'object' — Executor directly subclasses object; verified with Python 3.14.3"]
    - [future_base,    "Future.__bases__[0].__name__.__eq__",              ["object"],   true, "Future.__bases__[0].__name__ == 'object' — Future directly subclasses object; verified with Python 3.14.3"]

