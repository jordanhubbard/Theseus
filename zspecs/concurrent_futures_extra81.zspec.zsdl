table concurrent_futures_extra81.exception_mro_lengths:
  description: "concurrent.futures exception __mro__.__len__() checks in cfextra81 namespace — wave 246 theme: concurrent.futures exception MRO depths; CancelledError.__mro__.__len__()==5; BrokenExecutor.__mro__.__len__()==5; InvalidStateError.__mro__.__len__()==5; all three exceptions have 5-level MROs reflecting their deep inheritance hierarchies through the exception tree; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra81b

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_mro,   "CancelledError.__mro__.__len__",   [], 5, "CancelledError.__mro__.__len__() == 5 — 5-level MRO through exception hierarchy; verified with Python 3.14.3"]
    - [broken_mro,      "BrokenExecutor.__mro__.__len__",   [], 5, "BrokenExecutor.__mro__.__len__() == 5 — 5-level MRO through exception hierarchy; verified with Python 3.14.3"]
    - [invalid_mro,     "InvalidStateError.__mro__.__len__", [], 5, "InvalidStateError.__mro__.__len__() == 5 — 5-level MRO through exception hierarchy; verified with Python 3.14.3"]

