    - [tpe_mro_len,    "ThreadPoolExecutor.__mro__.__len__",  [], 3, "ThreadPoolExecutor.__mro__.__len__() == 3 — MRO: [ThreadPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [ppe_mro_len,    "ProcessPoolExecutor.__mro__.__len__", [], 3, "ProcessPoolExecutor.__mro__.__len__() == 3 — MRO: [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [exec_mro_len,   "Executor.__mro__.__len__",            [], 2, "Executor.__mro__.__len__() == 2 — MRO: [Executor, object]; verified with Python 3.14.3"]
    - [future_mro_len, "Future.__mro__.__len__",              [], 2, "Future.__mro__.__len__() == 2 — MRO: [Future, object]; verified with Python 3.14.3"]

