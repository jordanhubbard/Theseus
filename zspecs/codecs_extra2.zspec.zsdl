spec: codecs_extra2
version: ">=3.2"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/codecs.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "CPython source: internal codec state machines"
  notes:
    - "Complements codecs.zspec.zsdl and codecs_extra.zspec.zsdl."
    - "codecs_extra.zspec.zsdl covers: CodecInfo.__name__, CodecInfo.__module__, lookup return type, encode/decode UTF-8 roundtrip, open/__name__, register/__name__, getincrementalencoder/getincrementaldecoder."
    - "codecs.zspec.zsdl covers: hex codec encode/decode, BOM constants, lookup."
    - "This spec adds: BufferedIncrementalDecoder/__name__, StreamReader/__name__, StreamWriter/__name__, lookup/__name__, encode/__name__, decode/__name__, open/__name__ (via a table), and encode/decode return type checks."
    - "codecs.BufferedIncrementalDecoder is the base class for buffered incremental decoders."
    - "codecs.StreamReader and codecs.StreamWriter are base classes for codec-aware file I/O."
    - "codecs.lookup, codecs.encode, codecs.decode are implemented in _codecs (C extension); their __module__ is '_codecs'."
    - "codecs.open.__module__ is 'codecs' (pure Python wrapper)."
    - "codecs.encode('hello', 'utf-8') returns bytes; codecs.decode(b'hello', 'utf-8') returns str."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — classes not covered in codecs_extra
# ---------------------------------------------------------------------------

table codecs_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [CodecInfo,                 CodecInfo.__name__.__eq__,                 ["CodecInfo"],                 true]
    - [BufferedIncrementalDecoder, BufferedIncrementalDecoder.__name__.__eq__, ["BufferedIncrementalDecoder"], true]
    - [StreamReader,              StreamReader.__name__.__eq__,              ["StreamReader"],              true]
    - [StreamWriter,              StreamWriter.__name__.__eq__,              ["StreamWriter"],              true]

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table codecs_extra2.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [lookup,   lookup.__name__.__eq__,   ["lookup"],   true]
    - [encode,   encode.__name__.__eq__,   ["encode"],   true]
    - [decode,   decode.__name__.__eq__,   ["decode"],   true]
    - [open,     open.__name__.__eq__,     ["open"],     true]

# ---------------------------------------------------------------------------
# encode() — output type check
# ---------------------------------------------------------------------------

invariant codecs_extra2.encode.returns_bytes:
  description: "codecs.encode('hello', 'utf-8').__class__.__name__ == 'bytes'"
  category: encode_decode
  kind: python_call_eq
  function: encode
  args: ["hello", "utf-8"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# decode() — output value check
# ---------------------------------------------------------------------------

invariant codecs_extra2.decode.utf8_hello:
  description: "codecs.decode(b'hello', 'utf-8') == 'hello'"
  category: encode_decode
  kind: python_call_eq
  function: decode
  args: [!ascii "hello", "utf-8"]
  expected: "hello"
