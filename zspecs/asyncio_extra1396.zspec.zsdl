spec: asyncio_extra1396
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks and futures"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence and type checks."
    - "asyncio.Queue has __class_getitem__ in its __dict__ — type is 'method' (bound GenericAlias method)."
    - "asyncio.Task and asyncio.Future have __class_getitem__ in their __dict__ — type is 'builtin_function_or_method' (C-level)."
    - "asyncio.Lock, Event, Semaphore, Barrier, TaskGroup do NOT have __class_getitem__ in their own __dict__."
    - "All 8 asyncio classes have __init_subclass__ inherited from object; it is NOT in their own __dict__ — type is 'builtin_function_or_method'."
    - "asyncio.Queue.__class_getitem__.__class__.__name__ == 'method' (inherited via GenericAlias pattern from Python-level classmethod)."
    - "asyncio.Task.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' (C extension class)."
    - "asyncio.Future.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' (C extension class)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1396.queue_class_getitem_checks:
  description: "asyncio.Queue __class_getitem__ presence, type, and dict membership — Queue has cgi in __dict__ as 'method'; Task and Future have cgi in __dict__ as 'builtin_function_or_method'"
  kind: python_call_eq
  category: class_getitem_check
  id_prefix: as1396qc
  columns: [id, function, args, expected]
  rows:
    - [as1396qc001, asyncio.Queue.__dict__.__contains__,                                    ["__class_getitem__"],          true]
    - [as1396qc002, asyncio.Queue.__class_getitem__.__class__.__name__.__eq__,              ["method"],                    true]
    - [as1396qc003, asyncio.Task.__dict__.__contains__,                                     ["__class_getitem__"],          true]
    - [as1396qc004, asyncio.Task.__class_getitem__.__class__.__name__.__eq__,               ["builtin_function_or_method"], true]
    - [as1396qc005, asyncio.Future.__dict__.__contains__,                                   ["__class_getitem__"],          true]
    - [as1396qc006, asyncio.Future.__class_getitem__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]

table asyncio_extra1396.lock_event_semaphore_class_getitem_absent:
  description: "asyncio.Lock, Event, Semaphore, Barrier, TaskGroup do NOT have __class_getitem__ in their own __dict__"
  kind: python_call_eq
  category: class_getitem_dict_absent
  id_prefix: as1396la
  columns: [id, function, args, expected]
  rows:
    - [as1396la001, asyncio.Lock.__dict__.__contains__,      ["__class_getitem__"], false]
    - [as1396la002, asyncio.Event.__dict__.__contains__,     ["__class_getitem__"], false]
    - [as1396la003, asyncio.Semaphore.__dict__.__contains__,  ["__class_getitem__"], false]
    - [as1396la004, asyncio.Barrier.__dict__.__contains__,    ["__class_getitem__"], false]
    - [as1396la005, asyncio.TaskGroup.__dict__.__contains__,  ["__class_getitem__"], false]
    - [as1396la006, asyncio.Queue.__dict__.__contains__,      ["__init_subclass__"], false]

table asyncio_extra1396.init_subclass_type_checks:
  description: "asyncio classes all have __init_subclass__ as builtin_function_or_method (inherited from object, not in own __dict__)"
  kind: python_call_eq
  category: init_subclass_check
  id_prefix: as1396is
  columns: [id, function, args, expected]
  rows:
    - [as1396is001, asyncio.Queue.__init_subclass__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [as1396is002, asyncio.Task.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [as1396is003, asyncio.Future.__init_subclass__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [as1396is004, asyncio.Lock.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [as1396is005, asyncio.Event.__init_subclass__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [as1396is006, asyncio.Semaphore.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [as1396is007, asyncio.Barrier.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [as1396is008, asyncio.TaskGroup.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
