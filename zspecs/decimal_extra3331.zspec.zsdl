spec: dc3331
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (dc3331): __iand__, __ior__, __ixor__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __iand__, __ior__, __ixor__ dict-presence (in-place &=, |=, ^=)."
    - "decimal.Decimal does NOT define __iand__ in its own __dict__: false. Decimal is a decimal floating-point numeric type; bitwise AND is not defined for arbitrary-precision decimal arithmetic. Waves 661/665 confirmed __and__, __or__, __xor__ and __rand__, __ror__, __rxor__ are all false; in-place variants are also false."
    - "decimal.Decimal does NOT define __ior__ in its own __dict__: false. Same reason; bitwise OR has no meaning for decimal.Decimal values."
    - "decimal.Decimal does NOT define __ixor__ in its own __dict__: false. Same reason; bitwise XOR has no meaning for decimal.Decimal values."
    - "decimal.Context does NOT define __iand__, __ior__, or __ixor__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "Consistent with waves 661/665 (__and__/__or__/__xor__ and __rand__/__ror__/__rxor__ all false) and waves 666/667/668 (in-place arithmetic/shift operators all false): the complete set of bitwise and in-place operators is absent from decimal.Decimal.__dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iand__ dict-presence — operator.contains(Cls.__dict__, '__iand__')
#
# decimal.Decimal does NOT define __iand__ in its own __dict__: false.
# Decimal is a decimal floating-point type; bitwise AND is not defined for
# arbitrary-precision decimal arithmetic. Waves 661/665 confirmed __and__ and
# __rand__ are also absent. All decimal classes: false.
# ---------------------------------------------------------------------------

table dc3331.iand:
  description: "decimal types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3331

  columns: [id, function, args, expected]
  rows:
    - ["dc3331001", operator.contains, [decimal.Decimal.__dict__,          "__iand__"], false]
    - ["dc3331002", operator.contains, [decimal.Context.__dict__,           "__iand__"], false]
    - ["dc3331003", operator.contains, [decimal.DecimalException.__dict__,  "__iand__"], false]
    - ["dc3331004", operator.contains, [decimal.InvalidOperation.__dict__,  "__iand__"], false]
    - ["dc3331005", operator.contains, [decimal.Overflow.__dict__,          "__iand__"], false]
    - ["dc3331006", operator.contains, [decimal.Underflow.__dict__,         "__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — operator.contains(Cls.__dict__, '__ior__')
#
# decimal.Decimal does NOT define __ior__ in its own __dict__: false.
# Bitwise OR is not defined for decimal floating-point arithmetic;
# Decimal neither defines __or__ nor __ior__. All decimal classes: false.
# ---------------------------------------------------------------------------

