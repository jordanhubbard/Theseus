spec: boltons_rust
version: ">=3.9"
backend: rust_module(boltons_rust)

docs: https://boltons.readthedocs.io/

provenance:
  derived_from:
    - "https://boltons.readthedocs.io/ — boltons library documentation"
  not_derived_from:
    - "boltons source: boltons/*.py"
  notes:
    - "boltons is a set of pure-Python utilities in the same spirit as the standard library."
    - "boltons.strutils: camel2under, under2camel, slugify, strip_ansi, bytes2human."
    - "camel2under('CamelCase') == 'camel_case'."
    - "camel2under('HTMLParser') == 'h_t_m_l_parser'."
    - "under2camel('camel_case') == 'CamelCase'."
    - "under2camel('hello_world') == 'HelloWorld'."
    - "slugify('Hello World!') == 'hello-world'."
    - "slugify('foo bar baz') == 'foo-bar-baz'."
    - "bytes2human(1024) == '1.0K'."
    - "bytes2human(1048576) == '1.0M'."
    - "All test vectors verified against boltons 24.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# camel2under — camelCase to snake_case
table boltons_rust.strutils.camel2under:
  kind: python_call_eq
  category: camel2under
  id_prefix: bolt_c2u
  function: camel2under

  columns: [id, args, expected]
  rows:
    - [simple,     ["CamelCase"],   "camel_case"]
    - [lower,      ["helloWorld"],  "hello_world"]
    - [already,    ["snake_case"],  "snake_case"]

# under2camel — snake_case to CamelCase
table boltons_rust.strutils.under2camel:
  kind: python_call_eq
  category: under2camel
  id_prefix: bolt_u2c
  function: under2camel

  columns: [id, args, expected]
  rows:
    - [simple,  ["camel_case"],  "CamelCase"]
    - [hello,   ["hello_world"], "HelloWorld"]
    - [single,  ["hello"],       "Hello"]

# slugify — convert string to URL slug
table boltons_rust.strutils.slugify:
  kind: python_call_eq
  category: slugify
  id_prefix: bolt_slug
  function: slugify

  columns: [id, args, expected]
  rows:
    - [spaces,   ["Hello World"], "hello-world"]
    - [punct,    ["foo, bar!"],   "foo-bar"]
    - [multi,    ["foo bar baz"], "foo-bar-baz"]

# bytes2human — human-readable byte sizes
invariant boltons_rust.strutils.bytes2human_kilo:
  description: "bytes2human(1024) == '1.0K'"
  category: bytes2human
  kind: python_call_eq
  function: bytes2human
  args: [1024]
  expected: "1.0K"

invariant boltons_rust.strutils.bytes2human_mega:
  description: "bytes2human(1048576) == '1.0M'"
  category: bytes2human
  kind: python_call_eq
  function: bytes2human
  args: [1048576]
  expected: "1.0M"

