spec: io2986
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (io2986): __len__, __length_hint__, __contains__ dict-presence checks for io types."
    - "IO stream classes are not containers or sequences — none define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Verified types: io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper."
    - "BytesIO and StringIO provide read/write but no length or membership protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# No io stream class defines __len__ in its own __dict__; all false.
# ---------------------------------------------------------------------------

table io2986.len:
  description: "io types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2986
  columns: [id, function, args, expected]
  rows:
    - ["io2986001", operator.contains, [io.IOBase.__dict__,        "__len__"], false]
    - ["io2986002", operator.contains, [io.RawIOBase.__dict__,     "__len__"], false]
    - ["io2986003", operator.contains, [io.BufferedIOBase.__dict__, "__len__"], false]
    - ["io2986004", operator.contains, [io.TextIOBase.__dict__,    "__len__"], false]
    - ["io2986005", operator.contains, [io.BytesIO.__dict__,       "__len__"], false]
    - ["io2986006", operator.contains, [io.StringIO.__dict__,      "__len__"], false]

