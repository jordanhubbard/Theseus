spec: fast_xml_parser
version: ">=4.0.0"
backend: node(fast-xml-parser)

docs: https://www.npmjs.com/package/fast-xml-parser

provenance:
  derived_from:
    - "fast-xml-parser README — https://www.npmjs.com/package/fast-xml-parser"
    - "Test vectors verified with fast-xml-parser via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fast-xml-parser source"
  notes:
    - "fast-xml-parser is an npm package. Install: npm install fast-xml-parser"
    - "new XMLParser().parse(xml) parses an XML string to a JavaScript object."
    - "Multiple sibling elements with the same tag become an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fast_xml_parser.parse:
  kind: node_constructor_call_eq
  class: XMLParser
  ctor_args: []
  method: parse
  category: parse
  id_prefix: fxmlp

  columns: [id, args, expected]
  rows:
    - [single,  ["<root><item>hello</item></root>"],
       {"root": {"item": "hello"}}]
    - [multi,   ["<root><item>a</item><item>b</item></root>"],
       {"root": {"item": ["a", "b"]}}]
    - [nested,  ["<person><name>Alice</name><age>30</age></person>"],
       {"person": {"name": "Alice", "age": 30}}]
