spec: prepend_http
version: ">=4.0.0"
backend: node(prepend-http)

docs: https://github.com/sindresorhus/prepend-http#readme

provenance:
  derived_from:
    - "prepend-http README — https://github.com/sindresorhus/prepend-http#readme"
    - "Test vectors verified with prepend-http via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "prepend-http source"
  notes:
    - "Prepends 'https://' to a URL if no protocol is present."
    - "Install: npm install prepend-http"
    - "v4 ESM with CJS shim; default export is the function. Default protocol is https (was http in older versions)."
    - "Already-prefixed URLs (http:, https:, //) are returned unchanged."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table prepend_http.prepend:
  kind: node_module_call_eq
  category: prepend
  function: default
  id_prefix: prepend

  columns: [id, args, expected]
  rows:
    - [bare_domain_default_https,
       ["example.com"],
       "https://example.com"]

    - [http_unchanged,
       ["http://example.com"],
       "http://example.com"]

    - [https_unchanged,
       ["https://example.com"],
       "https://example.com"]

    - [protocol_relative_unchanged,
       ["//example.com"],
       "//example.com"]

    - [path_only_with_https,
       ["example.com/foo"],
       "https://example.com/foo"]

    - [explicit_http_option,
       ["example.com", {https: false}],
       "http://example.com"]
