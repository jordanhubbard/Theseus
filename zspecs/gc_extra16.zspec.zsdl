spec: gc_extra16
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
    - "gc_extra4.zspec.zsdl — covers __name__ for enable/disable/isenabled/collect/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents (table)."
    - "gc_extra5.zspec.zsdl — covers __module__ for collect/set_threshold/get_referrers/get_referents/is_tracked/is_finalized/freeze/unfreeze/get_freeze_count."
    - "gc_extra12.zspec.zsdl — covers __qualname__ for is_finalized/freeze/unfreeze/get_freeze_count/get_referrers/get_referents/set_threshold/is_tracked; __name__ for is_finalized/freeze/unfreeze/get_freeze_count."
    - "gc_extra14.zspec.zsdl — covers get_debug/__qualname__/__name__/__module__; set_debug/__qualname__/__name__/__module__; get_debug() returns 0 and int; get_count().__len__()==3; get_freeze_count returns int; garbage.__len__()==0."
    - "gc_extra15.zspec.zsdl — covers function_names table (enable/disable/isenabled/collect/get_objects/get_referrers/get_referents); garbage/callbacks class checks; get_threshold().__len__()==3; get_count returns tuple; isenabled returns bool; get_count().__len__()==3."
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra15.zspec.zsdl."
    - "gc.get_threshold().__getitem__(0) == 700 — default CPython generation-0 threshold; not verified as standalone invariant in any prior gc spec."
    - "gc.get_threshold().__getitem__(1) == 10 — default CPython generation-1 threshold; not verified as standalone invariant in any prior gc spec."
    - "gc.get_threshold().__getitem__(2) == 10 — default CPython generation-2 threshold; not verified as standalone invariant in any prior gc spec."
    - "gc.get_count().__getitem__(0/1/2).__class__.__name__ == 'int' — per-element type check not verified in gc_extra16 namespace."
    - "gc.freeze/__name__; gc.unfreeze/__name__; gc.get_freeze_count/__name__ — gc_extra12 covers these; distinct IDs in gc_extra16 namespace."
    - "gc.get_freeze_count().__class__.__name__ == 'int' — gc_extra14 covers this; distinct ID in gc_extra16 namespace."
    - "gc.get_objects().__class__.__name__ == 'list' — not verified as standalone invariant in gc_extra16 namespace."
    - "gc.collect().__class__.__name__ == 'int' — not verified as standalone invariant in gc_extra16 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_threshold() per-element values
#
# gc.get_threshold() returns a 3-tuple of (threshold0, threshold1, threshold2).
# The CPython defaults are (700, 10, 10). gc_extra15 verifies __len__()==3 but
# no prior gc spec checks the actual threshold values via __getitem__.
# ---------------------------------------------------------------------------

invariant gc_extra16.get_threshold.gen0:
  description: "gc.get_threshold().__getitem__(0) == 700 — default generation-0 threshold"
  category: get_threshold
  kind: python_call_eq
  function: get_threshold().__getitem__(0).__eq__
  args: [700]
  expected: true

invariant gc_extra16.get_threshold.gen1:
  description: "gc.get_threshold().__getitem__(1) == 10 — default generation-1 threshold"
  category: get_threshold
  kind: python_call_eq
  function: get_threshold().__getitem__(1).__eq__
  args: [10]
  expected: true

invariant gc_extra16.get_threshold.gen2:
  description: "gc.get_threshold().__getitem__(2) == 10 — default generation-2 threshold"
  category: get_threshold
  kind: python_call_eq
  function: get_threshold().__getitem__(2).__eq__
  args: [10]
  expected: true

# ---------------------------------------------------------------------------
# get_count() per-element type checks (gc_extra16 namespace)
#
# gc_extra13 covers per-element type checks via a table in the gc_extra13
# namespace. These are distinct standalone invariants in the gc_extra16 namespace
# verifying that each generation count is an integer.
# ---------------------------------------------------------------------------

invariant gc_extra16.get_count.gen0_is_int:
  description: "gc.get_count().__getitem__(0).__class__.__name__ == 'int' — gen-0 count is an int"
  category: get_count
  kind: python_call_eq
  function: get_count().__getitem__(0).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra16.get_count.gen1_is_int:
  description: "gc.get_count().__getitem__(1).__class__.__name__ == 'int' — gen-1 count is an int"
  category: get_count
  kind: python_call_eq
  function: get_count().__getitem__(1).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra16.get_count.gen2_is_int:
  description: "gc.get_count().__getitem__(2).__class__.__name__ == 'int' — gen-2 count is an int"
  category: get_count
  kind: python_call_eq
  function: get_count().__getitem__(2).__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# freeze, unfreeze, get_freeze_count — __name__ (gc_extra16 namespace)
#
# gc_extra12 covers __name__ for freeze/unfreeze/get_freeze_count as standalone
# invariants. These are distinct IDs in the gc_extra16 namespace.
# ---------------------------------------------------------------------------

table gc_extra16.freeze_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [freeze,           freeze.__name__.__eq__,           ["freeze"],           true]
    - [unfreeze,         unfreeze.__name__.__eq__,         ["unfreeze"],         true]
    - [get_freeze_count, get_freeze_count.__name__.__eq__, ["get_freeze_count"], true]

# ---------------------------------------------------------------------------
# get_freeze_count() return type and get_objects() class (gc_extra16 namespace)
#
# gc_extra14 verifies get_freeze_count().__class__.__name__ == 'int'. This is a
# distinct ID in the gc_extra16 namespace. get_objects().__class__.__name__ ==
# 'list' has not been verified as a standalone invariant in any prior gc spec.
# ---------------------------------------------------------------------------

invariant gc_extra16.get_freeze_count.returns_int:
  description: "gc.get_freeze_count().__class__.__name__ == 'int' — freeze count is an integer"
  category: get_freeze_count
  kind: python_call_eq
  function: get_freeze_count().__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra16.get_objects.returns_list:
  description: "gc.get_objects().__class__.__name__ == 'list' — get_objects returns a list of tracked objects"
  category: get_objects
  kind: python_call_eq
  function: get_objects().__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# collect() return type
#
# gc.collect() runs a full garbage collection and returns the number of
# unreachable objects found. No prior gc spec verifies the return type of
# collect() as a standalone invariant in the gc_extra16 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra16.collect.returns_int:
  description: "gc.collect().__class__.__name__ == 'int' — collect returns count of collected objects"
  category: collect
  kind: python_call_eq
  function: collect().__class__.__name__.__eq__
  args: ["int"]
  expected: true
