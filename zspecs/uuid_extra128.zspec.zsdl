spec: uuid_extra128
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra127.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__ __name__ equality / UUID dunder __class__.__name__=='function' / UUID.__init__ co_argcount==7 and co_varnames.__len__()==15 / UUID.__new__ identity (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality (table + invariants)."
    - "uuid_extra122.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__ co_varnames[0] ('self') and co_varnames.__len__() / co_argcount for __str__/__repr__/__eq__ (table + invariants)."
    - "uuid_extra125.zspec.zsdl — covers uuid.getnode/__name__/__qualname__/__module__/co_argcount/co_name identity / uuid1/uuid3/uuid5/uuid4 co_varnames[0] / uuid.SafeUUID identity (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__.__name__/__qualname__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 358 theme: uuid.UUID comparison operator (__le__, __gt__, __ge__) qualname, __name__, __class__.__name__, __module__, co_argcount, co_name / UUID.__repr__ and __hash__ co_name and co_varnames.__len__()."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__code__.co_name == '__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__code__.co_name == '__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__code__.co_name == '__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__class__.__name__ == 'function'. All comparison dunders are pure-Python functions. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__name__ == '__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__name__ == '__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__name__ == '__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_name == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__code__.co_name == '__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_varnames.__len__() == 1 (only 'self'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__code__.co_varnames.__len__() == 2 ('self', 'other'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid_extra99 anchors UUID.__lt__ qualname. uuid_extra127 anchors UUID dunder __name__ for __init__/__str__/__repr__/__eq__/__hash__. This spec is the first to anchor UUID.__le__/__gt__/__ge__ qualname, __name__, __class__.__name__, __module__, co_argcount, co_name, co_varnames.__len__(), and UUID.__repr__/__hash__ co_name under uuidcmp128."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__')
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__')
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__')
# uuid.UUID.__le__.__class__.__name__.__eq__('function')
# uuid.UUID.__le__.__module__.__eq__('uuid')
#
# Wave 358 theme: uuid.UUID remaining comparison operator qualnames.
#
# uuid.UUID implements a full set of comparison operators: __eq__, __hash__,
# __lt__, __le__, __gt__, __ge__. They compare UUIDs by their integer value
# (self.int), making UUIDs totally ordered. uuid_extra99 anchors __lt__ qualname;
# this spec anchors the remaining three: __le__, __gt__, __ge__. All are pure-
# Python functions (function, not method_descriptor or wrapper_descriptor) defined
# in Lib/uuid.py, with __module__=='uuid'. No prior uuid spec anchors these
# three qualnames via __eq__ under uuidcmp128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra128.UUID_comparison_qualnames:
  description: "uuid.UUID/__le__/__qualname__.__eq__('UUID.__le__')==True / __gt__/__qualname__.__eq__('UUID.__gt__')==True / __ge__/__qualname__.__eq__('UUID.__ge__')==True / __le__/__class__/__name__.__eq__('function')==True / __le__/__module__.__eq__('uuid')==True — UUID comparison operators are pure-Python functions; all compare by self.int; extra99 anchors __lt__ qualname; first uuidcmp128 anchor for __le__/__gt__/__ge__ qualname"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidcmp128

  columns: [id, function, args, expected, description]
  rows:
    - [le_qualname,  UUID.__le__.__qualname__.__eq__,             ["UUID.__le__"],  true, "UUID.__le__.__qualname__ is 'UUID.__le__' (less-than-or-equal; compares self.int <= other.int)"]
    - [gt_qualname,  UUID.__gt__.__qualname__.__eq__,             ["UUID.__gt__"],  true, "UUID.__gt__.__qualname__ is 'UUID.__gt__' (greater-than; compares self.int > other.int)"]
    - [ge_qualname,  UUID.__ge__.__qualname__.__eq__,             ["UUID.__ge__"],  true, "UUID.__ge__.__qualname__ is 'UUID.__ge__' (greater-than-or-equal; compares self.int >= other.int)"]
    - [le_cls,       UUID.__le__.__class__.__name__.__eq__,       ["function"],     true, "UUID.__le__.__class__.__name__ is 'function' (pure-Python; all UUID comparison operators are functions)"]
    - [le_module,    UUID.__le__.__module__.__eq__,               ["uuid"],         true, "UUID.__le__.__module__ is 'uuid' (defined in Lib/uuid.py alongside __lt__/__gt__/__ge__)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__name__.__eq__('__le__')
# uuid.UUID.__gt__.__name__.__eq__('__gt__')
# uuid.UUID.__ge__.__name__.__eq__('__ge__')
# uuid.UUID.__le__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__le__.__code__.co_name.__eq__('__le__')
#
# Wave 358 theme: UUID comparison operator __name__ and code attributes.
#
# The __name__ attribute of a Python function is the short name as it appears
# in the def statement (without the class qualifier). UUID.__le__.__name__ is
# '__le__' (7 chars). The co_argcount for all four comparison operators (__le__,
# __lt__, __gt__, __ge__) is 2: self and other. The co_name matches the __name__.
# uuid_extra127 anchors __init__/__str__/__repr__/__eq__/__hash__ __name__; this
# spec anchors __le__/__gt__/__ge__ __name__ for the first time under uuidcmp128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra128.UUID_comparison_names_and_code:
  description: "uuid.UUID/__le__/__name__.__eq__('__le__')==True / __gt__/__name__.__eq__('__gt__')==True / __ge__/__name__.__eq__('__ge__')==True / __le__/__code__/co_argcount.__eq__(2)==True / __le__/__code__/co_name.__eq__('__le__')==True — comparison operators take 2 args (self+other); co_name matches __name__; extra127 anchors __init__/__str__ etc. __name__; first uuidcmp128 anchor for __le__/__gt__/__ge__ __name__ and code attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidcmp128

  columns: [id, function, args, expected, description]
  rows:
    - [le_name,      UUID.__le__.__name__.__eq__,                 ["__le__"],  true, "UUID.__le__.__name__ is '__le__' (short form; qualname is 'UUID.__le__')"]
    - [gt_name,      UUID.__gt__.__name__.__eq__,                 ["__gt__"],  true, "UUID.__gt__.__name__ is '__gt__' (short form; qualname is 'UUID.__gt__')"]
    - [ge_name,      UUID.__ge__.__name__.__eq__,                 ["__ge__"],  true, "UUID.__ge__.__name__ is '__ge__' (short form; qualname is 'UUID.__ge__')"]
    - [le_argcount,  UUID.__le__.__code__.co_argcount.__eq__,     [2],         true, "UUID.__le__.__code__.co_argcount is 2 (self + other; same as __lt__/__gt__/__ge__)"]
    - [le_co_name,   UUID.__le__.__code__.co_name.__eq__,         ["__le__"],  true, "UUID.__le__.__code__.co_name is '__le__' (co_name always equals __name__ for simple methods)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__ge__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__')
# uuid.UUID.__hash__.__code__.co_name.__eq__('__hash__')
# uuid.UUID.__repr__.__code__.co_varnames.__len__().__eq__(1)
#
# Wave 358 theme: UUID comparison co_argcount cross-check and __repr__/__hash__ co attrs.
#
# All four comparison operators (__lt__, __le__, __gt__, __ge__) have co_argcount==2.
# uuid.UUID.__repr__.__code__.co_varnames has exactly 1 element: ('self',) because
# __repr__ takes no other arguments and has no local variables. By contrast,
# UUID.__str__ has co_varnames.__len__()==2 (self and x), since __str__ computes
# a local variable. UUID.__hash__.__code__.co_name == '__hash__' confirms the
# function name in the code object. No prior uuid spec anchors these code attrs
# under uuidcmp128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra128.UUID_code_attrs_cross_check:
  description: "uuid.UUID/__gt__/__code__/co_argcount.__eq__(2)==True / __ge__/__code__/co_argcount.__eq__(2)==True / __repr__/__code__/co_name.__eq__('__repr__')==True / __hash__/__code__/co_name.__eq__('__hash__')==True / __repr__/__code__/co_varnames/__len__()==1 — all comparison ops take 2 args; __repr__ has 1 co_varname ('self' only); __hash__ co_name=='__hash__'; first uuidcmp128 anchor for __gt__/__ge__ co_argcount and __repr__/__hash__ co_name and co_varnames len"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidcmp128

  columns: [id, function, args, expected, description]
  rows:
    - [gt_argcount,     UUID.__gt__.__code__.co_argcount.__eq__,           [2],         true, "UUID.__gt__.__code__.co_argcount is 2 (self + other; consistent with __lt__/__le__/__ge__)"]
    - [ge_argcount,     UUID.__ge__.__code__.co_argcount.__eq__,           [2],         true, "UUID.__ge__.__code__.co_argcount is 2 (self + other; all comparison ops take exactly 2 args)"]
    - [repr_co_name,    UUID.__repr__.__code__.co_name.__eq__,             ["__repr__"], true, "UUID.__repr__.__code__.co_name is '__repr__' (code object name matches __name__)"]
    - [hash_co_name,    UUID.__hash__.__code__.co_name.__eq__,             ["__hash__"], true, "UUID.__hash__.__code__.co_name is '__hash__' (code object name matches __name__)"]
    - [repr_varlen,     UUID.__repr__.__code__.co_varnames.__len__,        [],           1,    "UUID.__repr__ has 1 co_varname ('self' only; no local temporaries unlike __str__ which has 'x')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') — standalone
#
# uuid.UUID.__le__.__qualname__ is 'UUID.__le__'. UUID implements total ordering
# by providing all six comparison methods explicitly (__eq__, __ne__ via inheritance,
# __lt__, __le__, __gt__, __ge__). Python's @functools.total_ordering decorator was
# NOT used — UUID defines all four ordering operators directly. The __le__ method
# (less-than-or-equal) compares self.int <= other.int. Its __qualname__ 'UUID.__le__'
# carries the class prefix 'UUID.' confirming it is defined by the UUID class.
# uuid_extra99 anchors UUID.__lt__ qualname; this is the first standalone for
# UUID.__le__.__qualname__.__eq__ under uuidcmp128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra128.UUID_le_qualname:
  description: "uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') == True — UUID defines all comparison ops explicitly (not via @total_ordering); __le__ compares self.int <= other.int; extra99 anchors __lt__ qualname; first standalone for UUID.__le__.__qualname__.__eq__ under uuidcmp128"
  category: type_identity
  kind: python_call_eq
  function: UUID.__le__.__qualname__.__eq__
  args: ["UUID.__le__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') — standalone
#
# uuid.UUID.__gt__.__qualname__ is 'UUID.__gt__'. The greater-than comparison
# __gt__ compares self.int > other.int. UUID integers are 128-bit values (stored
# in self.int), so the comparison is an integer comparison. All UUID versions
# (1, 3, 4, 5, 6, 7, 8) produce UUIDs that can be ordered, though only UUID
# version 7 is designed for time-ordered monotonic sequences. The __qualname__
# 'UUID.__gt__' confirms this is a UUID-defined method, not inherited from object
# (which defines __gt__ as the default NotImplemented-returning stub). No prior
# uuid spec anchors UUID.__gt__.__qualname__ via __eq__ as a standalone under
# uuidcmp128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra128.UUID_gt_qualname:
  description: "uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') == True — UUID defines __gt__ explicitly (compares self.int > other.int); all UUID versions are orderable; extra99 anchors __lt__; first standalone for UUID.__gt__.__qualname__.__eq__ under uuidcmp128"
  category: type_identity
  kind: python_call_eq
  function: UUID.__gt__.__qualname__.__eq__
  args: ["UUID.__gt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') — standalone
#
# uuid.UUID.__ge__.__qualname__ is 'UUID.__ge__'. The greater-than-or-equal
# comparison __ge__ compares self.int >= other.int. Together with __le__, __gt__,
# and __lt__, UUID supports full sorting via sorted() and bisect operations.
# The qualname 'UUID.__ge__' uses the 'UUID.' prefix (same as all other UUID
# dunder methods), contrasting with inherited methods that would show their
# defining class (e.g., 'object.__ne__' if UUID didn't define __ne__). No prior
# uuid spec anchors UUID.__ge__.__qualname__ via __eq__ as a standalone under
# uuidcmp128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra128.UUID_ge_qualname:
  description: "uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') == True — UUID defines __ge__ explicitly (compares self.int >= other.int); supports full sorting; qualname 'UUID.__ge__' with 'UUID.' prefix; extra99 anchors __lt__; first standalone for UUID.__ge__.__qualname__.__eq__ under uuidcmp128"
  category: type_identity
  kind: python_call_eq
  function: UUID.__ge__.__qualname__.__eq__
  args: ["UUID.__ge__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__code__.co_argcount.__eq__(2) — standalone
#
# uuid.UUID.__le__.__code__.co_argcount is 2. The co_argcount for all UUID
# comparison operators is 2: the 'self' (the UUID being compared) and 'other'
# (the right-hand operand). uuid_extra122 anchors co_argcount==2 for UUID.__eq__
# (which also takes self+other). This standalone confirms the same applies to
# UUID.__le__ and establishes the pattern for all four ordering operators. No
# prior uuid spec anchors UUID.__le__.__code__.co_argcount via __eq__ as a
# standalone under uuidcmp128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra128.UUID_le_co_argcount_2:
  description: "uuid.UUID.__le__.__code__.co_argcount.__eq__(2) == True — UUID.__le__ takes 2 positional args: self + other; same pattern as __lt__/__gt__/__ge__/__eq__ (all comparison ops take self+other); extra122 anchors __eq__.co_argcount==2; first standalone for __le__.co_argcount.__eq__(2) under uuidcmp128"
  category: type_identity
  kind: python_call_eq
  function: UUID.__le__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_varnames.__len__().__eq__(1) — standalone
#
# uuid.UUID.__repr__.__code__.co_varnames.__len__() is 1. The co_varnames tuple
# contains exactly one element: ('self',). UUID.__repr__ is a simple one-liner
# that returns f'UUID({str(self)!r})' — it uses no local variables beyond the
# implicit 'self' parameter. This contrasts with UUID.__str__ which has
# co_varnames.__len__()==2 because __str__ computes a local variable 'x' during
# hex formatting. uuid_extra122 anchors co_varnames len for __str__(2)/__repr__(1)
# at table level; this is the first standalone for __repr__.co_varnames.__len__()
# ==1 via __eq__ call under uuidcmp128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra128.UUID_repr_co_varnames_len_1:
  description: "uuid.UUID.__repr__.__code__.co_varnames.__len__() == 1 — __repr__ has only 'self' in co_varnames (no local temporaries); returns f'UUID({str(self)!r})' as a one-liner; contrasts with __str__ which has len==2 (self+x for hex work); extra122 anchors this at table level; first standalone for __repr__.co_varnames.__len__()==1 under uuidcmp128"
  category: type_identity
  kind: python_call_eq
  function: UUID.__repr__.__code__.co_varnames.__len__
  args: []
  expected: 1

