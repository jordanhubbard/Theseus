spec: pathlib_extra1696
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/*.py"
    - "pathlib.zspec.zsdl — covers core pathlib type attributes and path construction"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "pathlib.PurePath defines __reduce__ in its own __dict__ — this is how all Path objects support pickling."
    - "pathlib.PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath do NOT define __reduce__ in their own __dict__ — they inherit from PurePath."
    - "No pathlib type defines __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__ in its own __dict__."
    - "No pathlib type defines __copy__ or __deepcopy__ in its own __dict__."
    - "WindowsPath exists as a class on macOS/Darwin but can only be instantiated on Windows."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol
#
# Records whether each pathlib type defines the five pickling dunder methods
# directly in its own __dict__.
#
# pathlib.PurePath: __reduce__ → True; all others → False.
# All subclasses (PurePosixPath, PureWindowsPath, Path, PosixPath,
# WindowsPath): all five → False (inherit __reduce__ from PurePath).
# ---------------------------------------------------------------------------

table pathlib_extra1696.pickling_protocol:
  description: "pathlib types pickling protocol dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol
  id_prefix: pl1696

  columns: [id, function, args, expected]
  rows:
    - ["pl1696001", "pathlib.PurePath.__dict__.__contains__",        ["__reduce__"],        true]
    - ["pl1696002", "pathlib.PurePath.__dict__.__contains__",        ["__getstate__"],      false]
    - ["pl1696003", "pathlib.PurePath.__dict__.__contains__",        ["__setstate__"],      false]
    - ["pl1696004", "pathlib.PurePath.__dict__.__contains__",        ["__getnewargs__"],    false]
    - ["pl1696005", "pathlib.PurePath.__dict__.__contains__",        ["__getnewargs_ex__"], false]
    - ["pl1696006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__reduce__"],        false]
    - ["pl1696007", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getstate__"],      false]
    - ["pl1696008", "pathlib.PurePosixPath.__dict__.__contains__",   ["__setstate__"],      false]
    - ["pl1696009", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reduce__"],        false]
    - ["pl1696010", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getstate__"],      false]
    - ["pl1696011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__setstate__"],      false]
    - ["pl1696012", "pathlib.Path.__dict__.__contains__",            ["__reduce__"],        false]
    - ["pl1696013", "pathlib.Path.__dict__.__contains__",            ["__getstate__"],      false]
    - ["pl1696014", "pathlib.Path.__dict__.__contains__",            ["__setstate__"],      false]
    - ["pl1696015", "pathlib.Path.__dict__.__contains__",            ["__getnewargs__"],    false]
    - ["pl1696016", "pathlib.Path.__dict__.__contains__",            ["__getnewargs_ex__"], false]
    - ["pl1696017", "pathlib.PosixPath.__dict__.__contains__",       ["__reduce__"],        false]
    - ["pl1696018", "pathlib.PosixPath.__dict__.__contains__",       ["__getstate__"],      false]
    - ["pl1696019", "pathlib.WindowsPath.__dict__.__contains__",     ["__reduce__"],        false]
    - ["pl1696020", "pathlib.WindowsPath.__dict__.__contains__",     ["__getstate__"],      false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol
#
# Checks whether pathlib types define __copy__ or __deepcopy__ in their own
# __dict__.  No pathlib type does — path objects are immutable value types
# and rely on default copy semantics (not custom protocols).
# ---------------------------------------------------------------------------

table pathlib_extra1696.copy_protocol:
  description: "pathlib types copy protocol (__copy__, __deepcopy__) dict-presence checks"
  kind: python_call_eq
  category: copy_protocol
  id_prefix: pl1696

  columns: [id, function, args, expected]
  rows:
    - ["pl1696030", "pathlib.PurePath.__dict__.__contains__",        ["__copy__"],     false]
    - ["pl1696031", "pathlib.PurePath.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["pl1696032", "pathlib.PurePosixPath.__dict__.__contains__",   ["__copy__"],     false]
    - ["pl1696033", "pathlib.PurePosixPath.__dict__.__contains__",   ["__deepcopy__"], false]
    - ["pl1696034", "pathlib.PureWindowsPath.__dict__.__contains__", ["__copy__"],     false]
    - ["pl1696035", "pathlib.PureWindowsPath.__dict__.__contains__", ["__deepcopy__"], false]
    - ["pl1696036", "pathlib.Path.__dict__.__contains__",            ["__copy__"],     false]
    - ["pl1696037", "pathlib.Path.__dict__.__contains__",            ["__deepcopy__"], false]
    - ["pl1696038", "pathlib.PosixPath.__dict__.__contains__",       ["__copy__"],     false]
    - ["pl1696039", "pathlib.PosixPath.__dict__.__contains__",       ["__deepcopy__"], false]
    - ["pl1696040", "pathlib.WindowsPath.__dict__.__contains__",     ["__copy__"],     false]
    - ["pl1696041", "pathlib.WindowsPath.__dict__.__contains__",     ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: reduce_inheritance_contrast
#
# Confirms that __reduce__ is defined exactly on PurePath and inherited by
# all subclasses (none redefine it), and contrasts with structural attrs
# that ARE defined on subclasses directly.
# ---------------------------------------------------------------------------

table pathlib_extra1696.reduce_inheritance_contrast:
  description: "PurePath.__reduce__ defined there; subclasses inherit but do not redefine"
  kind: python_call_eq
  category: reduce_inheritance_contrast
  id_prefix: pl1696

  columns: [id, function, args, expected]
  rows:
    - ["pl1696050", "pathlib.PurePath.__dict__.__contains__",        ["__reduce__"], true]
    - ["pl1696051", "pathlib.PurePosixPath.__dict__.__contains__",   ["__reduce__"], false]
    - ["pl1696052", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reduce__"], false]
    - ["pl1696053", "pathlib.Path.__dict__.__contains__",            ["__reduce__"], false]
    - ["pl1696054", "pathlib.PosixPath.__dict__.__contains__",       ["__reduce__"], false]
    - ["pl1696055", "pathlib.WindowsPath.__dict__.__contains__",     ["__reduce__"], false]
    - ["pl1696056", "pathlib.PurePath.__dict__.__contains__",        ["__str__"],    true]
    - ["pl1696057", "pathlib.PurePath.__dict__.__contains__",        ["__fspath__"], true]
    - ["pl1696058", "pathlib.PurePath.__dict__.__contains__",        ["__hash__"],   true]
    - ["pl1696059", "pathlib.Path.__dict__.__contains__",            ["__str__"],    false]
    - ["pl1696060", "pathlib.Path.__dict__.__contains__",            ["__hash__"],   false]
