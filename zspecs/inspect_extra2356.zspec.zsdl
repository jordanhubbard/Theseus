spec: inspect_extra2356
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are Python classes with custom __init__: returns 'function'."
    - "inspect.FrameInfo is a named tuple subclass: __init__ == 'wrapper_descriptor' (inherited from tuple), __new__ == 'function' (generated __new__ from namedtuple)."
    - "inspect.FrameInfo.__doc__ is None (no docstring on the FrameInfo named tuple class)."
    - "inspect.Parameter.__doc__, inspect.Signature.__doc__, inspect.BoundArguments.__doc__ are str."
    - "Module-level inspect functions (getmembers, signature, isfunction, isclass) are plain Python functions."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __init__ implementation type for inspect classes
# ---------------------------------------------------------------------------

table inspect_extra2356.init_types:
  description: "inspect class __init__ implementation type — Python classes with custom __init__ return 'function'; namedtuple subclass returns 'wrapper_descriptor'"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2356
  columns: [id, function, args, expected]
  rows:
    - ["in2356001", "inspect.Parameter.__init__.__class__.__name__",     [], "function"]
    - ["in2356002", "inspect.Signature.__init__.__class__.__name__",     [], "function"]
    - ["in2356003", "inspect.BoundArguments.__init__.__class__.__name__", [], "function"]
    - ["in2356004", "inspect.FrameInfo.__init__.__class__.__name__",     [], "wrapper_descriptor"]

# ---------------------------------------------------------------------------
# __new__ implementation type for inspect classes
# ---------------------------------------------------------------------------

table inspect_extra2356.new_types:
  description: "inspect class __new__ implementation type — Python classes without custom __new__ return 'builtin_function_or_method'; FrameInfo namedtuple __new__ is 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2356
  columns: [id, function, args, expected]
  rows:
    - ["in2356005", "inspect.Parameter.__new__.__class__.__name__",      [], "builtin_function_or_method"]
    - ["in2356006", "inspect.Signature.__new__.__class__.__name__",      [], "builtin_function_or_method"]
    - ["in2356007", "inspect.BoundArguments.__new__.__class__.__name__", [], "builtin_function_or_method"]
    - ["in2356008", "inspect.FrameInfo.__new__.__class__.__name__",      [], "function"]

# ---------------------------------------------------------------------------
# __doc__ class names for inspect classes
# ---------------------------------------------------------------------------

table inspect_extra2356.doc_class_names:
  description: "inspect class and function __doc__.__class__.__name__ — str for documented, NoneType for undocumented (FrameInfo namedtuple has no docstring)"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2356
  columns: [id, function, args, expected]
  rows:
    - ["in2356009", "inspect.Parameter.__doc__.__class__.__name__",      [], "str"]
    - ["in2356010", "inspect.Signature.__doc__.__class__.__name__",      [], "str"]
    - ["in2356011", "inspect.BoundArguments.__doc__.__class__.__name__", [], "str"]
    - ["in2356012", "inspect.FrameInfo.__doc__.__class__.__name__",      [], "NoneType"]
    - ["in2356013", "inspect.getmembers.__doc__.__class__.__name__",     [], "str"]
    - ["in2356014", "inspect.signature.__doc__.__class__.__name__",      [], "str"]

# ---------------------------------------------------------------------------
# Module-level function __class__.__name__ — all Python functions
# ---------------------------------------------------------------------------

table inspect_extra2356.function_class_names:
  description: "inspect module-level function implementation type — all are Python functions returning 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2356
  columns: [id, function, args, expected]
  rows:
    - ["in2356015", "inspect.getmembers.__class__.__name__",  [], "function"]
    - ["in2356016", "inspect.signature.__class__.__name__",   [], "function"]
    - ["in2356017", "inspect.isfunction.__class__.__name__",  [], "function"]
    - ["in2356018", "inspect.isclass.__class__.__name__",     [], "function"]
    - ["in2356019", "inspect.ismodule.__class__.__name__",    [], "function"]
    - ["in2356020", "inspect.ismethod.__class__.__name__",    [], "function"]
