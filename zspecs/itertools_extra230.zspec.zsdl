# ---------------------------------------------------------------------------

table itertools_extra230.batched_identity:
  description: "itertools.batched identity contracts: __name__, __qualname__, __module__, name length, class type; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra230batchedid

  columns: [id, function, args, expected, description]
  rows:
    - [batched_name_eq,
       batched.__name__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__name__ == 'batched' — batched is a C extension type added in Python 3.12 that batches elements into fixed-length tuples; __name__.__eq__('batched') returns True; new to extra230"]
    - [batched_qualname_eq,
       batched.__qualname__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__qualname__ == 'batched' — batched is a top-level C type with unqualified qualname 'batched'; __qualname__.__eq__('batched') returns True; new to extra230"]
    - [batched_module_eq,
       batched.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.batched.__module__ == 'itertools' — batched reports its module as 'itertools'; __module__.__eq__('itertools') returns True; new to extra230"]
    - [batched_name_len_7,
       batched.__name__.__len__,
       [],
       7,
       "itertools.batched.__name__.__len__() == 7 — 'batched' has exactly 7 characters (b-a-t-c-h-e-d); __len__() returns 7; new to extra230"]
    - [batched_class_is_type,
       batched.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.batched.__class__.__name__ == 'type' — batched is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra230"]

