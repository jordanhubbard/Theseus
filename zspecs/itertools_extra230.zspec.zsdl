spec: itertools_extra230
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.groupby, itertools.pairwise (3.10+), and itertools.batched (3.12+) identity contracts."
    - "itertools.groupby.__name__ == 'groupby' — C extension type in itertoolsmodule.c with __name__=='groupby'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' — groupby reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__class__.__name__ == 'type' — groupby is a C extension type. Verified with Python 3.14.3."
    - "itertools.pairwise.__name__ == 'pairwise' — C extension type added in Python 3.10. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools' — pairwise reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' — C extension type added in Python 3.12. Verified with Python 3.14.3."
    - "itertools.batched.__module__ == 'itertools' — batched reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters. Verified with Python 3.14.3."
    - "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has 8 characters. Verified with Python 3.14.3."
    - "itertools.batched.__name__.__len__() == 7 — 'batched' has 7 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby identity contracts
#
# itertools.groupby.__name__ == 'groupby'
# itertools.groupby.__qualname__ == 'groupby'
# itertools.groupby.__module__ == 'itertools'
# itertools.groupby.__name__.__len__() == 7
# itertools.groupby.__class__.__name__ == 'type'
#
# New to extra230.
# ---------------------------------------------------------------------------

table itertools_extra230.groupby_identity:
  description: "itertools.groupby identity contracts: __name__, __qualname__, __module__, name length, class type; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra230groupbyid

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_eq,
       groupby.__name__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__name__ == 'groupby' — groupby is a C extension type in itertoolsmodule.c that groups consecutive elements by a key; __name__.__eq__('groupby') returns True; new to extra230"]
    - [groupby_qualname_eq,
       groupby.__qualname__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__qualname__ == 'groupby' — groupby is a top-level C type with unqualified qualname 'groupby'; __qualname__.__eq__('groupby') returns True; new to extra230"]
    - [groupby_module_eq,
       groupby.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.groupby.__module__ == 'itertools' — groupby reports its module as 'itertools'; __module__.__eq__('itertools') returns True; new to extra230"]
    - [groupby_name_len_7,
       groupby.__name__.__len__,
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — 'groupby' has exactly 7 characters (g-r-o-u-p-b-y); __len__() returns 7; new to extra230"]
    - [groupby_class_is_type,
       groupby.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.groupby.__class__.__name__ == 'type' — groupby is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra230"]

# ---------------------------------------------------------------------------
# Table 2: itertools.pairwise identity contracts (Python 3.10+)
#
# itertools.pairwise.__name__ == 'pairwise'
# itertools.pairwise.__qualname__ == 'pairwise'
# itertools.pairwise.__module__ == 'itertools'
# itertools.pairwise.__name__.__len__() == 8
# itertools.pairwise.__class__.__name__ == 'type'
#
# New to extra230.
# ---------------------------------------------------------------------------

table itertools_extra230.pairwise_identity:
  description: "itertools.pairwise identity contracts: __name__, __qualname__, __module__, name length, class type; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra230pairwiseid

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_name_eq,
       pairwise.__name__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__name__ == 'pairwise' — pairwise is a C extension type added in Python 3.10 that returns successive overlapping pairs; __name__.__eq__('pairwise') returns True; new to extra230"]
    - [pairwise_qualname_eq,
       pairwise.__qualname__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__qualname__ == 'pairwise' — pairwise is a top-level C type with unqualified qualname 'pairwise'; __qualname__.__eq__('pairwise') returns True; new to extra230"]
    - [pairwise_module_eq,
       pairwise.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.pairwise.__module__ == 'itertools' — pairwise reports its module as 'itertools'; __module__.__eq__('itertools') returns True; new to extra230"]
    - [pairwise_name_len_8,
       pairwise.__name__.__len__,
       [],
       8,
       "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has exactly 8 characters (p-a-i-r-w-i-s-e); __len__() returns 8; new to extra230"]
    - [pairwise_class_is_type,
       pairwise.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.pairwise.__class__.__name__ == 'type' — pairwise is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra230"]

