spec: is_palindrome
version: ">=0.3.0"
backend: node(is-palindrome)

docs: https://www.npmjs.com/package/is-palindrome

provenance:
  derived_from:
    - "is-palindrome README — https://www.npmjs.com/package/is-palindrome"
    - "Test vectors verified with is-palindrome via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-palindrome source"
  notes:
    - "is-palindrome is an npm package. Install: npm install is-palindrome"
    - "Returns true if the string reads the same forwards and backwards."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_palindrome.check:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: ispal

  columns: [id, args, expected]
  rows:
    - [yes,    ["racecar"],  true]
    - [no,     ["hello"],    false]
    - [level,  ["level"],    true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:30:04Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
