spec: multiprocessing_extra2341
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "multiprocessing source: Lib/multiprocessing/process.py"
    - "multiprocessing source: Lib/multiprocessing/pool.py"
    - "multiprocessing source: Lib/multiprocessing/managers.py"
  notes:
    - "Theme: __slots__ contents — verifying that multiprocessing classes are not slotted."
    - "multiprocessing.Process, Pool, managers.BaseManager, and managers.BaseProxy are all non-slotted."
    - "For non-slotted classes, .__dict__.__contains__('__slots__') returns False."
    - "BaseProxy and BaseManager are in multiprocessing.managers."
    - "multiprocessing.Process on macOS is a context-specific subclass; its __module__ is 'multiprocessing.context'."
    - "Process methods (start, join, run, terminate, kill) are inherited from BaseProcess in multiprocessing.process, NOT in Process.__dict__ directly."
    - "Process.__dict__ contains only _start_method, _Popen, _after_fork (platform-specific overrides)."
    - "Pool methods (map, apply, close, terminate) are defined directly on Pool.__dict__."
    - "BaseManager has register, start, connect in its __dict__."
    - "BaseProxy has _callmethod and _getvalue in its __dict__."
    - "All expected values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Non-slotted multiprocessing classes — .__dict__ does NOT contain '__slots__'
#
# Process, Pool, BaseManager, and BaseProxy are all dict-based; no __slots__
# is declared at the class level.
# ---------------------------------------------------------------------------

table multiprocessing_extra2341.no_slots_in_dict:
  kind: python_call_eq
  category: slots_absent

  columns: [id, function, args, expected]
  rows:
    - ["mp2341001", Process.__dict__.__contains__,              ["__slots__"], false]
    - ["mp2341002", Pool.__dict__.__contains__,                 ["__slots__"], false]
    - ["mp2341003", managers.BaseManager.__dict__.__contains__,  ["__slots__"], false]
    - ["mp2341004", managers.BaseProxy.__dict__.__contains__,    ["__slots__"], false]

# ---------------------------------------------------------------------------
# Class __dict__ type — all class-level __dict__ objects are mappingproxy
# ---------------------------------------------------------------------------

table multiprocessing_extra2341.dict_type:
  kind: python_call_eq
  category: dict_presence

  columns: [id, function, args, expected]
  rows:
    - ["mp2341005", Process.__dict__.__class__.__name__.__eq__,              ["mappingproxy"], true]
    - ["mp2341006", Pool.__dict__.__class__.__name__.__eq__,                 ["mappingproxy"], true]
    - ["mp2341007", managers.BaseManager.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - ["mp2341008", managers.BaseProxy.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Class name identity
# ---------------------------------------------------------------------------

table multiprocessing_extra2341.class_names:
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected]
  rows:
    - ["mp2341009",  Process.__name__.__eq__,              ["Process"],     true]
    - ["mp2341010",  Pool.__name__.__eq__,                 ["Pool"],        true]
    - ["mp2341011",  managers.BaseManager.__name__.__eq__, ["BaseManager"], true]
    - ["mp2341012",  managers.BaseProxy.__name__.__eq__,   ["BaseProxy"],   true]

# ---------------------------------------------------------------------------
# Pool — key interface methods present in Pool.__dict__
#
# map, apply, close, and terminate are all defined directly on the Pool class.
# ---------------------------------------------------------------------------

table multiprocessing_extra2341.pool_methods:
  kind: python_call_eq
  category: pool_interface

  columns: [id, function, args, expected]
  rows:
    - ["mp2341013", Pool.__dict__.__contains__, ["map"],      true]
    - ["mp2341014", Pool.__dict__.__contains__, ["apply"],    true]
    - ["mp2341015", Pool.__dict__.__contains__, ["close"],    true]
    - ["mp2341016", Pool.__dict__.__contains__, ["terminate"], true]

# ---------------------------------------------------------------------------
# BaseManager — key interface methods present in BaseManager.__dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra2341.basemanager_methods:
  kind: python_call_eq
  category: manager_interface

  columns: [id, function, args, expected]
  rows:
    - ["mp2341017", managers.BaseManager.__dict__.__contains__, ["register"], true]
    - ["mp2341018", managers.BaseManager.__dict__.__contains__, ["start"],    true]
    - ["mp2341019", managers.BaseManager.__dict__.__contains__, ["connect"],  true]

# ---------------------------------------------------------------------------
# BaseProxy — key interface methods present in BaseProxy.__dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra2341.baseproxy_methods:
  kind: python_call_eq
  category: proxy_interface

  columns: [id, function, args, expected]
  rows:
    - ["mp2341020", managers.BaseProxy.__dict__.__contains__, ["_callmethod"], true]
    - ["mp2341021", managers.BaseProxy.__dict__.__contains__, ["_getvalue"],   true]

# ---------------------------------------------------------------------------
# Process platform-specific attributes — __dict__ contains context overrides
#
# The context-specific Process subclass (macOS: spawn/fork) overrides only
# _start_method and _Popen in its own __dict__; inherited methods live on
# BaseProcess.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra2341.Process.has_start_method_attr:
  description: "multiprocessing.Process.__dict__.__contains__('_start_method') == True — context override present"
  category: process_context
  kind: python_call_eq
  function: Process.__dict__.__contains__
  args: ["_start_method"]
  expected: true

invariant multiprocessing_extra2341.Process.has_popen_attr:
  description: "multiprocessing.Process.__dict__.__contains__('_Popen') == True — context override present"
  category: process_context
  kind: python_call_eq
  function: Process.__dict__.__contains__
  args: ["_Popen"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation
# ---------------------------------------------------------------------------

invariant multiprocessing_extra2341.Process.module:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context' on macOS (context-specific subclass)"
  category: module_identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra2341.Pool.module:
  description: "multiprocessing.Pool.__module__ == 'multiprocessing.pool'"
  category: module_identity
  kind: python_call_eq
  function: Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra2341.BaseManager.module:
  description: "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'"
  category: module_identity
  kind: python_call_eq
  function: managers.BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra2341.BaseProxy.module:
  description: "multiprocessing.managers.BaseProxy.__module__ == 'multiprocessing.managers'"
  category: module_identity
  kind: python_call_eq
  function: managers.BaseProxy.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true
