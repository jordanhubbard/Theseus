spec: lodash_findindex
version: ">=4.0.0"
backend: node(lodash.findindex)

docs: https://lodash.com/docs/#findIndex

provenance:
  derived_from:
    - "lodash.findindex README — https://www.npmjs.com/package/lodash.findindex"
    - "Test vectors verified with lodash.findindex@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.findindex exports the _.findIndex function directly as module.exports."
    - "findIndex(array, predicate) returns the index of the first matching element."
    - "Object predicate uses match shorthand."
    - "Returns -1 if not found."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer index. Returns -1 if not found."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_findindex.findindex:
  kind: node_module_call_eq
  function: ~
  category: findindex
  id_prefix: lfi

  columns: [id, args, expected]
  rows:
    - [found,     [[{"id": 1}, {"id": 2}, {"id": 3}], {"id": 2}],  1]
    - [first,     [[{"id": 1}, {"id": 2}], {"id": 1}],             0]
    - [not_found, [[{"id": 1}, {"id": 2}], {"id": 9}],             -1]
