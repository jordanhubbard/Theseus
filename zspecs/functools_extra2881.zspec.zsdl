spec: ft2881
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 639 (ft2881): __iadd__, __isub__, __imul__ dict-presence checks for functools types."
    - "functools classes are not numeric or sequence types — none define in-place add, subtract, or multiply operators."
    - "Verified types: functools.partial, functools.partialmethod, functools.cached_property, functools._lru_cache_wrapper, functools._CacheInfo, functools.singledispatch."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by functools.lru_cache()."
    - "functools._CacheInfo is the namedtuple class for lru_cache statistics."
    - "functools.singledispatch is the dispatch decorator class (type of the wrapper returned by @singledispatch)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft2881.iadd:
  description: "functools types __iadd__ dict-presence checks; wave 639"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2881
  columns: [id, function, args, expected]
  rows:
    - ["ft2881001", operator.contains, [functools.partial.__dict__,              "__iadd__"], false]
    - ["ft2881002", operator.contains, [functools.partialmethod.__dict__,        "__iadd__"], false]
    - ["ft2881003", operator.contains, [functools.cached_property.__dict__,      "__iadd__"], false]
    - ["ft2881004", operator.contains, [functools._lru_cache_wrapper.__dict__,   "__iadd__"], false]
    - ["ft2881005", operator.contains, [functools._CacheInfo.__dict__,           "__iadd__"], false]
    - ["ft2881006", operator.contains, [functools.singledispatch.__dict__,       "__iadd__"], false]

