spec: hashlib_extra250
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity / HASH method qualname lengths / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra10.zspec.zsdl — covers new('sha3_224').digest_size==28 / new('sha3_384').digest_size==48 / sha3_224/__name__/__module__ / sha512 hello hexdigest (table + invariants)."
    - "hashlib_extra.zspec.zsdl — covers blake2b default/custom digest_size / sha3_224/sha3_384 attrs / algorithms_guaranteed (table + invariants)."
  notes:
    - "Wave 290 theme: hashlib digest output sizes and block sizes — digest_size and block_size for md5/sha1/sha224/sha256/sha384/sha512 instances / hexdigest string lengths."
    - "hashlib.md5(b'').digest_size == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1(b'').digest_size == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224(b'').digest_size == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'').digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384(b'').digest_size == 48. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512(b'').digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5(b'').block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1(b'').block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224(b'').block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'').block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384(b'').block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512(b'').block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hexdigest lengths: md5=32, sha1=40, sha224=56, sha256=64, sha384=96, sha512=128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.md5/sha1/sha224/sha256/sha384/sha512 are builtin_function_or_method objects (C constructors); digest_size and block_size are instance attributes on the HASH object returned by calling the constructor. hashlib_extra107 covers md5/sha1/sha256/sha512 digest_size and block_size; this spec adds sha224 and sha384 and groups hexdigest lengths."
    - "Note: hexdigest() returns a hex-encoded string of length 2 * digest_size (each byte encoded as 2 hex chars). hexdigest length is independent of input length."
    - "Note: md5/sha1/sha224/sha256 all share block_size==64 (512-bit block). sha384/sha512 both share block_size==128 (1024-bit block)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# digest_size for sha224/sha384 instances (md5/sha1/sha256/sha512 anchored in extra107)
# plus sha224/sha384 block_size
#
# Wave 290 theme: hashlib hash instance digest_size and block_size for sha224/sha384.
#
# hashlib_extra107 anchors digest_size and block_size for md5/sha1/sha256/sha512.
# This spec adds sha224 (digest_size=28, block_size=64) and sha384
# (digest_size=48, block_size=128) and groups all six algorithms together.
# sha224 and sha384 are the two SHA-2 variants not covered by extra107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra250.digest_and_block_sizes:
  description: "md5().digest_size.__eq__(16)==True / sha1().digest_size.__eq__(20)==True / sha224().digest_size.__eq__(28)==True / sha256().digest_size.__eq__(32)==True / sha384().digest_size.__eq__(48)==True / sha512().digest_size.__eq__(64)==True / sha224().block_size.__eq__(64)==True / sha384().block_size.__eq__(128)==True — extra107 anchors md5/sha1/sha256/sha512 digest_size and block_size; this adds sha224 digest_size==28/block_size==64 and sha384 digest_size==48/block_size==128; first hashlibdsize290 anchor"
  kind: python_call_eq
  category: digest_sizes
  id_prefix: hashlibdsize290

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_size,    "md5().digest_size.__eq__",    [16], true, "md5 digest_size is 16 bytes (128-bit output)"]
    - [sha1_digest_size,   "sha1().digest_size.__eq__",   [20], true, "sha1 digest_size is 20 bytes (160-bit output)"]
    - [sha224_digest_size, "sha224().digest_size.__eq__", [28], true, "sha224 digest_size is 28 bytes (224-bit output)"]
    - [sha256_digest_size, "sha256().digest_size.__eq__", [32], true, "sha256 digest_size is 32 bytes (256-bit output)"]
    - [sha384_digest_size, "sha384().digest_size.__eq__", [48], true, "sha384 digest_size is 48 bytes (384-bit output)"]
    - [sha512_digest_size, "sha512().digest_size.__eq__", [64], true, "sha512 digest_size is 64 bytes (512-bit output)"]
    - [sha224_block_size,  "sha224().block_size.__eq__",  [64],  true, "sha224 block_size is 64 bytes (512-bit block; same as md5/sha1/sha256)"]
    - [sha384_block_size,  "sha384().block_size.__eq__",  [128], true, "sha384 block_size is 128 bytes (1024-bit block; same as sha512)"]

# ---------------------------------------------------------------------------
# hexdigest string lengths for md5/sha1/sha224/sha256/sha384/sha512
#
# Wave 290 theme: hashlib hexdigest() string lengths.
#
# hexdigest() returns a hex-encoded string of length 2 * digest_size because
# each byte of the raw digest is encoded as exactly 2 hexadecimal characters.
# md5: 2*16=32, sha1: 2*20=40, sha224: 2*28=56, sha256: 2*32=64,
# sha384: 2*48=96, sha512: 2*64=128. hashlib_extra239 anchors
# sha3_256/sha3_512 hexdigest lengths; no prior spec anchors the SHA-2
# hexdigest lengths as a grouped table under hashlibdsize290.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra250.hexdigest_lengths:
  description: "md5(b'').hexdigest().__len__()==32 / sha1(b'').hexdigest().__len__()==40 / sha224(b'').hexdigest().__len__()==56 / sha256(b'').hexdigest().__len__()==64 / sha384(b'').hexdigest().__len__()==96 / sha512(b'').hexdigest().__len__()==128 — hexdigest length is always 2*digest_size; sha256 hexdigest is 64 chars; sha512 is 128 chars; sha224=56 and sha384=96 fill the gaps between sha1=40 and sha256=64; extra239 anchors sha3 hexdigest lengths; first hashlibdsize290 anchor for SHA-2 hexdigest length table"
  kind: python_call_eq
  category: hexdigest_lengths
  id_prefix: hashlibdsize290

  columns: [id, function, args, expected, description]
  rows:
    - [md5_hexlen,    "md5(b'').hexdigest().__len__",    [], 32,  "md5 hexdigest length is 32 chars (2 * 16 bytes)"]
    - [sha1_hexlen,   "sha1(b'').hexdigest().__len__",   [], 40,  "sha1 hexdigest length is 40 chars (2 * 20 bytes)"]
    - [sha224_hexlen, "sha224(b'').hexdigest().__len__", [], 56,  "sha224 hexdigest length is 56 chars (2 * 28 bytes)"]
    - [sha256_hexlen, "sha256(b'').hexdigest().__len__", [], 64,  "sha256 hexdigest length is 64 chars (2 * 32 bytes)"]
    - [sha384_hexlen, "sha384(b'').hexdigest().__len__", [], 96,  "sha384 hexdigest length is 96 chars (2 * 48 bytes)"]
    - [sha512_hexlen, "sha512(b'').hexdigest().__len__", [], 128, "sha512 hexdigest length is 128 chars (2 * 64 bytes)"]

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size == 16 — standalone
#
# hashlib.md5().digest_size is 16. MD5 produces a 128-bit (16-byte) digest.
# Although MD5 is cryptographically broken (collision-prone), it remains
# available in hashlib for non-security uses. digest_size is an instance
# attribute on the HASH object. hashlib_extra107 anchors md5 digest_size in
# a table; this provides a standalone cross-check under hashlibdsize290.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra250.md5_digest_size_16:
  description: "hashlib.md5().digest_size == 16 — MD5 produces a 128-bit (16-byte) digest; digest_size is an instance attribute on the HASH object; MD5 available for non-security uses despite being cryptographically broken; extra107 anchors md5 digest_size in a table; first standalone under hashlibdsize290"
  category: digest_sizes
  kind: python_call_eq
  function: md5
  args: []
  method: digest_size.__eq__
  method_args: [16]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha224().digest_size == 28 — standalone
#
# hashlib.sha224().digest_size is 28. SHA-224 produces a 224-bit (28-byte)
# digest. It is a truncated variant of SHA-256 that uses a different
# initialization vector and produces a shorter output. SHA-224 is used where
# a 128-bit security level is required with a smaller output size than SHA-256.
# hashlib_extra.zspec.zsdl anchors sha3_224 via new() factory; hashlib_extra107
# covers md5/sha1/sha256/sha512 but not sha224. No prior spec anchors
# sha224().digest_size as a standalone under hashlibdsize290.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra250.sha224_digest_size_28:
  description: "hashlib.sha224().digest_size == 28 — SHA-224 produces a 224-bit (28-byte) digest; truncated variant of SHA-256 with different initialization vector; used where 128-bit security level suffices with smaller output than SHA-256; extra107 covers md5/sha1/sha256/sha512 but not sha224; first standalone for sha224 digest_size under hashlibdsize290"
  category: digest_sizes
  kind: python_call_eq
  function: sha224
  args: []
  method: digest_size.__eq__
  method_args: [28]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha384().digest_size == 48 — standalone
#
# hashlib.sha384().digest_size is 48. SHA-384 produces a 384-bit (48-byte)
# digest. It uses the same compression function as SHA-512 but starts with
# a different initialization vector and truncates the output to 48 bytes.
# SHA-384 shares block_size==128 with SHA-512 (both use 1024-bit blocks).
# hashlib_extra107 covers md5/sha1/sha256/sha512 but not sha384. No prior
# spec anchors sha384().digest_size as a standalone under hashlibdsize290.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra250.sha384_digest_size_48:
  description: "hashlib.sha384().digest_size == 48 — SHA-384 produces a 384-bit (48-byte) digest; uses same compression function as SHA-512 with different init vector and truncated output; block_size==128 (shared with SHA-512, both use 1024-bit blocks); extra107 covers md5/sha1/sha256/sha512 but not sha384; first standalone for sha384 digest_size under hashlibdsize290"
  category: digest_sizes
  kind: python_call_eq
  function: sha384
  args: []
  method: digest_size.__eq__
  method_args: [48]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256(b'').hexdigest().__len__() == 64 — standalone
#
# hashlib.sha256(b'').hexdigest().__len__() is 64. The hexdigest of an empty
# bytes input is a 64-character lowercase hex string — exactly 2 * digest_size
# (2 * 32 == 64). hexdigest length is independent of input length; it only
# depends on the algorithm's digest_size. No prior hashlib_extra spec anchors
# sha256 hexdigest length as a standalone under hashlibdsize290.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra250.sha256_hexdigest_len_64:
  description: "hashlib.sha256(b'').hexdigest().__len__() == 64 — SHA-256 hexdigest is always 64 chars (2 * 32 bytes); hexdigest length is independent of input, depends only on digest_size; empty input SHA-256 is 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855'; no prior hashlib spec anchors sha256 hexdigest length as standalone; first standalone under hashlibdsize290"
  category: hexdigest_lengths
  kind: python_call_eq
  function: "sha256(b'').hexdigest().__len__"
  args: []
  expected: 64
