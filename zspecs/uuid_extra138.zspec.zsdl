spec: uuid_extra138
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra137.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('hex'/'int'/'bytes'/'version'/__slots__/__init__) / UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__spec__.name.__eq__('uuid') / uuid.__doc__.__len__()==1948 (table + invariants)."
    - "uuid_extra136.zspec.zsdl — covers uuid.UUID.__lt__/__gt__/__le__/__ge__ comparison operator __qualname__ string equality (all 'UUID.<method>', len 11) / UUID.__int__ __qualname__.__eq__('UUID.__int__') and __len__()==12 / __lt__/__gt__/__le__/__ge__/__eq__ all __class__.__name__=='function' / UUID.__ne__.__class__.__name__=='wrapper_descriptor' (table + invariants)."
    - "uuid_extra135.zspec.zsdl — covers uuid.UUID property descriptor __class__.__name__ == 'property' for hex/urn/variant/version/bytes/fields / UUID.int/__class__.__name__ == 'member_descriptor' / property fget __qualname__ lengths for hex/urn/variant/version/fields/node/time (table + invariants)."
    - "uuid_extra134.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__ __qualname__ lengths / __qualname__ equality strings / __slots__ class name/length / UUID.__bases__[0].__name__=='object' (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra137."
    - "Wave 313 theme: uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') (len 4) / NAMESPACE_URL/__class__.__name__.__eq__('UUID') / NAMESPACE_OID/__class__.__name__.__eq__('UUID') / NAMESPACE_X500/__class__.__name__.__eq__('UUID') / NAMESPACE_DNS.version==1 / NAMESPACE_URL.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') (len 16)."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.hex.__len__() == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The four NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) are all instances of the UUID class. Their __class__.__name__ is 'UUID' (4 chars). These are pre-defined RFC 4122 namespace UUIDs used as the namespace argument to uuid3() and uuid5(). extra98 anchors the NAMESPACE constants via hex/str/version values; this spec anchors their class name as a group."
    - "Note: NAMESPACE_DNS.version == 1 and NAMESPACE_URL.version == 1. All four namespace UUIDs are version 1 UUIDs (time-based). The version number is encoded in bits 12-15 of the time_hi field (bits 76-79 of the 128-bit UUID), and the namespace UUIDs were historically generated as version 1 time-based UUIDs."
    - "Note: uuid has no __all__ attribute (verified Python 3.14.3 macOS/Darwin 25.4.0). This contrasts with hashlib (tuple, 19 entries), struct (list, 8 entries), and socket (list, 238 entries), all of which define __all__. The uuid module relies on import * behavior defined only by what is not prefixed with underscore."
    - "Note: uuid.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). This is the standard loader for pure-Python stdlib modules (Lib/uuid.py). The 16-char 'SourceFileLoader' name ties in length with struct.__loader__.__class__.__name__ (also 'SourceFileLoader', 16 chars) since both uuid and struct are pure-Python modules loaded by SourceFileLoader."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID')
# all four __class__.__name__.__len__()==4
#
# Wave 313 theme: all four NAMESPACE constants are UUID instances.
#
# The four predefined namespace UUIDs (DNS, URL, OID, X.500) are all instances
# of the UUID class. Their __class__.__name__ is 'UUID' (4 chars). extra98
# anchors individual NAMESPACE hex/str values; no prior uuid spec anchors all four
# NAMESPACE constants' class names together as a table under uuidns138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra138.NAMESPACE_constants_class_identity:
  description: "uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL/__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID/__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500/__class__.__name__.__eq__('UUID')==True — all four namespace constants are UUID instances (class name 'UUID', 4 chars); pre-defined RFC 4122 namespaces for uuid3/uuid5; extra98 anchors their hex/str/version values; first uuidns138 anchor for class name group"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns138

  columns: [id, function, args, expected, description]
  rows:
    - [dns_class_UUID,   NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (4 chars; DNS namespace UUID instance)"]
    - [url_class_UUID,   NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' (4 chars; URL namespace UUID instance)"]
    - [oid_class_UUID,   NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true, "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' (4 chars; OID namespace UUID instance)"]
    - [x500_class_UUID,  NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true, "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' (4 chars; X.500 namespace UUID instance)"]
    - [dns_class_len,    NAMESPACE_DNS.__class__.__name__.__len__, [],        4,   "uuid.NAMESPACE_DNS.__class__.__name__.__len__() is 4 ('UUID' = 4 chars; ties with uuid.__spec__.name length)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version==1
# uuid.NAMESPACE_URL.version==1
# uuid.NAMESPACE_DNS.hex.__len__()==32
# uuid.NAMESPACE_URL.hex.__len__()==32
#
# Wave 313 theme: NAMESPACE_DNS and NAMESPACE_URL version and hex length.
#
# Both NAMESPACE_DNS and NAMESPACE_URL are version 1 UUIDs (time-based, per RFC 4122).
# Their .hex attribute returns a 32-char lowercase hex string (no hyphens).
# extra98 anchors individual hex values; no prior uuid spec anchors the version
# attribute or hex length for these namespace UUIDs as a table under uuidns138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra138.NAMESPACE_DNS_URL_version_and_hex_length:
  description: "uuid.NAMESPACE_DNS.version==1 / NAMESPACE_URL.version==1 / NAMESPACE_DNS.hex.__len__()==32 / NAMESPACE_URL.hex.__len__()==32 — both are version 1 (time-based) UUIDs per RFC 4122; .hex returns a 32-char lowercase hex string without hyphens; hex length 32 equals 128 bits / 4 bits per hex digit; extra98 anchors their hex values; first uuidns138 anchor for version attribute and hex length"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns138

  columns: [id, function, args, expected, description]
  rows:
    - [dns_version_1,    NAMESPACE_DNS.version.__eq__,  [1],  true, "uuid.NAMESPACE_DNS.version == 1 (time-based UUID per RFC 4122; version encoded in time_hi field)"]
    - [url_version_1,    NAMESPACE_URL.version.__eq__,  [1],  true, "uuid.NAMESPACE_URL.version == 1 (same version as NAMESPACE_DNS; all four namespace UUIDs are version 1)"]
    - [dns_hex_len_32,   NAMESPACE_DNS.hex.__len__,     [],   32,   "uuid.NAMESPACE_DNS.hex.__len__() is 32 (128-bit UUID as 32 lowercase hex chars without hyphens)"]
    - [url_hex_len_32,   NAMESPACE_URL.hex.__len__,     [],   32,   "uuid.NAMESPACE_URL.hex.__len__() is 32 (same format as NAMESPACE_DNS; 32 lowercase hex chars)"]

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# uuid.__loader__.__class__.__name__.__len__()==16
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__name__.__len__()==4
#
# Wave 313 theme: uuid module loader class and UUID class name.
#
# uuid is a pure-Python module (Lib/uuid.py), so its __loader__ is a SourceFileLoader
# (16 chars). UUID.__name__ is 'UUID' (4 chars), the same string as __class__.__name__
# for the namespace constants. No prior uuid spec anchors __loader__.__class__.__name__
# or UUID.__name__ equality string as a table under uuidns138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra138.module_loader_and_UUID_name:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True / __class__.__name__.__len__()==16 / uuid.UUID.__name__.__eq__('UUID')==True / UUID.__name__.__len__()==4 — SourceFileLoader (16 chars) is the standard loader for pure-Python stdlib modules; UUID.__name__ 'UUID' (4 chars) ties in length with uuid.__spec__.name ('uuid', 4 chars); extra97 anchors UUID property identities; first uuidns138 anchor for loader class name and UUID __name__ equality"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns138

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_SourceFileLoader, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; pure-Python module loader)"]
    - [loader_class_len,              __loader__.__class__.__name__.__len__, [],                  16,   "uuid.__loader__.__class__.__name__.__len__() is 16 ('SourceFileLoader' = 16 chars)"]
    - [UUID_name_eq,                  UUID.__name__.__eq__,                 ["UUID"],             true, "uuid.UUID.__name__ == 'UUID' (4 chars; same length as uuid.__spec__.name 'uuid')"]
    - [UUID_name_len,                 UUID.__name__.__len__,                [],                   4,    "uuid.UUID.__name__.__len__() is 4 ('UUID' = 4 chars; ties with uuid.__spec__.name length)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_DNS is the
# pre-defined RFC 4122 namespace UUID for DNS domain names. Its class name 'UUID'
# is the same 4-char string as the module spec name 'uuid' — two different things
# that coincidentally share the same length. extra98 anchors NAMESPACE_DNS hex value
# ('6ba7b8109dad11d180b400c04fd430c8'); no prior uuid spec anchors NAMESPACE_DNS
# class name as a standalone under uuidns138. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra138.NAMESPACE_DNS_class_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars); NAMESPACE_DNS is the RFC 4122 DNS namespace UUID (used as namespace arg to uuid3/uuid5); class name 'UUID' ties in length with module spec name 'uuid' (also 4 chars); extra98 anchors the hex value; no prior uuid spec anchors this as a standalone; first standalone under uuidns138"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_URL.__class__.__name__ is 'UUID'. NAMESPACE_URL is the pre-defined
# RFC 4122 namespace UUID for URLs. Together with NAMESPACE_DNS, it is one of the
# two most commonly used namespace UUIDs in practice (for generating name-based
# UUIDs from URLs using uuid3 or uuid5). NAMESPACE_URL.hex is
# '6ba7b8119dad11d180b400c04fd430c8' — one digit differs from NAMESPACE_DNS.hex
# ('6ba7b8109dad11d180b400c04fd430c8') at position 8 ('1' vs '0'). No prior uuid
# spec anchors NAMESPACE_URL class name as a standalone under uuidns138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra138.NAMESPACE_URL_class_UUID:
  description: "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars); NAMESPACE_URL is the RFC 4122 URL namespace UUID; hex differs from NAMESPACE_DNS at position 8 ('1' vs '0'); used as namespace arg to uuid3/uuid5 for URL-based names; no prior uuid spec anchors this as a standalone; first standalone under uuidns138"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version==1 — standalone
#
# uuid.NAMESPACE_DNS.version is 1. The four pre-defined RFC 4122 namespace UUIDs
# were historically generated as version 1 (time-based) UUIDs. The version is
# encoded in bits 12-15 of the time_hi_and_version field (octets 6-7 of the
# 16-byte representation). Version 1 indicates a time-based UUID using the MAC
# address and current timestamp. No prior uuid spec anchors NAMESPACE_DNS.version==1
# as a standalone under uuidns138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra138.NAMESPACE_DNS_version_1:
  description: "uuid.NAMESPACE_DNS.version == 1 — version 1 (time-based UUID using MAC address and timestamp); version encoded in bits 12-15 of time_hi field; all four RFC 4122 namespace UUIDs are version 1; extra98 anchors NAMESPACE_DNS hex/str values; no prior uuid spec anchors this as a standalone; first standalone under uuidns138"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.version.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__len__()==32 — standalone
#
# uuid.NAMESPACE_DNS.hex.__len__() is 32. The .hex attribute returns the UUID as
# a 32-character lowercase hexadecimal string with no hyphens or separators. This
# encodes the 128-bit UUID as 32 hex digits (4 bits per digit). For NAMESPACE_DNS
# the value is '6ba7b8109dad11d180b400c04fd430c8'. extra97 anchors UUID.hex as a
# property descriptor; extra98 anchors the hex value; no prior uuid spec anchors
# NAMESPACE_DNS.hex.__len__()==32 as a standalone under uuidns138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra138.NAMESPACE_DNS_hex_len_32:
  description: "uuid.NAMESPACE_DNS.hex.__len__() == 32 — 32 hex chars encoding the 128-bit UUID (4 bits per digit = 128/4 = 32); no hyphens or separators in .hex format; NAMESPACE_DNS value '6ba7b8109dad11d180b400c04fd430c8'; extra97 anchors hex as property descriptor; extra98 anchors hex value; no prior uuid spec anchors this as a standalone; first standalone under uuidns138"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.hex.__len__
  args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# uuid.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). uuid is a
# pure-Python module (Lib/uuid.py), so the import system uses SourceFileLoader
# to load it from the .py file. This contrasts with C extension modules like
# _struct and _hashlib which use ExtensionFileLoader. The 16-char 'SourceFileLoader'
# name is the same length as struct.__loader__.__class__.__name__ (also 'SourceFileLoader',
# 16 chars), since both uuid and struct are pure-Python source modules. No prior
# uuid spec anchors __loader__.__class__.__name__ == 'SourceFileLoader' as a standalone
# under uuidns138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra138.loader_class_SourceFileLoader:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 'SourceFileLoader' (16 chars); pure-Python module Lib/uuid.py loaded from .py source; contrasts with C extensions that use ExtensionFileLoader; same loader class as struct (also SourceFileLoader, 16 chars); no prior uuid spec anchors this as a standalone; first standalone under uuidns138"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_OID.__class__.__name__ is 'UUID'. NAMESPACE_OID is the pre-defined
# RFC 4122 namespace UUID for ISO OID (Object Identifier) names. It is less commonly
# used in practice than NAMESPACE_DNS or NAMESPACE_URL, but is part of the four
# standard RFC 4122 namespaces. All four namespace UUIDs share the same class name
# 'UUID' (4 chars) because they are all instances of the uuid.UUID class. No prior
# uuid spec anchors NAMESPACE_OID class name as a standalone under uuidns138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra138.NAMESPACE_OID_class_UUID:
  description: "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars); NAMESPACE_OID is the RFC 4122 OID namespace UUID (for ISO Object Identifiers); less common than DNS/URL namespaces but still part of the four standard RFC 4122 namespaces; all four NAMESPACE constants are UUID instances; no prior uuid spec anchors this as a standalone; first standalone under uuidns138"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true
