spec: concurrent_futures_extra27
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/exceptions.html — Python built-in exceptions"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra26.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, thread/process submodule __name__, class __module__/__name__/__len__() tables, ThreadPoolExecutor.submit/__qualname__.__len__()=25, ThreadPoolExecutor.shutdown/__qualname__.__len__()=27, Executor.map/__qualname__.__len__()=12, Future method __qualname__.__len__() for result/add_done_callback/cancel."
    - "This spec covers: Future method __qualname__.__len__() for done/exception (not yet measured); ProcessPoolExecutor method __qualname__.__len__() for submit/shutdown; CancelledError.__bases__[0].__name__; TimeoutError.__bases__[0].__name__; BrokenExecutor.__bases__[0].__name__; exception __mro__.__len__() for CancelledError/TimeoutError/BrokenExecutor."
    - "Future.done.__qualname__ == 'Future.done' — length 11."
    - "Future.exception.__qualname__ == 'Future.exception' — length 16."
    - "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' — length 26."
    - "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' — length 28."
    - "CancelledError.__bases__[0].__name__ == 'Error' — subclass of concurrent.futures._base.Error."
    - "TimeoutError.__bases__[0].__name__ == 'OSError' — built-in TimeoutError subclasses OSError."
    - "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — BrokenExecutor subclasses RuntimeError."
    - "CancelledError.__mro__.__len__() == 5 — [CancelledError, Error, Exception, BaseException, object]."
    - "TimeoutError.__mro__.__len__() == 5 — [TimeoutError, OSError, Exception, BaseException, object]."
    - "BrokenExecutor.__mro__.__len__() == 5 — [BrokenExecutor, RuntimeError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future method __qualname__ length table — remaining methods, extra27 namespace
#
# Prior spec (extra26) covered result (13), add_done_callback (24), and
# cancel (13). This table extends coverage to the two remaining public
# instance methods not yet measured:
#   Future.done.__qualname__      == 'Future.done'      (11)
#   Future.exception.__qualname__ == 'Future.exception' (16)
# ---------------------------------------------------------------------------

table concurrent_futures_extra27.future_method_qualname_lengths:
  description: "concurrent.futures.Future method __qualname__ lengths for done/exception in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futmqualnamelen27

  columns: [id, function, args, expected]
  rows:
    - [done,      Future.done.__qualname__.__len__,      [], 11]
    - [exception, Future.exception.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor method __qualname__ length table — extra27 namespace
#
# ProcessPoolExecutor defines submit and shutdown directly on the class.
# The class name is longer than ThreadPoolExecutor, yielding lengths one
# character longer for each method:
#   ProcessPoolExecutor.submit.__qualname__   == 'ProcessPoolExecutor.submit'   (26)
#   ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (28)
# Prior spec (extra26) covered ThreadPoolExecutor submit (25) and shutdown (27);
# this table adds the ProcessPoolExecutor equivalents.
# ---------------------------------------------------------------------------

table concurrent_futures_extra27.ppe_method_qualname_lengths:
  description: "ProcessPoolExecutor method __qualname__ lengths for submit/shutdown in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ppemqualnamelen27

  columns: [id, function, args, expected]
  rows:
    - [submit,   ProcessPoolExecutor.submit.__qualname__.__len__,   [], 26]
    - [shutdown, ProcessPoolExecutor.shutdown.__qualname__.__len__, [], 28]

# ---------------------------------------------------------------------------
# Exception __bases__[0].__name__ table — extra27 namespace
#
# concurrent.futures exceptions have three distinct base classes:
#   CancelledError.__bases__[0].__name__ == 'Error'        — _base.Error (internal hierarchy)
#   TimeoutError.__bases__[0].__name__   == 'OSError'      — built-in TimeoutError → OSError
#   BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — subclasses RuntimeError
# No prior spec measures __bases__[0].__name__ for these three exceptions.
# ---------------------------------------------------------------------------

table concurrent_futures_extra27.exception_bases_names:
  description: "concurrent.futures exception __bases__[0].__name__ for CancelledError/TimeoutError/BrokenExecutor in extra27 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excbasename27

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,  "CancelledError.__bases__[0].__name__.__eq__",  ["Error"],        true]
    - [TimeoutError,    "TimeoutError.__bases__[0].__name__.__eq__",    ["OSError"],       true]
    - [BrokenExecutor,  "BrokenExecutor.__bases__[0].__name__.__eq__",  ["RuntimeError"],  true]

# ---------------------------------------------------------------------------
# Exception __mro__.__len__() table — extra27 namespace
#
# All three exceptions share MRO depth 5, but via different chains:
#   CancelledError: [CancelledError, Error, Exception, BaseException, object]
#   TimeoutError:   [TimeoutError,   OSError, Exception, BaseException, object]
#   BrokenExecutor: [BrokenExecutor, RuntimeError, Exception, BaseException, object]
# The shared depth of 5 reflects that each has one intermediate class
# between itself and Exception.
# ---------------------------------------------------------------------------

table concurrent_futures_extra27.exception_mro_lengths:
  description: "concurrent.futures exception __mro__.__len__() for CancelledError/TimeoutError/BrokenExecutor in extra27 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excmrolen27

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [CancelledError, CancelledError.__mro__, [], !ascii "", __len__, [], "CancelledError MRO depth == 5"]
    - [TimeoutError,   TimeoutError.__mro__,   [], !ascii "", __len__, [], "TimeoutError MRO depth == 5"]
    - [BrokenExecutor, BrokenExecutor.__mro__, [], !ascii "", __len__, [], "BrokenExecutor MRO depth == 5"]

# ---------------------------------------------------------------------------
# Future.done qualname string equality — extra27 standalone invariant
#
# Confirms the full __qualname__ string 'Future.done' for the done method,
# complementing the length check in the table above.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra27.Future.done_qualname_eq:
  description: "concurrent.futures.Future.done.__qualname__ == 'Future.done' — method defined on Future"
  category: method_names
  kind: python_call_eq
  function: Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError.__bases__[0].__name__ string equality — extra27 standalone
#
# Confirms that concurrent.futures.CancelledError subclasses the module-
# internal Error class (not Exception directly). This distinguishes it from
# asyncio.CancelledError which subclasses BaseException.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra27.CancelledError.base_name_eq:
  description: "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error' — subclasses the internal _base.Error class"
  category: class_hierarchy
  kind: python_call_eq
  function: CancelledError.__bases__[0].__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenExecutor.__bases__[0].__name__ string equality — extra27 standalone
#
# Confirms that BrokenExecutor subclasses RuntimeError, not Exception or
# ProcessError. This is notable because it breaks from the Error-based
# hierarchy used by CancelledError and reflects the "broken state" semantics.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra27.BrokenExecutor.base_name_eq:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — subclasses RuntimeError"
  category: class_hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__bases__[0].__name__.__eq__
  args: ["RuntimeError"]
  expected: true
