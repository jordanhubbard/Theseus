spec: asyncio_extra1771
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "Wave 565, suffix _extra1771. Theme: async protocol — which stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "asyncio.Lock defines __aenter__ and __aexit__ in its own __dict__ (async context manager)."
    - "asyncio.Semaphore defines __aenter__ and __aexit__ in its own __dict__ (async context manager)."
    - "asyncio.Condition defines __aenter__ and __aexit__ in its own __dict__ (async context manager)."
    - "asyncio.Event does NOT define __aenter__ or __aexit__ in its __dict__ — Event is not an async context manager."
    - "asyncio.Queue does NOT define __aenter__ or __aexit__ in its __dict__ — Queue is not an async context manager."
    - "asyncio.Future defines __await__ in its own __dict__ (awaitable), but NOT __aenter__ or __aexit__."
    - "asyncio.Task does NOT define __await__ in its own __dict__ — Task inherits __await__ from Future."
    - "None of the asyncio types define __aiter__ or __anext__ — asyncio synchronisation types are not async iterators."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __aenter__ and __aexit__ presence in asyncio type __dict__
#
# Lock, Semaphore, Condition each define __aenter__ and __aexit__ directly.
# Event and Queue do NOT define these methods.
# Future and Task do NOT define __aenter__ or __aexit__.
# ---------------------------------------------------------------------------

table asyncio_extra1771.aenter_aexit_in_dict:
  kind: python_call_eq
  category: async_protocol
  id_prefix: as1771

  columns: [id, function, args, expected]
  rows:
    - ["as1771001", asyncio.Lock.__dict__.__contains__,      ["__aenter__"], true]
    - ["as1771002", asyncio.Lock.__dict__.__contains__,      ["__aexit__"],  true]
    - ["as1771003", asyncio.Semaphore.__dict__.__contains__,  ["__aenter__"], true]
    - ["as1771004", asyncio.Semaphore.__dict__.__contains__,  ["__aexit__"],  true]
    - ["as1771005", asyncio.Condition.__dict__.__contains__,  ["__aenter__"], true]
    - ["as1771006", asyncio.Condition.__dict__.__contains__,  ["__aexit__"],  true]
    - ["as1771007", asyncio.Event.__dict__.__contains__,      ["__aenter__"], false]
    - ["as1771008", asyncio.Event.__dict__.__contains__,      ["__aexit__"],  false]
    - ["as1771009", asyncio.Queue.__dict__.__contains__,      ["__aenter__"], false]
    - ["as1771010", asyncio.Queue.__dict__.__contains__,      ["__aexit__"],  false]
    - ["as1771011", asyncio.Future.__dict__.__contains__,     ["__aenter__"], false]
    - ["as1771012", asyncio.Future.__dict__.__contains__,     ["__aexit__"],  false]
    - ["as1771013", asyncio.Task.__dict__.__contains__,       ["__aenter__"], false]
    - ["as1771014", asyncio.Task.__dict__.__contains__,       ["__aexit__"],  false]

# ---------------------------------------------------------------------------
# Table 2: __await__, __aiter__, __anext__ presence in asyncio type __dict__
#
# asyncio.Future defines __await__ in its own __dict__.
# asyncio.Task does NOT define __await__ in its own __dict__ (inherits from Future).
# No asyncio type defines __aiter__ or __anext__ — they are not async iterators.
# ---------------------------------------------------------------------------

table asyncio_extra1771.await_aiter_anext_in_dict:
  kind: python_call_eq
  category: async_protocol
  id_prefix: as1771

  columns: [id, function, args, expected]
  rows:
    - ["as1771015", asyncio.Future.__dict__.__contains__,    ["__await__"],  true]
    - ["as1771016", asyncio.Task.__dict__.__contains__,      ["__await__"],  false]
    - ["as1771017", asyncio.Lock.__dict__.__contains__,      ["__await__"],  false]
    - ["as1771018", asyncio.Semaphore.__dict__.__contains__,  ["__await__"],  false]
    - ["as1771019", asyncio.Condition.__dict__.__contains__,  ["__await__"],  false]
    - ["as1771020", asyncio.Event.__dict__.__contains__,      ["__await__"],  false]
    - ["as1771021", asyncio.Queue.__dict__.__contains__,      ["__await__"],  false]
    - ["as1771022", asyncio.Future.__dict__.__contains__,    ["__aiter__"],  false]
    - ["as1771023", asyncio.Future.__dict__.__contains__,    ["__anext__"],  false]
    - ["as1771024", asyncio.Lock.__dict__.__contains__,      ["__aiter__"],  false]
    - ["as1771025", asyncio.Lock.__dict__.__contains__,      ["__anext__"],  false]
