spec: functools_extra1111
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks cached_property descriptor method qualnames (__init__, __set_name__, __get__), update_wrapper/wraps identity, partial.__call__/__repr__ qualnames, WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES class names — not covered in _extra1081/_extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1111.cached_property_descriptor_qualnames:
  description: "functools.cached_property descriptor method __qualname__ identity"
  kind: python_call_eq
  category: cached_property_descriptor_qualnames
  id_prefix: fn1111cp
  columns: [id, function, args, expected]
  rows:
    - [fn1111cp001, functools.cached_property.__init__.__qualname__.__eq__,       ["cached_property.__init__"],     true]
    - [fn1111cp002, functools.cached_property.__set_name__.__qualname__.__eq__,   ["cached_property.__set_name__"], true]
    - [fn1111cp003, functools.cached_property.__get__.__qualname__.__eq__,        ["cached_property.__get__"],      true]
    - [fn1111cp004, functools.cached_property.__class__.__name__.__eq__,          ["type"],                         true]
    - [fn1111cp005, functools.cached_property.__name__.__eq__,                    ["cached_property"],              true]
    - [fn1111cp006, functools.cached_property.__qualname__.__eq__,                ["cached_property"],              true]
    - [fn1111cp007, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,      ["tuple"],                        true]
    - [fn1111cp008, functools.WRAPPER_UPDATES.__class__.__name__.__eq__,          ["tuple"],                        true]

table functools_extra1111.update_wrapper_wraps_identity:
  description: "functools.update_wrapper and wraps function identity (qualname, module, class)"
  kind: python_call_eq
  category: update_wrapper_wraps_identity
  id_prefix: fn1111uw
  columns: [id, function, args, expected]
  rows:
    - [fn1111uw001, functools.update_wrapper.__qualname__.__eq__,                 ["update_wrapper"],               true]
    - [fn1111uw002, functools.update_wrapper.__module__.__eq__,                   ["functools"],                    true]
    - [fn1111uw003, functools.update_wrapper.__class__.__name__.__eq__,           ["function"],                     true]
    - [fn1111uw004, functools.update_wrapper.__doc__.__class__.__name__.__eq__,   ["str"],                          true]
    - [fn1111uw005, functools.wraps.__qualname__.__eq__,                          ["wraps"],                        true]
    - [fn1111uw006, functools.wraps.__module__.__eq__,                            ["functools"],                    true]
    - [fn1111uw007, functools.wraps.__class__.__name__.__eq__,                    ["function"],                     true]
    - [fn1111uw008, functools.wraps.__doc__.__class__.__name__.__eq__,            ["str"],                          true]

table functools_extra1111.partial_call_repr_qualnames:
  description: "functools.partial method qualnames (__call__, __repr__) and singledispatch module/qualname"
  kind: python_call_eq
  category: partial_call_repr_qualnames
  id_prefix: fn1111pr
  columns: [id, function, args, expected]
  rows:
    - [fn1111pr001, functools.partial.__call__.__qualname__.__eq__,               ["partial.__call__"],             true]
    - [fn1111pr002, functools.partial.__repr__.__qualname__.__eq__,               ["partial.__repr__"],             true]
    - [fn1111pr003, functools.partial.__class__.__name__.__eq__,                  ["type"],                         true]
    - [fn1111pr004, functools.singledispatch.__qualname__.__eq__,                 ["singledispatch"],               true]
    - [fn1111pr005, functools.singledispatch.__module__.__eq__,                   ["functools"],                    true]
    - [fn1111pr006, functools.singledispatch.__class__.__name__.__eq__,           ["function"],                     true]
    - [fn1111pr007, functools.reduce.__qualname__.__eq__,                         ["reduce"],                       true]
    - [fn1111pr008, functools.reduce.__class__.__name__.__eq__,                   ["builtin_function_or_method"],   true]
