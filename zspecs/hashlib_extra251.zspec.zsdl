spec: hashlib_extra251
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra.zspec.zsdl — covers blake2b default/custom digest_size / sha3_224/sha3_384 attrs / algorithms_guaranteed (table + invariants)."
    - "hashlib_extra250.zspec.zsdl — covers digest_size and block_size for md5/sha1/sha224/sha256/sha384/sha512 instances / hexdigest string lengths (table + invariants)."
  notes:
    - "Wave 291 theme: hashlib algorithms_guaranteed and algorithms_available set membership and type identity."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.algorithms_guaranteed) == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha512') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha224') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha384') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: algorithms_guaranteed is a set (not frozenset) of algorithm names guaranteed to be available on all platforms in the Python standard library. Python 3.14.3 on macOS contains 14 entries: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256."
    - "Note: algorithms_available is also a plain set (same type as algorithms_guaranteed); it includes additional hashes available from the OpenSSL library on the current platform, so its contents are platform-dependent."
    - "Note: The __contains__ method is the set membership test (__contains__(x) is equivalent to x in s). Using __contains__ allows expressing set membership checks in ZSDL python_call_eq rows."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__ for core algorithm names
#
# Wave 291 theme: algorithms_guaranteed set membership for SHA-2, SHA-3, BLAKE2.
#
# algorithms_guaranteed is a set of algorithm names that are available on all
# Python platforms. The SHA-2 family (md5, sha1, sha224, sha256, sha384, sha512)
# and the SHA-3 family (sha3_224, sha3_256, sha3_384, sha3_512) and BLAKE2
# (blake2b, blake2s) are all guaranteed as of Python 3.6+. hashlib_extra.zspec
# anchors algorithms_guaranteed in invariants; no prior spec anchors all six SHA-2
# names plus sha3_256 and blake2b together as a grouped __contains__ table under
# hashlibalgos291. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra251.algorithms_guaranteed_membership:
  description: "algorithms_guaranteed.__contains__('md5')==True / __contains__('sha1')==True / __contains__('sha256')==True / __contains__('sha512')==True / __contains__('sha224')==True / __contains__('sha384')==True / __contains__('sha3_256')==True / __contains__('blake2b')==True — all six SHA-2 variants plus sha3_256 and blake2b are in algorithms_guaranteed on all platforms; set of 14 entries in Python 3.14.3; hashlib_extra anchors algorithms_guaranteed in invariants; first hashlibalgos291 anchor for __contains__ membership table"
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: hashlibalgos291

  columns: [id, function, args, expected, description]
  rows:
    - [contains_md5,     "algorithms_guaranteed.__contains__", ["md5"],     true, "md5 is in algorithms_guaranteed (available on all Python platforms)"]
    - [contains_sha1,    "algorithms_guaranteed.__contains__", ["sha1"],    true, "sha1 is in algorithms_guaranteed (available on all Python platforms)"]
    - [contains_sha224,  "algorithms_guaranteed.__contains__", ["sha224"],  true, "sha224 is in algorithms_guaranteed (SHA-2 224-bit variant)"]
    - [contains_sha256,  "algorithms_guaranteed.__contains__", ["sha256"],  true, "sha256 is in algorithms_guaranteed (SHA-2 256-bit; most widely used)"]
    - [contains_sha384,  "algorithms_guaranteed.__contains__", ["sha384"],  true, "sha384 is in algorithms_guaranteed (SHA-2 384-bit variant)"]
    - [contains_sha512,  "algorithms_guaranteed.__contains__", ["sha512"],  true, "sha512 is in algorithms_guaranteed (SHA-2 512-bit variant)"]
    - [contains_sha3_256, "algorithms_guaranteed.__contains__", ["sha3_256"], true, "sha3_256 is in algorithms_guaranteed (SHA-3 256-bit; Keccak-based)"]
    - [contains_blake2b, "algorithms_guaranteed.__contains__", ["blake2b"], true, "blake2b is in algorithms_guaranteed (BLAKE2 64-bit optimized variant)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed and algorithms_available type identity
#
# Wave 291 theme: algorithms_guaranteed and algorithms_available are plain sets.
#
# Both algorithms_guaranteed and algorithms_available are instances of the
# built-in set type (not frozenset). algorithms_guaranteed has 14 members in
# Python 3.14.3. algorithms_available is a superset containing additional
# hashes provided by the OpenSSL library (platform-dependent). No prior spec
# anchors the __class__.__name__ of both sets or len(algorithms_guaranteed)
# as a grouped table under hashlibalgos291.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra251.algo_set_type_identity:
  description: "algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__len__()==14 — both algo sets are plain set instances (not frozenset); len(algorithms_guaranteed)==14 on Python 3.14.3 (blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256); no prior spec anchors type identity of both sets together; first hashlibalgos291 anchor for set type identity"
  kind: python_call_eq
  category: set_identity
  id_prefix: hashlibalgos291

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_class,  "algorithms_guaranteed.__class__.__name__.__eq__",  ["set"], true, "algorithms_guaranteed is a plain set (not frozenset)"]
    - [available_class,   "algorithms_available.__class__.__name__.__eq__",   ["set"], true, "algorithms_available is a plain set (platform-dependent contents)"]
    - [guaranteed_len,    "algorithms_guaranteed.__len__",                     [],      14,   "algorithms_guaranteed has 14 entries in Python 3.14.3 on macOS"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('md5') is True. MD5 has been in
# the guaranteed set since Python 3.2 when hashlib.algorithms_guaranteed was
# introduced. Although MD5 is cryptographically broken for security uses (it is
# collision-prone), it remains in algorithms_guaranteed because it is widely
# used for checksums and non-security hashing. hashlib_extra.zspec anchors
# algorithms_guaranteed in a table row using 'md5' in membership checks;
# no prior spec anchors algorithms_guaranteed.__contains__('md5') as a
# standalone under hashlibalgos291. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra251.algorithms_guaranteed_contains_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 guaranteed on all Python platforms since algorithms_guaranteed was introduced in Python 3.2; MD5 is cryptographically broken but retained for checksums and non-security use; hashlib_extra anchors algorithms_guaranteed membership; no prior spec anchors __contains__('md5') as standalone; first standalone under hashlibalgos291"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha3_256') is True. SHA-3 (Keccak)
# was added to hashlib in Python 3.6 and all four SHA-3 variants (sha3_224,
# sha3_256, sha3_384, sha3_512) became guaranteed. SHA-3 uses a fundamentally
# different sponge construction (Keccak) compared to SHA-2's Merkle-Damgard
# structure. sha3_256 provides 256-bit output with 128-bit security level and
# is the most commonly used SHA-3 variant. No prior spec anchors
# algorithms_guaranteed.__contains__('sha3_256') as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra251.algorithms_guaranteed_contains_sha3_256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 guaranteed since Python 3.6 (SHA-3 family added); uses Keccak sponge construction (different from SHA-2 Merkle-Damgard); provides 256-bit output with 128-bit security level; most widely used SHA-3 variant; no prior spec anchors __contains__('sha3_256') as standalone; first standalone under hashlibalgos291"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__() == 14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 guaranteed algorithms
# in Python 3.14.3 are: blake2b, blake2s, md5, sha1, sha224, sha256, sha384,
# sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256.
# This count has been stable since Python 3.6 when SHA-3 and BLAKE2 were added.
# No prior spec anchors algorithms_guaranteed.__len__() as a standalone
# under hashlibalgos291. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra251.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — 14 guaranteed algorithms in Python 3.14.3: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256; count stable since Python 3.6 when SHA-3 and BLAKE2 were added; no prior spec anchors __len__() as standalone; first standalone under hashlibalgos291"
  category: set_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14
