# wait.__code__.co_varnames.__class__.__name__ == 'tuple'
# as_completed.__module__ == 'concurrent.futures._base'
# wait.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra74.as_completed_and_wait_code_attrs:
  description: "concurrent.futures as_completed and wait code attribute checks in cfmore74 namespace — wave 243 theme: as_completed/wait code attributes; as_completed.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple in CPython); wait.__code__.co_varnames.__class__.__name__=='tuple'; as_completed.__module__=='concurrent.futures._base' (defined in _base submodule); wait.__module__=='concurrent.futures._base'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore74a

  columns: [id, function, args, expected, description]
  rows:
    - [as_completed_varnames_cls, as_completed.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"],                        true, "as_completed.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; verified with Python 3.14.3"]
    - [wait_varnames_cls,         wait.__code__.co_varnames.__class__.__name__.__eq__,         ["tuple"],                        true, "wait.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; verified with Python 3.14.3"]
    - [as_completed_module,       as_completed.__module__.__eq__,                               ["concurrent.futures._base"],    true, "as_completed.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]
    - [wait_module,               wait.__module__.__eq__,                                       ["concurrent.futures._base"],    true, "wait.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]

