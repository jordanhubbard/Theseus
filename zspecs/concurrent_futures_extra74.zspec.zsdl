spec: concurrent_futures_extra74
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra73.zspec.zsdl."
    - "This spec covers: wave 243 theme — concurrent.futures Executor.__dict__ content + as_completed/wait code attributes. NEW in extra74: Executor.__dict__.__class__.__name__=='mappingproxy'; Executor.__dict__.__contains__('submit')==True; Executor.__dict__.__contains__('__enter__')==True; Executor.__dict__.__contains__('__exit__')==True; as_completed.__code__.co_varnames.__class__.__name__=='tuple'; wait.__code__.co_varnames.__class__.__name__=='tuple'; as_completed.__module__=='concurrent.futures._base'; wait.__module__=='concurrent.futures._base'; as_completed.__qualname__=='as_completed'; FIRST_EXCEPTION.__class__.__name__=='str'."
    - "concurrent.futures.Executor.__dict__.__class__.__name__ == 'mappingproxy'. Executor is a Python abstract base class in concurrent/futures/_base.py; its __dict__ is a read-only mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('submit') == True. Executor defines submit in its own __dict__ (raises NotImplementedError) in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('__enter__') == True. Executor is a context manager and defines __enter__ directly in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('__exit__') == True. Executor defines __exit__ directly in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_varnames.__class__.__name__ == 'tuple'. as_completed is a Python generator function in _base.py; code object co_varnames is always a tuple in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_varnames.__class__.__name__ == 'tuple'. wait is a Python function in _base.py; code object co_varnames is always a tuple in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'. as_completed is defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__module__ == 'concurrent.futures._base'. wait is defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__qualname__ == 'as_completed'. as_completed has a simple qualname (not nested inside a class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'. FIRST_EXCEPTION is a plain string constant in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Executor.__dict__ class name and method content — extra74
#
# Wave 243 theme: Executor.__dict__ content + as_completed/wait code attributes.
#
# Executor.__dict__.__class__.__name__ == 'mappingproxy'
# Executor.__dict__.__contains__('submit') == True
# Executor.__dict__.__contains__('__enter__') == True
# Executor.__dict__.__contains__('__exit__') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra74.Executor_dict_content:
  description: "concurrent.futures Executor.__dict__ class name and method content checks in cfmore74 namespace — wave 243 theme: Executor.__dict__ content; Executor.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); Executor.__dict__.__contains__('submit')==True (Executor defines submit to raise NotImplementedError); Executor.__dict__.__contains__('__enter__')==True (Executor is a context manager); Executor.__dict__.__contains__('__exit__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: cfmore74

  columns: [id, function, args, expected, description]
  rows:
    - [exec_dict_class_name,  Executor.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Executor.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [exec_dict_has_submit,  Executor.__dict__.__contains__,              ["submit"],        true, "Executor.__dict__.__contains__('submit') == True — Executor defines submit (raises NotImplementedError) in concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [exec_dict_has_enter,   Executor.__dict__.__contains__,              ["__enter__"],     true, "Executor.__dict__.__contains__('__enter__') == True — Executor is a context manager and defines __enter__ in _base.py; verified with Python 3.14.3"]
    - [exec_dict_has_exit,    Executor.__dict__.__contains__,              ["__exit__"],      true, "Executor.__dict__.__contains__('__exit__') == True — Executor defines __exit__ in concurrent/futures/_base.py; verified with Python 3.14.3"]

