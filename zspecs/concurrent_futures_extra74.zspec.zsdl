invariant concurrent_futures_extra74.Executor_dict_class_name:
  description: "concurrent.futures.Executor.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — Executor is an abstract base class in concurrent/futures/_base.py; its class __dict__ is a read-only mappingproxy; NEW in extra74: first standalone __dict__.__class__.__name__ invariant for Executor in cfmore74 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Executor.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant concurrent_futures_extra74.Executor_dict_has_enter:
  description: "concurrent.futures.Executor.__dict__.__contains__('__enter__') returns True — Executor is a context manager and defines __enter__ directly in concurrent/futures/_base.py; NEW in extra74: first standalone __contains__('__enter__') invariant for Executor.__dict__ in cfmore74 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Executor.__dict__.__contains__
  args: ["__enter__"]
  expected: true

invariant concurrent_futures_extra74.as_completed_varnames_class_name:
  description: "concurrent.futures.as_completed.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — as_completed is a Python generator function; co_varnames is always a tuple in CPython; NEW in extra74: first standalone co_varnames.__class__.__name__ invariant for as_completed in cfmore74 namespace; wave 243; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: as_completed.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra74.as_completed_qualname:
  description: "concurrent.futures.as_completed.__qualname__.__eq__('as_completed') returns True — as_completed has a simple qualname (not nested inside a class); NEW in extra74: first standalone __qualname__ invariant for as_completed in cfmore74 namespace; wave 243; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: as_completed.__qualname__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra74.wait_varnames_class_name:
  description: "concurrent.futures.wait.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — wait is a Python function; co_varnames is always a tuple in CPython; NEW in extra74: first standalone co_varnames.__class__.__name__ invariant for wait in cfmore74 namespace; wave 243; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_varnames.__class__.__name__.__eq__
