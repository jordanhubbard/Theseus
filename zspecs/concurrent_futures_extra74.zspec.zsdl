table concurrent_futures_extra74.as_completed_qualname_and_first_exception:
  description: "concurrent.futures as_completed.__qualname__ and FIRST_EXCEPTION.__class__.__name__ checks in cfmore74 namespace — wave 243 theme: as_completed identity + constant type; as_completed.__qualname__=='as_completed' (simple qualname, not nested in a class); FIRST_EXCEPTION.__class__.__name__=='str' (plain string constant in _base.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmore74b

  columns: [id, function, args, expected, description]
  rows:
    - [as_completed_qualname,       as_completed.__qualname__.__eq__,             ["as_completed"], true, "as_completed.__qualname__ == 'as_completed' — simple qualname (not nested inside a class); verified with Python 3.14.3"]
    - [first_exception_class_name,  FIRST_EXCEPTION.__class__.__name__.__eq__,    ["str"],          true, "FIRST_EXCEPTION.__class__.__name__ == 'str' — FIRST_EXCEPTION is a plain string constant in concurrent/futures/_base.py; verified with Python 3.14.3"]

