table concurrent_futures_extra74.Executor_dict_and_code_cross_check:
  description: "concurrent.futures Executor.__dict__ class and as_completed/wait module cross-check in cfmore74 namespace — wave 243 theme: Executor dict + code attribute cross-check; Executor.__dict__.__class__.__name__=='mappingproxy'; as_completed.__module__=='concurrent.futures._base'; wait.__module__=='concurrent.futures._base'; as_completed.__qualname__=='as_completed'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: cfmore74c

  columns: [id, function, args, expected, description]
  rows:
    - [exec_dict_cls_check,        Executor.__dict__.__class__.__name__.__eq__, ["mappingproxy"],              true, "Executor.__dict__.__class__.__name__ == 'mappingproxy' — cross-check; verified with Python 3.14.3"]
    - [as_completed_module_check,  as_completed.__module__.__eq__,              ["concurrent.futures._base"],  true, "as_completed.__module__ == 'concurrent.futures._base' — cross-check; verified with Python 3.14.3"]
    - [wait_module_check,          wait.__module__.__eq__,                      ["concurrent.futures._base"],  true, "wait.__module__ == 'concurrent.futures._base' — cross-check; verified with Python 3.14.3"]

