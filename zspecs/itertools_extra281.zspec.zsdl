spec: itertools_extra281
version: ">=3.1"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.chain(42) does not raise at construction time; TypeError is raised only when the iterator is advanced (next() call)."
    - "The error message is: 'int' object is not iterable."
    - "itertools.groupby is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __name__ == 'groupby'."
    - "itertools.groupby.__doc__ is not None — groupby ships with a docstring."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain — TypeError when iterating over a non-iterable argument
#
# chain(42) constructs successfully; TypeError is raised on the first next() call.
# The error class is TypeError (not ValueError or StopIteration).
# ---------------------------------------------------------------------------

table itertools_extra281.chain_non_iterable_raises:
  description: "itertools.chain raises TypeError when iterating over a non-iterable argument; verified with Python 3.14.3"
  kind: python_call_raises
  category: error_cases
  id_prefix: itex281cr

  columns: [id, function, args, expected, description]
  rows:
    - [cr_int,   chain, [42],  TypeError, "chain(42) raises TypeError when iterated — int is not iterable; verified with Python 3.14.3"]
    - [cr_float, chain, [3.0], TypeError, "chain(3.0) raises TypeError when iterated — float is not iterable; verified with Python 3.14.3"]
    - [cr_bool,  chain, [true], TypeError, "chain(True) raises TypeError when iterated — bool is not iterable; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.groupby — C-level type identity
#
# groupby.__name__ == 'groupby'; __module__ == 'itertools'; __class__.__name__ == 'type'.
# groupby.__doc__ is not None.
# ---------------------------------------------------------------------------

table itertools_extra281.groupby_identity:
  description: "itertools.groupby identity — __name__, __module__, __class__.__name__, doc presence; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex281gi

  columns: [id, function, args, expected, description]
  rows:
    - [gi_name_eq,  groupby.__name__.__eq__,           ["groupby"],   true,  "itertools.groupby.__name__ == 'groupby'; verified with Python 3.14.3"]
    - [gi_name_len, groupby.__name__.__len__,            [],           7,     "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 chars; verified with Python 3.14.3"]
    - [gi_mod_eq,   groupby.__module__.__eq__,           ["itertools"], true,  "itertools.groupby.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [gi_cls_eq,   groupby.__class__.__name__.__eq__,   ["type"],     true,  "itertools.groupby.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [gi_doc_none, groupby.__doc__.__eq__,              [null],       false, "itertools.groupby.__doc__ is not None — groupby ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra281
# ---------------------------------------------------------------------------

invariant itertools_extra281.chain_int_raises_typeerror:
  description: "itertools.chain(42) raises TypeError when iterated — 'int' object is not iterable"
  category: error_cases
  kind: python_call_raises
  function: chain
  args: [42]
  raises: TypeError

invariant itertools_extra281.groupby_name_is_groupby:
  description: "itertools.groupby.__name__ == 'groupby' — the C-level type's __name__ matches the public API name"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra281.groupby_module_is_itertools:
  description: "itertools.groupby.__module__ == 'itertools' — groupby is registered in the itertools module"
  category: identity
  kind: python_call_eq
  function: groupby.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra281.groupby_is_type:
  description: "itertools.groupby.__class__.__name__ == 'type' — groupby is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: groupby.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra281.groupby_name_length_is_7:
  description: "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra281.groupby_has_docstring:
  description: "itertools.groupby.__doc__.__eq__(None) == False — groupby ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: groupby.__doc__.__eq__
  args: [null]
  expected: false
