error_model: python_exceptions

# ---------------------------------------------------------------------------
# algorithms_guaranteed membership — core digest algorithms
# ---------------------------------------------------------------------------

table hashlib_extra207.algorithms_guaranteed_core_digests:
  description: "hashlib.algorithms_guaranteed.__contains__ checks for md5, sha1, sha256, sha512 — the four core digest algorithms required on every Python 3.9+ platform"
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: hashlibalgos207

  columns: [id, function, args, expected, description]
  rows:
    - [ag_md5,    algorithms_guaranteed.__contains__, ["md5"],    true, "hashlib.algorithms_guaranteed.__contains__('md5') — md5 is in the guaranteed algorithm set"]
    - [ag_sha1,   algorithms_guaranteed.__contains__, ["sha1"],   true, "hashlib.algorithms_guaranteed.__contains__('sha1') — sha1 is in the guaranteed algorithm set"]
    - [ag_sha256, algorithms_guaranteed.__contains__, ["sha256"], true, "hashlib.algorithms_guaranteed.__contains__('sha256') — sha256 is in the guaranteed algorithm set"]
    - [ag_sha512, algorithms_guaranteed.__contains__, ["sha512"], true, "hashlib.algorithms_guaranteed.__contains__('sha512') — sha512 is in the guaranteed algorithm set"]

# ---------------------------------------------------------------------------
# algorithms_guaranteed membership — SHA-3 and BLAKE2 families
# ---------------------------------------------------------------------------

table hashlib_extra207.algorithms_guaranteed_sha3_blake2:
  description: "hashlib.algorithms_guaranteed.__contains__ checks for sha3_256, sha3_512, blake2b, blake2s — SHA-3 and BLAKE2 algorithms required since Python 3.6"
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: hashlibalgos207

  columns: [id, function, args, expected, description]
  rows:
    - [ag_sha3_256, algorithms_guaranteed.__contains__, ["sha3_256"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_256') — sha3_256 is in the guaranteed algorithm set"]
    - [ag_sha3_512, algorithms_guaranteed.__contains__, ["sha3_512"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_512') — sha3_512 is in the guaranteed algorithm set"]
    - [ag_blake2b,  algorithms_guaranteed.__contains__, ["blake2b"],  true, "hashlib.algorithms_guaranteed.__contains__('blake2b') — blake2b is in the guaranteed algorithm set"]
    - [ag_blake2s,  algorithms_guaranteed.__contains__, ["blake2s"],  true, "hashlib.algorithms_guaranteed.__contains__('blake2s') — blake2s is in the guaranteed algorithm set"]

# ---------------------------------------------------------------------------
# algorithms_guaranteed length and algorithms_available md5 membership
# ---------------------------------------------------------------------------

table hashlib_extra207.algorithms_set_cardinality_and_available:
  description: "hashlib.algorithms_guaranteed.__len__()==14; algorithms_available.__contains__('md5')==True — cardinality of the guaranteed set and md5 availability"
  kind: python_call_eq
  category: algorithms_set
  id_prefix: hashlibalgos207

  columns: [id, function, args, expected, description]
  rows:
    - [ag_len,         algorithms_guaranteed.__len__,        [], 14,   "hashlib.algorithms_guaranteed.__len__() == 14 — exactly 14 algorithms are guaranteed on Python 3.14.3"]
    - [aa_md5,         algorithms_available.__contains__,    ["md5"], true, "hashlib.algorithms_available.__contains__('md5') — md5 is available on every platform"]
    - [ag_sha256_2,    algorithms_guaranteed.__contains__,   ["sha256"], true, "hashlib.algorithms_guaranteed.__contains__('sha256') re-anchored in cardinality table"]
    - [ag_blake2b_2,   algorithms_guaranteed.__contains__,   ["blake2b"], true, "hashlib.algorithms_guaranteed.__contains__('blake2b') re-anchored in cardinality table"]

