spec: io3121
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (io3121): __ge__, __repr__, __str__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IOBase."
    - "No io class defines __ge__ in its own __dict__: io stream classes do not implement ordering operators."
    - "io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper define __repr__ in their own __dict__; the abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) and BytesIO/StringIO do not."
    - "No io class defines __str__ in its own __dict__: str() falls back to __repr__ or the inherited object.__str__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# No io stream class defines __ge__ in its own __dict__; all false.
# io classes are I/O stream abstractions; ordering operators are not defined.
# ---------------------------------------------------------------------------

table io3121.ge:
  description: "io types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3121

  columns: [id, function, args, expected]
  rows:
    - ["io3121001", operator.contains, [io.RawIOBase.__dict__,      "__ge__"], false]
    - ["io3121002", operator.contains, [io.BufferedIOBase.__dict__,  "__ge__"], false]
    - ["io3121003", operator.contains, [io.TextIOBase.__dict__,      "__ge__"], false]
    - ["io3121004", operator.contains, [io.BytesIO.__dict__,         "__ge__"], false]
    - ["io3121005", operator.contains, [io.StringIO.__dict__,        "__ge__"], false]
    - ["io3121006", operator.contains, [io.FileIO.__dict__,          "__ge__"], false]
    - ["io3121007", operator.contains, [io.BufferedReader.__dict__,  "__ge__"], false]
    - ["io3121008", operator.contains, [io.BufferedWriter.__dict__,  "__ge__"], false]
    - ["io3121009", operator.contains, [io.BufferedRandom.__dict__,  "__ge__"], false]
    - ["io3121010", operator.contains, [io.TextIOWrapper.__dict__,   "__ge__"], false]
    - ["io3121011", operator.contains, [io.IOBase.__dict__,          "__ge__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and
# io.TextIOWrapper define __repr__ (true): concrete stream classes provide
# a human-readable representation showing mode, name, and encoding where relevant.
# io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, and
# io.StringIO do NOT define __repr__ in their own __dict__ (false).
# ---------------------------------------------------------------------------

table io3121.repr:
  description: "io types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3121

  columns: [id, function, args, expected]
  rows:
    - ["io3121012", operator.contains, [io.RawIOBase.__dict__,      "__repr__"], false]
    - ["io3121013", operator.contains, [io.BufferedIOBase.__dict__,  "__repr__"], false]
    - ["io3121014", operator.contains, [io.TextIOBase.__dict__,      "__repr__"], false]
    - ["io3121015", operator.contains, [io.BytesIO.__dict__,         "__repr__"], false]
    - ["io3121016", operator.contains, [io.StringIO.__dict__,        "__repr__"], false]
    - ["io3121017", operator.contains, [io.FileIO.__dict__,          "__repr__"], true]
    - ["io3121018", operator.contains, [io.BufferedReader.__dict__,  "__repr__"], true]
    - ["io3121019", operator.contains, [io.BufferedWriter.__dict__,  "__repr__"], true]
    - ["io3121020", operator.contains, [io.BufferedRandom.__dict__,  "__repr__"], true]
    - ["io3121021", operator.contains, [io.TextIOWrapper.__dict__,   "__repr__"], true]
    - ["io3121022", operator.contains, [io.IOBase.__dict__,          "__repr__"], false]

# ---------------------------------------------------------------------------
