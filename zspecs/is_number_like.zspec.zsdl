spec: is_number_like
version: ">=1.0.8"
backend: node(is-number-like)

docs: https://www.npmjs.com/package/is-number-like

provenance:
  derived_from:
    - "is-number-like README — https://www.npmjs.com/package/is-number-like"
    - "Test vectors verified with is-number-like via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-number-like source"
  notes:
    - "is-number-like is an npm package. Install: npm install is-number-like"
    - "Returns true if the value can be coerced to a number (numeric strings and numbers)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_number_like.check:
  kind: node_module_call_eq
  function: ~
  category: validation
  id_prefix: inuml

  columns: [id, args, expected]
  rows:
    - [number,    [42],     true]
    - [float,     [3.14],   true]
    - [str_num,   ["42"],   true]
