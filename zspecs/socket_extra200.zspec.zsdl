spec: socket_extra200
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.gethostname, gethostbyname, setdefaulttimeout are C-level built-ins: __class__.__name__ == 'builtin_function_or_method'."
    - "socket.getaddrinfo is a Python-level function in Lib/socket.py: __class__.__name__ == 'function'."
    - "socket.create_connection, create_server, getfqdn are Python-level functions: __class__.__name__ == 'function'."
    - "socket.socket is a type object (the socket class): __class__.__name__ == 'type'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ for socket module-level C-level built-in functions
# ---------------------------------------------------------------------------

table socket_extra200.functions_builtin:
  kind: python_call_eq
  category: types
  id_prefix: socketclasses200builtin

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_class,       gethostname.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'"]
    - [gethostbyname_class,     gethostbyname.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method'"]
    - [setdefaulttimeout_class, setdefaulttimeout.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# __class__.__name__ for socket module-level Python functions
# ---------------------------------------------------------------------------

table socket_extra200.functions_python:
  kind: python_call_eq
  category: types
  id_prefix: socketclasses200python

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_class,      getaddrinfo.__class__.__name__.__eq__,      ["function"], true, "socket.getaddrinfo.__class__.__name__ == 'function' — Python-level wrapper in Lib/socket.py"]
    - [create_connection_class, create_connection.__class__.__name__.__eq__, ["function"], true, "socket.create_connection.__class__.__name__ == 'function' — pure-Python convenience function"]
    - [create_server_class,    create_server.__class__.__name__.__eq__,    ["function"], true, "socket.create_server.__class__.__name__ == 'function' — pure-Python convenience function"]
    - [getfqdn_class,          getfqdn.__class__.__name__.__eq__,          ["function"], true, "socket.getfqdn.__class__.__name__ == 'function' — pure-Python FQDN lookup"]

# ---------------------------------------------------------------------------
# __class__.__name__ for socket.socket — the socket class itself
# ---------------------------------------------------------------------------

table socket_extra200.socket_type:
  kind: python_call_eq
  category: types
  id_prefix: socketclasses200type

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class, socket.__class__.__name__.__eq__, ["type"], true, "socket.socket.__class__.__name__ == 'type' — socket is a class (type object)"]

