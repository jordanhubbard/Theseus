spec: pathlib_extra67
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra66.zspec.zsdl — covers pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16; pathlib.__spec__.origin.__class__.__name__.__eq__('str'); pathlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('list'); pathlib.__spec__.has_location.__eq__(True)."
    - "pathlib_extra65.zspec.zsdl — covers pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader'); pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec'); pathlib.__file__.__class__.__name__.__eq__('str'); pathlib.__cached__.__class__.__name__.__eq__('str')."
    - "pathlib_extra52.zspec.zsdl — covers PurePath.__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__len__() (16/17/19/15/17 respectively); Path.open/read_text/write_text __qualname__.__len__() (9/14/15)."
    - "pathlib_extra44.zspec.zsdl — covers various PurePath/Path method __qualname__.__len__() values."
    - "pathlib_extra43.zspec.zsdl — covers PurePath/Path __qualname__ length checks."
    - "pathlib_extra63.zspec.zsdl — covers pathlib.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==7; Path/PurePath/PurePosixPath/PureWindowsPath __eq__.__class__.__name__.__eq__('function')."
  notes:
    - "This spec extends pathlib_extra66.zspec.zsdl."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "PurePath.__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__eq__() — pathlib_extra52 covers the __qualname__.__len__() values for these five PurePath dunder methods (16/17/19/15/17). No prior pathlib spec checks their __qualname__.__eq__() string equality form. Novel equality anchors in pathlibqual67 namespace. PurePath is a pure Python class (Lib/pathlib/__init__.py) so these are regular functions with standard __qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open/__repr__.__qualname__.__eq__() — pathlib_extra52 covers Path.open/__qualname__.__len__()==9; Path.read_text/__len__()==14; Path.write_text/__len__()==15. No prior pathlib spec checks __qualname__.__eq__() for Path.open/read_text/write_text. Novel equality anchors in pathlibqual67 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath dunder method __qualname__.__eq__() string equality
#
# PurePath is a pure Python class (Lib/pathlib/__init__.py). Its dunder
# methods are regular Python functions. Their __qualname__ follows the pattern
# 'PurePath.<method_name>'.
#
#   PurePath.__str__.__qualname__    == 'PurePath.__str__'    (len 16)
#   PurePath.__repr__.__qualname__   == 'PurePath.__repr__'   (len 17)
#   PurePath.__fspath__.__qualname__ == 'PurePath.__fspath__' (len 19)
#   PurePath.__eq__.__qualname__     == 'PurePath.__eq__'     (len 15)
#   PurePath.__hash__.__qualname__   == 'PurePath.__hash__'   (len 17)
#
# pathlib_extra52 covers the __qualname__.__len__() values for all five.
# No prior pathlib spec checks any of these via __qualname__.__eq__().
# Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra67.purepath_dunder_qualnames:
  description: "PurePath.__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__eq__() — PurePath is pure Python so these are regular functions with __qualname__=='PurePath.<method>'; pathlib_extra52 covers __qualname__.__len__() for all five (16/17/19/15/17); no prior pathlib spec checks __qualname__.__eq__() for any PurePath dunder method; novel equality anchors in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: pathlibqual67pp

  columns: [id, function, args, expected]
  rows:
    - [str_qualname_eq,    "PurePath.__str__.__qualname__.__eq__",    ["PurePath.__str__"],    true]
    - [repr_qualname_eq,   "PurePath.__repr__.__qualname__.__eq__",   ["PurePath.__repr__"],   true]
    - [fspath_qualname_eq, "PurePath.__fspath__.__qualname__.__eq__", ["PurePath.__fspath__"], true]
    - [eq_qualname_eq,     "PurePath.__eq__.__qualname__.__eq__",     ["PurePath.__eq__"],     true]
    - [hash_qualname_eq,   "PurePath.__hash__.__qualname__.__eq__",   ["PurePath.__hash__"],   true]

# ---------------------------------------------------------------------------
# Path.open / read_text / write_text __qualname__.__eq__() string equality
#
# Path is a pure Python class inheriting from PurePath. These three methods
# are defined directly on Path; their __qualname__ follows 'Path.<method>'.
#
#   Path.open.__qualname__       == 'Path.open'       (len 9)
#   Path.read_text.__qualname__  == 'Path.read_text'  (len 14)
#   Path.write_text.__qualname__ == 'Path.write_text' (len 15)
#
# pathlib_extra52 covers the __qualname__.__len__() values for all three.
# No prior pathlib spec checks these via __qualname__.__eq__() string equality.
# Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra67.path_method_qualnames:
  description: "Path.open/read_text/write_text __qualname__.__eq__() — Path is pure Python; these methods are defined directly on Path so __qualname__=='Path.<method>'; pathlib_extra52 covers __qualname__.__len__() for all three (9/14/15); no prior pathlib spec checks __qualname__.__eq__() for Path.open/read_text/write_text; novel equality anchors in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: pathlibqual67path

  columns: [id, function, args, expected]
  rows:
    - [open_qualname_eq,       Path.open.__qualname__.__eq__,       ["Path.open"],       true]
    - [read_text_qualname_eq,  Path.read_text.__qualname__.__eq__,  ["Path.read_text"],  true]
    - [write_text_qualname_eq, Path.write_text.__qualname__.__eq__, ["Path.write_text"], true]

invariant pathlib_extra67.purepath_str_qualname_eq:
  description: "PurePath.__str__.__qualname__.__eq__('PurePath.__str__') == True — PurePath is pure Python; __str__ is a function defined on PurePath with __qualname__=='PurePath.__str__' (16 chars); pathlib_extra52 covers __len__()==16; no prior pathlib spec checks __qualname__.__eq__() for PurePath.__str__; novel equality anchor in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: "PurePath.__str__.__qualname__.__eq__"
  args: ["PurePath.__str__"]
  expected: true

invariant pathlib_extra67.purepath_fspath_qualname_eq:
  description: "PurePath.__fspath__.__qualname__.__eq__('PurePath.__fspath__') == True — PurePath is pure Python; __fspath__ is a function defined on PurePath with __qualname__=='PurePath.__fspath__' (19 chars); pathlib_extra52 covers __len__()==19; no prior pathlib spec checks __qualname__.__eq__() for PurePath.__fspath__; novel equality anchor in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: "PurePath.__fspath__.__qualname__.__eq__"
  args: ["PurePath.__fspath__"]
  expected: true

invariant pathlib_extra67.purepath_hash_qualname_eq:
  description: "PurePath.__hash__.__qualname__.__eq__('PurePath.__hash__') == True — PurePath is pure Python; __hash__ is a function defined on PurePath with __qualname__=='PurePath.__hash__' (17 chars); pathlib_extra52 covers __len__()==17; no prior pathlib spec checks __qualname__.__eq__() for PurePath.__hash__; novel equality anchor in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: "PurePath.__hash__.__qualname__.__eq__"
  args: ["PurePath.__hash__"]
  expected: true

invariant pathlib_extra67.path_open_qualname_eq:
  description: "Path.open.__qualname__.__eq__('Path.open') == True — Path is pure Python; open is a function defined on Path with __qualname__=='Path.open' (9 chars); pathlib_extra52 covers __len__()==9; no prior pathlib spec checks __qualname__.__eq__() for Path.open in string equality form; novel equality anchor in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra67.path_read_text_qualname_eq:
  description: "Path.read_text.__qualname__.__eq__('Path.read_text') == True — Path is pure Python; read_text is a function defined on Path with __qualname__=='Path.read_text' (14 chars); pathlib_extra52 covers __len__()==14; no prior pathlib spec checks __qualname__.__eq__() for Path.read_text; novel equality anchor in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra67.path_write_text_qualname_eq:
  description: "Path.write_text.__qualname__.__eq__('Path.write_text') == True — Path is pure Python; write_text is a function defined on Path with __qualname__=='Path.write_text' (15 chars); pathlib_extra52 covers __len__()==15; no prior pathlib spec checks __qualname__.__eq__() for Path.write_text; novel equality anchor in pathlibqual67 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Path.write_text.__qualname__.__eq__
  args: ["Path.write_text"]
  expected: true
