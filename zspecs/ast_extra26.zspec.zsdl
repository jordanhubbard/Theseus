spec: ast_extra26
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra25.zspec.zsdl — covers Expression/Interactive __qualname__/__module__; abstract category class __qualname__ and __bases__[0].__name__ (table)"
    - "ast_extra24.zspec.zsdl — covers parse/dump/literal_eval/fix_missing_locations/walk/unparse __module__; AST/Module/NodeVisitor/NodeTransformer __module__; NodeVisitor/NodeTransformer __bases__[0].__name__; unparse/__qualname__ standalone"
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval and these two methods"
    - "ast_extra16.zspec.zsdl — covers NodeVisitor/__qualname__.__eq__; NodeTransformer/__qualname__.__eq__"
  notes:
    - "This spec extends ast_extra25.zspec.zsdl."
    - "Prior specs covered: ast.__name__/__package__, parse/__name__/__module__, dump/__name__/__module__, literal_eval/__name__/__module__, get_docstring/__name__, fix_missing_locations/__name__, walk/__name__, unparse/__name__, NodeVisitor/__name__/__module__/__qualname__, NodeTransformer/__name__/__module__, AST/__name__/__module__, parse/dump/literal_eval/__qualname__, NodeVisitor/__bases__[0].__name__, NodeTransformer/__bases__[0].__name__, AST/__bases__[0].__name__, various __qualname__ checks, abstract category class quals and bases."
    - "This spec covers: ast.parse.__module__.__len__(), ast.dump.__module__.__len__(), ast.literal_eval.__module__.__len__() (all == 3, 'ast' has length 3); ast.NodeVisitor.__init__.__name__ (inherited from object, == '__init__'); ast.NodeTransformer.__init__.__name__ (inherited from object, == '__init__'); ast.NodeVisitor.visit.__name__ and __qualname__; ast.NodeVisitor.generic_visit.__name__ and __qualname__; ast.NodeTransformer.generic_visit.__name__ and __qualname__."
    - "ast.parse.__module__.__len__() == 3 — 'ast' has 3 characters; no prior ast spec covers this as a standalone __eq__ invariant."
    - "ast.dump.__module__.__len__() == 3 — same; no prior ast spec covers this."
    - "ast.literal_eval.__module__.__len__() == 3 — same; no prior ast spec covers this."
    - "ast.NodeVisitor.__init__.__name__ == '__init__' — NodeVisitor does not define __init__; it is inherited from object; __name__ is still '__init__'."
    - "ast.NodeTransformer.__init__.__name__ == '__init__' — same situation as NodeVisitor."
    - "ast.NodeVisitor.visit.__name__ == 'visit' — no prior ast spec covers visit.__name__ as a standalone __eq__ invariant."
    - "ast.NodeVisitor.visit.__qualname__ == 'NodeVisitor.visit' — ast_extra22 covers this via __qualname__.__eq__ in its namespace; distinct standalone invariant in ast_extra26 namespace."
    - "ast.NodeVisitor.generic_visit.__name__ == 'generic_visit' — no prior ast spec covers this as a standalone __eq__ invariant."
    - "ast.NodeVisitor.generic_visit.__qualname__ == 'NodeVisitor.generic_visit' — ast_extra22 covers generic_visit qualname length; no prior spec covers the __eq__ standalone in ast_extra26 namespace."
    - "ast.NodeTransformer.generic_visit.__name__ == 'generic_visit' — no prior ast spec covers this as a standalone __eq__ invariant."
    - "ast.NodeTransformer.generic_visit.__qualname__ == 'NodeTransformer.generic_visit' — ast_extra22 covers this in its namespace; distinct standalone invariant in ast_extra26 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# parse/dump/literal_eval __module__.__len__() — standalone invariants
# (ast_extra26 namespace)
#
# 'ast' has 3 characters. ast_extra24 covers __module__.__eq__ for these
# functions. No prior ast spec covers __module__.__len__() for any of them
# as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

invariant ast_extra26.parse.module_len:
  description: "ast.parse.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: parse.__module__.__len__
  args: []
  expected: 3

invariant ast_extra26.dump.module_len:
  description: "ast.dump.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: dump.__module__.__len__
  args: []
  expected: 3

invariant ast_extra26.literal_eval.module_len:
  description: "ast.literal_eval.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: literal_eval.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# NodeVisitor.__init__ and NodeTransformer.__init__ __name__
# (ast_extra26 namespace)
#
# Neither NodeVisitor nor NodeTransformer defines __init__; both inherit it
# from object. The __name__ attribute is still '__init__'. The __qualname__
# is 'object.__init__', reflecting the actual defining class.
# No prior ast spec covers these __name__ values as standalone invariants.
# ---------------------------------------------------------------------------

invariant ast_extra26.NodeVisitor_init.name:
  description: "ast.NodeVisitor.__init__.__name__ == '__init__' — inherited from object; __name__ is '__init__'"
  category: method_names
  kind: python_call_eq
  function: NodeVisitor.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant ast_extra26.NodeTransformer_init.name:
  description: "ast.NodeTransformer.__init__.__name__ == '__init__' — inherited from object; __name__ is '__init__'"
  category: method_names
  kind: python_call_eq
  function: NodeTransformer.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# NodeVisitor.visit __name__ and __qualname__ — standalone invariants
# (ast_extra26 namespace)
#
# ast_extra22 covers NodeVisitor.visit/__qualname__.__eq__ in its namespace.
# No prior ast spec covers NodeVisitor.visit.__name__ as a standalone invariant.
# These are distinct standalone invariants in the ast_extra26 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra26.NodeVisitor_visit.name:
  description: "ast.NodeVisitor.visit.__name__ == 'visit'"
  category: method_names
  kind: python_call_eq
  function: NodeVisitor.visit.__name__.__eq__
  args: ["visit"]
  expected: true

invariant ast_extra26.NodeVisitor_visit.qualname:
  description: "ast.NodeVisitor.visit.__qualname__ == 'NodeVisitor.visit'"
  category: method_qualnames
  kind: python_call_eq
  function: NodeVisitor.visit.__qualname__.__eq__
  args: ["NodeVisitor.visit"]
  expected: true

# ---------------------------------------------------------------------------
# NodeVisitor.generic_visit and NodeTransformer.generic_visit
# __name__ and __qualname__ — table
# (ast_extra26 namespace)
#
# ast_extra22 covers generic_visit qualname __len__() values and
# NodeTransformer.generic_visit/__qualname__.__eq__ in its namespace.
# No prior ast spec covers generic_visit.__name__ for either class
# as a standalone __eq__ invariant. These are distinct invariants in
# the ast_extra26 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra26.NodeVisitor_generic_visit.name:
  description: "ast.NodeVisitor.generic_visit.__name__ == 'generic_visit'"
  category: method_names
  kind: python_call_eq
  function: NodeVisitor.generic_visit.__name__.__eq__
  args: ["generic_visit"]
  expected: true

invariant ast_extra26.NodeVisitor_generic_visit.qualname:
  description: "ast.NodeVisitor.generic_visit.__qualname__ == 'NodeVisitor.generic_visit'"
  category: method_qualnames
  kind: python_call_eq
  function: NodeVisitor.generic_visit.__qualname__.__eq__
  args: ["NodeVisitor.generic_visit"]
  expected: true

invariant ast_extra26.NodeTransformer_generic_visit.name:
  description: "ast.NodeTransformer.generic_visit.__name__ == 'generic_visit'"
  category: method_names
  kind: python_call_eq
  function: NodeTransformer.generic_visit.__name__.__eq__
  args: ["generic_visit"]
  expected: true

invariant ast_extra26.NodeTransformer_generic_visit.qualname:
  description: "ast.NodeTransformer.generic_visit.__qualname__ == 'NodeTransformer.generic_visit'"
  category: method_qualnames
  kind: python_call_eq
  function: NodeTransformer.generic_visit.__qualname__.__eq__
  args: ["NodeTransformer.generic_visit"]
  expected: true

# ---------------------------------------------------------------------------
# Module string lengths for parse, dump, literal_eval — table
# (ast_extra26 namespace)
#
# Convenience table grouping all three __module__.__len__() checks together.
# All three functions belong to the 'ast' module (length 3).
# ---------------------------------------------------------------------------

table ast_extra26.function_module_lengths:
  description: "__module__.__len__() for ast top-level functions — all equal 3 ('ast')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [parse,        parse.__module__.__len__,        [], 3]
    - [dump,         dump.__module__.__len__,         [], 3]
    - [literal_eval, literal_eval.__module__.__len__, [], 3]
