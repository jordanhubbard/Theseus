spec: inspect_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "inspect standard library module"
    - "CPython runtime function attribute inspection"
  not_derived_from:
    - "any third-party inspection or introspection packages"
    - "objinspect or similar tools"
  notes:
    - "Covers source/doc introspection function qualnames and module membership"
    - "All listed functions are pure Python functions defined directly in inspect"
    - "__qualname__ and __module__ together uniquely identify function provenance"
  created_at: "2026-04-12"

table inspect_extra871.function_qualnames:
  description: "inspect module source/doc introspection function qualnames"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: in871xx
  columns: [id, function, args, expected]
  rows:
    - [in871xx001, inspect.getsourcefile.__qualname__.__eq__, ["getsourcefile"], true]
    - [in871xx002, inspect.getsourcefile.__module__.__eq__, ["inspect"], true]
    - [in871xx003, inspect.getsourcelines.__qualname__.__eq__, ["getsourcelines"], true]
    - [in871xx004, inspect.getsourcelines.__module__.__eq__, ["inspect"], true]
    - [in871xx005, inspect.getlineno.__qualname__.__eq__, ["getlineno"], true]
    - [in871xx006, inspect.getlineno.__module__.__eq__, ["inspect"], true]
    - [in871xx007, inspect.getmro.__qualname__.__eq__, ["getmro"], true]
    - [in871xx008, inspect.getmro.__module__.__eq__, ["inspect"], true]
    - [in871xx009, inspect.getclosurevars.__qualname__.__eq__, ["getclosurevars"], true]
    - [in871xx010, inspect.getclosurevars.__module__.__eq__, ["inspect"], true]
    - [in871xx011, inspect.getfullargspec.__qualname__.__eq__, ["getfullargspec"], true]
    - [in871xx012, inspect.getfullargspec.__module__.__eq__, ["inspect"], true]
