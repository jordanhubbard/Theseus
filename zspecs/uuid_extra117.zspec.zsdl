spec: uuid_extra117
version: ">=3.11"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra116.zspec.zsdl — covers UUID time-related property fget co_varnames[0]=='self' / fget qualname lengths for time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__ qualname equality and lengths / UUID.__init__.__code__.co_name/co_argcount equality (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__() (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers UUID property fget.__code__.co_name equality and co_argcount==1 (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier uuid specs."
    - "Wave 274 theme: uuid module-level function code object co_qualname equality and co_nlocals — uuid1/uuid3/uuid4/uuid5/getnode __code__.co_qualname and co_nlocals values."
    - "uuid.uuid1.__code__.co_qualname == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_qualname == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_qualname == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_qualname == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_qualname == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_nlocals == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_nlocals == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_nlocals == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_nlocals == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_nlocals == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_varnames[0] == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_varnames[0] == 'namespace'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_varnames[0] == 'int_uuid_4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_varnames[0] == 'namespace'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_varnames[0] == 'getter'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: co_qualname (Python 3.11+) equals co_name for top-level functions (no enclosing class or function). For uuid1/uuid3/uuid4/uuid5/getnode, co_qualname == co_name == the function name. This differs from methods where co_qualname would be 'ClassName.method_name'."
    - "Note: extra96 anchors co_name equality and co_argcount; extra86 anchors co_argcount at table level. This spec first anchors co_qualname equality and co_nlocals for uuid module functions."
    - "Note: co_nlocals counts ALL local variables including arguments (co_argcount <= co_nlocals always). uuid1 has co_nlocals==13 reflecting 2 args (node, clock_seq) + 11 locals. uuid3 and uuid5 share co_nlocals==5 (2 args + 3 locals: hashlib, h, int_uuid_N). uuid4 has co_nlocals==1 (0 args + 1 local: int_uuid_4). getnode has co_nlocals==1 (0 args + 1 local: getter)."
    - "Note: co_varnames[0] for uuid3 and uuid5 is 'namespace' (their first argument). For uuid1 it is 'node'. For uuid4 (no args) it is 'int_uuid_4' (the first local). For getnode (no args) it is 'getter'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_qualname.__eq__('uuid1')
# uuid.uuid3.__code__.co_qualname.__eq__('uuid3')
# uuid.uuid4.__code__.co_qualname.__eq__('uuid4')
# uuid.uuid5.__code__.co_qualname.__eq__('uuid5')
# uuid.getnode.__code__.co_qualname.__eq__('getnode')
#
# Wave 274 theme: uuid module function co_qualname equality.
#
# co_qualname (Python 3.11+) is the qualified name of the code object's
# function. For top-level functions (no enclosing class or function),
# co_qualname equals co_name. For uuid1/uuid3/uuid4/uuid5/getnode, all are
# top-level functions in Lib/uuid.py, so co_qualname equals the function name.
# extra96 anchors co_name equality; this spec first anchors co_qualname equality
# for uuid module functions under uuidcode117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra117.uuid_fn_co_qualname:
  description: "uuid.uuid1/__code__.co_qualname.__eq__('uuid1')==True / uuid3/__code__.co_qualname.__eq__('uuid3')==True / uuid4/__code__.co_qualname.__eq__('uuid4')==True / uuid5/__code__.co_qualname.__eq__('uuid5')==True / getnode/__code__.co_qualname.__eq__('getnode')==True — co_qualname equals co_name for top-level functions; Python 3.11+ attribute; extra96 anchors co_name equality; first uuidcode117 anchor for co_qualname equality"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcode117

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_co_qualname,   "uuid1.__code__.co_qualname.__eq__",   ["uuid1"],   true, "uuid1 is a top-level function so co_qualname == co_name == 'uuid1'"]
    - [uuid3_co_qualname,   "uuid3.__code__.co_qualname.__eq__",   ["uuid3"],   true, "uuid3 is a top-level function so co_qualname == co_name == 'uuid3'"]
    - [uuid4_co_qualname,   "uuid4.__code__.co_qualname.__eq__",   ["uuid4"],   true, "uuid4 is a top-level function so co_qualname == co_name == 'uuid4'"]
    - [uuid5_co_qualname,   "uuid5.__code__.co_qualname.__eq__",   ["uuid5"],   true, "uuid5 is a top-level function so co_qualname == co_name == 'uuid5'"]
    - [getnode_co_qualname, "getnode.__code__.co_qualname.__eq__", ["getnode"], true, "getnode is a top-level function so co_qualname == co_name == 'getnode'"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_nlocals.__eq__(13)
# uuid.uuid3.__code__.co_nlocals.__eq__(5)
# uuid.uuid4.__code__.co_nlocals.__eq__(1)
# uuid.uuid5.__code__.co_nlocals.__eq__(5)
# uuid.getnode.__code__.co_nlocals.__eq__(1)
#
# Wave 274 theme: uuid module function co_nlocals values.
#
# co_nlocals is the number of local variables (including arguments) used by
# the code object. uuid1 has 13 (2 args: node, clock_seq; 11 locals including
# uuid_time, safely_generated, is_safe, nanoseconds, etc.). uuid3 and uuid5
# each have 5 (2 args: namespace, name; 3 locals: hashlib, h, int_uuid_N).
# uuid4 has 1 (0 args; 1 local: int_uuid_4). getnode has 1 (0 args; 1 local:
# getter). No prior uuid spec anchors co_nlocals for these functions under
# uuidcode117. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra117.uuid_fn_co_nlocals:
  description: "uuid.uuid1/__code__.co_nlocals.__eq__(13)==True / uuid3/__code__.co_nlocals.__eq__(5)==True / uuid4/__code__.co_nlocals.__eq__(1)==True / uuid5/__code__.co_nlocals.__eq__(5)==True / getnode/__code__.co_nlocals.__eq__(1)==True — co_nlocals counts args + locals; uuid1 has 13 (2 args + 11 locals); uuid3/uuid5 share 5 (2 args + 3 locals); uuid4/getnode each have 1 (0 args + 1 local); no prior uuid spec anchors co_nlocals; first uuidcode117 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcode117

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_nlocals,   "uuid1.__code__.co_nlocals.__eq__",   [13], true, "uuid1 has 13 locals: 2 args (node, clock_seq) + 11 local vars (uuid_time, etc.)"]
    - [uuid3_nlocals,   "uuid3.__code__.co_nlocals.__eq__",   [5],  true, "uuid3 has 5 locals: 2 args (namespace, name) + 3 locals (hashlib, h, int_uuid_3)"]
    - [uuid4_nlocals,   "uuid4.__code__.co_nlocals.__eq__",   [1],  true, "uuid4 has 1 local: 0 args + 1 local (int_uuid_4); the simplest uuid generator"]
    - [uuid5_nlocals,   "uuid5.__code__.co_nlocals.__eq__",   [5],  true, "uuid5 has 5 locals: 2 args (namespace, name) + 3 locals (hashlib, h, int_uuid_5)"]
    - [getnode_nlocals, "getnode.__code__.co_nlocals.__eq__", [1],  true, "getnode has 1 local: 0 args + 1 local (getter); detects hardware MAC address"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_varnames[0].__eq__('node')
# uuid.uuid3.__code__.co_varnames[0].__eq__('namespace')
# uuid.uuid4.__code__.co_varnames[0].__eq__('int_uuid_4')
# uuid.uuid5.__code__.co_varnames[0].__eq__('namespace')
# uuid.getnode.__code__.co_varnames[0].__eq__('getter')
#
# Wave 274 theme: uuid module function co_varnames[0] equality.
#
# co_varnames is the tuple of all local variable names (args first, then locals).
# co_varnames[0] is the first entry: for functions with arguments, this is the
# first argument name; for functions with no arguments, this is the first local.
# uuid1's first arg is 'node'; uuid3/uuid5's first arg is 'namespace'; uuid4 has
# no args so co_varnames[0] is 'int_uuid_4' (first local); getnode has no args
# so co_varnames[0] is 'getter'. No prior uuid spec anchors co_varnames[0] for
# any uuid module function under uuidcode117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra117.uuid_fn_co_varnames_0:
  description: "uuid.uuid1/__code__.co_varnames[0].__eq__('node')==True / uuid3/__code__.co_varnames[0].__eq__('namespace')==True / uuid4/__code__.co_varnames[0].__eq__('int_uuid_4')==True / uuid5/__code__.co_varnames[0].__eq__('namespace')==True / getnode/__code__.co_varnames[0].__eq__('getter')==True — co_varnames[0] is first arg for functions with args (uuid1:'node', uuid3/uuid5:'namespace') or first local for no-arg functions (uuid4:'int_uuid_4', getnode:'getter'); no prior uuid spec anchors co_varnames[0]; first uuidcode117 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcode117

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_varnames0,   "uuid1.__code__.co_varnames[0].__eq__",   ["node"],       true, "uuid1 first arg is 'node' (optional MAC address override)"]
    - [uuid3_varnames0,   "uuid3.__code__.co_varnames[0].__eq__",   ["namespace"],  true, "uuid3 first arg is 'namespace' (UUID namespace for MD5-based deterministic UUID)"]
    - [uuid4_varnames0,   "uuid4.__code__.co_varnames[0].__eq__",   ["int_uuid_4"], true, "uuid4 has no args; first local is 'int_uuid_4' (random integer for UUID construction)"]
    - [uuid5_varnames0,   "uuid5.__code__.co_varnames[0].__eq__",   ["namespace"],  true, "uuid5 first arg is 'namespace' (UUID namespace for SHA-1-based deterministic UUID)"]
    - [getnode_varnames0, "getnode.__code__.co_varnames[0].__eq__", ["getter"],     true, "getnode has no args; first local is 'getter' (the MAC address getter function)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_qualname.__eq__('uuid1') — standalone
#
# uuid.uuid1.__code__.co_qualname is 'uuid1'. co_qualname (introduced in
# Python 3.11) stores the fully-qualified name of the code object. For
# top-level functions in uuid.py, co_qualname equals co_name. This is
# distinguishable from nested functions or methods where co_qualname would
# include the enclosing class or function name (e.g., 'UUID.__init__').
# extra96 anchors uuid1 co_name; this spec first anchors uuid1 co_qualname
# as a standalone under uuidcode117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra117.uuid1_co_qualname_eq:
  description: "uuid.uuid1.__code__.co_qualname.__eq__('uuid1') == True — co_qualname equals co_name for top-level functions (no enclosing scope); Python 3.11+ attribute; distinguishable from methods where co_qualname includes class prefix; extra96 anchors co_name equality; first standalone for uuid1 co_qualname under uuidcode117"
  category: code_attributes
  kind: python_call_eq
  function: "uuid1.__code__.co_qualname.__eq__"
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_nlocals.__eq__(1) — standalone
#
# uuid.uuid4.__code__.co_nlocals is 1. uuid4 takes no arguments and uses
# only a single local variable (int_uuid_4) to store the random 128-bit integer
# before constructing the UUID. This makes uuid4 the simplest uuid generator
# in terms of local variable count. uuid4 generates random UUIDs using
# os.urandom(16) for maximum randomness. No prior uuid spec anchors
# uuid4.__code__.co_nlocals as a standalone under uuidcode117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra117.uuid4_co_nlocals_1:
  description: "uuid.uuid4.__code__.co_nlocals.__eq__(1) == True — uuid4 uses only 1 local (int_uuid_4); 0 args + 1 local; simplest uuid generator by local count; generates random 128-bit UUID via os.urandom(16); no prior uuid spec anchors uuid4 co_nlocals as standalone; first standalone under uuidcode117"
  category: code_attributes
  kind: python_call_eq
  function: "uuid4.__code__.co_nlocals.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3.__code__.co_varnames[0].__eq__('namespace') — standalone
#
# uuid.uuid3.__code__.co_varnames[0] is 'namespace'. uuid3 generates a
# deterministic UUID from a namespace (UUID object) and a name (string) using
# MD5 hashing. The first argument to uuid3 is 'namespace', which must be one
# of the RFC 4122 namespace UUIDs (NAMESPACE_DNS, NAMESPACE_URL, etc.) or
# any other UUID. uuid5 shares the same first argument name 'namespace'.
# No prior uuid spec anchors uuid3 co_varnames[0] as a standalone under
# uuidcode117. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra117.uuid3_co_varnames0_namespace:
  description: "uuid.uuid3.__code__.co_varnames[0].__eq__('namespace') == True — uuid3 first arg is 'namespace' (a UUID object per RFC 4122); uuid3 uses MD5 hashing for deterministic UUID generation; uuid5 shares the same first arg name 'namespace'; no prior uuid spec anchors uuid3 co_varnames[0] as standalone; first standalone under uuidcode117"
  category: code_attributes
  kind: python_call_eq
  function: "uuid3.__code__.co_varnames[0].__eq__"
  args: ["namespace"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_nlocals.__eq__(13) — standalone
#
# uuid.uuid1.__code__.co_nlocals is 13. uuid1 is by far the most complex
# uuid generator with 13 local variables: 2 positional arguments (node,
# clock_seq) plus 11 internal locals (uuid_time, safely_generated, is_safe,
# nanoseconds, timestamp, random, time_low, time_mid, time_hi_version,
# clock_seq_low, clock_seq_hi_variant). uuid1 generates a time-based UUID
# using the host MAC address and current time. No prior uuid spec anchors
# uuid1 co_nlocals as a standalone under uuidcode117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra117.uuid1_co_nlocals_13:
  description: "uuid.uuid1.__code__.co_nlocals.__eq__(13) == True — uuid1 has 13 locals: 2 args (node, clock_seq) + 11 locals (uuid_time, safely_generated, is_safe, nanoseconds, timestamp, random, time_low, time_mid, time_hi_version, clock_seq_low, clock_seq_hi_variant); most complex uuid generator; no prior uuid spec anchors uuid1 co_nlocals as standalone; first standalone under uuidcode117"
  category: code_attributes
  kind: python_call_eq
  function: "uuid1.__code__.co_nlocals.__eq__"
  args: [13]
  expected: true

# ---------------------------------------------------------------------------
# uuid.getnode.__code__.co_varnames[0].__eq__('getter') — standalone
#
# uuid.getnode.__code__.co_varnames[0] is 'getter'. getnode takes no arguments;
# its first local variable is named 'getter', which holds a reference to the
# platform-specific function used to obtain the MAC address (e.g., by reading
# network interface info on Unix or using the Windows registry). getnode attempts
# several getter functions in sequence until one returns a valid address.
# No prior uuid spec anchors getnode co_varnames[0] as a standalone under
# uuidcode117. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra117.getnode_co_varnames0_getter:
  description: "uuid.getnode.__code__.co_varnames[0].__eq__('getter') == True — getnode has no args; first local is 'getter' (the platform-specific MAC address getter function); getnode tries multiple getter functions until one returns a valid MAC address; no prior uuid spec anchors getnode co_varnames[0] as standalone; first standalone under uuidcode117"
  category: code_attributes
  kind: python_call_eq
  function: "getnode.__code__.co_varnames[0].__eq__"
  args: ["getter"]
  expected: true
