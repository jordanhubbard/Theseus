spec: functools_extra1801
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and container protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra1801.truth_protocol:
  description: "functools types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1801

  columns: [id, function, args, expected]
  rows:
    - ["fu1801001", "functools.partial.__dict__.__contains__", ["__bool__"], false]
    - ["fu1801002", "functools.partial.__dict__.__contains__", ["__len__"], false]
    - ["fu1801003", "functools.reduce.__class__.__dict__.__contains__", ["__bool__"], false]
    - ["fu1801004", "functools.lru_cache.__class__.__dict__.__contains__", ["__bool__"], false]
    - ["fu1801005", "functools.cached_property.__dict__.__contains__", ["__bool__"], false]
    - ["fu1801006", "functools.cached_property.__dict__.__contains__", ["__len__"], false]
    - ["fu1801007", "functools.partialmethod.__dict__.__contains__", ["__bool__"], false]
    - ["fu1801008", "functools.partialmethod.__dict__.__contains__", ["__len__"], false]

table functools_extra1801.container_protocol:
  description: "functools types container and descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1801

  columns: [id, function, args, expected]
  rows:
    - ["fu1801101", "functools.partial.__dict__.__contains__", ["__contains__"], false]
    - ["fu1801102", "functools.partial.__dict__.__contains__", ["__getitem__"], false]
    - ["fu1801103", "functools.partial.__dict__.__contains__", ["__iter__"], false]
    - ["fu1801104", "functools.partial.__dict__.__contains__", ["__len__"], false]
    - ["fu1801105", "functools.cached_property.__dict__.__contains__", ["__get__"], true]
    - ["fu1801106", "functools.cached_property.__dict__.__contains__", ["__set__"], false]
    - ["fu1801107", "functools.cached_property.__dict__.__contains__", ["__delete__"], false]
    - ["fu1801108", "functools.cached_property.__dict__.__contains__", ["__set_name__"], true]

table functools_extra1801.lru_cache_attrs:
  description: "functools.partial and lru_cache dict-presence checks for key attributes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1801

  columns: [id, function, args, expected]
  rows:
    - ["fu1801201", "functools.lru_cache.__dict__.__contains__", ["__wrapped__"], false]
    - ["fu1801202", "functools.partial.__dict__.__contains__", ["func"], true]
    - ["fu1801203", "functools.partial.__dict__.__contains__", ["args"], true]
    - ["fu1801204", "functools.partial.__dict__.__contains__", ["keywords"], true]
    - ["fu1801205", "functools.partial.__dict__.__contains__", ["__doc__"], true]
    - ["fu1801206", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["fu1801207", "functools.partial.__dict__.__contains__", ["__setstate__"], true]
    - ["fu1801208", "functools.partial.__dict__.__contains__", ["__new__"], true]
