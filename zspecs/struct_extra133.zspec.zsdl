spec: struct_extra133
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra132.zspec.zsdl — covers Struct.size/format __name__ equality / Struct method __objclass__.__module__ / Struct.iter_unpack full identity / Struct.__sizeof__ identity (table + invariants)."
    - "struct_extra131.zspec.zsdl — covers Struct.__repr__ wrapper_descriptor identity / Struct.__str__/__hash__ inherited-from-object identity (qualname 'object.__str__'/'object.__hash__', __objclass__.__name__=='object') (table + invariants)."
    - "struct_extra130.zspec.zsdl — covers struct.error MRO / Struct.__mro__[1].__name__ / Struct.iter_unpack method identity / Struct.__new__ identity (table + invariants)."
    - "struct_extra129.zspec.zsdl — covers struct module-level function __name__/__qualname__/__module__/__class__.__name__ for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra128.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__ equality / Struct method __class__.__name__=='method_descriptor' / Struct method __name__ equality (table + invariants)."
    - "struct_extra127.zspec.zsdl — covers Struct.size and format __objclass__.__name__ and __module__ equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 363 theme: struct.Struct.__init__ wrapper_descriptor identity (__qualname__/__name__/__class__.__name__/__objclass__) / struct.Struct.__init_subclass__ builtin_function_or_method identity / Struct method doc string class names / Struct.__subclasshook__ identity."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init_subclass__.__qualname__ == 'Struct.__init_subclass__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init_subclass__.__name__ == '__init_subclass__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__subclasshook__.__qualname__ == 'Struct.__subclasshook__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__subclasshook__.__name__ == '__subclasshook__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__doc__.__len__() == 175. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__len__() == 190. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra128 anchors Struct.pack/unpack qualname/name/class. extra131 anchors __repr__/__str__/__hash__ identity. extra130 anchors Struct.__new__ identity and iter_unpack method identity. This spec is the first to anchor Struct.__init__ wrapper_descriptor identity, __init_subclass__ builtin identity, __subclasshook__ identity, and method doc string lengths under structinit133."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.__init__.__name__.__eq__('__init__')
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.__init__.__objclass__.__name__.__eq__('Struct')
# struct.Struct.__init__.__objclass__.__module__.__eq__('_struct')
#
# Wave 363 theme: Struct.__init__ wrapper_descriptor identity.
#
# struct.Struct.__init__ is a wrapper_descriptor — the standard CPython type
# for C-level slot wrappers (__init__, __repr__, etc.) on C extension types.
# This is in contrast to socket.socket.__init__, which is a pure-Python
# function (class 'function'). Struct.__init__ has qualname 'Struct.__init__',
# __name__ '__init__', __class__.__name__ 'wrapper_descriptor', and
# __objclass__.__name__ 'Struct' (__objclass__.__module__ '_struct').
# Prior struct specs anchor Struct.pack/unpack/iter_unpack (method_descriptor)
# and __repr__/__str__/__hash__ (wrapper_descriptor/from object), but not
# Struct.__init__ specifically. This is the first time Struct.__init__ is
# anchored via __eq__ under structinit133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra133.Struct_init_wrapper_descriptor:
  description: "struct.Struct/__init__/__qualname__.__eq__('Struct.__init__')==True / __init__/__name__.__eq__('__init__')==True / __init__/__class__/__name__.__eq__('wrapper_descriptor')==True / __init__/__objclass__/__name__.__eq__('Struct')==True / __init__/__objclass__/__module__.__eq__('_struct')==True — Struct.__init__ is a wrapper_descriptor (C-level slot wrapper; contrasts with socket.socket.__init__ which is a Python function); __objclass__ is Struct from _struct; first structinit133 anchor for Struct.__init__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structinit133

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname,   Struct.__init__.__qualname__.__eq__,            ["Struct.__init__"],   true, "Struct.__init__.__qualname__ is 'Struct.__init__' (C-level __init__ slot wrapper from _struct.c)"]
    - [init_name,       Struct.__init__.__name__.__eq__,                ["__init__"],          true, "Struct.__init__.__name__ is '__init__' (short name; qualname has 'Struct.' prefix)"]
    - [init_cls,        Struct.__init__.__class__.__name__.__eq__,      ["wrapper_descriptor"],true, "Struct.__init__.__class__.__name__ is 'wrapper_descriptor' (C slot wrapper; contrasts with 'method_descriptor' for pack/unpack)"]
    - [init_obj_name,   Struct.__init__.__objclass__.__name__.__eq__,   ["Struct"],            true, "Struct.__init__.__objclass__.__name__ is 'Struct' (method defined by Struct, not inherited)"]
    - [init_obj_mod,    Struct.__init__.__objclass__.__module__.__eq__,  ["_struct"],           true, "Struct.__init__.__objclass__.__module__ is '_struct' (C extension owning the Struct type)"]

# ---------------------------------------------------------------------------
# struct.Struct.__init_subclass__.__qualname__.__eq__('Struct.__init_subclass__')
# struct.Struct.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method')
# struct.Struct.__init_subclass__.__name__.__eq__('__init_subclass__')
# struct.Struct.__subclasshook__.__qualname__.__eq__('Struct.__subclasshook__')
# struct.Struct.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 363 theme: Struct.__init_subclass__ and __subclasshook__ builtin identity.
#
# struct.Struct.__init_subclass__ and __subclasshook__ are both
# builtin_function_or_method objects bound to the Struct class. These are the
# standard class-level hooks provided by CPython's C type machinery.
# __init_subclass__ is called when Struct is subclassed; __subclasshook__ is
# used by isinstance() checking. Both have qualnames starting with 'Struct.'
# and __class__.__name__=='builtin_function_or_method'. This contrasts with
# __repr__ (wrapper_descriptor, extra131) and pack/unpack (method_descriptor,
# extra128). No prior struct spec anchors __init_subclass__ or __subclasshook__
# under structinit133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra133.Struct_init_subclass_and_subclasshook:
  description: "struct.Struct/__init_subclass__/__qualname__.__eq__('Struct.__init_subclass__')==True / __init_subclass__/__class__/__name__.__eq__('builtin_function_or_method')==True / __init_subclass__/__name__.__eq__('__init_subclass__')==True / __subclasshook__/__qualname__.__eq__('Struct.__subclasshook__')==True / __subclasshook__/__class__/__name__.__eq__('builtin_function_or_method')==True — __init_subclass__/__subclasshook__ are builtin_function_or_method (C-level class hooks); distinct from wrapper_descriptor (__init__/__repr__) and method_descriptor (pack/unpack); first structinit133 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structinit133

  columns: [id, function, args, expected, description]
  rows:
    - [initsub_qual,  Struct.__init_subclass__.__qualname__.__eq__,        ["Struct.__init_subclass__"], true, "Struct.__init_subclass__.__qualname__ is 'Struct.__init_subclass__' (class hook for subclassing)"]
    - [initsub_cls,   Struct.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "Struct.__init_subclass__.__class__.__name__ is 'builtin_function_or_method' (C-level class method hook)"]
    - [initsub_name,  Struct.__init_subclass__.__name__.__eq__,            ["__init_subclass__"],        true, "Struct.__init_subclass__.__name__ is '__init_subclass__' (short form without 'Struct.' prefix)"]
    - [subhook_qual,  Struct.__subclasshook__.__qualname__.__eq__,         ["Struct.__subclasshook__"],  true, "Struct.__subclasshook__.__qualname__ is 'Struct.__subclasshook__' (class hook for isinstance() checking)"]
    - [subhook_cls,   Struct.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "Struct.__subclasshook__.__class__.__name__ is 'builtin_function_or_method' (C-level class method; same type as __init_subclass__)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__class__.__name__.__eq__('str')
# struct.Struct.pack.__doc__.__len__().__eq__(175)
# struct.Struct.unpack.__doc__.__len__().__eq__(190)
# struct.Struct.__subclasshook__.__name__.__eq__('__subclasshook__')
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')   [cross-check]
#
# Wave 363 theme: Struct method doc string class names and lengths.
#
# struct.Struct.pack.__doc__ is a str object (not None or NoneType), meaning
# the C-level pack method has a docstring. Its length is 175 chars. Struct.unpack
# __doc__.__len__() is 190 chars. These doc string properties confirm that
# Struct's C-level methods are documented at the C layer. No prior struct spec
# anchors the doc string class name or length for Struct methods. This is the
# first time these doc string properties are anchored under structinit133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra133.Struct_method_doc_lengths:
  description: "struct.Struct/pack/__doc__/__class__/__name__.__eq__('str')==True / pack/__doc__/__len__()==175 / unpack/__doc__/__len__()==190 / __subclasshook__/__name__.__eq__('__subclasshook__')==True / __init__/__qualname__.__eq__('Struct.__init__')==True — pack/unpack docstrings are str objects; pack doc is 175 chars, unpack is 190 chars; __subclasshook__ cross-check __name__; first structinit133 anchor for Struct method doc string class name and lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: structinit133

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_cls,      Struct.pack.__doc__.__class__.__name__.__eq__,   ["str"],  true, "Struct.pack.__doc__.__class__.__name__ is 'str' (pack() has a C-level docstring; not None)"]
    - [pack_doc_len,      Struct.pack.__doc__.__len__,                     [],       175,  "Struct.pack.__doc__.__len__() is 175 (length of the C-level pack docstring)"]
    - [unpack_doc_len,    Struct.unpack.__doc__.__len__,                   [],       190,  "Struct.unpack.__doc__.__len__() is 190 (unpack docstring is longer than pack: includes return type description)"]
    - [subhook_name,      Struct.__subclasshook__.__name__.__eq__,         ["__subclasshook__"], true, "Struct.__subclasshook__.__name__ is '__subclasshook__' (short form; cross-check to uuidcls129 table)"]
    - [init_qual_xchk,    Struct.__init__.__qualname__.__eq__,             ["Struct.__init__"],  true, "Struct.__init__.__qualname__ is 'Struct.__init__' (cross-check; wrapper_descriptor with 'Struct.' prefix)"]

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# struct.Struct.__init__.__class__.__name__ is 'wrapper_descriptor'. This
# distinguishes Struct.__init__ from socket.socket.__init__ (which is a
# pure-Python 'function') and uuid.UUID.__init__ (also a 'function'). C
# extension types in CPython expose their __init__ as wrapper_descriptor
# objects — the same type used for __repr__, __lt__, and other dunder
# slot wrappers on built-in types. The wrapper_descriptor type wraps a
# C-level slot function pointer. No prior struct spec anchors
# Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') as a
# standalone under structinit133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra133.Struct_init_wrapper_descriptor:
  description: "struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — Struct.__init__ is a C-level slot wrapper (contrasts with socket.socket.__init__ and uuid.UUID.__init__ which are Python functions); wrapper_descriptor wraps a C slot function pointer; extra131 anchors Struct.__repr__.__class__.__name__=='wrapper_descriptor'; first standalone for Struct.__init__ class name under structinit133"
  category: type_identity
  kind: python_call_eq
  function: Struct.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.__init__.__objclass__.__name__ is 'Struct'. The __objclass__
# of a wrapper_descriptor identifies the C type that defines the slot. For
# Struct.__init__, the owning class is Struct (from _struct.c), confirming
# that __init__ is defined by Struct and not inherited from object. By
# contrast, __str__ and __hash__ (anchored in extra131) have
# __objclass__.__name__=='object' because they are inherited. This __objclass__
# attribution for Struct.__init__ is the first standalone anchor for
# Struct.__init__.__objclass__.__name__ under structinit133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra133.Struct_init_objclass_name:
  description: "struct.Struct.__init__.__objclass__.__name__.__eq__('Struct') == True — __objclass__ is Struct (defined by Struct, not inherited from object); contrasts with __str__/__hash__.__objclass__.__name__=='object' (extra131); wrapper_descriptor __objclass__ attribute reveals defining C type; first standalone for Struct.__init__.__objclass__.__name__.__eq__ under structinit133"
  category: type_identity
  kind: python_call_eq
  function: Struct.__init__.__objclass__.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__init_subclass__.__qualname__.__eq__('Struct.__init_subclass__') — standalone
#
# struct.Struct.__init_subclass__.__qualname__ is 'Struct.__init_subclass__'.
# __init_subclass__ is a Python class machinery hook introduced in PEP 487
# (Python 3.6). It is called whenever Struct is subclassed, with the subclass
# as the first argument. On C extension types like struct.Struct, it is
# provided as a builtin_function_or_method (not a classmethod wrapper, unlike
# on Python-level classes). The qualname 'Struct.__init_subclass__' confirms
# the Struct class provides this hook. No prior struct spec anchors
# Struct.__init_subclass__.__qualname__ via __eq__ as a standalone under
# structinit133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra133.Struct_init_subclass_qualname:
  description: "struct.Struct.__init_subclass__.__qualname__.__eq__('Struct.__init_subclass__') == True — PEP 487 hook called when Struct is subclassed; builtin_function_or_method on C extension types; qualname 'Struct.__init_subclass__' (22 chars); first standalone for __init_subclass__.__qualname__.__eq__ under structinit133"
  category: type_identity
  kind: python_call_eq
  function: Struct.__init_subclass__.__qualname__.__eq__
  args: ["Struct.__init_subclass__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__len__().__eq__(175) — standalone
#
# struct.Struct.pack.__doc__.__len__() is 175. The C-level method_descriptor
# Struct.pack has a docstring of 175 characters. The docstring describes the
# pack(v1, v2, ...) method — it packs the given values according to the
# Struct format string and returns bytes. Having a docstring (vs None) is
# significant because it means pack() is documented at the C layer via
# PyMethodDef.ml_doc. The 175-char length is a precise anchor that would
# change if the CPython docstring is ever edited. No prior struct spec anchors
# Struct.pack.__doc__.__len__() as a standalone under structinit133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra133.Struct_pack_doc_len:
  description: "struct.Struct.pack.__doc__.__len__() == 175 — Struct.pack has a 175-char C-level docstring (documents 'pack(v1, v2, ...) -> bytes'; would change if CPython docstring edited); docstring is str type (not None); first standalone for Struct.pack.__doc__.__len__()==175 under structinit133"
  category: type_identity
  kind: python_call_eq
  function: Struct.pack.__doc__.__len__
  args: []
  expected: 175

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__objclass__.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__init__.__objclass__.__module__ is '_struct'. The __objclass__
# of Struct.__init__ is the Struct C type from the _struct extension module.
# __objclass__.__module__ == '_struct' confirms that Struct.__init__ originates
# from the _struct C extension (Modules/_struct.c in CPython). This is
# consistent with all other Struct method_descriptor and wrapper_descriptor
# objects (pack, unpack, iter_unpack, __sizeof__ all have
# __objclass__.__module__=='_struct', anchored in extra132). No prior struct
# spec anchors Struct.__init__.__objclass__.__module__ as a standalone under
# structinit133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra133.Struct_init_objclass_module:
  description: "struct.Struct.__init__.__objclass__.__module__.__eq__('_struct') == True — __objclass__.__module__ is '_struct' (C extension defining Struct; consistent with pack/unpack/__sizeof__ all having same __objclass__.__module__, anchored in extra132); first standalone for Struct.__init__.__objclass__.__module__.__eq__ under structinit133"
  category: type_identity
  kind: python_call_eq
  function: Struct.__init__.__objclass__.__module__.__eq__
  args: ["_struct"]
  expected: true

