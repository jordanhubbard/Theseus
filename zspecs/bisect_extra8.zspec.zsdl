spec: bisect_extra8
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras through bisect_extra7.zspec.zsdl."
    - "bisect.zspec.zsdl covers: bisect_left/bisect_right tables on [1,3,5,7,9]; duplicates on [1,3,5,5,5,7]; bisect alias; lo/hi args; function __name__ identity."
    - "bisect_extra.zspec.zsdl covers: bisect_left/__module__=='_bisect'; bisect_right/__name__; insort_left/insort_right/__name__; bisect/__name__; insort/__name__; behavioral on [1,2,3,4,5] and [1,2,3,3,3,4]."
    - "bisect_extra2.zspec.zsdl covers: insort/__name__; insort_left/__name__; insort_right/__name__; bisect/__name__; bisect_left([1,3,5,7],4)==2."
    - "bisect_extra3.zspec.zsdl covers: __module__ for bisect/bisect_right/insort/insort_left/insort_right; __name__ for bisect_left/bisect_right/insort_left/insort_right; behavioral on [1,2,3,4,5]."
    - "bisect_extra4.zspec.zsdl covers: bisect module __name__; behavioral on [1,2,3,3,4] and [2,4,6,8,10]."
    - "bisect_extra5.zspec.zsdl covers: __qualname__ for all bisect functions; behavioral on [1,3,5,7] (multiple search values)."
    - "bisect_extra6.zspec.zsdl covers: __name__ table (id_prefix bname); module identity table; behavioral on [10,20,30,40,50]."
    - "bisect_extra7.zspec.zsdl covers: bisect_left/bisect_right __module__ standalone; bisect_left/bisect_right/insort_left/insort_right __qualname__ standalone; behavioral on [5,10,15,20,25]."
    - "This spec adds: insort_left/__module__ standalone (extra8 namespace); insort_right/__module__ standalone; bisect/__module__ standalone; insort/__module__ standalone; behavioral on [3,6,9,12,15] (multiples of 3, not used in any prior spec)."
    - "bisect.insort_left.__module__ == '_bisect' — C extension; extra3 covers this in a multi-function table; extra8 adds standalone invariant."
    - "bisect.insort_right.__module__ == '_bisect' — C extension; extra3 covers in table; extra8 adds standalone."
    - "bisect.bisect.__module__ == '_bisect' — extra3 covers bisect/__module__ in table; extra8 adds standalone invariant."
    - "bisect.insort.__module__ == '_bisect' — extra3 covers insort/__module__ in table; extra8 adds standalone invariant."
    - "bisect_left([3,6,9,12,15], 7) == 2 — 7 falls between 6 (index 1) and 9 (index 2); left insertion at index 2."
    - "bisect_right([3,6,9,12,15], 9) == 3 — 9 at index 2; right insertion point is 3."
    - "bisect_left([3,6,9,12,15], 9) == 2 — 9 at index 2; left insertion point is 2 (element present)."
    - "bisect_left([3,6,9,12,15], 3) == 0 — 3 at index 0; left insertion point is 0."
    - "bisect_left([3,6,9,12,15], 16) == 5 — 16 is after all elements; insertion at end."
    - "bisect_right([3,6,9,12,15], 2) == 0 — 2 is before all elements; insertion at beginning."
    - "bisect_right([3,6,9,12,15], 12) == 4 — 12 at index 3; right insertion point is 4."
    - "bisect_left([3,6,9,12,15], 12) == 3 — 12 at index 3; left insertion point is 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ standalone invariants — extra8 namespace
#
# bisect_extra3 and bisect_extra6 cover module attrs in tables.
# bisect_extra7 adds standalone invariants for bisect_left and bisect_right.
# This spec adds standalone invariants for insort_left, insort_right,
# bisect (alias for bisect_right), and insort (alias for insort_right).
# ---------------------------------------------------------------------------

invariant bisect_extra8.insort_left.module:
  description: "bisect.insort_left.__module__ == '_bisect' — C extension (extra8 namespace)"
  category: module_identity
  kind: python_call_eq
  function: insort_left.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra8.insort_right.module:
  description: "bisect.insort_right.__module__ == '_bisect' — C extension (extra8 namespace)"
  category: module_identity
  kind: python_call_eq
  function: insort_right.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra8.bisect.module:
  description: "bisect.bisect.__module__ == '_bisect' — bisect alias is also from C extension (extra8 namespace)"
  category: module_identity
  kind: python_call_eq
  function: bisect.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra8.insort.module:
  description: "bisect.insort.__module__ == '_bisect' — insort alias is also from C extension (extra8 namespace)"
  category: module_identity
  kind: python_call_eq
  function: insort.__module__.__eq__
  args: ["_bisect"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — [3, 6, 9, 12, 15] (multiples of 3)
#
# This input is distinct from all prior spec inputs:
#   bisect        uses [1,3,5,7,9] and [1,3,5,5,5,7]
#   bisect_extra  uses [1,2,3,4,5] and [1,2,3,3,3,4]
#   bisect_extra2 uses [1,3,5,7]
#   bisect_extra3 uses [1,2,3,4,5]
#   bisect_extra4 uses [1,2,3,3,4] and [2,4,6,8,10]
#   bisect_extra5 uses [1,3,5,7]
#   bisect_extra6 uses [10,20,30,40,50]
#   bisect_extra7 uses [5,10,15,20,25]
# [3,6,9,12,15] is a new fixture not used in any prior spec.
# ---------------------------------------------------------------------------

invariant bisect_extra8.bisect_left.threes_gap:
  description: "bisect_left([3,6,9,12,15], 7) == 2 — 7 falls between 6 and 9; left insertion at index 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[3, 6, 9, 12, 15], 7]
  expected: 2

invariant bisect_extra8.bisect_right.threes_present_nine:
  description: "bisect_right([3,6,9,12,15], 9) == 3 — 9 at index 2; right insertion point is 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[3, 6, 9, 12, 15], 9]
  expected: 3

invariant bisect_extra8.bisect_left.threes_present_nine:
  description: "bisect_left([3,6,9,12,15], 9) == 2 — 9 at index 2; left insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[3, 6, 9, 12, 15], 9]
  expected: 2

invariant bisect_extra8.bisect_left.threes_before_all:
  description: "bisect_left([3,6,9,12,15], 3) == 0 — 3 at index 0; left insertion at beginning"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[3, 6, 9, 12, 15], 3]
  expected: 0

invariant bisect_extra8.bisect_left.threes_after_all:
  description: "bisect_left([3,6,9,12,15], 16) == 5 — 16 exceeds all elements; insertion at end"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[3, 6, 9, 12, 15], 16]
  expected: 5

invariant bisect_extra8.bisect_right.threes_before_first:
  description: "bisect_right([3,6,9,12,15], 2) == 0 — 2 is less than all elements; insertion at index 0"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[3, 6, 9, 12, 15], 2]
  expected: 0

invariant bisect_extra8.bisect_right.threes_present_twelve:
  description: "bisect_right([3,6,9,12,15], 12) == 4 — 12 at index 3; right insertion point is 4"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[3, 6, 9, 12, 15], 12]
  expected: 4

invariant bisect_extra8.bisect_left.threes_present_twelve:
  description: "bisect_left([3,6,9,12,15], 12) == 3 — 12 at index 3; left insertion point is 3"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[3, 6, 9, 12, 15], 12]
  expected: 3
