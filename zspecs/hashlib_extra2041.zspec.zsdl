spec: hashlib_extra2041
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "_hashlib.HASH is a cryptographic digest type, not a bitwise type; it defines none of these bit-shift or bitwise protocols in its own __dict__."
    - "hashlib.blake2b and hashlib.blake2s are real type objects; they are also non-bitwise."
    - "All bit-shift and bitwise dunder methods are absent from all three hashlib hash type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2041.hash_lshift_protocol:
  description: "_hashlib.HASH __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2041

  columns: [id, function, args, expected]
  rows:
    - ["hl2041001", "_hashlib.HASH.__dict__.__contains__", ["__lshift__"],  false]
    - ["hl2041002", "_hashlib.HASH.__dict__.__contains__", ["__rlshift__"], false]
    - ["hl2041003", "_hashlib.HASH.__dict__.__contains__", ["__ilshift__"], false]

