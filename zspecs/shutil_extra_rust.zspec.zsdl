invariant shutil_extra_rust.terminal_size_cols_positive:
  description: "shutil.get_terminal_size().columns > 0"
  category: terminal_size
  kind: python_call_eq
  function: shutil_extra_terminal_size_positive
  args: []
  expected: true

invariant shutil_extra_rust.has_copy:
  description: "shutil.copy is callable"
  category: presence
  kind: python_call_eq
  function: shutil_extra_has_copy
  args: []
  expected: true

