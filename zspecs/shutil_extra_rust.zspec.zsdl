docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — shutil stdlib"
  notes:
    - "shutil provides high-level file operations."
    - "shutil.which('python3') returns non-None path."
    - "shutil.disk_usage('/').total > 0."
    - "shutil.get_terminal_size().columns > 0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant shutil_extra_rust.disk_usage_positive:
  description: "shutil.disk_usage('/').total > 0"
  category: disk_usage
  kind: python_call_eq
  function: shutil_extra_disk_usage_positive
  args: []
