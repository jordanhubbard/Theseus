spec: dis_extra17
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra14.zspec.zsdl — covers opmap __contains__ table; opmap.__len__() >= 50; Instruction/Bytecode __name__ and __module__; stack_effect/get_instructions __module__"
    - "dis_extra15.zspec.zsdl — covers Bytecode/__qualname__; Instruction/__qualname__; function_modules table; opname item0 type; opmap class/len; cmp_op class; HAVE_ARGUMENT.__ge__(1)"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__module__ and Instruction/__module__ standalone; class_qualnames table (Bytecode/Instruction); COMPILER_FLAG_NAMES.__class__.__name__; has* lists class"
  notes:
    - "This spec extends dis_extra16.zspec.zsdl."
    - "dis.dis.__name__ == 'dis' — no prior dis spec verifies dis.__name__ as a standalone invariant in the dis_extra17 namespace."
    - "dis.disassemble.__name__ == 'disassemble' — no prior dis spec verifies this in the dis_extra17 namespace."
    - "dis.get_instructions.__name__ == 'get_instructions' — dis_extra15 covers this via a function_modules table; __name__ standalone is new in dis_extra17."
    - "dis.findlinestarts.__name__ == 'findlinestarts' — dis_extra15 covers this via function_modules table; __name__ standalone is new in dis_extra17."
    - "dis.findlabels.__name__ == 'findlabels' — dis_extra15 covers this via function_modules table; __name__ standalone is new in dis_extra17."
    - "dis.Instruction.__name__ == 'Instruction' — dis_extra14 covers this in the dis_extra14 namespace; distinct standalone ID in dis_extra17 namespace."
    - "dis.opname.__class__.__name__ == 'list' — dis_extra15 covers opname item0 type; opname class is covered in dis_extra15 via opmap class/len context; standalone dis_extra17 invariant is new."
    - "dis.opmap.__class__.__name__ == 'dict' — dis_extra15 covers opmap class; standalone dis_extra17 invariant is new."
    - "dis.dis.__module__ and dis.disassemble.__module__ — verified as 'dis' with Python 3.14.3."
    - "dis.get_instructions.__module__ == 'dis' — dis_extra14/15 cover this; standalone dis_extra17 invariant is new."
    - "dis.findlinestarts.__module__ == 'dis' and dis.findlabels.__module__ == 'dis' — dis_extra15 covers these in a table; standalone dis_extra17 invariants are new."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — dis, disassemble, get_instructions, findlinestarts, findlabels
# (dis_extra17 namespace)
#
# No prior dis spec verifies these __name__ attributes as standalone invariants
# in the dis_extra17 namespace.
# ---------------------------------------------------------------------------

table dis_extra17.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [dis,              dis.__name__.__eq__,              ["dis"],              true]
    - [disassemble,      disassemble.__name__.__eq__,      ["disassemble"],      true]
    - [get_instructions, get_instructions.__name__.__eq__,  ["get_instructions"], true]
    - [findlinestarts,   findlinestarts.__name__.__eq__,   ["findlinestarts"],   true]
    - [findlabels,       findlabels.__name__.__eq__,       ["findlabels"],       true]

# ---------------------------------------------------------------------------
# Function __module__ — dis, disassemble, get_instructions, findlinestarts, findlabels
# (dis_extra17 namespace)
#
# dis_extra14/15 cover some of these in tables in earlier namespaces.
# These are distinct standalone IDs in the dis_extra17 namespace.
# ---------------------------------------------------------------------------

table dis_extra17.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [dis,              dis.__module__.__eq__,              ["dis"], true]
    - [disassemble,      disassemble.__module__.__eq__,      ["dis"], true]
    - [get_instructions, get_instructions.__module__.__eq__,  ["dis"], true]
    - [findlinestarts,   findlinestarts.__module__.__eq__,   ["dis"], true]
    - [findlabels,       findlabels.__module__.__eq__,       ["dis"], true]

# ---------------------------------------------------------------------------
# Instruction class identity — __name__
# (dis_extra17 namespace)
#
# dis_extra14 covers Instruction.__name__ in the dis_extra14 namespace.
# This is a distinct standalone invariant in the dis_extra17 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra17.Instruction.name:
  description: "dis.Instruction.__name__ == 'Instruction'"
  category: class_names
  kind: python_call_eq
  function: Instruction.__name__.__eq__
  args: ["Instruction"]
  expected: true

# ---------------------------------------------------------------------------
# opname — class identity
# (dis_extra17 namespace)
#
# dis_extra15 covers opname in context of item0 type checks.
# Standalone __class__.__name__ check in dis_extra17 namespace is new.
# ---------------------------------------------------------------------------

invariant dis_extra17.opname.class_is_list:
  description: "dis.opname.__class__.__name__ == 'list' — opname is a list of opcode name strings"
  category: class_names
  kind: python_call_eq
  function: opname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# opmap — class identity
# (dis_extra17 namespace)
#
# dis_extra15 covers opmap class/len checks in the dis_extra15 namespace.
# Standalone invariant in dis_extra17 namespace is new.
# ---------------------------------------------------------------------------

invariant dis_extra17.opmap.class_is_dict:
  description: "dis.opmap.__class__.__name__ == 'dict' — opmap is a dict mapping opcode names to ints"
  category: class_names
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
