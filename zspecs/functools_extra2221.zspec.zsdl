spec: functools_extra2221
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221: identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "functools.partial defines __repr__ and __doc__ and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "functools.partialmethod defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "functools.cached_property defines __doc__ and __module__ in its own __dict__. It does NOT define __hash__, __repr__, __str__, __qualname__, or __name__."
    - "functools._lru_cache_wrapper defines __doc__ and __module__ in its own __dict__. It does NOT define __hash__, __repr__, __str__, __qualname__, or __name__."
    - "__qualname__ and __name__ are never in a class __dict__ — they are type-level attributes supplied by the metaclass (type) and not stored in the instance __dict__."
    - "__module__ is always in the class __dict__ for Python-defined and C extension classes as it records the defining module string."
    - "__doc__ is always in the class __dict__ — it is stored there explicitly at class creation time."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2221.partial_identity_display:
  description: "functools.partial dict-presence for identity/display protocol: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2221

  columns: [id, function, args, expected]
  rows:
    - ["ft2221001", "functools.partial.__dict__.__contains__", ["__hash__"], false]
    - ["ft2221002", "functools.partial.__dict__.__contains__", ["__repr__"], true]
    - ["ft2221003", "functools.partial.__dict__.__contains__", ["__str__"], false]
    - ["ft2221004", "functools.partial.__dict__.__contains__", ["__doc__"], true]
    - ["ft2221005", "functools.partial.__dict__.__contains__", ["__module__"], true]
    - ["ft2221006", "functools.partial.__dict__.__contains__", ["__qualname__"], false]
    - ["ft2221007", "functools.partial.__dict__.__contains__", ["__name__"], false]

