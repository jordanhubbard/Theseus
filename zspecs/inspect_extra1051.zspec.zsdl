spec: inspect_extra1051
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect predicate functions for builtins, functions, classes, modules, routines, and methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1051.predicate_true:
  description: "inspect predicates that must return True"
  kind: python_call_eq
  category: predicate_true
  id_prefix: ip1051t
  columns: [id, function, args, expected]
  rows:
    - [ip1051t001, inspect.isbuiltin.__call__.__qualname__.__eq__, ["isbuiltin.__call__"],           true]
    - [ip1051t002, inspect.isbuiltin.__module__.__eq__,            ["inspect"],                     true]
    - [ip1051t003, inspect.isfunction.__module__.__eq__,           ["inspect"],                     true]
    - [ip1051t004, inspect.isclass.__module__.__eq__,              ["inspect"],                     true]
    - [ip1051t005, inspect.ismodule.__module__.__eq__,             ["inspect"],                     true]
    - [ip1051t006, inspect.isroutine.__module__.__eq__,            ["inspect"],                     true]
    - [ip1051t007, inspect.isabstract.__module__.__eq__,           ["inspect"],                     true]
    - [ip1051t008, inspect.ismethod.__module__.__eq__,             ["inspect"],                     true]

table inspect_extra1051.predicate_results:
  description: "inspect predicate call results for common types"
  kind: python_call_eq
  category: predicate_results
  id_prefix: ip1051r
  columns: [id, function, args, expected]
  rows:
    - [ip1051r001, inspect.isbuiltin.__qualname__.__eq__,          ["isbuiltin"],                   true]
    - [ip1051r002, inspect.isfunction.__qualname__.__eq__,         ["isfunction"],                  true]
    - [ip1051r003, inspect.isclass.__qualname__.__eq__,            ["isclass"],                     true]
    - [ip1051r004, inspect.ismodule.__qualname__.__eq__,           ["ismodule"],                    true]
    - [ip1051r005, inspect.isroutine.__qualname__.__eq__,          ["isroutine"],                   true]
    - [ip1051r006, inspect.isabstract.__qualname__.__eq__,         ["isabstract"],                  true]
    - [ip1051r007, inspect.ismethod.__qualname__.__eq__,           ["ismethod"],                    true]

table inspect_extra1051.error_conditions:
  description: "inspect functions that raise on invalid input"
  kind: python_call_raises
  category: error_conditions
  id_prefix: ip1051x
  columns: [id, function, args, expected]
  rows:
    - [ip1051x001, inspect.getmembers,                             [null],                          TypeError]
    - [ip1051x002, inspect.getdoc,                                 [null],                          AttributeError]
    - [ip1051x003, inspect.getsource,                              [42],                            TypeError]
    - [ip1051x004, inspect.getsourcelines,                         [42],                            TypeError]
    - [ip1051x005, inspect.getfile,                                [42],                            TypeError]
