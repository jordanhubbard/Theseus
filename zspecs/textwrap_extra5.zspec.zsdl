spec: textwrap_extra5
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl, textwrap_extra.zspec.zsdl, textwrap_extra2.zspec.zsdl, textwrap_extra3.zspec.zsdl, and textwrap_extra4.zspec.zsdl."
    - "textwrap.zspec.zsdl: wrap/fill/dedent/indent/shorten basic vectors, TextWrapper(width=40).width."
    - "textwrap_extra.zspec.zsdl: wrap/fill/dedent/indent/shorten __name__, TextWrapper __name__/__module__, additional wrap/fill/dedent/indent/shorten vectors."
    - "textwrap_extra2.zspec.zsdl: function_names/qualnames/modules tables for fill/indent/dedent/shorten; TextWrapper __name__/__module__/__qualname__/is_type; TextWrapper defaults (width=70, break_long_words=True, custom_width=120); fill/dedent return type."
    - "textwrap_extra3.zspec.zsdl: function __module__ invariants for wrap/fill/dedent/indent/shorten/TextWrapper; wrap break_long_word/empty; fill wide/empty; indent angle-bracket; dedent blank_first_line; shorten truncated_with_placeholder/fits_within_width."
    - "textwrap_extra4.zspec.zsdl: function_names table (wrap/fill/dedent/indent/shorten), function_modules table, TextWrapper __name__/__module__ invariants, TextWrapper defaults (width, expand_tabs), wrap/fill/dedent/dedent_multiline basic invariants."
    - "Focus: TextWrapper.__bases__[0].__name__; TextWrapper defaults (drop_whitespace, fix_sentence_endings, placeholder); shorten with exact-fit width; shorten with default placeholder."
    - "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper inherits directly from object."
    - "textwrap.TextWrapper().drop_whitespace == True — default is True (leading/trailing whitespace is dropped from lines)."
    - "textwrap.TextWrapper().fix_sentence_endings == False — default is False."
    - "textwrap.TextWrapper().placeholder == ' [...]' — default truncation placeholder string."
    - "textwrap.shorten('Hello world', width=11) == 'Hello world' — string fits exactly, no truncation."
    - "textwrap.shorten('Hello world foo', width=12) == 'Hello [...]' — default placeholder ' [...]' (6 chars) used; result is 11 chars."
    - "textwrap.shorten('Hi', width=10) == 'Hi' — short string well within width, returned unchanged."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper — base class
# ---------------------------------------------------------------------------

invariant textwrap_extra5.TextWrapper.base_is_object:
  description: "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper inherits from object"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# TextWrapper defaults — drop_whitespace, fix_sentence_endings, placeholder
#
# textwrap_extra2 covers: width=70, break_long_words=True.
# textwrap_extra4 covers: width, expand_tabs.
# We add: drop_whitespace, fix_sentence_endings, and placeholder.
# ---------------------------------------------------------------------------

invariant textwrap_extra5.TextWrapper.drop_whitespace_default:
  description: "textwrap.TextWrapper().drop_whitespace == True — default is True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: drop_whitespace.__eq__
  method_args: [true]
  expected: true

invariant textwrap_extra5.TextWrapper.fix_sentence_endings_default:
  description: "textwrap.TextWrapper().fix_sentence_endings == False — default is False"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: fix_sentence_endings.__eq__
  method_args: [false]
  expected: true

invariant textwrap_extra5.TextWrapper.placeholder_default:
  description: "textwrap.TextWrapper().placeholder == ' [...]' — default truncation placeholder"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: placeholder.__eq__
  method_args: [" [...]"]
  expected: true

# ---------------------------------------------------------------------------
# shorten() — exact-fit and new-width truncation vectors
#
# textwrap.zspec.zsdl: shorten('The quick brown fox', 15) == 'The quick [...]'
#                       shorten('short', 80) == 'short'
# textwrap_extra3: shorten('hello world foo', 11, placeholder='...') == 'hello...'
#                  shorten('hello world', 20) == 'hello world'
# We add:
#   shorten('Hello world', width=11) — exact fit (11 == len('Hello world'))
#   shorten('Hello world foo', width=12) — default placeholder ' [...]' (6 chars)
#   shorten('Hi', width=10) — short string well within width
# ---------------------------------------------------------------------------

invariant textwrap_extra5.shorten.exact_fit:
  description: "textwrap.shorten('Hello world', width=11) == 'Hello world' — fits exactly"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["Hello world", 11]
  expected: "Hello world"

invariant textwrap_extra5.shorten.default_placeholder:
  description: "textwrap.shorten('Hello world foo', width=12) == 'Hello [...]' — default placeholder ' [...]'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["Hello world foo", 12]
  expected: "Hello [...]"

invariant textwrap_extra5.shorten.short_input_wide_width:
  description: "textwrap.shorten('Hi', width=10) == 'Hi' — short string well within width"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["Hi", 10]
  expected: "Hi"

# ---------------------------------------------------------------------------
# Function __qualname__ — wrap (not covered in any prior spec)
#
# textwrap_extra2 covers qualnames for fill/indent/dedent/shorten.
# We add wrap.__qualname__ which was missing from that table.
# ---------------------------------------------------------------------------

invariant textwrap_extra5.wrap.qualname:
  description: "textwrap.wrap.__qualname__ == 'wrap' — module-level function has a flat qualname"
  category: function_qualnames
  kind: python_call_eq
  function: wrap.__qualname__.__eq__
  args: ["wrap"]
  expected: true

# ---------------------------------------------------------------------------
# shorten — function type check
# ---------------------------------------------------------------------------

invariant textwrap_extra5.shorten.is_function:
  description: "textwrap.shorten.__class__.__name__ == 'function' — shorten is a plain function"
  category: shorten
  kind: python_call_eq
  function: shorten.__class__.__name__.__eq__
  args: ["function"]
  expected: true
