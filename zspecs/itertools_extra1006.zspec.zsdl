spec: itertools_extra1006
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __reduce__.__qualname__ for combinatoric and filtering itertools classes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1006.combinatoric_qualnames:
  description: "itertools combinatoric iterator __reduce__.__qualname__ checks"
  kind: python_call_eq
  category: combinatoric_qualnames
  id_prefix: it1006cq
  columns: [id, function, args, expected]
  rows:
    - [it1006cq001, itertools.combinations.__reduce__.__qualname__.__eq__,                ["combinations.__reduce__"],                true]
    - [it1006cq002, itertools.combinations_with_replacement.__reduce__.__qualname__.__eq__, ["combinations_with_replacement.__reduce__"], true]
    - [it1006cq003, itertools.permutations.__reduce__.__qualname__.__eq__,                ["permutations.__reduce__"],                true]
    - [it1006cq004, itertools.product.__reduce__.__qualname__.__eq__,                     ["product.__reduce__"],                     true]
    - [it1006cq005, itertools.combinations.__class__.__name__.__eq__,                     ["type"],                                   true]
    - [it1006cq006, itertools.permutations.__class__.__name__.__eq__,                     ["type"],                                   true]

table itertools_extra1006.groupby_slice_qualnames:
  description: "itertools.groupby and islice __reduce__.__qualname__ checks"
  kind: python_call_eq
  category: groupby_slice_qualnames
  id_prefix: it1006gs
  columns: [id, function, args, expected]
  rows:
    - [it1006gs001, itertools.groupby.__reduce__.__qualname__.__eq__,  ["groupby.__reduce__"],  true]
    - [it1006gs002, itertools.islice.__reduce__.__qualname__.__eq__,   ["islice.__reduce__"],   true]
    - [it1006gs003, itertools.groupby.__class__.__name__.__eq__,       ["type"],                true]
    - [it1006gs004, itertools.islice.__class__.__name__.__eq__,        ["type"],                true]
    - [it1006gs005, itertools.groupby.__module__.__eq__,               ["itertools"],           true]

table itertools_extra1006.filter_qualnames:
  description: "itertools takewhile, dropwhile, filterfalse __reduce__.__qualname__ checks"
  kind: python_call_eq
  category: filter_qualnames
  id_prefix: it1006fq
  columns: [id, function, args, expected]
  rows:
    - [it1006fq001, itertools.takewhile.__reduce__.__qualname__.__eq__,   ["takewhile.__reduce__"],   true]
    - [it1006fq002, itertools.dropwhile.__reduce__.__qualname__.__eq__,   ["dropwhile.__reduce__"],   true]
    - [it1006fq003, itertools.filterfalse.__reduce__.__qualname__.__eq__, ["filterfalse.__reduce__"], true]
    - [it1006fq004, itertools.takewhile.__class__.__name__.__eq__,        ["type"],                   true]
    - [it1006fq005, itertools.dropwhile.__module__.__eq__,                ["itertools"],              true]
