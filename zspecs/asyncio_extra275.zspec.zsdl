spec: asyncio_extra275
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "asyncio.Task.__module__ == '_asyncio' — Task is implemented in C and lives in the _asyncio extension module."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits directly from Future."
    - "asyncio.Handle.__module__ == 'asyncio.events'; __bases__[0].__name__ == 'object'."
    - "asyncio.TimerHandle.__module__ == 'asyncio.events'; __bases__[0].__name__ == 'Handle'."
    - "Handle.cancel and Handle.cancelled are the two primary methods for checking/cancelling scheduled callbacks."
    - "TimerHandle.when() returns the scheduled time as a float."
    - "TimerHandle.cancel overrides Handle.cancel; its __qualname__ is 'TimerHandle.cancel'."
    - "Task.cancel.__qualname__ == 'Task.cancel'; Task.get_name.__qualname__ == 'Task.get_name'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task class identity — table
#
# asyncio.Task is implemented in C (_asyncio module) and inherits from Future.
# ---------------------------------------------------------------------------

table asyncio_extra275.task_identity:
  description: "asyncio.Task class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: taskid

  columns: [id, function, args, expected, description]
  rows:
    - [task_name,            Task.__name__.__eq__,                   ["Task"],        true, "asyncio.Task.__name__ == 'Task'"]
    - [task_module,          Task.__module__.__eq__,                 ["_asyncio"],    true, "asyncio.Task.__module__ == '_asyncio'"]
    - [task_cancel,          Task.cancel.__name__.__eq__,            ["cancel"],      true, "asyncio.Task.cancel.__name__ == 'cancel'"]
    - [task_done,            Task.done.__name__.__eq__,              ["done"],        true, "asyncio.Task.done.__name__ == 'done'"]
    - [task_result,          Task.result.__name__.__eq__,            ["result"],      true, "asyncio.Task.result.__name__ == 'result'"]
    - [task_get_name,        Task.get_name.__name__.__eq__,          ["get_name"],    true, "asyncio.Task.get_name.__name__ == 'get_name'"]
    - [task_set_name,        Task.set_name.__name__.__eq__,          ["set_name"],    true, "asyncio.Task.set_name.__name__ == 'set_name'"]

# ---------------------------------------------------------------------------
# asyncio.Handle and asyncio.TimerHandle class identity — table
#
# Both classes live in asyncio.events. Handle inherits from object;
# TimerHandle inherits from Handle.
# ---------------------------------------------------------------------------

table asyncio_extra275.handle_identity:
  description: "asyncio.Handle and asyncio.TimerHandle class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: hdlid

  columns: [id, function, args, expected, description]
  rows:
    - [hdl_name,        Handle.__name__.__eq__,              ["Handle"],          true, "asyncio.Handle.__name__ == 'Handle'"]
    - [hdl_module,      Handle.__module__.__eq__,            ["asyncio.events"],  true, "asyncio.Handle.__module__ == 'asyncio.events'"]
    - [hdl_cancel,      Handle.cancel.__name__.__eq__,       ["cancel"],          true, "asyncio.Handle.cancel.__name__ == 'cancel'"]
    - [hdl_cancelled,   Handle.cancelled.__name__.__eq__,    ["cancelled"],       true, "asyncio.Handle.cancelled.__name__ == 'cancelled'"]
    - [tmr_name,        TimerHandle.__name__.__eq__,         ["TimerHandle"],     true, "asyncio.TimerHandle.__name__ == 'TimerHandle'"]
    - [tmr_module,      TimerHandle.__module__.__eq__,       ["asyncio.events"],  true, "asyncio.TimerHandle.__module__ == 'asyncio.events'"]
    - [tmr_when,        TimerHandle.when.__name__.__eq__,    ["when"],            true, "asyncio.TimerHandle.when.__name__ == 'when'"]
    - [tmr_cancel,      TimerHandle.cancel.__name__.__eq__,  ["cancel"],          true, "asyncio.TimerHandle.cancel.__name__ == 'cancel'"]

# ---------------------------------------------------------------------------
# asyncio.Task base class — standalone invariant
#
# Task inherits from Future; __bases__[0].__name__ == 'Future'.
# ---------------------------------------------------------------------------

invariant asyncio_extra275.Task.bases0_name:
  description: "asyncio.Task.__bases__[0].__name__ == 'Future'"
  category: identity
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Handle base class — standalone invariant
#
# Handle inherits directly from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra275.Handle.bases0_name:
  description: "asyncio.Handle.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "Handle.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.TimerHandle base class — standalone invariant
#
# TimerHandle inherits from Handle (not from object directly).
# ---------------------------------------------------------------------------

invariant asyncio_extra275.TimerHandle.bases0_name:
  description: "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle'"
  category: identity
  kind: python_call_eq
  function: "TimerHandle.__bases__[0].__name__.__eq__"
  args: ["Handle"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Task method __qualname__ values — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra275.Task.cancel_qualname:
  description: "asyncio.Task.cancel.__qualname__ == 'Task.cancel'"
  category: identity
  kind: python_call_eq
  function: Task.cancel.__qualname__.__eq__
  args: ["Task.cancel"]
  expected: true

invariant asyncio_extra275.Task.get_name_qualname:
  description: "asyncio.Task.get_name.__qualname__ == 'Task.get_name'"
  category: identity
  kind: python_call_eq
  function: Task.get_name.__qualname__.__eq__
  args: ["Task.get_name"]
  expected: true

invariant asyncio_extra275.Task.add_done_callback_name:
  description: "asyncio.Task.add_done_callback.__name__ == 'add_done_callback'"
  category: identity
  kind: python_call_eq
  function: Task.add_done_callback.__name__.__eq__
  args: ["add_done_callback"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Handle method __qualname__ values — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra275.Handle.cancel_qualname:
  description: "asyncio.Handle.cancel.__qualname__ == 'Handle.cancel'"
  category: identity
  kind: python_call_eq
  function: Handle.cancel.__qualname__.__eq__
  args: ["Handle.cancel"]
  expected: true

invariant asyncio_extra275.Handle.cancelled_qualname:
  description: "asyncio.Handle.cancelled.__qualname__ == 'Handle.cancelled'"
  category: identity
  kind: python_call_eq
  function: Handle.cancelled.__qualname__.__eq__
  args: ["Handle.cancelled"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.TimerHandle method __qualname__ values — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra275.TimerHandle.when_qualname:
  description: "asyncio.TimerHandle.when.__qualname__ == 'TimerHandle.when'"
  category: identity
  kind: python_call_eq
  function: TimerHandle.when.__qualname__.__eq__
  args: ["TimerHandle.when"]
  expected: true

invariant asyncio_extra275.TimerHandle.cancel_qualname:
  description: "asyncio.TimerHandle.cancel.__qualname__ == 'TimerHandle.cancel'"
  category: identity
  kind: python_call_eq
  function: TimerHandle.cancel.__qualname__.__eq__
  args: ["TimerHandle.cancel"]
  expected: true
