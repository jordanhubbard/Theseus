spec: minimist
version: ">=1.2.0"
backend: node(minimist)

docs: https://github.com/minimistjs/minimist#readme

provenance:
  derived_from:
    - "minimist npm package README — https://github.com/minimistjs/minimist#readme"
    - "Test vectors verified with minimist@1.2.8 via Node.js 22.20.0 on macOS/Darwin 25.3.0, 2026-03-31"
    - "minimist source: index.js — option parsing rules for negation, string type, alias, defaults (MIT; source inspection permitted)"
  not_derived_from:
    - "minimist source: internal argv tokenizer implementation"
  notes:
    - "minimist exports the parse function directly as the module default export, not as a named method. Invariants use function: null to call the module itself."
    - "Positional arguments land in the '_' array."
    - "Arguments after '--' are treated as positional (added to '_')."
    - "Short flags like -x without a value become {x: true}."
    - "Numeric strings after '--num' become integers (type coercion is default behavior)."
  created_at: "2026-03-31T00:00:00Z"

error_model:
  semantics: "minimist does not throw for normal inputs. node exits 0 for all invariants in this spec."
  stderr: "null"
  stickiness: "N/A — each function call is stateless."
  codes: {}

table minimist.parse:
  kind: node_module_call_eq
  function: ~
  id_prefix: parse

  columns: [id, category, args, expected]
  rows:
    - [long_flag_with_value,   long_flags, [["--foo", "bar"]],   {_: [], foo: "bar"}]
    - [long_flag_equals_syntax,long_flags, [["--foo=bar"]],       {_: [], foo: "bar"}]
    - [long_boolean_flag,      long_flags, [["--flag"]],          {_: [], flag: true}]
    - [short_boolean_flags,    short_flags,[  ["-x", "-y"]],      {_: [], x: true, y: true}]
    - [short_combined_flags,   short_flags,[  ["-xy"]],           {_: [], x: true, y: true}]
    - [positional_args,        positional, [["a", "b", "c"]],     {_: ["a", "b", "c"]}]
    - [double_dash_separator,  positional, [["a", "b", "--", "c"]],{_: ["a", "b", "c"]}]
    - [numeric_value,          coercion,   [["--num", "42"]],     {_: [], num: 42}]
    - [empty_argv,             edge_cases, [[]],                  {_: []}]
    - [negated_flag,          boolean_flags,[["--no-verbose"]],   {_: [], verbose: false}]
    - [string_prevents_coerce,types,       [["--port", "80"], {string: ["port"]}], {_: [], port: "80"}]
    - [alias_short,           alias,       [["-v"], {alias: {v: "verbose"}}], {_: [], v: true, verbose: true}]
    - [default_value,         defaults,    [["--other", "x"], {default: {foo: "bar"}}], {_: [], other: "x", foo: "bar"}]
    - [double_negative,       boolean_flags,[["--no-no-flag"]],   {_: [], "no-flag": false}]
    - [mixed_types,           mixed,       [["foo", "--bar", "baz", "-q"]], {_: ["foo"], bar: "baz", q: true}]
