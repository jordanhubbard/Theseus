spec: inspect_extra28
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra27.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__name__, getmembers/signature/Parameter/Signature/BoundArguments identity, Parameter kind class names, empty sentinel class names, class __bases__[0].__name__ for Parameter/Signature/BoundArguments (all 'object'), various __qualname__ and __module__ checks."
    - "This spec covers: inspect.ismodule.__qualname__, inspect.isclass.__qualname__, inspect.isfunction.__qualname__, inspect.ismethod.__qualname__, inspect.isbuiltin.__qualname__, inspect.isroutine.__qualname__, inspect.signature.__qualname__, inspect.getmembers.__qualname__, inspect.ismodule.__module__.__len__(), inspect.isclass.__module__.__len__(), inspect.signature.__module__.__len__(), inspect.getmembers.__module__.__len__()."
    - "All predicate functions have __qualname__ equal to their __name__ (simple module-level functions)."
    - "ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/signature/getmembers all have __module__ == 'inspect' (len 7)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect predicate and utility function __qualname__ values — combined table
#
# ismodule, isclass, isfunction, ismethod, isbuiltin, isroutine, signature,
# and getmembers are all module-level functions; their __qualname__ values
# equal their simple identifier strings. No prior inspect spec records these
# eight __qualname__ values together in a combined table in the extra28 namespace.
# ---------------------------------------------------------------------------

table inspect_extra28.function_qualnames:
  description: "__qualname__ for inspect predicate and utility functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ismodule,   ismodule.__qualname__.__eq__,   ["ismodule"],   true]
    - [isclass,    isclass.__qualname__.__eq__,    ["isclass"],    true]
    - [isfunction, isfunction.__qualname__.__eq__, ["isfunction"], true]
    - [ismethod,   ismethod.__qualname__.__eq__,   ["ismethod"],   true]
    - [isbuiltin,  isbuiltin.__qualname__.__eq__,  ["isbuiltin"],  true]
    - [isroutine,  isroutine.__qualname__.__eq__,  ["isroutine"],  true]
    - [signature,  signature.__qualname__.__eq__,  ["signature"],  true]
    - [getmembers, getmembers.__qualname__.__eq__, ["getmembers"], true]

# ---------------------------------------------------------------------------
# inspect function __module__.__len__() — combined table
#
# ismodule, isclass, signature, and getmembers all have __module__ == 'inspect'
# (len 7). No prior inspect spec records these four __module__.__len__() values
# together in a combined table in the extra28 namespace.
# ---------------------------------------------------------------------------

table inspect_extra28.function_module_lens:
  description: "__module__.__len__() for inspect functions — all 7 ('inspect')"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [ismodule,   ismodule.__module__.__len__,   [], 7]
    - [isclass,    isclass.__module__.__len__,    [], 7]
    - [signature,  signature.__module__.__len__,  [], 7]
    - [getmembers, getmembers.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# len('inspect') == 7 — standalone invariant
#
# inspect.ismodule.__module__ == 'inspect'; its length is 7. This invariant
# anchors the module name length. No prior inspect spec records
# ismodule.__module__.__len__() in any standalone invariant in the extra28
# namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra28.ismodule.module_len:
  description: "len(inspect.ismodule.__module__) == 7 — len('inspect') == 7"
  category: module_attr_lengths
  kind: python_call_eq
  function: ismodule.__module__.__len__
  args: []
  expected: 7
