spec: struct_extra2281
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size."
    - "Covers struct.Struct (C extension type) and struct.error (Python exception class)."
    - "struct.Struct inherits directly from object (MRO length 2, bases length 1)."
    - "struct.error MRO: error -> Exception -> BaseException -> object (length 4)."
    - "Neither class carries __abstractmethods__; accessing it raises AttributeError."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2281.struct_mro:
  description: "struct.Struct MRO depth, base count, and dict size (C extension type)"
  kind: python_call_eq
  category: mro_depth
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281001", "struct.Struct.__mro__.__len__", [], 2]
    - ["st2281002", "struct.Struct.__bases__.__len__", [], 1]
    - ["st2281003", "struct.Struct.__dict__.__len__", [], 16]

table struct_extra2281.struct_error_mro:
  description: "struct.error MRO depth, base count, and dict size (exception subclass)"
  kind: python_call_eq
  category: mro_depth
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281004", "struct.error.__mro__.__len__", [], 4]
    - ["st2281005", "struct.error.__bases__.__len__", [], 1]
    - ["st2281006", "struct.error.__dict__.__len__", [], 3]

table struct_extra2281.struct_abstractmethods_raises:
  description: "struct.Struct does not expose __abstractmethods__ (C extension type)"
  kind: python_call_raises
  category: attribute_error
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281007", "struct.Struct.__abstractmethods__.__len__", [], "AttributeError"]

table struct_extra2281.struct_error_abstractmethods_raises:
  description: "struct.error does not expose __abstractmethods__"
  kind: python_call_raises
  category: attribute_error
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281008", "struct.error.__abstractmethods__.__len__", [], "AttributeError"]

table struct_extra2281.struct_bases_detail:
  description: "struct.Struct base class tuple properties (flat C extension hierarchy)"
  kind: python_call_eq
  category: mro_depth
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281009", "struct.Struct.__mro__.__len__", [], 2]
    - ["st2281010", "struct.Struct.__bases__.__len__", [], 1]

table struct_extra2281.struct_error_bases_detail:
  description: "struct.error base class tuple properties (deep exception hierarchy)"
  kind: python_call_eq
  category: mro_depth
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281011", "struct.error.__mro__.__len__", [], 4]
    - ["st2281012", "struct.error.__bases__.__len__", [], 1]

table struct_extra2281.dict_sizes:
  description: "struct.Struct and struct.error dict sizes reflect their public API"
