  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281013", "struct.Struct.__dict__.__len__", [], 16]
    - ["st2281014", "struct.error.__dict__.__len__", [], 3]

table struct_extra2281.mro_contrast:
  description: "struct.Struct (flat C type, depth 2) vs struct.error (exception chain, depth 4)"
  kind: python_call_eq
  category: mro_depth
  id_prefix: st2281

  columns: [id, function, args, expected]
  rows:
    - ["st2281015", "struct.Struct.__mro__.__len__", [], 2]
    - ["st2281016", "struct.error.__mro__.__len__", [], 4]
    - ["st2281017", "struct.Struct.__bases__.__len__", [], 1]
