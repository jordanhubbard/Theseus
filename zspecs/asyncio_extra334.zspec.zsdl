spec: asyncio_extra334
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers asyncio.Queue class-level attributes only — no coroutines are invoked."
    - "Queue.__doc__.__class__.__name__ == 'str' confirms the docstring is a string."
    - "Qualnames for Queue methods follow the 'Queue.method_name' pattern."
    - "asyncio.LifoQueue inherits directly from asyncio.Queue; __bases__[0].__name__ == 'Queue'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue.__doc__ — the docstring is a plain str
# ---------------------------------------------------------------------------

invariant asyncio_extra334.queue.doc_is_str:
  description: "asyncio.Queue.__doc__.__class__.__name__ == 'str' — docstring is a string"
  category: queue
  kind: python_call_eq
  function: Queue.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Queue method qualnames — all follow the 'Queue.<method>' pattern
# ---------------------------------------------------------------------------

invariant asyncio_extra334.queue.qsize_qualname:
  description: "asyncio.Queue.qsize.__qualname__ == 'Queue.qsize'"
  category: queue
  kind: python_call_eq
  function: Queue.qsize.__qualname__.__eq__
  args: ["Queue.qsize"]
  expected: true

invariant asyncio_extra334.queue.empty_qualname:
  description: "asyncio.Queue.empty.__qualname__ == 'Queue.empty'"
  category: queue
  kind: python_call_eq
  function: Queue.empty.__qualname__.__eq__
  args: ["Queue.empty"]
  expected: true

invariant asyncio_extra334.queue.full_qualname:
  description: "asyncio.Queue.full.__qualname__ == 'Queue.full'"
  category: queue
  kind: python_call_eq
  function: Queue.full.__qualname__.__eq__
  args: ["Queue.full"]
  expected: true

invariant asyncio_extra334.queue.put_qualname:
  description: "asyncio.Queue.put.__qualname__ == 'Queue.put'"
  category: queue
  kind: python_call_eq
  function: Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true

invariant asyncio_extra334.queue.get_qualname:
  description: "asyncio.Queue.get.__qualname__ == 'Queue.get'"
  category: queue
  kind: python_call_eq
  function: Queue.get.__qualname__.__eq__
  args: ["Queue.get"]
  expected: true

invariant asyncio_extra334.queue.put_nowait_qualname:
  description: "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait'"
  category: queue
  kind: python_call_eq
  function: Queue.put_nowait.__qualname__.__eq__
  args: ["Queue.put_nowait"]
  expected: true

invariant asyncio_extra334.queue.get_nowait_qualname:
  description: "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait'"
  category: queue
  kind: python_call_eq
  function: Queue.get_nowait.__qualname__.__eq__
  args: ["Queue.get_nowait"]
  expected: true

# ---------------------------------------------------------------------------
# LifoQueue — inherits from Queue
#
# asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' confirms the direct
# base class is asyncio.Queue (not object).
# ---------------------------------------------------------------------------

invariant asyncio_extra334.lifoqueue.base_is_queue:
  description: "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue inherits from Queue"
  category: lifoqueue
  kind: python_call_eq
  function: LifoQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"
