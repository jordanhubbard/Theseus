spec: multiprocessing_extra175
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing process start methods — multiprocessing.get_start_method.__name__=='get_start_method' (len=16); multiprocessing.get_start_method.__module__=='multiprocessing.context'; multiprocessing.set_start_method.__name__=='set_start_method' (len=16; same len as get); multiprocessing.get_context.__name__=='get_context' (len=11); multiprocessing.get_all_start_methods.__name__=='get_all_start_methods' (len=21); multiprocessing.cpu_count.__name__=='cpu_count' (len=9); multiprocessing.cpu_count.__module__=='multiprocessing.context'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.get_start_method.__name__ == 'get_start_method' (len=16: 'get'=3+'_start_method'=13=16). get_start_method() returns the name of the current start method ('fork', 'forkserver', or 'spawn'). Defined in Lib/multiprocessing/context.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.get_start_method.__module__ == 'multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23). Same module as set_start_method, get_context, and cpu_count. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.set_start_method.__name__ == 'set_start_method' (len=16: 'set'=3+'_start_method'=13=16; same len as 'get_start_method'=16 — 'get' and 'set' both have 3 chars so the names have equal length). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.get_context.__name__ == 'get_context' (len=11: 'get'=3+'_context'=8=11). get_context(method=None) returns a context object with the given start method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.get_all_start_methods.__name__ == 'get_all_start_methods' (len=21: 'get'=3+'_all_start_methods'=18=21; longest function name in this spec). get_all_start_methods() returns list of supported start methods on this platform. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.cpu_count.__name__ == 'cpu_count' (len=9: 'cpu'=3+'_count'=6=9). multiprocessing.cpu_count.__module__ == 'multiprocessing.context'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.get_start_method and set_start_method identity
#
# multiprocessing.get_start_method.__name__ == 'get_start_method' (len=16)
# multiprocessing.get_start_method.__module__ == 'multiprocessing.context'
# multiprocessing.set_start_method.__name__ == 'set_start_method' (len=16; same)
#
# get_start_method() and set_start_method() are the primary API for querying
# and configuring the process start method. Both are defined in
# Lib/multiprocessing/context.py. Both names have length 16 because 'get' and
# 'set' both have 3 characters. New to extra175.
# ---------------------------------------------------------------------------

table multiprocessing_extra175.get_set_start_method_identity:
  description: "get_start_method.__name__ 'get_start_method' len 16; __module__ 'multiprocessing.context'; set_start_method.__name__ 'set_start_method' len 16 (same); new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: mpstartmethod175

  columns: [id, function, args, expected, description]
  rows:
    - [get_start_name_eq,
       multiprocessing.get_start_method.__name__.__eq__,
       ["get_start_method"],
       true,
       "multiprocessing.get_start_method.__name__.__eq__('get_start_method') == True — get_start_method() returns the name of the current start method ('fork', 'forkserver', or 'spawn'); defined in Lib/multiprocessing/context.py; __name__ is 'get_start_method' (16 chars: 'get'=3+'_start_method'=13=16); str.__eq__('get_start_method') returns True; new to extra175"]
    - [get_start_name_len_16,
       multiprocessing.get_start_method.__name__.__len__,
       [],
       16,
       "multiprocessing.get_start_method.__name__.__len__() == 16 — 'get_start_method' has 16 characters: 'get'=3+'_start_method'=13=16; same length as 'set_start_method'=16; str.__len__() returns 16; new to extra175"]
    - [get_start_module_eq,
       multiprocessing.get_start_method.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.get_start_method.__module__.__eq__('multiprocessing.context') == True — get_start_method is defined in Lib/multiprocessing/context.py; its __module__ is 'multiprocessing.context' (23 chars: 'multiprocessing'=15+'.'=1+'context'=7=23); str.__eq__('multiprocessing.context') returns True; new to extra175"]
    - [get_start_module_len_23,
       multiprocessing.get_start_method.__module__.__len__,
       [],
       23,
       "multiprocessing.get_start_method.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters: 'multiprocessing'=15+'.'=1+'context'=7=23; all start-method functions share this module; str.__len__() returns 23; new to extra175"]
    - [set_start_name_eq,
       multiprocessing.set_start_method.__name__.__eq__,
       ["set_start_method"],
       true,
       "multiprocessing.set_start_method.__name__.__eq__('set_start_method') == True — set_start_method(method, force=False) sets the start method for child processes; defined in Lib/multiprocessing/context.py; __name__ is 'set_start_method' (16 chars: 'set'=3+'_start_method'=13=16); str.__eq__('set_start_method') returns True; new to extra175"]
    - [set_start_name_len_16,
       multiprocessing.set_start_method.__name__.__len__,
       [],
       16,
       "multiprocessing.set_start_method.__name__.__len__() == 16 — 'set_start_method' has 16 characters: same as 'get_start_method'=16; 'get' and 'set' both have 3 chars so names have equal length; str.__len__() returns 16; new to extra175"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.get_context and get_all_start_methods identity
#
# multiprocessing.get_context.__name__ == 'get_context' (len=11)
# multiprocessing.get_all_start_methods.__name__ == 'get_all_start_methods' (len=21)
#
# get_context(method=None) returns a context object that uses the given start
# method. get_all_start_methods() returns all supported start methods on the
# current platform (varies by OS). NAME LENGTHS: 'get_context'=11 is shorter
# than 'get_start_method'=16 which is shorter than 'get_all_start_methods'=21.
# New to extra175.
# ---------------------------------------------------------------------------

table multiprocessing_extra175.get_context_and_all_start_methods:
  description: "get_context.__name__ 'get_context' len 11; get_all_start_methods.__name__ 'get_all_start_methods' len 21; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: mpstartmethod175

  columns: [id, function, args, expected, description]
  rows:
    - [get_context_name_eq,
       multiprocessing.get_context.__name__.__eq__,
       ["get_context"],
       true,
       "multiprocessing.get_context.__name__.__eq__('get_context') == True — get_context(method=None) returns a context object that has the same attributes as the multiprocessing module but uses the given start method; defined in Lib/multiprocessing/context.py; __name__ is 'get_context' (11 chars: 'get'=3+'_context'=8=11); str.__eq__('get_context') returns True; new to extra175"]
    - [get_context_name_len_11,
       multiprocessing.get_context.__name__.__len__,
       [],
       11,
       "multiprocessing.get_context.__name__.__len__() == 11 — 'get_context' has 11 characters: 'get'=3+'_context'=8=11; shorter than 'get_start_method'=16; str.__len__() returns 11; new to extra175"]
    - [get_all_start_name_eq,
       multiprocessing.get_all_start_methods.__name__.__eq__,
       ["get_all_start_methods"],
       true,
       "multiprocessing.get_all_start_methods.__name__.__eq__('get_all_start_methods') == True — get_all_start_methods() returns a list of the supported start methods on this platform (e.g., ['fork', 'forkserver', 'spawn'] on Linux; ['spawn'] on Windows); defined in Lib/multiprocessing/context.py; __name__ is 'get_all_start_methods' (21 chars); str.__eq__('get_all_start_methods') returns True; new to extra175"]
    - [get_all_start_name_len_21,
       multiprocessing.get_all_start_methods.__name__.__len__,
       [],
       21,
       "multiprocessing.get_all_start_methods.__name__.__len__() == 21 — 'get_all_start_methods' has 21 characters: 'get'=3+'_all_start_methods'=18=21; longest function name in this spec; NAME LENGTHS: get_context=11 < get_start_method=16 < get_all_start_methods=21; str.__len__() returns 21; new to extra175"]
    - [get_context_module_eq,
       multiprocessing.get_context.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.get_context.__module__.__eq__('multiprocessing.context') == True — get_context is defined in Lib/multiprocessing/context.py; shares __module__ 'multiprocessing.context' (23 chars) with get_start_method and set_start_method; str.__eq__('multiprocessing.context') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.cpu_count __name__ and __module__
#
# multiprocessing.cpu_count.__name__ == 'cpu_count' (len=9)
# multiprocessing.cpu_count.__module__ == 'multiprocessing.context'
#
# cpu_count() returns the number of CPUs in the system. It is defined in
# Lib/multiprocessing/context.py alongside the start method functions.
# NAME LENGTH: 'cpu_count'=9 is shorter than all start method function names.
# New to extra175.
# ---------------------------------------------------------------------------

table multiprocessing_extra175.cpu_count_identity:
  description: "cpu_count.__name__ 'cpu_count' len 9; __module__ 'multiprocessing.context' len 23; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: mpstartmethod175

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count_name_eq,
       multiprocessing.cpu_count.__name__.__eq__,
       ["cpu_count"],
       true,
       "multiprocessing.cpu_count.__name__.__eq__('cpu_count') == True — cpu_count() returns the number of CPUs in the system; defined in Lib/multiprocessing/context.py; __name__ is 'cpu_count' (9 chars: 'cpu'=3+'_count'=6=9); str.__eq__('cpu_count') returns True; new to extra175"]
    - [cpu_count_name_len_9,
       multiprocessing.cpu_count.__name__.__len__,
       [],
       9,
       "multiprocessing.cpu_count.__name__.__len__() == 9 — 'cpu_count' has 9 characters: 'cpu'=3+'_count'=6=9; shorter than all start method names (get_context=11, get_start_method=16, set_start_method=16, get_all_start_methods=21); str.__len__() returns 9; new to extra175"]
    - [cpu_count_module_eq,
       multiprocessing.cpu_count.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.cpu_count.__module__.__eq__('multiprocessing.context') == True — cpu_count is defined in Lib/multiprocessing/context.py; shares __module__ 'multiprocessing.context' with all start method functions in this spec; str.__eq__('multiprocessing.context') returns True; new to extra175"]
    - [cpu_count_module_len_23,
       multiprocessing.cpu_count.__module__.__len__,
       [],
       23,
       "multiprocessing.cpu_count.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters: 'multiprocessing'=15+'.'=1+'context'=7=23; shared __module__ for all context.py functions; str.__len__() returns 23; new to extra175"]
    - [set_start_module_eq,
       multiprocessing.set_start_method.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.set_start_method.__module__.__eq__('multiprocessing.context') == True — set_start_method shares __module__ 'multiprocessing.context' with get_start_method, get_context, get_all_start_methods, and cpu_count; str.__eq__('multiprocessing.context') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra175
# ---------------------------------------------------------------------------

invariant multiprocessing_extra175.get_start_method_name_eq:
  description: "multiprocessing.get_start_method.__name__ == 'get_start_method' — returns current start method name; __name__ len=16 ('get'=3+'_start_method'=13=16); new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_start_method.__name__.__eq__
  args: ["get_start_method"]
  expected: true

invariant multiprocessing_extra175.get_start_method_module_eq:
  description: "multiprocessing.get_start_method.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; module len=23; new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_start_method.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra175.set_start_method_name_len_16:
  description: "multiprocessing.set_start_method.__name__.__len__() == 16 — 'set_start_method' has 16 chars; same as 'get_start_method'=16 (get/set both 3 chars); new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.set_start_method.__name__.__len__
  args: []
  expected: 16

invariant multiprocessing_extra175.get_context_name_len_11:
  description: "multiprocessing.get_context.__name__.__len__() == 11 — 'get_context' has 11 chars ('get'=3+'_context'=8=11); shorter than get_start_method=16; new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_context.__name__.__len__
  args: []
  expected: 11

invariant multiprocessing_extra175.get_all_start_methods_name_len_21:
  description: "multiprocessing.get_all_start_methods.__name__.__len__() == 21 — 'get_all_start_methods' has 21 chars; longest function name in this spec; new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_all_start_methods.__name__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra175.cpu_count_name_cpu_count:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count' — returns number of CPUs; __name__ is 'cpu_count' (9 chars: 'cpu'=3+'_count'=6=9); new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra175.cpu_count_module_context:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py alongside start method functions; new to extra175"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
