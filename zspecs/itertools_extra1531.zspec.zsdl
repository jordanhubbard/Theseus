spec: itertools_extra1531
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks via __dict__.__contains__ for itertools classes."
    - "All itertools iterator types are C extension types implemented in Modules/itertoolsmodule.c."
    - "itertools.chain.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "itertools.count.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "itertools.cycle.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "itertools.repeat.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "itertools.accumulate.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "itertools.combinations.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "itertools.product.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "No itertools C type defines any of __lt__, __le__, __gt__, __ge__, __ne__, __eq__, or __hash__ in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain — comparison operator dict-presence checks
#
# Wave 549 theme: chain is a C extension type. Its own __dict__ does not
# contain any of the comparison dunder methods. These invariants confirm
# that the absence of comparison operators is a stable property of the type.
# ---------------------------------------------------------------------------

table itertools_extra1531.chain_dict_contains:
  description: "itertools.chain.__dict__.__contains__ returns False for all comparison dunder methods; wave 549; new to extra1531"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1531ch

  columns: [id, function, args, expected, description]
  rows:
    - ["it1531ch001",
       "chain.__dict__.__contains__",
       ["__lt__"],
       false,
       "itertools.chain.__dict__.__contains__('__lt__') == False — chain is a C extension type; its __dict__ does not define __lt__; wave 549; new to extra1531"]
    - ["it1531ch002",
       "chain.__dict__.__contains__",
       ["__le__"],
       false,
       "itertools.chain.__dict__.__contains__('__le__') == False — chain does not define __le__ in its own class __dict__; wave 549; new to extra1531"]
    - ["it1531ch003",
       "chain.__dict__.__contains__",
       ["__gt__"],
       false,
       "itertools.chain.__dict__.__contains__('__gt__') == False — chain does not define __gt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["it1531ch004",
       "chain.__dict__.__contains__",
       ["__ge__"],
       false,
       "itertools.chain.__dict__.__contains__('__ge__') == False — chain does not define __ge__ in its own class __dict__; wave 549; new to extra1531"]
    - ["it1531ch005",
       "chain.__dict__.__contains__",
       ["__ne__"],
       false,
       "itertools.chain.__dict__.__contains__('__ne__') == False — chain does not define __ne__ in its own class __dict__; wave 549; new to extra1531"]
    - ["it1531ch006",
       "chain.__dict__.__contains__",
       ["__eq__"],
       false,
       "itertools.chain.__dict__.__contains__('__eq__') == False — chain does not define __eq__ in its own class __dict__; wave 549; new to extra1531"]
    - ["it1531ch007",
       "chain.__dict__.__contains__",
       ["__hash__"],
       false,
       "itertools.chain.__dict__.__contains__('__hash__') == False — chain does not define __hash__ in its own class __dict__; wave 549; new to extra1531"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count — comparison operator dict-presence checks
#
# Wave 549 theme: count is a C extension type that generates consecutive
# integers. Its own __dict__ defines no comparison dunder methods;
# iterator types are not ordered relative to each other.
# ---------------------------------------------------------------------------

table itertools_extra1531.count_dict_contains:
  description: "itertools.count.__dict__.__contains__ returns False for all comparison dunder methods; wave 549; new to extra1531"
  kind: python_call_eq
