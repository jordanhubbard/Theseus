spec: struct_extra2746
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "struct.Struct is a compiled struct object class; it does not implement __round__, __divmod__, or __pow__ in its own __dict__."
    - "struct.error is an exception subclass (inherits from Exception); it does not define __round__, __divmod__, or __pow__ in its own __dict__."
    - "None of the struct public classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2746.round_protocol:
  description: "__round__ is absent from all struct class __dict__s — none implement numeric rounding"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2746

  columns: [id, function, args, expected]
  rows:
    - ["st2746001", "struct.Struct.__dict__.__contains__", ["__round__"], false]
    - ["st2746002", "struct.error.__dict__.__contains__",  ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2746.divmod_protocol:
  description: "__divmod__ is absent from all struct class __dict__s — none implement divmod"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2746

  columns: [id, function, args, expected]
  rows:
    - ["st2746003", "struct.Struct.__dict__.__contains__", ["__divmod__"], false]
    - ["st2746004", "struct.error.__dict__.__contains__",  ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2746.pow_protocol:
  description: "__pow__ is absent from all struct class __dict__s — none implement exponentiation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2746

  columns: [id, function, args, expected]
  rows:
    - ["st2746005", "struct.Struct.__dict__.__contains__", ["__pow__"], false]
    - ["st2746006", "struct.error.__dict__.__contains__",  ["__pow__"], false]

# ---------------------------------------------------------------------------
# Combined view — Struct and error vs. all three arithmetic protocols
# ---------------------------------------------------------------------------

table struct_extra2746.struct_arithmetic_combined:
  description: "struct.Struct and struct.error define none of __round__, __divmod__, __pow__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2746

  columns: [id, function, args, expected]
  rows:
    - ["st2746007", "struct.Struct.__dict__.__contains__", ["__round__"],  false]
    - ["st2746008", "struct.Struct.__dict__.__contains__", ["__divmod__"], false]
    - ["st2746009", "struct.Struct.__dict__.__contains__", ["__pow__"],    false]
    - ["st2746010", "struct.error.__dict__.__contains__",  ["__round__"],  false]
    - ["st2746011", "struct.error.__dict__.__contains__",  ["__divmod__"], false]
    - ["st2746012", "struct.error.__dict__.__contains__",  ["__pow__"],    false]
