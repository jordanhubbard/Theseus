    - [fileio_mro0_name_eq,   "FileIO.__mro__[0].__name__.__eq__",  ["FileIO"],    true,  "io.FileIO.__mro__[0].__name__ == 'FileIO'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [fileio_mro1_name_eq,   "FileIO.__mro__[1].__name__.__eq__",  ["_RawIOBase"], true,  "io.FileIO.__mro__[1].__name__ == '_RawIOBase'; FileIO directly inherits from _RawIOBase; confirmed Python 3.14.3 macOS"]
