    - [fileio_mro_class_name_eq,  FileIO.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "io.FileIO.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [fileio_mro_class_name_len, FileIO.__mro__.__class__.__name__.__len__,  [],        5,     "io.FileIO.__mro__.__class__.__name__.__len__() == 5; 'tuple' has 5 characters; confirmed Python 3.14.3 macOS"]
    - [fileio_mro_len_eq,         FileIO.__mro__.__len__,                    [],        4,     "io.FileIO.__mro__.__len__() == 4; MRO is [FileIO, _RawIOBase, _IOBase, object]; confirmed Python 3.14.3 macOS"]
    - [fileio_mro_len_gt_zero,    FileIO.__mro__.__len__,                    [],        4,     "io.FileIO.__mro__.__len__() == 4; MRO is non-empty and has exactly 4 entries; confirmed Python 3.14.3 macOS"]

