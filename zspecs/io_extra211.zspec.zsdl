spec: io_extra211
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra210.zspec.zsdl — covers io.__all__ membership and identity"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata"
  notes:
    - "io.FileIO.__mro__ is a tuple; len == 4; MRO is [FileIO, _RawIOBase, _IOBase, object]; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__mro__ is a tuple; len == 4; MRO is [BufferedReader, _BufferedIOBase, _IOBase, object]; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__mro__ is a tuple; len == 4; MRO is [TextIOWrapper, _TextIOBase, _IOBase, object]; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__mro__ is a tuple; len == 4; MRO is [BytesIO, _BufferedIOBase, _IOBase, object]; confirmed Python 3.14.3 macOS."
    - "Index access on __mro__ uses bracket notation — function paths containing '[' must be double-quoted."
    - "All four concrete io classes share the same MRO depth of 4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

