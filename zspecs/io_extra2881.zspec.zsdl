spec: io2881
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2866.zspec.zsdl — wave 638 predecessor (covered __rand__, __ror__, __rxor__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 639 theme: __iadd__, __isub__, __imul__ dict-presence checks (in-place augmented assignment operators)."
    - "io classes are I/O stream objects, not numeric types — none define in-place arithmetic operators."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase do NOT define __iadd__, __isub__, or __imul__."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these in-place operators."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IncrementalNewlineDecoder also absent for all three."
    - "Absence is consistent across all 12 io classes tested — io streams have no arithmetic semantics."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iadd__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io2881.iadd:
  description: "__iadd__ is absent from all io class __dict__s — io streams are not in-place addition operands"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2881

  columns: [id, function, args, expected]
  rows:
    - ["io2881001", "io.IOBase.__dict__.__contains__",              ["__iadd__"], false]
    - ["io2881002", "io.RawIOBase.__dict__.__contains__",           ["__iadd__"], false]
    - ["io2881003", "io.BufferedIOBase.__dict__.__contains__",      ["__iadd__"], false]
    - ["io2881004", "io.TextIOBase.__dict__.__contains__",          ["__iadd__"], false]
    - ["io2881005", "io.BytesIO.__dict__.__contains__",             ["__iadd__"], false]
    - ["io2881006", "io.StringIO.__dict__.__contains__",            ["__iadd__"], false]
    - ["io2881007", "io.FileIO.__dict__.__contains__",              ["__iadd__"], false]
    - ["io2881008", "io.BufferedReader.__dict__.__contains__",      ["__iadd__"], false]
    - ["io2881009", "io.BufferedWriter.__dict__.__contains__",      ["__iadd__"], false]
    - ["io2881010", "io.BufferedRandom.__dict__.__contains__",      ["__iadd__"], false]
    - ["io2881011", "io.TextIOWrapper.__dict__.__contains__",       ["__iadd__"], false]
    - ["io2881012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__iadd__"], false]

