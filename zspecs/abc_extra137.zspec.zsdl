invariant abc_extra137.abcmeta_register_doc_len_99:
  description: "abc.ABCMeta.register.__doc__.__len__() == 99 — abc.ABCMeta.register.__doc__ is 'Register a virtual subclass of an ABC.\\n\\nReturns the subclass, to allow usage as a class decorator.\\n' (99 chars); ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); co_argcount==2 ('cls','subclass'); NEW in extra137: first standalone ABCMeta.register doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__doc__.__len__
  args: []
  expected: 99

invariant abc_extra137.abcmeta_instancecheck_qualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — abc.ABCMeta.__instancecheck__.__qualname__ is 'ABCMeta.__instancecheck__' (25 chars: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25); this is the same length as ABCMeta.__subclasscheck__.__qualname__ (also 25 chars); __instancecheck__.__doc__.__len__()==39; co_argcount==2; NEW in extra137: first standalone ABCMeta.__instancecheck__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra137.get_cache_token_module_len_4:
  description: "abc.get_cache_token.__module__.__len__() == 4 — abc.get_cache_token.__module__ is '_abc' (4 chars: leading underscore + 'abc'=3=4); get_cache_token is implemented in the C extension module _abc rather than the pure-Python abc module (where ABCMeta and ABC live); __name__=='get_cache_token' (len=15); __doc__.__len__()==230; NEW in extra137: first standalone get_cache_token module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__len__
  args: []
  expected: 4

invariant abc_extra137.get_cache_token_doc_len_230:
  description: "abc.get_cache_token.__doc__.__len__() == 230 — abc.get_cache_token.__doc__ is a 230-char description of the ABC cache token mechanism (an opaque object supporting equality testing that identifies the current version of the ABC cache); __name__=='get_cache_token' (len=15); __module__=='_abc' (len=4, C extension); NEW in extra137: first standalone get_cache_token doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__doc__.__len__
  args: []
  expected: 230

invariant abc_extra137.abcmeta_doc_len_576:
  description: "abc.ABCMeta.__doc__.__len__() == 576 — abc.ABCMeta.__doc__ is a 576-char multi-paragraph doc beginning 'Metaclass for defining Abstract Base Classes (ABCs).'; ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc' (len=3); NEW in extra137: first standalone ABCMeta __doc__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__len__
