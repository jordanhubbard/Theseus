    - [ic_doc_len,   abc.ABCMeta.__instancecheck__.__doc__.__len__,                    [],                                         39,    "abc.ABCMeta.__instancecheck__.__doc__.__len__() == 39; verified with Python 3.14.3"]
    - [ic_argc,      abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__,       [2],                                         true,  "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2 ('cls','instance'); verified with Python 3.14.3"]
    - [ic_vlen,      abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__,       [],                                         2,     "abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__() == 2 ('cls','instance'); verified with Python 3.14.3"]
