spec: abc_extra137
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABCMeta — __name__=='ABCMeta' (len=7); __module__=='abc' (len=3); __doc__.__len__()==576. abc.ABCMeta.register — __name__=='register' (len=8); __qualname__=='ABCMeta.register' (len=16); __doc__.__len__()==99; __doc__=='Register a virtual subclass of an ABC.\\n\\nReturns the subclass, to allow usage as a class decorator.\\n'; co_argcount==2 ('cls','subclass'); co_varnames.__len__()==2. abc.ABCMeta.__instancecheck__ — __name__=='__instancecheck__' (len=17); __qualname__=='ABCMeta.__instancecheck__' (len=25); __doc__.__len__()==39; __doc__=='Override for isinstance(instance, cls).'; co_argcount==2 ('cls','instance'); co_varnames.__len__()==2. abc.ABCMeta.__subclasscheck__ — __name__=='__subclasscheck__' (len=17); __qualname__=='ABCMeta.__subclasscheck__' (len=25); __doc__.__len__()==39; __doc__=='Override for issubclass(subclass, cls).'; co_argcount==2 ('cls','subclass'); co_varnames.__len__()==2. abc.get_cache_token — __name__=='get_cache_token' (len=15); __qualname__=='get_cache_token' (len=15); __module__=='_abc' (len=4); __doc__.__len__()==230. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__qualname__=='ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); co_varnames==('cls','subclass') (len=2). ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25); co_varnames==('cls','instance') (len=2). ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25, same len as __instancecheck__ qualname); co_varnames==('cls','subclass') (len=2). abc.get_cache_token.__module__=='_abc' (len=4: implemented in the C extension _abc, not in the pure-Python abc module); __doc__.__len__()==230. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

