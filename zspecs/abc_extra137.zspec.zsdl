table abc_extra137.get_cache_token:
  description: "abc.get_cache_token __name__, __qualname__, __module__, and __doc__ checks — get_cache_token.__name__.__eq__('get_cache_token')==True (len=15: 'get_cache_token'=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15: top-level function, no class nesting, qualname equals name); get_cache_token.__module__.__eq__('_abc')==True (len=4: implemented in the C extension _abc, not in pure-Python abc module; leading underscore indicates C-level implementation); get_cache_token.__doc__.__len__()==230 (describes opaque token supporting equality testing that identifies the current version of the ABC cache); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abctoken137

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,  abc.get_cache_token.__name__.__eq__,    ["get_cache_token"],  true,  "abc.get_cache_token.__name__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [name_len, abc.get_cache_token.__name__.__len__,    [],                  15,    "abc.get_cache_token.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [qn_eq,    abc.get_cache_token.__qualname__.__eq__, ["get_cache_token"],  true,  "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15: qualname equals name, top-level function); verified with Python 3.14.3"]
    - [mod_eq,   abc.get_cache_token.__module__.__eq__,  ["_abc"],             true,  "abc.get_cache_token.__module__ == '_abc' (len=4: C extension implementation); verified with Python 3.14.3"]
    - [mod_len,  abc.get_cache_token.__module__.__len__,  [],                  4,     "abc.get_cache_token.__module__.__len__() == 4 ('_abc'); verified with Python 3.14.3"]
    - [doc_len,  abc.get_cache_token.__doc__.__len__,     [],                  230,   "abc.get_cache_token.__doc__.__len__() == 230; verified with Python 3.14.3"]

