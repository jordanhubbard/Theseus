table abc_extra137.abcmeta_checks:
  description: "abc.ABCMeta.__instancecheck__ and __subclasscheck__ __doc__, qualname, and code checks — __instancecheck__.__name__.__eq__('__instancecheck__')==True (len=17: '__'=2+'instancecheck'=13+'__'=2=17); __instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25); __instancecheck__.__doc__.__eq__('Override for isinstance(instance, cls).')==True (len=39); __instancecheck__ co_argcount==2 ('cls','instance'); __subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')==True (len=25: same length as __instancecheck__ qualname); __subclasscheck__.__doc__.__eq__('Override for issubclass(subclass, cls).')==True (len=39: same length as __instancecheck__ doc); __subclasscheck__ co_argcount==2 ('cls','subclass'); verified with Python 3.14.3"
