spec: hashlib_extra151
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra150.zspec.zsdl — covers hashlib._hashlib.__name__.__eq__('_hashlib') / _hashlib.__spec__.name.__eq__('_hashlib') / _hashlib.__loader__.__class__.__name__.__eq__('ExtensionFileLoader') / _hashlib.__package__.__eq__('') / _hashlib.HASH.__name__/__module__/__qualname__ equality / hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / hashlib.__package__.__eq__('') (table + invariants)."
    - "hashlib_extra149.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__eq__('tuple') / __all__.__len__()==19 / __all__.__contains__ checks for md5/sha256/new/file_digest/algorithms_guaranteed/blake2b/pbkdf2_hmac/sha3_256/algorithms_available (table + invariants)."
    - "hashlib_extra148.zspec.zsdl — covers hashlib.file_digest/__qualname__/__module__/__class__.__name__ / __code__.co_argcount==2 / hashlib.__spec__.name.__eq__('hashlib') / hashlib.__doc__.__len__()==2098 (table + invariants)."
    - "hashlib_extra147.zspec.zsdl — covers hashlib.sha3_256/sha3_512/sha3_224/sha3_384 __name__ equality strings / shake_128/shake_256 __name__ equality (table + invariants)."
    - "hashlib_extra146.zspec.zsdl — covers hashlib.pbkdf2_hmac and hashlib.scrypt function identity / blake2b/__module__.__eq__('_blake2') / blake2s/__module__.__eq__('_blake2') (table + invariants)."
    - "hashlib_extra145.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib_extra144.zspec.zsdl — covers hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH method qualname lengths (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra150."
    - "Wave 320 theme: hashlib._hashlib.HASH method __qualname__ string equality — HASH.update.__qualname__.__eq__('HASH.update') (len 11) / HASH.digest.__qualname__.__eq__('HASH.digest') (len 11) / HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest') (len 14) / HASH.copy.__qualname__.__eq__('HASH.copy') (len 9) / HASH.__dict__.__class__.__name__.__eq__('mappingproxy') (len 12) / HASH.__dict__.__len__()==10."
    - "hashlib._hashlib.HASH.update.__qualname__ == 'HASH.update' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.digest.__qualname__ == 'HASH.digest' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.hexdigest.__qualname__ == 'HASH.hexdigest' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.copy.__qualname__ == 'HASH.copy' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__dict__.__len__() == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.update.__class__.__name__ == 'method_descriptor'. All four methods (update/digest/hexdigest/copy) are method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The four HASH method qualnames follow the 'HASH.<method>' pattern (5-char 'HASH.' prefix + method name). Length ordering: copy (9 = 5+4) < update == digest (11 = 5+6) < hexdigest (14 = 5+9). The 'hexdigest' method has the longest name because 'hexdigest' (9 chars) is 3 chars longer than 'update'/'digest' (both 6 chars). All four are method_descriptor objects — C-level descriptors defined in Modules/_hashlib.c."
    - "Note: hashlib._hashlib.HASH.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). This differs from hashlib.__dict__.__class__.__name__ which is 'dict' (4 chars) and hashlib._hashlib.__dict__.__class__.__name__ which is also 'dict'. The HASH class dict is a mappingproxy (read-only view) because HASH is a C extension type — C extension types expose their class dict as a mappingproxy, just as Python-defined classes do."
    - "Note: hashlib._hashlib.HASH.__dict__.__len__() == 10. The 10 entries are: __repr__, update, digest, hexdigest, copy (5 method_descriptors), digest_size, block_size, name (3 attribute descriptors/slots), __doc__, __module__ (2 str metadata). extra144 anchors HASH.__doc__.__len__()==442; this spec anchors HASH.__dict__ class name and length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.update.__qualname__.__eq__('HASH.update')
# hashlib._hashlib.HASH.update.__qualname__.__len__()==11
# hashlib._hashlib.HASH.digest.__qualname__.__eq__('HASH.digest')
# hashlib._hashlib.HASH.digest.__qualname__.__len__()==11
#
# Wave 320 theme: HASH method qualname string equality for update and digest.
#
# update and digest are the two most-used HASH methods. Their qualnames follow the
# 'HASH.<method>' pattern with a 5-char 'HASH.' prefix. Both update and digest have
# 6-char method names giving 11-char qualnames. extra144 anchors qualname lengths for
# HASH methods; no prior hashlib spec anchors HASH.update or HASH.digest qualname
# equality strings as a table under hashmeth151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra151.HASH_update_digest_qualnames:
  description: "hashlib._hashlib.HASH.update/__qualname__.__eq__('HASH.update')==True / __qualname__.__len__()==11 / HASH.digest/__qualname__.__eq__('HASH.digest')==True / __qualname__.__len__()==11 — both are 'HASH.'+6-char method = 11 chars; update adds data to the hash; digest returns the hash as bytes; both are method_descriptor (C-level); extra144 anchors qualname lengths; first hashmeth151 anchor for update/digest qualname equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: hashmeth151

  columns: [id, function, args, expected, description]
  rows:
    - [update_qualname_eq,  "_hashlib.HASH.update.__qualname__.__eq__",  ["HASH.update"],  true, "hashlib._hashlib.HASH.update.__qualname__ == 'HASH.update' (11 chars = 5-char 'HASH.' + 6-char 'update')"]
    - [update_qualname_len, "_hashlib.HASH.update.__qualname__.__len__",  [],               11,   "hashlib._hashlib.HASH.update.__qualname__.__len__() is 11 ('HASH.update' = 5 + 6)"]
    - [digest_qualname_eq,  "_hashlib.HASH.digest.__qualname__.__eq__",  ["HASH.digest"],  true, "hashlib._hashlib.HASH.digest.__qualname__ == 'HASH.digest' (11 chars = 5-char 'HASH.' + 6-char 'digest')"]
    - [digest_qualname_len, "_hashlib.HASH.digest.__qualname__.__len__",  [],               11,   "hashlib._hashlib.HASH.digest.__qualname__.__len__() is 11 ('HASH.digest' = 5 + 6)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest')
# hashlib._hashlib.HASH.hexdigest.__qualname__.__len__()==14
# hashlib._hashlib.HASH.copy.__qualname__.__eq__('HASH.copy')
# hashlib._hashlib.HASH.copy.__qualname__.__len__()==9
#
# Wave 320 theme: HASH method qualname string equality for hexdigest and copy.
#
# hexdigest returns the hash as a lowercase hex string (9-char method name, 14-char
# qualname). copy returns a copy of the HASH object (4-char method name, 9-char qualname).
# Length ordering: copy(9) < update==digest(11) < hexdigest(14). extra144 anchors
# HASH method qualname lengths; no prior hashlib spec anchors hexdigest or copy
# qualname equality strings as a table under hashmeth151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra151.HASH_hexdigest_copy_qualnames:
  description: "hashlib._hashlib.HASH.hexdigest/__qualname__.__eq__('HASH.hexdigest')==True / __qualname__.__len__()==14 / HASH.copy/__qualname__.__eq__('HASH.copy')==True / __qualname__.__len__()==9 — hexdigest 'HASH.'+9 = 14 (longest HASH method qualname); copy 'HASH.'+4 = 9 (shortest); ordering: copy(9) < update==digest(11) < hexdigest(14); both are method_descriptor; extra144 anchors lengths; first hashmeth151 anchor for hexdigest/copy qualname equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: hashmeth151

  columns: [id, function, args, expected, description]
  rows:
    - [hexdigest_qualname_eq,  "_hashlib.HASH.hexdigest.__qualname__.__eq__",  ["HASH.hexdigest"], true, "hashlib._hashlib.HASH.hexdigest.__qualname__ == 'HASH.hexdigest' (14 chars = 5-char 'HASH.' + 9-char 'hexdigest')"]
    - [hexdigest_qualname_len, "_hashlib.HASH.hexdigest.__qualname__.__len__",  [],                14,   "hashlib._hashlib.HASH.hexdigest.__qualname__.__len__() is 14 ('HASH.hexdigest'; longest of the four HASH method qualnames)"]
    - [copy_qualname_eq,       "_hashlib.HASH.copy.__qualname__.__eq__",        ["HASH.copy"],     true, "hashlib._hashlib.HASH.copy.__qualname__ == 'HASH.copy' (9 chars = 5-char 'HASH.' + 4-char 'copy')"]
    - [copy_qualname_len,      "_hashlib.HASH.copy.__qualname__.__len__",        [],                9,    "hashlib._hashlib.HASH.copy.__qualname__.__len__() is 9 ('HASH.copy'; shortest of the four HASH method qualnames)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__dict__.__class__.__name__.__eq__('mappingproxy')
# hashlib._hashlib.HASH.__dict__.__class__.__name__.__len__()==12
# hashlib._hashlib.HASH.__dict__.__len__()==10
# hashlib._hashlib.HASH.__dict__.__contains__('update')
#
# Wave 320 theme: HASH class __dict__ type and contents.
#
# HASH.__dict__ is a mappingproxy (12 chars) — the standard read-only class dict
# for C extension types. It has 10 entries: __repr__, update, digest, hexdigest,
# copy (method_descriptors), digest_size, block_size, name, __doc__, __module__.
# extra144 anchors HASH.__doc__.__len__()==442; no prior hashlib spec anchors
# HASH.__dict__ class name or length as a table under hashmeth151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra151.HASH_dict_type_and_contents:
  description: "hashlib._hashlib.HASH.__dict__/__class__.__name__.__eq__('mappingproxy')==True / __class__.__name__.__len__()==12 / HASH.__dict__.__len__()==10 / HASH.__dict__.__contains__('update')==True — HASH.__dict__ is a mappingproxy (12 chars; C extension type class dict); 10 entries: 5 method_descriptors + 3 attribute descriptors + __doc__ + __module__; extra144 anchors HASH.__doc__ length; first hashmeth151 anchor for HASH dict class name, length, and update membership"
  kind: python_call_eq
  category: identity
  id_prefix: hashmeth151

  columns: [id, function, args, expected, description]
  rows:
    - [hash_dict_mappingproxy, "_hashlib.HASH.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "hashlib._hashlib.HASH.__dict__.__class__.__name__ == 'mappingproxy' (C extension type class dict)"]
    - [hash_dict_class_len,    "_hashlib.HASH.__dict__.__class__.__name__.__len__",  [],              12,   "hashlib._hashlib.HASH.__dict__.__class__.__name__.__len__() is 12 ('mappingproxy' = 12 chars)"]
    - [hash_dict_len_10,       "_hashlib.HASH.__dict__.__len__",                     [],              10,   "hashlib._hashlib.HASH.__dict__.__len__() is 10 (5 method_descriptors + 3 attr descriptors + __doc__ + __module__)"]
    - [hash_dict_contains_update, "_hashlib.HASH.__dict__.__contains__",             ["update"],      true, "hashlib._hashlib.HASH.__dict__.__contains__('update') == True (method_descriptor for updating the hash state)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.update.__qualname__.__eq__('HASH.update') — standalone
#
# hashlib._hashlib.HASH.update.__qualname__ is 'HASH.update' (11 chars). The update
# method is the primary interface for feeding data into a hash object — each call
# updates the internal hash state without allocating a new HASH object. The qualname
# 'HASH.update' uses the 5-char 'HASH.' prefix plus 6-char 'update'. This is the same
# length as 'HASH.digest' (also 11 chars). extra144 anchors HASH.update qualname
# length; no prior hashlib spec anchors HASH.update.__qualname__.__eq__('HASH.update')
# as a standalone under hashmeth151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra151.HASH_update_qualname_eq:
  description: "hashlib._hashlib.HASH.update.__qualname__.__eq__('HASH.update') == True — 'HASH.update' (11 chars = 5-char 'HASH.' + 6-char 'update'); primary interface for feeding data into hash; same length as 'HASH.digest' (also 11); method_descriptor (C-level); extra144 anchors length; no prior hashlib spec anchors this as a standalone; first standalone under hashmeth151"
  category: qualname_identity
  kind: python_call_eq
  function: "_hashlib.HASH.update.__qualname__.__eq__"
  args: ["HASH.update"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest') — standalone
#
# hashlib._hashlib.HASH.hexdigest.__qualname__ is 'HASH.hexdigest' (14 chars). The
# hexdigest method returns the hash as a lowercase hex string — the human-readable
# form (as opposed to digest which returns raw bytes). 'hexdigest' (9 chars) is the
# longest method name of the four HASH methods (copy=4, update=digest=6, hexdigest=9).
# Adding the 5-char 'HASH.' prefix gives 14 chars, making hexdigest have the longest
# HASH method qualname. extra144 anchors HASH.hexdigest qualname length; no prior
# hashlib spec anchors HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest') as a
# standalone under hashmeth151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra151.HASH_hexdigest_qualname_eq:
  description: "hashlib._hashlib.HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — 'HASH.hexdigest' (14 chars = 5-char 'HASH.' + 9-char 'hexdigest'); returns hash as lowercase hex string; longest HASH method qualname (copy=9 < update=digest=11 < hexdigest=14); method_descriptor; extra144 anchors length; no prior hashlib spec anchors this as a standalone; first standalone under hashmeth151"
  category: qualname_identity
  kind: python_call_eq
  function: "_hashlib.HASH.hexdigest.__qualname__.__eq__"
  args: ["HASH.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.copy.__qualname__.__eq__('HASH.copy') — standalone
#
# hashlib._hashlib.HASH.copy.__qualname__ is 'HASH.copy' (9 chars). The copy method
# returns a copy of the HASH object — a new HASH with the same accumulated state as
# the original. This is useful for computing the final digest from an intermediate
# state while continuing to update the original. 'copy' (4 chars) is the shortest
# method name of the four HASH methods, giving the shortest qualname (9 chars).
# No prior hashlib spec anchors HASH.copy.__qualname__.__eq__('HASH.copy') as a
# standalone under hashmeth151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra151.HASH_copy_qualname_eq:
  description: "hashlib._hashlib.HASH.copy.__qualname__.__eq__('HASH.copy') == True — 'HASH.copy' (9 chars = 5-char 'HASH.' + 4-char 'copy'); returns a copy of HASH with the same accumulated state; shortest HASH method qualname (copy=9 < update=digest=11 < hexdigest=14); method_descriptor; no prior hashlib spec anchors this as a standalone; first standalone under hashmeth151"
  category: qualname_identity
  kind: python_call_eq
  function: "_hashlib.HASH.copy.__qualname__.__eq__"
  args: ["HASH.copy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# hashlib._hashlib.HASH.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# All C extension type class dicts are exposed as mappingproxy objects — a read-only
# proxy over the underlying C dict. This matches the behavior of Python-defined classes:
# both expose their class __dict__ as a mappingproxy. Contrasting with the module-level
# dicts: hashlib.__dict__ (plain 'dict', 4 chars) and hashlib._hashlib.__dict__ (also
# plain 'dict'). The HASH class dict mappingproxy (12 chars) ties in length with
# uuid.UUID.__dict__.__class__.__name__ (also 'mappingproxy', 12 chars). No prior
# hashlib spec anchors HASH.__dict__.__class__.__name__.__eq__('mappingproxy') as a
# standalone under hashmeth151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra151.HASH_dict_mappingproxy:
  description: "hashlib._hashlib.HASH.__dict__.__class__.__name__.__eq__('mappingproxy') == True — 'mappingproxy' (12 chars); C extension types expose class __dict__ as mappingproxy (read-only); hashlib.__dict__ and _hashlib.__dict__ are plain 'dict'; ties with uuid.UUID.__dict__.__class__.__name__ (also 'mappingproxy'); no prior hashlib spec anchors this as a standalone; first standalone under hashmeth151"
  category: identity
  kind: python_call_eq
  function: "_hashlib.HASH.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__dict__.__len__()==10 — standalone
#
# hashlib._hashlib.HASH.__dict__.__len__() is 10. The 10 entries are: __repr__,
# update, digest, hexdigest, copy (5 method_descriptors), digest_size, block_size,
# name (3 attribute descriptors), __doc__ (str), __module__ (str). Comparing HASH
# dict sizes with related classes: HASH (10) < struct.Struct (16) < socket.socket (28)
# << uuid.UUID (37). The compact 10-entry dict reflects that HASH is a minimal C
# extension type exposing only the methods and attributes needed for hashing.
# No prior hashlib spec anchors HASH.__dict__.__len__()==10 as a standalone under
# hashmeth151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra151.HASH_dict_len_10:
  description: "hashlib._hashlib.HASH.__dict__.__len__() == 10 — 10 entries: 5 method_descriptors (__repr__/update/digest/hexdigest/copy) + 3 attr descriptors (digest_size/block_size/name) + __doc__ + __module__; compact C extension type: HASH(10) < Struct(16) < socket.socket(28) << UUID(37); no prior hashlib spec anchors this as a standalone; first standalone under hashmeth151"
  category: identity
  kind: python_call_eq
  function: "_hashlib.HASH.__dict__.__len__"
  args: []
  expected: 10

