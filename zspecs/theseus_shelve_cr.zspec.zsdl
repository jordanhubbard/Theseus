spec: theseus_shelve_cr
version: ">=3.8"
backend: python_cleanroom(theseus_shelve_cr)
blocks: shelve

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shelve.html"
  not_derived_from:
    - "CPython source: Lib/shelve.py (internal implementation)"
  notes:
    - "Clean-room shelve module. Do NOT import shelve."
    - "open(filename): return a shelf object for persistent storage."
    - "Shelf maps string keys to arbitrary pickled values."

error_model: python_exceptions

invariant theseus_shelve_cr.shelve2_open_close:
  description: "open/set/get/close cycle works correctly"
  category: open
  kind: python_call_eq
  function: shelve2_open_close
  args: []
  expected: true

invariant theseus_shelve_cr.shelve2_keys:
  description: "keys() returns stored keys"
  category: keys
  kind: python_call_eq
  function: shelve2_keys
  args: []
  expected: true

invariant theseus_shelve_cr.shelve2_context_manager:
  description: "shelf works as context manager (with statement)"
  category: open
  kind: python_call_eq
  function: shelve2_context_manager
  args: []
  expected: true
