spec: struct_extra1321
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for struct types."
    - "struct.Struct is a C extension type; its __repr__ is a wrapper_descriptor at the type level."
    - "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor' (C-level slot)."
    - "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' (the C extension type defines its own __repr__)."
    - "struct.Struct.__str__ inherits from object: __qualname__ == 'object.__str__', class 'wrapper_descriptor'."
    - "struct.error is a Python exception class derived from Exception."
    - "struct.error.__repr__.__class__.__name__ == 'wrapper_descriptor' (inherits from BaseException.__repr__)."
    - "struct.error.__repr__.__qualname__ == 'BaseException.__repr__' (inherited C-level slot)."
    - "repr(struct.Struct).__class__.__name__ == 'str' — repr of class object always returns str."
    - "repr(struct.error).__class__.__name__ == 'str' — same for exception class object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1321.Struct_repr_descriptor_checks:
  description: "struct.Struct C extension type __repr__ and __str__: wrapper_descriptor class checks and qualname identity"
  kind: python_call_eq
  category: identity
  id_prefix: st1321sr
  columns: [id, function, args, expected]
  rows:
    - [st1321sr001, struct.Struct.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1321sr002, struct.Struct.__repr__.__qualname__.__eq__,       ["Struct.__repr__"],    true]
    - [st1321sr003, struct.Struct.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [st1321sr004, struct.Struct.__str__.__qualname__.__eq__,        ["object.__str__"],     true]
    - [st1321sr005, struct.Struct.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1321sr006, struct.Struct.__str__.__qualname__.__eq__,        ["object.__str__"],     true]

table struct_extra1321.error_repr_inheritance:
  description: "struct.error exception class __repr__ and __str__ inherited from BaseException: wrapper_descriptor checks"
  kind: python_call_eq
  category: identity
  id_prefix: st1321er
  columns: [id, function, args, expected]
  rows:
    - [st1321er001, struct.error.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"],      true]
    - [st1321er002, struct.error.__repr__.__qualname__.__eq__,       ["BaseException.__repr__"],  true]
    - [st1321er003, struct.error.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"],      true]
    - [st1321er004, struct.error.__str__.__qualname__.__eq__,        ["BaseException.__str__"],   true]
    - [st1321er005, struct.error.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"],      true]
    - [st1321er006, struct.error.__str__.__qualname__.__eq__,        ["BaseException.__str__"],   true]

table struct_extra1321.repr_of_class_objects_returns_str:
  description: "repr() called on struct class objects always returns a str instance"
  kind: python_call_eq
  category: identity
  id_prefix: st1321ro
  columns: [id, function, args, expected]
  rows:
    - [st1321ro001, repr(struct.Struct).__class__.__name__.__eq__,  ["str"], true]
    - [st1321ro002, repr(struct.error).__class__.__name__.__eq__,   ["str"], true]
    - [st1321ro003, struct.Struct.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1321ro004, struct.error.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [st1321ro005, struct.Struct.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [st1321ro006, struct.error.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
