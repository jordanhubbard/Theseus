# ---------------------------------------------------------------------------
# Table 4: combined __neg__/__pos__/__abs__ checks for ABCMeta and
#          abstractproperty
#
# Wave 628 theme: ABCMeta is a metaclass that enforces abstract method
# contracts; abstractproperty is a deprecated decorator combining
# abstractmethod and property. Neither construct participates in numeric
# protocols, so all three unary arithmetic dunder methods are absent from
# their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2716.abcmeta_abstractproperty_unary:
  description: "abc.ABCMeta and abc.abstractproperty combined __neg__/__pos__/__abs__ dict-presence checks — metaclass and deprecated decorator define no unary arithmetic"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2716

  columns: [id, function, args, expected]
  rows:
    - ["ab2716013", "abc.ABCMeta.__dict__.__contains__",          ["__neg__"], false]
    - ["ab2716014", "abc.ABCMeta.__dict__.__contains__",          ["__pos__"], false]
    - ["ab2716015", "abc.ABCMeta.__dict__.__contains__",          ["__abs__"], false]
    - ["ab2716016", "abc.abstractproperty.__dict__.__contains__", ["__neg__"], false]
    - ["ab2716017", "abc.abstractproperty.__dict__.__contains__", ["__pos__"], false]
    - ["ab2716018", "abc.abstractproperty.__dict__.__contains__", ["__abs__"], false]
