spec: abc_extra2716
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 628 (_extra2716): __neg__, __pos__, __abs__ dict-presence checks (unary arithmetic operators)."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod and abc.abstractproperty are decorators."
    - "None of these abc constructs define unary minus, unary plus, or absolute value protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __neg__ dict-presence checks
#
# Wave 628 theme: abc module types do not implement the unary minus operator.
# __neg__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2716.neg_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __neg__ dict-presence checks — none define unary minus in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2716

  columns: [id, function, args, expected]
  rows:
    - ["ab2716001", "abc.ABCMeta.__dict__.__contains__",          ["__neg__"], false]
    - ["ab2716002", "abc.ABC.__dict__.__contains__",              ["__neg__"], false]
    - ["ab2716003", "abc.abstractmethod.__dict__.__contains__",   ["__neg__"], false]
    - ["ab2716004", "abc.abstractproperty.__dict__.__contains__", ["__neg__"], false]

