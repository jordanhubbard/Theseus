# ---------------------------------------------------------------------------

table abc_extra2716.abs_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __abs__ dict-presence checks — none define absolute value in own __dict__"
