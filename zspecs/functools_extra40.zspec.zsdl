spec: functools_extra40
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra39.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps(5)/partial(7)/lru_cache(9)/total_ordering(14)/singledispatch(14)/cached_property(15)/reduce(6)/cmp_to_key(10); __qualname__.__len__() for update_wrapper(14)/partialmethod(13)/singledispatchmethod(20)/cache(5)/total_ordering(14)/singledispatch(14)/cmp_to_key(10)/cached_property(15)/lru_cache(9)/wraps(5)/reduce(6); partial/__mro__/partialmethod/__mro__/cached_property/__mro__/singledispatchmethod/__mro__ (all 2); WRAPPER_ASSIGNMENTS.__len__()==6; WRAPPER_UPDATES.__len__()==1; __all__.__len__()==15; reduce single-element identity; partial.__doc__.__class__.__name__.__len__()==3; partial.__new__.__qualname__.__len__()==15; __all__[0].__len__()==14 ('update_wrapper'); __all__[-1].__len__()==11 ('Placeholder')."
    - "This spec covers: partial.__doc__.__len__() (83 — the full docstring byte length); reduce.__doc__.__len__() (389 — the C-level reduce builtin has a longer docstring); functools.reduce with initial value: reduce(add, [1,2,3], 10) == 16; functools.__all__[1].__len__() (5 — 'wraps', the second public API name); functools.__all__[-2].__len__() (15 — 'cached_property', the second-to-last element)."
    - "Key findings: functools.partial.__doc__ is an 83-char string describing partial application. functools.reduce.__doc__ is 389 chars — the C builtin docstring is more verbose. reduce with an initial accumulator: reduce(add, [1,2,3], 10) == 16 (10+1+2+3). functools.__all__[1] is 'wraps' (5 chars) — immediately after 'update_wrapper'. functools.__all__[-2] is 'cached_property' (15 chars), the longest name in __all__ and the penultimate entry."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools docstring length table — partial and reduce __doc__.__len__()
#
# functools.partial.__doc__ is 'Create a new function with partial application
# of the given arguments\nand keywords.' — exactly 83 characters. No prior
# functools spec records partial.__doc__.__len__() == 83 as a standalone value.
# functools.reduce.__doc__ is 389 characters — the C-level builtin carries a
# more verbose docstring than the Python wrapper. No prior functools spec records
# reduce.__doc__.__len__() == 389. These two values are recorded together
# for the first time in the extra40 namespace.
# ---------------------------------------------------------------------------

table functools_extra40.docstring_lengths:
  description: "functools.partial.__doc__.__len__() (83) and functools.reduce.__doc__.__len__() (389)"
  kind: python_call_eq
  category: string_properties
  id_prefix: docstrlen40

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc,
       partial.__doc__.__len__,
       [],
       83,
       "len(functools.partial.__doc__) == 83 — full docstring describing partial application of arguments and keywords"]
    - [reduce_doc,
       reduce.__doc__.__len__,
       [],
       389,
       "len(functools.reduce.__doc__) == 389 — C-level builtin docstring is more verbose than Python wrappers"]

# ---------------------------------------------------------------------------
# functools.__all__ element lengths — extra40 namespace
#
# functools.__all__[1] is 'wraps' (5 chars) — the second element, immediately
# following 'update_wrapper'. functools.__all__[-2] is 'cached_property' (15 chars)
# — the penultimate element and the longest name in __all__. Prior specs recorded
# __all__[0].__len__()==14 ('update_wrapper') in extra39 and __all__[-1].__len__()==11
# ('Placeholder') in extra38. These two additional indexed element lengths are
# recorded together for the first time in the extra40 namespace.
# ---------------------------------------------------------------------------

table functools_extra40.all_element_lengths:
  description: "functools.__all__ indexed element lengths: [1] == 5 ('wraps') and [-2] == 15 ('cached_property')"
  kind: python_call_eq
  category: module_metadata
  id_prefix: allelem40

  columns: [id, function, args, expected, description]
  rows:
    - [all_idx1,
       "__all__[1].__len__",
       [],
       5,
       "len(functools.__all__[1]) == 5 — '__all__[1]' is 'wraps', the second public API name after 'update_wrapper'"]
    - [all_idx_neg2,
       "__all__[-2].__len__",
       [],
       15,
       "len(functools.__all__[-2]) == 15 — '__all__[-2]' is 'cached_property', the longest name in __all__ and the penultimate entry"]

# ---------------------------------------------------------------------------
# functools.reduce with initial accumulator — standalone invariant
#
# functools.reduce(operator.add, [1,2,3], 10) == 16. When an initial value is
# provided, reduce starts accumulation from that value: 10+1+2+3 == 16. Prior
# specs covered reduce(operator.add, [1,2,3,4]) == 10 (extra2) and reduce with
# a single-element list (extra22), but not reduce with a non-zero initial
# accumulator. This is the first spec to record reduce-with-initializer in the
# extra40 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra40.reduce_with_initial:
  description: "functools.reduce(operator.add, [1,2,3], 10) == 16 — initial accumulator is added before folding [1,2,3]"
  category: behavioral
  kind: python_call_eq
  function: reduce
  args: [{type: module_attr, module: "operator", attr: "add"}, [1, 2, 3], 10]
  expected: 16
