spec: struct_extra97
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra96

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra96.zspec.zsdl — covers struct.Struct method __name__.__len__() / module-level function __name__.__len__() / Struct and error __name__.__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') for all six functions (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth and entry names / module-level function __qualname__.__len__() for pack/unpack/calcsize (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra96; it does NOT duplicate invariants present in those files."
    - "Wave 264 theme: struct module __spec__ and __loader__ attribute lengths + sub-component __module__ lengths."
    - "struct.__name__.__len__() == 6 ('struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name.__len__() == 6 ('struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.has_location == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name.__eq__('struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__.__len__() == 7 ('_struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__.__len__() == 7 ('_struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__len__() == 6 ('struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__loader__.__class__.__name__ is 'SourceFileLoader' even though _struct is a C extension — struct has a thin Python wrapper in Lib/struct.py which is what the loader loads."
    - "Note: struct.pack/__module__ is '_struct' (7 chars) because pack is implemented in the C extension; struct.error/__module__ is 'struct' (6 chars) because error is defined in the Python wrapper."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__name__.__len__()==6
# struct.__spec__.name.__len__()==6
# struct.__spec__.__class__.__name__.__len__()==10
# struct.__loader__.__class__.__name__.__len__()==16
#
# Wave 264 theme: struct module attribute name lengths.
#
# struct.__name__ is 'struct' (6 chars). __spec__.name is also 'struct' (6),
# confirming the spec's canonical name matches __name__. __spec__.__class__.__name__
# is 'ModuleSpec' (10 chars). __loader__.__class__.__name__ is 'SourceFileLoader'
# (16 chars). Even though struct uses C extensions (_struct), the Python wrapper
# in Lib/struct.py is what the SourceFileLoader loads. struct_extra93 anchors
# Struct.__module__/__qualname__; no prior spec anchors __len__() for the top-level
# module attrs under structmodlen97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra97.struct_module_attr_name_lengths:
  description: "struct.__name__/__len__()==6 / __spec__.name/__len__()==6 / __spec__/__class__.__name__/__len__()==10 / __loader__/__class__.__name__/__len__()==16 — __name__ and __spec__.name share length 6; 'ModuleSpec' is 10 chars; 'SourceFileLoader' is 16 chars; SourceFileLoader loads Lib/struct.py even though _struct is a C extension; first structmodlen97 anchor for module attribute name lengths"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmodlen97

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,              __name__.__len__,                       [], 6,  "'struct' is 6 chars"]
    - [spec_name_len,         __spec__.name.__len__,                  [], 6,  "__spec__.name is 'struct', also 6 chars"]
    - [spec_class_name_len,   __spec__.__class__.__name__.__len__,    [], 10, "'ModuleSpec' is 10 chars"]
    - [loader_class_name_len, __loader__.__class__.__name__.__len__,  [], 16, "'SourceFileLoader' is 16 chars"]

# ---------------------------------------------------------------------------
# struct.__spec__.has_location == True
# struct.__spec__.name.__eq__('struct')
#
# Wave 264 theme: struct __spec__ location and name equality.
#
# struct.__spec__.has_location is True because struct's spec refers to Lib/struct.py
# (the Python wrapper), which has a known file-system path. __spec__.name is 'struct',
# matching __name__. struct_extra93 anchors Struct.__module__.__eq__('_struct');
# no prior spec anchors has_location or __spec__.name equality under structmodlen97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra97.struct_spec_location_and_name:
  description: "struct.__spec__.has_location==True / __spec__.name/__eq__('struct')==True — has_location is True because Lib/struct.py has a known file-system path; __spec__.name equals __name__ (both 'struct'); extra93 anchors Struct.__module__.__eq__('_struct'); first structmodlen97 anchor for has_location and __spec__.name equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmodlen97

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location, __spec__.has_location.__eq__, [true],      true, "has_location is True: Lib/struct.py has a known file-system path"]
    - [spec_name_eq,      __spec__.name.__eq__,         ["struct"],  true, "__spec__.name is 'struct', equal to __name__"]

# ---------------------------------------------------------------------------
# struct.pack.__module__.__len__()==7
# struct.Struct.__module__.__len__()==7
# struct.error.__module__.__len__()==6
#
# Wave 264 theme: struct sub-component __module__ string lengths.
#
# struct.pack.__module__ is '_struct' (7 chars): underscore + 'struct' = 7.
# struct.Struct.__module__ is '_struct' (7 chars): same C extension.
# struct.error.__module__ is 'struct' (6 chars): error is defined in the Python
# wrapper (Lib/struct.py), not in the C extension, so its __module__ is 'struct'.
# struct_extra95 anchors pack/Struct/unpack/etc __module__.__eq__('_struct');
# struct_extra93 anchors error.__module__.__eq__('struct'); no prior spec anchors
# __module__.__len__() for these under structmodlen97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra97.struct_subcomponent_module_lengths:
  description: "struct.pack/__module__/__len__()==7 / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 — '_struct' is 7 chars (C extension); 'struct' is 6 chars (Python wrapper); pack and Struct share __module__=='_struct' (7); error.__module__=='struct' (6) because error is defined in the Python wrapper; extra95 anchors pack/Struct __module__.__eq__('_struct'); extra93 anchors error.__module__.__eq__('struct'); first structmodlen97 anchor for sub-component __module__ lengths"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmodlen97

  columns: [id, function, args, expected, description]
  rows:
    - [pack_module_len,   pack.__module__.__len__,   [], 7, "'_struct' is 7 chars (C extension; pack is implemented in _struct)"]
    - [Struct_module_len, Struct.__module__.__len__, [], 7, "'_struct' is 7 chars (C extension; Struct class is from _struct)"]
    - [error_module_len,  error.__module__.__len__,  [], 6, "'struct' is 6 chars (Python wrapper; error is defined in Lib/struct.py)"]

# ---------------------------------------------------------------------------
# struct.__spec__.name.__len__()==6 — standalone
#
# struct.__spec__.name.__len__() is 6. __spec__.name is 'struct', the canonical
# dotted name used by importlib to identify the module. For top-level modules this
# equals __name__. Both are 6 chars. struct_extra93 anchors Struct.__module__
# .__eq__('_struct') and Struct.__qualname__.__eq__('Struct'); no prior spec
# anchors __spec__.name.__len__()==6 as a standalone under structmodlen97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra97.spec_name_len_6:
  description: "struct.__spec__.name.__len__() == 6 — __spec__.name is 'struct' (6 chars); canonical importlib module name equals __name__; both are 6 chars; extra93 anchors Struct.__module__.__eq__('_struct'); first standalone for __spec__.name.__len__() under structmodlen97"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.__spec__.has_location == True — standalone
#
# struct.__spec__.has_location is True. struct's spec refers to Lib/struct.py,
# the Python-level wrapper module that re-exports the _struct C extension's
# contents. Because this wrapper is a source file, the spec has a file-system
# origin and has_location is True. struct_extra93 anchors Struct.__bases__ and
# __mro__.__len__(); no prior spec anchors has_location as a standalone under
# structmodlen97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra97.spec_has_location_true:
  description: "struct.__spec__.has_location.__eq__(True) == True — has_location is True because Lib/struct.py (the Python wrapper) has a known file-system path; struct uses a thin Python wrapper over the _struct C extension; extra93 anchors Struct.__bases__ and __mro__; first standalone for has_location under structmodlen97"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__len__()==6 — standalone
#
# struct.error.__module__.__len__() is 6. error.__module__ is 'struct' (6 chars).
# struct.error is defined in the Python wrapper (Lib/struct.py), not in the C
# extension (_struct). This makes error.__module__ equal to 'struct' (6 chars)
# rather than '_struct' (7 chars). This contrasts with struct.pack and struct.Struct,
# which have __module__=='_struct' (7 chars). struct_extra93 anchors
# error.__module__.__eq__('struct'); no prior spec anchors error.__module__.__len__()
# ==6 as a standalone under structmodlen97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra97.error_module_len_6:
  description: "struct.error.__module__.__len__() == 6 — error.__module__ is 'struct' (6 chars); error is defined in Lib/struct.py (not _struct C extension), giving it __module__=='struct' vs pack/Struct __module__=='_struct' (7 chars); extra93 anchors error.__module__.__eq__('struct'); first standalone for error.__module__.__len__() under structmodlen97"
  category: module_identity
  kind: python_call_eq
  function: error.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__len__()==16 — standalone
#
# struct.__loader__.__class__.__name__.__len__() is 16. The class name is
# 'SourceFileLoader' — 16 characters. Although struct internally uses the
# _struct C extension, the module that Python loads is Lib/struct.py, a
# Python source file. So the loader is SourceFileLoader (not ExtensionFileLoader).
# struct_extra93 anchors Struct.__module__.__eq__('_struct'); no prior spec
# anchors __loader__.__class__.__name__.__len__()==16 as a standalone under
# structmodlen97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra97.loader_class_name_len_16:
  description: "struct.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' is 16 chars; Python loads Lib/struct.py (a source file), not _struct directly, so the loader is SourceFileLoader (not ExtensionFileLoader); extra93 anchors Struct.__module__.__eq__('_struct'); first standalone for __loader__.__class__.__name__.__len__() under structmodlen97"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16
