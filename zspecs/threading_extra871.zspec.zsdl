spec: threading_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "threading standard library module"
    - "CPython runtime class type identity inspection"
  not_derived_from:
    - "concurrent.futures or multiprocessing"
    - "any third-party threading wrappers"
  notes:
    - "Covers class type identity checks verifying threading primitives are proper types"
    - "Module-level attribute checks mirror pattern used in functools_extra871 and itertools_extra871"
    - "current_thread code object check confirms it is a pure Python function not a C builtin"
  created_at: "2026-04-12"

table threading_extra871.class_type_identity:
  description: "threading class type identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: th871xx
  columns: [id, function, args, expected]
  rows:
    - [th871xx001, threading.Thread.__class__.__name__.__eq__, ["type"], true]
    - [th871xx002, threading.Semaphore.__class__.__name__.__eq__, ["type"], true]
    - [th871xx003, threading.Event.__class__.__name__.__eq__, ["type"], true]
    - [th871xx004, threading.Condition.__class__.__name__.__eq__, ["type"], true]
    - [th871xx005, threading.Barrier.__class__.__name__.__eq__, ["type"], true]
    - [th871xx006, threading.Timer.__class__.__name__.__eq__, ["type"], true]
    - [th871xx007, threading.local.__class__.__name__.__eq__, ["type"], true]
    - [th871xx008, threading.__name__.__eq__, ["threading"], true]
    - [th871xx009, threading.__package__.__eq__, ["threading"], true]
    - [th871xx010, threading.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [th871xx011, threading.__all__.__class__.__name__.__eq__, ["list"], true]
    - [th871xx012, threading.current_thread.__code__.__class__.__name__.__eq__, ["code"], true]
