spec: pathlib_extra2506
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers class names, suffix/stem, is_absolute, parents, drive, root"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence for pathlib classes."
    - "Checks whether pathlib.PurePath, PurePosixPath, PureWindowsPath, and Path define arithmetic operators."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ for the / path-join operator — these ARE in __dict__."
    - "pathlib.PurePath does NOT define __add__, __sub__, or __mul__ — only the / operator is overloaded."
    - "pathlib.PurePosixPath and PureWindowsPath inherit __truediv__ and __rtruediv__ from PurePath; neither adds arithmetic operators in their own __dict__."
    - "pathlib.Path inherits path-join from PurePath; Path.__dict__ also contains no __truediv__, __rtruediv__, __add__, __sub__, or __mul__."
    - "The contrast between __truediv__ (True on PurePath) and __add__/__sub__/__mul__ (False on PurePath) is the key insight: path join is spelled with /, not +."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath — __truediv__ present, __add__/__sub__/__mul__ absent
#
# PurePath overloads / for path joining via __truediv__ and __rtruediv__.
# It does NOT define arithmetic operators +, -, or *.
# This contrast confirms that the / overload is path-specific, not numeric.
# ---------------------------------------------------------------------------

table pathlib_extra2506.purepath_arith_vs_truediv:
  description: "PurePath defines __truediv__/__rtruediv__ but NOT __add__/__sub__/__mul__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: pp2506

  columns: [id, function, args, expected]
  rows:
    - ["pp2506-001", "PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2506-002", "PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2506-003", "PurePath.__dict__.__contains__", ["__add__"],      false]
    - ["pp2506-004", "PurePath.__dict__.__contains__", ["__sub__"],      false]
    - ["pp2506-005", "PurePath.__dict__.__contains__", ["__mul__"],      false]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PurePosixPath and PureWindowsPath — no arithmetic operators
#
# These concrete pure-path subclasses add OS-specific behaviour but inherit
# __truediv__ and __rtruediv__ from PurePath; their own __dict__ defines
# neither the path-join operators nor any arithmetic operators.
# ---------------------------------------------------------------------------

table pathlib_extra2506.concrete_pure_paths_arith:
  description: "__add__, __sub__, __mul__, __truediv__ absent from PurePosixPath and PureWindowsPath __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: pp2506

  columns: [id, function, args, expected]
  rows:
    - ["pp2506-006", "PurePosixPath.__dict__.__contains__",   ["__add__"],      false]
    - ["pp2506-007", "PurePosixPath.__dict__.__contains__",   ["__sub__"],      false]
    - ["pp2506-008", "PurePosixPath.__dict__.__contains__",   ["__mul__"],      false]
    - ["pp2506-009", "PurePosixPath.__dict__.__contains__",   ["__truediv__"],  false]
    - ["pp2506-010", "PureWindowsPath.__dict__.__contains__", ["__add__"],      false]
    - ["pp2506-011", "PureWindowsPath.__dict__.__contains__", ["__sub__"],      false]
    - ["pp2506-012", "PureWindowsPath.__dict__.__contains__", ["__mul__"],      false]
    - ["pp2506-013", "PureWindowsPath.__dict__.__contains__", ["__truediv__"],  false]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path — no arithmetic operators, no __truediv__ in own dict
#
# Path is the concrete filesystem-backed subclass. Its own __dict__ adds
# filesystem methods (open, stat, mkdir, etc.) but inherits path-join from
# PurePath. No arithmetic operators appear in Path.__dict__ either.
# Positive anchors verify __dict__.__contains__ works on PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra2506.path_arith_and_anchors:
  description: "__add__, __sub__, __mul__ absent from Path; PurePath.__init__ and __hash__ present as anchors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: pp2506

  columns: [id, function, args, expected]
  rows:
    - ["pp2506-014", "Path.__dict__.__contains__",     ["__add__"],    false]
    - ["pp2506-015", "Path.__dict__.__contains__",     ["__sub__"],    false]
    - ["pp2506-016", "Path.__dict__.__contains__",     ["__mul__"],    false]
    - ["pp2506-017", "Path.__dict__.__contains__",     ["__truediv__"], false]
    - ["pp2506-018", "PurePath.__dict__.__contains__", ["__init__"],   true]
    - ["pp2506-019", "PurePath.__dict__.__contains__", ["__hash__"],   true]
    - ["pp2506-020", "PurePath.__dict__.__contains__", ["__str__"],    true]
