spec: queue
version: ">=3.0"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/queue.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "queue source: internal lock and condition variable implementation"
  notes:
    - "Queue(maxsize) stores items up to maxsize; 0 or negative maxsize means unbounded."
    - "Queue.get_nowait() raises queue.Empty if the queue is empty (does not block)."
    - "Queue.put_nowait() raises queue.Full if the queue is full (does not block)."
    - "LifoQueue is a stack (last-in, first-out); PriorityQueue returns lowest-priority item first."
    - "SimpleQueue is a simplified thread-safe FIFO queue without maxsize, task_done, or join."
    - "queue.Empty and queue.Full both inherit directly from Exception."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

table queue.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [queue_cls,      Queue.__name__.__eq__,       ["Queue"],       true]
    - [lifoqueue,      LifoQueue.__name__.__eq__,   ["LifoQueue"],   true]
    - [priorityqueue,  PriorityQueue.__name__.__eq__, ["PriorityQueue"], true]
    - [simplequeue,    SimpleQueue.__name__.__eq__,  ["SimpleQueue"], true]
    - [empty_exc,      Empty.__name__.__eq__,        ["Empty"],       true]
    - [full_exc,       Full.__name__.__eq__,         ["Full"],        true]

# ---------------------------------------------------------------------------
# Queue(maxsize) — maxsize attribute reflects constructor argument
# ---------------------------------------------------------------------------

invariant queue.queue_maxsize:
  description: "queue.Queue(3).maxsize == 3"
  category: queue_attrs
  kind: python_call_eq
  function: Queue
  args: [3]
  method: maxsize
  expected: 3

# ---------------------------------------------------------------------------
# Queue() initial state — empty, not full, size zero
# ---------------------------------------------------------------------------

invariant queue.queue_qsize_empty:
  description: "queue.Queue().qsize() == 0 — a new queue has no items"
  category: queue_state
  kind: python_call_eq
  function: Queue
  args: []
  method: qsize
  method_args: []
  expected: 0

invariant queue.queue_empty_true:
  description: "queue.Queue().empty() == True — a new queue is empty"
  category: queue_state
  kind: python_call_eq
  function: Queue
  args: []
  method: empty
  method_args: []
  expected: true

invariant queue.queue_full_false:
  description: "queue.Queue(1).full() == False — an empty bounded queue is not full"
  category: queue_state
  kind: python_call_eq
  function: Queue
  args: [1]
  method: full
  method_args: []
  expected: false

# ---------------------------------------------------------------------------
# Queue.get_nowait() — raises Empty when queue is empty
# ---------------------------------------------------------------------------

invariant queue.get_nowait_raises_empty:
  description: "queue.Queue().get_nowait() raises queue.Empty"
  category: exceptions
  kind: python_call_raises
  function: Queue
  args: []
  method: get_nowait
  method_args: []
  exception: Empty

# ---------------------------------------------------------------------------
# SimpleQueue — initial state is empty
# ---------------------------------------------------------------------------

invariant queue.simplequeue_empty:
  description: "queue.SimpleQueue().empty() == True — a new SimpleQueue has no items"
  category: queue_state
  kind: python_call_eq
  function: SimpleQueue
  args: []
  method: empty
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# PriorityQueue — initial state is empty
# ---------------------------------------------------------------------------

invariant queue.priorityqueue_empty:
  description: "queue.PriorityQueue().empty() == True — a new PriorityQueue has no items"
  category: queue_state
  kind: python_call_eq
  function: PriorityQueue
  args: []
  method: empty
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# LifoQueue — initial state is empty
# ---------------------------------------------------------------------------

invariant queue.lifoqueue_empty:
  description: "queue.LifoQueue().empty() == True — a new LifoQueue has no items"
  category: queue_state
  kind: python_call_eq
  function: LifoQueue
  args: []
  method: empty
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — Empty and Full both inherit from Exception
# ---------------------------------------------------------------------------

invariant queue.empty_base_is_exception:
  description: "queue.Empty.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Empty.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant queue.full_base_is_exception:
  description: "queue.Full.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Full.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true
