spec: zipfile_extra6
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl and prior extras."
    - "zipfile.ZipFile.__name__ == 'ZipFile' — table form with new id_prefix zn6."
    - "zipfile.ZipInfo.__name__ == 'ZipInfo' — in table form."
    - "zipfile.BadZipFile.__name__ == 'BadZipFile' — in table form."
    - "zipfile.ZipFile.__module__ == 'zipfile' — standalone invariant (distinct from prior table forms in extra3/extra4)."
    - "zipfile.ZipFile.__qualname__ == 'ZipFile' — covered in zipfile_extra5; this is a standalone invariant form."
    - "zipfile.ZipInfo.__qualname__ == 'ZipInfo' — covered in zipfile_extra5 table; this is a standalone invariant form."
    - "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception' — bool form (__eq__ returning true) vs zipfile_extra string form."
    - "zipfile_extra covers: ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path __name__ invariants, ZipFile.__module__, BadZipFile base string form, is_zipfile __name__, all ZIP_* class and value checks."
    - "zipfile_extra5 covers: ZipFile/ZipInfo/Path/BadZipFile/LargeZipFile __qualname__ table, is_zipfile __qualname__, LargeZipFile/Path/is_zipfile __module__, ZIP_BZIP2/ZIP_LZMA class names."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — table form with new id_prefix zn6
# zipfile_extra used standalone invariants; zipfile_extra2/extra4 used tables
# with different id_prefixes. This is a fresh table grouping the three focus classes.
# ---------------------------------------------------------------------------

table zipfile_extra6.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: zn6

  columns: [id, function, args, expected]
  rows:
    - [ZipFile,    ZipFile.__name__.__eq__,    ["ZipFile"],    true]
    - [ZipInfo,    ZipInfo.__name__.__eq__,    ["ZipInfo"],    true]
    - [BadZipFile, BadZipFile.__name__.__eq__, ["BadZipFile"], true]

# ---------------------------------------------------------------------------
# ZipFile.__module__ — standalone invariant form
# zipfile_extra has a standalone invariant; zipfile_extra3 has a table;
# zipfile_extra4 has a standalone invariant.
# This is a distinct cross-check invariant with a new name.
# ---------------------------------------------------------------------------

invariant zipfile_extra6.ZipFile.module_check:
  description: "zipfile.ZipFile.__module__ == 'zipfile' — ZipFile is defined in the zipfile module"
  category: module
  kind: python_call_eq
  function: ZipFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# ZipInfo.__module__ — standalone invariant
# zipfile_extra3 covers ZipInfo.__module__ in a table; this is standalone.
# ---------------------------------------------------------------------------

invariant zipfile_extra6.ZipInfo.module_check:
  description: "zipfile.ZipInfo.__module__ == 'zipfile' — ZipInfo is defined in the zipfile module"
  category: module
  kind: python_call_eq
  function: ZipInfo.__module__.__eq__
  args: ["zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# ZipFile.__qualname__ — standalone invariant form
# zipfile_extra5 covers this in a table row (ZipFile.__qualname__.__eq__).
# This is an equivalent standalone invariant for cross-validation.
# ---------------------------------------------------------------------------

invariant zipfile_extra6.ZipFile.qualname_eq:
  description: "zipfile.ZipFile.__qualname__ == 'ZipFile' — top-level class qualname equals its name"
  category: qualnames
  kind: python_call_eq
  function: ZipFile.__qualname__.__eq__
  args: ["ZipFile"]
  expected: true

# ---------------------------------------------------------------------------
# ZipInfo.__qualname__ — standalone invariant form
# zipfile_extra5 covers this in a table row.
# ---------------------------------------------------------------------------

invariant zipfile_extra6.ZipInfo.qualname_eq:
  description: "zipfile.ZipInfo.__qualname__ == 'ZipInfo' — top-level class qualname equals its name"
  category: qualnames
  kind: python_call_eq
  function: ZipInfo.__qualname__.__eq__
  args: ["ZipInfo"]
  expected: true

# ---------------------------------------------------------------------------
# BadZipFile base class — bool form via __eq__
# zipfile_extra covers: method: __name__, method_args: [], expected: "Exception"
# (returns the string directly).
# This is a distinct form: method: __name__.__eq__, method_args: ["Exception"],
# expected: true  (returns bool).
# ---------------------------------------------------------------------------

invariant zipfile_extra6.BadZipFile.base_name_bool:
  description: "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception' — BadZipFile inherits directly from Exception"
  category: hierarchy
  kind: python_call_eq
  function: BadZipFile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true
