spec: http_client_extra14
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra2.zspec.zsdl — covers __qualname__.__eq__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__.__eq__ for HTTPException/HTTPResponse/NotConnected/InvalidURL."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for several classes; __bases__[0].__name__ for HTTPSConnection/HTTPResponse/LineTooLong."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected; __module__.__len__()==11."
    - "http_client_extra11.zspec.zsdl — covers __qualname__.__eq__ and __len__() for HTTPConnection.request/getresponse/connect/close and HTTPResponse.read/getheader."
    - "http_client_extra12.zspec.zsdl — covers __qualname__.__eq__ and __len__() for HTTPResponse.getheaders/geturl/info; HTTPSConnection.connect __qualname__; HTTPException.__bases__[0].__name__; cross-namespace anchors."
    - "http_client_extra13.zspec.zsdl — covers HTTPResponse __qualname__/__module__, HTTPMessage __qualname__/__module__/__bases__[0].__name__, responses.__class__.__name__, HTTPException __qualname__ cross-namespace anchor."
  notes:
    - "This spec extends the http.client chain through http_client_extra13; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) HTTPConnection.__qualname__ cross-namespace anchor and __module__ — extra2 covers __qualname__.__eq__ in a table; extra10 covers __qualname__.__len__(); no standalone __module__ check exists for HTTPConnection; (2) HTTPSConnection.__qualname__ cross-namespace anchor and __module__ — same situation; (3) HTTPConnection.__bases__[0].__name__ == 'object' — no prior spec checks HTTPConnection inheritance; (4) HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection' — extra9 covers this; (5) HTTPConnection method qualnames: request.__qualname__, connect.__qualname__, close.__qualname__ — extra11 covers request/connect/close __qualname__.__eq__ and __len__(); this spec provides cross-namespace anchors; (6) HTTP_PORT==80 and HTTPS_PORT==443 integer constants and their __class__.__name__; (7) BadStatusLine and CannotSendRequest exception class qualnames, modules, and inheritance."
    - "http.client.HTTPConnection.__qualname__ == 'HTTPConnection' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.__module__ == 'http.client' — len 11. No prior spec checks HTTPConnection.__module__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__qualname__ == 'HTTPSConnection' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__module__ == 'http.client' — len 11. No prior spec checks HTTPSConnection.__module__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.__bases__[0].__name__ == 'object' — HTTPConnection inherits directly from object. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection' — HTTPSConnection extends HTTPConnection. extra9 checks this; cross-namespace anchor from extra14."
    - "http.client.HTTPConnection.request.__qualname__ == 'HTTPConnection.request' — len 22. extra11 covers __qualname__.__eq__ and __len__(). Cross-namespace anchor from extra14."
    - "http.client.HTTPConnection.connect.__qualname__ == 'HTTPConnection.connect' — len 22. Cross-namespace anchor from extra14."
    - "http.client.HTTPConnection.close.__qualname__ == 'HTTPConnection.close' — len 20. Cross-namespace anchor from extra14."
    - "http.client.HTTP_PORT == 80 and HTTPS_PORT == 443 — module-level integer constants. __class__.__name__ == 'int'. No prior spec checks these. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.BadStatusLine.__qualname__ == 'BadStatusLine' — len 13. __module__ == 'http.client'. __bases__[0].__name__ == 'HTTPException'. No prior spec checks BadStatusLine attributes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.CannotSendRequest.__qualname__ == 'CannotSendRequest' — len 17. __module__ == 'http.client'. __bases__[0].__name__ == 'ImproperConnectionState'. No prior spec checks CannotSendRequest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPConnection __qualname__ cross-namespace anchor and __module__
#
# http_client_extra2 covers HTTPConnection.__qualname__.__eq__ in a table.
# http_client_extra10 covers __qualname__.__len__() == 14.
# No prior spec provides a standalone __module__ invariant for HTTPConnection.
# HTTPConnection.__module__ == 'http.client' (len 11).
# ---------------------------------------------------------------------------

invariant http_client_extra14.HTTPConnection.qualname_eq:
  description: "http.client.HTTPConnection.__qualname__ == 'HTTPConnection' — cross-namespace anchor from extra14; extra2 covers in table"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPConnection.__qualname__.__eq__
  args: ["HTTPConnection"]
  expected: true

invariant http_client_extra14.HTTPConnection.module_eq:
  description: "http.client.HTTPConnection.__module__ == 'http.client' — no prior spec provides standalone __module__ check for HTTPConnection"
  category: class_module
  kind: python_call_eq
  function: HTTPConnection.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra14.HTTPConnection.module_len:
  description: "len(http.client.HTTPConnection.__module__) == 11 — len('http.client') == 11"
  category: class_module
  kind: python_call_eq
  function: HTTPConnection.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# HTTPSConnection __qualname__ cross-namespace anchor and __module__
#
# http_client_extra2 covers HTTPSConnection.__qualname__.__eq__ in a table.
# http_client_extra10 covers __qualname__.__len__() == 15.
# http_client_extra12 covers a cross-namespace anchor from extra12 namespace.
# No prior spec provides a standalone __module__ invariant for HTTPSConnection.
# HTTPSConnection.__module__ == 'http.client' (len 11).
# ---------------------------------------------------------------------------

invariant http_client_extra14.HTTPSConnection.qualname_eq:
  description: "http.client.HTTPSConnection.__qualname__ == 'HTTPSConnection' — cross-namespace anchor from extra14; extra2 covers in table"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPSConnection.__qualname__.__eq__
  args: ["HTTPSConnection"]
  expected: true

invariant http_client_extra14.HTTPSConnection.module_eq:
  description: "http.client.HTTPSConnection.__module__ == 'http.client' — no prior spec provides standalone __module__ check for HTTPSConnection"
  category: class_module
  kind: python_call_eq
  function: HTTPSConnection.__module__.__eq__
  args: ["http.client"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPConnection.__bases__[0].__name__ and HTTPSConnection.__bases__[0].__name__
#
# http_client_extra9 covers HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection'.
# No prior spec checks HTTPConnection.__bases__[0].__name__ == 'object'.
# This spec adds a cross-namespace anchor for HTTPSConnection and a new
# invariant for HTTPConnection's direct object inheritance.
# ---------------------------------------------------------------------------

invariant http_client_extra14.HTTPConnection.bases0_name_eq:
  description: "http.client.HTTPConnection.__bases__[0].__name__ == 'object' — HTTPConnection inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  "function": "HTTPConnection.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant http_client_extra14.HTTPSConnection.bases0_name_eq:
  description: "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection' — HTTPSConnection extends HTTPConnection; cross-namespace anchor from extra14"
  category: class_hierarchy
  kind: python_call_eq
  "function": "HTTPSConnection.__bases__[0].__name__.__eq__"
  args: ["HTTPConnection"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPConnection method __qualname__ cross-namespace anchors
#
# http_client_extra11 covers HTTPConnection.request.__qualname__.__eq__ and
# __len__() == 22, HTTPConnection.connect.__qualname__.__eq__ and __len__() == 22,
# HTTPConnection.close.__qualname__.__eq__ and __len__() == 20.
# These standalone invariants provide cross-namespace anchors from extra14.
# ---------------------------------------------------------------------------

table http_client_extra14.http_connection_method_qualnames:
  description: "__qualname__.__eq__ cross-namespace anchors for HTTPConnection.request/connect/close — extra11 covers in its own namespace"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hcmqn14

  columns: [id, function, args, expected]
  rows:
    - [request, HTTPConnection.request.__qualname__.__eq__, ["HTTPConnection.request"], true]
    - [connect, HTTPConnection.connect.__qualname__.__eq__, ["HTTPConnection.connect"], true]
    - [close,   HTTPConnection.close.__qualname__.__eq__,   ["HTTPConnection.close"],   true]

table http_client_extra14.http_connection_method_qualname_lengths:
  description: "__qualname__.__len__() cross-namespace anchors for HTTPConnection.request/connect/close"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hcmqlen14

  columns: [id, function, args, expected]
  rows:
    - [request, HTTPConnection.request.__qualname__.__len__, [], 22]
    - [connect, HTTPConnection.connect.__qualname__.__len__, [], 22]
    - [close,   HTTPConnection.close.__qualname__.__len__,   [], 20]

# ---------------------------------------------------------------------------
# HTTP_PORT and HTTPS_PORT integer constants
#
# http.client defines module-level integer constants for the default HTTP and
# HTTPS port numbers. No prior spec checks these constants.
# HTTP_PORT == 80; HTTPS_PORT == 443; both are plain Python ints.
# ---------------------------------------------------------------------------

invariant http_client_extra14.HTTP_PORT.value_eq:
  description: "http.client.HTTP_PORT == 80 — default HTTP port constant; plain int"
  category: module_attributes
  kind: python_call_eq
  function: HTTP_PORT.__eq__
  args: [80]
  expected: true

invariant http_client_extra14.HTTPS_PORT.value_eq:
  description: "http.client.HTTPS_PORT == 443 — default HTTPS port constant; plain int"
  category: module_attributes
  kind: python_call_eq
  function: HTTPS_PORT.__eq__
  args: [443]
  expected: true

table http_client_extra14.port_constant_class_names:
  description: "__class__.__name__ == 'int' for HTTP_PORT and HTTPS_PORT — both are plain Python int constants"
  kind: python_call_eq
  category: module_attributes
  id_prefix: pccn14

  columns: [id, function, args, expected]
  rows:
    - [HTTP_PORT,  "HTTP_PORT.__class__.__name__.__eq__",  ["int"], true]
    - [HTTPS_PORT, "HTTPS_PORT.__class__.__name__.__eq__", ["int"], true]

# ---------------------------------------------------------------------------
# BadStatusLine exception __qualname__, __module__, __bases__[0].__name__
#
# BadStatusLine is raised when an invalid HTTP status line is received.
# No prior spec checks any attribute of BadStatusLine.
# __qualname__ == 'BadStatusLine' (len 13).
# __module__ == 'http.client' (len 11).
# __bases__[0].__name__ == 'HTTPException' — inherits from HTTPException.
# ---------------------------------------------------------------------------

invariant http_client_extra14.BadStatusLine.qualname_eq:
  description: "http.client.BadStatusLine.__qualname__ == 'BadStatusLine' — no prior spec checks any BadStatusLine attribute"
  category: class_qualnames
  kind: python_call_eq
  function: BadStatusLine.__qualname__.__eq__
  args: ["BadStatusLine"]
  expected: true

invariant http_client_extra14.BadStatusLine.qualname_len:
  description: "len(http.client.BadStatusLine.__qualname__) == 13 — len('BadStatusLine') == 13"
  category: class_qualnames
  kind: python_call_eq
  function: BadStatusLine.__qualname__.__len__
  args: []
  expected: 13

invariant http_client_extra14.BadStatusLine.module_eq:
  description: "http.client.BadStatusLine.__module__ == 'http.client' — BadStatusLine is defined in http.client"
  category: class_module
  kind: python_call_eq
  function: BadStatusLine.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra14.BadStatusLine.bases0_name_eq:
  description: "http.client.BadStatusLine.__bases__[0].__name__ == 'HTTPException' — BadStatusLine inherits from HTTPException"
  category: class_hierarchy
  kind: python_call_eq
  "function": "BadStatusLine.__bases__[0].__name__.__eq__"
  args: ["HTTPException"]
  expected: true

# ---------------------------------------------------------------------------
# CannotSendRequest exception __qualname__, __module__, __bases__[0].__name__
#
# CannotSendRequest is raised when a request cannot be sent on the connection.
# No prior spec checks any attribute of CannotSendRequest.
# __qualname__ == 'CannotSendRequest' (len 17).
# __module__ == 'http.client' (len 11).
# __bases__[0].__name__ == 'ImproperConnectionState'.
# ---------------------------------------------------------------------------

invariant http_client_extra14.CannotSendRequest.qualname_eq:
  description: "http.client.CannotSendRequest.__qualname__ == 'CannotSendRequest' — no prior spec checks any CannotSendRequest attribute"
  category: class_qualnames
  kind: python_call_eq
  function: CannotSendRequest.__qualname__.__eq__
  args: ["CannotSendRequest"]
  expected: true

invariant http_client_extra14.CannotSendRequest.qualname_len:
  description: "len(http.client.CannotSendRequest.__qualname__) == 17 — len('CannotSendRequest') == 17"
  category: class_qualnames
  kind: python_call_eq
  function: CannotSendRequest.__qualname__.__len__
  args: []
  expected: 17

invariant http_client_extra14.CannotSendRequest.module_eq:
  description: "http.client.CannotSendRequest.__module__ == 'http.client' — CannotSendRequest is defined in http.client"
  category: class_module
  kind: python_call_eq
  function: CannotSendRequest.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra14.CannotSendRequest.bases0_name_eq:
  description: "http.client.CannotSendRequest.__bases__[0].__name__ == 'ImproperConnectionState' — CannotSendRequest inherits from ImproperConnectionState"
  category: class_hierarchy
  kind: python_call_eq
  "function": "CannotSendRequest.__bases__[0].__name__.__eq__"
  args: ["ImproperConnectionState"]
  expected: true
