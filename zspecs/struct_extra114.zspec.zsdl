spec: struct_extra114
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra113.zspec.zsdl — covers Struct.size/format descriptor __objclass__.__module__, __class__.__module__, __class__.__name__ equality, lengths, and __doc__ equality (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__eq__ and pack/unpack/calcsize __qualname__.__eq__ / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra103.zspec.zsdl — covers struct.pack.__qualname__.__eq__('pack') and calcsize.__qualname__.__eq__('calcsize') as standalone invariants."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra113; it does NOT duplicate invariants present in those files."
    - "Wave 278 theme: struct module-level function __name__.__len__() and __class__.__module__ equality not yet covered as grouped tables — extra104 anchors __qualname__ eq; extra95 anchors qualname __len__; NOT YET covered: pack_into.__name__.__len__()==9, unpack_from.__name__.__len__()==11, iter_unpack.__name__.__len__()==11, pack_into.__class__.__module__.__eq__('builtins'), pack.__class__.__module__.__eq__('builtins')."
    - "struct.pack_into.__name__.__len__() == 9. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All struct module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) are builtin_function_or_method objects from the _struct C extension. Their __class__.__module__ is 'builtins' (the builtin_function_or_method type is a fundamental CPython runtime type defined in Objects/methodobject.c). Their __name__ equals their __qualname__ (no class prefix; they are module-level). __name__ lengths: 'pack'=4, 'calcsize'=8, 'pack_into'=9, 'unpack_from'=11, 'iter_unpack'=11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__len__() == 9
# struct.unpack_from.__name__.__len__() == 11
# struct.iter_unpack.__name__.__len__() == 11
# struct.calcsize.__name__.__len__() == 8
# struct.pack.__name__.__len__() == 4
#
# Wave 278 theme: struct module-level function __name__ lengths.
#
# struct_extra95 anchors __qualname__.__len__() for pack_into/unpack_from/iter_unpack
# (qualname==name for module-level C functions). No prior spec anchors these as
# explicit __name__.__len__() calls in a grouped table. 'pack' is shortest (4 chars);
# 'calcsize' is 8; 'pack_into' is 9; 'unpack_from' and 'iter_unpack' are both 11
# (tied for longest among module-level struct functions). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra114.struct_function_name_lengths:
  description: "pack_into.__name__.__len__()==9 / unpack_from.__name__.__len__()==11 / iter_unpack.__name__.__len__()==11 / calcsize.__name__.__len__()==8 / pack.__name__.__len__()==4 — 'pack'=4 (shortest); 'calcsize'=8; 'pack_into'=9; 'unpack_from'/'iter_unpack'=11 (tied longest); __name__==__qualname__ for C-level module functions; extra95 anchors qualname lengths; no prior spec anchors __name__.__len__() as explicit grouped table; first structfn114 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfn114

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name_len,    "pack_into.__name__.__len__",    [], 9,  "pack_into.__name__.__len__() is 9 (len('pack_into')==9; 'pack_'=5 + 'into'=4; writes packed data into buffer at offset)"]
    - [unpack_from_name_len,  "unpack_from.__name__.__len__",  [], 11, "unpack_from.__name__.__len__() is 11 (len('unpack_from')==11; tied with iter_unpack; 'unpack_'=7 + 'from'=4)"]
    - [iter_unpack_name_len,  "iter_unpack.__name__.__len__",  [], 11, "iter_unpack.__name__.__len__() is 11 (len('iter_unpack')==11; tied with unpack_from; 'iter_'=5 + 'unpack'=6; returns iterator)"]
    - [calcsize_name_len,     "calcsize.__name__.__len__",     [], 8,  "calcsize.__name__.__len__() is 8 (len('calcsize')==8; 'calc'=4 + 'size'=4; returns packed byte count for format)"]
    - [pack_name_len,         "pack.__name__.__len__",         [], 4,  "pack.__name__.__len__() is 4 (len('pack')==4; shortest struct module-level function name)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__class__.__module__.__eq__('builtins') == True
# struct.unpack_from.__class__.__module__.__eq__('builtins') == True
# struct.iter_unpack.__class__.__module__.__eq__('builtins') == True
# struct.calcsize.__class__.__module__.__eq__('builtins') == True
# struct.pack.__class__.__module__.__eq__('builtins') == True
#
# Wave 278 theme: struct module-level function __class__.__module__ equality.
#
# struct_extra113 anchors Struct.size/format descriptor __class__.__module__=='builtins'
# for getset_descriptor objects. No prior spec anchors __class__.__module__=='builtins'
# for the module-level C functions (pack, unpack, pack_into, unpack_from, iter_unpack,
# calcsize). All are builtin_function_or_method instances; their __class__.__module__
# is 'builtins' because the builtin_function_or_method type is defined in
# Objects/methodobject.c (a fundamental CPython runtime type). This parallels the
# pattern for hashlib sha3_256/sha3_512 (extra120) and _hashlib hash constructors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra114.struct_function_class_module_equality:
  description: "pack_into.__class__.__module__.__eq__('builtins')==True / unpack_from.__class__.__module__.__eq__('builtins')==True / iter_unpack.__class__.__module__.__eq__('builtins')==True / calcsize.__class__.__module__.__eq__('builtins')==True / pack.__class__.__module__.__eq__('builtins')==True — all are builtin_function_or_method instances from _struct.c; their TYPE (builtin_function_or_method) has __module__=='builtins' (fundamental CPython runtime type in Objects/methodobject.c); extra113 anchors getset_descriptor class module; no prior spec anchors module-level function class module as grouped table; first structfn114 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structfn114

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_class_mod,   "pack_into.__class__.__module__.__eq__",   ["builtins"], true, "pack_into.__class__.__module__ is 'builtins' (builtin_function_or_method type defined in Objects/methodobject.c)"]
    - [unpack_from_class_mod, "unpack_from.__class__.__module__.__eq__", ["builtins"], true, "unpack_from.__class__.__module__ is 'builtins' (same as pack_into; all _struct C functions share this type)"]
    - [iter_unpack_class_mod, "iter_unpack.__class__.__module__.__eq__", ["builtins"], true, "iter_unpack.__class__.__module__ is 'builtins' (same pattern; returns an iterator over consecutive struct records)"]
    - [calcsize_class_mod,    "calcsize.__class__.__module__.__eq__",    ["builtins"], true, "calcsize.__class__.__module__ is 'builtins' (same type as pack/pack_into/unpack_from; computes format size in bytes)"]
    - [pack_class_mod,        "pack.__class__.__module__.__eq__",        ["builtins"], true, "pack.__class__.__module__ is 'builtins' (shortest-named function; builtin_function_or_method from _struct.c)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__len__() == 9
# struct.pack_into.__class__.__module__.__eq__('builtins') == True
# struct.pack.__name__.__len__() == 4
# struct.calcsize.__name__.__len__() == 8
# struct.unpack_from.__class__.__module__.__eq__('builtins') == True
#
# Wave 278 theme: cross-group consistency for pack_into/pack/calcsize name and type.
#
# This table cross-checks name lengths with class module equality in a single
# view to confirm the consistent module attribution for _struct C functions.
# pack_into (9 chars) and pack (4 chars) differ by 5 chars; calcsize (8 chars) is
# one less than pack_into. All share __class__.__module__=='builtins'. Grouping
# mixed name lengths and class module checks in one table highlights the
# uniformity of type attribution across differently-named functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra114.struct_function_name_and_class_cross:
  description: "pack_into.__name__.__len__()==9 / pack_into.__class__.__module__.__eq__('builtins')==True / pack.__name__.__len__()==4 / calcsize.__name__.__len__()==8 / unpack_from.__class__.__module__.__eq__('builtins')==True — cross-group table linking name lengths with class module equality; pack_into=9 chars; pack=4 chars (difference of 5); calcsize=8 chars; all share __class__.__module__=='builtins'; no prior spec groups these cross-checks in one table; first structfn114 cross anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfn114

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name_len2,     "pack_into.__name__.__len__",              [], 9,        "pack_into name length is 9 (cross-check with function_name_lengths table)"]
    - [pack_into_class_mod2,    "pack_into.__class__.__module__.__eq__",   ["builtins"],true, "pack_into class module is 'builtins' (cross-check with function_class_module_equality table)"]
    - [pack_name_len2,          "pack.__name__.__len__",                   [], 4,        "pack name length is 4 (shortest; cross-check confirming pack.__name__=='pack')"]
    - [calcsize_name_len2,      "calcsize.__name__.__len__",               [], 8,        "calcsize name length is 8 ('calcsize' is 8 chars; same length as '_hashlib' and 'builtins' — coincidental)"]
    - [unpack_from_class_mod2,  "unpack_from.__class__.__module__.__eq__", ["builtins"],true, "unpack_from class module is 'builtins' (cross-check; same type attribution as pack_into)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__len__() == 9 — standalone
#
# struct.pack_into.__name__.__len__() is 9. 'pack_into' has 9 chars: 'pack_'=5
# plus 'into'=4 = 9. struct.pack_into(buffer, offset, format, v1, v2, ...) packs
# values into an existing mutable buffer object at a given byte offset, instead of
# returning a new bytes object like struct.pack(). This in-place writing is
# efficient for binary protocol builders. 'pack_into' (9 chars) is 5 chars longer
# than 'pack' (4 chars) — the added chars encode the 'into' directionality.
# struct_extra95 anchors __qualname__.__len__()==9; no prior spec anchors pack_into
# __name__.__len__() as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra114.pack_into_name_len_9:
  description: "struct.pack_into.__name__.__len__() == 9 — len('pack_into')==9 ('pack_'=5 + 'into'=4; in-place buffer writing vs pack which returns bytes; 9-4=5 extra chars encode the 'into' directionality); extra95 anchors qualname len==9 (same value since __name__==__qualname__ for module-level C functions); no prior spec anchors pack_into __name__.__len__() as standalone; first standalone under structfn114"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# struct.unpack_from.__name__.__len__() == 11 — standalone
#
# struct.unpack_from.__name__.__len__() is 11. 'unpack_from' has 11 chars: 'unpack_'=7
# plus 'from'=4 = 11. struct.unpack_from(format, buffer, offset=0) reads packed bytes
# from a buffer at a given byte offset without consuming the buffer. This is useful for
# parsing binary protocols where a single buffer contains multiple concatenated records.
# 'unpack_from' (11 chars) and 'iter_unpack' (11 chars) are tied for the longest
# module-level function names in the struct module. No prior spec anchors
# unpack_from.__name__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra114.unpack_from_name_len_11:
  description: "struct.unpack_from.__name__.__len__() == 11 — len('unpack_from')==11 ('unpack_'=7 + 'from'=4; reads from buffer at offset without consuming it; tied with iter_unpack for longest module-level function name in struct); extra95 anchors qualname len==11; no prior spec anchors unpack_from __name__.__len__() as standalone; first standalone under structfn114"
  category: function_identity
  kind: python_call_eq
  function: unpack_from.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__len__() == 11 — standalone
#
# struct.iter_unpack.__name__.__len__() is 11. 'iter_unpack' has 11 chars: 'iter_'=5
# plus 'unpack'=6 = 11. struct.iter_unpack(format, buffer) returns an iterator that
# repeatedly unpacks from the buffer according to the format. Each call to next()
# returns a tuple of the unpacked values. This is more memory-efficient than calling
# unpack() repeatedly on manually sliced buffer segments. 'iter_unpack' (11 chars)
# and 'unpack_from' (11 chars) are tied for longest struct module-level function names.
# No prior spec anchors iter_unpack.__name__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra114.iter_unpack_name_len_11:
  description: "struct.iter_unpack.__name__.__len__() == 11 — len('iter_unpack')==11 ('iter_'=5 + 'unpack'=6; returns iterator for successive struct-sized chunks from buffer; tied with unpack_from for longest module-level name); extra95 anchors qualname len==11; no prior spec anchors iter_unpack __name__.__len__() as standalone; first standalone under structfn114"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.pack_into.__class__.__module__.__eq__('builtins') — standalone
#
# struct.pack_into.__class__.__module__ is 'builtins'. The builtin_function_or_method
# type (type(struct.pack_into)) has its __module__ set to 'builtins'. This is because
# builtin_function_or_method is a fundamental CPython runtime type defined in
# Objects/methodobject.c — it is not attributed to any specific C extension module.
# struct_extra113 anchors the same pattern for Struct descriptor objects
# (getset_descriptor.__class__.__module__=='builtins'); no prior spec anchors
# pack_into.__class__.__module__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra114.pack_into_class_module_builtins:
  description: "struct.pack_into.__class__.__module__.__eq__('builtins') == True — builtin_function_or_method TYPE has __module__=='builtins' (fundamental CPython runtime type in Objects/methodobject.c; not attributed to _struct or any specific extension); extra113 anchors same pattern for getset_descriptor; no prior spec anchors pack_into class module as standalone; first standalone under structfn114"
  category: type_identity
  kind: python_call_eq
  function: pack_into.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__class__.__module__.__eq__('builtins') — standalone
#
# struct.pack.__class__.__module__ is 'builtins'. struct.pack(format, v1, v2, ...)
# is the most fundamental struct module function — it packs values into a new bytes
# object according to the format string. Like all _struct C functions, it is a
# builtin_function_or_method with __class__.__module__=='builtins'. The 'pack'
# function (4-char name) is the simplest counterpart to 'pack_into' (9-char name).
# No prior spec anchors struct.pack.__class__.__module__ as a standalone invariant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra114.pack_class_module_builtins:
  description: "struct.pack.__class__.__module__.__eq__('builtins') == True — pack is the most fundamental struct function (packs values into new bytes object; 4-char name; shortest module-level struct function name); builtin_function_or_method TYPE has __module__=='builtins'; no prior spec anchors pack.__class__.__module__ as standalone; first standalone under structfn114"
  category: type_identity
  kind: python_call_eq
  function: pack.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
