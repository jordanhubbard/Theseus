spec: json_mask
version: ">=2.0.0"
backend: node(json-mask)

docs: https://www.npmjs.com/package/json-mask

provenance:
  derived_from:
    - "json-mask README — https://www.npmjs.com/package/json-mask"
    - "Test vectors verified with json-mask via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "json-mask source"
  notes:
    - "json-mask is an npm package. Install: npm install json-mask"
    - "Returns a subset of an object with only the fields matching the mask string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table json_mask.mask:
  kind: node_module_call_eq
  function: ~
  category: objects
  id_prefix: jmask

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"a": 1, "b": 2, "c": 3}, "a,c"],      {"a": 1, "c": 3}]
    - [nested,   [{"a": {"x": 1, "y": 2}, "b": 3}, "a/x"], {"a": {"x": 1}}]
    - [one_key,  [{"name": "Alice", "age": 30}, "name"],   {"name": "Alice"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:57:48Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
