spec: threading_extra2341
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "threading.Event is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "threading.Condition is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "threading.Semaphore is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "threading.Barrier is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "threading.Timer is a pure-Python class (subclass of Thread) without __slots__; __dict__.__contains__('__slots__') == False."
    - "threading.local is a C extension type; __dict__.__contains__('__slots__') == False."
  created_at: "2026-04-12"

table threading_extra2341.thread_family_no_slots:
  description: "threading.Thread, Timer — pure-Python classes without __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: th2341
  columns: [id, function, args, expected]
  rows:
    - ["th2341001", "threading.Thread.__dict__.__contains__", ["__slots__"], false]
    - ["th2341002", "threading.Timer.__dict__.__contains__", ["__slots__"], false]
    - ["th2341003", "threading.Thread.__dict__.__contains__", ["_target"], false]
    - ["th2341004", "threading.Thread.__dict__.__contains__", ["_name"], false]
    - ["th2341005", "threading.Timer.__dict__.__contains__", ["interval"], false]

table threading_extra2341.sync_primitives_no_slots:
  description: "threading synchronization primitives — pure-Python classes without __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: th2341
  columns: [id, function, args, expected]
  rows:
    - ["th2341006", "threading.Event.__dict__.__contains__", ["__slots__"], false]
    - ["th2341007", "threading.Condition.__dict__.__contains__", ["__slots__"], false]
    - ["th2341008", "threading.Semaphore.__dict__.__contains__", ["__slots__"], false]
    - ["th2341009", "threading.Barrier.__dict__.__contains__", ["__slots__"], false]
    - ["th2341010", "threading.Event.__dict__.__contains__", ["_flag"], false]
    - ["th2341011", "threading.Condition.__dict__.__contains__", ["_lock"], false]
    - ["th2341012", "threading.Semaphore.__dict__.__contains__", ["_value"], false]
    - ["th2341013", "threading.Barrier.__dict__.__contains__", ["_cond"], false]

table threading_extra2341.local_no_slots:
  description: "threading.local is a C extension type — no Python-level __slots__ in __dict__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: th2341
  columns: [id, function, args, expected]
  rows:
    - ["th2341014", "threading.local.__dict__.__contains__", ["__slots__"], false]
    - ["th2341015", "threading.local.__dict__.__contains__", ["_local__impl"], false]
    - ["th2341016", "threading.local.__dict__.__contains__", ["__dict__"], false]

table threading_extra2341.no_slots_cross_check:
  description: "Cross-check: none of the threading classes expose common slot names as __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: th2341
  columns: [id, function, args, expected]
  rows:
    - ["th2341017", "threading.Thread.__dict__.__contains__", ["__slots__"], false]
    - ["th2341018", "threading.Event.__dict__.__contains__", ["__slots__"], false]
    - ["th2341019", "threading.Condition.__dict__.__contains__", ["__slots__"], false]
    - ["th2341020", "threading.Semaphore.__dict__.__contains__", ["__slots__"], false]
    - ["th2341021", "threading.Barrier.__dict__.__contains__", ["__slots__"], false]
    - ["th2341022", "threading.local.__dict__.__contains__", ["__slots__"], false]
