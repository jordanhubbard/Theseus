spec: threading_extra2221
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221: identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "threading.Thread defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "threading.Event defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "threading.Condition defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "threading.Semaphore defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "threading.Barrier defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "threading.BoundedSemaphore defines __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __hash__, __str__, __qualname__, or __name__."
    - "threading.Timer defines __doc__ and __module__ but NOT __repr__, __hash__, __str__, __qualname__, or __name__ in its own __dict__."
    - "threading.local defines __doc__ and __module__ but NOT __repr__, __hash__, __str__, __qualname__, or __name__ in its own __dict__."
    - "__qualname__ and __name__ are never in a class __dict__ — they are metaclass-level type attributes not stored as per-class dict entries."
    - "None of the threading classes define __hash__ in their own __dict__; they rely on the inherited identity hash from object."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2221.thread_identity_display:
  description: "threading.Thread dict-presence for identity/display protocol — defines __repr__; not __hash__, __str__, __qualname__, or __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2221

  columns: [id, function, args, expected]
  rows:
    - ["th2221001", "threading.Thread.__dict__.__contains__", ["__hash__"], false]
    - ["th2221002", "threading.Thread.__dict__.__contains__", ["__repr__"], true]
    - ["th2221003", "threading.Thread.__dict__.__contains__", ["__str__"], false]
    - ["th2221004", "threading.Thread.__dict__.__contains__", ["__doc__"], true]
    - ["th2221005", "threading.Thread.__dict__.__contains__", ["__module__"], true]
    - ["th2221006", "threading.Thread.__dict__.__contains__", ["__qualname__"], false]
    - ["th2221007", "threading.Thread.__dict__.__contains__", ["__name__"], false]

