spec: struct_extra144
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra143.zspec.zsdl — covers struct.Struct.__dict__.__contains__('pack'/'unpack'/'pack_into'/'format'/'size'/'iter_unpack'/'unpack_from'/'__repr__') / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct') / struct.__package__.__eq__('') (table + invariants)."
    - "struct_extra142.zspec.zsdl — covers struct.__all__.__class__.__name__.__eq__('list') / __all__.__len__()==8 / __all__.__contains__('Struct'/'error'/'pack'/'calcsize') / __spec__.name.__eq__('struct') / __loader__.__class__.__name__.__eq__('SourceFileLoader') / Struct.__init__.__qualname__.__eq__('Struct.__init__') (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__qualname__.__eq__('error') (table + invariants)."
    - "struct_extra140.zspec.zsdl — covers struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / struct.__doc__.__len__()==1278 / struct.error/__doc__ is None (table + invariants)."
    - "struct_extra139.zspec.zsdl — covers struct module-level function __qualname__ string equality (all six) / __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra138.zspec.zsdl — covers Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / error.__name__/__qualname__/__bases__[0].__name__ (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra143."
    - "Wave 322 theme: struct.__dict__.__contains__ membership checks (module-level dict, NOT Struct.__dict__) — struct.__dict__.__contains__('pack')==True / __dict__.__contains__('Struct')==True / __dict__.__contains__('error')==True / __dict__.__contains__('calcsize')==True / __dict__.__contains__('unpack')==True / __dict__.__contains__('pack_into')==True. Also struct.Struct.__dict__.__contains__('__init__')==True / __dict__.__contains__('__sizeof__')==True."
    - "struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__dict__.__contains__('Struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__dict__.__contains__('error') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__dict__.__contains__('calcsize') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__dict__.__contains__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__sizeof__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__dict__ is a plain 'dict' (not 'mappingproxy') because module __dict__ objects are mutable plain dicts. This is different from class __dict__ objects (like struct.Struct.__dict__) which are mappingproxy objects. The 18-entry module dict contains: __name__, __doc__, __package__, __loader__, __spec__, __file__, __cached__, __builtins__, __all__, calcsize, iter_unpack, pack, pack_into, unpack, unpack_from, Struct, error, _clearcache."
    - "Note: struct.__dict__.__contains__ checks for the module-level dict are distinct from Struct.__dict__.__contains__ checks (covered by extra143). The module-level dict contains the 6 exported functions (pack, pack_into, unpack, unpack_from, calcsize, iter_unpack), the Struct class, and the error exception — the same 8 names as struct.__all__. Extra142 covers __all__.__contains__ for these same 8 names; this spec covers struct.__dict__.__contains__ for a subset (non-duplicated with extra143)."
    - "Note: struct.Struct.__dict__.__contains__('__init__') == True. struct.Struct.__init__ is a wrapper_descriptor (C-level slot wrapper) present in the Struct class dict. extra142 anchors Struct.__init__.__qualname__.__eq__('Struct.__init__') and length; this spec is the first to anchor Struct.__dict__.__contains__('__init__')."
    - "Note: struct.Struct.__dict__.__contains__('__sizeof__') == True. struct.Struct.__sizeof__ is a method_descriptor (C-level method) present in the Struct class dict. extra142 anchors Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' (17 chars); this spec is the first to anchor Struct.__dict__.__contains__('__sizeof__')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__dict__.__contains__('pack')
# struct.__dict__.__contains__('Struct')
# struct.__dict__.__contains__('error')
# struct.__dict__.__contains__('calcsize')
#
# Wave 322 theme: struct module-level __dict__ contains the main public names.
#
# The module-level dict (a plain dict, distinct from Struct's mappingproxy class dict)
# contains pack, Struct, error, and calcsize as direct module-level attributes.
# extra143 covers Struct.__dict__.__contains__ for the same names; no prior struct spec
# anchors struct.__dict__.__contains__ for any name as a table under structmod144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra144.module_dict_contains_main_names:
  description: "struct.__dict__.__contains__('pack')==True / __dict__.__contains__('Struct')==True / __dict__.__contains__('error')==True / __dict__.__contains__('calcsize')==True — module-level plain dict (not a mappingproxy like Struct.__dict__); pack/Struct/error/calcsize are the four most-used public names; extra142 covers __all__.__contains__ for these names; first structmod144 anchor for struct.__dict__.__contains__ membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: structmod144

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_pack,      __dict__.__contains__, ["pack"],     true, "struct.__dict__.__contains__('pack') == True (builtin_function_or_method from _struct C extension)"]
    - [module_dict_Struct,    __dict__.__contains__, ["Struct"],   true, "struct.__dict__.__contains__('Struct') == True (the compiled Struct class from _struct C extension)"]
    - [module_dict_error,     __dict__.__contains__, ["error"],    true, "struct.__dict__.__contains__('error') == True (struct.error exception class)"]
    - [module_dict_calcsize,  __dict__.__contains__, ["calcsize"], true, "struct.__dict__.__contains__('calcsize') == True (builtin_function_or_method returning byte size for format string)"]

# ---------------------------------------------------------------------------
# struct.__dict__.__contains__('unpack')
# struct.__dict__.__contains__('pack_into')
# struct.__dict__.__contains__('unpack_from')
# struct.__dict__.__contains__('iter_unpack')
#
# Wave 322 theme: struct module-level __dict__ contains the remaining four functions.
#
# unpack, pack_into, unpack_from, and iter_unpack are the four remaining module-level
# functions in the struct public API (completing the set of 6 functions alongside
# pack and calcsize). All four are present in struct.__dict__ as C-level functions
# imported from _struct. No prior struct spec anchors struct.__dict__.__contains__
# for these four names as a table under structmod144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra144.module_dict_contains_remaining_functions:
  description: "struct.__dict__.__contains__('unpack')==True / __dict__.__contains__('pack_into')==True / __dict__.__contains__('unpack_from')==True / __dict__.__contains__('iter_unpack')==True — the four remaining module-level functions (completing the 6-function set with pack/calcsize); all are builtin_function_or_method imported from _struct C extension; extra142 covers __all__.__contains__ for these names; first structmod144 anchor for struct.__dict__.__contains__ for these four"
  kind: python_call_eq
  category: identity
  id_prefix: structmod144

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_unpack,      __dict__.__contains__, ["unpack"],      true, "struct.__dict__.__contains__('unpack') == True (builtin_function_or_method; unpacks bytes to tuple)"]
    - [module_dict_pack_into,   __dict__.__contains__, ["pack_into"],   true, "struct.__dict__.__contains__('pack_into') == True (builtin_function_or_method; packs into an existing buffer)"]
    - [module_dict_unpack_from, __dict__.__contains__, ["unpack_from"], true, "struct.__dict__.__contains__('unpack_from') == True (builtin_function_or_method; unpacks from buffer at offset)"]
    - [module_dict_iter_unpack, __dict__.__contains__, ["iter_unpack"], true, "struct.__dict__.__contains__('iter_unpack') == True (builtin_function_or_method; yields successive tuples from buffer)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__init__')
# struct.Struct.__dict__.__contains__('__sizeof__')
# struct.Struct.__dict__.__contains__('__new__')
# struct.Struct.__dict__.__contains__('__doc__')
#
# Wave 322 theme: struct.Struct class __dict__ contains dunder entries.
#
# __init__ (wrapper_descriptor), __sizeof__ (method_descriptor), __new__
# (builtin_function_or_method), and __doc__ (str) are all direct entries in
# Struct.__dict__. extra143 covers Struct.__dict__.__contains__ for the public
# methods (pack/unpack/etc.) and __repr__; extra142 anchors Struct.__init__ qualname;
# no prior struct spec anchors Struct.__dict__.__contains__ for these dunder names
# as a table under structmod144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra144.Struct_dict_contains_dunder_entries:
  description: "struct.Struct.__dict__.__contains__('__init__')==True / __dict__.__contains__('__sizeof__')==True / __dict__.__contains__('__new__')==True / __dict__.__contains__('__doc__')==True — __init__ is a wrapper_descriptor; __sizeof__ is a method_descriptor; __new__ is a builtin_function_or_method; __doc__ is a str (the 40-char docstring); extra143 covers public method __contains__ checks; extra142 anchors __init__ and __sizeof__ qualnames; first structmod144 anchor for dunder __dict__ membership"
  kind: python_call_eq
  category: identity
  id_prefix: structmod144

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_dict_init,    Struct.__dict__.__contains__, ["__init__"],   true, "struct.Struct.__dict__.__contains__('__init__') == True (wrapper_descriptor; extra142 anchors qualname 'Struct.__init__', 15 chars)"]
    - [Struct_dict_sizeof,  Struct.__dict__.__contains__, ["__sizeof__"], true, "struct.Struct.__dict__.__contains__('__sizeof__') == True (method_descriptor; extra142 anchors qualname 'Struct.__sizeof__', 17 chars)"]
    - [Struct_dict_new,     Struct.__dict__.__contains__, ["__new__"],    true, "struct.Struct.__dict__.__contains__('__new__') == True (builtin_function_or_method; allocates the Struct object)"]
    - [Struct_dict_doc,     Struct.__dict__.__contains__, ["__doc__"],    true, "struct.Struct.__dict__.__contains__('__doc__') == True (str; the 40-char Struct docstring anchored in extra141)"]

# ---------------------------------------------------------------------------
# struct.__dict__.__contains__('pack') — standalone
#
# struct.__dict__.__contains__('pack') is True. The 'pack' name at the module level
# refers to the builtin_function_or_method struct.pack imported from the _struct C
# extension. The module-level dict (a plain dict) mirrors the 8-entry struct.__all__
# list for the public API names. extra142 anchors struct.__all__.__contains__('pack');
# extra143 anchors pack.__module__.__eq__('_struct'); no prior struct spec anchors
# struct.__dict__.__contains__('pack') as a standalone under structmod144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra144.module_dict_contains_pack:
  description: "struct.__dict__.__contains__('pack') == True — 'pack' is a module-level builtin_function_or_method from _struct; module-level dict mirrors __all__ for public API names; extra142 anchors __all__.__contains__('pack'); extra143 anchors pack.__module__; no prior struct spec anchors this as a standalone; first standalone under structmod144"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__dict__.__contains__('Struct') — standalone
#
# struct.__dict__.__contains__('Struct') is True. 'Struct' at the module level refers
# to the compiled Struct class, imported from the _struct C extension into the struct
# namespace. The Struct class is the object-oriented alternative to the module-level
# functions — it compiles the format string once at construction time and reuses it
# for multiple pack/unpack calls. struct.__dict__['Struct'] is the same object as
# struct.Struct. extra141 anchors Struct.__module__.__eq__('_struct') and
# Struct.__qualname__; no prior struct spec anchors struct.__dict__.__contains__
# ('Struct') as a standalone under structmod144. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra144.module_dict_contains_Struct:
  description: "struct.__dict__.__contains__('Struct') == True — 'Struct' is the compiled class from _struct C extension; OO alternative to module-level functions; struct.__dict__['Struct'] is struct.Struct; extra141 anchors Struct identity; no prior struct spec anchors this as a standalone; first standalone under structmod144"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__dict__.__contains__('error') — standalone
#
# struct.__dict__.__contains__('error') is True. 'error' at the module level refers
# to struct.error, the exception class raised when struct operations fail (bad format
# strings, data that does not match the format, etc.). struct.error is a subclass of
# Exception (extra138 anchors __bases__[0].__name__ == 'Exception'). Its __module__
# is 'struct' (6 chars, anchored in extra97), distinct from the module-level functions
# which have __module__ == '_struct' (7 chars). No prior struct spec anchors
# struct.__dict__.__contains__('error') as a standalone under structmod144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra144.module_dict_contains_error:
  description: "struct.__dict__.__contains__('error') == True — struct.error is the Exception subclass raised on struct failures; __module__ 'struct' (6 chars, extra97) unlike functions with __module__ '_struct' (7 chars); extra138 anchors __bases__[0].__name__=='Exception'; no prior struct spec anchors this as a standalone; first standalone under structmod144"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__dict__.__contains__('calcsize') — standalone
#
# struct.__dict__.__contains__('calcsize') is True. 'calcsize' at the module level
# refers to the builtin_function_or_method struct.calcsize, which returns the number
# of bytes required for a given format string. 'calcsize' (8 chars) is the longest
# of the six module-level function names (pack=4, unpack=6, pack_into=8, calcsize=8,
# unpack_from=11, iter_unpack=11). It ties in length with 'pack_into' (also 8 chars).
# No prior struct spec anchors struct.__dict__.__contains__('calcsize') as a
# standalone under structmod144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra144.module_dict_contains_calcsize:
  description: "struct.__dict__.__contains__('calcsize') == True — 'calcsize' (8 chars) returns the byte size for a format string; ties in length with 'pack_into' (also 8 chars); longer than pack (4) or unpack (6); builtin_function_or_method from _struct; no prior struct spec anchors this as a standalone; first standalone under structmod144"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__init__') — standalone
#
# struct.Struct.__dict__.__contains__('__init__') is True. Struct.__init__ is a
# wrapper_descriptor — a C-level slot wrapper that initializes a Struct object with
# a format string argument. extra142 anchors Struct.__init__.__qualname__.__eq__
# ('Struct.__init__') (15 chars) and __class__.__name__.__eq__('wrapper_descriptor');
# no prior struct spec anchors Struct.__dict__.__contains__('__init__') as a standalone
# under structmod144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra144.Struct_dict_contains_init:
  description: "struct.Struct.__dict__.__contains__('__init__') == True — Struct.__init__ is a wrapper_descriptor (C-level slot wrapper); takes a format string argument; extra142 anchors qualname 'Struct.__init__' (15 chars) and class name 'wrapper_descriptor'; no prior struct spec anchors this as a standalone; first standalone under structmod144"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__sizeof__') — standalone
#
# struct.Struct.__dict__.__contains__('__sizeof__') is True. Struct.__sizeof__ is a
# method_descriptor — a C-level method that returns the memory size in bytes of a
# Struct object (used by sys.getsizeof()). extra142 anchors Struct.__sizeof__.__qualname__
# .__eq__('Struct.__sizeof__') (17 chars; longest Struct dunder qualname) and the class
# name 'method_descriptor'. No prior struct spec anchors Struct.__dict__.__contains__
# ('__sizeof__') as a standalone under structmod144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra144.Struct_dict_contains_sizeof:
  description: "struct.Struct.__dict__.__contains__('__sizeof__') == True — Struct.__sizeof__ is a method_descriptor (C-level); returns memory size of Struct object for sys.getsizeof(); extra142 anchors qualname 'Struct.__sizeof__' (17 chars; longest Struct dunder) and class 'method_descriptor'; no prior struct spec anchors this as a standalone; first standalone under structmod144"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__sizeof__"]
  expected: true

