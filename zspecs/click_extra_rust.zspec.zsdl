spec: click_extra_rust
version: ">=3.9"
backend: rust_module(click_extra_rust)

docs: https://click.palletsprojects.com/

provenance:
  derived_from:
    - "https://click.palletsprojects.com/ — Click library documentation"
  not_derived_from:
    - "click source: click/utils.py"
  notes:
    - "Additional Click operations not in click_ansi_rust (echo, formatting utilities)."
    - "click.style('hello', bold=True) — returns ANSI-styled string."
    - "click.unstyle(s) — removes ANSI codes (already in click_ansi_rust)."
    - "click.get_terminal_size() — returns (width, height) tuple."
    - "Expose style_contains_ansi(s, bold) -> bool: click.style(s, bold=bold) contains ESC."
    - "Expose style_len_ge(s, bold) -> bool: len(click.style(s, bold=bold)) >= len(s)."
    - "Expose get_terminal_width() -> int: click.get_terminal_size()[0] > 0."
    - "Expose progressbar_len(items) -> int: len(list(click.progressbar(items, label='')))"
    - "progressbar([1,2,3], label='') iterates 3 items."
    - "click.style('hello', bold=True) is longer than 'hello' due to ANSI codes."
    - "All test vectors verified against click 8.1.8."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# style — apply ANSI styling
table click_extra_rust.style.contains_ansi:
  kind: python_call_eq
  category: style
  id_prefix: ck_style
  function: style_contains_ansi

  columns: [id, args, expected]
  rows:
    - [bold_true,   ["hello", true],  true]
    - [no_bold,     ["hello", false], false]

# progressbar — iteration count
table click_extra_rust.progressbar.length:
  kind: python_call_eq
  category: progressbar
  id_prefix: ck_pb
  function: progressbar_len

  columns: [id, args, expected]
  rows:
    - [three, [[1, 2, 3]], 3]
    - [empty, [[]], 0]
    - [five,  [[1, 2, 3, 4, 5]], 5]

# terminal width is positive
invariant click_extra_rust.terminal.width_positive:
  description: "click.get_terminal_size()[0] > 0"
  category: terminal
  kind: python_call_eq
  function: get_terminal_width_positive
  args: []
  expected: true

