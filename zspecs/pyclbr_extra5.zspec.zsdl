spec: pyclbr_extra5
version: ">=3.9"
backend: python_module(pyclbr)

docs: https://docs.python.org/3/library/pyclbr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pyclbr.html — Python pyclbr module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pyclbr.py"
  notes:
    - "Extends pyclbr.zspec.zsdl through pyclbr_extra4.zspec.zsdl."
    - "pyclbr (base) covers: readmodule/__name__/__qualname__, readmodule_ex/__name__/__qualname__, Class/__name__/__module__, Function/__name__/__module__, type_checks, readmodule('math')/__class__/__name__, readmodule_ex('math')/__class__/__name__."
    - "pyclbr_extra covers: function names/modules table, Function/__name__/__module__, Class/__name__/__module__, Class.__bases__[0]/__name__=='_Object', Class.__bases__[0]/__module__=='pyclbr', Function.__bases__[0]/__name__=='_Object', class_is_type table."
    - "pyclbr_extra2 covers: Class/__qualname__, Function/__qualname__, Function.__bases__[0].__module__, Class/__bases__.__len__==1, Function/__bases__.__len__==1, readmodule('math').__len__()==0."
    - "pyclbr_extra3 covers: Class.__bases__[0].__name__ via method_args: [], readmodule_ex('math').__len__()==0, Class/__name__/__len__==5, Function/__name__/__len__==8, readmodule/__module__/__len__==6, readmodule_ex/__module__/__len__==6."
    - "pyclbr_extra4 covers: _Object/__name__/__module__/__qualname__/__class__/__bases__[0]/__bases__.__len__, _Object/__qualname__/__module__ lengths, readmodule('pyclbr').__len__()==4."
    - "This spec adds: pyclbr._ModuleBrowser introspection (__name__, __module__, __qualname__, __class__.__name__, __bases__[0].__name__, __bases__[0].__module__, __bases__.__len__, __name__ length); readmodule_ex('pyclbr').__len__()==11 (all Python-level names including functions); Class.__init__.__name__ and __qualname__; readmodule.__doc__ is str."
    - "pyclbr._ModuleBrowser is an internal class that walks the AST; it inherits from ast.NodeVisitor."
    - "pyclbr._ModuleBrowser.__bases__[0].__name__ == 'NodeVisitor' — differs from Class/Function which inherit from _Object."
    - "pyclbr._ModuleBrowser.__bases__[0].__module__ == 'ast' — NodeVisitor is defined in the ast module."
    - "readmodule_ex('pyclbr').__len__() == 11 — readmodule_ex returns both classes and functions; pyclbr exposes 11 Python-level names total."
    - "pyclbr.Class.__init__.__qualname__ == 'Class.__init__' — confirms the constructor is bound to the Class namespace."
    - "pyclbr.readmodule.__doc__.__class__.__name__ == 'str' — readmodule has a docstring."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pyclbr._ModuleBrowser — internal AST walker class
# No prior pyclbr spec checks _ModuleBrowser directly. It is the fourth
# Python-level class visible to pyclbr.readmodule('pyclbr').
# ---------------------------------------------------------------------------

invariant pyclbr_extra5._ModuleBrowser.name:
  description: "pyclbr._ModuleBrowser.__name__ == '_ModuleBrowser'"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__name__.__eq__
  args: ["_ModuleBrowser"]
  expected: true

invariant pyclbr_extra5._ModuleBrowser.module:
  description: "pyclbr._ModuleBrowser.__module__ == 'pyclbr'"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__module__.__eq__
  args: ["pyclbr"]
  expected: true

invariant pyclbr_extra5._ModuleBrowser.qualname:
  description: "pyclbr._ModuleBrowser.__qualname__ == '_ModuleBrowser'"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__qualname__.__eq__
  args: ["_ModuleBrowser"]
  expected: true

invariant pyclbr_extra5._ModuleBrowser.is_type:
  description: "pyclbr._ModuleBrowser.__class__.__name__ == 'type' — _ModuleBrowser is a class object"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pyclbr_extra5._ModuleBrowser.name_len:
  description: "len(pyclbr._ModuleBrowser.__name__) == 14 — '_ModuleBrowser' has 14 characters"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# _ModuleBrowser inherits from ast.NodeVisitor — not from pyclbr._Object
# This distinguishes it from Class and Function which both inherit from _Object.
# ---------------------------------------------------------------------------

invariant pyclbr_extra5._ModuleBrowser.base_name:
  description: "pyclbr._ModuleBrowser.__bases__[0].__name__ == 'NodeVisitor' — inherits from ast.NodeVisitor"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "NodeVisitor"

invariant pyclbr_extra5._ModuleBrowser.base_module:
  description: "pyclbr._ModuleBrowser.__bases__[0].__module__ == 'ast' — NodeVisitor is defined in the ast module"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "ast"

invariant pyclbr_extra5._ModuleBrowser.bases_len:
  description: "len(pyclbr._ModuleBrowser.__bases__) == 1 — _ModuleBrowser has exactly one base class"
  category: _modulebrowser_class
  kind: python_call_eq
  function: _ModuleBrowser.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# readmodule_ex('pyclbr') — full module scan including functions
# pyclbr_extra4 checks readmodule('pyclbr').__len__() == 4 (classes only).
# readmodule_ex returns both classes and module-level functions; pyclbr
# itself has 11 Python-level names total visible to the AST browser.
# ---------------------------------------------------------------------------

invariant pyclbr_extra5.readmodule_ex.pyclbr_len:
  description: "pyclbr.readmodule_ex('pyclbr').__len__() == 11 — readmodule_ex returns 11 names (classes + functions)"
  category: runtime
  kind: python_call_eq
  function: readmodule_ex
  args: ["pyclbr"]
  method: __len__
  method_args: []
  expected: 11

# ---------------------------------------------------------------------------
# Class.__init__ — constructor method identity
# Prior specs check Class.__name__ and __qualname__. No prior spec checks
# Class.__init__.__name__ or Class.__init__.__qualname__.
# ---------------------------------------------------------------------------

invariant pyclbr_extra5.Class.init_name:
  description: "pyclbr.Class.__init__.__name__ == '__init__'"
  category: class_methods
  kind: python_call_eq
  function: Class.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant pyclbr_extra5.Class.init_qualname:
  description: "pyclbr.Class.__init__.__qualname__ == 'Class.__init__' — constructor qualname is scoped to Class"
  category: class_methods
  kind: python_call_eq
  function: Class.__init__.__qualname__.__eq__
  args: ["Class.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# readmodule.__doc__ — confirms readmodule has a docstring
# No prior pyclbr spec checks __doc__ for any symbol.
# ---------------------------------------------------------------------------

invariant pyclbr_extra5.readmodule.doc_is_str:
  description: "pyclbr.readmodule.__doc__.__class__.__name__ == 'str' — readmodule has a docstring"
  category: functions
  kind: python_call_eq
  function: readmodule.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
