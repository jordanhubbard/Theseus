spec: io_extra1411
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers __sizeof__ method type/presence and __reduce_ex__ method type/presence for io module classes. io.IOBase.__sizeof__.__class__.__name__=='method_descriptor' (inherited from _IOBase C implementation; '__sizeof__' not in io.IOBase.__dict__ because it is defined on _IOBase). io.BytesIO.__dict__.__contains__('__sizeof__')==True (BytesIO defines its own __sizeof__ in the C-level _io.BytesIO type). io.IOBase.__reduce_ex__.__class__.__name__=='method_descriptor' (inherited; '__reduce_ex__' not in io.IOBase.__dict__). io.UnsupportedOperation.__mro__.__len__()==6 (MRO: UnsupportedOperation->OSError->ValueError->Exception->BaseException->object). io.BytesIO.__mro__.__len__()==4 (MRO: BytesIO->_BufferedIOBase->_IOBase->object). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.BytesIO.__dict__.__contains__('__sizeof__')==True is the key distinguishing fact: BytesIO is the only io class in this batch that overrides __sizeof__ in its own __dict__. All other classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, StringIO, UnsupportedOperation) do not have '__sizeof__' in their own __dict__ — they inherit it. Similarly, none of the io classes in this batch have '__reduce_ex__' in their own __dict__; they all inherit it. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __sizeof__ type and dict presence checks — extra1411
#
# io.IOBase.__sizeof__.__class__.__name__          == 'method_descriptor'
# io.BytesIO.__dict__.__contains__('__sizeof__')  == True
# io.IOBase.__dict__.__contains__('__sizeof__')   == False
# io.BytesIO.__sizeof__.__class__.__name__         == 'method_descriptor'
# io.StringIO.__dict__.__contains__('__sizeof__') == False
# io.RawIOBase.__dict__.__contains__('__sizeof__')== False
# ---------------------------------------------------------------------------

table io_extra1411.io_sizeof_type:
  description: "io class __sizeof__ method type and __dict__ presence checks — wave 541 extra1411 theme. io.IOBase.__sizeof__.__class__.__name__=='method_descriptor' (IOBase inherits __sizeof__ from _IOBase, a C-level class; the method_descriptor type is the descriptor object for C-implemented instance methods). io.BytesIO.__dict__.__contains__('__sizeof__')==True (BytesIO defines its own __sizeof__ at the C level in _io.BytesIO.__dict__, making it the only class in this batch with sizeof in its own dict). io.IOBase.__dict__.__contains__('__sizeof__')==False (IOBase does not define __sizeof__ directly; it inherits from _IOBase). io.StringIO.__dict__.__contains__('__sizeof__')==False (StringIO likewise does not define __sizeof__ in its own dict). io.RawIOBase.__dict__.__contains__('__sizeof__')==False. io.BufferedIOBase.__dict__.__contains__('__sizeof__')==False. All verified with Python 3.14.3."
  kind: python_call_eq
  category: sizeof_introspection
  id_prefix: io1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [io1411sz001, io.IOBase.__sizeof__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "io.IOBase.__sizeof__.__class__.__name__ == 'method_descriptor' (C-level method descriptor, inherited from _IOBase); verified with Python 3.14.3"]
    - [io1411sz002, io.BytesIO.__sizeof__.__class__.__name__.__eq__,         ["method_descriptor"], true,  "io.BytesIO.__sizeof__.__class__.__name__ == 'method_descriptor' (BytesIO defines __sizeof__ in its own C-level dict); verified with Python 3.14.3"]
    - [io1411sz003, io.BytesIO.__dict__.__contains__,                        ["__sizeof__"],         true,  "io.BytesIO.__dict__.__contains__('__sizeof__') == True (BytesIO is the only io class in this batch that owns __sizeof__ in its __dict__); verified with Python 3.14.3"]
    - [io1411sz004, io.IOBase.__dict__.__contains__,                         ["__sizeof__"],         false, "io.IOBase.__dict__.__contains__('__sizeof__') == False (IOBase inherits __sizeof__ from _IOBase, not defined in its own dict); verified with Python 3.14.3"]
    - [io1411sz005, io.StringIO.__dict__.__contains__,                       ["__sizeof__"],         false, "io.StringIO.__dict__.__contains__('__sizeof__') == False (StringIO inherits __sizeof__; not in its own dict); verified with Python 3.14.3"]
    - [io1411sz006, io.RawIOBase.__dict__.__contains__,                      ["__sizeof__"],         false, "io.RawIOBase.__dict__.__contains__('__sizeof__') == False (RawIOBase inherits __sizeof__; not in its own dict); verified with Python 3.14.3"]
    - [io1411sz007, io.BufferedIOBase.__dict__.__contains__,                 ["__sizeof__"],         false, "io.BufferedIOBase.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [io1411sz008, io.TextIOBase.__dict__.__contains__,                     ["__sizeof__"],         false, "io.TextIOBase.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# io class __reduce_ex__ type and dict presence checks — extra1411
#
# io.IOBase.__reduce_ex__.__class__.__name__          == 'method_descriptor'
# io.IOBase.__dict__.__contains__('__reduce_ex__')   == False
# io.BytesIO.__reduce_ex__.__class__.__name__         == 'method_descriptor'
# io.BytesIO.__dict__.__contains__('__reduce_ex__')  == False
# io.UnsupportedOperation.__reduce_ex__.__class__.__name__ == 'method_descriptor'
# io.StringIO.__dict__.__contains__('__reduce_ex__') == False
# ---------------------------------------------------------------------------

table io_extra1411.io_reduce_ex_type:
  description: "io class __reduce_ex__ method type and __dict__ presence checks — wave 541 extra1411 theme. io.IOBase.__reduce_ex__.__class__.__name__=='method_descriptor' (inherited from _IOBase; none of the io classes in this batch define __reduce_ex__ in their own __dict__). io.IOBase.__dict__.__contains__('__reduce_ex__')==False. io.BytesIO.__reduce_ex__.__class__.__name__=='method_descriptor'. io.BytesIO.__dict__.__contains__('__reduce_ex__')==False. io.UnsupportedOperation.__reduce_ex__.__class__.__name__=='method_descriptor' (UnsupportedOperation inherits reduce_ex from BaseException chain; its MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object], len=6). io.StringIO.__dict__.__contains__('__reduce_ex__')==False. All verified with Python 3.14.3."
  kind: python_call_eq
  category: reduce_ex_introspection
  id_prefix: io1411rx

  columns: [id, function, args, expected, description]
  rows:
    - [io1411rx001, io.IOBase.__reduce_ex__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "io.IOBase.__reduce_ex__.__class__.__name__ == 'method_descriptor' (inherited from _IOBase); verified with Python 3.14.3"]
    - [io1411rx002, io.IOBase.__dict__.__contains__,                               ["__reduce_ex__"],      false, "io.IOBase.__dict__.__contains__('__reduce_ex__') == False (not in own dict); verified with Python 3.14.3"]
    - [io1411rx003, io.BytesIO.__reduce_ex__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "io.BytesIO.__reduce_ex__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [io1411rx004, io.BytesIO.__dict__.__contains__,                              ["__reduce_ex__"],      false, "io.BytesIO.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [io1411rx005, io.UnsupportedOperation.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true, "io.UnsupportedOperation.__reduce_ex__.__class__.__name__ == 'method_descriptor' (inherits from BaseException chain; MRO len=6); verified with Python 3.14.3"]
    - [io1411rx006, io.UnsupportedOperation.__dict__.__contains__,                 ["__reduce_ex__"],      false, "io.UnsupportedOperation.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [io1411rx007, io.StringIO.__reduce_ex__.__class__.__name__.__eq__,           ["method_descriptor"], true,  "io.StringIO.__reduce_ex__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [io1411rx008, io.StringIO.__dict__.__contains__,                             ["__reduce_ex__"],      false, "io.StringIO.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# io class MRO length and name checks — extra1411
#
# io.IOBase.__mro__.__len__()             == 3   ([IOBase, _IOBase, object])
# io.BytesIO.__mro__.__len__()            == 4   ([BytesIO, _BufferedIOBase, _IOBase, object])
# io.UnsupportedOperation.__mro__.__len__() == 6 ([UnsupportedOperation, OSError, ValueError, Exception, BaseException, object])
# io.IOBase.__name__.__len__()            == 6
# io.UnsupportedOperation.__name__.__len__() == 20
# io.BytesIO.__name__.__len__()           == 7
# ---------------------------------------------------------------------------

table io_extra1411.io_mro_and_name:
  description: "io class MRO length and class name length checks — wave 541 extra1411. io.IOBase.__mro__.__len__()==3 (MRO: [IOBase, _IOBase, object]). io.BytesIO.__mro__.__len__()==4 (MRO: [BytesIO, _BufferedIOBase, _IOBase, object]). io.UnsupportedOperation.__mro__.__len__()==6 (MRO: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]; deepest chain in this batch because UnsupportedOperation subclasses both OSError and ValueError). io.IOBase.__name__.__len__()==6 ('IOBase'=6 chars). io.UnsupportedOperation.__name__.__len__()==20 ('UnsupportedOperation'=20 chars; longest in this batch). io.BytesIO.__name__.__len__()==7. io.RawIOBase.__mro__.__len__()==5 (MRO: [RawIOBase, _RawIOBase, IOBase, _IOBase, object]). io.StringIO.__name__.__len__()==8. All verified with Python 3.14.3."
  kind: python_call_eq
  category: mro_identity
  id_prefix: io1411mr

  columns: [id, function, args, expected, description]
  rows:
    - [io1411mr001, io.IOBase.__mro__.__len__,                   [], 3,  "io.IOBase.__mro__.__len__() == 3 ([IOBase, _IOBase, object]); verified with Python 3.14.3"]
    - [io1411mr002, io.BytesIO.__mro__.__len__,                  [], 4,  "io.BytesIO.__mro__.__len__() == 4 ([BytesIO, _BufferedIOBase, _IOBase, object]); verified with Python 3.14.3"]
    - [io1411mr003, io.UnsupportedOperation.__mro__.__len__,     [], 6,  "io.UnsupportedOperation.__mro__.__len__() == 6 ([UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [io1411mr004, io.RawIOBase.__mro__.__len__,                [], 5,  "io.RawIOBase.__mro__.__len__() == 5 ([RawIOBase, _RawIOBase, IOBase, _IOBase, object]); verified with Python 3.14.3"]
    - [io1411mr005, io.IOBase.__name__.__len__,                  [], 6,  "io.IOBase.__name__.__len__() == 6 ('IOBase'=6 chars); verified with Python 3.14.3"]
    - [io1411mr006, io.UnsupportedOperation.__name__.__len__,    [], 20, "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation'=20 chars; longest in this batch); verified with Python 3.14.3"]
    - [io1411mr007, io.BytesIO.__name__.__len__,                 [], 7,  "io.BytesIO.__name__.__len__() == 7 ('BytesIO'=7 chars); verified with Python 3.14.3"]
    - [io1411mr008, io.StringIO.__name__.__len__,                [], 8,  "io.StringIO.__name__.__len__() == 8 ('StringIO'=8 chars); verified with Python 3.14.3"]
