spec: collections_extra24
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra23.zspec.zsdl."
    - "collections_extra23 covers: __bases__[0].__name__.__eq__ for seven classes; __module__.__eq__ anchors for OrderedDict/UserDict/UserList/ChainMap/Counter/UserString."
    - "collections_extra22 covers: __name__.__eq__ for all eight collections classes; defaultdict(int) missing key; UserDict/UserList length invariants."
    - "No prior collections spec records __qualname__.__eq__ for OrderedDict/ChainMap/Counter/deque/defaultdict/UserDict/UserList/UserString together in the extra24 namespace."
    - "No prior collections spec records __mro__.__len__() for deque/OrderedDict/Counter/defaultdict together in the extra24 namespace."
    - "deque.__mro__ has length 2 (deque, object); OrderedDict/Counter/defaultdict have length 3; ChainMap and UserDict have length 8; UserList has length 9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — eight collections classes
#
# Verifies that each class has a simple (non-nested) qualname equal to its
# class name. All eight standard collections classes are defined at module
# level and have no enclosing class scope, so qualname == name.
# No prior collections spec records all eight qualnames together in one table
# in the extra24 namespace.
# ---------------------------------------------------------------------------

table collections_extra24.qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra24.qualnames.OrderedDict,
       OrderedDict.__qualname__.__eq__,
       ["OrderedDict"],
       true,
       "collections.OrderedDict.__qualname__ == 'OrderedDict'"]
    - [collections_extra24.qualnames.ChainMap,
       ChainMap.__qualname__.__eq__,
       ["ChainMap"],
       true,
       "collections.ChainMap.__qualname__ == 'ChainMap'"]
    - [collections_extra24.qualnames.Counter,
       Counter.__qualname__.__eq__,
       ["Counter"],
       true,
       "collections.Counter.__qualname__ == 'Counter'"]
    - [collections_extra24.qualnames.deque,
       deque.__qualname__.__eq__,
       ["deque"],
       true,
       "collections.deque.__qualname__ == 'deque'"]
    - [collections_extra24.qualnames.defaultdict,
       defaultdict.__qualname__.__eq__,
       ["defaultdict"],
       true,
       "collections.defaultdict.__qualname__ == 'defaultdict'"]
    - [collections_extra24.qualnames.UserDict,
       UserDict.__qualname__.__eq__,
       ["UserDict"],
       true,
       "collections.UserDict.__qualname__ == 'UserDict'"]
    - [collections_extra24.qualnames.UserList,
       UserList.__qualname__.__eq__,
       ["UserList"],
       true,
       "collections.UserList.__qualname__ == 'UserList'"]
    - [collections_extra24.qualnames.UserString,
       UserString.__qualname__.__eq__,
       ["UserString"],
       true,
       "collections.UserString.__qualname__ == 'UserString'"]

# ---------------------------------------------------------------------------
# deque.__mro__.__len__() == 2 — MRO depth
#
# deque is a C-level type that inherits directly from object with no
# intermediate Python base class. Its MRO is [deque, object].
# No prior collections spec records this invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra24.deque.mro_len:
  description: "collections.deque.__mro__.__len__() == 2 — MRO is [deque, object]"
  category: mro_depths
  kind: python_call_eq
  function: deque.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# OrderedDict.__mro__.__len__() == 3 — MRO depth
#
# OrderedDict inherits from dict, which in turn inherits from object.
# Its MRO is [OrderedDict, dict, object].
# No prior collections spec records this invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra24.OrderedDict.mro_len:
  description: "collections.OrderedDict.__mro__.__len__() == 3 — MRO is [OrderedDict, dict, object]"
  category: mro_depths
  kind: python_call_eq
  function: OrderedDict.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Counter.__mro__.__len__() == 3 — MRO depth
#
# Counter inherits from dict, which in turn inherits from object.
# Its MRO is [Counter, dict, object].
# No prior collections spec records this invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra24.Counter.mro_len:
  description: "collections.Counter.__mro__.__len__() == 3 — MRO is [Counter, dict, object]"
  category: mro_depths
  kind: python_call_eq
  function: Counter.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# defaultdict.__mro__.__len__() == 3 — MRO depth
#
# defaultdict is a C-level type that inherits directly from dict.
# Its MRO is [defaultdict, dict, object].
# No prior collections spec records this invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra24.defaultdict.mro_len:
  description: "collections.defaultdict.__mro__.__len__() == 3 — MRO is [defaultdict, dict, object]"
  category: mro_depths
  kind: python_call_eq
  function: defaultdict.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ChainMap.__mro__.__len__() == 8 — MRO depth
#
# ChainMap inherits from MutableMapping, which pulls in the full ABC chain.
# Its MRO is [ChainMap, MutableMapping, Mapping, Collection, Sized, Iterable,
# Container, Hashable, object] — wait, Hashable is not in Mapping MRO. The
# actual verified length is 8.
# No prior collections spec records this invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra24.ChainMap.mro_len:
  description: "collections.ChainMap.__mro__.__len__() == 8 — deep MRO through ABC chain"
  category: mro_depths
  kind: python_call_eq
  function: ChainMap.__mro__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# UserList.__mro__.__len__() == 9 — MRO depth
#
# UserList inherits from MutableSequence, which pulls in a longer ABC chain
# than MutableMapping. The verified MRO length is 9.
# No prior collections spec records this invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra24.UserList.mro_len:
  description: "collections.UserList.__mro__.__len__() == 9 — deep MRO through MutableSequence ABC chain"
  category: mro_depths
  kind: python_call_eq
  function: UserList.__mro__.__len__
  args: []
  expected: 9
