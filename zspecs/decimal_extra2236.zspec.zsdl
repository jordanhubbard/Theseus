spec: decimal_extra2236
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal.zspec.zsdl"
    - "_decimal_extra.zspec.zsdl"
    - "decimal_extra1876.zspec.zsdl"
  notes:
    - "Wave _extra2236: __slots__ and slot descriptor protocol checks for decimal classes."
    - "Covers __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__, __subclasshook__ presence in decimal class dicts."
    - "decimal.Decimal is a C extension type; it defines __new__ in its own __dict__ but no __slots__, __weakref__, __dict__, __abstractmethods__, __init__, or __subclasshook__."
    - "decimal.Context is a C extension type; it defines __init__ and __new__ but no __slots__, __weakref__, __dict__, __abstractmethods__, or __subclasshook__."
    - "decimal.DecimalException is a pure-Python exception; it defines __weakref__ in its own __dict__ but none of the other slot-related dunders."
    - "decimal.InvalidOperation, decimal.DivisionByZero, and decimal.Overflow are pure-Python exception subclasses with no slot-related dunders in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2236.Decimal_slot_protocol:
  description: "decimal.Decimal __slots__/__weakref__/__dict__/__abstractmethods__/__init__/__new__/__subclasshook__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2236

  columns: [id, function, args, expected]
  rows:
    - ["dc2236001", "decimal.Decimal.__dict__.__contains__", ["__slots__"], false]
    - ["dc2236002", "decimal.Decimal.__dict__.__contains__", ["__weakref__"], false]
    - ["dc2236003", "decimal.Decimal.__dict__.__contains__", ["__dict__"], false]
    - ["dc2236004", "decimal.Decimal.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["dc2236005", "decimal.Decimal.__dict__.__contains__", ["__init__"], false]
    - ["dc2236006", "decimal.Decimal.__dict__.__contains__", ["__new__"], true]
    - ["dc2236007", "decimal.Decimal.__dict__.__contains__", ["__subclasshook__"], false]

