spec: uuid_extra2836
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra2821.zspec.zsdl — covers __radd__, __rsub__, and __rmul__ absence for UUID, SafeUUID."
    - "uuid_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for UUID, SafeUUID."
    - "uuid_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for UUID, SafeUUID."
    - "uuid_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for UUID, SafeUUID."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "uuid.UUID.__dict__.__contains__('__rtruediv__') == False — UUID is an immutable identifier type; it does not define the reflected true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__rfloordiv__') == False — UUID does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__rmod__') == False — UUID does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__rtruediv__') == False — SafeUUID (an IntEnum subclass) does not add a reflected true division operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__rfloordiv__') == False — SafeUUID does not add a reflected floor division operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__rmod__') == False — SafeUUID does not add a reflected modulo operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# UUID is a pure-Python class representing a universally unique identifier.
# Reflected division/modulo operators (__rtruediv__, __rfloordiv__, __rmod__)
# are invoked when the left operand does not support the operation. UUID objects
# are immutable identifiers, not numeric operands, so none are defined in
# UUID.__dict__.
# ---------------------------------------------------------------------------

table uuid_extra2836.uuid_dict_rtruediv_rfloordiv_rmod:
  description: "uuid.UUID.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — UUID is an immutable identifier type with no reflected division or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2836

  columns: [id, function, args, expected]
  rows:
    - ["uu2836-uuid-rtruediv",  uuid.UUID.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["uu2836-uuid-rfloordiv", uuid.UUID.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["uu2836-uuid-rmod",      uuid.UUID.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 2: uuid.SafeUUID.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# SafeUUID is an IntEnum subclass with values -1 (unsafe) and 0 (safe).
# It does not add reflected division or modulo operators beyond those inherited
# from IntEnum; the __dict__ check is against SafeUUID's own namespace only.
# ---------------------------------------------------------------------------

table uuid_extra2836.safeuuid_dict_rtruediv_rfloordiv_rmod:
  description: "uuid.SafeUUID.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — SafeUUID (IntEnum subclass) adds no reflected division or modulo operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2836

  columns: [id, function, args, expected]
  rows:
    - ["uu2836-safe-rtruediv",  uuid.SafeUUID.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["uu2836-safe-rfloordiv", uuid.SafeUUID.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["uu2836-safe-rmod",      uuid.SafeUUID.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID.__dict__ — per-dunder detail with descriptions
# Explicit per-dunder rows documenting why each reflected operator is absent.
# ---------------------------------------------------------------------------

table uuid_extra2836.uuid_dict_detail:
  description: "uuid.UUID.__dict__ reflected division/modulo operator absence detail — __rtruediv__, __rfloordiv__, and __rmod__ are not defined because UUID is an immutable identifier type, not a numeric operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2836

  columns: [id, function, args, expected, description]
  rows:
    - ["uu2836-d-rtruediv",  uuid.UUID.__dict__.__contains__, ["__rtruediv__"],  false, "uuid.UUID does not support reflected / — UUIDs are immutable identifiers; right-hand true division is undefined"]
    - ["uu2836-d-rfloordiv", uuid.UUID.__dict__.__contains__, ["__rfloordiv__"], false, "uuid.UUID does not support reflected // — right-hand floor division has no meaning for a universally unique identifier"]
    - ["uu2836-d-rmod",      uuid.UUID.__dict__.__contains__, ["__rmod__"],      false, "uuid.UUID does not support reflected % — right-hand modulo is undefined for UUID objects"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — UUID and SafeUUID both lack all three dunders
# ---------------------------------------------------------------------------

table uuid_extra2836.all_types_all_dunders_absent:
  description: "uuid.UUID and uuid.SafeUUID both lack __rtruediv__, __rfloordiv__, and __rmod__ in __dict__ — neither uuid type defines reflected true division, floor division, or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2836

  columns: [id, function, args, expected]
  rows:
    - ["uu2836-x-uuid-rtruediv",  uuid.UUID.__dict__.__contains__,     ["__rtruediv__"],  false]
    - ["uu2836-x-uuid-rfloordiv", uuid.UUID.__dict__.__contains__,     ["__rfloordiv__"], false]
    - ["uu2836-x-uuid-rmod",      uuid.UUID.__dict__.__contains__,     ["__rmod__"],      false]
    - ["uu2836-x-safe-rtruediv",  uuid.SafeUUID.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["uu2836-x-safe-rfloordiv", uuid.SafeUUID.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["uu2836-x-safe-rmod",      uuid.SafeUUID.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra2836.uuid_no_rtruediv:
  description: "uuid.UUID.__dict__.__contains__('__rtruediv__') == False — UUID does not define the reflected true division operator; UUID objects are immutable (the int field is fixed at construction); confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__rtruediv__"]
  expected: false

invariant uuid_extra2836.uuid_no_rfloordiv:
  description: "uuid.UUID.__dict__.__contains__('__rfloordiv__') == False — UUID does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__rfloordiv__"]
  expected: false

invariant uuid_extra2836.uuid_no_rmod:
  description: "uuid.UUID.__dict__.__contains__('__rmod__') == False — UUID does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__rmod__"]
  expected: false

invariant uuid_extra2836.safeuuid_no_rtruediv:
  description: "uuid.SafeUUID.__dict__.__contains__('__rtruediv__') == False — SafeUUID is an IntEnum subclass and does not add __rtruediv__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__rtruediv__"]
  expected: false

invariant uuid_extra2836.safeuuid_no_rfloordiv:
  description: "uuid.SafeUUID.__dict__.__contains__('__rfloordiv__') == False — SafeUUID does not add __rfloordiv__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__rfloordiv__"]
  expected: false

invariant uuid_extra2836.safeuuid_no_rmod:
  description: "uuid.SafeUUID.__dict__.__contains__('__rmod__') == False — SafeUUID does not add __rmod__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__rmod__"]
  expected: false
