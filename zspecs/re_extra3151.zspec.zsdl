spec: re3151
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (re3151): __setitem__, __delitem__, __contains__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "No re class defines __setitem__ in its own __dict__: compiled patterns and match objects are read-only."
    - "No re class defines __delitem__ in its own __dict__."
    - "No re class defines __contains__ in its own __dict__: re.Match defines __getitem__ (wave 656) but not __contains__."
    - "Note: re.Match.__getitem__ (true, verified wave 656) enables m[n] group access but does not imply __contains__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# No re class defines __setitem__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only objects; re.RegexFlag is an IntFlag enum.
# ---------------------------------------------------------------------------

table re3151.setitem:
  description: "re types __setitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3151

  columns: [id, function, args, expected]
  rows:
    - ["re3151001", operator.contains, [re.Pattern.__dict__,   "__setitem__"], false]
    - ["re3151002", operator.contains, [re.Match.__dict__,     "__setitem__"], false]
    - ["re3151003", operator.contains, [re.RegexFlag.__dict__, "__setitem__"], false]

