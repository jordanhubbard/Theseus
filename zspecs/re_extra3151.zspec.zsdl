# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# No re class defines __contains__ in its own __dict__; all false.
# re.Match supports subscript access via __getitem__ (wave 656) but does not
# define __contains__: the `in` operator is not supported on match objects.
# ---------------------------------------------------------------------------

table re3151.contains:
  description: "re types __contains__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3151

  columns: [id, function, args, expected]
  rows:
    - ["re3151007", operator.contains, [re.Pattern.__dict__,   "__contains__"], false]
    - ["re3151008", operator.contains, [re.Match.__dict__,     "__contains__"], false]
    - ["re3151009", operator.contains, [re.RegexFlag.__dict__, "__contains__"], false]

# ---------------------------------------------------------------------------
# combined — __setitem__, __delitem__, __contains__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows (extended to 24 with additional cross-check rows).
# All nine values are false; re.Match's __getitem__ (true) does not imply the others.
# ---------------------------------------------------------------------------

