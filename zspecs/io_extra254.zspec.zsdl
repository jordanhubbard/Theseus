spec: io_extra254
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra253.zspec.zsdl — covers StringIO read/getvalue/write/readline/writable/readable"
    - "_io_extra.zspec.zsdl — covers _io-backend class name/module invariants for IOBase, RawIOBase, FileIO, BytesIO, StringIO, BufferedRandom, TextIOWrapper, IncrementalNewlineDecoder"
  notes:
    - "This spec covers: StringIO and BytesIO class identity (5-column tables) and seek/tell/seekable behavioral contracts (standalone invariants)."
    - "io.StringIO.__module__ == '_io' — StringIO is implemented in the C extension module _io; verified Python 3.14.3 macOS."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — immediate base class is _TextIOBase from the C extension; verified Python 3.14.3 macOS."
    - "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the C extension module _io; verified Python 3.14.3 macOS."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — immediate base class is _BufferedIOBase from the C extension; verified Python 3.14.3 macOS."
    - "io.StringIO().tell() == 0 — fresh StringIO starts at position 0; verified Python 3.14.3 macOS."
    - "io.BytesIO().tell() == 0 — fresh BytesIO starts at position 0; verified Python 3.14.3 macOS."
    - "io.StringIO('hello').seek(0) == 0 — seek() returns the new absolute stream position; verified Python 3.14.3 macOS."
    - "io.BytesIO().seekable() == True and io.StringIO().seekable() == True; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO class identity — 5-column table
# ---------------------------------------------------------------------------

table io_extra254.stringio_identity:
  description: "StringIO class identity contracts: __name__, __module__, base class name, and is-type check; verified Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iostrio254

  columns: [id, function, args, expected, description]
  rows:
    - [name,     "StringIO.__name__.__eq__",              ["StringIO"],   true, "io.StringIO.__name__ == 'StringIO'"]
    - [module,   "StringIO.__module__.__eq__",            ["_io"],        true, "io.StringIO.__module__ == '_io' (C extension)"]
    - [base,     "StringIO.__bases__[0].__name__.__eq__", ["_TextIOBase"], true, "io.StringIO base class is _TextIOBase"]
    - [is_type,  "StringIO.__class__.__name__.__eq__",    ["type"],       true, "io.StringIO is a type object"]

# ---------------------------------------------------------------------------
# BytesIO class identity — 5-column table
# ---------------------------------------------------------------------------

table io_extra254.bytesio_identity:
  description: "BytesIO class identity contracts: __name__, __module__, base class name, and is-type check; verified Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iobytio254

  columns: [id, function, args, expected, description]
  rows:
    - [name,     "BytesIO.__name__.__eq__",              ["BytesIO"],          true, "io.BytesIO.__name__ == 'BytesIO'"]
    - [module,   "BytesIO.__module__.__eq__",            ["_io"],              true, "io.BytesIO.__module__ == '_io' (C extension)"]
    - [base,     "BytesIO.__bases__[0].__name__.__eq__", ["_BufferedIOBase"],  true, "io.BytesIO base class is _BufferedIOBase"]
    - [is_type,  "BytesIO.__class__.__name__.__eq__",    ["type"],             true, "io.BytesIO is a type object"]

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO tell
# ---------------------------------------------------------------------------

invariant io_extra254.StringIO.tell.fresh_zero:
  description: "io.StringIO().tell() == 0 — fresh StringIO stream position starts at 0; verified Python 3.14.3 macOS"
  category: tell
  kind: python_call_eq
  function: StringIO
  args: []
  method: tell
  expected: 0

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO seek
# ---------------------------------------------------------------------------

invariant io_extra254.StringIO.seek.to_zero:
  description: "io.StringIO('hello').seek(0) == 0 — seek(0) returns new absolute position 0; verified Python 3.14.3 macOS"
  category: seek
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: seek
  method_args: [0]
  expected: 0

invariant io_extra254.StringIO.seek.to_three:
  description: "io.StringIO('hello').seek(3) == 3 — seek(3) returns new absolute position 3; verified Python 3.14.3 macOS"
  category: seek
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: seek
  method_args: [3]
  expected: 3

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO seekable
# ---------------------------------------------------------------------------

invariant io_extra254.StringIO.seekable.true:
  description: "io.StringIO().seekable() == True — StringIO supports random-access seeking; verified Python 3.14.3 macOS"
  category: seekable
  kind: python_call_eq
  function: StringIO
  args: []
  method: seekable
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — BytesIO tell
# ---------------------------------------------------------------------------

invariant io_extra254.BytesIO.tell.fresh_zero:
  description: "io.BytesIO().tell() == 0 — fresh BytesIO stream position starts at 0; verified Python 3.14.3 macOS"
  category: tell
  kind: python_call_eq
  function: BytesIO
  args: []
  method: tell
  expected: 0

# ---------------------------------------------------------------------------
# Standalone invariants — BytesIO seek
# ---------------------------------------------------------------------------

invariant io_extra254.BytesIO.seek.to_zero:
  description: "io.BytesIO(b'hello').seek(0) == 0 — seek(0) returns new absolute position 0; verified Python 3.14.3 macOS"
  category: seek
  kind: python_call_eq
  function: BytesIO
  args: [b"hello"]
  method: seek
  method_args: [0]
  expected: 0

invariant io_extra254.BytesIO.seek.to_three:
  description: "io.BytesIO(b'hello').seek(3) == 3 — seek(3) returns new absolute position 3; verified Python 3.14.3 macOS"
  category: seek
  kind: python_call_eq
  function: BytesIO
  args: [b"hello"]
  method: seek
  method_args: [3]
  expected: 3

# ---------------------------------------------------------------------------
# Standalone invariants — BytesIO seekable / readable / writable
# ---------------------------------------------------------------------------

invariant io_extra254.BytesIO.seekable.true:
  description: "io.BytesIO().seekable() == True — BytesIO supports random-access seeking; verified Python 3.14.3 macOS"
  category: seekable
  kind: python_call_eq
  function: BytesIO
  args: []
  method: seekable
  expected: true

invariant io_extra254.BytesIO.readable.true:
  description: "io.BytesIO().readable() == True — BytesIO is always readable; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable
  expected: true

invariant io_extra254.BytesIO.writable.true:
  description: "io.BytesIO().writable() == True — BytesIO is always writable; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: BytesIO
  args: []
  method: writable
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — BytesIO getvalue and read
# ---------------------------------------------------------------------------

invariant io_extra254.BytesIO.getvalue.hello:
  description: "io.BytesIO(b'hello').getvalue() == b'hello' — getvalue returns entire bytes contents; verified Python 3.14.3 macOS"
  category: getvalue
  kind: python_call_eq
  function: BytesIO
  args: [b"hello"]
  method: getvalue
  expected: b"hello"

invariant io_extra254.BytesIO.read.hello:
  description: "io.BytesIO(b'hello').read() == b'hello' — read() returns all bytes for BytesIO initialized with b'hello'; verified Python 3.14.3 macOS"
  category: read
  kind: python_call_eq
  function: BytesIO
  args: [b"hello"]
  method: read
  expected: b"hello"

invariant io_extra254.BytesIO.write.returns_4:
  description: "io.BytesIO().write(b'test') == 4 — write() returns number of bytes written; b'test' is 4 bytes; verified Python 3.14.3 macOS"
  category: write
  kind: python_call_eq
  function: BytesIO
  args: []
  method: write
  method_args: [b"test"]
  expected: 4
