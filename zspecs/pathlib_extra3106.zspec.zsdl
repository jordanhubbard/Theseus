spec: pp3106
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (pp3106): __lt__, __le__, __gt__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS)."
    - "pathlib.PurePath defines __lt__, __le__, and __gt__ in its own __dict__: pure paths support lexicographic path ordering."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, and pathlib.PosixPath do NOT define __lt__, __le__, or __gt__ in their own __dict__: they inherit ordering from PurePath."
    - "Ordering is defined on PurePath (the base) rather than on each subclass; e.g. PurePosixPath('/a') < PurePosixPath('/b') works via inheritance."
    - "pathlib.PosixPath is available on macOS/POSIX platforms; pathlib.WindowsPath is only instantiable on Windows."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# pathlib.PurePath defines __lt__ (true): path ordering is defined on the base
# pure-path class. Subclasses inherit __lt__ from PurePath; their own __dict__
# does NOT contain __lt__ (false).
# ---------------------------------------------------------------------------

table pp3106.lt:
  description: "pathlib types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3106

  columns: [id, function, args, expected]
  rows:
    - ["pp3106001", operator.contains, [pathlib.PurePath.__dict__,        "__lt__"], true]
    - ["pp3106002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__lt__"], false]
    - ["pp3106003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__lt__"], false]
    - ["pp3106004", operator.contains, [pathlib.Path.__dict__,            "__lt__"], false]
    - ["pp3106005", operator.contains, [pathlib.PosixPath.__dict__,       "__lt__"], false]

