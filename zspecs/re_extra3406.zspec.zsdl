spec: re3406
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (re3406): __bool__, __str__, __repr__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "No re class defines __bool__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; bool() truthiness is not explicitly defined. re.RegexFlag is an IntFlag enum but __bool__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __str__ in its own __dict__: re.Pattern, re.Match, and re.RegexFlag do not implement custom string conversion in their own __dict__s."
    - "No re class defines __repr__ in its own __dict__: re.Pattern, re.Match, and re.RegexFlag do not implement custom repr in their own __dict__s."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all conversion operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# No re class defines __bool__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but bool() support is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3406.bool:
  description: "re types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
