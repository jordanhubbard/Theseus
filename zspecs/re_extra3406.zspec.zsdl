  columns: [id, function, args, expected]
  rows:
    - ["re3406001", operator.contains, [re.Pattern.__dict__,   "__bool__"], false]
    - ["re3406002", operator.contains, [re.Match.__dict__,     "__bool__"], false]
    - ["re3406003", operator.contains, [re.RegexFlag.__dict__, "__bool__"], false]

