spec: uuid_extra151
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra150.zspec.zsdl — covers uuid.UUID property fget qualnames: hex.fget.__qualname__.__eq__('UUID.hex') / bytes.fget.__qualname__.__eq__('UUID.bytes') / version.fget.__qualname__.__eq__('UUID.version') / variant.fget.__qualname__.__eq__('UUID.variant') / urn.fget.__qualname__.__eq__('UUID.urn') / fields.fget.__qualname__.__eq__('UUID.fields') (table + invariants)."
    - "uuid_extra149.zspec.zsdl — covers uuid.UUID.__init__/__qualname__/__code__.co_argcount==7/__code__.co_name / __str__/__repr__/__hash__/__eq__ co_name and co_argcount ordering (table + invariants)."
    - "uuid_extra147.zspec.zsdl — covers uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__len__()==3 / UUID.__hash__/__str__/__repr__/__eq__ qualname lengths (table + invariants)."
    - "uuid_extra144.zspec.zsdl — covers uuid.UUID.__str__/__repr__/__hash__/__eq__/__int__ qualnames and qualname lengths (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra150."
    - "Wave 341 theme: uuid.UUID comparison/ordering dunder qualnames — UUID.__lt__/__le__/__gt__/__ge__ qualname strings and lengths; all four comparison dunders have qualname length 11 (same as __eq__); comparison ordering dunders are novel because extra144/extra147 cover __str__/__repr__/__hash__/__eq__/__int__ but NOT __lt__/__le__/__gt__/__ge__."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (11 chars = 'UUID.'=5 + '__lt__'=6). UUID implements all six comparison dunders: __eq__(11), __hash__(13), __lt__(11), __le__(11), __gt__(11), __ge__(11). The four ordering dunders (__lt__, __le__, __gt__, __ge__) all have 6-char dunder names ('__lt__', '__le__', '__gt__', '__ge__'), giving qualname length 11 (= 5 + 6), which equals __eq__(11). UUID comparison is based on the underlying 128-bit integer value (self.int). extra144 and extra147 anchor __str__/__repr__/__hash__/__eq__/__int__ qualnames; the ordering dunders __lt__/__le__/__gt__/__ge__ are novel."
    - "Note: uuid.UUID.__le__.__qualname__ == 'UUID.__le__' (11 chars). __le__ implements <=. UUID comparison methods delegate to integer comparison via self.int, enabling UUIDs to be sorted. All four ordering comparison qualnames ('UUID.__lt__', 'UUID.__le__', 'UUID.__gt__', 'UUID.__ge__') are 11 chars and follow the same pattern. The two-character dunder body ('lt', 'le', 'gt', 'ge') is always 2 chars wrapped in double underscores: '__' + 2 + '__' = 6 chars total."
    - "Note: uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (13 chars = 'UUID.'=5 + '__repr__'=8). extra144 anchors the __repr__ qualname string and length. This spec references it as context for comparison: __lt__(11) < __str__(12) < __hash__==__repr__(13) in qualname length. The four ordering dunders all tie at 11 chars (same as __eq__)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__')
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__')
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__')
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__')
#
# Wave 341 theme: UUID ordering dunder qualname strings (novel; not in extra144/extra147).
#
# UUID.__lt__.__qualname__ == 'UUID.__lt__' (11 chars = 'UUID.'=5 + '__lt__'=6).
# UUID.__le__.__qualname__ == 'UUID.__le__' (11 chars = 'UUID.'=5 + '__le__'=6).
# UUID.__gt__.__qualname__ == 'UUID.__gt__' (11 chars = 'UUID.'=5 + '__gt__'=6).
# UUID.__ge__.__qualname__ == 'UUID.__ge__' (11 chars = 'UUID.'=5 + '__ge__'=6).
# All four ordering dunders have identical qualname lengths (11 chars = length of __eq__).
# extra144 covers __str__/__repr__/__hash__/__eq__/__int__ qualnames; no prior uuid spec
# anchors __lt__/__le__/__gt__/__ge__ qualname strings as a table under uuidcmp151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra151.UUID_ordering_dunder_qualnames:
  description: "uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__')==True / UUID.__le__.__qualname__.__eq__('UUID.__le__')==True / UUID.__gt__.__qualname__.__eq__('UUID.__gt__')==True / UUID.__ge__.__qualname__.__eq__('UUID.__ge__')==True — __lt__.__qualname__ is 'UUID.__lt__' (11 chars = 'UUID.'=5 + '__lt__'=6; implements < comparison; delegates to self.int < other.int); __le__.__qualname__ is 'UUID.__le__' (11 chars; implements <=; same length as __lt__); __gt__.__qualname__ is 'UUID.__gt__' (11 chars; implements >; ties __lt__ and __le__); __ge__.__qualname__ is 'UUID.__ge__' (11 chars; implements >=; all four ordering dunders tie at 11 chars == __eq__.__qualname__.__len__()); extra144 covers __str__/__repr__/__hash__/__eq__ qualnames but NOT __lt__/__le__/__gt__/__ge__; first uuidcmp151 anchor for ordering dunder qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp151

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_UUID_lt, "__lt__.__qualname__.__eq__", ["UUID.__lt__"], true, "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (11 chars = 'UUID.'=5 + '__lt__'=6; implements <; delegates to self.int < other.int)"]
    - [le_qualname_UUID_le, "__le__.__qualname__.__eq__", ["UUID.__le__"], true, "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' (11 chars; implements <=; 'le' = 2-char dunder body; ties __lt__ at 11 chars)"]
    - [gt_qualname_UUID_gt, "__gt__.__qualname__.__eq__", ["UUID.__gt__"], true, "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' (11 chars; implements >; 'gt' = 2-char body; ties __lt__ and __le__)"]
    - [ge_qualname_UUID_ge, "__ge__.__qualname__.__eq__", ["UUID.__ge__"], true, "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' (11 chars; implements >=; all four ordering dunders tie at 11 chars = __eq__.__qualname__ length)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__len__()==11
# uuid.UUID.__le__.__qualname__.__len__()==11
# uuid.UUID.__gt__.__qualname__.__len__()==11
# uuid.UUID.__ge__.__qualname__.__len__()==11
#
# Wave 341 theme: ordering dunder qualname lengths all equal 11.
#
# All four comparison ordering dunders have qualname length 11.
# Length ordering: __lt__==__le__==__gt__==__ge__==__eq__(11) < __str__(12) < __hash__==__repr__(13).
# No prior uuid spec anchors __lt__/__le__/__gt__/__ge__ qualname lengths as a table under
# uuidcmp151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra151.UUID_ordering_dunder_qualname_lengths:
  description: "uuid.UUID.__lt__.__qualname__.__len__()==11 / UUID.__le__.__qualname__.__len__()==11 / UUID.__gt__.__qualname__.__len__()==11 / UUID.__ge__.__qualname__.__len__()==11 — all four comparison ordering dunders have qualname length 11 ('UUID.'=5 + '__Xz__'=6 for two-char body 'lt'/'le'/'gt'/'ge'); same length as __eq__.__qualname__.__len__()==11 (extra144); length ordering across all UUID comparison dunders: __lt__==__le__==__gt__==__ge__==__eq__(11) < __str__(12) < __hash__==__repr__(13); each ordering dunder name is 2 chars ('lt'/'le'/'gt'/'ge') wrapped in double underscores = '__'=2 + 2 + '__'=2 = 6 chars; 'UUID.'=5 + 6 = 11; first uuidcmp151 anchor for these four ordering dunder lengths"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp151

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_len_11, "__lt__.__qualname__.__len__", [], 11, "uuid.UUID.__lt__.__qualname__.__len__() is 11 ('UUID.__lt__' = 'UUID.'=5 + '__lt__'=6 = 11; ties __eq__.__qualname__.__len__()==11)"]
    - [le_qualname_len_11, "__le__.__qualname__.__len__", [], 11, "uuid.UUID.__le__.__qualname__.__len__() is 11 ('UUID.__le__' = 'UUID.'=5 + '__le__'=6 = 11; ties __lt__ and __gt__ and __ge__)"]
    - [gt_qualname_len_11, "__gt__.__qualname__.__len__", [], 11, "uuid.UUID.__gt__.__qualname__.__len__() is 11 ('UUID.__gt__' = 'UUID.'=5 + '__gt__'=6 = 11; all four ordering dunders tie at 11)"]
    - [ge_qualname_len_11, "__ge__.__qualname__.__len__", [], 11, "uuid.UUID.__ge__.__qualname__.__len__() is 11 ('UUID.__ge__' = 'UUID.'=5 + '__ge__'=6 = 11; length ordering: ordering(11) < __str__(12) < __hash__==__repr__(13))"]

# ---------------------------------------------------------------------------
# Cross-dunder length comparison table
#
# Wave 341 theme: complete length ordering for UUID comparison dunders.
#
# __lt__==__le__==__gt__==__ge__==__eq__ (all 11) < __str__(12) < __hash__==__repr__(13).
# No prior uuid spec shows all comparison dunder lengths together in one table under uuidcmp151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra151.UUID_comparison_dunder_length_ordering:
  description: "uuid.UUID.__eq__.__qualname__.__len__()==11 / UUID.__str__.__qualname__.__len__()==12 / UUID.__hash__.__qualname__.__len__()==13 / UUID.__repr__.__qualname__.__len__()==13 — __eq__.__qualname__.__len__() is 11 (extra144/extra147 anchor this; confirmed; ties all four ordering dunders); __str__.__qualname__.__len__() is 12 ('UUID.__str__' = 'UUID.'=5 + '__str__'=7; extra144 anchors this); __hash__.__qualname__.__len__() is 13 ('UUID.__hash__' = 'UUID.'=5 + '__hash__'=8; extra147 anchors this); __repr__.__qualname__.__len__() is 13 (ties __hash__; extra144); complete length ordering: __lt__==__le__==__gt__==__ge__==__eq__(11) < __str__(12) < __hash__==__repr__(13); first uuidcmp151 anchor showing complete comparison dunder length ordering"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp151

  columns: [id, function, args, expected, description]
  rows:
    - [eq_qualname_len_11b,   "__eq__.__qualname__.__len__",   [], 11, "uuid.UUID.__eq__.__qualname__.__len__() is 11 (extra144 anchors this; confirmed; ties all four ordering dunders __lt__/__le__/__gt__/__ge__)"]
    - [str_qualname_len_12,   "__str__.__qualname__.__len__",  [], 12, "uuid.UUID.__str__.__qualname__.__len__() is 12 ('UUID.__str__' = 'UUID.'=5 + '__str__'=7; extra144 anchors; 1 more than ordering dunders)"]
    - [hash_qualname_len_13,  "__hash__.__qualname__.__len__", [], 13, "uuid.UUID.__hash__.__qualname__.__len__() is 13 ('UUID.__hash__' = 'UUID.'=5 + '__hash__'=8; extra147 anchors; longest comparison dunder here)"]
    - [repr_qualname_len_13,  "__repr__.__qualname__.__len__", [], 13, "uuid.UUID.__repr__.__qualname__.__len__() is 13 ('UUID.__repr__' = 'UUID.'=5 + '__repr__'=8; extra144; ties __hash__ at 13; longest)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') — standalone
#
# uuid.UUID.__lt__.__qualname__ is 'UUID.__lt__' (11 chars = 'UUID.'=5 + '__lt__'=6).
# UUID.__lt__ implements the less-than comparison for UUID objects. UUIDs can be sorted
# because they implement a total ordering via __lt__, __le__, __gt__, __ge__ in addition
# to __eq__. UUID comparison is based on the underlying 128-bit integer (self.int < other.int).
# This enables sorting lists of UUIDs in lexicographic order of their integer values.
# '__lt__' (6 chars) = '__' + 'lt' + '__' where 'lt' (2 chars) is the operation code.
# All four ordering dunders (__lt__, __le__, __gt__, __ge__) share this 6-char dunder name
# pattern, tying at qualname length 11. extra144 and extra147 cover other comparison dunders;
# no prior uuid spec anchors UUID.__lt__.__qualname__ as a standalone under uuidcmp151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra151.UUID_lt_qualname_eq:
  description: "uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') == True — 11 chars = 'UUID.'=5 + '__lt__'=6; implements <; comparison by self.int < other.int (128-bit integer); enables UUID sorting; '__lt__' = '__'=2 + 'lt'=2 + '__'=2 = 6 chars; all four ordering dunders (__lt__/__le__/__gt__/__ge__) tie at qualname length 11 (= __eq__ length); extra144 anchors __eq__/__str__/__repr__/__hash__ qualnames but NOT __lt__; no prior uuid spec anchors UUID.__lt__.__qualname__ as a standalone; first standalone under uuidcmp151"
  category: identity
  kind: python_call_eq
  function: __lt__.__qualname__.__eq__
  args: ["UUID.__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') — standalone
#
# uuid.UUID.__ge__.__qualname__ is 'UUID.__ge__' (11 chars = 'UUID.'=5 + '__ge__'=6).
# UUID.__ge__ implements the greater-than-or-equal comparison (>=). Like all UUID
# comparison methods, it compares by the 128-bit integer value. '__ge__' uses 'ge'
# as the 2-char operation code, following the same pattern as '__lt__' ('lt'), '__le__'
# ('le'), and '__gt__' ('gt'). All four ordering dunders have identical qualname lengths
# (11 chars). 'UUID.__ge__' is the final comparison dunder anchor in this spec, completing
# the set of six comparison dunders: __eq__(11), __lt__(11), __le__(11), __gt__(11),
# __ge__(11), __hash__(13). No prior uuid spec anchors UUID.__ge__.__qualname__ as a
# standalone under uuidcmp151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra151.UUID_ge_qualname_eq:
  description: "uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') == True — 11 chars = 'UUID.'=5 + '__ge__'=6; implements >=; comparison by self.int >= other.int; '__ge__' = '__'=2 + 'ge'=2 + '__'=2 = 6 chars; 'ge' = 'greater-or-equal' 2-char code; ties __lt__/__le__/__gt__/__eq__ at qualname length 11; completing the four ordering dunders in this spec; extra144 anchors __eq__/__str__/__repr__/__hash__ qualnames but NOT __ge__; no prior uuid spec anchors UUID.__ge__.__qualname__ as a standalone; first standalone under uuidcmp151"
  category: identity
  kind: python_call_eq
  function: __ge__.__qualname__.__eq__
  args: ["UUID.__ge__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__le__.__qualname__.__len__() is 11. 'UUID.__le__' = 'UUID.'=5 + '__le__'=6 = 11.
# UUID.__le__ implements the less-than-or-equal comparison (<=). UUID objects support a
# total ordering, making them suitable as dictionary keys and for sorting. The four ordering
# dunders all have qualname length 11: UUID.__lt__(11), UUID.__le__(11), UUID.__gt__(11),
# UUID.__ge__(11). This equals the length of UUID.__eq__(11) (extra144 anchors this).
# Length ordering for UUID comparison dunders: ordering_dunders(11) < __str__(12) <
# __hash__==__repr__(13). This means the four ordering dunders form a cluster at length 11,
# tied with __eq__. No prior uuid spec anchors UUID.__le__.__qualname__.__len__() as a
# standalone under uuidcmp151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra151.UUID_le_qualname_len_11:
  description: "uuid.UUID.__le__.__qualname__.__len__() == 11 — 'UUID.__le__' = 'UUID.'=5 + '__le__'=6 = 11 chars; implements <=; ties __lt__/__gt__/__ge__/__eq__ at qualname length 11; all four ordering dunders have identical qualname lengths; length ordering: ordering_dunders(11) < __str__(12) < __hash__==__repr__(13); no prior uuid spec anchors UUID.__le__.__qualname__.__len__() as a standalone; first standalone under uuidcmp151"
  category: identity
  kind: python_call_eq
  function: __le__.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__gt__.__qualname__.__len__() is 11. 'UUID.__gt__' = 'UUID.'=5 + '__gt__'=6 = 11.
# UUID.__gt__ implements the greater-than comparison (>). The symmetry between __lt__ and
# __gt__, and between __le__ and __ge__, means that all four ordering dunders have the same
# qualname structure and length. 'gt' (2 chars) vs 'lt' (2 chars) vs 'le' (2 chars) vs
# 'ge' (2 chars) — all 2-char operation codes wrapped in double underscores. Together,
# __lt__, __le__, __gt__, __ge__ provide a complete total ordering. The qualname length 11
# is the same as __eq__ (extra144) and differs from __str__(12), __hash__(13), __repr__(13).
# No prior uuid spec anchors UUID.__gt__.__qualname__.__len__() as a standalone under uuidcmp151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra151.UUID_gt_qualname_len_11:
  description: "uuid.UUID.__gt__.__qualname__.__len__() == 11 — 'UUID.__gt__' = 'UUID.'=5 + '__gt__'=6 = 11 chars; implements >; 'gt'=2-char operation code (vs 'lt'=2/'le'=2/'ge'=2 for other ordering dunders); all four ordering dunders have 2-char op codes giving qualname length 11; ties __lt__/__le__/__ge__/__eq__(11); no prior uuid spec anchors UUID.__gt__.__qualname__.__len__() as a standalone; first standalone under uuidcmp151"
  category: identity
  kind: python_call_eq
  function: __gt__.__qualname__.__len__
  args: []
  expected: 11
