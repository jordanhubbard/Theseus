spec: pathlib_extra2131
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib.zspec.zsdl — covers Path/PurePath class metadata and basic operations"
  notes:
    - "Wave 2131, theme: exception protocol dict-presence."
    - "Checks whether __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, and with_traceback appear in the __dict__ of pathlib classes."
    - "__cause__, __context__, __traceback__, __suppress_context__ are set by CPython exception machinery on exception instances — not stored in class __dict__."
    - "args is an instance attribute of BaseException; not in any class __dict__."
    - "with_traceback is a BaseException C-level method; not redefined by any pathlib class."
    - "__notes__ (PEP 678, Python 3.11+) is lazily created on exception instances via add_note(); never in a class __dict__."
    - "pathlib.UnsupportedOperation subclasses NotImplementedError (which subclasses RuntimeError, Exception, BaseException)."
    - "pathlib.UnsupportedOperation.__dict__ contains only: __module__, __firstlineno__, __doc__, __static_attributes__, __weakref__ — no exception protocol attrs."
    - "pathlib.Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath are filesystem path classes — not exceptions."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __cause__ dict-presence — pathlib types
# __cause__ is the explicit exception cause ('raise X from Y'); instance-only.
# ---------------------------------------------------------------------------

table pathlib_extra2131.cause_protocol:
  description: "pathlib type __dict__.__contains__('__cause__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2131

  columns: [id, function, args, expected]
  rows:
    - ["pl2131001", "pathlib.Path.__dict__.__contains__",                 ["__cause__"], false]
    - ["pl2131002", "pathlib.PurePath.__dict__.__contains__",             ["__cause__"], false]
    - ["pl2131003", "pathlib.PurePosixPath.__dict__.__contains__",        ["__cause__"], false]
    - ["pl2131004", "pathlib.PureWindowsPath.__dict__.__contains__",      ["__cause__"], false]
    - ["pl2131005", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__cause__"], false]

# ---------------------------------------------------------------------------
# __context__ dict-presence — pathlib types
# __context__ is the implicit exception context; set by the interpreter.
# ---------------------------------------------------------------------------

table pathlib_extra2131.context_protocol:
  description: "pathlib type __dict__.__contains__('__context__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2131

  columns: [id, function, args, expected]
  rows:
    - ["pl2131006", "pathlib.Path.__dict__.__contains__",                 ["__context__"], false]
    - ["pl2131007", "pathlib.PurePath.__dict__.__contains__",             ["__context__"], false]
    - ["pl2131008", "pathlib.PurePosixPath.__dict__.__contains__",        ["__context__"], false]
    - ["pl2131009", "pathlib.PureWindowsPath.__dict__.__contains__",      ["__context__"], false]
    - ["pl2131010", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__context__"], false]

# ---------------------------------------------------------------------------
# __traceback__ dict-presence — pathlib types
# __traceback__ holds the traceback object on exception instances.
# ---------------------------------------------------------------------------

table pathlib_extra2131.traceback_protocol:
  description: "pathlib type __dict__.__contains__('__traceback__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
