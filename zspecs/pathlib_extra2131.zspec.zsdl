  columns: [id, function, args, expected]
  rows:
    - ["pl2131011", "pathlib.Path.__dict__.__contains__",                 ["__traceback__"], false]
    - ["pl2131012", "pathlib.PurePath.__dict__.__contains__",             ["__traceback__"], false]
    - ["pl2131013", "pathlib.PurePosixPath.__dict__.__contains__",        ["__traceback__"], false]
    - ["pl2131014", "pathlib.PureWindowsPath.__dict__.__contains__",      ["__traceback__"], false]
    - ["pl2131015", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__traceback__"], false]

# ---------------------------------------------------------------------------
