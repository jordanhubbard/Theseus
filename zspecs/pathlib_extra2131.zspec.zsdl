# ---------------------------------------------------------------------------

table pathlib_extra2131.suppress_context_protocol:
  description: "pathlib type __dict__.__contains__('__suppress_context__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2131

  columns: [id, function, args, expected]
  rows:
    - ["pl2131016", "pathlib.Path.__dict__.__contains__",                 ["__suppress_context__"], false]
    - ["pl2131017", "pathlib.PurePath.__dict__.__contains__",             ["__suppress_context__"], false]
    - ["pl2131018", "pathlib.PureWindowsPath.__dict__.__contains__",      ["__suppress_context__"], false]
    - ["pl2131019", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__suppress_context__"], false]

# ---------------------------------------------------------------------------
# __notes__ dict-presence — pathlib types
# __notes__ (PEP 678) is created lazily on instances via add_note(); not class-level.
# ---------------------------------------------------------------------------

table pathlib_extra2131.notes_protocol:
  description: "pathlib type __dict__.__contains__('__notes__') — all False (instance attribute, PEP 678)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2131

  columns: [id, function, args, expected]
  rows:
    - ["pl2131020", "pathlib.Path.__dict__.__contains__",                 ["__notes__"], false]
    - ["pl2131021", "pathlib.PurePath.__dict__.__contains__",             ["__notes__"], false]
    - ["pl2131022", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__notes__"], false]

