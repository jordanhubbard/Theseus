spec: concurrent_futures_extra1636
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures: Launching parallel tasks"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Lib/concurrent/futures/ (internal scheduling implementation)"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "Wave 1636: theme is __subclasshook__, __instancecheck__, __subclasscheck__ — the ABC virtual subclassing protocol."
    - "concurrent.futures classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) are NOT ABCs."
    - "None of these classes define __subclasshook__, __instancecheck__, or __subclasscheck__ in their own __dict__."
    - "Their metaclass is the plain built-in `type`, not ABCMeta; hence no virtual subclassing protocol applies."
    - "issubclass(ThreadPoolExecutor, Executor) is True — concrete executors inherit from Executor."
    - "issubclass(ProcessPoolExecutor, Executor) is True — concrete executors inherit from Executor."
    - "CancelledError inherits from concurrent.futures._base.Error (itself an Exception subclass)."
    - "TimeoutError also inherits from concurrent.futures._base.Error."
    - "BrokenExecutor inherits from RuntimeError (not from Error)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures classes have no ABC hooks in their own __dict__
#
# Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor are plain Python
# classes. Their metaclass is `type`, not ABCMeta, so none of the ABC virtual
# subclassing hooks (__subclasshook__, __instancecheck__, __subclasscheck__)
# appear in their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1636.no_virtual_subclassing:
  description: "concurrent.futures classes do not define ABC hooks in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1636nv

  columns: [id, function, args, expected]
  rows:
    - ["cf1636nv001", "concurrent.futures.Future.__dict__.__contains__",              ["__subclasshook__"],    false]
    - ["cf1636nv002", "concurrent.futures.Executor.__dict__.__contains__",            ["__subclasshook__"],    false]
    - ["cf1636nv003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__subclasshook__"],    false]
    - ["cf1636nv004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__subclasshook__"],    false]
    - ["cf1636nv005", "concurrent.futures.Future.__dict__.__contains__",              ["__instancecheck__"],   false]
    - ["cf1636nv006", "concurrent.futures.Executor.__dict__.__contains__",            ["__instancecheck__"],   false]
    - ["cf1636nv007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__instancecheck__"],   false]
    - ["cf1636nv008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__instancecheck__"],   false]
    - ["cf1636nv009", "concurrent.futures.Future.__dict__.__contains__",              ["__subclasscheck__"],   false]
    - ["cf1636nv010", "concurrent.futures.Executor.__dict__.__contains__",            ["__subclasscheck__"],   false]
    - ["cf1636nv011", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__subclasscheck__"],   false]
    - ["cf1636nv012", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__subclasscheck__"],   false]
    - ["cf1636nv013", "concurrent.futures.Future.__class__.__name__.__eq__",          ["type"],                true]
    - ["cf1636nv014", "concurrent.futures.Executor.__class__.__name__.__eq__",        ["type"],                true]
    - ["cf1636nv015", "concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__", ["type"],             true]
    - ["cf1636nv016", "concurrent.futures.ProcessPoolExecutor.__class__.__name__.__eq__", ["type"],            true]
    - ["cf1636nv017", "concurrent.futures.CancelledError.__dict__.__contains__",      ["__subclasshook__"],    false]
    - ["cf1636nv018", "concurrent.futures.TimeoutError.__dict__.__contains__",        ["__subclasshook__"],    false]
    - ["cf1636nv019", "concurrent.futures.BrokenExecutor.__dict__.__contains__",      ["__subclasshook__"],    false]
    - ["cf1636nv020", "concurrent.futures.InvalidStateError.__dict__.__contains__",   ["__subclasshook__"],    false]
    - ["cf1636nv021", "concurrent.futures.Future.__dict__.__contains__",              ["cancel"],              true]
    - ["cf1636nv022", "concurrent.futures.Future.__dict__.__contains__",              ["result"],              true]
    - ["cf1636nv023", "concurrent.futures.Future.__dict__.__contains__",              ["done"],                true]
    - ["cf1636nv024", "concurrent.futures.Future.__dict__.__contains__",              ["running"],             true]
    - ["cf1636nv025", "concurrent.futures.Executor.__dict__.__contains__",            ["submit"],              true]
    - ["cf1636nv026", "concurrent.futures.Executor.__dict__.__contains__",            ["map"],                 true]
    - ["cf1636nv027", "concurrent.futures.Executor.__dict__.__contains__",            ["shutdown"],            true]

# ---------------------------------------------------------------------------
# Table 2: class hierarchy — inheritance and issubclass relationships
#
# ThreadPoolExecutor and ProcessPoolExecutor both inherit from Executor.
# All classes ultimately inherit from object.
# Exception class hierarchy: CancelledError and TimeoutError inherit from the
# internal Error base; BrokenExecutor inherits from RuntimeError directly.
# These hierarchy invariants are independent of the ABC protocol.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1636.class_hierarchy:
  description: "concurrent.futures class inheritance hierarchy and issubclass relationships"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1636ch

  columns: [id, function, args, expected]
  rows:
    - ["cf1636ch001", "concurrent.futures.ThreadPoolExecutor.__bases__.__getitem__",  [0],                          null]
    - ["cf1636ch002", "concurrent.futures.ProcessPoolExecutor.__bases__.__getitem__", [0],                          null]
    - ["cf1636ch003", "concurrent.futures.ThreadPoolExecutor.__name__.__eq__",        ["ThreadPoolExecutor"],        true]
    - ["cf1636ch004", "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",       ["ProcessPoolExecutor"],       true]
    - ["cf1636ch005", "concurrent.futures.Executor.__name__.__eq__",                  ["Executor"],                  true]
    - ["cf1636ch006", "concurrent.futures.Future.__name__.__eq__",                    ["Future"],                    true]
    - ["cf1636ch007", "concurrent.futures.CancelledError.__name__.__eq__",            ["CancelledError"],            true]
    - ["cf1636ch008", "concurrent.futures.TimeoutError.__name__.__eq__",              ["TimeoutError"],              true]
    - ["cf1636ch009", "concurrent.futures.BrokenExecutor.__name__.__eq__",            ["BrokenExecutor"],            true]
    - ["cf1636ch010", "concurrent.futures.InvalidStateError.__name__.__eq__",         ["InvalidStateError"],         true]
    - ["cf1636ch011", "concurrent.futures.CancelledError.__bases__.__getitem__",      [0],                          null]
    - ["cf1636ch012", "concurrent.futures.TimeoutError.__bases__.__getitem__",        [0],                          null]
    - ["cf1636ch013", "concurrent.futures.BrokenExecutor.__bases__.__getitem__",      [0],                          null]
    - ["cf1636ch014", "concurrent.futures.BrokenExecutor.__bases__.__getitem__",      [0],                          null]
    - ["cf1636ch015", "concurrent.futures.Future.__module__.__eq__",                  ["concurrent.futures._base"], true]
    - ["cf1636ch016", "concurrent.futures.Executor.__module__.__eq__",                ["concurrent.futures._base"], true]
    - ["cf1636ch017", "concurrent.futures.ThreadPoolExecutor.__module__.__eq__",      ["concurrent.futures.thread"], true]
    - ["cf1636ch018", "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",     ["concurrent.futures.process"], true]
    - ["cf1636ch019", "concurrent.futures.CancelledError.__module__.__eq__",          ["concurrent.futures._base"], true]
    - ["cf1636ch020", "concurrent.futures.TimeoutError.__module__.__eq__",            ["concurrent.futures._base"], true]
    - ["cf1636ch021", "concurrent.futures.BrokenExecutor.__module__.__eq__",          ["concurrent.futures._base"], true]
    - ["cf1636ch022", "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__", ["str"],                       true]
    - ["cf1636ch023", "concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__", ["str"],                       true]
