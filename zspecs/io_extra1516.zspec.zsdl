spec: io_extra1516
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, BytesIO, StringIO, RawIOBase, BufferedIOBase, TextIOBase documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "_io C extension source"
  notes:
    - "Wave 548 (_extra1516): arithmetic/numeric operator __dict__ presence checks for io module classes."
    - "io classes are I/O stream types, not numeric types. None define __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, or __pow__ in their own __dict__."
    - "io.IOBase is the abstract base; its __dict__ contains only __abstractmethods__, __doc__, __module__, and _abc_impl — no arithmetic operators."
    - "io.BytesIO and io.StringIO are concrete in-memory stream types. Their __dict__ contains stream methods (read, write, seek, readline, etc.) and dunders (__init__, __iter__, __next__) but no arithmetic operator dunders."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract bases for the three I/O layers; their __dict__ entries are minimal with no arithmetic operators."
    - "Positive anchors confirm stream-specific methods ARE present: BytesIO defines read, write, __iter__; StringIO defines read, write; IOBase defines __abstractmethods__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1516.iobase_arithmetic_ops:
  description: "io.IOBase arithmetic operator absence — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__ are all absent from io.IOBase.__dict__; IOBase is an abstract I/O base class, not a numeric type; positive anchor shows __abstractmethods__ IS present; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: io1516ib
  columns: [id, function, args, expected, description]
  rows:
    - [io1516ib001,
       io.IOBase.__dict__.__contains__,
       ["__add__"],
       false,
       "io.IOBase.__dict__.__contains__('__add__') == False — io.IOBase is the abstract base class for all I/O stream classes; it is not a numeric type and defines no arithmetic operators; __add__ is absent from io.IOBase.__dict__; I/O streams are not addable; verified with Python 3.14.3"]
    - [io1516ib002,
       io.IOBase.__dict__.__contains__,
       ["__mul__"],
       false,
       "io.IOBase.__dict__.__contains__('__mul__') == False — io.IOBase does not implement __mul__; multiplication is meaningless for abstract I/O base objects; the I/O class hierarchy defines stream protocol methods (read, write, seek, close) but no arithmetic operators; verified with Python 3.14.3"]
    - [io1516ib003,
       io.IOBase.__dict__.__contains__,
       ["__sub__"],
       false,
       "io.IOBase.__dict__.__contains__('__sub__') == False — io.IOBase does not implement __sub__; subtraction is not part of the I/O stream protocol; IOBase defines abstract methods for stream interaction, not arithmetic operations; verified with Python 3.14.3"]
    - [io1516ib004,
       io.IOBase.__dict__.__contains__,
       ["__truediv__"],
       false,
       "io.IOBase.__dict__.__contains__('__truediv__') == False — io.IOBase does not implement __truediv__; division by I/O streams is undefined; contrast with pathlib.PurePath which defines __truediv__ for path joining (path / 'subdir'), but IOBase defines no such path-joining operator; verified with Python 3.14.3"]
    - [io1516ib005,
       io.IOBase.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "io.IOBase.__dict__.__contains__('__floordiv__') == False — io.IOBase does not implement __floordiv__; floor division is absent from the entire io class hierarchy; I/O streams have no numeric operator semantics; verified with Python 3.14.3"]
    - [io1516ib006,
       io.IOBase.__dict__.__contains__,
       ["__mod__"],
       false,
       "io.IOBase.__dict__.__contains__('__mod__') == False — io.IOBase does not implement __mod__; modulo is absent from io.IOBase.__dict__; while str defines __mod__ for % string formatting, the IOBase I/O base class does not implement string-formatting or numeric-modulo semantics; verified with Python 3.14.3"]
    - [io1516ib007,
       io.IOBase.__dict__.__contains__,
       ["__abstractmethods__"],
       true,
       "io.IOBase.__dict__.__contains__('__abstractmethods__') == True — positive anchor: io.IOBase defines __abstractmethods__ in its own __dict__; this marks IOBase as an abstract class with abstract method stubs; the class dict contains abstract-class metadata, not arithmetic operators; verified with Python 3.14.3"]
    - [io1516ib008,
       io.IOBase.__dict__.__contains__,
       ["__pow__"],
       false,
       "io.IOBase.__dict__.__contains__('__pow__') == False — io.IOBase does not implement __pow__; exponentiation is not defined for any io class; none of the six io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO) define any arithmetic operator dunder; verified with Python 3.14.3"]

table io_extra1516.bytesio_arithmetic_ops:
  description: "io.BytesIO arithmetic operator absence — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__ are all absent from io.BytesIO.__dict__; BytesIO is an in-memory bytes stream, not a numeric type; positive anchors show read, write, and __iter__ ARE present; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: io1516by
  columns: [id, function, args, expected, description]
  rows:
    - [io1516by001,
       io.BytesIO.__dict__.__contains__,
       ["__add__"],
       false,
       "io.BytesIO.__dict__.__contains__('__add__') == False — io.BytesIO is an in-memory byte stream backed by a bytes buffer; it is not a numeric type and defines no __add__; bytes objects (b'x') support __add__ for concatenation, but io.BytesIO stream objects do not expose this operator; verified with Python 3.14.3"]
    - [io1516by002,
       io.BytesIO.__dict__.__contains__,
       ["__mul__"],
       false,
       "io.BytesIO.__dict__.__contains__('__mul__') == False — io.BytesIO does not implement __mul__; while bytes objects support __mul__ for repetition (b'x' * 3), the BytesIO stream wrapper does not; BytesIO.__dict__ contains read, write, seek, and stream-related methods but no arithmetic operators; verified with Python 3.14.3"]
    - [io1516by003,
       io.BytesIO.__dict__.__contains__,
       ["__sub__"],
       false,
       "io.BytesIO.__dict__.__contains__('__sub__') == False — io.BytesIO does not implement __sub__; subtraction is undefined for byte stream objects; the bytes buffer inside BytesIO is opaque and not addressable via arithmetic; verified with Python 3.14.3"]
    - [io1516by004,
       io.BytesIO.__dict__.__contains__,
       ["__truediv__"],
       false,
       "io.BytesIO.__dict__.__contains__('__truediv__') == False — io.BytesIO does not implement __truediv__; the division-style path-joining semantics of pathlib.PurePath (which defines __truediv__) have no equivalent in io.BytesIO; BytesIO is a stream object that supports read/write/seek, not path arithmetic; verified with Python 3.14.3"]
    - [io1516by005,
       io.BytesIO.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "io.BytesIO.__dict__.__contains__('__floordiv__') == False — io.BytesIO does not implement __floordiv__; floor division is absent from BytesIO.__dict__; no arithmetic operators are defined for in-memory byte stream objects; verified with Python 3.14.3"]
    - [io1516by006,
       io.BytesIO.__dict__.__contains__,
       ["__iter__"],
       true,
       "io.BytesIO.__dict__.__contains__('__iter__') == True — positive anchor: io.BytesIO defines __iter__ in its own __dict__; BytesIO supports synchronous line-by-line iteration (for line in io.BytesIO(b'a\\nb\\n')); stream iteration dunders are present while arithmetic operators (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__) are absent; verified with Python 3.14.3"]
    - [io1516by007,
       io.BytesIO.__dict__.__contains__,
       ["read"],
       true,
       "io.BytesIO.__dict__.__contains__('read') == True — positive anchor: io.BytesIO defines 'read' in its own __dict__; the read method is the primary stream consumption method; stream I/O methods (read, write, seek) are present while all arithmetic operator dunders are absent; verified with Python 3.14.3"]
    - [io1516by008,
       io.BytesIO.__dict__.__contains__,
       ["write"],
       true,
       "io.BytesIO.__dict__.__contains__('write') == True — positive anchor: io.BytesIO defines 'write' in its own __dict__; write appends bytes to the in-memory buffer; stream write/read methods are defined, arithmetic operators are not; BytesIO.__dict__ has no __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, or __pow__; verified with Python 3.14.3"]
    - [io1516by009,
       io.BytesIO.__dict__.__contains__,
       ["__radd__"],
       false,
       "io.BytesIO.__dict__.__contains__('__radd__') == False — io.BytesIO does not implement __radd__; neither the left-side __add__ nor the right-side __radd__ addition protocol is defined for BytesIO; the complete arithmetic operator set (__add__, __radd__, __mul__, __rmul__, __sub__, __rsub__, __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__) is absent from BytesIO.__dict__; verified with Python 3.14.3"]

table io_extra1516.stringio_arithmetic_ops:
  description: "io.StringIO arithmetic operator absence — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__ are all absent from io.StringIO.__dict__; StringIO is an in-memory text stream, not a numeric type; positive anchors show read and write ARE present; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: io1516si
  columns: [id, function, args, expected, description]
  rows:
    - [io1516si001,
       io.StringIO.__dict__.__contains__,
       ["__add__"],
       false,
       "io.StringIO.__dict__.__contains__('__add__') == False — io.StringIO is an in-memory text stream; it is not a numeric type and defines no __add__; str objects define __add__ for concatenation, but io.StringIO stream objects do not expose this operator; StringIO wraps a text buffer with a stream interface, not a string interface; verified with Python 3.14.3"]
    - [io1516si002,
       io.StringIO.__dict__.__contains__,
       ["__mul__"],
       false,
       "io.StringIO.__dict__.__contains__('__mul__') == False — io.StringIO does not implement __mul__; while str objects support __mul__ for repetition ('x' * 3), the StringIO stream wrapper does not; StringIO.__dict__ contains read, write, seek, and stream methods but no arithmetic operators; verified with Python 3.14.3"]
    - [io1516si003,
       io.StringIO.__dict__.__contains__,
       ["__mod__"],
       false,
       "io.StringIO.__dict__.__contains__('__mod__') == False — io.StringIO does not implement __mod__; while str defines __mod__ for % string formatting ('hello %s' % name), io.StringIO as a stream wrapper does not expose __mod__; StringIO is for reading/writing text, not for format-string interpolation; verified with Python 3.14.3"]
    - [io1516si004,
       io.StringIO.__dict__.__contains__,
       ["__truediv__"],
       false,
       "io.StringIO.__dict__.__contains__('__truediv__') == False — io.StringIO does not implement __truediv__; division is undefined for text stream objects; pathlib.PurePath defines __truediv__ for path joining but io.StringIO has no analogous operator; verified with Python 3.14.3"]
    - [io1516si005,
       io.StringIO.__dict__.__contains__,
       ["__sub__"],
       false,
       "io.StringIO.__dict__.__contains__('__sub__') == False — io.StringIO does not implement __sub__; subtraction is not defined for text stream objects; the complete arithmetic operator set is absent from StringIO.__dict__; verified with Python 3.14.3"]
    - [io1516si006,
       io.StringIO.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "io.StringIO.__dict__.__contains__('__floordiv__') == False — io.StringIO does not implement __floordiv__; floor division is absent from StringIO.__dict__; no arithmetic operators are defined for in-memory text stream objects; verified with Python 3.14.3"]
    - [io1516si007,
       io.StringIO.__dict__.__contains__,
       ["read"],
       true,
       "io.StringIO.__dict__.__contains__('read') == True — positive anchor: io.StringIO defines 'read' in its own __dict__; read is the primary stream consumption method returning a str; stream methods (read, write, readline, seek) are present while arithmetic operators (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__) are absent; verified with Python 3.14.3"]
    - [io1516si008,
       io.StringIO.__dict__.__contains__,
       ["write"],
       true,
       "io.StringIO.__dict__.__contains__('write') == True — positive anchor: io.StringIO defines 'write' in its own __dict__; write appends text to the in-memory text buffer; stream write/read operations are defined, but arithmetic operators are not; verified with Python 3.14.3"]
    - [io1516si009,
       io.StringIO.__dict__.__contains__,
       ["__rmul__"],
       false,
       "io.StringIO.__dict__.__contains__('__rmul__') == False — io.StringIO does not implement __rmul__; neither __mul__ nor __rmul__ is defined; the reflected arithmetic operators (__radd__, __rmul__, __rsub__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__) are all absent from StringIO.__dict__ just as the forward operators are absent; verified with Python 3.14.3"]
