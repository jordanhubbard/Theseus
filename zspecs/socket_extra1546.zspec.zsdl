spec: socket_extra1546
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra1531.zspec.zsdl — covers comparison operator dict-presence checks on socket.socket, socket.error, and socket.timeout."
    - "socket_extra1516.zspec.zsdl — covers arithmetic operator absence on socket.socket and socket.error; I/O method presence."
    - "socket_extra1501.zspec.zsdl — covers bitwise operator absence on socket.socket, socket.error, and socket.timeout (earlier wave)."
    - "socket_extra991.zspec.zsdl — covers lifecycle, addressing, and configuration method __qualname__ attributes."
  notes:
    - "This spec is wave 550 / suffix _extra1546. Theme: bitwise operator dict-presence checks on socket.socket, socket.error, and socket.timeout."
    - "socket.socket is a Python-level class (Lib/socket.py) wrapping OS-level file descriptors. It represents an I/O endpoint, not a numeric value — bitwise operators are not defined in socket.socket.__dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (NOT IntFlag), so they also do not define bitwise operators in their own __dict__. This spec focuses on socket.socket only, per spec guidance."
    - "socket.error is identical to OSError (socket.error is OSError). OSError stores errno/strerror and overrides lifecycle dunders, but no bitwise operators."
    - "socket.timeout is identical to TimeoutError (a subclass of OSError). Its __dict__ contains only __doc__ — no bitwise operators."
    - "Verified: '__and__' in socket.socket.__dict__ == False."
    - "Verified: '__or__' in socket.socket.__dict__ == False."
    - "Verified: '__xor__' in socket.socket.__dict__ == False."
    - "Verified: '__invert__' in socket.socket.__dict__ == False."
    - "Verified: '__lshift__' in socket.socket.__dict__ == False."
    - "Verified: '__rshift__' in socket.socket.__dict__ == False."
    - "Verified: '__rand__' in socket.socket.__dict__ == False."
    - "Verified: '__ror__' in socket.socket.__dict__ == False."
    - "Verified: '__rxor__' in socket.socket.__dict__ == False."
    - "Verified: '__and__' in socket.error.__dict__ == False (through __rxor__) == False."
    - "Verified: '__and__' in socket.timeout.__dict__ == False (through __rxor__) == False."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — bitwise operator absence checks
#
# socket.socket is a Python class (Lib/socket.py) providing a high-level
# interface to OS-level sockets. A socket object represents an open I/O
# endpoint — it carries a file descriptor and connection state, not a
# numeric value. Bitwise operators (__and__, __or__, __xor__, __invert__,
# __lshift__, __rshift__) are numeric-domain operations and are not defined
# in socket.socket.__dict__. The reflected variants (__rand__, __ror__,
# __rxor__) are equally absent. True entries (__init__, __enter__, __exit__,
# close, accept) confirm the dict-presence mechanism is functioning.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table socket_extra1546.socket_bitwise_absent:
  description: "Bitwise operator dunders absent from socket.socket.__dict__ — I/O endpoint, not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1546sa

  columns: [id, function, args, expected]
  rows:
    - ["sk1546sa001", "socket.__dict__.__contains__", ["__and__"],    false]
    - ["sk1546sa002", "socket.__dict__.__contains__", ["__or__"],     false]
    - ["sk1546sa003", "socket.__dict__.__contains__", ["__xor__"],    false]
    - ["sk1546sa004", "socket.__dict__.__contains__", ["__invert__"], false]
    - ["sk1546sa005", "socket.__dict__.__contains__", ["__lshift__"], false]
    - ["sk1546sa006", "socket.__dict__.__contains__", ["__rshift__"], false]
    - ["sk1546sa007", "socket.__dict__.__contains__", ["__rand__"],   false]
    - ["sk1546sa008", "socket.__dict__.__contains__", ["__ror__"],    false]
    - ["sk1546sa009", "socket.__dict__.__contains__", ["__rxor__"],   false]
    - ["sk1546sa010", "socket.__dict__.__contains__", ["__init__"],   true]
    - ["sk1546sa011", "socket.__dict__.__contains__", ["__enter__"],  true]
    - ["sk1546sa012", "socket.__dict__.__contains__", ["close"],      true]

# ---------------------------------------------------------------------------
# socket.error — bitwise operator absence checks
#
# socket.error is OSError (socket.error is OSError evaluates to True). OSError
# defines errno, strerror, filename descriptors and overrides lifecycle
# dunders (__new__, __init__, __str__, __reduce__), but defines no bitwise
# operators in its own __dict__. socket.timeout is TimeoutError (a subclass
# of OSError) whose __dict__ contains only __doc__. Both confirm that OS-level
# exception types carry no bitwise operator semantics.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table socket_extra1546.error_bitwise_absent:
  description: "Bitwise operator dunders absent from socket.error (OSError).__dict__ and socket.timeout.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1546eb

  columns: [id, function, args, expected]
  rows:
    - ["sk1546eb001", "error.__dict__.__contains__",   ["__and__"],    false]
    - ["sk1546eb002", "error.__dict__.__contains__",   ["__or__"],     false]
    - ["sk1546eb003", "error.__dict__.__contains__",   ["__xor__"],    false]
    - ["sk1546eb004", "error.__dict__.__contains__",   ["__invert__"], false]
    - ["sk1546eb005", "error.__dict__.__contains__",   ["__lshift__"], false]
    - ["sk1546eb006", "error.__dict__.__contains__",   ["__rshift__"], false]
    - ["sk1546eb007", "error.__dict__.__contains__",   ["__rand__"],   false]
    - ["sk1546eb008", "error.__dict__.__contains__",   ["__ror__"],    false]
    - ["sk1546eb009", "error.__dict__.__contains__",   ["__rxor__"],   false]
    - ["sk1546eb010", "error.__dict__.__contains__",   ["errno"],      true]
    - ["sk1546eb011", "error.__dict__.__contains__",   ["strerror"],   true]
    - ["sk1546eb012", "timeout.__dict__.__contains__", ["__and__"],    false]
    - ["sk1546eb013", "timeout.__dict__.__contains__", ["__or__"],     false]
    - ["sk1546eb014", "timeout.__dict__.__contains__", ["__xor__"],    false]
    - ["sk1546eb015", "timeout.__dict__.__contains__", ["__doc__"],    true]

# ---------------------------------------------------------------------------
# socket.socket — I/O methods and reflected bitwise operator cross-check
#
# This table provides a focused cross-check for the reflected bitwise dunders
# (__rand__, __ror__, __rxor__) on socket.socket alongside additional I/O
# and descriptor entries (accept, makefile, sendfile, dup, detach, family,
# type, __repr__, __exit__) that are present in socket.socket.__dict__.
# The mix of False (bitwise) and True (I/O) entries within a single table
# validates that the dict-presence mechanism distinguishes correctly between
# operators that are defined and operators that are not.
# ---------------------------------------------------------------------------

table socket_extra1546.socket_reflected_and_io:
  description: "Reflected bitwise dunders absent and I/O methods present in socket.socket.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1546ri

  columns: [id, function, args, expected]
  rows:
    - ["sk1546ri001", "socket.__dict__.__contains__", ["__rand__"],   false]
    - ["sk1546ri002", "socket.__dict__.__contains__", ["__ror__"],    false]
    - ["sk1546ri003", "socket.__dict__.__contains__", ["__rxor__"],   false]
    - ["sk1546ri004", "socket.__dict__.__contains__", ["__repr__"],   true]
    - ["sk1546ri005", "socket.__dict__.__contains__", ["__exit__"],   true]
    - ["sk1546ri006", "socket.__dict__.__contains__", ["accept"],     true]
    - ["sk1546ri007", "socket.__dict__.__contains__", ["makefile"],   true]
    - ["sk1546ri008", "socket.__dict__.__contains__", ["sendfile"],   true]
    - ["sk1546ri009", "socket.__dict__.__contains__", ["dup"],        true]
    - ["sk1546ri010", "socket.__dict__.__contains__", ["detach"],     true]
    - ["sk1546ri011", "socket.__dict__.__contains__", ["family"],     true]
    - ["sk1546ri012", "socket.__dict__.__contains__", ["type"],       true]
