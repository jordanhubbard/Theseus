spec: th2941
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 643 (th2941): __neg__, __pos__, __abs__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define unary negation, positive, or absolute value operators."
    - "Verified types: threading.Thread, threading.Lock (type), threading.RLock (type), threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Lock and threading.RLock are factory functions; their types are accessed via type(threading.Lock()) and type(threading.RLock())."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th2941.neg:
  description: "threading types __neg__ dict-presence checks; wave 643"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2941
  columns: [id, function, args, expected]
  rows:
    - ["th2941001", operator.contains, [threading.Thread.__dict__,           "__neg__"], false]
    - ["th2941002", operator.contains, [threading.Condition.__dict__,        "__neg__"], false]
    - ["th2941003", operator.contains, [threading.Semaphore.__dict__,        "__neg__"], false]
    - ["th2941004", operator.contains, [threading.BoundedSemaphore.__dict__, "__neg__"], false]
    - ["th2941005", operator.contains, [threading.Event.__dict__,            "__neg__"], false]
    - ["th2941006", operator.contains, [threading.Barrier.__dict__,          "__neg__"], false]

