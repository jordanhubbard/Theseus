spec: threading_extra2431
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Thread, Lock, RLock, Event, Condition, Semaphore, Barrier, Timer async iteration protocol dict-presence"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py, Modules/_threadmodule.c"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for threading types."
    - "threading.Thread is the thread management class; no async or sync iteration protocol in its __dict__."
    - "threading.Lock is a C-implemented primitive lock (type name 'lock'); no iteration protocol."
    - "threading.RLock is a re-entrant lock; no iteration protocol."
    - "threading.Event is a synchronization primitive for signaling between threads; no iteration protocol."
    - "threading.Condition is a condition variable; no iteration protocol."
    - "threading.Semaphore is a counting semaphore; no iteration protocol."
    - "threading.Barrier is a synchronization barrier for a fixed number of threads; no iteration protocol."
    - "threading.Timer is a Thread subclass that runs a function after a delay; no iteration protocol."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

table threading_extra2431.async_iter_absent:
  description: "threading types do not define __aiter__ or __anext__ in their class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2431

  columns: [id, function, args, expected]
  rows:
    - ["th2431001", "threading.Thread.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431002", "threading.Thread.__dict__.__contains__", ["__anext__"], false]
    - ["th2431003", "threading.Lock.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431004", "threading.Lock.__dict__.__contains__", ["__anext__"], false]
    - ["th2431005", "threading.RLock.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431006", "threading.RLock.__dict__.__contains__", ["__anext__"], false]
    - ["th2431007", "threading.Event.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431008", "threading.Event.__dict__.__contains__", ["__anext__"], false]
    - ["th2431009", "threading.Condition.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431010", "threading.Condition.__dict__.__contains__", ["__anext__"], false]

