    - ["th2431012", "threading.Semaphore.__dict__.__contains__", ["__anext__"], false]
    - ["th2431013", "threading.Barrier.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431014", "threading.Barrier.__dict__.__contains__", ["__anext__"], false]
    - ["th2431015", "threading.Timer.__dict__.__contains__", ["__aiter__"], false]
    - ["th2431016", "threading.Timer.__dict__.__contains__", ["__anext__"], false]

table threading_extra2431.sync_iter_also_absent:
  description: "threading types do not define __iter__ or __next__ in their class __dict__ either — no iteration protocol of any kind"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2431

  columns: [id, function, args, expected]
  rows:
    - ["th2431017", "threading.Thread.__dict__.__contains__", ["__iter__"], false]
    - ["th2431018", "threading.Thread.__dict__.__contains__", ["__next__"], false]
    - ["th2431019", "threading.Lock.__dict__.__contains__", ["__iter__"], false]
    - ["th2431020", "threading.Lock.__dict__.__contains__", ["__next__"], false]
    - ["th2431021", "threading.Event.__dict__.__contains__", ["__iter__"], false]
    - ["th2431022", "threading.Event.__dict__.__contains__", ["__next__"], false]
    - ["th2431023", "threading.Barrier.__dict__.__contains__", ["__iter__"], false]
    - ["th2431024", "threading.Barrier.__dict__.__contains__", ["__next__"], false]
