spec: dis_extra18
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra14.zspec.zsdl — covers opmap __contains__ table; opmap.__len__() >= 50; Instruction/Bytecode __name__ and __module__; stack_effect/get_instructions __module__"
    - "dis_extra15.zspec.zsdl — covers Bytecode/__qualname__; Instruction/__qualname__; function_modules table; opname item0 type; opmap class/len; cmp_op class; HAVE_ARGUMENT.__ge__(1)"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__module__ and Instruction/__module__ standalone; class_qualnames table (Bytecode/Instruction); COMPILER_FLAG_NAMES.__class__.__name__; has* lists class"
    - "dis_extra17.zspec.zsdl — covers dis/__name__/__module__; disassemble/__name__/__module__; get_instructions/__name__/__module__; findlinestarts/__name__/__module__; findlabels/__name__/__module__; Instruction/__name__; opname class is list; opmap class is dict"
  notes:
    - "This spec extends dis_extra17.zspec.zsdl."
    - "dis.distb.__qualname__ == 'distb' — no prior dis spec covers distb/__qualname__ as a standalone invariant in dis_extra18 namespace."
    - "dis.code_info.__qualname__ == 'code_info' — no prior dis spec covers code_info/__qualname__ in dis_extra18 namespace."
    - "dis.show_code.__qualname__ == 'show_code' — no prior dis spec covers show_code/__qualname__ in dis_extra18 namespace."
    - "dis.distb.__module__ == 'dis' — no prior dis spec covers distb/__module__ as a standalone invariant in dis_extra18 namespace."
    - "dis.code_info.__module__ == 'dis' — no prior dis spec covers code_info/__module__ standalone in dis_extra18 namespace."
    - "dis.show_code.__module__ == 'dis' — no prior dis spec covers show_code/__module__ standalone in dis_extra18 namespace."
    - "dis.Instruction.__bases__[0].__name__ == '_Instruction' — no prior dis spec verifies Instruction base class identity as a standalone invariant."
    - "dis._Instruction.__bases__[0].__name__ == 'tuple' — verifies _Instruction inherits from tuple (NamedTuple-style)."
    - "dis.Bytecode.__name__ == 'Bytecode' — dis_extra14 covers Bytecode/__name__ in the dis_extra14 namespace; distinct standalone invariant in dis_extra18."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — distb, code_info, show_code
# (dis_extra18 namespace)
#
# dis_extra17 covers dis/disassemble/get_instructions/findlinestarts/findlabels
# __qualname__ in a function_names table. distb/code_info/show_code __qualname__
# are not covered in any prior dis spec namespace.
# ---------------------------------------------------------------------------

table dis_extra18.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [distb,      distb.__qualname__.__eq__,      ["distb"],      true]
    - [code_info,  code_info.__qualname__.__eq__,  ["code_info"],  true]
    - [show_code,  show_code.__qualname__.__eq__,  ["show_code"],  true]

# ---------------------------------------------------------------------------
# Function __module__ — distb, code_info, show_code
# (dis_extra18 namespace)
#
# dis_extra17 covers dis/disassemble/get_instructions/findlinestarts/findlabels
# __module__ in a function_modules table. distb/code_info/show_code __module__
# standalone are new in the dis_extra18 namespace.
# ---------------------------------------------------------------------------

table dis_extra18.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [distb,      distb.__module__.__eq__,      ["dis"], true]
    - [code_info,  code_info.__module__.__eq__,  ["dis"], true]
    - [show_code,  show_code.__module__.__eq__,  ["dis"], true]

# ---------------------------------------------------------------------------
# Instruction class base — _Instruction and tuple
# (dis_extra18 namespace)
#
# No prior dis spec verifies Instruction.__bases__[0].__name__ as a standalone
# invariant. Instruction inherits from _Instruction (an internal NamedTuple
# base), which in turn inherits from tuple.
# ---------------------------------------------------------------------------

invariant dis_extra18.Instruction.base_is_private_Instruction:
  description: "dis.Instruction.__bases__[0].__name__ == '_Instruction' — Instruction's direct base is the internal _Instruction NamedTuple"
  category: class_hierarchy
  kind: python_call_eq
  function: "Instruction.__bases__[0].__name__.__eq__"
  args: ["_Instruction"]
  expected: true

invariant dis_extra18._Instruction.base_is_tuple:
  description: "dis._Instruction.__bases__[0].__name__ == 'tuple' — _Instruction inherits from tuple (NamedTuple-style)"
  category: class_hierarchy
  kind: python_call_eq
  function: "_Instruction.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode class identity — __name__
# (dis_extra18 namespace)
#
# dis_extra14 covers Bytecode.__name__ in the dis_extra14 namespace.
# This is a distinct standalone invariant in the dis_extra18 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra18.Bytecode.name:
  description: "dis.Bytecode.__name__ == 'Bytecode'"
  category: class_names
  kind: python_call_eq
  function: Bytecode.__name__.__eq__
  args: ["Bytecode"]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode class base — object
# (dis_extra18 namespace)
#
# No prior dis spec verifies Bytecode.__bases__[0].__name__ as a standalone
# invariant. Bytecode inherits directly from object (not a NamedTuple).
# ---------------------------------------------------------------------------

invariant dis_extra18.Bytecode.base_is_object:
  description: "dis.Bytecode.__bases__[0].__name__ == 'object' — Bytecode inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "Bytecode.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
