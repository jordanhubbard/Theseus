spec: sys_rust
version: ">=3.9"
backend: rust_module(sys_rust)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python sys module constants, exposed via PyO3."
    - "Exposes stable, platform-invariant constants from sys."
    - "version_info[0] == 3 — always Python 3 for Python 3.x."
    - "len(version_info) == 5 — (major, minor, micro, releaselevel, serial)."
    - "maxsize == 9223372036854775807 — 2^63-1 on 64-bit platforms."
    - "float_info.dig == 15 — IEEE 754 double significant decimal digits."
    - "float_info.mant_dig == 53 — IEEE 754 double mantissa bits."
    - "byteorder == 'little' on x86/x86_64 (little-endian)."
    - "All test vectors verified against Python 3.14.3 sys module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# version_info — Python version tuple
invariant sys_rust.version_info.major:
  description: "sys.version_info[0] == 3 (Python 3.x)"
  category: version_info
  kind: python_call_eq
  function: version_info.__getitem__
  args: [0]
  expected: 3

invariant sys_rust.version_info.len:
  description: "len(sys.version_info) == 5"
  category: version_info
  kind: python_call_eq
  function: version_info.__len__
  args: []
  expected: 5

# maxsize — platform integer size
invariant sys_rust.maxsize:
  description: "sys.maxsize == 9223372036854775807 (2^63-1 on 64-bit)"
  category: maxsize
  kind: python_call_eq
  function: maxsize.__eq__
  args: [9223372036854775807]
  expected: true

# float_info — IEEE 754 double precision constants
invariant sys_rust.float_info.dig:
  description: "sys.float_info.dig == 15 (decimal digits of precision)"
  category: float_info
  kind: python_call_eq
  function: float_info.__getattribute__
  args: ["dig"]
  expected: 15

invariant sys_rust.float_info.mant_dig:
  description: "sys.float_info.mant_dig == 53 (binary mantissa digits)"
  category: float_info
  kind: python_call_eq
  function: float_info.__getattribute__
  args: ["mant_dig"]
  expected: 53

# byteorder — byte order string
invariant sys_rust.byteorder:
  description: "sys.byteorder == 'little' on x86/x86_64"
  category: byteorder
  kind: python_call_eq
  function: byteorder.__eq__
  args: ["little"]
  expected: true

