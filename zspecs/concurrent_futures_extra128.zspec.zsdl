# ---------------------------------------------------------------------------
# BrokenThreadPool vs BrokenProcessPool comparison — extra128
#
# BrokenThreadPool.__name__.__len__() == 16  ('Thread'=6 vs 'Process'=7)
# BrokenProcessPool.__name__.__len__() == 17
# Both __mro__.__len__() == 6
# Both __bases__[0].__name__ == 'BrokenExecutor'
# BrokenThreadPool.__module__.__len__() == 25  (cf.thread, len=25)
# BrokenProcessPool.__module__.__len__() == 26  (cf.process, len=26)
# ---------------------------------------------------------------------------

table concurrent_futures_extra128.cf_broken_pool_comparison:
  description: "BrokenThreadPool vs BrokenProcessPool comparative checks in cfbroken128 namespace — wave 255 theme: both BrokenThreadPool and BrokenProcessPool inherit from BrokenExecutor and share 6-element MROs; BrokenThreadPool.__name__.__len__()==16 vs BrokenProcessPool.__name__.__len__()==17 (one char difference due to 'Thread'=6 vs 'Process'=7); BrokenThreadPool.__module__.__len__()==25 vs BrokenProcessPool.__module__.__len__()==26 (one char difference: 'thread'=6 vs 'process'=7); both have __class__.__name__=='type'; both have __bases__[0].__name__=='BrokenExecutor' (neither inherits directly from RuntimeError); the symmetry in design reflects that ThreadPoolExecutor and ProcessPoolExecutor share the same BrokenExecutor base for their broken-pool exceptions; BrokenExecutor itself inherits from RuntimeError (module='concurrent.futures._base'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbroken128b

  columns: [id, function, args, expected, description]
  rows:
    - [btp_nm_len16,   "concurrent.futures.thread.BrokenThreadPool.__name__.__len__",               [],   16,   "BrokenThreadPool.__name__.__len__() == 16 ('Broken'=6+'Thread'=6+'Pool'=4); verified with Python 3.14.3"]
    - [bpp_nm_len17,   "concurrent.futures.process.BrokenProcessPool.__name__.__len__",             [],   17,   "BrokenProcessPool.__name__.__len__() == 17 ('Broken'=6+'Process'=7+'Pool'=4); verified with Python 3.14.3"]
    - [btp_mod_len25,  "concurrent.futures.thread.BrokenThreadPool.__module__.__len__",             [],   25,   "BrokenThreadPool.__module__.__len__() == 25 ('concurrent.futures.thread'); verified with Python 3.14.3"]
    - [bpp_mod_len26,  "concurrent.futures.process.BrokenProcessPool.__module__.__len__",           [],   26,   "BrokenProcessPool.__module__.__len__() == 26 ('concurrent.futures.process'); verified with Python 3.14.3"]
    - [btp_mro6,       "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__",                [],   6,    "BrokenThreadPool.__mro__.__len__() == 6 (full exception hierarchy depth); verified with Python 3.14.3"]
    - [bpp_mro6,       "concurrent.futures.process.BrokenProcessPool.__mro__.__len__",              [],   6,    "BrokenProcessPool.__mro__.__len__() == 6 (same depth as BrokenThreadPool); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra128
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra128.BrokenThreadPool_mro_len_is_6:
  description: "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__() == 6 — BrokenThreadPool's MRO is [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]; this 6-element chain is much deeper than typical class hierarchies like asyncio.Task (MRO len=3) or multiprocessing.queues.JoinableQueue (MRO len=3); the depth arises because BrokenExecutor inherits from RuntimeError, which inherits from Exception, which inherits from BaseException; BrokenThreadPool.__bases__[0].__name__ is 'BrokenExecutor' (not 'RuntimeError'); BrokenThreadPool.__module__ is 'concurrent.futures.thread' (len=25); NEW in extra128: first standalone BrokenThreadPool MRO length invariant in cfbroken128 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__"
  args: []
  expected: 6

invariant concurrent_futures_extra128.BrokenProcessPool_mro_len_is_6:
  description: "concurrent.futures.process.BrokenProcessPool.__mro__.__len__() == 6 — BrokenProcessPool's MRO is [BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]; same 6-element depth as BrokenThreadPool — both exception classes share the identical MRO structure differing only in the first element (BrokenThreadPool vs BrokenProcessPool); BrokenProcessPool.__module__ is 'concurrent.futures.process' (len=26, one char longer than BrokenThreadPool's module len=25); BrokenProcessPool.__name__.__len__() is 17 (one more than BrokenThreadPool's 16); NEW in extra128: first standalone BrokenProcessPool MRO length invariant in cfbroken128 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.process.BrokenProcessPool.__mro__.__len__"
  args: []
  expected: 6

invariant concurrent_futures_extra128.BrokenThreadPool_base_is_BrokenExecutor:
  description: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor') returns True — BrokenThreadPool inherits from BrokenExecutor (defined in concurrent.futures._base), not directly from RuntimeError; BrokenExecutor itself inherits from RuntimeError, which is why BrokenThreadPool's MRO includes RuntimeError, Exception, and BaseException; BrokenExecutor.__module__ is 'concurrent.futures._base'; the BrokenExecutor parent is shared by both BrokenThreadPool (thread.py) and BrokenProcessPool (process.py) — a single common base class for broken-executor exceptions; BrokenThreadPool.__name__.__len__() is 16; NEW in extra128: first standalone BrokenThreadPool base class invariant in cfbroken128 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra128.BrokenProcessPool_name_len_is_17:
  description: "concurrent.futures.process.BrokenProcessPool.__name__.__len__() == 17 — BrokenProcessPool.__name__ is 'BrokenProcessPool' (17 chars: 'Broken'=6 + 'Process'=7 + 'Pool'=4); this is one char longer than BrokenThreadPool.__name__.__len__()==16 ('Broken'=6+'Thread'=6+'Pool'=4) because 'Process' has 7 chars while 'Thread' has 6; BrokenProcessPool.__module__ is 'concurrent.futures.process' (len=26, also one char longer than BrokenThreadPool's module len=25); both classes share 6-element MROs and BrokenExecutor as their direct parent; NEW in extra128: first standalone BrokenProcessPool name length invariant in cfbroken128 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.process.BrokenProcessPool.__name__.__len__"
  args: []
  expected: 17

invariant concurrent_futures_extra128.BrokenProcessPool_base_is_BrokenExecutor:
  description: "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor') returns True — BrokenProcessPool inherits from BrokenExecutor (defined in concurrent.futures._base), the same parent as BrokenThreadPool; the design symmetry means both broken-pool exception classes go through the shared BrokenExecutor base; BrokenExecutor.__bases__[0].__name__ is 'RuntimeError' (BrokenExecutor inherits from RuntimeError, giving all broken-pool exceptions the 6-element MRO); BrokenProcessPool.__name__.__len__() is 17; BrokenProcessPool.__module__ is 'concurrent.futures.process' (len=26); NEW in extra128: first standalone BrokenProcessPool base class invariant in cfbroken128 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true

