    - [btp_mro_len,    "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__",                [],                            6,    "BrokenThreadPool.__mro__.__len__() == 6 — [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]
