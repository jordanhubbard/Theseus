spec: concurrent_futures_extra128
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: wave 255 theme — concurrent.futures BrokenThreadPool and BrokenProcessPool class identity. NEW in extra128: concurrent.futures.thread.BrokenThreadPool.__name__=='BrokenThreadPool' (len=16); concurrent.futures.thread.BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25); concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor'; concurrent.futures.thread.BrokenThreadPool.__mro__.__len__()==6 (MRO=[BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]); concurrent.futures.process.BrokenProcessPool.__name__=='BrokenProcessPool' (len=17); concurrent.futures.process.BrokenProcessPool.__module__=='concurrent.futures.process' (len=26); concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor'; concurrent.futures.process.BrokenProcessPool.__mro__.__len__()==6 (same 6-element chain). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__() == 6. MRO is [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object] — six elements because BrokenExecutor inherits from RuntimeError, which itself has the full exception hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'. BrokenThreadPool inherits from BrokenExecutor (defined in concurrent.futures._base), not directly from RuntimeError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.process.BrokenProcessPool.__name__.__len__() == 17. 'BrokenProcessPool' is 17 chars: 'Broken'=6 + 'Process'=7 + 'Pool'=4, one char longer than BrokenThreadPool (len=16: 'Broken'=6+'Thread'=6+'Pool'=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread.BrokenThreadPool class identity — extra128
#
# Wave 255 theme: BrokenThreadPool and BrokenProcessPool class identity.
#
# concurrent.futures.thread.BrokenThreadPool.__name__               == 'BrokenThreadPool'          (len=16)
# concurrent.futures.thread.BrokenThreadPool.__module__             == 'concurrent.futures.thread'  (len=25)
# concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__  == 'BrokenExecutor'
# concurrent.futures.thread.BrokenThreadPool.__mro__.__len__()      == 6
# concurrent.futures.thread.BrokenThreadPool.__qualname__           == 'BrokenThreadPool'
# concurrent.futures.thread.BrokenThreadPool.__class__.__name__     == 'type'
# ---------------------------------------------------------------------------

table concurrent_futures_extra128.cf_broken_thread_pool_identity:
  description: "concurrent.futures.thread.BrokenThreadPool class identity checks in cfbroken128 namespace — wave 255 theme: BrokenThreadPool and BrokenProcessPool class identity; concurrent.futures.thread.BrokenThreadPool.__name__.__eq__('BrokenThreadPool')==True (len=16: 'Broken'=6+'Thread'=6+'Pool'=4); concurrent.futures.thread.BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent.futures.'=19+'thread'=6; defined in Lib/concurrent/futures/thread.py); concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True (BrokenThreadPool inherits from BrokenExecutor, not directly from RuntimeError; BrokenExecutor is defined in concurrent.futures._base); concurrent.futures.thread.BrokenThreadPool.__mro__.__len__()==6 (MRO is [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object] — six elements due to the full exception hierarchy from RuntimeError); concurrent.futures.thread.BrokenThreadPool.__qualname__.__eq__('BrokenThreadPool')==True (len=16, module-level class); concurrent.futures.thread.BrokenThreadPool.__class__.__name__.__eq__('type')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbroken128

