table concurrent_futures_extra128.cf_broken_process_pool_identity:
  description: "concurrent.futures.process.BrokenProcessPool class identity checks in cfbroken128 namespace — wave 255 theme: concurrent.futures.process.BrokenProcessPool.__name__.__eq__('BrokenProcessPool')==True (len=17: 'Broken'=6+'Process'=7+'Pool'=4, one char longer than BrokenThreadPool len=16 because 'Process'=7 vs 'Thread'=6); concurrent.futures.process.BrokenProcessPool.__module__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent.futures.'=19+'process'=7; one char longer than the thread module len=25); concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True (same parent class as BrokenThreadPool; BrokenExecutor defined in concurrent.futures._base); concurrent.futures.process.BrokenProcessPool.__mro__.__len__()==6 (same 6-element MRO as BrokenThreadPool: [BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]); concurrent.futures.process.BrokenProcessPool.__qualname__.__eq__('BrokenProcessPool')==True (len=17); concurrent.futures.process.BrokenProcessPool.__class__.__name__.__eq__('type')==True; verified with Python 3.14.3"
