spec: concurrent_futures_extra272
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in the process submodule."
    - "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — direct subclass of Executor."
    - "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' — overrides Executor.submit."
    - "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' — overrides Executor.map."
    - "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' — overrides Executor.shutdown."
    - "ThreadPoolExecutor.map inherits from Executor and does NOT override it — __qualname__ == 'Executor.map'."
    - "concurrent.futures.CancelledError MRO is: CancelledError -> Error -> Exception -> BaseException -> object (depth 5)."
    - "CancelledError.__bases__[0].__name__ == 'Error' — the private _base.Error intermediate class."
    - "Error.__bases__[0].__name__ == 'Exception' — Error inherits from Exception."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ProcessPoolExecutor class identity and method qualnames — table
#
# ProcessPoolExecutor lives in concurrent.futures.process and overrides
# submit, map, and shutdown from the Executor base class.
# ---------------------------------------------------------------------------

table concurrent_futures_extra272.process_pool_executor_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity and method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: ppeid

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name,          ProcessPoolExecutor.__name__.__eq__,             ["ProcessPoolExecutor"],          true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'"]
    - [ppe_module,        ProcessPoolExecutor.__module__.__eq__,           ["concurrent.futures.process"],   true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"]
    - [ppe_submit_name,   ProcessPoolExecutor.submit.__name__.__eq__,      ["submit"],                       true, "ProcessPoolExecutor.submit.__name__ == 'submit'"]
    - [ppe_submit_qn,     ProcessPoolExecutor.submit.__qualname__.__eq__,  ["ProcessPoolExecutor.submit"],   true, "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'"]
    - [ppe_map_name,      ProcessPoolExecutor.map.__name__.__eq__,         ["map"],                          true, "ProcessPoolExecutor.map.__name__ == 'map'"]
    - [ppe_map_qn,        ProcessPoolExecutor.map.__qualname__.__eq__,     ["ProcessPoolExecutor.map"],      true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map'"]
    - [ppe_shutdown_name, ProcessPoolExecutor.shutdown.__name__.__eq__,    ["shutdown"],                     true, "ProcessPoolExecutor.shutdown.__name__ == 'shutdown'"]
    - [ppe_shutdown_qn,   ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"], true, "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'"]

# ---------------------------------------------------------------------------
# CancelledError inheritance chain — table
#
# concurrent.futures.CancelledError MRO depth is 5:
# CancelledError -> Error -> Exception -> BaseException -> object
# ---------------------------------------------------------------------------

table concurrent_futures_extra272.cancelled_error_chain:
  description: "concurrent.futures.CancelledError inheritance chain identity"
  kind: python_call_eq
  category: identity
  id_prefix: ceid

  columns: [id, function, args, expected, description]
  rows:
    - [ce_name,    CancelledError.__name__.__eq__,                  ["CancelledError"],             true, "CancelledError.__name__ == 'CancelledError'"]
    - [ce_module,  CancelledError.__module__.__eq__,                ["concurrent.futures._base"],   true, "CancelledError.__module__ == 'concurrent.futures._base'"]
    - [ce_base0,   "CancelledError.__bases__[0].__name__.__eq__",   ["Error"],                      true, "CancelledError.__bases__[0].__name__ == 'Error'"]
    - [ce_base1,   "CancelledError.__mro__[2].__name__.__eq__",     ["Exception"],                  true, "CancelledError.__mro__[2].__name__ == 'Exception'"]
    - [ce_base2,   "CancelledError.__mro__[3].__name__.__eq__",     ["BaseException"],              true, "CancelledError.__mro__[3].__name__ == 'BaseException'"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor base class — standalone invariant
#
# ProcessPoolExecutor inherits directly from Executor.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra272.ProcessPoolExecutor.bases0_name:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError MRO depth — standalone invariant
#
# The MRO has 5 entries: CancelledError, Error, Exception, BaseException, object.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra272.CancelledError.mro_depth:
  description: "len(concurrent.futures.CancelledError.__mro__) == 5"
  category: identity
  kind: python_call_eq
  function: CancelledError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.map inherits from Executor — standalone invariant
#
# ThreadPoolExecutor does NOT override map; its map.__qualname__ == 'Executor.map'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra272.ThreadPoolExecutor.map_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (inherited)"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor class identity — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra272.ThreadPoolExecutor.module:
  description: "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra272.ThreadPoolExecutor.bases0_name:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra272.ThreadPoolExecutor.submit_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra272.ThreadPoolExecutor.shutdown_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true
