spec: pickle_extra16
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra15.zspec.zsdl."
    - "pickle_extra15 covers: pickle.__package__; PickleError/PicklingError/UnpicklingError __qualname__.__class__.__name__; Pickler/__qualname__.__class__.__name__; Unpickler/__qualname__.__class__.__name__."
    - "pickle_extra14 covers: Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; loads/__qualname__; load/__qualname__; dump/__qualname__."
    - "pickle_extra12 covers: Pickler/__module__; Unpickler/__module__ (both == '_pickle')."
    - "Focus: __qualname__ for Pickler and Unpickler methods — dump, persistent_id, load, find_class."
    - "No prior pickle spec checks Pickler.dump.__qualname__."
    - "No prior pickle spec checks Pickler.persistent_id.__qualname__."
    - "No prior pickle spec checks Unpickler.load.__qualname__."
    - "No prior pickle spec checks Unpickler.find_class.__qualname__."
    - "pickle.Pickler.dump.__qualname__ == 'Pickler.dump' — C-accelerated method; qualname is compound dotted name."
    - "pickle.Pickler.persistent_id.__qualname__ == 'Pickler.persistent_id' — compound qualname for the persistent_id descriptor."
    - "pickle.Unpickler.load.__qualname__ == 'Unpickler.load' — C-accelerated method; compound dotted name."
    - "pickle.Unpickler.find_class.__qualname__ == 'Unpickler.find_class' — compound qualname for find_class method."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler method __qualname__ values
#
# pickle_extra14 checks Pickler.__qualname__ == 'Pickler' for the class.
# No prior pickle spec checks __qualname__ for any method or descriptor of
# Pickler. For a C-accelerated method in class Pickler, __qualname__ uses the
# compound dotted form 'Pickler.method'.
# ---------------------------------------------------------------------------

invariant pickle_extra16.Pickler.dump.qualname:
  description: "pickle.Pickler.dump.__qualname__ == 'Pickler.dump' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Pickler.dump.__qualname__.__eq__
  args: ["Pickler.dump"]
  expected: true

invariant pickle_extra16.Pickler.persistent_id.qualname:
  description: "pickle.Pickler.persistent_id.__qualname__ == 'Pickler.persistent_id' — compound descriptor qualname"
  category: method_attrs
  kind: python_call_eq
  function: Pickler.persistent_id.__qualname__.__eq__
  args: ["Pickler.persistent_id"]
  expected: true

# ---------------------------------------------------------------------------
# Unpickler method __qualname__ values
#
# pickle_extra14 checks Unpickler.__qualname__ == 'Unpickler' for the class.
# No prior pickle spec checks __qualname__ for any method of Unpickler.
# ---------------------------------------------------------------------------

invariant pickle_extra16.Unpickler.load.qualname:
  description: "pickle.Unpickler.load.__qualname__ == 'Unpickler.load' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Unpickler.load.__qualname__.__eq__
  args: ["Unpickler.load"]
  expected: true

invariant pickle_extra16.Unpickler.find_class.qualname:
  description: "pickle.Unpickler.find_class.__qualname__ == 'Unpickler.find_class' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Unpickler.find_class.__qualname__.__eq__
  args: ["Unpickler.find_class"]
  expected: true

# ---------------------------------------------------------------------------
# Pickler and Unpickler method __qualname__ table
#
# Consolidates all four method qualname checks into a single table.
# All four are first covered in this spec (pickle_extra16).
# ---------------------------------------------------------------------------

table pickle_extra16.method_qualnames:
  description: "pickle Pickler/Unpickler method __qualname__ — compound dotted names"
  kind: python_call_eq
  category: method_attrs
  id_prefix: pmq16

  columns: [id, function, args, expected]
  rows:
    - [Pickler_dump_qn,           Pickler.dump.__qualname__.__eq__,           ["Pickler.dump"],           true]
    - [Pickler_persistent_id_qn,  Pickler.persistent_id.__qualname__.__eq__,  ["Pickler.persistent_id"],  true]
    - [Unpickler_load_qn,         Unpickler.load.__qualname__.__eq__,         ["Unpickler.load"],         true]
    - [Unpickler_find_class_qn,   Unpickler.find_class.__qualname__.__eq__,   ["Unpickler.find_class"],   true]
