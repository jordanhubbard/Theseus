spec: uuid_extra1816
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "uuid module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party uuid library"
  notes:
    - "Tests __format__, __repr__, __str__ presence in uuid.UUID and uuid.SafeUUID __dict__"
    - "Tests __reduce__, __copy__, __deepcopy__, __getstate__, __setstate__ for copy/pickle protocol"
    - "Tests uuid module-level factory functions and constants"
  created_at: "2026-04-12"

table uuid_extra1816.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1816-fp-001", "uuid.UUID.__dict__.__contains__", ["__format__"], true]
    - ["uu1816-fp-002", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]
    - ["uu1816-fp-003", "uuid.UUID.__dict__.__contains__", ["__str__"], true]
    - ["uu1816-fp-004", "uuid.SafeUUID.__dict__.__contains__", ["__format__"], false]
    - ["uu1816-fp-005", "uuid.SafeUUID.__dict__.__contains__", ["__repr__"], false]
    - ["uu1816-fp-006", "uuid.SafeUUID.__dict__.__contains__", ["__str__"], false]

table uuid_extra1816.copy_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1816-cp-001", "uuid.UUID.__dict__.__contains__", ["__reduce__"], false]
    - ["uu1816-cp-002", "uuid.UUID.__dict__.__contains__", ["__copy__"], false]
    - ["uu1816-cp-003", "uuid.UUID.__dict__.__contains__", ["__deepcopy__"], false]
    - ["uu1816-cp-004", "uuid.UUID.__dict__.__contains__", ["__getstate__"], false]
    - ["uu1816-cp-005", "uuid.UUID.__dict__.__contains__", ["__setstate__"], false]
    - ["uu1816-cp-006", "uuid.SafeUUID.__dict__.__contains__", ["__reduce__"], false]
    - ["uu1816-cp-007", "uuid.SafeUUID.__dict__.__contains__", ["__copy__"], false]
    - ["uu1816-cp-008", "uuid.SafeUUID.__dict__.__contains__", ["__deepcopy__"], false]

table uuid_extra1816.uuid_factory_functions:
  columns: [id, function, args, expected]
  rows:
    - ["uu1816-ff-001", "uuid.__dict__.__contains__", ["uuid1"], true]
    - ["uu1816-ff-002", "uuid.__dict__.__contains__", ["uuid3"], true]
    - ["uu1816-ff-003", "uuid.__dict__.__contains__", ["uuid4"], true]
    - ["uu1816-ff-004", "uuid.__dict__.__contains__", ["uuid5"], true]
    - ["uu1816-ff-005", "uuid.__dict__.__contains__", ["UUID"], true]
    - ["uu1816-ff-006", "uuid.__dict__.__contains__", ["SafeUUID"], true]
    - ["uu1816-ff-007", "uuid.__dict__.__contains__", ["NAMESPACE_DNS"], true]
    - ["uu1816-ff-008", "uuid.__dict__.__contains__", ["NAMESPACE_URL"], true]
    - ["uu1816-ff-009", "uuid.__dict__.__contains__", ["NAMESPACE_OID"], true]
    - ["uu1816-ff-010", "uuid.__dict__.__contains__", ["NAMESPACE_X500"], true]
