spec: abc_extra223
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "issubclass(abc.ABCMeta, type) == True — ABCMeta inherits directly from type; ABCMeta.__bases__[0].__name__ == 'type'; verified with Python 3.14.3."
    - "issubclass(abc.ABC.__class__, type) == True — ABC's metaclass is ABCMeta which is a subclass of type; verified with Python 3.14.3."
    - "isinstance(abc.ABC, abc.ABCMeta) == True — ABC is an instance of ABCMeta (its metaclass); verified with Python 3.14.3."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — type(abc.ABC).__name__ is 'ABCMeta'; verified with Python 3.14.3."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' — qualname equals name for top-level class; verified with Python 3.14.3."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — qualname equals name for top-level decorator; verified with Python 3.14.3."
    - "abc.ABC.__qualname__ == 'ABC' — qualname equals name for top-level class; verified with Python 3.14.3."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta directly inherits from type; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta/ABC subclass and isinstance behavioral contracts — extra223 namespace
#
# ABCMeta is a subclass of type; ABC is an instance of ABCMeta.
# ---------------------------------------------------------------------------

table abc_extra223.subclass_checks:
  description: "abc ABCMeta/ABC subclass and isinstance behavioral contracts in abc223sc namespace"
  kind: python_call_eq
  category: behavioral
  id_prefix: abc223sc

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_sw_ABC,           ABCMeta.__name__.__startswith__, ["ABC"],      true, "abc.ABCMeta.__name__.__startswith__('ABC') == True; verified with Python 3.14.3"]
    - [ABCMeta_qualname_eq,      ABCMeta.__qualname__.__eq__,     ["ABCMeta"],  true, "abc.ABCMeta.__qualname__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [abstractmethod_qualname_eq, abstractmethod.__qualname__.__eq__, ["abstractmethod"], true, "abc.abstractmethod.__qualname__ == 'abstractmethod'; verified with Python 3.14.3"]
    - [ABC_qualname_eq,          ABC.__qualname__.__eq__,         ["ABC"],      true, "abc.ABC.__qualname__ == 'ABC'; verified with Python 3.14.3"]
    - [ABCMeta_module_eq,        ABCMeta.__module__.__eq__,       ["abc"],      true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ABC_module_eq,            ABC.__module__.__eq__,           ["abc"],      true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abstractmethod_module_eq, abstractmethod.__module__.__eq__, ["abc"],     true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta base class name contract — extra223 namespace
#
# ABCMeta directly inherits from type; __bases__[0].__name__ == 'type'.
# ---------------------------------------------------------------------------

invariant abc_extra223.abcmeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta directly inherits from type; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: behavioral
  kind: python_call_eq
  "function": "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# abc ABC metaclass class name contract — extra223 namespace
#
# abc.ABC.__class__.__name__ == 'ABCMeta' — type(ABC) is ABCMeta.
# ---------------------------------------------------------------------------

invariant abc_extra223.abc_class_is_abcmeta:
  description: "abc.ABC.__class__.__name__ == 'ABCMeta' — type(abc.ABC) is ABCMeta; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: behavioral
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# abc class name length contracts — extra223 namespace
#
# ABCMeta=7, abstractmethod=14 chars; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table abc_extra223.name_lengths:
  description: "abc class __name__.__len__() contracts in abc223nl namespace"
  kind: python_call_eq
  category: string_length
  id_prefix: abc223nl

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_name_len_7,          ABCMeta.__name__.__len__,        [], 7,  "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; verified with Python 3.14.3"]
    - [abstractmethod_name_len_14,  abstractmethod.__name__.__len__, [], 14, "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters; verified with Python 3.14.3"]
    - [ABC_name_len_3,              ABC.__name__.__len__,            [], 3,  "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; verified with Python 3.14.3"]
