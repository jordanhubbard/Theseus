spec: io_extra2116
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase, StringIO, BytesIO, FileIO are stream classes."
    - "None of these io classes define set/dict merge operators (__or__, __ror__, __ior__) in their own __dict__."
    - "None of these io classes define set-intersection operators (__and__, __rand__, __iand__) in their own __dict__."
    - "None of these io classes define set-symmetric-difference operators (__xor__, __rxor__, __ixor__) in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# None of the io stream classes define these operators
# ---------------------------------------------------------------------------

table io_extra2116.or_protocol:
  description: "io types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2116

  columns: [id, function, args, expected]
  rows:
    - ["io2116001", "io.IOBase.__dict__.__contains__",       ["__or__"],  false]
    - ["io2116002", "io.IOBase.__dict__.__contains__",       ["__ror__"], false]
    - ["io2116003", "io.IOBase.__dict__.__contains__",       ["__ior__"], false]
    - ["io2116004", "io.RawIOBase.__dict__.__contains__",    ["__or__"],  false]
    - ["io2116005", "io.RawIOBase.__dict__.__contains__",    ["__ror__"], false]
    - ["io2116006", "io.RawIOBase.__dict__.__contains__",    ["__ior__"], false]
    - ["io2116007", "io.BufferedIOBase.__dict__.__contains__", ["__or__"],  false]
    - ["io2116008", "io.BufferedIOBase.__dict__.__contains__", ["__ror__"], false]
    - ["io2116009", "io.BufferedIOBase.__dict__.__contains__", ["__ior__"], false]

