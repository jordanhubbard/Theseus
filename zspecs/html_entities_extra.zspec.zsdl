spec: html_entities_extra
version: ">=3.9"
backend: python_module(html.entities)

docs: https://docs.python.org/3/library/html.entities.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.entities.html — Python html.entities module documentation"
    - "https://html.spec.whatwg.org/multipage/named-character-references.html — HTML5 named character references"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/entities.py"
  notes:
    - "This spec extends html_entities.zspec.zsdl."
    - "html_entities.zspec.zsdl covers: module __name__, name2codepoint for amp/lt/gt/quot/nbsp, codepoint2name for cp38/60/62/34, entitydefs for amp/lt/gt, type checks for name2codepoint and html5, html5 for amp;/lt;/gt;."
    - "This spec adds: additional name2codepoint entries (copy, reg, euro, trade, mdash, ndash), additional codepoint2name entries (cp160/169/174/8364), additional entitydefs entries (quot, nbsp, copy), additional html5 entries (quot;/apos;/copy;/reg;/euro;/trade;), and dict-size invariants."
    - "html.entities.name2codepoint has 252 entries (HTML 4 entities)."
    - "html.entities.codepoint2name has 252 entries (inverse of name2codepoint)."
    - "html.entities.entitydefs has 252 entries."
    - "html.entities.html5 has 2231 entries (HTML5 named character references)."
    - "html5 keys always end with ';'; some entity names also have no-semicolon variants but those are separate keys."
    - "name2codepoint does NOT include 'apos' (that is an XML entity, not HTML 4)."
    - "codepoint 169 = '©' (COPYRIGHT SIGN), 174 = '®' (REGISTERED SIGN), 8364 = '€' (EURO SIGN)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name2codepoint — additional entity name to codepoint vectors
# (html_entities.zspec.zsdl covers amp/lt/gt/quot/nbsp)
# ---------------------------------------------------------------------------

table html_entities_extra.name2codepoint.additional:
  kind: python_call_eq
  category: name2codepoint
  id_prefix: name2cp_extra
  function: name2codepoint.__getitem__

  columns: [id, args, expected]
  rows:
    - [copy,  ["copy"],  169]
    - [reg,   ["reg"],   174]
    - [euro,  ["euro"],  8364]
    - [trade, ["trade"], 8482]
    - [mdash, ["mdash"], 8212]
    - [ndash, ["ndash"], 8211]

# ---------------------------------------------------------------------------
# codepoint2name — additional codepoint to entity name vectors
# (html_entities.zspec.zsdl covers cp38/cp60/cp62/cp34)
# ---------------------------------------------------------------------------

table html_entities_extra.codepoint2name.additional:
  kind: python_call_eq
  category: codepoint2name
  id_prefix: cp2name_extra

  columns: [id, function, args, expected]
  rows:
    - [cp160,  codepoint2name.__getitem__, [160],  "nbsp"]
    - [cp169,  codepoint2name.__getitem__, [169],  "copy"]
    - [cp174,  codepoint2name.__getitem__, [174],  "reg"]
    - [cp8364, codepoint2name.__getitem__, [8364], "euro"]

# ---------------------------------------------------------------------------
# entitydefs — additional entity name to single-character string vectors
# (html_entities.zspec.zsdl covers amp/lt/gt)
# ---------------------------------------------------------------------------

table html_entities_extra.entitydefs.additional:
  kind: python_call_eq
  category: entitydefs
  id_prefix: edef_extra
  function: entitydefs.__getitem__

  columns: [id, args, expected]
  rows:
    - [quot, ["quot"], "\""]
    - [copy, ["copy"], "©"]
    - [reg,  ["reg"],  "®"]

# ---------------------------------------------------------------------------
# html5 — additional HTML5 named character reference entries
# (html_entities.zspec.zsdl covers amp;/lt;/gt;)
# ---------------------------------------------------------------------------

table html_entities_extra.html5.additional:
  kind: python_call_eq
  category: html5
  id_prefix: html5_extra
  function: html5.__getitem__

  columns: [id, args, expected]
  rows:
    - [quot_semi,  ["quot;"],  "\""]
    - [apos_semi,  ["apos;"],  "'"]
    - [copy_semi,  ["copy;"],  "©"]
    - [reg_semi,   ["reg;"],   "®"]
    - [euro_semi,  ["euro;"],  "€"]
    - [trade_semi, ["trade;"], "™"]

# ---------------------------------------------------------------------------
# dict size invariants — pin the number of entries in each mapping
# ---------------------------------------------------------------------------

invariant html_entities_extra.name2codepoint.length:
  description: "len(html.entities.name2codepoint) == 252"
  category: types
  kind: python_call_eq
  function: name2codepoint.__len__
  args: []
  expected: 252

invariant html_entities_extra.codepoint2name.length:
  description: "len(html.entities.codepoint2name) == 252"
  category: types
  kind: python_call_eq
  function: codepoint2name.__len__
  args: []
  expected: 252

invariant html_entities_extra.entitydefs.length:
  description: "len(html.entities.entitydefs) == 252"
  category: types
  kind: python_call_eq
  function: entitydefs.__len__
  args: []
  expected: 252

invariant html_entities_extra.entitydefs.is_dict:
  description: "entitydefs.__class__.__name__ == 'dict'"
  category: types
  kind: python_call_eq
  function: entitydefs.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant html_entities_extra.codepoint2name.is_dict:
  description: "codepoint2name.__class__.__name__ == 'dict'"
  category: types
  kind: python_call_eq
  function: codepoint2name.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
