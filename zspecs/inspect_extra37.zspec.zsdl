spec: inspect_extra37
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra36.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty.__class__.__name__.__len__()==4; Parameter.POSITIONAL_ONLY/__class__.__name__.__len__()==14; _ParameterKind.__qualname__.__len__()==14; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; various field lengths; cleandoc/__name__.__len__()==8; formatannotation/__name__.__len__()==16; getattr_static/__name__.__len__()==14; classify_class_attrs/__name__.__len__()==20; CO_OPTIMIZED.__class__.__name__.__len__()==3."
    - "This spec covers: Signature.__init__.__qualname__.__len__() (18 — 'Signature.__init__'); Signature.bind.__qualname__.__len__() (14 — 'Signature.bind'); Signature.bind_partial.__qualname__.__len__() (22 — 'Signature.bind_partial'); Signature.replace.__qualname__.__len__() (17 — 'Signature.replace'); Parameter.__init__.__qualname__.__len__() (18 — 'Parameter.__init__'); Parameter.replace.__qualname__.__len__() (17 — 'Parameter.replace'); BoundArguments.apply_defaults.__qualname__.__len__() (29 — 'BoundArguments.apply_defaults', the longest qualname in the three core Signature-related classes); BoundArguments.args.__class__.__name__.__len__() (8 — 'property')."
    - "Key findings: inspect.Signature.__init__.__qualname__ is 'Signature.__init__' (18 chars) — 'Signature.' (10) plus '__init__' (8). inspect.Signature.bind.__qualname__ is 'Signature.bind' (14 chars) — the shortest Signature method qualname because 'bind' is only 4 chars. inspect.Signature.bind_partial.__qualname__ is 'Signature.bind_partial' (22 chars) — the longest Signature method qualname recorded here, because 'bind_partial' is 12 chars. inspect.BoundArguments.apply_defaults.__qualname__ is 'BoundArguments.apply_defaults' (29 chars) — the longest qualname across all three classes (Signature/Parameter/BoundArguments) recorded in this spec, because 'BoundArguments.' is 15 chars and 'apply_defaults' is 14 chars. inspect.BoundArguments.args is a property; its __class__.__name__ is 'property' (8 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signature method __qualname__.__len__() table — extra37 namespace
#
# inspect.Signature.__init__.__qualname__ is 'Signature.__init__' (18 chars).
# inspect.Signature.bind.__qualname__ is 'Signature.bind' (14 chars) — the
# shortest Signature method qualname because 'bind' is only 4 chars. inspect.
# Signature.bind_partial.__qualname__ is 'Signature.bind_partial' (22 chars)
# — the longest Signature method qualname, because 'bind_partial' is 12 chars.
# inspect.Signature.replace.__qualname__ is 'Signature.replace' (17 chars).
# No prior inspect spec records __qualname__.__len__() for Signature.__init__,
# Signature.bind, Signature.bind_partial, or Signature.replace as standalone
# values. These four are recorded together for the first time in the extra37
# namespace.
# ---------------------------------------------------------------------------

table inspect_extra37.signature_method_qualname_lengths:
  description: "inspect.Signature method __qualname__.__len__(): __init__(18), bind(14), bind_partial(22), replace(17)"
  kind: python_call_eq
  category: string_properties
  id_prefix: sigmethqlen37

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_init,
       Signature.__init__.__qualname__.__len__,
       [],
       18,
       "len(inspect.Signature.__init__.__qualname__) == 18 — 'Signature.__init__' ('Signature.' is 10 chars, '__init__' is 8 chars)"]
    - [Signature_bind,
       Signature.bind.__qualname__.__len__,
       [],
       14,
       "len(inspect.Signature.bind.__qualname__) == 14 — 'Signature.bind' (shortest Signature method qualname; 'bind' is only 4 chars)"]
    - [Signature_bind_partial,
       Signature.bind_partial.__qualname__.__len__,
       [],
       22,
       "len(inspect.Signature.bind_partial.__qualname__) == 22 — 'Signature.bind_partial' (longest Signature method qualname; 'bind_partial' is 12 chars)"]
    - [Signature_replace,
       Signature.replace.__qualname__.__len__,
       [],
       17,
       "len(inspect.Signature.replace.__qualname__) == 17 — 'Signature.replace' ('Signature.' is 10 chars, 'replace' is 7 chars)"]

# ---------------------------------------------------------------------------
# Parameter and BoundArguments method __qualname__.__len__() — extra37 namespace
#
# inspect.Parameter.__init__.__qualname__ is 'Parameter.__init__' (18 chars)
# — same length as Signature.__init__, because both classes have 9-char names
# and '__init__' is 8 chars (9+1+8==18). inspect.Parameter.replace.__qualname__
# is 'Parameter.replace' (17 chars) — same length as Signature.replace, again
# because both class names are 9 chars and 'replace' is 7 chars. inspect.
# BoundArguments.apply_defaults.__qualname__ is 'BoundArguments.apply_defaults'
# (29 chars) — the longest qualname across all three Signature-related classes
# recorded here, because 'BoundArguments.' is 15 chars and 'apply_defaults' is
# 14 chars. No prior inspect spec records these three values together in the
# extra37 namespace.
# ---------------------------------------------------------------------------

table inspect_extra37.parameter_boundargs_method_qualname_lengths:
  description: "inspect.Parameter and BoundArguments method __qualname__.__len__(): Parameter.__init__(18), Parameter.replace(17), BoundArguments.apply_defaults(29)"
  kind: python_call_eq
  category: string_properties
  id_prefix: paramboundqlen37

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_init,
       Parameter.__init__.__qualname__.__len__,
       [],
       18,
       "len(inspect.Parameter.__init__.__qualname__) == 18 — 'Parameter.__init__' (same length as Signature.__init__; both class names are 9 chars)"]
    - [Parameter_replace,
       Parameter.replace.__qualname__.__len__,
       [],
       17,
       "len(inspect.Parameter.replace.__qualname__) == 17 — 'Parameter.replace' (same length as Signature.replace; both class names are 9 chars)"]
    - [BoundArguments_apply_defaults,
       BoundArguments.apply_defaults.__qualname__.__len__,
       [],
       29,
       "len(inspect.BoundArguments.apply_defaults.__qualname__) == 29 — 'BoundArguments.apply_defaults' (longest qualname in the three Signature-related classes; 'BoundArguments.' is 15 chars, 'apply_defaults' is 14 chars)"]

# ---------------------------------------------------------------------------
# BoundArguments.args property class name — extra37 standalone invariant
#
# inspect.BoundArguments.args is a property descriptor. Its __class__.__name__
# is 'property' (8 chars), confirming that BoundArguments.args is implemented
# via Python's built-in property mechanism (not a plain attribute or a
# custom descriptor). The same holds for Signature.parameters and
# Signature.return_annotation — all three are properties. No prior inspect
# spec records BoundArguments.args.__class__.__name__.__len__() == 8 in the
# extra37 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra37.BoundArguments_args_property_class_name_len:
  description: "len(inspect.BoundArguments.args.__class__.__name__) == 8 — 'property' (BoundArguments.args is a built-in property descriptor, not a plain attribute)"
  category: string_properties
  kind: python_call_eq
  function: BoundArguments.args.__class__.__name__.__len__
  args: []
  expected: 8
