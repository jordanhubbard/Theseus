spec: concurrent_futures_extra197
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for eight concurrent.futures members: Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor, TimeoutError, BrokenExecutor, as_completed, wait."
    - "concurrent.futures.Future.__doc__.__class__.__name__ == 'str' (len=3) — Future has a non-None docstring. Verified with Python 3.14.3."
    - "concurrent.futures.Executor.__doc__.__class__.__name__ == 'str' (len=3) — Executor has a non-None docstring. Verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__ == 'NoneType' (len=8) — ThreadPoolExecutor.__doc__ is None in Python 3.14.3; __doc__.__class__ is NoneType. Verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__ == 'NoneType' (len=8) — ProcessPoolExecutor.__doc__ is None in Python 3.14.3; __doc__.__class__ is NoneType. Verified with Python 3.14.3."
    - "concurrent.futures.TimeoutError.__doc__.__class__.__name__ == 'str' (len=3) — TimeoutError has a non-None docstring. Verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__doc__.__class__.__name__ == 'str' (len=3) — BrokenExecutor has a non-None docstring. Verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__doc__.__class__.__name__ == 'str' (len=3) — as_completed has a non-None docstring. Verified with Python 3.14.3."
    - "concurrent.futures.wait.__doc__.__class__.__name__ == 'str' (len=3) — wait has a non-None docstring. Verified with Python 3.14.3."
    - "ThreadPoolExecutor and ProcessPoolExecutor are the two members with None __doc__ in Python 3.14.3; their __doc__.__class__.__name__ is 'NoneType' (len=8)."
    - "No prior concurrent.futures spec covers the __doc__.__class__.__name__ attribute path for any member."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures Future and Executor __doc__.__class__.__name__
#
# concurrent.futures.Future.__doc__.__class__.__name__ == 'str' (len=3)
# concurrent.futures.Executor.__doc__.__class__.__name__ == 'str' (len=3)
#
# Future and Executor are the two base abstractions in concurrent.futures.
# Both have non-None str docstrings. New to concurrent_futures_extra197.
# ---------------------------------------------------------------------------

table concurrent_futures_extra197.future_executor_doc_class_names:
  description: "cf.Future and cf.Executor __doc__.__class__.__name__ == 'str'; both have str docstrings; new to concurrent_futures_extra197"
  kind: python_call_eq
  category: doc_identity
  id_prefix: cfdocs197

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_class_name_eq_str,
       "Future.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "cf.Future.__doc__.__class__.__name__.__eq__('str') == True — Future has a non-None str docstring; new to concurrent_futures_extra197"]
    - [future_doc_class_name_len_eq_3,
       "Future.__doc__.__class__.__name__.__len__",
       [],
       3,
       "cf.Future.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to concurrent_futures_extra197"]
    - [executor_doc_class_name_eq_str,
       "Executor.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "cf.Executor.__doc__.__class__.__name__.__eq__('str') == True — Executor has a non-None str docstring; new to concurrent_futures_extra197"]
    - [executor_doc_class_name_len_eq_3,
       "Executor.__doc__.__class__.__name__.__len__",
       [],
       3,
       "cf.Executor.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to concurrent_futures_extra197"]

# ---------------------------------------------------------------------------
# Table 2: ThreadPoolExecutor and ProcessPoolExecutor __doc__.__class__.__name__
#
# concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__ == 'NoneType' (len=8)
# concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__ == 'NoneType' (len=8)
#
# Both concrete executor subclasses have __doc__ == None in Python 3.14.3.
# The type of None is NoneType, so __doc__.__class__.__name__ == 'NoneType'.
# New to concurrent_futures_extra197.
# ---------------------------------------------------------------------------

table concurrent_futures_extra197.pool_executor_doc_class_names:
  description: "cf.ThreadPoolExecutor and cf.ProcessPoolExecutor __doc__.__class__.__name__ == 'NoneType'; both have None __doc__ in Python 3.14.3; new to concurrent_futures_extra197"
  kind: python_call_eq
  category: doc_identity
  id_prefix: cfdocs197

  columns: [id, function, args, expected, description]
  rows:
    - [threadpool_doc_class_name_eq_nonetype,
       "ThreadPoolExecutor.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "cf.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') == True — ThreadPoolExecutor.__doc__ is None in Python 3.14.3; None.__class__.__name__ is 'NoneType'; new to concurrent_futures_extra197"]
    - [threadpool_doc_class_name_len_eq_8,
       "ThreadPoolExecutor.__doc__.__class__.__name__.__len__",
       [],
       8,
       "cf.ThreadPoolExecutor.__doc__.__class__.__name__.__len__() == 8 — 'NoneType' has 8 characters; new to concurrent_futures_extra197"]
    - [processpool_doc_class_name_eq_nonetype,
       "ProcessPoolExecutor.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "cf.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') == True — ProcessPoolExecutor.__doc__ is None in Python 3.14.3; None.__class__.__name__ is 'NoneType'; new to concurrent_futures_extra197"]
    - [processpool_doc_class_name_len_eq_8,
       "ProcessPoolExecutor.__doc__.__class__.__name__.__len__",
       [],
       8,
       "cf.ProcessPoolExecutor.__doc__.__class__.__name__.__len__() == 8 — 'NoneType' has 8 characters; new to concurrent_futures_extra197"]

# ---------------------------------------------------------------------------
# Table 3: TimeoutError, BrokenExecutor, as_completed, wait __doc__.__class__.__name__
#
# concurrent.futures.TimeoutError.__doc__.__class__.__name__ == 'str' (len=3)
# concurrent.futures.BrokenExecutor.__doc__.__class__.__name__ == 'str' (len=3)
# concurrent.futures.as_completed.__doc__.__class__.__name__ == 'str' (len=3)
# concurrent.futures.wait.__doc__.__class__.__name__ == 'str' (len=3)
#
# Exception classes and module-level functions all have non-None str docstrings.
# New to concurrent_futures_extra197.
# ---------------------------------------------------------------------------

table concurrent_futures_extra197.exceptions_and_functions_doc_class_names:
  description: "cf.TimeoutError/BrokenExecutor/as_completed/wait __doc__.__class__.__name__ == 'str'; all have str docstrings; new to concurrent_futures_extra197"
  kind: python_call_eq
  category: doc_identity
  id_prefix: cfdocs197

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_error_doc_class_name_eq_str,
       "TimeoutError.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "cf.TimeoutError.__doc__.__class__.__name__.__eq__('str') == True — TimeoutError has a non-None str docstring; new to concurrent_futures_extra197"]
    - [broken_executor_doc_class_name_eq_str,
       "BrokenExecutor.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "cf.BrokenExecutor.__doc__.__class__.__name__.__eq__('str') == True — BrokenExecutor has a non-None str docstring; new to concurrent_futures_extra197"]
    - [as_completed_doc_class_name_eq_str,
       "as_completed.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "cf.as_completed.__doc__.__class__.__name__.__eq__('str') == True — as_completed has a non-None str docstring; new to concurrent_futures_extra197"]
    - [wait_doc_class_name_eq_str,
       "wait.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "cf.wait.__doc__.__class__.__name__.__eq__('str') == True — wait has a non-None str docstring; new to concurrent_futures_extra197"]

