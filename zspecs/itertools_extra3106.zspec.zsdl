spec: it3106
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (it3106): __lt__, __le__, __gt__ dict-presence checks for itertools types."
    - "No itertools type defines __lt__, __le__, or __gt__ in its own __dict__."
    - "itertools iterator types are C-level types; none define ordering operators in their own __dict__."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table it3106.lt:
  description: "itertools types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it3106
  columns: [id, function, args, expected]
  rows:
