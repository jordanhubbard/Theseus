spec: hashlib_extra249
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "PKCS#5 v2.1 — Password-Based Cryptography Specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "PKCS#5 v2.1 — Password-Based Cryptography Specification, Version 2.1"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec extends hashlib.zspec.zsdl through hashlib_extra248.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "hashlib.pbkdf2_hmac is a C-level built-in function in the _hashlib extension module."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — the bare function name, 11 characters."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — lives in the C extension, not the pure Python hashlib wrapper."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — C-level callable."
    - "hashlib.sha256.__name__ == 'openssl_sha256' — the underlying OpenSSL constructor name, 14 characters."
    - "hashlib.sha256.__module__ == '_hashlib' — sha256 constructor lives in the C extension."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — C-level constructor."
    - "hashlib.sha256(b'').__class__.__name__ == 'HASH' — the C-level hash instance type name."
    - "len('pbkdf2_hmac') == 11 — pbkdf2_hmac name has 11 characters."
    - "len('openssl_sha256') == 14 — sha256.__name__ has 14 characters (not 6; 'sha256' is 6 but the actual __name__ is 'openssl_sha256')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names; TypeError for bad argument types to pbkdf2_hmac."
  stderr: "null"
  stickiness: "N/A — pbkdf2_hmac and sha256 are pure functions; module-level attributes are read-only."
  codes: {}

# ---------------------------------------------------------------------------
# pbkdf2_hmac identity — __name__, __module__, __class__.__name__
# pbkdf2_hmac is a C-level builtin in the _hashlib extension module.
# ---------------------------------------------------------------------------

table hl249pbkdf.identity:
  description: "pbkdf2_hmac __name__/__module__/__class__.__name__ identity on OpenSSL-backed CPython builds"
  kind: python_call_eq
  category: identity
  id_prefix: hl249pbkdf

  columns: [id, function, args, expected]
  rows:
    - [pbkdf_name,        pbkdf2_hmac.__name__.__eq__,              ["pbkdf2_hmac"],              true]
    - [pbkdf_module,      pbkdf2_hmac.__module__.__eq__,            ["_hashlib"],                 true]
    - [pbkdf_class,       pbkdf2_hmac.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# pbkdf2_hmac __name__ length == 11
# 'pbkdf2_hmac' has 11 characters.
# ---------------------------------------------------------------------------

invariant hl249pbkdf.name_len:
  description: "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — 'pbkdf2_hmac' has 11 characters"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__len__
  args: []
  expected: 11

invariant hl249pbkdf.name_startswith:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 constructor identity — __name__, __module__, __class__.__name__
# On OpenSSL-backed CPython builds (macOS/Linux), sha256.__name__ is
# 'openssl_sha256' (14 chars), not 'sha256' (6 chars).
# ---------------------------------------------------------------------------

table hl249sha256id.constructor_identity:
  description: "sha256 constructor __name__/__module__/__class__.__name__ on OpenSSL-backed CPython builds"
  kind: python_call_eq
  category: identity
  id_prefix: hl249sha256id

  columns: [id, function, args, expected]
  rows:
    - [sha256_name,   sha256.__name__.__eq__,           ["openssl_sha256"],            true]
    - [sha256_module, sha256.__module__.__eq__,         ["_hashlib"],                  true]
    - [sha256_class,  sha256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# sha256.__name__ string length == 14
# sha256.__name__ is 'openssl_sha256' which has 14 characters, not 6.
# ---------------------------------------------------------------------------

invariant hl249sha256id.name_len:
  description: "hashlib.sha256.__name__.__len__() == 14 — 'openssl_sha256' has 14 characters on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# sha256 instance class name — sha256(b'').__class__.__name__ == 'HASH'
# The C-level hash instance type is named 'HASH' in _hashlib.
# ---------------------------------------------------------------------------

invariant hl249sha256id.instance_class_name:
  description: "hashlib.sha256(b'').__class__.__name__ == 'HASH' — C-level hash instance type"
  category: identity
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: ""}]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hl249sha256id.instance_class_module:
  description: "hashlib.sha256(b'').__class__.__module__ == '_hashlib' — HASH type lives in the C extension"
  category: identity
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: ""}]
  method: __class__.__module__.__eq__
  method_args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# pbkdf2_hmac __class__ module check
# __class__ is builtin_function_or_method, whose __module__ is 'builtins'.
# ---------------------------------------------------------------------------

invariant hl249pbkdf.class_module:
  description: "hashlib.pbkdf2_hmac.__class__.__module__ == 'builtins' — builtin_function_or_method lives in builtins"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 instance name attribute == 'sha256'
# sha256(b'').name is 'sha256' even though sha256.__name__ is 'openssl_sha256'.
# ---------------------------------------------------------------------------

invariant hl249sha256id.instance_name_attr:
  description: "hashlib.sha256(b'').name == 'sha256' — instance .name attribute is the canonical short name"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: ""}]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 instance digest_size == 32 (256-bit output = 32 bytes)
# ---------------------------------------------------------------------------

invariant hl249sha256id.instance_digest_size:
  description: "hashlib.sha256(b'').digest_size == 32 — SHA-256 produces 256-bit (32-byte) digests"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: ""}]
  method: digest_size.__eq__
  method_args: [32]
  expected: true
