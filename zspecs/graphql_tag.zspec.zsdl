spec: graphql_tag
version: ">=2.0.0"
backend: node(graphql-tag)

docs: https://github.com/apollographql/graphql-tag#readme

provenance:
  derived_from:
    - "graphql-tag README — https://github.com/apollographql/graphql-tag#readme"
    - "Test vectors verified with graphql-tag via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "graphql-tag source"
  notes:
    - "Tagged template literal for GraphQL queries — parses to graphql AST at module load."
    - "Install: npm install graphql-tag"
    - "v2 CJS; named exports gql / default (alias) / resetCaches / disableFragmentWarnings / etc."
    - "gql is a template tag — can't be invoked through chain helper, so spec covers exports only."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on malformed GraphQL syntax during template evaluation."
  stderr: "null"
  stickiness: "Caches parsed documents (resetCaches() clears)."
  codes: {}

invariant graphql_tag.has_gql_export:
  description: "gql template tag exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "gql.constructor.name"}
  expected: "Function"

invariant graphql_tag.has_default_alias:
  description: "default export is also a function (alias of gql)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant graphql_tag.has_resetCaches:
  description: "resetCaches() helper exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "resetCaches.constructor.name"}
  expected: "Function"

invariant graphql_tag.has_disableFragmentWarnings:
  description: "disableFragmentWarnings() helper exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "disableFragmentWarnings.constructor.name"}
  expected: "Function"

invariant graphql_tag.has_enableExperimentalFragmentVariables:
  description: "enableExperimentalFragmentVariables() helper exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "enableExperimentalFragmentVariables.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:45:04Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
