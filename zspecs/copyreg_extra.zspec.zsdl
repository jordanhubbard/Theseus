spec: copyreg_extra
version: ">=3.0"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/copyreg.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
  notes:
    - "This spec covers copyreg behaviors not already captured in copyreg.zspec.zsdl."
    - "dispatch_table.__class__.__name__ == 'dict' — covered in copyreg.zspec.zsdl; restated here as standalone invariant."
    - "pickle, constructor, add_extension, remove_extension, clear_extension_cache names covered in copyreg.zspec.zsdl; standalone invariants added here per task spec."
    - "__newobj__.__name__ == '__newobj__' — internal helper used by pickle protocol 2+ to reconstruct objects via __new__."
    - "__newobj_ex__.__name__ == '__newobj_ex__' — extended variant introduced in pickle protocol 4, supporting *args and **kwargs to __new__."
    - "Both __newobj__ and __newobj_ex__ are public names in the copyreg namespace, referenced by the pickle module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dispatch_table — type check (also in copyreg.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant copyreg_extra.dispatch_table.class_name:
  description: "copyreg.dispatch_table.__class__.__name__ == 'dict'"
  category: dispatch_table
  kind: python_call_eq
  function: dispatch_table.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# Public function names (standalone invariants)
# ---------------------------------------------------------------------------

invariant copyreg_extra.functions.pickle:
  description: "copyreg.pickle.__name__ == 'pickle'"
  category: functions
  kind: python_call_eq
  function: pickle.__name__.__eq__
  args: ["pickle"]
  expected: true

invariant copyreg_extra.functions.constructor:
  description: "copyreg.constructor.__name__ == 'constructor'"
  category: functions
  kind: python_call_eq
  function: constructor.__name__.__eq__
  args: ["constructor"]
  expected: true

invariant copyreg_extra.functions.add_extension:
  description: "copyreg.add_extension.__name__ == 'add_extension'"
  category: functions
  kind: python_call_eq
  function: add_extension.__name__.__eq__
  args: ["add_extension"]
  expected: true

invariant copyreg_extra.functions.remove_extension:
  description: "copyreg.remove_extension.__name__ == 'remove_extension'"
  category: functions
  kind: python_call_eq
  function: remove_extension.__name__.__eq__
  args: ["remove_extension"]
  expected: true

invariant copyreg_extra.functions.clear_extension_cache:
  description: "copyreg.clear_extension_cache.__name__ == 'clear_extension_cache'"
  category: functions
  kind: python_call_eq
  function: clear_extension_cache.__name__.__eq__
  args: ["clear_extension_cache"]
  expected: true

# ---------------------------------------------------------------------------
# __newobj__ and __newobj_ex__ — pickle protocol reconstruction helpers
#
# __newobj__(cls, *args) is the pickle-protocol-2 hook: it calls cls.__new__
# to reconstruct an object without invoking __init__. __newobj_ex__(cls, args,
# kwargs) is the protocol-4 variant that forwards keyword arguments as well.
# Both are defined in copyreg and are callable; their __name__ attributes
# reflect their Python-level function names.
# ---------------------------------------------------------------------------

invariant copyreg_extra.newobj.name:
  description: "copyreg.__newobj__.__name__ == '__newobj__'"
  category: newobj
  kind: python_call_eq
  function: __newobj__.__name__.__eq__
  args: ["__newobj__"]
  expected: true

invariant copyreg_extra.newobj_ex.name:
  description: "copyreg.__newobj_ex__.__name__ == '__newobj_ex__'"
  category: newobj
  kind: python_call_eq
  function: __newobj_ex__.__name__.__eq__
  args: ["__newobj_ex__"]
  expected: true
