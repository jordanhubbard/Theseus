spec: types_extra8
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType; SimpleNamespace attribute access; MappingProxyType __getitem__/__len__/__contains__"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType"
    - "types_extra2.zspec.zsdl — covers __module__ for major types; __bases__[0].__name__ for FunctionType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace"
    - "types_extra3.zspec.zsdl — covers EllipsisType/__name__/__module__/__bases__; NotImplementedType/__name__/__module__/__bases__; NoneType/__name__/__module__/__bases__; MappingProxyType/__name__/__module__; SimpleNamespace/__module__/__name__; class_modules table"
    - "types_extra4.zspec.zsdl — covers __name__/__module__ (table) for FunctionType/CodeType/FrameType/TracebackType/ModuleType/MethodType/BuiltinFunctionType/MappingProxyType/CellType/NoneType; SimpleNamespace/ModuleType/MappingProxyType instances"
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType (table); BuiltinFunctionType/AsyncGeneratorType/LambdaType/SimpleNamespace/MappingProxyType/DynamicClassAttribute __qualname__"
    - "types_extra6.zspec.zsdl — covers __qualname__ for CellType/CodeType/FrameType/TracebackType/NoneType/EllipsisType/NotImplementedType (table); BuiltinFunctionType/LambdaType/MappingProxyType/CellType __bases__[0]; CellType.__module__"
    - "types_extra7.zspec.zsdl — covers GenericAlias/__name__/__qualname__/__module__/__bases__[0]; UnionType/__qualname__/__module__; BuiltinMethodType.__name__; descriptor types (__name__ and __qualname__): MethodWrapperType/WrapperDescriptorType/MethodDescriptorType/GetSetDescriptorType/MemberDescriptorType"
  notes:
    - "This spec adds new axes: descriptor types __module__ (not covered in types_extra7 which only checked __name__/__qualname__); descriptor types __bases__[0]; CapsuleType/__name__/__qualname__/__module__ (not covered in any prior spec); DynamicClassAttribute __name__/__module__ (types_extra5 covers __qualname__ only); SimpleNamespace.__bases__[0].__name__; UnionType.__bases__[0].__name__."
    - "types.MethodWrapperType.__module__ == 'builtins' — C-level type; __module__ not checked in types_extra7."
    - "types.WrapperDescriptorType.__module__ == 'builtins' — C-level type; __module__ not checked in types_extra7."
    - "types.MethodDescriptorType.__module__ == 'builtins' — C-level type; __module__ not checked in types_extra7."
    - "types.GetSetDescriptorType.__module__ == 'builtins' — C-level type; __module__ not checked in types_extra7."
    - "types.MemberDescriptorType.__module__ == 'builtins' — C-level type; __module__ not checked in types_extra7."
    - "All five descriptor types have __bases__[0].__name__ == 'object' — not checked in any prior spec."
    - "types.CapsuleType.__name__ == 'PyCapsule' — the capsule C-level type; not covered in any prior spec."
    - "types.CapsuleType.__module__ == 'builtins' — C-level type."
    - "types.CapsuleType.__qualname__ == 'PyCapsule' — same as __name__."
    - "types.DynamicClassAttribute.__name__ == 'DynamicClassAttribute' — types_extra5 covers __qualname__ but not __name__ or __module__."
    - "types.DynamicClassAttribute.__module__ == 'types'."
    - "types.SimpleNamespace.__bases__[0].__name__ == 'object' — not checked in types_extra2 table."
    - "types.UnionType.__bases__[0].__name__ == 'object' — not checked in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Descriptor types — __module__ checks
# types_extra7 covers __name__ and __qualname__ for all five descriptor types
# but does NOT cover __module__. All five are C-level types with __module__ == 'builtins'.
# ---------------------------------------------------------------------------

table types_extra8.descriptor_class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: dmod

  columns: [id, function, args, expected]
  rows:
    - [MethodWrapperType,       MethodWrapperType.__module__.__eq__,       ["builtins"], true]
    - [WrapperDescriptorType,   WrapperDescriptorType.__module__.__eq__,   ["builtins"], true]
    - [MethodDescriptorType,    MethodDescriptorType.__module__.__eq__,    ["builtins"], true]
    - [GetSetDescriptorType,    GetSetDescriptorType.__module__.__eq__,    ["builtins"], true]
    - [MemberDescriptorType,    MemberDescriptorType.__module__.__eq__,    ["builtins"], true]

# ---------------------------------------------------------------------------
# Descriptor types — __bases__[0].__name__ == 'object'
# No prior spec verifies that any descriptor type inherits from object.
# ---------------------------------------------------------------------------

table types_extra8.descriptor_class_bases:
  kind: python_call_eq
  category: hierarchy
  id_prefix: dbase

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [MethodWrapperType,     MethodWrapperType.__bases__.__getitem__,     [0], true, __name__.__eq__, ["object"]]
    - [WrapperDescriptorType, WrapperDescriptorType.__bases__.__getitem__, [0], true, __name__.__eq__, ["object"]]
    - [MethodDescriptorType,  MethodDescriptorType.__bases__.__getitem__,  [0], true, __name__.__eq__, ["object"]]
    - [GetSetDescriptorType,  GetSetDescriptorType.__bases__.__getitem__,  [0], true, __name__.__eq__, ["object"]]
    - [MemberDescriptorType,  MemberDescriptorType.__bases__.__getitem__,  [0], true, __name__.__eq__, ["object"]]

# ---------------------------------------------------------------------------
# CapsuleType — __name__, __qualname__, __module__
# The C-level PyCapsule type. Not covered in any prior spec.
# types.CapsuleType.__name__ == 'PyCapsule' (note: not 'CapsuleType').
# ---------------------------------------------------------------------------

invariant types_extra8.CapsuleType.name:
  description: "types.CapsuleType.__name__ == 'PyCapsule' — C-level capsule type"
  category: class_names
  kind: python_call_eq
  function: CapsuleType.__name__.__eq__
  args: ["PyCapsule"]
  expected: true

invariant types_extra8.CapsuleType.qualname:
  description: "types.CapsuleType.__qualname__ == 'PyCapsule'"
  category: qualnames
  kind: python_call_eq
  function: CapsuleType.__qualname__.__eq__
  args: ["PyCapsule"]
  expected: true

invariant types_extra8.CapsuleType.module:
  description: "types.CapsuleType.__module__ == 'builtins' — C-level type"
  category: class_modules
  kind: python_call_eq
  function: CapsuleType.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# DynamicClassAttribute — __name__ and __module__
# types_extra5 covers DynamicClassAttribute.__qualname__ only.
# __name__ and __module__ have not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant types_extra8.DynamicClassAttribute.name:
  description: "types.DynamicClassAttribute.__name__ == 'DynamicClassAttribute'"
  category: class_names
  kind: python_call_eq
  function: DynamicClassAttribute.__name__.__eq__
  args: ["DynamicClassAttribute"]
  expected: true

invariant types_extra8.DynamicClassAttribute.module:
  description: "types.DynamicClassAttribute.__module__ == 'types'"
  category: class_modules
  kind: python_call_eq
  function: DynamicClassAttribute.__module__.__eq__
  args: ["types"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleNamespace.__bases__[0].__name__ == 'object'
# types_extra2 __bases__ table covers FunctionType/GeneratorType/CoroutineType/
# AsyncGeneratorType/CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace
# but checks the __name__ of the result rather than verifying via __eq__.
# No standalone invariant confirms SimpleNamespace.__bases__[0] is 'object'.
# ---------------------------------------------------------------------------

invariant types_extra8.SimpleNamespace.base_is_object:
  description: "types.SimpleNamespace.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: SimpleNamespace.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# UnionType.__bases__[0].__name__ == 'object'
# types.zspec covers UnionType.__name__ == 'Union'.
# types_extra7 covers UnionType.__qualname__ and __module__.
# No prior spec checks UnionType's base class.
# ---------------------------------------------------------------------------

invariant types_extra8.UnionType.base_is_object:
  description: "types.UnionType.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: UnionType.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true
