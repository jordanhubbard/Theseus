spec: datetime_extra9
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra8.zspec.zsdl."
    - "datetime_extra7 covers datetime.max.isoformat, time.min/max.isoformat, date.fromordinal, datetime.replace."
    - "datetime_extra8 covers date.isoweekday, time.microsecond attr/isoformat, timedelta two-week/days+hours normalization."
    - "NEW in this spec: date.min/max class attributes (isoformat); timedelta.min/max class attributes (days); timedelta.resolution (microseconds==1); timezone.utc.tzname(None)==UTC; timezone.utc.utcoffset returns timedelta; date.min.toordinal()==1; date.max.toordinal()==3652059; datetime.min.isoformat()."
    - "datetime.date.min.isoformat() == '0001-01-01' — earliest representable date."
    - "datetime.date.max.isoformat() == '9999-12-31' — latest representable date."
    - "datetime.timedelta.min.days == -999999999 — most negative timedelta."
    - "datetime.timedelta.max.days == 999999999 — most positive timedelta."
    - "datetime.timedelta.resolution.microseconds == 1 — smallest representable difference is 1 microsecond."
    - "datetime.timezone.utc.tzname(None) == 'UTC' — UTC timezone name."
    - "datetime.timezone.utc.utcoffset(None).__class__.__name__ == 'timedelta' — utcoffset returns a timedelta."
    - "datetime.date.min.toordinal() == 1 — ordinal of the epoch date 0001-01-01."
    - "datetime.date.max.toordinal() == 3652059 — ordinal of 9999-12-31."
    - "datetime.datetime.min.isoformat() == '0001-01-01T00:00:00' — earliest representable datetime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# date.min and date.max — class bound attributes
#
# datetime_extra7 covers time.min/max and datetime.max but NOT date.min/max
# isoformat. These are the extreme endpoints of the date range.
# ---------------------------------------------------------------------------

invariant datetime_extra9.date.min_isoformat:
  description: "datetime.date.min.isoformat() == '0001-01-01' — earliest representable date"
  category: date_bounds
  kind: python_call_eq
  function: date.min.isoformat
  args: []
  expected: "0001-01-01"

invariant datetime_extra9.date.max_isoformat:
  description: "datetime.date.max.isoformat() == '9999-12-31' — latest representable date"
  category: date_bounds
  kind: python_call_eq
  function: date.max.isoformat
  args: []
  expected: "9999-12-31"

# ---------------------------------------------------------------------------
# timedelta.min and timedelta.max — class bound attributes
#
# No prior spec accesses timedelta.min or timedelta.max. These are the most
# negative and most positive representable timedelta values.
# ---------------------------------------------------------------------------

invariant datetime_extra9.timedelta.min_days:
  description: "datetime.timedelta.min.days == -999999999 — most negative representable timedelta"
  category: timedelta_bounds
  kind: python_call_eq
  function: timedelta.min.days
  expected: -999999999

invariant datetime_extra9.timedelta.max_days:
  description: "datetime.timedelta.max.days == 999999999 — most positive representable timedelta"
  category: timedelta_bounds
  kind: python_call_eq
  function: timedelta.max.days
  expected: 999999999

# ---------------------------------------------------------------------------
# timedelta.resolution — smallest representable timedelta increment
#
# No prior spec checks timedelta.resolution. The resolution is 1 microsecond,
# stored as a timedelta with microseconds==1.
# ---------------------------------------------------------------------------

invariant datetime_extra9.timedelta.resolution_microseconds:
  description: "datetime.timedelta.resolution.microseconds == 1 — smallest timedelta increment is 1 microsecond"
  category: timedelta_bounds
  kind: python_call_eq
  function: timedelta.resolution.microseconds
  expected: 1

# ---------------------------------------------------------------------------
# timezone.utc — name and utcoffset type
#
# Prior specs confirm timezone.utc.__class__.__name__ == 'timezone'. This spec
# adds tzname() and the class of utcoffset() — neither is covered in any prior spec.
# ---------------------------------------------------------------------------

invariant datetime_extra9.timezone.utc_tzname:
  description: "datetime.timezone.utc.tzname(None) == 'UTC' — UTC timezone name string"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.tzname
  args: [null]
  expected: "UTC"

invariant datetime_extra9.timezone.utc_utcoffset_class:
  description: "datetime.timezone.utc.utcoffset(None).__class__.__name__ == 'timedelta' — utcoffset returns a timedelta"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.utcoffset
  args: [null]
  method: __class__
  method_chain: __name__
  expected: "timedelta"

# ---------------------------------------------------------------------------
# date.min and date.max ordinals
#
# date.min is 0001-01-01, which is ordinal 1. date.max is 9999-12-31, which
# is ordinal 3652059. Neither ordinal has been tested in any prior spec.
# ---------------------------------------------------------------------------

invariant datetime_extra9.date.min_toordinal:
  description: "datetime.date.min.toordinal() == 1 — ordinal of the proleptic Gregorian epoch"
  category: date_bounds
  kind: python_call_eq
  function: date.min.toordinal
  args: []
  expected: 1

invariant datetime_extra9.date.max_toordinal:
  description: "datetime.date.max.toordinal() == 3652059 — ordinal of 9999-12-31"
  category: date_bounds
  kind: python_call_eq
  function: date.max.toordinal
  args: []
  expected: 3652059

# ---------------------------------------------------------------------------
# datetime.min — earliest representable datetime
#
# datetime_extra7 covers datetime.max.isoformat() but NOT datetime.min.
# datetime.min is 0001-01-01T00:00:00, the earliest representable datetime.
# ---------------------------------------------------------------------------

invariant datetime_extra9.datetime.min_isoformat:
  description: "datetime.datetime.min.isoformat() == '0001-01-01T00:00:00' — earliest representable datetime"
  category: datetime_bounds
  kind: python_call_eq
  function: datetime.min.isoformat
  args: []
  expected: "0001-01-01T00:00:00"
