spec: concurrent_futures_extra100
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra99

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures class and function __qualname__ values. NEW in extra100: concurrent.futures.Future.__qualname__=='Future' (len=6); concurrent.futures.Executor.__qualname__=='Executor' (len=8); concurrent.futures.ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor' (len=18); concurrent.futures.ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor' (len=19, longest class qualname); concurrent.futures.CancelledError.__qualname__=='CancelledError' (len=14); concurrent.futures.TimeoutError.__qualname__=='TimeoutError' (len=12); concurrent.futures.BrokenExecutor.__qualname__=='BrokenExecutor' (len=14); concurrent.futures.InvalidStateError.__qualname__=='InvalidStateError' (len=17); concurrent.futures.as_completed.__qualname__=='as_completed' (len=12); concurrent.futures.wait.__qualname__=='wait' (len=4, shortest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19. 'ProcessPoolExecutor' is 19 chars, making it the longest class __qualname__ in concurrent.futures. ThreadPoolExecutor is 18 chars (one fewer). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__qualname__ == 'wait' (len=4). This is the shortest __qualname__ in this spec. Module-level functions at the top level of a module have __qualname__ equal to __name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14) and BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14). These two are tied for the same qualname length. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __qualname__ values — extra100
#
# Wave 254 theme: concurrent.futures class and exception __qualname__ values.
#
# concurrent.futures.Future.__qualname__              == 'Future'              (len=6)
# concurrent.futures.Executor.__qualname__            == 'Executor'            (len=8)
# concurrent.futures.CancelledError.__qualname__      == 'CancelledError'      (len=14)
# concurrent.futures.TimeoutError.__qualname__        == 'TimeoutError'        (len=12)
# concurrent.futures.BrokenExecutor.__qualname__      == 'BrokenExecutor'      (len=14)
# concurrent.futures.InvalidStateError.__qualname__   == 'InvalidStateError'   (len=17)
# concurrent.futures.ThreadPoolExecutor.__qualname__  == 'ThreadPoolExecutor'  (len=18)
# concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19)
# ---------------------------------------------------------------------------

table concurrent_futures_extra100.cf_class_qualnames:
  description: "concurrent.futures class __qualname__ equality checks in cfclassqn100 namespace — wave 254 theme: all concurrent.futures public classes have __qualname__ equal to their simple name (module-level class, so qualname == name); concurrent.futures.Future.__qualname__.__eq__('Future')==True (len=6: 'Future' has 6 chars); concurrent.futures.Executor.__qualname__.__eq__('Executor')==True (len=8: abstract base executor class); concurrent.futures.CancelledError.__qualname__.__eq__('CancelledError')==True (len=14: tied with BrokenExecutor); concurrent.futures.TimeoutError.__qualname__.__eq__('TimeoutError')==True (len=12); concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14: tied with CancelledError); concurrent.futures.InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17); concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18); concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True (len=19, longest class qualname in this spec); all are module-level classes so qualname equals name; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: cfclassqn100

  columns: [id, function, args, expected, description]
  rows:
    - [future_qn_eq,     "concurrent.futures.Future.__qualname__.__eq__",              ["Future"],              true, "concurrent.futures.Future.__qualname__ == 'Future' (len=6); verified with Python 3.14.3"]
    - [future_qn_len,    "concurrent.futures.Future.__qualname__.__len__",             [],                      6,    "concurrent.futures.Future.__qualname__.__len__() == 6; verified with Python 3.14.3"]
    - [executor_qn_eq,   "concurrent.futures.Executor.__qualname__.__eq__",            ["Executor"],            true, "concurrent.futures.Executor.__qualname__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [executor_qn_len,  "concurrent.futures.Executor.__qualname__.__len__",           [],                      8,    "concurrent.futures.Executor.__qualname__.__len__() == 8; verified with Python 3.14.3"]
    - [cancel_qn_eq,     "concurrent.futures.CancelledError.__qualname__.__eq__",      ["CancelledError"],      true, "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14); verified with Python 3.14.3"]
    - [cancel_qn_len,    "concurrent.futures.CancelledError.__qualname__.__len__",     [],                      14,   "concurrent.futures.CancelledError.__qualname__.__len__() == 14 (tied with BrokenExecutor); verified with Python 3.14.3"]
    - [timeout_qn_eq,    "concurrent.futures.TimeoutError.__qualname__.__eq__",        ["TimeoutError"],        true, "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' (len=12); verified with Python 3.14.3"]
    - [timeout_qn_len,   "concurrent.futures.TimeoutError.__qualname__.__len__",       [],                      12,   "concurrent.futures.TimeoutError.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [broken_qn_eq,     "concurrent.futures.BrokenExecutor.__qualname__.__eq__",      ["BrokenExecutor"],      true, "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, tied with CancelledError); verified with Python 3.14.3"]
    - [broken_qn_len,    "concurrent.futures.BrokenExecutor.__qualname__.__len__",     [],                      14,   "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 (tied with CancelledError); verified with Python 3.14.3"]
    - [invalid_qn_eq,    "concurrent.futures.InvalidStateError.__qualname__.__eq__",   ["InvalidStateError"],   true, "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17); verified with Python 3.14.3"]
    - [invalid_qn_len,   "concurrent.futures.InvalidStateError.__qualname__.__len__",  [],                      17,   "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [tpe_qn_eq,        "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__",  ["ThreadPoolExecutor"],  true, "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [tpe_qn_len,       "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__", [],                      18,   "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18; verified with Python 3.14.3"]
    - [ppe_qn_eq,        "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__", ["ProcessPoolExecutor"], true, "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19, longest class qualname); verified with Python 3.14.3"]
    - [ppe_qn_len,       "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__", [],                     19,   "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 (longest class qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures function __qualname__ values — extra100
#
# Wave 254 theme: module-level function __qualname__ values.
#
# concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12)
# concurrent.futures.wait.__qualname__         == 'wait'         (len=4)
# ---------------------------------------------------------------------------

table concurrent_futures_extra100.cf_function_qualnames:
  description: "concurrent.futures module-level function __qualname__ equality checks in cfclassqn100 namespace — wave 254 theme: module-level functions have __qualname__ equal to __name__; concurrent.futures.as_completed.__qualname__.__eq__('as_completed')==True (len=12: 'as_completed' has 12 chars including the underscore); concurrent.futures.as_completed.__qualname__.__len__()==12; concurrent.futures.wait.__qualname__.__eq__('wait')==True (len=4: shortest qualname in this spec); concurrent.futures.wait.__qualname__.__len__()==4; concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base')==True (defined in _base.py); concurrent.futures.wait.__module__.__eq__('concurrent.futures._base')==True (also in _base.py); concurrent.futures.wait.__class__.__name__.__eq__('function')==True (pure Python); concurrent.futures.as_completed.__class__.__name__.__eq__('function')==True (pure Python generator function); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: cfclassqn100a

  columns: [id, function, args, expected, description]
  rows:
    - [asc_qn_eq,    "concurrent.futures.as_completed.__qualname__.__eq__", ["as_completed"], true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12); verified with Python 3.14.3"]
    - [asc_qn_len,   "concurrent.futures.as_completed.__qualname__.__len__", [],              12,   "concurrent.futures.as_completed.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [wait_qn_eq,   "concurrent.futures.wait.__qualname__.__eq__",          ["wait"],        true, "concurrent.futures.wait.__qualname__ == 'wait' (len=4, shortest qualname in spec); verified with Python 3.14.3"]
    - [wait_qn_len,  "concurrent.futures.wait.__qualname__.__len__",         [],              4,    "concurrent.futures.wait.__qualname__.__len__() == 4 (shortest qualname in this spec); verified with Python 3.14.3"]
    - [asc_mod_eq,   "concurrent.futures.as_completed.__module__.__eq__",    ["concurrent.futures._base"], true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [wait_mod_eq,  "concurrent.futures.wait.__module__.__eq__",            ["concurrent.futures._base"], true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [asc_cls,      "concurrent.futures.as_completed.__class__.__name__.__eq__", ["function"], true, "concurrent.futures.as_completed.__class__.__name__ == 'function' — pure Python; verified with Python 3.14.3"]
    - [wait_cls,     "concurrent.futures.wait.__class__.__name__.__eq__",    ["function"],    true, "concurrent.futures.wait.__class__.__name__ == 'function' — pure Python; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra100
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra100.ProcessPoolExecutor_qualname_longest:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — ProcessPoolExecutor.__qualname__ is 'ProcessPoolExecutor' (19 chars); this is the longest class __qualname__ in the concurrent.futures public API; compare class qualname lengths: Future=6, Executor=8, TimeoutError=12, CancelledError=14, BrokenExecutor=14, InvalidStateError=17, ThreadPoolExecutor=18, ProcessPoolExecutor=19; ProcessPoolExecutor is one char longer than ThreadPoolExecutor (19 vs 18); both Executor classes use the compound name pattern 'XxxPoolExecutor' (PoolExecutor suffix plus platform prefix Thread/Process); ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (defined in Lib/concurrent/futures/process.py); NEW in extra100: first standalone ProcessPoolExecutor qualname length invariant in cfclassqn100 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__"
  args: []
  expected: 19

invariant concurrent_futures_extra100.wait_qualname_shortest:
  description: "concurrent.futures.wait.__qualname__.__len__() == 4 — wait.__qualname__ is 'wait' (4 chars), the shortest __qualname__ in this spec; module-level functions have __qualname__ equal to __name__ (no class prefix); compare: as_completed=12, Executor=8, Future=6, wait=4; concurrent.futures.wait() waits for Future instances to complete and returns a named tuple (done, not_done); wait.__module__ is 'concurrent.futures._base'; wait.__class__.__name__ is 'function' (pure Python); concurrent.futures.wait takes an iterable of Futures plus timeout and return_when parameters; NEW in extra100: first standalone wait qualname shortest invariant in cfclassqn100 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.wait.__qualname__.__len__"
  args: []
  expected: 4

invariant concurrent_futures_extra100.Future_qualname_eq_Future:
  description: "concurrent.futures.Future.__qualname__.__eq__('Future') returns True — concurrent.futures.Future is a module-level class defined in Lib/concurrent/futures/_base.py; module-level classes have __qualname__ equal to their simple name (no enclosing class or function scope prefix); concurrent.futures.Future.__qualname__ is 'Future' (len=6: F-u-t-u-r-e); concurrent.futures.Future.__module__ is 'concurrent.futures._base'; compare with asyncio.Future (also len=4 as class __name__) but different module; concurrent.futures.Future is a pure-Python class (not a C extension), unlike asyncio.Future which is in '_asyncio' C extension; concurrent.futures.Future.__qualname__.__len__()==6; NEW in extra100: first standalone concurrent.futures.Future qualname invariant in cfclassqn100 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.Future.__qualname__.__eq__"
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra100.InvalidStateError_qualname_len_17:
  description: "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 — InvalidStateError.__qualname__ is 'InvalidStateError' (17 chars); InvalidStateError is the second-longest exception qualname in the concurrent.futures public API (after InvalidStateError itself); compare exception qualname lengths: TimeoutError=12, CancelledError=14, BrokenExecutor=14, InvalidStateError=17; InvalidStateError is raised when an operation is performed on a Future in a state that doesn't support it (e.g. calling set_result() when already done); InvalidStateError.__module__ is 'concurrent.futures._base'; InvalidStateError.__qualname__.__len__()==17; NEW in extra100: first standalone InvalidStateError qualname length invariant in cfclassqn100 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__qualname__.__len__"
  args: []
  expected: 17

invariant concurrent_futures_extra100.ThreadPoolExecutor_qualname_len_18:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — ThreadPoolExecutor.__qualname__ is 'ThreadPoolExecutor' (18 chars); ThreadPoolExecutor is one char shorter than ProcessPoolExecutor (18 vs 19) because 'Thread'=6 chars vs 'Process'=7 chars; ThreadPoolExecutor is the standard executor for I/O-bound work using threads; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (defined in Lib/concurrent/futures/thread.py); ThreadPoolExecutor inherits from Executor (qualname='Executor', len=8); ThreadPoolExecutor.__qualname__.__len__()==18; compare: ProcessPoolExecutor.__qualname__.__len__()==19 (one more); NEW in extra100: first standalone ThreadPoolExecutor qualname length invariant in cfclassqn100 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__"
  args: []
  expected: 18
