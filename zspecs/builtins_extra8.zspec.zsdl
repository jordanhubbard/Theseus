spec: builtins_extra8
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/builtins.html — Python builtins module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers exception/type/function __name__ checks and basic function calls"
    - "builtins_extra.zspec.zsdl — covers function call behavior"
    - "builtins_extra2.zspec.zsdl — covers exception class hierarchies"
    - "builtins_extra3.zspec.zsdl — covers __name__ for print/input/open/vars/dir/id/frozenset/memoryview/slice/staticmethod/classmethod/super; __module__ for built-in types; base class checks"
    - "builtins_extra4.zspec.zsdl — covers __qualname__ for abs through id (26 entries)"
    - "builtins_extra5.zspec.zsdl — covers __qualname__ for input through zip (36 entries)"
    - "builtins_extra6.zspec.zsdl — covers __qualname__ for bytearray/bytes/classmethod; NotImplemented/Ellipsis class names; __module__ for abs/len/print/type"
    - "builtins_extra7.zspec.zsdl — covers __module__ for all remaining built-in functions (ord through dir)"
  notes:
    - "This spec adds new axes not covered in any prior builtins spec."
    - "Axis 1: direct base class (__bases__[0].__name__) for selected built-in types — int, bool, str, list, dict, bytes, Exception."
    - "Axis 2: MRO length (__mro__.__len__()) for int, bool, str — distinct from base checks."
    - "Axis 3: singleton type checks — None.__class__.__name__, True/__class__.__name__, False/__class__.__name__."
    - "Axis 4: __module__ for built-in exception types ValueError, TypeError, KeyError."
    - "int.__bases__[0].__name__ == 'object' — int inherits directly from object."
    - "bool.__bases__[0].__name__ == 'int' — bool subclasses int."
    - "str.__bases__[0].__name__ == 'object' — str inherits directly from object."
    - "list.__bases__[0].__name__ == 'object' — list inherits directly from object."
    - "dict.__bases__[0].__name__ == 'object' — dict inherits directly from object."
    - "bytes.__bases__[0].__name__ == 'object' — bytes inherits directly from object."
    - "Exception.__bases__[0].__name__ == 'BaseException' — Exception subclasses BaseException."
    - "int.__mro__.__len__() == 2 — int MRO is [int, object]."
    - "bool.__mro__.__len__() == 3 — bool MRO is [bool, int, object]."
    - "str.__mro__.__len__() == 2 — str MRO is [str, object]."
    - "None.__class__.__name__ == 'NoneType' — the None singleton's type is NoneType."
    - "True.__class__.__name__ == 'bool' — True is an instance of bool."
    - "False.__class__.__name__ == 'bool' — False is an instance of bool."
    - "ValueError.__module__ == 'builtins', TypeError.__module__ == 'builtins', KeyError.__module__ == 'builtins'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ — direct base class of selected built-in types
#
# builtins_extra2 covers exception hierarchies (e.g. ValueError -> Exception).
# builtins_extra3 covers __module__ for types.
# No prior spec checks __bases__[0].__name__ via the dotted attribute chain
# for int, bool, str, list, dict, bytes.
# ---------------------------------------------------------------------------

invariant builtins_extra8.int.base_is_object:
  description: "int.__bases__[0].__name__ == 'object' — int inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: int.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant builtins_extra8.bool.base_is_int:
  description: "bool.__bases__[0].__name__ == 'int' — bool subclasses int"
  category: class_hierarchy
  kind: python_call_eq
  function: bool.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

invariant builtins_extra8.str.base_is_object:
  description: "str.__bases__[0].__name__ == 'object' — str inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: str.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant builtins_extra8.Exception.base_is_BaseException:
  description: "Exception.__bases__[0].__name__ == 'BaseException' — Exception subclasses BaseException"
  category: class_hierarchy
  kind: python_call_eq
  function: Exception.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# MRO length checks — int, bool, str
#
# No prior spec covers __mro__.__len__() for any built-in type.
# int MRO: [int, object] (length 2).
# bool MRO: [bool, int, object] (length 3).
# str MRO: [str, object] (length 2).
# ---------------------------------------------------------------------------

invariant builtins_extra8.int.mro_len_2:
  description: "int.__mro__.__len__() == 2 — MRO is [int, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: int.__mro__.__len__
  args: []
  expected: 2

invariant builtins_extra8.bool.mro_len_3:
  description: "bool.__mro__.__len__() == 3 — MRO is [bool, int, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: bool.__mro__.__len__
  args: []
  expected: 3

invariant builtins_extra8.str.mro_len_2:
  description: "str.__mro__.__len__() == 2 — MRO is [str, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: str.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Singleton type checks — None, True, False
#
# builtins_extra6 covers NotImplemented and Ellipsis class names.
# No prior spec covers None, True, or False class names.
# ---------------------------------------------------------------------------

invariant builtins_extra8.None.class_name:
  description: "builtins.None.__class__.__name__ == 'NoneType'"
  category: singletons
  kind: python_call_eq
  function: None.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant builtins_extra8.True.class_name:
  description: "builtins.True.__class__.__name__ == 'bool'"
  category: singletons
  kind: python_call_eq
  function: True.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant builtins_extra8.False.class_name:
  description: "builtins.False.__class__.__name__ == 'bool'"
  category: singletons
  kind: python_call_eq
  function: False.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for built-in exception types
#
# builtins_extra6/extra7 cover __module__ for built-in functions.
# builtins_extra3 covers __module__ for built-in numeric/container types.
# No prior spec covers __module__ for built-in exception classes.
# All built-in exceptions are defined in 'builtins'.
# ---------------------------------------------------------------------------

table builtins_extra8.exception_modules:
  kind: python_call_eq
  category: exception_modules
  id_prefix: emod

  columns: [id, function, args, expected]
  rows:
    - [ValueError,      ValueError.__module__.__eq__,      ["builtins"], true]
    - [TypeError,       TypeError.__module__.__eq__,       ["builtins"], true]
    - [KeyError,        KeyError.__module__.__eq__,        ["builtins"], true]
    - [IndexError,      IndexError.__module__.__eq__,      ["builtins"], true]
    - [AttributeError,  AttributeError.__module__.__eq__,  ["builtins"], true]
    - [NameError,       NameError.__module__.__eq__,       ["builtins"], true]
