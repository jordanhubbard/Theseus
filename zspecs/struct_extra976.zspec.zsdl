spec: struct_extra976
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct method qualnames and descriptor class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra976.struct_method_qualnames:
  description: "struct.Struct method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: st976mq
  columns: [id, function, args, expected]
  rows:
    - [st976mq001, struct.Struct.pack.__qualname__.__eq__,         ["Struct.pack"],         true]
    - [st976mq002, struct.Struct.unpack.__qualname__.__eq__,       ["Struct.unpack"],       true]
    - [st976mq003, struct.Struct.pack_into.__qualname__.__eq__,    ["Struct.pack_into"],    true]
    - [st976mq004, struct.Struct.unpack_from.__qualname__.__eq__,  ["Struct.unpack_from"],  true]
    - [st976mq005, struct.Struct.iter_unpack.__qualname__.__eq__,  ["Struct.iter_unpack"],  true]
    - [st976mq006, struct.Struct.__init__.__qualname__.__eq__,     ["Struct.__init__"],     true]

table struct_extra976.struct_descriptor_class_names:
  description: "struct.Struct attribute descriptor class name checks"
  kind: python_call_eq
  category: descriptor_classnames
  id_prefix: st976dc
  columns: [id, function, args, expected]
  rows:
    - [st976dc001, struct.Struct.size.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [st976dc002, struct.Struct.format.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [st976dc003, struct.Struct.pack.__class__.__name__.__eq__,   ["slot_wrapper"],      false]
    - [st976dc004, struct.Struct.__class__.__name__.__eq__,        ["type"],              true]
    - [st976dc005, struct.Struct.__module__.__eq__,                ["struct"],            true]
    - [st976dc006, struct.Struct.__qualname__.__eq__,              ["Struct"],            true]

table struct_extra976.struct_module_function_qualnames:
  description: "struct module-level function __qualname__ checks"
  kind: python_call_eq
  category: module_function_qualnames
  id_prefix: st976fq
  columns: [id, function, args, expected]
  rows:
    - [st976fq001, struct.pack.__qualname__.__eq__,          ["pack"],          true]
    - [st976fq002, struct.unpack.__qualname__.__eq__,        ["unpack"],        true]
    - [st976fq003, struct.pack_into.__qualname__.__eq__,     ["pack_into"],     true]
    - [st976fq004, struct.unpack_from.__qualname__.__eq__,   ["unpack_from"],   true]
    - [st976fq005, struct.iter_unpack.__qualname__.__eq__,   ["iter_unpack"],   true]
    - [st976fq006, struct.calcsize.__qualname__.__eq__,      ["calcsize"],      true]
    - [st976fq007, struct.pack.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
