spec: pp3496
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (io3496): __aenter__, __aexit__, __await__ dict-presence checks for io/pathlib/re/decimal types."
    - "All values False — these types are synchronous and do not implement the async context manager or awaitable protocols."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async context manager / awaitable protocol)."
    - "No pathlib class defines __aenter__ in its own __dict__: path objects are synchronous value types and do not implement the async context manager protocol."
    - "No pathlib class defines __aexit__ in its own __dict__: path objects do not implement the async context manager exit protocol."
    - "No pathlib class defines __await__ in its own __dict__: path objects are not awaitable."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No pathlib class defines __aenter__ in its own __dict__; all false.
# Path objects are immutable filesystem path value types and do not
# implement the async context manager protocol.
# ---------------------------------------------------------------------------

table pp3496.aenter:
  description: "pathlib types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3496

  columns: [id, function, args, expected]
  rows:
    - ["pp3496001", operator.contains, [pathlib.PurePath.__dict__,         "__aenter__"], false]
    - ["pp3496002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__aenter__"], false]
    - ["pp3496003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__aenter__"], false]
    - ["pp3496004", operator.contains, [pathlib.Path.__dict__,             "__aenter__"], false]
    - ["pp3496005", operator.contains, [pathlib.PosixPath.__dict__,        "__aenter__"], false]

