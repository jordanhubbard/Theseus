spec: theseus_functools_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_functools_cr2)
blocks: functools

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
  notes:
    - "Clean-room extended functools. Do NOT import functools."
    - "cached_property: descriptor that caches computed property value on instance."
    - "total_ordering: class decorator filling in missing comparison methods."
    - "singledispatch: register function implementations for different types."
    - "functools2_cached_property(): cached_property computed once, reused."
    - "functools2_total_ordering(): class with __eq__ and __lt__ gets __le__ etc."
    - "functools2_singledispatch(): dispatches to int handler for int argument."
    - "Export: cached_property, total_ordering, singledispatch (extending theseus_functools_cr)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_functools_cr2.cached_property:
  description: "cached_property computes value once and caches it"
  category: cached_property
  kind: python_call_eq
  function: functools2_cached_property
  args: []
  expected: true

invariant theseus_functools_cr2.total_ordering:
  description: "@total_ordering class with __eq__ and __lt__ gets __le__"
  category: total_ordering
  kind: python_call_eq
  function: functools2_total_ordering
  args: []
  expected: true

invariant theseus_functools_cr2.singledispatch:
  description: "singledispatch dispatches to registered int handler"
  category: singledispatch
  kind: python_call_eq
  function: functools2_singledispatch
  args: []
  expected: "int"
