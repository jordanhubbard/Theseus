spec: multiprocessing_extra1981
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "multiprocessing.Process is a pure Python class (multiprocessing/process.py); it does NOT define __sizeof__ in its own __dict__ -> False."
    - "multiprocessing.Queue is a factory function returning a multiprocessing.queues.Queue instance; multiprocessing.queues.Queue is a pure Python class; it does NOT define __sizeof__ -> False."
    - "multiprocessing.synchronize types (Event, Lock, Semaphore, BoundedSemaphore, Condition) are pure Python wrappers around C-level semaphores; none define __sizeof__ in their own __dict__ -> False."
    - "__length_hint__ is an iterator length-estimation protocol; multiprocessing synchronisation and process types are not iterators -> False for all."
    - "__floor__, __ceil__, __trunc__ are math rounding protocol methods; multiprocessing types are not numeric -> False for all."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __sizeof__ dict-presence checks
#
# Wave 579 theme: multiprocessing.Process and the synchronise/queue types are
# all pure Python classes. None define __sizeof__ in their own __dict__; the
# method is inherited from object without override.
# ---------------------------------------------------------------------------

table multiprocessing_extra1981.sizeof_protocol:
  description: "multiprocessing types __sizeof__ dict-presence checks — none define __sizeof__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1981

  columns: [id, function, args, expected]
  rows:
    - ["mp1981001", "multiprocessing.Process.__dict__.__contains__",                        ["__sizeof__"], false]
    - ["mp1981002", "multiprocessing.queues.Queue.__dict__.__contains__",                   ["__sizeof__"], false]
    - ["mp1981003", "multiprocessing.queues.SimpleQueue.__dict__.__contains__",             ["__sizeof__"], false]
    - ["mp1981004", "multiprocessing.synchronize.Event.__dict__.__contains__",              ["__sizeof__"], false]
    - ["mp1981005", "multiprocessing.synchronize.Lock.__dict__.__contains__",               ["__sizeof__"], false]
    - ["mp1981006", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",          ["__sizeof__"], false]
    - ["mp1981007", "multiprocessing.synchronize.BoundedSemaphore.__dict__.__contains__",   ["__sizeof__"], false]
    - ["mp1981008", "multiprocessing.synchronize.Condition.__dict__.__contains__",          ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence checks
#
# __length_hint__ supports operator.length_hint() and is part of the iterator
# protocol (PEP 424). multiprocessing synchronisation primitives and process
# types are not iterators or sequences; none define __length_hint__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1981.length_hint_protocol:
  description: "multiprocessing types __length_hint__ dict-presence checks — none define __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1981

  columns: [id, function, args, expected]
  rows:
    - ["mp1981009",  "multiprocessing.Process.__dict__.__contains__",                        ["__length_hint__"], false]
    - ["mp1981010",  "multiprocessing.queues.Queue.__dict__.__contains__",                   ["__length_hint__"], false]
    - ["mp1981011",  "multiprocessing.queues.SimpleQueue.__dict__.__contains__",             ["__length_hint__"], false]
    - ["mp1981012",  "multiprocessing.synchronize.Event.__dict__.__contains__",              ["__length_hint__"], false]
    - ["mp1981013",  "multiprocessing.synchronize.Lock.__dict__.__contains__",               ["__length_hint__"], false]
    - ["mp1981014",  "multiprocessing.synchronize.Semaphore.__dict__.__contains__",          ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: __floor__ dict-presence checks
#
# math.floor() dispatches to type.__floor__ when the type defines it in its
# __dict__. multiprocessing types are not numeric; none define __floor__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1981.floor_protocol:
  description: "multiprocessing types __floor__ dict-presence checks — none define __floor__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1981

  columns: [id, function, args, expected]
  rows:
    - ["mp1981015",  "multiprocessing.Process.__dict__.__contains__",                        ["__floor__"], false]
    - ["mp1981016",  "multiprocessing.queues.Queue.__dict__.__contains__",                   ["__floor__"], false]
    - ["mp1981017",  "multiprocessing.queues.SimpleQueue.__dict__.__contains__",             ["__floor__"], false]
    - ["mp1981018",  "multiprocessing.synchronize.Event.__dict__.__contains__",              ["__floor__"], false]
    - ["mp1981019",  "multiprocessing.synchronize.Lock.__dict__.__contains__",               ["__floor__"], false]
    - ["mp1981020",  "multiprocessing.synchronize.Semaphore.__dict__.__contains__",          ["__floor__"], false]

