spec: pathlib_extra84
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra83."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for open/read_text/write_text/iterdir/mkdir/exists/unlink/stat/rename/read_bytes/write_bytes/touch/rmdir/resolve/glob/rglob/is_dir/is_file/absolute/symlink_to/hardlink_to/lstat/expanduser; PurePath/__dict__ membership; Path/__dict__ membership; Path.parent/name/suffix as property descriptors."
    - "This spec covers: Path.chmod/__code__.co_name and co_argcount; Path.with_name/__code__.co_name and co_argcount; Path.with_suffix/__code__.co_name and co_argcount; Path.with_stem/__code__.co_name and co_argcount; Path.touch/__code__.co_name and co_argcount; Path.stem/__class__.__name__; Path.parts/__class__.__name__; Path.drive/__class__.__name__."
    - "pathlib.Path.chmod.__code__.co_name == 'chmod' — verified by code object attribute."
    - "pathlib.Path.chmod.__code__.co_argcount == 2 — chmod(self, mode, *, follow_symlinks=True): self + mode; follow_symlinks is keyword-only (co_kwonlyargcount == 1) so co_argcount == 2."
    - "pathlib.Path.with_name.__code__.co_name == 'with_name' — verified by code object attribute."
    - "pathlib.Path.with_name.__code__.co_argcount == 2 — with_name(self, name): self + name."
    - "pathlib.Path.with_suffix.__code__.co_name == 'with_suffix' — verified by code object attribute."
    - "pathlib.Path.with_suffix.__code__.co_argcount == 2 — with_suffix(self, suffix): self + suffix."
    - "pathlib.Path.with_stem.__code__.co_name == 'with_stem' — verified by code object attribute."
    - "pathlib.Path.with_stem.__code__.co_argcount == 2 — with_stem(self, stem): self + stem."
    - "pathlib.Path.touch.__code__.co_name == 'touch' — verified by code object attribute."
    - "pathlib.Path.touch.__code__.co_argcount == 3 — touch(self, mode=438, exist_ok=True): self + mode + exist_ok."
    - "pathlib.Path.stem.__class__.__name__ == 'property' — Path.stem is a Python property descriptor."
    - "pathlib.Path.parts.__class__.__name__ == 'property' — Path.parts is a Python property descriptor."
    - "pathlib.Path.drive.__class__.__name__ == 'property' — Path.drive is a Python property descriptor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.chmod __code__ attributes
# chmod(self, mode, *, follow_symlinks=True): follow_symlinks is keyword-only,
# so co_argcount == 2 (self + mode only); co_kwonlyargcount == 1.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra84.chmod_code:
  description: "Path.chmod __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore84

  columns: [id, function, args, expected]
  rows:
    - [chmod_co_name, Path.chmod.__code__.co_name.__eq__,     ["chmod"], true]
    - [chmod_co_argc, Path.chmod.__code__.co_argcount.__eq__, [2],       true]

# ---------------------------------------------------------------------------
# Path.with_name, Path.with_suffix, Path.with_stem __code__ attributes
# All three are (self, <single arg>) with co_argcount == 2.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra84.with_name_suffix_stem_code:
  description: "Path.with_name, Path.with_suffix, Path.with_stem __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore84

  columns: [id, function, args, expected]
  rows:
    - [with_name_co_name,   Path.with_name.__code__.co_name.__eq__,      ["with_name"],   true]
    - [with_name_co_argc,   Path.with_name.__code__.co_argcount.__eq__,   [2],            true]
    - [with_suffix_co_name, Path.with_suffix.__code__.co_name.__eq__,    ["with_suffix"], true]
    - [with_suffix_co_argc, Path.with_suffix.__code__.co_argcount.__eq__, [2],            true]
    - [with_stem_co_name,   Path.with_stem.__code__.co_name.__eq__,      ["with_stem"],   true]
    - [with_stem_co_argc,   Path.with_stem.__code__.co_argcount.__eq__,   [2],            true]

# ---------------------------------------------------------------------------
# Path.touch __code__ attributes
# touch(self, mode=438, exist_ok=True): all three are positional-or-keyword args.
# co_argcount == 3 (self + mode + exist_ok).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra84.touch_code:
  description: "Path.touch __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore84

  columns: [id, function, args, expected]
  rows:
    - [touch_co_name, Path.touch.__code__.co_name.__eq__,     ["touch"], true]
    - [touch_co_argc, Path.touch.__code__.co_argcount.__eq__, [3],       true]

# ---------------------------------------------------------------------------
# Path.stem, Path.parts, Path.drive are property descriptors
# All three are Python property objects defined on the Path class.
# __class__.__name__ == 'property' for each.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra84.stem_parts_drive_property:
  description: "Path.stem, Path.parts, Path.drive are property descriptors"
  kind: python_call_eq
  category: class_properties
  id_prefix: pathlibmore84

  columns: [id, function, args, expected]
  rows:
    - [stem_cls,  Path.stem.__class__.__name__.__eq__,  ["property"], true]
    - [parts_cls, Path.parts.__class__.__name__.__eq__, ["property"], true]
    - [drive_cls, Path.drive.__class__.__name__.__eq__, ["property"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra84.chmod_code.co_name:
  description: "pathlib.Path.chmod.__code__.co_name == 'chmod'"
  category: code_attrs
  kind: python_call_eq
  function: Path.chmod.__code__.co_name.__eq__
  args: ["chmod"]
  expected: true

invariant pathlib_extra84.chmod_code.co_argcount:
  description: "pathlib.Path.chmod.__code__.co_argcount == 2 (self + mode; follow_symlinks is keyword-only)"
  category: code_attrs
  kind: python_call_eq
  function: Path.chmod.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra84.with_stem_code.co_name:
  description: "pathlib.Path.with_stem.__code__.co_name == 'with_stem'"
  category: code_attrs
  kind: python_call_eq
  function: Path.with_stem.__code__.co_name.__eq__
  args: ["with_stem"]
  expected: true

invariant pathlib_extra84.stem.is_property:
  description: "pathlib.Path.stem.__class__.__name__ == 'property'"
  category: class_properties
  kind: python_call_eq
  function: Path.stem.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra84.parts.is_property:
  description: "pathlib.Path.parts.__class__.__name__ == 'property'"
  category: class_properties
  kind: python_call_eq
  function: Path.parts.__class__.__name__.__eq__
  args: ["property"]
  expected: true
