spec: decode_named_character_reference
version: ">=1.3.0"
backend: node(decode-named-character-reference)

docs: https://www.npmjs.com/package/decode-named-character-reference

provenance:
  derived_from:
    - "decode-named-character-reference README — https://www.npmjs.com/package/decode-named-character-reference"
    - "Test vectors verified with decode-named-character-reference via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "decode-named-character-reference source"
  notes:
    - "decode-named-character-reference is an npm package. Install: npm install decode-named-character-reference"
    - "Decodes a named HTML character reference (without & and ;) to its character. Returns false for unknown names."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string (the character) or false."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table decode_named_character_reference.decodeNamedCharacterReference:
  kind: node_module_call_eq
  function: decodeNamedCharacterReference
  category: decode
  id_prefix: decncr

  columns: [id, args, expected]
  rows:
    - [amp,     ["amp"],      "&"]
    - [lt,      ["lt"],       "<"]
    - [gt,      ["gt"],       ">"]
    - [invalid, ["invalid"],  false]
