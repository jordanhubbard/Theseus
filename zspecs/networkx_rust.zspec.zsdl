spec: networkx_rust
version: ">=3.9"
backend: rust_module(networkx_rust)

docs: https://networkx.org/documentation/stable/reference/

provenance:
  derived_from:
    - "https://networkx.org/documentation/stable/reference/ — NetworkX documentation"
  not_derived_from:
    - "networkx source: networkx/classes/graph.py"
  notes:
    - "NetworkX provides graph data structures and algorithms."
    - "G = nx.Graph(); G.add_edges_from([(1,2),(2,3)]); G.number_of_nodes() == 3."
    - "G.number_of_edges() == 2."
    - "nx.shortest_path_length(G, 1, 3) == 2."
    - "nx.is_connected(G) == True."
    - "Expose nx_node_count(edges) -> int: G.number_of_nodes() after adding edges."
    - "Expose nx_edge_count(edges) -> int: G.number_of_edges()."
    - "Expose nx_shortest_path(edges, source, target) -> int: shortest_path_length."
    - "Expose nx_is_connected(edges) -> bool: nx.is_connected(G)."
    - "All test vectors verified against networkx 3.4.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# nx_node_count — number of nodes in graph from edge list
table networkx_rust.graph.node_count:
  kind: python_call_eq
  category: node_count
  id_prefix: nx_nc
  function: nx_node_count

  columns: [id, args, expected]
  rows:
    - [triangle,  [[[1, 2], [2, 3], [3, 1]]],  3]
    - [chain,     [[[1, 2], [2, 3]]],            3]
    - [single,    [[[1, 2]]],                    2]

# nx_edge_count — number of edges
table networkx_rust.graph.edge_count:
  kind: python_call_eq
  category: edge_count
  id_prefix: nx_ec
  function: nx_edge_count

  columns: [id, args, expected]
  rows:
    - [two_edges,   [[[1, 2], [2, 3]]],           2]
    - [three_edges, [[[1, 2], [2, 3], [3, 1]]],   3]

# nx_shortest_path — shortest path length between nodes
invariant networkx_rust.path.chain_1_3:
  description: "shortest path 1->3 in chain 1-2-3 == 2"
  category: shortest_path
  kind: python_call_eq
  function: nx_shortest_path
  args: [[[1, 2], [2, 3]], 1, 3]
  expected: 2

invariant networkx_rust.path.adjacent:
  description: "shortest path 1->2 in edge (1,2) == 1"
  category: shortest_path
  kind: python_call_eq
  function: nx_shortest_path
  args: [[[1, 2], [2, 3]], 1, 2]
  expected: 1

# nx_is_connected — connectivity check
invariant networkx_rust.connected.chain:
  description: "chain 1-2-3 is connected"
  category: connected
  kind: python_call_eq
  function: nx_is_connected
  args: [[[1, 2], [2, 3]]]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:06:02Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
