spec: re_extra9
version: ">=3.12"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras."
    - "re_extra3 covers: Pattern.__name__, Match.__name__ (type objects), error.__name__ == 'PatternError' (3.12+), error base == Exception."
    - "re_extra6 covers: Pattern.__module__ == 're', Match.__module__ == 're', error.__module__ == 're', error base == Exception."
    - "re_extra8 covers: Pattern.__qualname__ == 'Pattern', Match.__qualname__ == 'Match', error.__qualname__ (NOT covered — re_extra8 covers compile/match/search/etc qualnames)."
    - "re.Pattern.__name__ == 'Pattern' — the compiled pattern type added as a public name in Python 3.7."
    - "re.Match.__name__ == 'Match' — the match object type added as a public name in Python 3.7."
    - "re.error.__name__ == 'PatternError' on Python 3.12+ (the canonical name; 're.error' is an alias)."
    - "re.Pattern.__module__ == 're' — the Pattern type reports 're' as its module."
    - "re.Match.__module__ == 're' — the Match type reports 're' as its module."
    - "re.error.__module__ == 're' — the error/PatternError class is defined in the re package."
    - "re.error.__bases__[0].__name__ == 'Exception' — error inherits directly from Exception."
    - "re.error.__qualname__ == 'PatternError' on Python 3.12+ (same as __name__ for a top-level class)."
    - "re.Match.__bases__[0].__name__ == 'object' — Match is a C extension type inheriting from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cross-spec anchoring table — Pattern.__name__, Match.__name__, error.__name__,
# Pattern.__module__, Match.__module__, error.__module__
#
# re_extra3 covers Pattern.__name__ and Match.__name__ as standalone invariants.
# re_extra6 covers Pattern.__module__, Match.__module__, error.__module__.
# Here we provide a compact table from the re_extra9 namespace for anchoring.
# ---------------------------------------------------------------------------

table re_extra9.type_names_and_modules:
  kind: python_call_eq
  category: class_metadata
  id_prefix: meta

  columns: [id, function, args, expected]
  rows:
    - [Pattern_name,    Pattern.__name__.__eq__,    ["Pattern"],      true]
    - [Match_name,      Match.__name__.__eq__,      ["Match"],        true]
    - [error_name,      error.__name__.__eq__,      ["PatternError"], true]
    - [Pattern_module,  Pattern.__module__.__eq__,  ["re"],           true]
    - [Match_module,    Match.__module__.__eq__,    ["re"],           true]
    - [error_module,    error.__module__.__eq__,    ["re"],           true]

# ---------------------------------------------------------------------------
# re.error — __qualname__ check
#
# re_extra8 covers Pattern.__qualname__ and Match.__qualname__ in its
# class_qualnames table, but does NOT cover error.__qualname__.
# On Python 3.12+ error.__qualname__ == 'PatternError' (same as __name__).
# ---------------------------------------------------------------------------

invariant re_extra9.error.qualname:
  description: "re.error.__qualname__ == 'PatternError' on Python 3.12+"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

# ---------------------------------------------------------------------------
# re.error.__bases__[0].__name__ == 'Exception'
#
# re_extra3 and re_extra6 cover this; here we add it as a named invariant
# from the re_extra9 namespace for cross-spec anchoring.
# ---------------------------------------------------------------------------

invariant re_extra9.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' — error inherits directly from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# re.Match — base class check
# re_extra6 covers Pattern.__bases__[0].__name__ == 'object'.
# No prior spec covers Match.__bases__[0].__name__.
# Match is a C extension type; its base is object.
# ---------------------------------------------------------------------------

invariant re_extra9.Match.base_is_object:
  description: "re.Match.__bases__[0].__name__ == 'object' — Match is a C extension type inheriting from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Match.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# re.error — is_subclass of Exception (functional check via __mro__)
# The MRO of error includes Exception; __mro__[1].__name__ == 'Exception'.
# No prior spec checks __mro__ for re.error.
# ---------------------------------------------------------------------------

invariant re_extra9.error.mro_includes_Exception:
  description: "re.error.__mro__[1].__name__ == 'Exception' — Exception is second in error's MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# re.Pattern and re.Match — __qualname__ standalone anchors from re_extra9
# re_extra8 covers these in a table; here we add named standalone invariants
# from this spec's namespace for independent cross-spec anchoring.
# ---------------------------------------------------------------------------

invariant re_extra9.Pattern.qualname:
  description: "re.Pattern.__qualname__ == 'Pattern'"
  category: qualnames
  kind: python_call_eq
  function: Pattern.__qualname__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra9.Match.qualname:
  description: "re.Match.__qualname__ == 'Match'"
  category: qualnames
  kind: python_call_eq
  function: Match.__qualname__.__eq__
  args: ["Match"]
  expected: true
