spec: socket_extra131
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra130.zspec.zsdl — covers socket module Python function code attributes — create_connection/create_server/getfqdn/getaddrinfo co_name/co_argcount/co_varnames[0]/co_varnames.__len__() (table + invariants)."
    - "socket_extra129.zspec.zsdl — covers socket.__all__ list membership / socket.socket C method __objclass__.__name__ equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() values / SocketIO class identity (ABCMeta, module, bases, qualname length) (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW __class__.__name__=='SocketKind' / AddressFamily/SocketKind __bases__[0].__name__=='IntEnum' / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 310 theme: socket.AF_INET/AF_INET6/AF_UNIX and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW enum value equality / AddressFamily and SocketKind class name lengths / enum member name lengths."
    - "socket.AF_INET.value == 2. IPv4 address family, numeric value 2 on macOS and Linux. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.value == 30. IPv6 address family, numeric value 30 on macOS (value is 10 on Linux). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.value == 1. Unix domain socket address family, numeric value 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.value == 1. Stream socket type (TCP), numeric value 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.value == 2. Datagram socket type (UDP), numeric value 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.value == 3. Raw socket type, numeric value 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. len == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. len == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__module__ == 'socket'. AddressFamily is defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__module__ == 'socket'. SocketKind is defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.name.__len__() == 7. len('AF_INET') == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.name.__len__() == 7. len('AF_UNIX') == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.name.__len__() == 11. len('SOCK_STREAM') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.name.__len__() == 10. len('SOCK_DGRAM') == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.name.__len__() == 8. len('SOCK_RAW') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket_extra95 anchors AF_INET/AF_INET6/AF_UNIX/SOCK_STREAM/SOCK_DGRAM/SOCK_RAW numeric values and names at table level. This spec anchors the same values via .value.__eq__() and .name.__len__() calls under sockenumeq131, adding class name length and module equality — not covered by extra95."
    - "Note: socket_extra96 anchors AF_INET.__class__.__name__=='AddressFamily' and SOCK_STREAM.__class__.__name__=='SocketKind' at table level. This spec anchors the class name lengths and module equality for these enum types."
    - "Note: AF_INET6.value == 30 is macOS-specific (the BSD value). On Linux, AF_INET6 == 10. These specs target macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.value.__eq__(2)
# socket.AF_INET6.value.__eq__(30)
# socket.AF_UNIX.value.__eq__(1)
# socket.SOCK_STREAM.value.__eq__(1)
# socket.SOCK_DGRAM.value.__eq__(2)
#
# Wave 310 theme: AddressFamily and SocketKind enum .value equality.
#
# The integer values of AF_INET (2), AF_INET6 (30 on macOS), AF_UNIX (1),
# SOCK_STREAM (1), and SOCK_DGRAM (2) are fixed POSIX/BSD constants. These
# values are exposed as Python int attributes via .value on IntEnum members.
# socket_extra95 anchors these values at table level as direct comparisons;
# this spec anchors them via .value.__eq__() method calls under sockenumeq131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra131.AF_SOCK_value_equality:
  description: "socket.AF_INET/value/__eq__(2)==True / AF_INET6/value/__eq__(30)==True (macOS) / AF_UNIX/value/__eq__(1)==True / SOCK_STREAM/value/__eq__(1)==True / SOCK_DGRAM/value/__eq__(2)==True — POSIX/BSD constants for address family and socket type; extra95 anchors at table level as direct values; this spec anchors via .value.__eq__() calls; first sockenumeq131 anchor"
  kind: python_call_eq
  category: enum_values
  id_prefix: sockenumeq131

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_val,   AF_INET.value.__eq__,   [2],  true, "AF_INET.value is 2 (IPv4; POSIX constant AF_INET=2 on all platforms)"]
    - [af_inet6_val,  AF_INET6.value.__eq__,  [30], true, "AF_INET6.value is 30 (IPv6; BSD value on macOS; Linux uses 10)"]
    - [af_unix_val,   AF_UNIX.value.__eq__,   [1],  true, "AF_UNIX.value is 1 (Unix domain sockets; POSIX constant)"]
    - [sock_stream,   SOCK_STREAM.value.__eq__, [1], true, "SOCK_STREAM.value is 1 (TCP stream sockets; POSIX constant)"]
    - [sock_dgram,    SOCK_DGRAM.value.__eq__, [2],  true, "SOCK_DGRAM.value is 2 (UDP datagram sockets; POSIX constant)"]

# ---------------------------------------------------------------------------
# socket.SOCK_RAW.value.__eq__(3)
# socket.AF_INET.__class__.__name__.__len__().__eq__(13)
# socket.SOCK_STREAM.__class__.__name__.__len__().__eq__(10)
# socket.AF_INET.__class__.__module__.__eq__('socket')
# socket.SOCK_STREAM.__class__.__module__.__eq__('socket')
#
# Wave 310 theme: SOCK_RAW value and enum class name lengths and modules.
#
# SOCK_RAW.value is 3 (raw socket access). AddressFamily class name is
# 'AddressFamily' (13 chars); SocketKind class name is 'SocketKind' (10 chars).
# Both enum classes are defined in Lib/socket.py (__module__ == 'socket').
# socket_extra96 anchors AF_INET.__class__.__name__=='AddressFamily' and
# SOCK_STREAM.__class__.__name__=='SocketKind' at table level; this spec adds
# class name lengths and module equality under sockenumeq131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra131.enum_class_name_lengths_and_modules:
  description: "SOCK_RAW/value/__eq__(3)==True / AF_INET/__class__.__name__/__len__().__eq__(13)==True / SOCK_STREAM/__class__.__name__/__len__().__eq__(10)==True / AF_INET/__class__.__module__.__eq__('socket')==True / SOCK_STREAM/__class__.__module__.__eq__('socket')==True — SOCK_RAW=3; AddressFamily is 13 chars; SocketKind is 10 chars; both enums defined in Lib/socket.py; extra96 anchors class names; first sockenumeq131 anchor for lengths and modules"
  kind: python_call_eq
  category: enum_values
  id_prefix: sockenumeq131

  columns: [id, function, args, expected, description]
  rows:
    - [sock_raw_val,       SOCK_RAW.value.__eq__,                           [3],       true, "SOCK_RAW.value is 3 (raw socket; POSIX constant SOCK_RAW=3)"]
    - [af_cls_name_len,    AF_INET.__class__.__name__.__len__,               [],        13,   "len('AddressFamily') == 13 (the enum class name for AF_* constants)"]
    - [sock_cls_name_len,  SOCK_STREAM.__class__.__name__.__len__,           [],        10,   "len('SocketKind') == 10 (the enum class name for SOCK_* constants)"]
    - [af_cls_module,      AF_INET.__class__.__module__.__eq__,              ["socket"], true, "AddressFamily.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [sock_cls_module,    SOCK_STREAM.__class__.__module__.__eq__,          ["socket"], true, "SocketKind.__module__ is 'socket' (defined in Lib/socket.py)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.name.__len__()==7
# socket.AF_UNIX.name.__len__()==7
# socket.SOCK_STREAM.name.__len__()==11
# socket.SOCK_DGRAM.name.__len__()==10
# socket.SOCK_RAW.name.__len__()==8
#
# Wave 310 theme: Enum member .name string lengths.
#
# Each enum member's .name attribute holds the string name of the constant.
# AF_INET: 'AF_INET' (7 chars), AF_UNIX: 'AF_UNIX' (7 chars — same length as
# AF_INET). SOCK_STREAM: 'SOCK_STREAM' (11 chars), SOCK_DGRAM: 'SOCK_DGRAM'
# (10 chars), SOCK_RAW: 'SOCK_RAW' (8 chars). socket_extra95 anchors the name
# strings; this spec anchors the name string lengths under sockenumeq131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra131.enum_member_name_lengths:
  description: "socket.AF_INET/name/__len__()==7 / AF_UNIX/name/__len__()==7 / SOCK_STREAM/name/__len__()==11 / SOCK_DGRAM/name/__len__()==10 / SOCK_RAW/name/__len__()==8 — AF_INET and AF_UNIX share name length 7; SOCK_STREAM is 11; SOCK_DGRAM is 10; SOCK_RAW is 8; extra95 anchors name strings; first sockenumeq131 anchor for .name.__len__() values"
  kind: python_call_eq
  category: enum_values
  id_prefix: sockenumeq131

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_name_len,   AF_INET.name.__len__,    [], 7,  "'AF_INET' is 7 chars"]
    - [af_unix_name_len,   AF_UNIX.name.__len__,    [], 7,  "'AF_UNIX' is 7 chars (same length as AF_INET)"]
    - [sock_stream_nlen,   SOCK_STREAM.name.__len__, [], 11, "'SOCK_STREAM' is 11 chars"]
    - [sock_dgram_nlen,    SOCK_DGRAM.name.__len__,  [], 10, "'SOCK_DGRAM' is 10 chars"]
    - [sock_raw_nlen,      SOCK_RAW.name.__len__,    [], 8,  "'SOCK_RAW' is 8 chars"]

# ---------------------------------------------------------------------------
# socket.AF_INET.value.__eq__(2) — standalone
#
# socket.AF_INET.value is 2. This is the POSIX AF_INET constant (Address
# Family: Internet). It is consistent across all platforms (macOS, Linux,
# Windows). AF_INET (value 2) is the most commonly used address family for
# IPv4 TCP/IP networking. socket_extra95 anchors the value at table level;
# this is the first standalone for AF_INET.value.__eq__(2) under sockenumeq131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra131.AF_INET_value_2:
  description: "socket.AF_INET.value.__eq__(2) == True — AF_INET is 2 on all POSIX platforms; the primary IPv4 address family constant; socket_extra95 anchors at table level; first standalone for AF_INET.value.__eq__(2) under sockenumeq131"
  category: enum_values
  kind: python_call_eq
  function: AF_INET.value.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.value.__eq__(1) — standalone
#
# socket.SOCK_STREAM.value is 1. This is the POSIX SOCK_STREAM constant for
# stream (TCP) sockets. It is consistent across all POSIX platforms. SOCK_STREAM
# provides reliable, ordered, connection-based byte streams (used by TCP). Its
# value (1) is the same as AF_UNIX.value (1), but these are from different
# enum types (SocketKind vs AddressFamily). socket_extra95 anchors at table
# level; this is the first standalone under sockenumeq131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra131.SOCK_STREAM_value_1:
  description: "socket.SOCK_STREAM.value.__eq__(1) == True — SOCK_STREAM is 1 on all POSIX platforms; stream (TCP) socket type; same numeric value as AF_UNIX.value (1) but from different enum type (SocketKind vs AddressFamily); extra95 anchors at table level; first standalone under sockenumeq131"
  category: enum_values
  kind: python_call_eq
  function: SOCK_STREAM.value.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__len__().__eq__(13) — standalone
#
# socket.AF_INET.__class__.__name__.__len__() is 13. The class name is
# 'AddressFamily' which has 13 characters. This length distinguishes it
# from 'SocketKind' (10 chars). The AddressFamily IntEnum class is defined
# in Lib/socket.py and contains all AF_* constants. No prior socket spec
# anchors AF_INET.__class__.__name__.__len__().__eq__(13) as a standalone
# under sockenumeq131. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra131.AddressFamily_name_len_13:
  description: "socket.AF_INET.__class__.__name__.__len__().__eq__(13) == True — 'AddressFamily' is 13 chars; the IntEnum class for AF_* constants; distinguishes from 'SocketKind' (10 chars); first standalone for AddressFamily name length under sockenumeq131"
  category: enum_values
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__name__.__len__().__eq__(10) — standalone
#
# socket.SOCK_STREAM.__class__.__name__.__len__() is 10. The class name is
# 'SocketKind' which has 10 characters. This is shorter than 'AddressFamily'
# (13 chars). The SocketKind IntEnum class is defined in Lib/socket.py and
# contains all SOCK_* constants. No prior socket spec anchors
# SOCK_STREAM.__class__.__name__.__len__().__eq__(10) as a standalone under
# sockenumeq131. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra131.SocketKind_name_len_10:
  description: "socket.SOCK_STREAM.__class__.__name__.__len__().__eq__(10) == True — 'SocketKind' is 10 chars; the IntEnum class for SOCK_* constants; shorter than 'AddressFamily' (13 chars); first standalone for SocketKind name length under sockenumeq131"
  category: enum_values
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__module__.__eq__('socket') — standalone
#
# socket.AF_INET.__class__.__module__ is 'socket'. The AddressFamily IntEnum
# class is defined in Lib/socket.py (the pure-Python socket module), not in
# the socketmodule.c C extension. This reflects Python's design where the
# enum wrappers around integer constants are defined in the Python layer.
# No prior socket spec anchors AddressFamily.__module__.__eq__('socket') as
# a standalone under sockenumeq131. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra131.AddressFamily_module_socket:
  description: "socket.AF_INET.__class__.__module__.__eq__('socket') == True — AddressFamily IntEnum class is defined in Lib/socket.py (not C extension socketmodule.c); Python-layer enum wrappers around integer constants; first standalone for AddressFamily.__module__ under sockenumeq131"
  category: enum_values
  kind: python_call_eq
  function: AF_INET.__class__.__module__.__eq__
  args: ["socket"]
  expected: true
