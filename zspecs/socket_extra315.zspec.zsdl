spec: socket_extra315
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.socket() with no arguments creates an AF_INET/SOCK_STREAM socket (the POSIX default)."
    - "socket.socket().__class__.__name__ == 'socket' — the instance class is named 'socket'."
    - "The .family attribute of a default socket is AF_INET (== 2); its __class__.__name__ == 'AddressFamily'."
    - "The .type attribute of a default socket is SOCK_STREAM (== 1); its __class__.__name__ == 'SocketKind'."
    - "The default timeout is None (blocking mode). socket.socket().timeout.__eq__(None) is True."
    - "socket.socket().fileno() returns a non-negative int (the OS file descriptor)."
    - "socket_extra2.zspec.zsdl covers AddressFamily/SocketKind class names on module-level constants; this spec covers the same class names on a live socket instance."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket() — instance class name
# ---------------------------------------------------------------------------

invariant socket_extra315.socket_instance.class_name:
  description: "socket.socket().__class__.__name__ == 'socket'"
  category: instance_identity
  kind: python_call_eq
  function: socket
  args: []
  method: __class__.__name__.__eq__
  method_args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket().family — AddressFamily enum
# ---------------------------------------------------------------------------

invariant socket_extra315.socket_instance.family_class_name:
  description: "socket.socket().family.__class__.__name__ == 'AddressFamily'"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: []
  method: family.__class__.__name__.__eq__
  method_args: ["AddressFamily"]
  expected: true

invariant socket_extra315.socket_instance.family_value:
  description: "socket.socket().family == socket.AF_INET == 2 (default address family)"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: []
  method: family.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket().type — SocketKind enum
# ---------------------------------------------------------------------------

invariant socket_extra315.socket_instance.type_class_name:
  description: "socket.socket().type.__class__.__name__ == 'SocketKind'"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: []
  method: type.__class__.__name__.__eq__
  method_args: ["SocketKind"]
  expected: true

invariant socket_extra315.socket_instance.type_value:
  description: "socket.socket().type == socket.SOCK_STREAM == 1 (default socket type)"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: []
  method: type.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket().timeout — default is None (blocking mode)
# ---------------------------------------------------------------------------

invariant socket_extra315.socket_instance.timeout_is_none:
  description: "socket.socket().timeout.__eq__(None) is True — default timeout is None (blocking)"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: []
  method: timeout.__eq__
  method_args: [~]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket().fileno() — returns an int (OS file descriptor)
# ---------------------------------------------------------------------------

invariant socket_extra315.socket_instance.fileno_class_name:
  description: "socket.socket().fileno().__class__.__name__ == 'int'"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: []
  method: fileno
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["int"]
  expected: true
