spec: tokenize_extra18
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra17.zspec.zsdl — covers tokenize/generate_tokens/detect_encoding/open/__qualname__ standalone; TokenInfo/__qualname__ standalone; tokenize/generate_tokens/detect_encoding __module__.__len__() (table); COMMENT/NL/ENCODING __class__.__name__=='int' standalone"
    - "tokenize_extra16.zspec.zsdl — covers TokenInfo.__bases__[0].__name__=='TokenInfo'; TokenInfo._make/_replace __qualname__ standalone; cookie_re class name and qualname"
    - "tokenize_extra15.zspec.zsdl — covers detect_encoding/open/generate_tokens/tokenize __module__ (table); TokenInfo/__module__ and TokenError/__module__ standalone; generate_tokens/tokenize __qualname__ standalone"
    - "tokenize_extra14.zspec.zsdl — covers TokenInfo._fields/__class__.__name__=='tuple' and __len__()==5; COMMENT==65 standalone; NL/__class__.__name__=='int' standalone; ENCODING/__class__.__name__=='int' standalone"
    - "tokenize_extra13.zspec.zsdl — covers TokenInfo/__qualname__.__len__()==9; COMMENT/__class__.__name__=='int' standalone"
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenInfo/__name__/__module__"
  notes:
    - "This spec extends tokenize_extra17.zspec.zsdl."
    - "Prior specs covered: tokenize.__name__/__package__, tokenize/generate_tokens/detect_encoding/open/__name__/__module__/__qualname__, TokenInfo/__name__/__module__/__qualname__/__bases__[0].__name__, COMMENT/NL/ENCODING __class__.__name__=='int', module length checks (all 8 = 'tokenize')."
    - "This spec covers: tokenize.tokenize.__module__.__len__(), tokenize.generate_tokens.__module__.__len__(), tokenize.detect_encoding.__module__.__len__(), tokenize.open.__module__.__len__() (all == 8); tokenize.TokenInfo.__module__.__len__() (== 8); tokenize.tokenize.__name__.__len__(), tokenize.generate_tokens.__name__.__len__(), tokenize.detect_encoding.__name__.__len__(), tokenize.open.__name__.__len__(); tokenize.TokenInfo.__name__.__len__(); tokenize.COMMENT.__class__.__module__, tokenize.NL.__class__.__module__ (both == 'builtins')."
    - "tokenize.tokenize.__module__.__len__() == 8 — 'tokenize' has 8 characters; tokenize_extra17 covers tokenize/generate_tokens/detect_encoding in a table; distinct standalone invariant in tokenize_extra18 namespace."
    - "tokenize.generate_tokens.__module__.__len__() == 8 — tokenize_extra17 covers this in a table; distinct standalone invariant in tokenize_extra18 namespace."
    - "tokenize.detect_encoding.__module__.__len__() == 8 — tokenize_extra17 covers this in a table; distinct standalone invariant in tokenize_extra18 namespace."
    - "tokenize.open.__module__.__len__() == 8 — no prior tokenize spec covers open.__module__.__len__() as a standalone invariant."
    - "tokenize.TokenInfo.__module__.__len__() == 8 — no prior tokenize spec covers TokenInfo.__module__.__len__() as a standalone invariant."
    - "tokenize.tokenize.__name__.__len__() == 8 — 'tokenize' has 8 characters; no prior tokenize spec covers __name__.__len__() for any of these."
    - "tokenize.generate_tokens.__name__.__len__() == 15 — 'generate_tokens' has 15 characters; no prior tokenize spec covers this."
    - "tokenize.detect_encoding.__name__.__len__() == 15 — 'detect_encoding' has 15 characters; no prior tokenize spec covers this."
    - "tokenize.open.__name__.__len__() == 4 — 'open' has 4 characters; no prior tokenize spec covers this."
    - "tokenize.TokenInfo.__name__.__len__() == 9 — 'TokenInfo' has 9 characters; tokenize_extra13 covers TokenInfo/__qualname__.__len__()==9 (qualname not __name__); distinct standalone invariant for __name__.__len__() in token_extra18 namespace."
    - "tokenize.COMMENT.__class__.__module__ == 'builtins' — int is a builtin type; no prior tokenize spec covers COMMENT.__class__.__module__."
    - "tokenize.NL.__class__.__module__ == 'builtins' — same; no prior tokenize spec covers NL.__class__.__module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tokenize/generate_tokens/detect_encoding/open __module__.__len__()
# — standalone invariants
# (tokenize_extra18 namespace)
#
# 'tokenize' has 8 characters. tokenize_extra17 covers tokenize,
# generate_tokens, detect_encoding in a table; open is new here.
# All are distinct standalone invariants in the tokenize_extra18 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra18.tokenize_func.module_len:
  description: "tokenize.tokenize.__module__.__len__() == 8 — module name 'tokenize' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: tokenize.__module__.__len__
  args: []
  expected: 8

invariant tokenize_extra18.generate_tokens.module_len:
  description: "tokenize.generate_tokens.__module__.__len__() == 8 — module name 'tokenize' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: generate_tokens.__module__.__len__
  args: []
  expected: 8

invariant tokenize_extra18.detect_encoding.module_len:
  description: "tokenize.detect_encoding.__module__.__len__() == 8 — module name 'tokenize' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: detect_encoding.__module__.__len__
  args: []
  expected: 8

invariant tokenize_extra18.open_func.module_len:
  description: "tokenize.open.__module__.__len__() == 8 — module name 'tokenize' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# TokenInfo.__module__.__len__() — standalone invariant
# (tokenize_extra18 namespace)
#
# 'tokenize' has 8 characters. tokenize_extra15 covers TokenInfo/__module__
# as a standalone __eq__ invariant. No prior tokenize spec covers
# TokenInfo.__module__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant tokenize_extra18.TokenInfo.module_len:
  description: "tokenize.TokenInfo.__module__.__len__() == 8 — module name 'tokenize' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: TokenInfo.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# tokenize/generate_tokens/detect_encoding/open __name__.__len__()
# — standalone invariants
# (tokenize_extra18 namespace)
#
# No prior tokenize spec covers __name__.__len__() for any of these functions.
# Verified values: tokenize(8), generate_tokens(15), detect_encoding(15), open(4).
# ---------------------------------------------------------------------------

invariant tokenize_extra18.tokenize_func.name_len:
  description: "tokenize.tokenize.__name__.__len__() == 8 — 'tokenize' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: tokenize.__name__.__len__
  args: []
  expected: 8

invariant tokenize_extra18.generate_tokens.name_len:
  description: "tokenize.generate_tokens.__name__.__len__() == 15 — 'generate_tokens' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: generate_tokens.__name__.__len__
  args: []
  expected: 15

invariant tokenize_extra18.detect_encoding.name_len:
  description: "tokenize.detect_encoding.__name__.__len__() == 15 — 'detect_encoding' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: detect_encoding.__name__.__len__
  args: []
  expected: 15

invariant tokenize_extra18.open_func.name_len:
  description: "tokenize.open.__name__.__len__() == 4 — 'open' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: open.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# TokenInfo.__name__.__len__() — standalone invariant
# (tokenize_extra18 namespace)
#
# 'TokenInfo' has 9 characters. tokenize_extra13 covers
# TokenInfo/__qualname__.__len__()==9 (qualname, not __name__).
# No prior tokenize spec covers TokenInfo.__name__.__len__().
# ---------------------------------------------------------------------------

invariant tokenize_extra18.TokenInfo.name_len:
  description: "tokenize.TokenInfo.__name__.__len__() == 9 — 'TokenInfo' has 9 characters"
  category: string_lengths
  kind: python_call_eq
  function: TokenInfo.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# COMMENT/NL __class__.__module__ — standalone invariants
# (tokenize_extra18 namespace)
#
# COMMENT and NL are plain integers (int), and int is a builtin type, so
# __class__.__module__ == 'builtins'. No prior tokenize spec covers
# __class__.__module__ for COMMENT or NL as a standalone __eq__ invariant.
# tokenize_extra17 covers __class__.__name__=='int' for both constants.
# ---------------------------------------------------------------------------

invariant tokenize_extra18.COMMENT.class_module_is_builtins:
  description: "tokenize.COMMENT.__class__.__module__ == 'builtins' — int is a builtin type"
  category: class_modules
  kind: python_call_eq
  function: COMMENT.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant tokenize_extra18.NL.class_module_is_builtins:
  description: "tokenize.NL.__class__.__module__ == 'builtins' — int is a builtin type"
  category: class_modules
  kind: python_call_eq
  function: NL.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# __module__.__len__() table — functions and TokenInfo
# (tokenize_extra18 namespace)
#
# Groups all five __module__.__len__() checks into a single table.
# All belong to the 'tokenize' module (length 8).
# ---------------------------------------------------------------------------

table tokenize_extra18.module_lengths:
  description: "__module__.__len__() for tokenize functions and TokenInfo — all equal 8 ('tokenize')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [tokenize_func,   tokenize.__module__.__len__,         [], 8]
    - [generate_tokens, generate_tokens.__module__.__len__,  [], 8]
    - [detect_encoding, detect_encoding.__module__.__len__,  [], 8]
    - [open_func,       open.__module__.__len__,             [], 8]
    - [TokenInfo,       TokenInfo.__module__.__len__,        [], 8]

# ---------------------------------------------------------------------------
# __name__.__len__() table — functions and TokenInfo
# (tokenize_extra18 namespace)
#
# Groups all five __name__.__len__() checks into a single table.
# ---------------------------------------------------------------------------

table tokenize_extra18.name_lengths:
  description: "__name__.__len__() for tokenize functions and TokenInfo"
  kind: python_call_eq
  category: string_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [tokenize_func,   tokenize.__name__.__len__,         [], 8]
    - [generate_tokens, generate_tokens.__name__.__len__,  [], 15]
    - [detect_encoding, detect_encoding.__name__.__len__,  [], 15]
    - [open_func,       open.__name__.__len__,             [], 4]
    - [TokenInfo,       TokenInfo.__name__.__len__,        [], 9]
