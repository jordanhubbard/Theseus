spec: dc3406
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (dc3406): __bool__, __str__, __repr__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "decimal.Decimal defines __bool__ (true): bool(Decimal('0')) is False, bool(Decimal('1')) is True — Decimal implements truthiness."
    - "decimal.Decimal defines __str__ (true): str(Decimal('3.14')) returns '3.14' — Decimal implements string conversion."
    - "decimal.Decimal defines __repr__ (true): repr(Decimal('3.14')) returns \"Decimal('3.14')\" — Decimal implements repr."
    - "decimal.Context does NOT define __bool__, __str__, or __repr__ in its own __dict__: Context is a precision/rounding configuration object."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no bool/str/repr protocol defined in their own __dict__."
    - "decimal.Decimal is unique among the covered types in this wave: it is the only type defining __bool__, __str__, and __repr__ (all true), reflecting its status as a complete numeric type with rich string and truthiness semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# decimal.Decimal DOES define __bool__ in its own __dict__: true.
# bool(Decimal('0')) is False, bool(Decimal('1')) is True — Decimal
# implements truthiness via __bool__.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3406.bool:
  description: "decimal types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
