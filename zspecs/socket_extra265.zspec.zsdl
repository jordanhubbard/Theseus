spec: socket_extra265
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra264.zspec.zsdl — covers socket.socket setblocking/makefile/settimeout/gettimeout/fileno method identity; CMSG_SPACE/CMSG_LEN function identity and macOS values."
    - "socket_extra263.zspec.zsdl — covers socket module identity (__name__, __package__, __spec__, __loader__); socket.socket.__doc__ string checks; IPPROTO_ICMP/TCP/UDP/IP/IPV6 integer values."
    - "socket.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; socket/herror/gaierror class names."
  notes:
    - "socket.AF_INET is AddressFamily.AF_INET with integer value 2 — portable across all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AF_UNSPEC is AddressFamily.AF_UNSPEC with integer value 0 — unspecified address family, portable. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_STREAM is SocketKind.SOCK_STREAM with integer value 1 — TCP stream socket, portable. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_DGRAM is SocketKind.SOCK_DGRAM with integer value 2 — UDP datagram socket, portable. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_RAW is SocketKind.SOCK_RAW with integer value 3 — raw socket, portable. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an IntEnum member; its integer value is platform-specific (30 on macOS, 10 on Linux). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is an IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Address family type identity — AF_INET, AF_INET6, AF_UNSPEC
# All are AddressFamily IntEnum members; AF_INET == 2 and AF_UNSPEC == 0
# are portable across all platforms.
# ---------------------------------------------------------------------------

table socket_extra265.address_family_identity:
  description: "socket.AF_INET/AF_INET6/AF_UNSPEC __class__.__name__ — all are AddressFamily (IntEnum); AF_INET==2 and AF_UNSPEC==0 are portable; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockaf265

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class,    AF_INET.__class__.__name__.__eq__,    ["AddressFamily"], true, "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member"]
    - [af_inet6_class,   AF_INET6.__class__.__name__.__eq__,   ["AddressFamily"], true, "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an IntEnum member"]
    - [af_unspec_class,  AF_UNSPEC.__class__.__name__.__eq__,  ["AddressFamily"], true, "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily' — AF_UNSPEC is an IntEnum member"]
    - [af_inet_value,    AF_INET.__eq__,                       [2],               true, "socket.AF_INET == 2 — portable value across all platforms"]
    - [af_unspec_value,  AF_UNSPEC.__eq__,                     [0],               true, "socket.AF_UNSPEC == 0 — unspecified address family, portable value"]

# ---------------------------------------------------------------------------
# Socket kind type identity — SOCK_STREAM, SOCK_DGRAM, SOCK_RAW
# All are SocketKind IntEnum members; values 1/2/3 are portable.
# ---------------------------------------------------------------------------

table socket_extra265.socket_kind_identity:
  description: "socket.SOCK_STREAM/SOCK_DGRAM/SOCK_RAW __class__.__name__ — all are SocketKind (IntEnum); values 1/2/3 are portable; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socksk265

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_class,  SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"], true, "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member"]
    - [sock_dgram_class,   SOCK_DGRAM.__class__.__name__.__eq__,  ["SocketKind"], true, "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is an IntEnum member"]
    - [sock_raw_class,     SOCK_RAW.__class__.__name__.__eq__,    ["SocketKind"], true, "socket.SOCK_RAW.__class__.__name__ == 'SocketKind' — SOCK_RAW is an IntEnum member"]
    - [sock_stream_value,  SOCK_STREAM.__eq__,                    [1],            true, "socket.SOCK_STREAM == 1 — TCP stream socket, portable value"]
    - [sock_dgram_value,   SOCK_DGRAM.__eq__,                     [2],            true, "socket.SOCK_DGRAM == 2 — UDP datagram socket, portable value"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra265.AF_INET_class_eq:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member of AddressFamily"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra265.AF_INET_value_eq:
  description: "socket.AF_INET == 2 — AF_INET integer value is 2 on all platforms"
  category: identity
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra265.AF_UNSPEC_value_eq:
  description: "socket.AF_UNSPEC == 0 — AF_UNSPEC integer value is 0 on all platforms"
  category: identity
  kind: python_call_eq
  function: AF_UNSPEC.__eq__
  args: [0]
  expected: true

invariant socket_extra265.SOCK_STREAM_class_eq:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member of SocketKind"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra265.SOCK_STREAM_value_eq:
  description: "socket.SOCK_STREAM == 1 — SOCK_STREAM integer value is 1 on all platforms"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra265.SOCK_DGRAM_class_eq:
  description: "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is an IntEnum member of SocketKind"
  category: identity
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra265.SOCK_DGRAM_value_eq:
  description: "socket.SOCK_DGRAM == 2 — SOCK_DGRAM integer value is 2 on all platforms"
  category: identity
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

invariant socket_extra265.SOCK_RAW_value_eq:
  description: "socket.SOCK_RAW == 3 — SOCK_RAW integer value is 3 on all platforms"
  category: identity
  kind: python_call_eq
  function: SOCK_RAW.__eq__
  args: [3]
  expected: true
