spec: pathlib_extra262
version: ">=3.12"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib.Path traversal and comparison method identity: glob, rglob, walk, iterdir, samefile, is_symlink, is_mount, lstat."
    - "pathlib.Path.glob.__name__ == 'glob', __qualname__ == 'Path.glob' — yields paths matching a pattern."
    - "pathlib.Path.rglob.__name__ == 'rglob', __qualname__ == 'Path.rglob' — recursive glob traversal."
    - "pathlib.Path.walk.__name__ == 'walk', __qualname__ == 'Path.walk' — added in Python 3.12; generates (dirpath, dirnames, filenames) tuples."
    - "pathlib.Path.iterdir.__name__ == 'iterdir', __qualname__ == 'Path.iterdir' — iterates directory children."
    - "pathlib.Path.samefile.__name__ == 'samefile', __qualname__ == 'Path.samefile' — tests if two paths refer to the same file."
    - "pathlib.Path.is_symlink.__name__ == 'is_symlink', __qualname__ == 'Path.is_symlink' — True if the path is a symbolic link."
    - "pathlib.Path.is_mount.__name__ == 'is_mount', __qualname__ == 'Path.is_mount' — True if the path is a mount point."
    - "pathlib.Path.lstat.__name__ == 'lstat', __qualname__ == 'Path.lstat' — like stat() but does not follow symlinks."
    - "All listed methods are pure-Python functions (__class__.__name__ == 'function'), not C builtins."
    - "version set to >=3.12 because pathlib.Path.walk was added in Python 3.12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path glob and recursive traversal method identity
#
# glob, rglob, and walk are the three directory-traversal methods on Path.
# glob and rglob yield matching paths; walk (Python 3.12+) generates
# (dirpath, dirnames, filenames) triples like os.walk. All are pure Python.
# ---------------------------------------------------------------------------

table pathlib_extra262.path_traversal_method_identity:
  description: "pathlib.Path traversal method identity — __name__, __qualname__, and class kind for glob, rglob, walk; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: plxptm262

  columns: [id, function, args, expected, description]
  rows:
    - [glob_name,
       "Path.glob.__name__.__eq__",
       ["glob"],
       true,
       "pathlib.Path.glob.__name__.__eq__('glob') == True — glob yields all matching paths under the path using a shell-style pattern; its __name__ is 'glob'; str.__eq__('glob') returns True; new to extra262"]
    - [glob_qualname,
       "Path.glob.__qualname__.__eq__",
       ["Path.glob"],
       true,
       "pathlib.Path.glob.__qualname__.__eq__('Path.glob') == True — the qualified name is 'Path.glob', confirming it is defined in the Path class; str.__eq__('Path.glob') returns True; new to extra262"]
    - [glob_class,
       "Path.glob.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.glob.__class__.__name__.__eq__('function') == True — glob is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra262"]
    - [rglob_name,
       "Path.rglob.__name__.__eq__",
       ["rglob"],
       true,
       "pathlib.Path.rglob.__name__.__eq__('rglob') == True — rglob is equivalent to calling glob('**/' + pattern), recursively matching the pattern throughout the subtree; its __name__ is 'rglob'; str.__eq__('rglob') returns True; new to extra262"]
    - [rglob_qualname,
       "Path.rglob.__qualname__.__eq__",
       ["Path.rglob"],
       true,
       "pathlib.Path.rglob.__qualname__.__eq__('Path.rglob') == True — the qualified name is 'Path.rglob'; str.__eq__('Path.rglob') returns True; new to extra262"]
    - [rglob_class,
       "Path.rglob.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.rglob.__class__.__name__.__eq__('function') == True — rglob is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra262"]
    - [walk_name,
       "Path.walk.__name__.__eq__",
       ["walk"],
       true,
       "pathlib.Path.walk.__name__.__eq__('walk') == True — walk (Python 3.12+) generates (dirpath, dirnames, filenames) tuples for the directory tree rooted at the path, analogous to os.walk; its __name__ is 'walk'; str.__eq__('walk') returns True; new to extra262"]
    - [walk_qualname,
       "Path.walk.__qualname__.__eq__",
       ["Path.walk"],
       true,
       "pathlib.Path.walk.__qualname__.__eq__('Path.walk') == True — the qualified name is 'Path.walk'; str.__eq__('Path.walk') returns True; new to extra262"]
    - [walk_class,
       "Path.walk.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.walk.__class__.__name__.__eq__('function') == True — walk is a pure-Python method (added in Python 3.12); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra262"]
    - [iterdir_name,
       "Path.iterdir.__name__.__eq__",
       ["iterdir"],
       true,
       "pathlib.Path.iterdir.__name__.__eq__('iterdir') == True — iterdir yields all immediate children of the directory; its __name__ is 'iterdir'; str.__eq__('iterdir') returns True; new to extra262"]
    - [iterdir_qualname,
       "Path.iterdir.__qualname__.__eq__",
       ["Path.iterdir"],
       true,
       "pathlib.Path.iterdir.__qualname__.__eq__('Path.iterdir') == True — the qualified name is 'Path.iterdir'; str.__eq__('Path.iterdir') returns True; new to extra262"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path comparison and stat method identity
#
# samefile, is_symlink, is_mount, and lstat are the key comparison and
# stat-inspection methods on Path. All are pure Python functions.
# samefile compares inodes; is_symlink/is_mount check filesystem properties;
# lstat calls lstat(2) without following symlinks.
# ---------------------------------------------------------------------------

table pathlib_extra262.path_comparison_stat_identity:
  description: "pathlib.Path comparison and stat method identity — __name__, __qualname__, and class kind for samefile, is_symlink, is_mount, lstat; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: plxpcs262

  columns: [id, function, args, expected, description]
  rows:
    - [samefile_name,
       "Path.samefile.__name__.__eq__",
       ["samefile"],
       true,
       "pathlib.Path.samefile.__name__.__eq__('samefile') == True — samefile returns True if this path refers to the same file as another path (compares inodes and devices); its __name__ is 'samefile'; str.__eq__('samefile') returns True; new to extra262"]
    - [samefile_qualname,
       "Path.samefile.__qualname__.__eq__",
       ["Path.samefile"],
       true,
       "pathlib.Path.samefile.__qualname__.__eq__('Path.samefile') == True — the qualified name is 'Path.samefile'; str.__eq__('Path.samefile') returns True; new to extra262"]
    - [samefile_class,
       "Path.samefile.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.samefile.__class__.__name__.__eq__('function') == True — samefile is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra262"]
    - [is_symlink_name,
       "Path.is_symlink.__name__.__eq__",
       ["is_symlink"],
       true,
       "pathlib.Path.is_symlink.__name__.__eq__('is_symlink') == True — is_symlink returns True if the path points to a symbolic link; its __name__ is 'is_symlink'; str.__eq__('is_symlink') returns True; new to extra262"]
    - [is_symlink_qualname,
       "Path.is_symlink.__qualname__.__eq__",
       ["Path.is_symlink"],
       true,
       "pathlib.Path.is_symlink.__qualname__.__eq__('Path.is_symlink') == True — the qualified name is 'Path.is_symlink'; str.__eq__('Path.is_symlink') returns True; new to extra262"]
    - [is_symlink_class,
       "Path.is_symlink.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.is_symlink.__class__.__name__.__eq__('function') == True — is_symlink is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra262"]
    - [is_mount_name,
       "Path.is_mount.__name__.__eq__",
       ["is_mount"],
       true,
       "pathlib.Path.is_mount.__name__.__eq__('is_mount') == True — is_mount returns True if the path is a mount point (a point where a different filesystem is mounted); its __name__ is 'is_mount'; str.__eq__('is_mount') returns True; new to extra262"]
    - [is_mount_qualname,
       "Path.is_mount.__qualname__.__eq__",
       ["Path.is_mount"],
       true,
       "pathlib.Path.is_mount.__qualname__.__eq__('Path.is_mount') == True — the qualified name is 'Path.is_mount'; str.__eq__('Path.is_mount') returns True; new to extra262"]
    - [lstat_name,
       "Path.lstat.__name__.__eq__",
       ["lstat"],
       true,
       "pathlib.Path.lstat.__name__.__eq__('lstat') == True — lstat returns a stat_result for the path like os.lstat(), without following symlinks; its __name__ is 'lstat'; str.__eq__('lstat') returns True; new to extra262"]
    - [lstat_qualname,
       "Path.lstat.__qualname__.__eq__",
       ["Path.lstat"],
       true,
       "pathlib.Path.lstat.__qualname__.__eq__('Path.lstat') == True — the qualified name is 'Path.lstat'; str.__eq__('Path.lstat') returns True; new to extra262"]
    - [lstat_class,
       "Path.lstat.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.lstat.__class__.__name__.__eq__('function') == True — lstat is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra262"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra262
# ---------------------------------------------------------------------------

invariant pathlib_extra262.glob_name:
  description: "pathlib.Path.glob.__name__ == 'glob' — yields paths matching a shell-style pattern; new to extra262"
  kind: python_call_eq
  function: Path.glob.__name__.__eq__
  args: ["glob"]
  expected: true

invariant pathlib_extra262.glob_qualname:
  description: "pathlib.Path.glob.__qualname__ == 'Path.glob' — qualified name includes the class; new to extra262"
  kind: python_call_eq
  function: Path.glob.__qualname__.__eq__
  args: ["Path.glob"]
  expected: true

invariant pathlib_extra262.glob_is_function:
  description: "pathlib.Path.glob.__class__.__name__ == 'function' — glob is a pure-Python method; new to extra262"
  kind: python_call_eq
  function: Path.glob.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra262.rglob_name:
  description: "pathlib.Path.rglob.__name__ == 'rglob' — recursive glob yielding all matching paths in the subtree; new to extra262"
  kind: python_call_eq
  function: Path.rglob.__name__.__eq__
  args: ["rglob"]
  expected: true

invariant pathlib_extra262.rglob_qualname:
  description: "pathlib.Path.rglob.__qualname__ == 'Path.rglob' — qualified name includes the class; new to extra262"
  kind: python_call_eq
  function: Path.rglob.__qualname__.__eq__
  args: ["Path.rglob"]
  expected: true

invariant pathlib_extra262.walk_name:
  description: "pathlib.Path.walk.__name__ == 'walk' — generates directory tree triples; added in Python 3.12; new to extra262"
  kind: python_call_eq
  function: Path.walk.__name__.__eq__
  args: ["walk"]
  expected: true

invariant pathlib_extra262.walk_qualname:
  description: "pathlib.Path.walk.__qualname__ == 'Path.walk' — qualified name includes the class; new to extra262"
  kind: python_call_eq
  function: Path.walk.__qualname__.__eq__
  args: ["Path.walk"]
  expected: true

invariant pathlib_extra262.walk_is_function:
  description: "pathlib.Path.walk.__class__.__name__ == 'function' — walk is a pure-Python method (Python 3.12+); new to extra262"
  kind: python_call_eq
  function: Path.walk.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra262.iterdir_name:
  description: "pathlib.Path.iterdir.__name__ == 'iterdir' — yields immediate directory children; new to extra262"
  kind: python_call_eq
  function: Path.iterdir.__name__.__eq__
  args: ["iterdir"]
  expected: true

invariant pathlib_extra262.iterdir_qualname:
  description: "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' — qualified name includes the class; new to extra262"
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__eq__
  args: ["Path.iterdir"]
  expected: true

invariant pathlib_extra262.samefile_name:
  description: "pathlib.Path.samefile.__name__ == 'samefile' — tests if two paths refer to the same file by inode; new to extra262"
  kind: python_call_eq
  function: Path.samefile.__name__.__eq__
  args: ["samefile"]
  expected: true

invariant pathlib_extra262.is_symlink_name:
  description: "pathlib.Path.is_symlink.__name__ == 'is_symlink' — returns True if the path is a symbolic link; new to extra262"
  kind: python_call_eq
  function: Path.is_symlink.__name__.__eq__
  args: ["is_symlink"]
  expected: true

invariant pathlib_extra262.is_mount_name:
  description: "pathlib.Path.is_mount.__name__ == 'is_mount' — returns True if the path is a filesystem mount point; new to extra262"
  kind: python_call_eq
  function: Path.is_mount.__name__.__eq__
  args: ["is_mount"]
  expected: true

invariant pathlib_extra262.lstat_name:
  description: "pathlib.Path.lstat.__name__ == 'lstat' — returns stat_result without following symlinks; new to extra262"
  kind: python_call_eq
  function: Path.lstat.__name__.__eq__
  args: ["lstat"]
  expected: true

invariant pathlib_extra262.lstat_qualname:
  description: "pathlib.Path.lstat.__qualname__ == 'Path.lstat' — qualified name includes the class; new to extra262"
  kind: python_call_eq
  function: Path.lstat.__qualname__.__eq__
  args: ["Path.lstat"]
  expected: true
