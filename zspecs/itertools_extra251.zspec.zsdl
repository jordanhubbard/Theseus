spec: itertools_extra251
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.product, itertools.chain, itertools.chain.from_iterable, and itertools.islice class identity behavioral contracts."
    - "itertools.product.__class__.__name__ == 'type' — product is a C-level type (class) defined in the itertools module; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — product is exposed at the itertools module level; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product' — the class name is 'product'. Verified with Python 3.14.3."
    - "itertools.chain.__class__.__name__ == 'type' — chain is a C-level type (class); __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — chain is exposed at the itertools module level; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__name__ == 'chain' — the class name is 'chain'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' — from_iterable is a classmethod descriptor; __name__ is 'from_iterable'. Verified with Python 3.14.3."
    - "itertools.islice.__name__ == 'islice' — islice is a C-level type (class); __name__ is 'islice'. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools' — islice is exposed at the itertools module level; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.islice.__class__.__name__ == 'type' — islice is a C-level type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.product class identity
#
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__module__ == 'itertools'
# itertools.product.__name__ == 'product'
#
# product is a C-level class (type) that computes the Cartesian product of
# input iterables. Its __class__.__name__ is 'type' and __module__ is
# 'itertools'. New to extra251.
# ---------------------------------------------------------------------------

table itertools_extra251.product_identity:
  description: "itertools.product __name__, __module__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: product251

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C-level Cartesian-product type; __name__ is 'product'; new to extra251"]
    - [product_module_eq,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is exposed at the itertools module level; __module__ is 'itertools'; new to extra251"]
    - [product_class_name_eq,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C-level class; __class__.__name__ is 'type'; new to extra251"]
    - [product_name_len_7,
       product.__name__.__len__,
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters; new to extra251"]
    - [product_module_len_9,
       product.__module__.__len__,
       [],
       9,
       "itertools.product.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain class identity and from_iterable
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.chain.__module__ == 'itertools'
# itertools.chain.__name__ == 'chain'
# itertools.chain.from_iterable.__name__ == 'from_iterable'
#
# chain is a C-level class that chains multiple iterables into a single
# sequence. from_iterable is a classmethod alternative constructor.
# New to extra251.
# ---------------------------------------------------------------------------

table itertools_extra251.chain_identity:
  description: "itertools.chain __name__, __module__, __class__.__name__, from_iterable.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: chain251

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C-level iterator chaining type; __name__ is 'chain'; new to extra251"]
    - [chain_module_eq,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is exposed at the itertools module level; __module__ is 'itertools'; new to extra251"]
    - [chain_class_name_eq,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C-level class; __class__.__name__ is 'type'; new to extra251"]
    - [chain_from_iterable_name_eq,
       chain.from_iterable.__name__.__eq__,
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — from_iterable is the classmethod alternative constructor; __name__ is 'from_iterable'; new to extra251"]
    - [chain_name_len_5,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Table 3: itertools.islice class identity
#
# itertools.islice.__name__ == 'islice'
# itertools.islice.__module__ == 'itertools'
# itertools.islice.__class__.__name__ == 'type'
#
# islice is a C-level class that returns an iterator that returns selected
# elements from the input iterable. New to extra251.
# ---------------------------------------------------------------------------

table itertools_extra251.islice_identity:
  description: "itertools.islice __name__, __module__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: islice251

  columns: [id, function, args, expected, description]
  rows:
    - [islice_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C-level iterator-slicing type; __name__ is 'islice'; new to extra251"]
    - [islice_module_eq,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is exposed at the itertools module level; __module__ is 'itertools'; new to extra251"]
    - [islice_class_name_eq,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — islice is a C-level class; __class__.__name__ is 'type'; new to extra251"]
    - [islice_name_len_6,
       islice.__name__.__len__,
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — 'islice' has 6 characters; new to extra251"]
    - [islice_module_len_9,
       islice.__module__.__len__,
       [],
       9,
       "itertools.islice.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra251
# ---------------------------------------------------------------------------

invariant itertools_extra251.product.name_eq:
  description: "itertools.product.__name__ == 'product' — C-level Cartesian-product type; new to extra251"
  category: identity
  kind: python_call_eq
  function: product.__name__.__eq__
  args: ["product"]
  expected: true

invariant itertools_extra251.product.module_eq:
  description: "itertools.product.__module__ == 'itertools' — exposed at the itertools module level; new to extra251"
  category: identity
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra251.product.class_is_type:
  description: "itertools.product.__class__.__name__ == 'type' — product is a C-level class; new to extra251"
  category: identity
  kind: python_call_eq
  function: product.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra251.product.name_len_7:
  description: "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: product.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra251.chain.name_eq:
  description: "itertools.chain.__name__ == 'chain' — C-level iterator chaining type; new to extra251"
  category: identity
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra251.chain.module_eq:
  description: "itertools.chain.__module__ == 'itertools' — exposed at the itertools module level; new to extra251"
  category: identity
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra251.chain.class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C-level class; new to extra251"
  category: identity
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra251.chain.from_iterable_name_eq:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' — classmethod alternative constructor; new to extra251"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra251.chain.from_iterable_name_len_13:
  description: "itertools.chain.from_iterable.__name__.__len__() == 13 — 'from_iterable' has 13 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__name__.__len__
  args: []
  expected: 13

invariant itertools_extra251.islice.name_eq:
  description: "itertools.islice.__name__ == 'islice' — C-level iterator-slicing type; new to extra251"
  category: identity
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra251.islice.module_eq:
  description: "itertools.islice.__module__ == 'itertools' — exposed at the itertools module level; new to extra251"
  category: identity
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra251.islice.class_is_type:
  description: "itertools.islice.__class__.__name__ == 'type' — islice is a C-level class; new to extra251"
  category: identity
  kind: python_call_eq
  function: islice.__class__.__name__.__eq__
