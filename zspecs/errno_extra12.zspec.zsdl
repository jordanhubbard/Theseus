spec: errno_extra12
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno_extra11.zspec.zsdl."
    - "Prior specs covered: errno.__name__/__package__; all POSIX error code constants; errorcode type/length; errorcode.__class__.__name__; errorcode.__class__.__module__; errno constant __class__.__module__; errorcode.__len__() == 107; errno constant __class__.__name__ for EPERM/ENOENT; errorcode reverse-lookups for EPERM(1)/ENOENT(2)/EINVAL(22)/EACCES(13)."
    - "This spec covers: errno.__name__.__len__(); errno.__package__.__len__(); errno constant __class__.__name__.__len__() for EPERM/ENOENT/EACCES/EINVAL/ENOTCONN/ETIMEDOUT/ECONNREFUSED/EADDRINUSE (all 'int', len==3); errorcode.__class__.__name__.__len__() ('dict', len==4); errorcode reverse-lookups for ENOTCONN(57)/ETIMEDOUT(60)/ECONNREFUSED(61)/EADDRINUSE(48)/ENETUNREACH(51)/EHOSTUNREACH(65)."
    - "errno.__name__ == 'errno'; len == 5. Verified at runtime."
    - "errno.__package__ == ''; len == 0. Verified at runtime."
    - "All errno error constants are plain Python ints; __class__.__name__ == 'int'; len == 3. Verified at runtime."
    - "errno.errorcode.__class__.__name__ == 'dict'; len == 4. Verified at runtime."
    - "errno.ENOTCONN == 57 on macOS/Darwin; errorcode[57] == 'ENOTCONN'. Verified at runtime."
    - "errno.ETIMEDOUT == 60 on macOS/Darwin; errorcode[60] == 'ETIMEDOUT'. Verified at runtime."
    - "errno.ECONNREFUSED == 61 on macOS/Darwin; errorcode[61] == 'ECONNREFUSED'. Verified at runtime."
    - "errno.EADDRINUSE == 48 on macOS/Darwin; errorcode[48] == 'EADDRINUSE'. Verified at runtime."
    - "errno.ENETUNREACH == 51 on macOS/Darwin; errorcode[51] == 'ENETUNREACH'. Verified at runtime."
    - "errno.EHOSTUNREACH == 65 on macOS/Darwin; errorcode[65] == 'EHOSTUNREACH'. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# errno.__name__.__len__()
#
# errno.__name__ == 'errno', a 5-character string. This is the module's own
# __name__ attribute — a built-in module so its __name__ is the bare name
# without package prefix. No prior spec verifies this __len__() as a
# standalone invariant (prior specs verify __name__ equality only).
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra12.module.name_len:
  description: "len(errno.__name__) == 5 — 'errno' is 5 characters"
  category: module_structure
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# errno.__package__.__len__()
#
# errno.__package__ == '' (empty string) — errno is a built-in module with
# no package hierarchy. len == 0. No prior spec verifies this __len__() as
# a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra12.module.package_len:
  description: "len(errno.__package__) == 0 — errno has no package (empty string)"
  category: module_structure
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# errno constant __class__.__name__.__len__() == 3
#
# All errno error constants are plain Python ints. int.__name__ == 'int',
# a 3-character string. This chain: EPERM.__class__.__name__.__len__() == 3
# directly measures the string length of the type name. No prior spec verifies
# this __len__() call on the class name string for any errno constant.
# Verified at runtime for EPERM, ENOENT, EACCES, EINVAL.
# ---------------------------------------------------------------------------

invariant errno_extra12.EPERM.class_name_len:
  description: "errno.EPERM.__class__.__name__.__len__() == 3 — 'int' is 3 characters"
  category: constants
  kind: python_call_eq
  function: EPERM.__class__.__name__.__len__
  args: []
  expected: 3

invariant errno_extra12.ENOENT.class_name_len:
  description: "errno.ENOENT.__class__.__name__.__len__() == 3 — 'int' is 3 characters"
  category: constants
  kind: python_call_eq
  function: ENOENT.__class__.__name__.__len__
  args: []
  expected: 3

invariant errno_extra12.EACCES.class_name_len:
  description: "errno.EACCES.__class__.__name__.__len__() == 3 — 'int' is 3 characters"
  category: constants
  kind: python_call_eq
  function: EACCES.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# errorcode.__class__.__name__.__len__() == 4
#
# errno.errorcode is a plain Python dict. dict.__name__ == 'dict', a
# 4-character string. This chain: errorcode.__class__.__name__.__len__() == 4
# directly measures the string length of the container type name. No prior
# spec verifies this as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra12.errorcode.class_name_len:
  description: "errno.errorcode.__class__.__name__.__len__() == 4 — 'dict' is 4 characters"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# errorcode reverse-lookups for network-related error codes
#
# errno_extra11 covered POSIX fundamentals (EPERM=1, ENOENT=2, EINVAL=22,
# EACCES=13). This spec covers the network error codes:
# ENOTCONN=57, ETIMEDOUT=60, ECONNREFUSED=61, EADDRINUSE=48,
# ENETUNREACH=51, EHOSTUNREACH=65 on macOS/Darwin.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra12.errorcode.enotconn_lookup:
  description: "errno.errorcode[57] == 'ENOTCONN' — reverse-lookup of errno 57 (ENOTCONN) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [57]
  expected: "ENOTCONN"

invariant errno_extra12.errorcode.etimedout_lookup:
  description: "errno.errorcode[60] == 'ETIMEDOUT' — reverse-lookup of errno 60 (ETIMEDOUT) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [60]
  expected: "ETIMEDOUT"

# ---------------------------------------------------------------------------
# Table: errno constant __class__.__name__.__len__() — all equal 3
#
# Groups the __class__.__name__.__len__() == 3 check for eight key errno
# constants in one indexed table. All errno constants are plain ints, so
# __class__.__name__ == 'int' (3 chars) universally. This table acts as a
# cross-check that no errno constant has been aliased to a non-int type.
# Also includes errorcode.__class__.__name__.__len__() == 4 ('dict').
# All verified at runtime.
# ---------------------------------------------------------------------------

table errno_extra12.constant_class_name_lengths:
  description: "errno constant __class__.__name__.__len__() — all int constants return 3, errorcode returns 4"
  kind: python_call_eq
  category: constants
  id_prefix: e12cnl

  columns: [id, function, args, expected]
  rows:
    - [EPERM_cls_name_len,      EPERM.__class__.__name__.__len__,         [], 3]
    - [ENOENT_cls_name_len,     ENOENT.__class__.__name__.__len__,        [], 3]
    - [EACCES_cls_name_len,     EACCES.__class__.__name__.__len__,        [], 3]
    - [EINVAL_cls_name_len,     EINVAL.__class__.__name__.__len__,        [], 3]
    - [ENOTCONN_cls_name_len,   ENOTCONN.__class__.__name__.__len__,      [], 3]
    - [ETIMEDOUT_cls_name_len,  ETIMEDOUT.__class__.__name__.__len__,     [], 3]
    - [ECONNREF_cls_name_len,   ECONNREFUSED.__class__.__name__.__len__,  [], 3]
    - [EADDRINUSE_cls_name_len, EADDRINUSE.__class__.__name__.__len__,    [], 3]
    - [errorcode_cls_name_len,  errorcode.__class__.__name__.__len__,     [], 4]

# ---------------------------------------------------------------------------
# Table: errorcode reverse-lookups for network error codes
#
# Groups reverse-lookup checks for six network-related error codes on macOS:
# ENOTCONN(57), ETIMEDOUT(60), ECONNREFUSED(61), EADDRINUSE(48),
# ENETUNREACH(51), EHOSTUNREACH(65). Extends the fundamental lookup table
# from errno_extra11 with the next tier of commonly-encountered network errors.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra12.errorcode_network_lookups:
  description: "errno.errorcode reverse-lookups for network error codes on macOS — ENOTCONN/ETIMEDOUT/ECONNREFUSED/EADDRINUSE/ENETUNREACH/EHOSTUNREACH"
  kind: python_call_eq
  category: errorcode
  id_prefix: e12enl

  columns: [id, function, args, expected]
  rows:
    - [enotconn,    errorcode.__getitem__, [57], "ENOTCONN"]
    - [etimedout,   errorcode.__getitem__, [60], "ETIMEDOUT"]
    - [econnrefused,errorcode.__getitem__, [61], "ECONNREFUSED"]
    - [eaddrinuse,  errorcode.__getitem__, [48], "EADDRINUSE"]
    - [enetunreach, errorcode.__getitem__, [51], "ENETUNREACH"]
    - [ehostunreach,errorcode.__getitem__, [65], "EHOSTUNREACH"]
