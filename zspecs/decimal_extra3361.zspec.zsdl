# ---------------------------------------------------------------------------
# combined — __invert__, __floor__, __ceil__ across all 6 decimal subjects
#
# 6 classes x 3 methods = 18 rows.
# decimal.Decimal: __invert__ = false (Decimal is not an integer type; ~d
# raises TypeError), __floor__ = true (math.floor(d) supported), __ceil__ =
# true (math.ceil(d) supported). This false/true/true pattern is the key
# finding of wave 671 for the decimal module: Decimal supports IEEE 754
# rounding operations but not integer bitwise operators.
# All other decimal classes (Context, DecimalException, InvalidOperation,
# Overflow, Underflow): false for all three operators.
# ---------------------------------------------------------------------------

table dc3361.combined:
  description: "decimal types combined __invert__/__floor__/__ceil__; wave 671"
