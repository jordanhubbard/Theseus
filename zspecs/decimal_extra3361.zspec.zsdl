spec: dc3361
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (dc3361): __invert__, __floor__, __ceil__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __invert__, __floor__, __ceil__ dict-presence (~x, math.floor(x), math.ceil(x))."
    - "decimal.Decimal does NOT define __invert__ in its own __dict__: false. Decimal is an IEEE 754 arbitrary-precision decimal numeric type, not an integer type. The bitwise inversion operator (~x) requires an integer operand and is undefined for Decimal; ~d raises TypeError at runtime."
    - "decimal.Decimal DOES define __floor__ in its own __dict__: true. Decimal supports math.floor(); __floor__ returns the greatest integer less than or equal to the Decimal value, respecting the current context."
    - "decimal.Decimal DOES define __ceil__ in its own __dict__: true. Decimal supports math.ceil(); __ceil__ returns the smallest integer greater than or equal to the Decimal value, respecting the current context."
    - "decimal.Context does NOT define __invert__, __floor__, or __ceil__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "decimal.Decimal is unique among the covered types in this wave: it is the only type defining __floor__ and __ceil__ (true), reflecting its status as a complete IEEE 754 numeric type supporting math rounding. However, Decimal is not an integer type and does not define __invert__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# decimal.Decimal does NOT define __invert__ in its own __dict__: false.
# Decimal is a decimal numeric type, not an integer type; bitwise inversion
# (~x) is undefined for Decimal and raises TypeError at runtime.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3361.invert:
  description: "decimal types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3361

  columns: [id, function, args, expected]
  rows:
    - ["dc3361001", operator.contains, [decimal.Decimal.__dict__,          "__invert__"], false]
    - ["dc3361002", operator.contains, [decimal.Context.__dict__,           "__invert__"], false]
    - ["dc3361003", operator.contains, [decimal.DecimalException.__dict__,  "__invert__"], false]
    - ["dc3361004", operator.contains, [decimal.InvalidOperation.__dict__,  "__invert__"], false]
    - ["dc3361005", operator.contains, [decimal.Overflow.__dict__,          "__invert__"], false]
    - ["dc3361006", operator.contains, [decimal.Underflow.__dict__,         "__invert__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# decimal.Decimal DOES define __floor__ in its own __dict__: true.
# math.floor(d) is supported by Decimal; __floor__ returns the greatest
# integer less than or equal to d, using the current context precision.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3361.floor:
