    - ["dc3361010", operator.contains, [decimal.InvalidOperation.__dict__,  "__floor__"], false]
    - ["dc3361011", operator.contains, [decimal.Overflow.__dict__,          "__floor__"], false]
    - ["dc3361012", operator.contains, [decimal.Underflow.__dict__,         "__floor__"], false]

