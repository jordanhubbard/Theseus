spec: itertools_extra277
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.chain is a C-level type: __class__.__name__ == 'type', __module__ == 'itertools'."
    - "chain.__new__ is a builtin_function_or_method: __qualname__ == 'chain.__new__' (13 chars)."
    - "chain.from_iterable is a builtin_function_or_method: __qualname__ == 'chain.from_iterable' (19 chars), __name__ == 'from_iterable' (13 chars)."
    - "itertools.islice.__doc__ is not None — islice ships with a docstring."
    - "itertools.product.__doc__ is not None — product ships with a docstring."
    - "islice.__name__ == 'islice' (6 chars); product.__name__ == 'product' (7 chars)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain method identity — __new__ and from_iterable
#
# chain.__new__ is a builtin_function_or_method.
# chain.__new__.__qualname__ == 'chain.__new__' (13 chars).
# chain.__new__.__name__ == '__new__' (7 chars).
# chain.from_iterable is a builtin_function_or_method.
# chain.from_iterable.__qualname__ == 'chain.from_iterable' (19 chars).
# chain.from_iterable.__name__ == 'from_iterable' (13 chars).
# ---------------------------------------------------------------------------

table itertools_extra277.chain_method_identity:
  description: "itertools.chain.__new__ and chain.from_iterable identity — __qualname__, __name__, __class__.__name__; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex277cm

  columns: [id, function, args, expected, description]
  rows:
    - [cn_qn_eq,   chain.__new__.__qualname__.__eq__,              ["chain.__new__"],      true, "itertools.chain.__new__.__qualname__ == 'chain.__new__'; verified with Python 3.14.3"]
    - [cn_qn_len,  chain.__new__.__qualname__.__len__,              [],                    13,   "itertools.chain.__new__.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [cn_nm_eq,   chain.__new__.__name__.__eq__,                   ["__new__"],           true, "itertools.chain.__new__.__name__ == '__new__'; verified with Python 3.14.3"]
    - [cn_nm_len,  chain.__new__.__name__.__len__,                   [],                   7,    "itertools.chain.__new__.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [cn_cls_eq,  chain.__new__.__class__.__name__.__eq__,         ["builtin_function_or_method"], true, "itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [fi_qn_eq,   chain.from_iterable.__qualname__.__eq__,         ["chain.from_iterable"], true, "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'; verified with Python 3.14.3"]
    - [fi_qn_len,  chain.from_iterable.__qualname__.__len__,         [],                    19,   "itertools.chain.from_iterable.__qualname__.__len__() == 19; verified with Python 3.14.3"]
    - [fi_nm_eq,   chain.from_iterable.__name__.__eq__,             ["from_iterable"],     true, "itertools.chain.from_iterable.__name__ == 'from_iterable'; verified with Python 3.14.3"]
    - [fi_nm_len,  chain.from_iterable.__name__.__len__,             [],                   13,   "itertools.chain.from_iterable.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [fi_cls_eq,  chain.from_iterable.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.islice and itertools.product — doc presence and name identity
#
# islice.__doc__ is not None; islice.__name__ == 'islice' (6 chars).
# product.__doc__ is not None; product.__name__ == 'product' (7 chars).
# Both are C-level types: __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table itertools_extra277.islice_product_identity:
  description: "itertools.islice and product identity — __name__, __class__.__name__, doc presence; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex277ip

  columns: [id, function, args, expected, description]
  rows:
    - [is_nm_eq,    islice.__name__.__eq__,           ["islice"],    true,  "itertools.islice.__name__ == 'islice'; verified with Python 3.14.3"]
    - [is_nm_len,   islice.__name__.__len__,           [],            6,     "itertools.islice.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [is_mod_eq,   islice.__module__.__eq__,          ["itertools"], true,  "itertools.islice.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [is_doc_none, islice.__doc__.__eq__,             [null],        false, "itertools.islice.__doc__ is not None — islice ships with a docstring; verified with Python 3.14.3"]
    - [pr_nm_eq,    product.__name__.__eq__,           ["product"],   true,  "itertools.product.__name__ == 'product'; verified with Python 3.14.3"]
    - [pr_nm_len,   product.__name__.__len__,           [],            7,     "itertools.product.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [pr_mod_eq,   product.__module__.__eq__,          ["itertools"], true,  "itertools.product.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pr_doc_none, product.__doc__.__eq__,             [null],        false, "itertools.product.__doc__ is not None — product ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra277
# ---------------------------------------------------------------------------

invariant itertools_extra277.chain_new_qualname:
  description: "itertools.chain.__new__.__qualname__ == 'chain.__new__' — the __new__ builtin method carries a qualname encoding the owning class"
  category: identity
  kind: python_call_eq
  function: chain.__new__.__qualname__.__eq__
  args: ["chain.__new__"]
  expected: true

invariant itertools_extra277.chain_new_qualname_length_is_13:
  description: "itertools.chain.__new__.__qualname__.__len__() == 13 — 'chain.__new__' has 13 characters"
  category: identity
  kind: python_call_eq
  function: chain.__new__.__qualname__.__len__
  args: []
  expected: 13

invariant itertools_extra277.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — the classmethod's qualname encodes its owning class"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra277.chain_from_iterable_qualname_length_is_19:
  description: "itertools.chain.from_iterable.__qualname__.__len__() == 19 — 'chain.from_iterable' has 19 characters"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__len__
  args: []
  expected: 19

invariant itertools_extra277.islice_doc_is_not_none:
  description: "itertools.islice.__doc__.__eq__(None) == False — islice ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: islice.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra277.product_doc_is_not_none:
  description: "itertools.product.__doc__.__eq__(None) == False — product ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: product.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra277.chain_from_iterable_is_builtin:
  description: "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — from_iterable is a C-level classmethod, not a Python function"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
