spec: re_extra378
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern methods match, search, fullmatch, findall, finditer, sub, subn, split each report __name__ matching their Python-level name"
    - "re.Pattern.__name__ == 'Pattern' and re.Pattern.__module__ == 're'"
    - "re.Pattern is the type of compiled regular expression objects returned by re.compile()"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __name__ identity
# ---------------------------------------------------------------------------

table re_extra378.pattern_method_names:
  description: "re.Pattern method __name__ identity — match, search, fullmatch, findall, finditer, sub, subn, split; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: repatmeth378

  columns: [id, function, args, expected]
  rows:
    - [match_name,     re.Pattern.match.__name__.__eq__,     ["match"],     true]
    - [search_name,    re.Pattern.search.__name__.__eq__,    ["search"],    true]
    - [fullmatch_name, re.Pattern.fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [findall_name,   re.Pattern.findall.__name__.__eq__,   ["findall"],   true]
    - [finditer_name,  re.Pattern.finditer.__name__.__eq__,  ["finditer"],  true]
    - [sub_name,       re.Pattern.sub.__name__.__eq__,       ["sub"],       true]
    - [subn_name,      re.Pattern.subn.__name__.__eq__,      ["subn"],      true]
    - [split_name,     re.Pattern.split.__name__.__eq__,     ["split"],     true]

# ---------------------------------------------------------------------------
# re.Pattern class identity — __name__ and __module__
# ---------------------------------------------------------------------------

table re_extra378.pattern_class_identity:
  description: "re.Pattern class identity — __name__ == 'Pattern', __module__ == 're'; re.Pattern is the public type for compiled regular expression objects; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: repatcls378

  columns: [id, function, args, expected]
  rows:
    - [pattern_name,   re.Pattern.__name__.__eq__,   ["Pattern"], true]
    - [pattern_module, re.Pattern.__module__.__eq__, ["re"],      true]
