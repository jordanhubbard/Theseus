invariant socket_extra74.shutdown_qualname_len_15:
  description: "socket.socket.shutdown.__qualname__.__len__() == 15 — 'socket.shutdown' is 15 chars; no prior socket spec checks shutdown.__qualname__.__len__(); first qualname length standalone for shutdown"
  category: qualnames
  kind: python_call_eq
  function: socket.shutdown.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# socket.socket.__dict__ is a mappingproxy. In python_module(socket), 'socket'
# refers to the socket.socket class. No prior socket spec checks
# socket.__dict__.__class__.__name__ as a standalone invariant in the extra74
# namespace. First mappingproxy class standalone in extra74 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra74.socket_dict_class_mappingproxy:
  description: "socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') == True — socket.socket class __dict__ is a mappingproxy; in python_module(socket) 'socket' refers to the socket.socket class; no prior socket spec covers this as a standalone invariant in extra74 namespace; first mappingproxy class standalone in extra74 namespace"
  category: class_identity
  kind: python_call_eq
  function: socket.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
