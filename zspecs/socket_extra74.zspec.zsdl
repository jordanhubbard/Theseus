# for recvfrom. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra74.recvfrom_qualname_socket_recvfrom:
  description: "socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom') == True — recvfrom.__qualname__ is 'socket.recvfrom'; no prior socket spec checks recvfrom.__qualname__ equality; first qualname identity standalone for recvfrom"
  category: qualnames
  kind: python_call_eq
  function: socket.recvfrom.__qualname__.__eq__
  args: ["socket.recvfrom"]
  expected: true

# ---------------------------------------------------------------------------
