invariant socket_extra74.shutdown_qualname_socket_shutdown:
  description: "socket.socket.shutdown.__qualname__.__eq__('socket.shutdown') == True — shutdown.__qualname__ is 'socket.shutdown'; no prior socket spec checks shutdown.__qualname__ equality; first qualname identity standalone for shutdown"
  category: qualnames
  kind: python_call_eq
