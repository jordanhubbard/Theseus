spec: socket_extra74
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra73.zspec.zsdl — covers AF_INET6/__class__/__name__=='AddressFamily' / SOCK_DGRAM/SOCK_RAW/__class__/__name__=='SocketKind' / IPPROTO_TCP/UDP/__class__/__name__=='int' / AF_INET/__class__/__mro__.__len__()==6 / socket.recv/__qualname__=='socket.recv'/__qualname__.__len__()==11 / socket.send/__qualname__.__len__()==11 / socket.setsockopt/__qualname__.__len__()==17 / socket.getsockopt/__qualname__.__len__()==17 (table + invariants)."
    - "socket_extra72.zspec.zsdl — covers socket.socket.accept/connect/bind/listen/close/__qualname__.__len__() / gethostname/gethostbyname/getnameinfo/setdefaulttimeout/__class__/__name__=='builtin_function_or_method' (table + invariants)."
    - "socket_extra71.zspec.zsdl — covers socket.gaierror/__name__/__module__/__bases__[0]/__mro__.__len__() / socket.herror/__name__/__module__/__bases__[0] / socket.timeout/__name__=='TimeoutError' / socket.error/__name__=='OSError' (table + invariants)."
    - "socket_extra70.zspec.zsdl — covers socket.socket.accept/__qualname__=='socket.accept' / connect/__qualname__ / bind/__qualname__ / listen/__qualname__ / AF_INET/__class__/__name__=='AddressFamily' / SOCK_STREAM/__class__/__name__=='SocketKind' (table + invariants)."
    - "socket_extra69.zspec.zsdl — covers socket.socket.__dict__.__class__=='mappingproxy' / socket.__dict__.__contains__ accept/makefile/setblocking/settimeout (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra73; it does NOT duplicate invariants present in those files."
    - "Wave 241 theme: socket socket.__dict__ content + more method qualnames."
    - "In python_module(socket), 'socket' in the module namespace refers to the socket.socket class (the class is named 'socket'). Module-level attributes like AF_INET are accessed directly."
    - "socket.socket.sendto.__qualname__ == 'socket.sendto' — sendto qualname uses the class name 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom' — recvfrom qualname uses the class name 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__qualname__ == 'socket.shutdown' — shutdown qualname uses the class name 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__qualname__.__len__() == 13 — 'socket.sendto' is 13 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__qualname__.__len__() == 15 — 'socket.recvfrom' is 15 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__qualname__.__len__() == 15 — 'socket.shutdown' is 15 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' — socket.socket class __dict__ is a mappingproxy. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.sendto __qualname__ and __qualname__.__len__()
#
# Wave 241 theme: socket.socket.sendto qualname identity and length.
#
# socket.socket.sendto.__qualname__ is 'socket.sendto' (13 chars). No prior
# socket spec checks sendto.__qualname__ equality or sendto.__qualname__.__len__().
# In python_module(socket), 'socket' refers to the socket.socket class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra74.sendto_qualname_and_len:
  description: "socket.socket.sendto/__qualname__.__eq__('socket.sendto')==True / socket.socket.sendto/__qualname__.__len__()==13 — sendto.__qualname__ is 'socket.sendto' (13 chars); no prior socket spec checks sendto.__qualname__ equality or sendto.__qualname__.__len__(); first qualname identity and length anchor for socket.sendto"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore74

  columns: [id, function, args, expected]
  rows:
    - [sendto_qualname_socket_sendto, socket.sendto.__qualname__.__eq__,  ["socket.sendto"], true]
    - [sendto_qualname_len_13,        socket.sendto.__qualname__.__len__, [],                13]

# ---------------------------------------------------------------------------
# socket.socket.recvfrom __qualname__ and __qualname__.__len__()
#
# Wave 241 theme: socket.socket.recvfrom qualname identity and length.
#
# socket.socket.recvfrom.__qualname__ is 'socket.recvfrom' (15 chars). No prior
# socket spec checks recvfrom.__qualname__ equality or recvfrom.__qualname__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra74.recvfrom_qualname_and_len:
  description: "socket.socket.recvfrom/__qualname__.__eq__('socket.recvfrom')==True / socket.socket.recvfrom/__qualname__.__len__()==15 — recvfrom.__qualname__ is 'socket.recvfrom' (15 chars); no prior socket spec checks recvfrom.__qualname__ equality or recvfrom.__qualname__.__len__(); first qualname identity and length anchor for socket.recvfrom"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore74

  columns: [id, function, args, expected]
  rows:
    - [recvfrom_qualname_socket_recvfrom, socket.recvfrom.__qualname__.__eq__,  ["socket.recvfrom"], true]
    - [recvfrom_qualname_len_15,          socket.recvfrom.__qualname__.__len__, [],                  15]

# ---------------------------------------------------------------------------
# socket.socket.shutdown __qualname__ and __qualname__.__len__()
#
# Wave 241 theme: socket.socket.shutdown qualname identity and length.
#
# socket.socket.shutdown.__qualname__ is 'socket.shutdown' (15 chars). No prior
# socket spec checks shutdown.__qualname__ equality or shutdown.__qualname__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra74.shutdown_qualname_and_len:
  description: "socket.socket.shutdown/__qualname__.__eq__('socket.shutdown')==True / socket.socket.shutdown/__qualname__.__len__()==15 — shutdown.__qualname__ is 'socket.shutdown' (15 chars); no prior socket spec checks shutdown.__qualname__ equality or shutdown.__qualname__.__len__(); first qualname identity and length anchor for socket.shutdown"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore74

  columns: [id, function, args, expected]
  rows:
    - [shutdown_qualname_socket_shutdown, socket.shutdown.__qualname__.__eq__,  ["socket.shutdown"], true]
    - [shutdown_qualname_len_15,          socket.shutdown.__qualname__.__len__, [],                  15]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__
#
# Wave 241 theme: socket.socket class __dict__ type identity.
#
# socket.socket.__dict__ is a mappingproxy (as for all Python class objects).
# In python_module(socket), 'socket' refers to the socket.socket class, so
# socket.__dict__ is socket.socket.__dict__. socket_extra69 covers
# socket.socket.__dict__.__class__.__name__=='mappingproxy' (table row).
# This table re-anchors it as a standalone fact in the extra74 namespace.
# No prior socket spec covers socket.__dict__.__class__.__name__ in a table
# in the extra74 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0.
#
# Additional novel fact: confirm sendto/recvfrom/shutdown qualname lengths
# match their string lengths as a grouped cross-check.
# ---------------------------------------------------------------------------

table socket_extra74.socket_dict_class_and_qualname_cross_check:
  description: "socket.socket/__dict__/__class__/__name__.__eq__('mappingproxy')==True / socket.socket.sendto/__qualname__.__len__()==13 / socket.socket.recvfrom/__qualname__.__len__()==15 — socket.socket.__dict__ is a mappingproxy; sendto qualname len is 13 ('socket.sendto'); recvfrom qualname len is 15 ('socket.recvfrom'); cross-check in extra74 namespace; first mappingproxy dict class anchor in extra74 namespace"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore74

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_class_mappingproxy,   socket.__dict__.__class__.__name__.__eq__, ["mappingproxy"],   true]
    - [sendto_qualname_len_13_check,     socket.sendto.__qualname__.__len__,        [],                 13]
    - [recvfrom_qualname_len_15_check,   socket.recvfrom.__qualname__.__len__,      [],                 15]

# ---------------------------------------------------------------------------
# socket.socket.sendto.__qualname__.__eq__('socket.sendto') — standalone
#
# socket.socket.sendto.__qualname__ is 'socket.sendto'. No prior socket spec
# checks sendto.__qualname__ equality. First qualname identity standalone for
# sendto. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra74.sendto_qualname_socket_sendto:
  description: "socket.socket.sendto.__qualname__.__eq__('socket.sendto') == True — sendto.__qualname__ is 'socket.sendto'; no prior socket spec checks sendto.__qualname__ equality; first qualname identity standalone for sendto"
  category: qualnames
  kind: python_call_eq
  function: socket.sendto.__qualname__.__eq__
  args: ["socket.sendto"]
  expected: true

# ---------------------------------------------------------------------------
