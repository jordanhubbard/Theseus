spec: pp3376
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (pp3376): __trunc__, __round__, __index__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __trunc__, __round__, __index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "No pathlib class defines __trunc__ in its own __dict__: path objects are filesystem path abstractions, not numeric types; math.trunc() has no meaning for paths."
    - "No pathlib class defines __round__ in its own __dict__: path objects are not numeric types; round() has no semantic meaning for filesystem path objects."
    - "No pathlib class defines __index__ in its own __dict__: path objects are not integer types; operator.index() requires an exact integer type and is not defined for path objects."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all numeric truncation, rounding, and integer-conversion operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — operator.contains(Cls.__dict__, '__trunc__')
#
# No pathlib class defines __trunc__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions, not numeric types;
# math.trunc() has no semantic meaning for path objects.
# ---------------------------------------------------------------------------

table pp3376.trunc:
  description: "pathlib types __trunc__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3376

  columns: [id, function, args, expected]
  rows:
    - ["pp3376001", operator.contains, [pathlib.PurePath.__dict__,         "__trunc__"], false]
    - ["pp3376002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__trunc__"], false]
    - ["pp3376003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__trunc__"], false]
    - ["pp3376004", operator.contains, [pathlib.Path.__dict__,             "__trunc__"], false]
    - ["pp3376005", operator.contains, [pathlib.PosixPath.__dict__,        "__trunc__"], false]

