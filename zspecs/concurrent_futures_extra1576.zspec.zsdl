spec: concurrent_futures_extra1576
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "Tests cover __name__, __str__, __repr__ of exception classes, executor class hierarchy, and string sentinel constants."
    - "concurrent.futures.CancelledError is an alias for the builtin CancelledError since Python 3.8."
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are plain string constants."
    - "ThreadPoolExecutor and ProcessPoolExecutor are both subclasses of Executor."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Exception class __name__ identity
# ---------------------------------------------------------------------------

table concurrent_futures_extra1576.exception_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cf1576

  columns: [id, function, args, expected]
  rows:
    - ["cf1576_001", "CancelledError.__name__.__eq__", ["CancelledError"], true]
    - ["cf1576_002", "TimeoutError.__name__.__eq__",   ["TimeoutError"],   true]
    - ["cf1576_003", "Future.__name__.__eq__",         ["Future"],         true]
    - ["cf1576_004", "Executor.__name__.__eq__",       ["Executor"],       true]
    - ["cf1576_005", "ThreadPoolExecutor.__name__.__eq__",  ["ThreadPoolExecutor"],  true]
    - ["cf1576_006", "ProcessPoolExecutor.__name__.__eq__", ["ProcessPoolExecutor"], true]

# ---------------------------------------------------------------------------
# __repr__ of zero-argument exception instances
# repr(ExcClass()) == "ExcClass()"
# ---------------------------------------------------------------------------

table concurrent_futures_extra1576.exception_repr:
  kind: python_call_eq
  category: str_repr
  id_prefix: cf1576

  columns: [id, function, args, expected]
  rows:
    - ["cf1576_010", "CancelledError.__repr__", [], "CancelledError()"]

# ---------------------------------------------------------------------------
# __str__ of zero-argument exception instances — str(ExcClass()) == ""
# ---------------------------------------------------------------------------

table concurrent_futures_extra1576.exception_str_empty:
  kind: python_call_eq
  category: str_repr
  id_prefix: cf1576

  columns: [id, function, args, expected]
  rows:
    - ["cf1576_020", "CancelledError.__str__", [], ""]
    - ["cf1576_021", "TimeoutError.__str__",   [], ""]

# ---------------------------------------------------------------------------
# __str__ of exception instances with a message argument
# str(ExcClass("msg")) == "msg"
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.cancelled_error.str_with_msg:
  description: "str(concurrent.futures.CancelledError('task cancelled')) == 'task cancelled'"
  category: str_repr
  kind: python_call_eq
  function: CancelledError
  args: ["task cancelled"]
  method: __str__
  expected: "task cancelled"

invariant concurrent_futures_extra1576.timeout_error.str_with_msg:
  description: "str(concurrent.futures.TimeoutError('timed out')) == 'timed out'"
  category: str_repr
  kind: python_call_eq
  function: TimeoutError
  args: ["timed out"]
  method: __str__
  expected: "timed out"

# ---------------------------------------------------------------------------
# __repr__ of exception instances with a message argument
# repr(ExcClass("msg")) == "ExcClass('msg')"
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.cancelled_error.repr_with_msg:
  description: "repr(concurrent.futures.CancelledError('task cancelled')) == \"CancelledError('task cancelled')\""
  category: str_repr
  kind: python_call_eq
  function: CancelledError
  args: ["task cancelled"]
  method: __repr__
  expected: "CancelledError('task cancelled')"

invariant concurrent_futures_extra1576.timeout_error.repr_with_msg:
  description: "repr(concurrent.futures.TimeoutError('timed out')) == \"TimeoutError('timed out')\""
  category: str_repr
  kind: python_call_eq
  function: TimeoutError
  args: ["timed out"]
  method: __repr__
  expected: "TimeoutError('timed out')"

# ---------------------------------------------------------------------------
# Inheritance — exception parent class names
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.cancelled_error.parent_is_base_exception:
  description: "concurrent.futures.CancelledError.__bases__[0].__name__ == 'BaseException'"
  category: inheritance
  kind: python_call_eq
  function: CancelledError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseException"

invariant concurrent_futures_extra1576.timeout_error.is_subclass_of_exception:
  description: "concurrent.futures.TimeoutError is a subclass of Exception (via OSError chain)"
  category: inheritance
  kind: python_call_eq
  function: TimeoutError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# Executor class hierarchy — ThreadPoolExecutor and ProcessPoolExecutor
# are both subclasses of Executor.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.thread_pool_executor.parent_is_executor:
  description: "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: inheritance
  kind: python_call_eq
  function: ThreadPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Executor"

invariant concurrent_futures_extra1576.process_pool_executor.parent_is_executor:
  description: "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: inheritance
  kind: python_call_eq
  function: ProcessPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Executor"

# ---------------------------------------------------------------------------
# String sentinel constants — FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED
# These are plain str values; str() is a no-op on them.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.first_completed.value:
  description: "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra1576.first_exception.value:
  description: "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures_extra1576.all_completed.value:
  description: "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

# ---------------------------------------------------------------------------
# str() of the sentinel constants — str(constant) == constant (identity)
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.first_completed.str:
  description: "str(concurrent.futures.FIRST_COMPLETED) == 'FIRST_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__str__
  args: []
  expected: "FIRST_COMPLETED"

invariant concurrent_futures_extra1576.first_exception.str:
  description: "str(concurrent.futures.FIRST_EXCEPTION) == 'FIRST_EXCEPTION'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__str__
  args: []
  expected: "FIRST_EXCEPTION"

invariant concurrent_futures_extra1576.all_completed.str:
  description: "str(concurrent.futures.ALL_COMPLETED) == 'ALL_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__str__
  args: []
  expected: "ALL_COMPLETED"

# ---------------------------------------------------------------------------
# __repr__ of the sentinel constants — repr("FIRST_COMPLETED") == "'FIRST_COMPLETED'"
# These are plain str values so repr() wraps them in quotes.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1576.first_completed.repr:
  description: "repr(concurrent.futures.FIRST_COMPLETED) == \"'FIRST_COMPLETED'\""
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__repr__
  args: []
  expected: "'FIRST_COMPLETED'"

invariant concurrent_futures_extra1576.first_exception.repr:
  description: "repr(concurrent.futures.FIRST_EXCEPTION) == \"'FIRST_EXCEPTION'\""
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__repr__
  args: []
  expected: "'FIRST_EXCEPTION'"

invariant concurrent_futures_extra1576.all_completed.repr:
  description: "repr(concurrent.futures.ALL_COMPLETED) == \"'ALL_COMPLETED'\""
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__repr__
  args: []
  expected: "'ALL_COMPLETED'"

# ---------------------------------------------------------------------------
# Constants are strings — type(constant).__name__ == 'str'
# ---------------------------------------------------------------------------

table concurrent_futures_extra1576.constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: cf1576

  columns: [id, function, args, expected]
  rows:
    - ["cf1576_050", "FIRST_COMPLETED.__class__.__name__.__eq__", ["str"], true]
    - ["cf1576_051", "FIRST_EXCEPTION.__class__.__name__.__eq__", ["str"], true]
    - ["cf1576_052", "ALL_COMPLETED.__class__.__name__.__eq__",   ["str"], true]

# ---------------------------------------------------------------------------
# Constants have expected lengths
# ---------------------------------------------------------------------------

table concurrent_futures_extra1576.constant_lengths:
  kind: python_call_eq
  category: constants
  id_prefix: cf1576

  columns: [id, function, args, expected]
  rows:
    - ["cf1576_060", "FIRST_COMPLETED.__len__", [], 15]
    - ["cf1576_061", "FIRST_EXCEPTION.__len__", [], 15]
    - ["cf1576_062", "ALL_COMPLETED.__len__",   [], 13]
