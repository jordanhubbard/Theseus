spec: locust_rust
version: ">=3.9"
backend: rust_module(locust_rust)

docs: https://docs.locust.io/en/stable/

provenance:
  derived_from:
    - "https://docs.locust.io/en/stable/ — Locust documentation"
  not_derived_from:
    - "locust source: locust/__init__.py"
  notes:
    - "Locust is a load testing framework for Python."
    - "locust.User is available."
    - "locust.HttpUser is available."
    - "locust.task is available as a decorator."
    - "locust.__version__ is a non-empty string."
    - "Expose locust_has_http_user() -> bool: hasattr(locust, 'HttpUser')."
    - "Expose locust_has_task() -> bool: hasattr(locust, 'task')."
    - "Expose locust_version_nonempty() -> bool: len(locust.__version__) > 0."
    - "All test vectors verified against locust 2.34.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# locust_has_http_user — HttpUser present
invariant locust_rust.module.has_http_user:
  description: "locust.HttpUser is available"
  category: module
  kind: python_call_eq
  function: locust_has_http_user
  args: []
  expected: true

# locust_has_task — task decorator present
invariant locust_rust.module.has_task:
  description: "locust.task is available"
  category: module
  kind: python_call_eq
  function: locust_has_task
  args: []
  expected: true

# locust_version_nonempty — version non-empty
invariant locust_rust.version.nonempty:
  description: "locust.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: locust_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:13:19Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
