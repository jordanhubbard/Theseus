spec: in3076
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (in3076): __get__, __set__, __delete__ dict-presence checks for inspect types."
    - "None of the inspect types define __get__, __set__, or __delete__ in their own __dict__."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are pure Python classes."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception classes."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3076.get:
  description: "inspect types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3076
  columns: [id, function, args, expected]
  rows:
    - ["in3076001", operator.contains, [inspect.Parameter.__dict__,            "__get__"], false]
    - ["in3076002", operator.contains, [inspect.Signature.__dict__,            "__get__"], false]
    - ["in3076003", operator.contains, [inspect.BoundArguments.__dict__,       "__get__"], false]
    - ["in3076004", operator.contains, [inspect.FrameInfo.__dict__,            "__get__"], false]
    - ["in3076005", operator.contains, [inspect.ArgInfo.__dict__,              "__get__"], false]
    - ["in3076006", operator.contains, [inspect.FullArgSpec.__dict__,          "__get__"], false]
    - ["in3076007", operator.contains, [inspect.Attribute.__dict__,            "__get__"], false]
    - ["in3076008", operator.contains, [inspect.ClassFoundException.__dict__,  "__get__"], false]
    - ["in3076009", operator.contains, [inspect.EndOfBlock.__dict__,           "__get__"], false]

