    - [ppe_mro_len,     ProcessPoolExecutor.__mro__.__len__,                [],                           3,    "ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [ppe_name_eq,     ProcessPoolExecutor.__name__.__eq__,                ["ProcessPoolExecutor"],      true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — verified with Python 3.14.3"]
