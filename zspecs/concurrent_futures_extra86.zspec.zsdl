# ---------------------------------------------------------------------------

table concurrent_futures_extra86.Future_hierarchy_cross_checks:
  description: "concurrent.futures Future hierarchy and cross-checks in cfhier86 namespace — wave 249 theme: concurrent.futures Executor class hierarchy; Future.__bases__[0].__name__=='object' (cf.Future directly subclasses object, not asyncio.Future); Future.__mro__.__len__()==2 (MRO is [Future, object]); Executor.__mro__.__len__()==2 (cross-check); ThreadPoolExecutor.__mro__.__len__()==3 (cross-check); ProcessPoolExecutor.__bases__[0].__name__=='Executor' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfhier86c

  columns: [id, function, args, expected, description]
  rows:
    - [future_base_name,    "Future.__bases__[0].__name__.__eq__",           ["object"],   true, "Future.__bases__[0].__name__ == 'object' — cf.Future directly subclasses object; verified with Python 3.14.3"]
    - [future_mro_len,      Future.__mro__.__len__,                          [],           2,    "Future.__mro__.__len__() == 2 — MRO is [Future, object]; verified with Python 3.14.3"]
    - [executor_mro_cross,  Executor.__mro__.__len__,                        [],           2,    "Executor.__mro__.__len__() == 2 — cross-check; verified with Python 3.14.3"]
    - [tpe_mro_cross,       ThreadPoolExecutor.__mro__.__len__,              [],           3,    "ThreadPoolExecutor.__mro__.__len__() == 3 — cross-check; verified with Python 3.14.3"]
    - [ppe_base_cross,      "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra86.Executor_base_is_object:
  description: "concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') returns True — Executor directly subclasses object; it is the abstract base class for thread and process pool executors; NEW in extra86: first standalone __bases__ hierarchy invariant for Executor in cfhier86 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra86.ThreadPoolExecutor_base_is_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor directly subclasses Executor; it uses threads to execute calls asynchronously; NEW in extra86: first standalone __bases__ hierarchy invariant for ThreadPoolExecutor in cfhier86 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra86.ProcessPoolExecutor_mro_len:
  description: "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]; ProcessPoolExecutor subclasses Executor which subclasses object; NEW in extra86: first standalone MRO length invariant for ProcessPoolExecutor in cfhier86 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra86.Future_mro_len:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — MRO is [Future, object]; cf.Future directly subclasses object and is unrelated to asyncio.Future; NEW in extra86: first standalone MRO length invariant for cf.Future in cfhier86 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra86.Executor_module:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — Executor is defined in the _base private submodule of concurrent.futures; NEW in extra86: first standalone __module__ equality invariant for Executor in cfhier86 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
