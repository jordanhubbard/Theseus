spec: concurrent_futures_extra86
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra85

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra85.zspec.zsdl."
    - "This spec covers: wave 249 theme — concurrent.futures Executor class hierarchy. NEW in extra86: Executor.__bases__[0].__name__=='object'; Executor.__mro__.__len__()==2; ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ThreadPoolExecutor.__mro__.__len__()==3; ProcessPoolExecutor.__bases__[0].__name__=='Executor'; ProcessPoolExecutor.__mro__.__len__()==3; Future.__bases__[0].__name__=='object'; Future.__mro__.__len__()==2; Executor.__name__.__eq__('Executor')==True; Executor.__module__=='concurrent.futures._base'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__bases__[0].__name__ == 'object'. Executor directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__mro__.__len__() == 2. MRO is [Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'. ThreadPoolExecutor directly subclasses Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3. MRO is [ThreadPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'. ProcessPoolExecutor directly subclasses Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3. MRO is [ProcessPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object'. cf.Future directly subclasses object (not asyncio.Future). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__mro__.__len__() == 2. MRO is [Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__name__ == 'Executor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Executor hierarchy — extra86
#
# Wave 249 theme: concurrent.futures Executor class hierarchy.
#
# Executor.__bases__[0].__name__ == 'object'
# Executor.__mro__.__len__() == 2
# Executor.__name__ == 'Executor'
# Executor.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra86.Executor_hierarchy:
  description: "concurrent.futures Executor class hierarchy checks in cfhier86 namespace — wave 249 theme: concurrent.futures Executor class hierarchy; Executor.__bases__[0].__name__=='object' (Executor directly subclasses object); Executor.__mro__.__len__()==2 (MRO is [Executor, object]); Executor.__name__.__eq__('Executor')==True; Executor.__module__.__eq__('concurrent.futures._base')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfhier86

  columns: [id, function, args, expected, description]
  rows:
    - [executor_base_name,   "Executor.__bases__[0].__name__.__eq__", ["object"],                     true, "Executor.__bases__[0].__name__ == 'object' — Executor directly subclasses object; verified with Python 3.14.3"]
    - [executor_mro_len,     Executor.__mro__.__len__,                [],                             2,    "Executor.__mro__.__len__() == 2 — MRO is [Executor, object]; verified with Python 3.14.3"]
    - [executor_name_eq,     Executor.__name__.__eq__,                ["Executor"],                   true, "Executor.__name__ == 'Executor' — verified with Python 3.14.3"]
    - [executor_module_eq,   Executor.__module__.__eq__,              ["concurrent.futures._base"],   true, "Executor.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]

