table concurrent_futures_extra86.ThreadPoolExecutor_hierarchy:
  description: "concurrent.futures ThreadPoolExecutor class hierarchy checks in cfhier86 namespace — wave 249 theme: concurrent.futures Executor class hierarchy; ThreadPoolExecutor.__bases__[0].__name__=='Executor' (directly subclasses Executor); ThreadPoolExecutor.__mro__.__len__()==3 (MRO is [ThreadPoolExecutor, Executor, object]); ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True; ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfhier86a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_base_name,   "ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — directly subclasses Executor; verified with Python 3.14.3"]
    - [tpe_mro_len,     ThreadPoolExecutor.__mro__.__len__,                [],                          3,    "ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [tpe_name_eq,     ThreadPoolExecutor.__name__.__eq__,                ["ThreadPoolExecutor"],      true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' — verified with Python 3.14.3"]
    - [tpe_module_eq,   ThreadPoolExecutor.__module__.__eq__,              ["concurrent.futures.thread"],true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in thread submodule; verified with Python 3.14.3"]

