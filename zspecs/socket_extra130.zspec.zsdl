spec: socket_extra130
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra129.zspec.zsdl — covers socket.__all__ list membership for socket/AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM/gethostname/getaddrinfo/create_connection/error/timeout/getfqdn/create_server/IPPROTO_TCP / socket.socket C method __objclass__.__name__ equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() values / SocketIO class identity (ABCMeta, module, bases, qualname length) (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 306 theme: socket module-level Python function code attributes — create_connection/create_server/getfqdn/getaddrinfo co_name equality / co_argcount / co_varnames[0] / co_varnames.__len__()."
    - "socket.create_connection.__code__.co_name == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__code__.co_argcount == 3. Args: address, timeout, source_address. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__code__.co_varnames[0] == 'address'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__code__.co_varnames.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__code__.co_name == 'create_server'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__code__.co_argcount == 1. Args: address (family/backlog/reuse_port/dualstack_ipv6 are keyword-only with defaults). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__code__.co_varnames[0] == 'address'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__code__.co_varnames.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_name == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_argcount == 1. Arg: name (default ''). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_varnames[0] == 'name'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_varnames.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_name == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_argcount == 6. Args: host, port, family, type, proto, flags. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_varnames[0] == 'host'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_varnames.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.create_connection and socket.create_server are pure-Python helpers in Lib/socket.py (not C builtins). socket.gethostname and socket.getdefaulttimeout are C builtins from _socket with no __code__."
    - "Note: extra96 confirms create_connection is a 'Python function' (class 'function'); this spec first anchors co_name/co_argcount/co_varnames for create_connection/create_server/getfqdn/getaddrinfo."
    - "Note: create_connection co_argcount==3 (address, timeout, source_address) + keyword-only 'all_errors' added in Python 3.11. co_varnames has 15 entries including loop locals."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection.__code__.co_name.__eq__('create_connection')
# socket.create_connection.__code__.co_argcount.__eq__(3)
# socket.create_connection.__code__.co_varnames[0].__eq__('address')
# socket.create_connection.__code__.co_varnames.__len__()==15
# socket.create_server.__code__.co_name.__eq__('create_server')
#
# Wave 306 theme: create_connection and create_server co_name/co_argcount/co_varnames.
#
# create_connection is a pure-Python helper for establishing a connected client
# socket. It takes 3 positional args (address, timeout, source_address) and the
# keyword-only 'all_errors' (added in 3.11). co_varnames has 15 entries including
# loop locals (host, port, exceptions, res, af, socktype, proto, canonname, sa, sock,
# exc). create_server takes 1 positional arg (address) with keyword-only defaults
# for family, backlog, reuse_port, dualstack_ipv6. extra96 confirms create_connection
# is a 'function'; extra94 anchors __qualname__ and __module__; no prior socket spec
# anchors co_name/co_argcount/co_varnames for these functions under sockcode130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra130.create_connection_server_code_attrs:
  description: "create_connection/__code__/co_name.__eq__('create_connection')==True / co_argcount.__eq__(3)==True / co_varnames[0].__eq__('address')==True / co_varnames/__len__()==15 / create_server/__code__/co_name.__eq__('create_server')==True — create_connection is a pure-Python client socket helper (3 positional args); co_varnames has 15 entries including loop locals; create_server is pure-Python server helper; first sockcode130 anchor for co_name/co_argcount/co_varnames"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode130

  columns: [id, function, args, expected, description]
  rows:
    - [conn_co_name,      "create_connection.__code__.co_name.__eq__",        ["create_connection"], true, "create_connection co_name is 'create_connection' (pure-Python helper in Lib/socket.py)"]
    - [conn_co_argcount,  "create_connection.__code__.co_argcount.__eq__",    [3],                   true, "create_connection co_argcount=3 (address, timeout, source_address; 'all_errors' is keyword-only)"]
    - [conn_varnames_0,   "create_connection.__code__.co_varnames[0].__eq__", ["address"],           true, "create_connection co_varnames[0] is 'address' (a (host, port) tuple)"]
    - [conn_varnames_len, "create_connection.__code__.co_varnames.__len__",   [],                    15,   "create_connection co_varnames has 15 entries (3 args + keyword-only + 11 loop locals)"]
    - [serv_co_name,      "create_server.__code__.co_name.__eq__",            ["create_server"],     true, "create_server co_name is 'create_server' (pure-Python server socket setup helper)"]

# ---------------------------------------------------------------------------
# socket.create_server.__code__.co_argcount.__eq__(1)
# socket.create_server.__code__.co_varnames[0].__eq__('address')
# socket.create_server.__code__.co_varnames.__len__()==8
# socket.getfqdn.__code__.co_name.__eq__('getfqdn')
# socket.getfqdn.__code__.co_argcount.__eq__(1)
# socket.getfqdn.__code__.co_varnames[0].__eq__('name')
#
# Wave 306 theme: create_server and getfqdn code attributes.
#
# create_server takes 1 positional arg (address) with 4 keyword-only defaults
# (family, backlog, reuse_port, dualstack_ipv6). Its co_varnames has 8 entries
# (1 arg + 4 keyword-only + 3 locals: sock, err, msg). getfqdn is the fully-qualified
# domain name lookup helper — it takes 1 optional arg (name, default '') and has
# 4 co_varnames (name, hostname, aliases, ipaddrs). Both are pure Python (extra96
# confirms create_connection; extra94 anchors getfqdn __qualname__/__module__).
# No prior socket spec anchors create_server or getfqdn code attributes under
# sockcode130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra130.create_server_getfqdn_code_attrs:
  description: "create_server/__code__/co_argcount.__eq__(1)==True / co_varnames[0].__eq__('address')==True / co_varnames/__len__()==8 / getfqdn/__code__/co_name.__eq__('getfqdn')==True / getfqdn/__code__/co_argcount.__eq__(1)==True / getfqdn/__code__/co_varnames[0].__eq__('name')==True — create_server has 1 positional arg (address) and 8 co_varnames (4 keyword-only + 3 locals); getfqdn has 1 arg ('name') and 4 co_varnames; first sockcode130 anchor for create_server/getfqdn code attrs"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode130

  columns: [id, function, args, expected, description]
  rows:
    - [serv_co_argcount,   "create_server.__code__.co_argcount.__eq__",    [1],         true, "create_server co_argcount=1 (only 'address'; family/backlog/reuse_port/dualstack_ipv6 are keyword-only)"]
    - [serv_varnames_0,    "create_server.__code__.co_varnames[0].__eq__", ["address"], true, "create_server co_varnames[0] is 'address' (a (host, port) tuple like create_connection)"]
    - [serv_varnames_len,  "create_server.__code__.co_varnames.__len__",   [],          8,    "create_server co_varnames has 8 entries (address + 4 keyword-only + sock + err + msg)"]
    - [fqdn_co_name,       "getfqdn.__code__.co_name.__eq__",              ["getfqdn"], true, "getfqdn co_name is 'getfqdn' (fully-qualified domain name lookup in Lib/socket.py)"]
    - [fqdn_co_argcount,   "getfqdn.__code__.co_argcount.__eq__",          [1],         true, "getfqdn co_argcount=1 (name='' default; uses gethostbyaddr for FQDN lookup)"]
    - [fqdn_varnames_0,    "getfqdn.__code__.co_varnames[0].__eq__",       ["name"],    true, "getfqdn co_varnames[0] is 'name' (hostname string argument with default='')"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_name.__eq__('getaddrinfo')
# socket.getaddrinfo.__code__.co_argcount.__eq__(6)
# socket.getaddrinfo.__code__.co_varnames[0].__eq__('host')
# socket.getaddrinfo.__code__.co_varnames.__len__()==12
# socket.getfqdn.__code__.co_varnames.__len__()==4
#
# Wave 306 theme: getaddrinfo code attributes.
#
# getaddrinfo is a pure-Python wrapper in Lib/socket.py that calls the C-level
# _socket.getaddrinfo. It takes 6 positional args (host, port, family, type, proto,
# flags). co_varnames has 12 entries (6 args + 6 locals: addrlist, res, af, socktype,
# canonname, sa). This is consistent with getaddrinfo's role as an address resolution
# bridge that iterates over results and repacks them. extra96 confirms create_connection
# is a Python function and anchors getaddrinfo as a 'Python function'; extra94 anchors
# getaddrinfo __qualname__ and __module__. No prior socket spec anchors getaddrinfo
# co_name/co_argcount/co_varnames under sockcode130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra130.getaddrinfo_code_attrs:
  description: "getaddrinfo/__code__/co_name.__eq__('getaddrinfo')==True / co_argcount.__eq__(6)==True / co_varnames[0].__eq__('host')==True / co_varnames/__len__()==12 / getfqdn/__code__/co_varnames/__len__()==4 — getaddrinfo is pure-Python wrapper with 6 positional args (host/port/family/type/proto/flags) and 12 co_varnames (6 args + 6 iteration locals); getfqdn has 4 co_varnames (name/hostname/aliases/ipaddrs); first sockcode130 anchor for getaddrinfo code attrs"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode130

  columns: [id, function, args, expected, description]
  rows:
    - [addr_co_name,      "getaddrinfo.__code__.co_name.__eq__",        ["getaddrinfo"], true, "getaddrinfo co_name is 'getaddrinfo' (pure-Python wrapper over _socket.getaddrinfo)"]
    - [addr_co_argcount,  "getaddrinfo.__code__.co_argcount.__eq__",    [6],             true, "getaddrinfo co_argcount=6 (host, port, family, type, proto, flags)"]
    - [addr_varnames_0,   "getaddrinfo.__code__.co_varnames[0].__eq__", ["host"],        true, "getaddrinfo co_varnames[0] is 'host' (hostname or IP address to resolve)"]
    - [addr_varnames_len, "getaddrinfo.__code__.co_varnames.__len__",   [],              12,   "getaddrinfo co_varnames has 12 entries (6 args + 6 iteration locals)"]
    - [fqdn_varnames_len, "getfqdn.__code__.co_varnames.__len__",       [],              4,    "getfqdn co_varnames has 4 entries (name, hostname, aliases, ipaddrs)"]

# ---------------------------------------------------------------------------
# socket.create_connection.__code__.co_name.__eq__('create_connection') — standalone
#
# socket.create_connection.__code__.co_name is 'create_connection'. co_name is
# the name string of the code object, matching the function name. For pure-Python
# functions, co_name always matches the def statement name. create_connection is
# defined with 'def create_connection(address, timeout=...)' in Lib/socket.py,
# so co_name=='create_connection'. extra96 confirms create_connection is a Python
# function (class 'function'); extra94 anchors __qualname__=='create_connection'
# and __module__=='socket'. No prior socket spec anchors create_connection co_name
# as a standalone under sockcode130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra130.create_connection_co_name:
  description: "socket.create_connection.__code__.co_name.__eq__('create_connection') == True — co_name is 'create_connection' (matches def statement name in Lib/socket.py); extra96 confirms 'function' class; extra94 anchors __qualname__=='create_connection'; first standalone for create_connection co_name under sockcode130"
  category: code_attributes
  kind: python_call_eq
  function: "create_connection.__code__.co_name.__eq__"
  args: ["create_connection"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__code__.co_argcount.__eq__(3) — standalone
#
# socket.create_connection.__code__.co_argcount is 3. create_connection takes
# 3 positional-or-keyword arguments: address (required), timeout (default
# GLOBAL_DEFAULT_TIMEOUT), and source_address (default None). The 'all_errors'
# parameter (added in Python 3.11) is keyword-only and does NOT count in
# co_argcount (keyword-only args are counted in co_kwonlyargcount instead).
# No prior socket spec anchors create_connection co_argcount as a standalone
# under sockcode130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra130.create_connection_co_argcount_3:
  description: "socket.create_connection.__code__.co_argcount.__eq__(3) == True — create_connection takes 3 positional args (address, timeout, source_address); 'all_errors' (added in 3.11) is keyword-only (counted in co_kwonlyargcount, not co_argcount); first standalone for create_connection co_argcount under sockcode130"
  category: code_attributes
  kind: python_call_eq
  function: "create_connection.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__code__.co_name.__eq__('getfqdn') — standalone
#
# socket.getfqdn.__code__.co_name is 'getfqdn'. getfqdn (get fully-qualified
# domain name) is a pure-Python function in Lib/socket.py that wraps
# gethostbyaddr to retrieve the canonical FQDN for a host. It is exported
# in socket.__all__ (confirmed in extra129). extra94 anchors getfqdn __qualname__
# and __module__; no prior socket spec anchors getfqdn co_name as a standalone
# under sockcode130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra130.getfqdn_co_name:
  description: "socket.getfqdn.__code__.co_name.__eq__('getfqdn') == True — co_name is 'getfqdn' (pure-Python FQDN lookup using gethostbyaddr in Lib/socket.py); extra94 anchors __qualname__/__module__; extra129 anchors __all__ membership; first standalone for getfqdn co_name under sockcode130"
  category: code_attributes
  kind: python_call_eq
  function: "getfqdn.__code__.co_name.__eq__"
  args: ["getfqdn"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_argcount.__eq__(6) — standalone
#
# socket.getaddrinfo.__code__.co_argcount is 6. getaddrinfo takes 6 positional
# arguments: host, port, family=0, type=0, proto=0, flags=0. This is the Python
# wrapper layer over the C-level _socket.getaddrinfo which does the actual system
# call. The 6-argument signature matches the POSIX getaddrinfo(3) interface (node,
# service, hints.ai_family, hints.ai_socktype, hints.ai_protocol, hints.ai_flags).
# No prior socket spec anchors getaddrinfo co_argcount as a standalone under
# sockcode130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra130.getaddrinfo_co_argcount_6:
  description: "socket.getaddrinfo.__code__.co_argcount.__eq__(6) == True — getaddrinfo takes 6 positional args (host, port, family, type, proto, flags) matching POSIX getaddrinfo(3); pure-Python wrapper over _socket.getaddrinfo C builtin; extra94 anchors __qualname__/__module__; first standalone for getaddrinfo co_argcount under sockcode130"
  category: code_attributes
  kind: python_call_eq
  function: "getaddrinfo.__code__.co_argcount.__eq__"
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_server.__code__.co_argcount.__eq__(1) — standalone
#
# socket.create_server.__code__.co_argcount is 1. create_server takes 1 positional
# argument (address) plus 4 keyword-only arguments (family=AF_INET, backlog=None,
# reuse_port=False, dualstack_ipv6=False). The keyword-only args are counted in
# co_kwonlyargcount (4), not co_argcount (1). create_server was added in Python 3.8
# as a convenience function for creating listening server sockets. No prior socket
# spec anchors create_server co_argcount as a standalone under sockcode130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra130.create_server_co_argcount_1:
  description: "socket.create_server.__code__.co_argcount.__eq__(1) == True — create_server takes 1 positional arg (address); 4 keyword-only args (family/backlog/reuse_port/dualstack_ipv6) are in co_kwonlyargcount; added in Python 3.8 for server socket convenience; first standalone for create_server co_argcount under sockcode130"
  category: code_attributes
  kind: python_call_eq
  function: "create_server.__code__.co_argcount.__eq__"
  args: [1]
  expected: true
