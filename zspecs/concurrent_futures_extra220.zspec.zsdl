spec: concurrent_futures_extra220
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.Executor.__class__.__name__ == 'type' — Executor is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__class__.__name__ == 'type' — ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__class__.__name__ == 'type' — ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "concurrent.futures.Future.__class__.__name__ == 'type' — ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__class__.__name__ == 'type' — ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object]; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — MRO is [InvalidStateError, Error, Exception, BaseException, object]; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __class__.__name__ type checks — extra220 namespace
#
# Executor, ThreadPoolExecutor, ProcessPoolExecutor, Future, and BrokenExecutor
# are all ordinary Python classes whose metaclass is the built-in 'type'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra220.class_type_checks:
  description: "concurrent.futures class __class__.__name__.__eq__('type') checks in extra220 namespace"
  kind: python_call_eq
  category: class_types
  id_prefix: cf220classtypes

  columns: [id, function, args, expected, description]
  rows:
    - [executor_class_type,          Executor.__class__.__name__.__eq__,          ["type"], true, "concurrent.futures.Executor.__class__.__name__ == 'type'; Executor is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [threadpoolexecutor_class_type, ThreadPoolExecutor.__class__.__name__.__eq__, ["type"], true, "concurrent.futures.ThreadPoolExecutor.__class__.__name__ == 'type'; ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [processpoolexecutor_class_type, ProcessPoolExecutor.__class__.__name__.__eq__, ["type"], true, "concurrent.futures.ProcessPoolExecutor.__class__.__name__ == 'type'; ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [future_class_type,             Future.__class__.__name__.__eq__,            ["type"], true, "concurrent.futures.Future.__class__.__name__ == 'type'; Future is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [brokenexecutor_class_type,     BrokenExecutor.__class__.__name__.__eq__,    ["type"], true, "concurrent.futures.BrokenExecutor.__class__.__name__ == 'type'; BrokenExecutor is an ordinary Python class with metaclass type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class MRO length checks — extra220 namespace
#
# ThreadPoolExecutor MRO: [ThreadPoolExecutor, Executor, object] — len 3
# ProcessPoolExecutor MRO: [ProcessPoolExecutor, Executor, object] — len 3
# BrokenExecutor MRO: [BrokenExecutor, RuntimeError, Exception, BaseException, object] — len 5
# InvalidStateError MRO: [InvalidStateError, Error, Exception, BaseException, object] — len 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra220.class_mro_lengths:
  description: "concurrent.futures class __mro__.__len__() checks in extra220 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cf220mrolens

  columns: [id, function, args, expected, description]
  rows:
    - [threadpoolexecutor_mro_len,  ThreadPoolExecutor.__mro__.__len__,  [], 3, "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [processpoolexecutor_mro_len, ProcessPoolExecutor.__mro__.__len__, [], 3, "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [brokenexecutor_mro_len,      BrokenExecutor.__mro__.__len__,      [], 5, "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [invalidstateerror_mro_len,   InvalidStateError.__mro__.__len__,   [], 5, "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — MRO is [InvalidStateError, Error, Exception, BaseException, object]; verified with Python 3.14.3"]
