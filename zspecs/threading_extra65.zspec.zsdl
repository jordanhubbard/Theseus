spec: threading_extra65
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra64.zspec.zsdl."
    - "Wave 230 theme: __code__ attribute deep chains — co_name, co_argcount values."
    - "threading.Thread.__init__.__code__.co_name == '__init__' — co_name is the function's def-statement name as a str. For __init__ it is the 8-character string '__init__'. Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_name == 'start' — 5 characters. Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_name == 'run' — 3 characters. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_name == 'current_thread' — 14 characters. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_argcount == 6 — Thread.__init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None, context=None); co_argcount counts positional parameters including self and those with defaults, but excludes keyword-only parameters after the bare *. The positional parameters are: self, group, target, name, args, kwargs — that is 6. daemon and context are keyword-only (after *) and excluded. Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_argcount == 1 — start(self) has only the implicit self parameter. Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_argcount == 1 — run(self) has only self. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_name.__class__.__name__ == 'str' — co_name is always a plain str in CPython. Verified with Python 3.14.3."
    - "No prior threading spec checks co_name or co_argcount for any threading function. All checks in this spec are new to extra65."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading function __code__.co_name checks — extra65
#
# Wave 230 theme: __code__.co_name deep chains.
#
# co_name is the name field of the code object (PyCodeObject.co_name).
# It is a str equal to the function's name as defined in its def statement.
#
# Thread.__init__.__code__.co_name == '__init__'
# Thread.start.__code__.co_name   == 'start'
# Thread.run.__code__.co_name     == 'run'
# current_thread.__code__.co_name == 'current_thread'
#
# All are pure-Python functions in Lib/threading.py.
# No prior threading spec checks co_name. New to extra65.
# ---------------------------------------------------------------------------

table threading_extra65.co_name_eq:
  description: "threading function __code__.co_name.__eq__ — co_name matches the def-statement name; wave 230 co_name deep chains; new to extra65"
  kind: python_call_eq
  category: co_name
  id_prefix: thrdcode2_65

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_name_eq_init,
       Thread.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "threading.Thread.__init__.__code__.co_name.__eq__('__init__') == True — Thread.__init__ is a pure-Python method (Lib/threading.py) defined with 'def __init__(...)'; the code object attribute co_name (PyCodeObject.co_name) stores the function's name as an interned str; for __init__ it is the 8-character string '__init__'; __eq__ on a str returns True when the argument equals the string; no prior threading spec checks co_name for Thread.__init__; new to extra65"]
    - [thread_start_code_co_name_eq_start,
       Thread.start.__code__.co_name.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__code__.co_name.__eq__('start') == True — Thread.start is a pure-Python method (Lib/threading.py) defined with 'def start(...)'; co_name for start is the 5-character string 'start'; __eq__ returns True; no prior threading spec checks co_name for Thread.start; new to extra65"]
    - [thread_run_code_co_name_eq_run,
       Thread.run.__code__.co_name.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__code__.co_name.__eq__('run') == True — Thread.run is a pure-Python method (Lib/threading.py) defined with 'def run(...)'; co_name for run is the 3-character string 'run'; __eq__ returns True; no prior threading spec checks co_name for Thread.run; new to extra65"]
    - [current_thread_code_co_name_eq_current_thread,
       current_thread.__code__.co_name.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__code__.co_name.__eq__('current_thread') == True — current_thread is a pure-Python module-level function (Lib/threading.py) defined with 'def current_thread(...)'; co_name for current_thread is the 14-character string 'current_thread'; __eq__ returns True; no prior threading spec checks co_name for current_thread; new to extra65"]

# ---------------------------------------------------------------------------
# threading function __code__.co_argcount values — extra65
#
# Wave 230 theme: co_argcount counts positional parameters.
#
# co_argcount (PyCodeObject.co_argcount) counts positional parameters
# including self and those with defaults, excluding *args, **kwargs, and
# keyword-only parameters (those after a bare *).
#
# Thread.__init__(self, group=None, target=None, name=None, args=(),
#                 kwargs=None, *, daemon=None, context=None)
#   Positional params: self, group, target, name, args, kwargs → co_argcount == 6
#   daemon, context are keyword-only (after *) → excluded
#
# Thread.start(self) → co_argcount == 1
# Thread.run(self)   → co_argcount == 1
#
# Verified with Python 3.14.3: Thread.__init__=6, start=1, run=1.
#
# No prior threading spec checks co_argcount. New to extra65.
# ---------------------------------------------------------------------------

table threading_extra65.co_argcount_eq:
  description: "threading function __code__.co_argcount — Thread.__init__ has 6, start/run have 1; wave 230 co_argcount values; new to extra65"
  kind: python_call_eq
  category: co_argcount
  id_prefix: thrdcode2_65

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_argcount_eq_6,
       Thread.__init__.__code__.co_argcount.__eq__,
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__ is a pure-Python method (Lib/threading.py) with signature __init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None, context=None); co_argcount counts positional parameters including self and those with defaults but excluding keyword-only parameters after the bare *; the positional parameters are self, group, target, name, args, kwargs — giving co_argcount == 6; daemon and context are keyword-only and not counted; verified with Python 3.14.3; no prior threading spec checks co_argcount for Thread.__init__; new to extra65"]
    - [thread_start_code_co_argcount_eq_1,
       Thread.start.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Thread.start.__code__.co_argcount.__eq__(1) == True — Thread.start is a pure-Python method (Lib/threading.py) with signature start(self); the only positional parameter is self (no defaults, no keyword-only params); co_argcount == 1; verified with Python 3.14.3; no prior threading spec checks co_argcount for Thread.start; new to extra65"]
    - [thread_run_code_co_argcount_eq_1,
       Thread.run.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Thread.run.__code__.co_argcount.__eq__(1) == True — Thread.run is a pure-Python method (Lib/threading.py) with signature run(self); the only positional parameter is self; co_argcount == 1; verified with Python 3.14.3; no prior threading spec checks co_argcount for Thread.run; new to extra65"]

# ---------------------------------------------------------------------------
# Thread.__init__.__code__.co_name.__class__.__name__ — extra65
#
# Wave 230 theme: co_name is always a str.
#
# co_name is stored as a PyObject* in PyCodeObject; in CPython it is always
# an interned str. Therefore co_name.__class__ is the built-in str type and
# str.__name__ == 'str'.
#
# Checking co_name.__class__.__name__.__eq__('str') confirms the type of the
# co_name field without depending on the exact method name string.
#
# No prior threading spec checks co_name.__class__.__name__. New to extra65.
# ---------------------------------------------------------------------------

table threading_extra65.co_name_class_name:
  description: "Thread.__init__.__code__.co_name.__class__.__name__.__eq__('str')==true — co_name is always a str object; wave 230 co_name deep chains; new to extra65"
  kind: python_call_eq
  category: co_name
  id_prefix: thrdcode2_65

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_name_class_name_eq_str,
       Thread.__init__.__code__.co_name.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__init__.__code__.co_name.__class__.__name__.__eq__('str') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_name is always an interned str in CPython (the method name is stored as a Python str at compile time); therefore co_name.__class__ is the built-in str type and str.__name__ == 'str' (3 chars); __eq__ returns True; this chain verifies the type of co_name without depending on the method name's content; no prior threading spec checks co_name.__class__.__name__ for any threading function; new to extra65"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant threading_extra65.thread_init_co_name_eq_init:
  description: "threading.Thread.__init__.__code__.co_name.__eq__('__init__') == True — co_name is the method's def-statement name; wave 230 co_name deep chains; new to extra65"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra65.thread_start_co_name_eq_start:
  description: "threading.Thread.start.__code__.co_name.__eq__('start') == True — co_name is the method's def-statement name; wave 230 co_name deep chains; new to extra65"
  kind: python_call_eq
  function: Thread.start.__code__.co_name.__eq__
  args: ["start"]
  expected: true

invariant threading_extra65.current_thread_co_name_eq_current_thread:
  description: "threading.current_thread.__code__.co_name.__eq__('current_thread') == True — co_name is the function's def-statement name; wave 230 co_name deep chains; new to extra65"
  kind: python_call_eq
  function: current_thread.__code__.co_name.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra65.thread_init_co_argcount_eq_6:
  description: "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — self + group + target + name + args + kwargs = 6 positional params; daemon/context are keyword-only; wave 230 co_argcount values; new to extra65"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant threading_extra65.thread_init_co_name_class_eq_str:
  description: "threading.Thread.__init__.__code__.co_name.__class__.__name__.__eq__('str') == True — co_name is always a str object; wave 230 co_name deep chains; new to extra65"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
