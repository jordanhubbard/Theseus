spec: th3001
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (th3001): __getitem__, __setitem__, __delitem__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define item access or mutation operators."
    - "Verified types: threading.Thread, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Lock and threading.RLock are factory functions returning C-level lock objects, not checked here."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3001.getitem:
  description: "threading types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3001
  columns: [id, function, args, expected]
  rows:
    - ["th3001001", operator.contains, [threading.Thread.__dict__,           "__getitem__"], false]
    - ["th3001002", operator.contains, [threading.Condition.__dict__,        "__getitem__"], false]
    - ["th3001003", operator.contains, [threading.Semaphore.__dict__,        "__getitem__"], false]
    - ["th3001004", operator.contains, [threading.BoundedSemaphore.__dict__, "__getitem__"], false]
    - ["th3001005", operator.contains, [threading.Event.__dict__,            "__getitem__"], false]
    - ["th3001006", operator.contains, [threading.Barrier.__dict__,          "__getitem__"], false]

