spec: just_sort_by
version: ">=3.2.0"
backend: node(just-sort-by)

docs: https://www.npmjs.com/package/just-sort-by

provenance:
  derived_from:
    - "just-sort-by README — https://www.npmjs.com/package/just-sort-by"
    - "Test vectors verified with just-sort-by via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-sort-by source"
  notes:
    - "just-sort-by is an npm package. Install: npm install just-sort-by"
    - "Sorts an array of objects by the given key name."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a sorted array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_sort_by.sort:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: jsrtby

  columns: [id, args, expected]
  rows:
    - [by_string,  [[{"a": 3}, {"a": 1}, {"a": 2}], "a"],  [{"a": 1}, {"a": 2}, {"a": 3}]]
    - [by_number,  [[{"n": 10}, {"n": 5}, {"n": 8}], "n"],  [{"n": 5}, {"n": 8}, {"n": 10}]]
