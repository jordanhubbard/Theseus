spec: base64_js
version: ">=1.5.1"
backend: node(base64-js)

docs: https://www.npmjs.com/package/base64-js

provenance:
  derived_from:
    - "base64-js README — https://www.npmjs.com/package/base64-js"
    - "Test vectors verified with base64-js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "base64-js source"
  notes:
    - "base64-js is an npm package. Install: npm install base64-js"
    - "fromByteArray(uint8arr) encodes bytes to base64 string."
    - "toByteArray(str) decodes base64 string to Uint8Array; serializes as a plain array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a base64 string or a byte array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table base64_js.fromByteArray:
  kind: node_module_call_eq
  function: fromByteArray
  category: encode
  id_prefix: b64enc

  columns: [id, args, expected]
  rows:
    - [hello, [[72, 101, 108, 108, 111]], "SGVsbG8="]
    - [hi,    [[72, 105]],                "SGk="]

table base64_js.toByteArray:
  kind: node_module_call_eq
  function: toByteArray
  category: decode
  id_prefix: b64dec

  columns: [id, args, expected]
  rows:
    - [hello, ["SGVsbG8="], {"0": 72, "1": 101, "2": 108, "3": 108, "4": 111}]
    - [hi,    ["SGk="],     {"0": 72, "1": 105}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:45:09Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
