spec: uuid_extra258
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra257.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 function identity; NAMESPACE_* class names and variant; UUID.__name__/__module__/__bases__."
    - "uuid_extra256.zspec.zsdl — covers uuid4() version/variant statistical properties; UUID.__eq__/__ne__/__lt__ comparison method identity; UUID equality/ordering behavioral contracts."
    - "uuid_extra255.zspec.zsdl — covers uuid module identity (__name__, __package__, __spec__, __loader__); UUID repr/hash/bytes/bytes_le; UUID.__repr__/__hash__ method identity."
    - "uuid_extra.zspec.zsdl — covers UUID class name/module; uuid1/3/4/5 function names; uuid4 return class and version; NAMESPACE_* class names; UUID.int and hex class names."
  notes:
    - "uuid.UUID.__str__.__name__ == '__str__' and __class__.__name__ == 'function' — UUID.__str__ is a pure-Python function in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__repr__.__name__ == '__repr__' and __class__.__name__ == 'function' — UUID.__repr__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__hash__.__name__ == '__hash__' and __class__.__name__ == 'function' — UUID.__hash__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__eq__.__name__ == '__eq__' and __class__.__name__ == 'function' — UUID.__eq__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__lt__/__le__/__gt__/__ge__.__class__.__name__ == 'function' — all comparison methods are pure-Python functions. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' — qualname has 'UUID.' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' — qualname has 'UUID.' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.bytes is a property whose fget.__name__ == 'bytes' and fget.__qualname__ == 'UUID.bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.hex is a property whose fget.__name__ == 'hex' and fget.__qualname__ == 'UUID.hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.version is a property whose fget.__name__ == 'version' and fget.__qualname__ == 'UUID.version'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.int is a member_descriptor (not a property) — it has no fget attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID class method identity — __str__, __repr__, __hash__, __eq__
# All four are pure-Python functions defined in Lib/uuid.py.
# __class__.__name__ == 'function' for all of them.
# ---------------------------------------------------------------------------

table uuid_extra258.UUID_dunder_method_identity:
  description: "uuid.UUID.__str__/__repr__/__hash__/__eq__ method __name__ and __class__.__name__ — all pure-Python functions in Lib/uuid.py; __class__.__name__ == 'function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmeth258

  columns: [id, function, args, expected, description]
  rows:
    - [str_name,    UUID.__str__.__name__.__eq__,               ["__str__"],   true, "uuid.UUID.__str__.__name__ == '__str__' — pure-Python method"]
    - [str_class,   UUID.__str__.__class__.__name__.__eq__,      ["function"],  true, "uuid.UUID.__str__.__class__.__name__ == 'function' — pure-Python function"]
    - [repr_name,   UUID.__repr__.__name__.__eq__,              ["__repr__"],  true, "uuid.UUID.__repr__.__name__ == '__repr__' — pure-Python method"]
    - [repr_class,  UUID.__repr__.__class__.__name__.__eq__,     ["function"],  true, "uuid.UUID.__repr__.__class__.__name__ == 'function' — pure-Python function"]
    - [hash_name,   UUID.__hash__.__name__.__eq__,              ["__hash__"],  true, "uuid.UUID.__hash__.__name__ == '__hash__' — pure-Python method"]

# ---------------------------------------------------------------------------
# UUID comparison method identity — __eq__, __lt__, __le__, __gt__, __ge__
# All five are pure-Python functions in Lib/uuid.py.
# __class__.__name__ == 'function', qualnames have 'UUID.' prefix.
# ---------------------------------------------------------------------------

table uuid_extra258.UUID_comparison_method_identity:
  description: "uuid.UUID.__eq__/__lt__/__le__/__gt__/__ge__ method __name__ and __class__.__name__ — all pure-Python functions in Lib/uuid.py; __class__.__name__ == 'function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp258

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name,   UUID.__eq__.__name__.__eq__,              ["__eq__"], true, "uuid.UUID.__eq__.__name__ == '__eq__' — pure-Python equality method"]
    - [eq_class,  UUID.__eq__.__class__.__name__.__eq__,     ["function"], true, "uuid.UUID.__eq__.__class__.__name__ == 'function' — pure-Python function"]
    - [lt_name,   UUID.__lt__.__name__.__eq__,              ["__lt__"], true, "uuid.UUID.__lt__.__name__ == '__lt__' — pure-Python less-than method"]
    - [le_name,   UUID.__le__.__name__.__eq__,              ["__le__"], true, "uuid.UUID.__le__.__name__ == '__le__' — pure-Python less-or-equal method"]
    - [gt_name,   UUID.__gt__.__name__.__eq__,              ["__gt__"], true, "uuid.UUID.__gt__.__name__ == '__gt__' — pure-Python greater-than method"]

# ---------------------------------------------------------------------------
# UUID qualname identity — __str__, __eq__, __repr__, __hash__
# All qualnames have the 'UUID.' prefix, confirming class membership.
# ---------------------------------------------------------------------------

invariant uuid_extra258.UUID_str_qualname_eq:
  description: "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' — qualname has 'UUID.' prefix confirming class membership in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__eq__
  args: ["UUID.__str__"]
  expected: true

invariant uuid_extra258.UUID_eq_qualname_eq:
  description: "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' — qualname has 'UUID.' prefix confirming class membership; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__eq__.__qualname__.__eq__
  args: ["UUID.__eq__"]
  expected: true

invariant uuid_extra258.UUID_repr_qualname_eq:
  description: "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' — qualname has 'UUID.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__repr__.__qualname__.__eq__
  args: ["UUID.__repr__"]
  expected: true

invariant uuid_extra258.UUID_hash_qualname_eq:
  description: "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' — qualname has 'UUID.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__hash__.__qualname__.__eq__
  args: ["UUID.__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# UUID property fget identity — bytes, hex, version
# uuid.UUID.bytes and uuid.UUID.hex are property objects.
# Their fget is a pure-Python function with __name__ == property name
# and __qualname__ == 'UUID.<name>'.
# ---------------------------------------------------------------------------

invariant uuid_extra258.UUID_bytes_fget_name_eq:
  description: "uuid.UUID.bytes.fget.__name__ == 'bytes' — bytes is a property on UUID; fget is pure-Python with __name__ 'bytes'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.bytes.fget.__name__.__eq__
  args: ["bytes"]
  expected: true

invariant uuid_extra258.UUID_bytes_fget_qualname_eq:
  description: "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' — fget qualname has 'UUID.' prefix; confirmed class membership; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.bytes.fget.__qualname__.__eq__
  args: ["UUID.bytes"]
  expected: true

invariant uuid_extra258.UUID_hex_fget_name_eq:
  description: "uuid.UUID.hex.fget.__name__ == 'hex' — hex is a property on UUID; fget is pure-Python with __name__ 'hex'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.hex.fget.__name__.__eq__
  args: ["hex"]
  expected: true

invariant uuid_extra258.UUID_hex_fget_qualname_eq:
  description: "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' — fget qualname has 'UUID.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.hex.fget.__qualname__.__eq__
  args: ["UUID.hex"]
  expected: true

invariant uuid_extra258.UUID_version_fget_name_eq:
  description: "uuid.UUID.version.fget.__name__ == 'version' — version is a property on UUID; fget is pure-Python with __name__ 'version'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.version.fget.__name__.__eq__
  args: ["version"]
  expected: true

invariant uuid_extra258.UUID_version_fget_qualname_eq:
  description: "uuid.UUID.version.fget.__qualname__ == 'UUID.version' — fget qualname has 'UUID.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.version.fget.__qualname__.__eq__
  args: ["UUID.version"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__ge__ standalone
# ---------------------------------------------------------------------------

invariant uuid_extra258.UUID_ge_name_eq:
  description: "uuid.UUID.__ge__.__name__ == '__ge__' — pure-Python greater-or-equal method; __class__.__name__ == 'function'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__ge__.__name__.__eq__
  args: ["__ge__"]
  expected: true

invariant uuid_extra258.UUID_lt_qualname_eq:
  description: "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' — qualname has 'UUID.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__lt__.__qualname__.__eq__
  args: ["UUID.__lt__"]
  expected: true
