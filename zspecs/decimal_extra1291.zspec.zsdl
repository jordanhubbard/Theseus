spec: decimal_extra1291
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 533 _extra1291: checks __init__/__new__ qualname, __class__.__name__, and __dict__.__contains__ for decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation."
    - "decimal.Decimal does NOT define __init__ in its own __dict__; MRO resolves to object.__init__ (qualname 'object.__init__')."
    - "decimal.Decimal defines __new__ directly; __new__.__qualname__ == 'Decimal.__new__'; __class__.__name__ == 'builtin_function_or_method' (C extension)."
    - "decimal.Context defines both __init__ and __new__ directly; __init__.__class__.__name__ == 'wrapper_descriptor'; __new__.__class__.__name__ == 'builtin_function_or_method'."
    - "decimal.DecimalException and decimal.InvalidOperation do NOT define __init__ in their own __dict__; MRO resolves to BaseException.__init__."
    - "decimal.Overflow and decimal.DivisionByZero also do not define __init__ directly."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1291.decimal_init_new:
  description: "decimal.Decimal __init__ and __new__ qualname, type, and __dict__.__contains__ checks"
  kind: python_call_eq
  category: decimal_init_new
  id_prefix: dc1291dn
  columns: [id, function, args, expected]
  rows:
    - [dc1291dn001, decimal.Decimal.__dict__.__contains__,           ["__init__"],                     false]
    - [dc1291dn002, decimal.Decimal.__dict__.__contains__,           ["__new__"],                      true]
    - [dc1291dn003, decimal.Decimal.__new__.__qualname__.__eq__,     ["Decimal.__new__"],              true]
    - [dc1291dn004, decimal.Decimal.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [dc1291dn005, decimal.Decimal.__init__.__qualname__.__eq__,    ["object.__init__"],              true]
    - [dc1291dn006, decimal.Decimal.__class__.__name__.__eq__,       ["type"],                         true]

table decimal_extra1291.context_init_new:
  description: "decimal.Context __init__ and __new__ qualname, type, and __dict__.__contains__ checks"
  kind: python_call_eq
  category: context_init_new
  id_prefix: dc1291cn
  columns: [id, function, args, expected]
  rows:
    - [dc1291cn001, decimal.Context.__dict__.__contains__,            ["__init__"],                     true]
    - [dc1291cn002, decimal.Context.__dict__.__contains__,            ["__new__"],                      true]
    - [dc1291cn003, decimal.Context.__init__.__qualname__.__eq__,     ["Context.__init__"],             true]
    - [dc1291cn004, decimal.Context.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],         true]
    - [dc1291cn005, decimal.Context.__new__.__qualname__.__eq__,      ["Context.__new__"],              true]
    - [dc1291cn006, decimal.Context.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [dc1291cn007, decimal.Context.__class__.__name__.__eq__,        ["type"],                         true]
    - [dc1291cn008, decimal.Context.__name__.__eq__,                  ["Context"],                      true]

table decimal_extra1291.exception_init:
  description: "decimal.DecimalException and decimal.InvalidOperation __dict__.__contains__ and __init__.__qualname__ checks"
  kind: python_call_eq
  category: exception_init
  id_prefix: dc1291ei
  columns: [id, function, args, expected]
  rows:
    - [dc1291ei001, decimal.DecimalException.__dict__.__contains__,        ["__init__"],            false]
    - [dc1291ei002, decimal.DecimalException.__init__.__qualname__.__eq__, ["BaseException.__init__"], true]
    - [dc1291ei003, decimal.InvalidOperation.__dict__.__contains__,        ["__init__"],            false]
    - [dc1291ei004, decimal.InvalidOperation.__init__.__qualname__.__eq__, ["BaseException.__init__"], true]
    - [dc1291ei005, decimal.Overflow.__dict__.__contains__,                ["__init__"],            false]
    - [dc1291ei006, decimal.DivisionByZero.__dict__.__contains__,          ["__init__"],            false]
    - [dc1291ei007, decimal.DecimalException.__class__.__name__.__eq__,   ["type"],                 true]
    - [dc1291ei008, decimal.InvalidOperation.__class__.__name__.__eq__,   ["type"],                 true]
