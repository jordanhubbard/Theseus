spec: re2851
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2836.zspec.zsdl — wave 636 predecessor (covered __rtruediv__, __rfloordiv__, __rmod__)"
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave 637 theme: __rlshift__, __rrshift__, and __rpow__ dict-presence checks (reflected left-shift, right-shift, and power operators)."
    - "re.Pattern and re.Match are regex engine objects, not numeric types — none define reflected shift or power operators."
    - "re.RegexFlag is an IntFlag enum; IntFlag defines bitwise operators (__lshift__, __rshift__) on integer values but does NOT define the reflected forms __rlshift__ or __rrshift__ in its own __dict__."
    - "re.Pattern (type(re.compile(''))) does NOT define __rlshift__, __rrshift__, or __rpow__ in its __dict__."
    - "re.Match (type(re.match('', ''))) does NOT define __rlshift__, __rrshift__, or __rpow__ in its __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rlshift__ dict-presence — absent from re.Pattern, re.Match, re.RegexFlag
# ---------------------------------------------------------------------------

table re2851.rlshift_protocol:
  description: "__rlshift__ is absent from re.Pattern, re.Match, and re.RegexFlag __dict__s — regex objects have no left-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2851

  columns: [id, function, args, expected]
  rows:
    - ["re2851001", "re.Pattern.__dict__.__contains__",   ["__rlshift__"], false]
    - ["re2851002", "re.Match.__dict__.__contains__",     ["__rlshift__"], false]
    - ["re2851003", "re.RegexFlag.__dict__.__contains__", ["__rlshift__"], false]

# ---------------------------------------------------------------------------
