  id_prefix: re2851

  columns: [id, function, args, expected]
  rows:
    - ["re2851007", "re.Pattern.__dict__.__contains__",   ["__rpow__"], false]
    - ["re2851008", "re.Match.__dict__.__contains__",     ["__rpow__"], false]
    - ["re2851009", "re.RegexFlag.__dict__.__contains__", ["__rpow__"], false]

# ---------------------------------------------------------------------------
# Table: all three reflected ops — combined view for all three re types
# Confirms that none of Pattern, Match, or RegexFlag define any reflected
# shift or power protocol in their own __dict__
# ---------------------------------------------------------------------------

table re2851.reflected_shift_pow_summary:
