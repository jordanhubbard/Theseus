  columns: [id, function, args, expected]
  rows:
    - ["re2851004", "re.Pattern.__dict__.__contains__",   ["__rrshift__"], false]
    - ["re2851005", "re.Match.__dict__.__contains__",     ["__rrshift__"], false]
    - ["re2851006", "re.RegexFlag.__dict__.__contains__", ["__rrshift__"], false]

