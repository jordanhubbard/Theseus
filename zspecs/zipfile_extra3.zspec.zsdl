spec: zipfile_extra3
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "Extends zipfile.zspec.zsdl, zipfile_extra.zspec.zsdl, and zipfile_extra2.zspec.zsdl."
    - "zipfile_extra.zspec.zsdl covers: ZipFile.__name__, ZipInfo.__name__, BadZipFile.__name__, LargeZipFile.__name__, Path.__name__, ZipFile.__module__, BadZipFile.__bases__[0].__name__, is_zipfile.__name__, all ZIP_* class names, all ZIP_* values."
    - "zipfile_extra2.zspec.zsdl covers: table-form class names (ZipFile, ZipInfo, BadZipFile, LargeZipFile), BadZipFile base, table-form constant type checks (ZIP_STORED, ZIP_DEFLATED, ZIP_BZIP2, ZIP_LZMA), is_zipfile name."
    - "This spec adds: ZipFile.__module__ via table, ZipInfo __module__, BadZipFile __module__, Path.__name__ (Python>=3.8), ZipInfo class type check, ZipFile is_type check, ZipInfo compress_type default, LargeZipFile base class, additional constant cross-checks."
    - "zipfile.ZipFile.__module__ == 'zipfile' — public module identity."
    - "zipfile.Path.__name__ == 'Path' — available since Python 3.8."
    - "zipfile.ZIP_STORED == 0, zipfile.ZIP_DEFLATED == 8 — well-known constant values."
    - "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception' — direct Exception subclass."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — ZipFile, ZipInfo, BadZipFile (individual invariants)
# ---------------------------------------------------------------------------

invariant zipfile_extra3.ZipFile.name:
  description: "zipfile.ZipFile.__name__ == 'ZipFile'"
  category: class_names
  kind: python_call_eq
  function: ZipFile.__name__.__eq__
  args: ["ZipFile"]
  expected: true

invariant zipfile_extra3.ZipInfo.name:
  description: "zipfile.ZipInfo.__name__ == 'ZipInfo'"
  category: class_names
  kind: python_call_eq
  function: ZipInfo.__name__.__eq__
  args: ["ZipInfo"]
  expected: true

invariant zipfile_extra3.BadZipFile.name:
  description: "zipfile.BadZipFile.__name__ == 'BadZipFile'"
  category: class_names
  kind: python_call_eq
  function: BadZipFile.__name__.__eq__
  args: ["BadZipFile"]
  expected: true

# ---------------------------------------------------------------------------
# Path class name — available since Python 3.8
# ---------------------------------------------------------------------------

invariant zipfile_extra3.Path.name:
  description: "zipfile.Path.__name__ == 'Path' — Path class available since Python 3.8"
  category: class_names
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — classes live in the zipfile module
# ---------------------------------------------------------------------------

invariant zipfile_extra3.ZipFile.module:
  description: "zipfile.ZipFile.__module__ == 'zipfile'"
  category: modules
  kind: python_call_eq
  function: ZipFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

invariant zipfile_extra3.ZipInfo.module:
  description: "zipfile.ZipInfo.__module__ == 'zipfile'"
  category: modules
  kind: python_call_eq
  function: ZipInfo.__module__.__eq__
  args: ["zipfile"]
  expected: true

invariant zipfile_extra3.BadZipFile.module:
  description: "zipfile.BadZipFile.__module__ == 'zipfile'"
  category: modules
  kind: python_call_eq
  function: BadZipFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — BadZipFile inherits directly from Exception
# ---------------------------------------------------------------------------

invariant zipfile_extra3.BadZipFile.base_is_Exception:
  description: "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: BadZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# LargeZipFile exception hierarchy — also a direct Exception subclass
# ---------------------------------------------------------------------------

invariant zipfile_extra3.LargeZipFile.base_is_Exception:
  description: "zipfile.LargeZipFile.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: LargeZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Compression constant type checks — ZIP_STORED and ZIP_DEFLATED are int
# ---------------------------------------------------------------------------

invariant zipfile_extra3.ZIP_STORED.class_name:
  description: "zipfile.ZIP_STORED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_STORED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zipfile_extra3.ZIP_DEFLATED.class_name:
  description: "zipfile.ZIP_DEFLATED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_DEFLATED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Compression constant value checks — canonical values
# ---------------------------------------------------------------------------

invariant zipfile_extra3.ZIP_STORED.value:
  description: "zipfile.ZIP_STORED == 0 — no compression"
  category: constants
  kind: python_call_eq
  function: ZIP_STORED.__eq__
  args: [0]
  expected: true

invariant zipfile_extra3.ZIP_DEFLATED.value:
  description: "zipfile.ZIP_DEFLATED == 8 — zlib deflate compression"
  category: constants
  kind: python_call_eq
  function: ZIP_DEFLATED.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# Type identity checks — ZipFile and ZipInfo are proper types (classes)
# ---------------------------------------------------------------------------

invariant zipfile_extra3.ZipFile.is_type:
  description: "zipfile.ZipFile.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: ZipFile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant zipfile_extra3.ZipInfo.is_type:
  description: "zipfile.ZipInfo.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: ZipInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true
