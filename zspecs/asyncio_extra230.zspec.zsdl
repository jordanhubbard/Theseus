spec: asyncio_extra230
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html — asyncio Runners documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "asyncio.run.__name__ == 'run' — 3 characters; module is asyncio.runners; verified with Python 3.14.3."
    - "asyncio.run.__module__ == 'asyncio.runners' — top-level runner function; verified with Python 3.14.3."
    - "asyncio.run.__qualname__ == 'run' — simple top-level function; verified with Python 3.14.3."
    - "asyncio.gather.__name__ == 'gather' — 6 characters; module is asyncio.tasks; verified with Python 3.14.3."
    - "asyncio.create_task.__name__ == 'create_task' — 11 characters; module is asyncio.tasks; verified with Python 3.14.3."
    - "asyncio.sleep.__name__ == 'sleep' — 5 characters; module is asyncio.tasks; verified with Python 3.14.3."
    - "asyncio.wait.__name__ == 'wait' — 4 characters; module is asyncio.tasks; verified with Python 3.14.3."
    - "asyncio.ensure_future.__name__ == 'ensure_future' — 13 characters; module is asyncio.tasks; verified with Python 3.14.3."
    - "asyncio.shield.__name__ == 'shield' — 6 characters; module is asyncio.tasks; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.run function identity contracts — extra230 namespace
#
# asyncio.run.__name__ == 'run'; __module__ == 'asyncio.runners'.
# asyncio.gather/sleep/wait live in asyncio.tasks.
# ---------------------------------------------------------------------------

table asyncio_extra230.run_identity:
  description: "asyncio.run __name__, __module__, and __qualname__ contracts in aio230run namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio230run

  columns: [id, function, args, expected, description]
  rows:
    - [run_name_eq,      run.__name__.__eq__,      ["run"],             true, "asyncio.run.__name__ == 'run'; verified with Python 3.14.3"]
    - [run_name_len_3,   run.__name__.__len__,      [],                  3,    "asyncio.run.__name__.__len__() == 3 — 'run' has 3 characters; verified with Python 3.14.3"]
    - [run_module_eq,    run.__module__.__eq__,     ["asyncio.runners"], true, "asyncio.run.__module__ == 'asyncio.runners'; verified with Python 3.14.3"]
    - [run_qualname_eq,  run.__qualname__.__eq__,   ["run"],             true, "asyncio.run.__qualname__ == 'run'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio gather/create_task/sleep/wait function identity contracts — extra230
#
# All four functions live in asyncio.tasks; __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table asyncio_extra230.tasks_function_identity:
  description: "asyncio gather/create_task/sleep/wait __name__ and __module__ contracts in aio230tf namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio230tf

  columns: [id, function, args, expected, description]
  rows:
    - [gather_name_eq,        gather.__name__.__eq__,        ["gather"],        true, "asyncio.gather.__name__ == 'gather'; verified with Python 3.14.3"]
    - [gather_name_len_6,     gather.__name__.__len__,       [],                6,    "asyncio.gather.__name__.__len__() == 6 — 'gather' has 6 characters; verified with Python 3.14.3"]
    - [gather_module_eq,      gather.__module__.__eq__,      ["asyncio.tasks"], true, "asyncio.gather.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [gather_qualname_eq,    gather.__qualname__.__eq__,    ["gather"],        true, "asyncio.gather.__qualname__ == 'gather'; verified with Python 3.14.3"]
    - [create_task_name_eq,   create_task.__name__.__eq__,   ["create_task"],   true, "asyncio.create_task.__name__ == 'create_task'; verified with Python 3.14.3"]
    - [create_task_name_len,  create_task.__name__.__len__,  [],                11,   "asyncio.create_task.__name__.__len__() == 11 — 'create_task' has 11 characters; verified with Python 3.14.3"]
    - [create_task_module_eq, create_task.__module__.__eq__, ["asyncio.tasks"], true, "asyncio.create_task.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [sleep_name_eq,         sleep.__name__.__eq__,         ["sleep"],         true, "asyncio.sleep.__name__ == 'sleep'; verified with Python 3.14.3"]
    - [sleep_name_len_5,      sleep.__name__.__len__,        [],                5,    "asyncio.sleep.__name__.__len__() == 5 — 'sleep' has 5 characters; verified with Python 3.14.3"]
    - [sleep_module_eq,       sleep.__module__.__eq__,       ["asyncio.tasks"], true, "asyncio.sleep.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [wait_name_eq,          wait.__name__.__eq__,          ["wait"],          true, "asyncio.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [wait_module_eq,        wait.__module__.__eq__,        ["asyncio.tasks"], true, "asyncio.wait.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio ensure_future/shield function identity contracts — extra230 namespace
#
# Both live in asyncio.tasks; qualname equals name.
# ---------------------------------------------------------------------------

table asyncio_extra230.ensure_future_shield_identity:
  description: "asyncio ensure_future and shield __name__, __module__, __qualname__ contracts in aio230ef namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio230ef

  columns: [id, function, args, expected, description]
  rows:
    - [ensure_future_name_eq,     ensure_future.__name__.__eq__,     ["ensure_future"],  true, "asyncio.ensure_future.__name__ == 'ensure_future'; verified with Python 3.14.3"]
    - [ensure_future_name_len,    ensure_future.__name__.__len__,    [],                 13,   "asyncio.ensure_future.__name__.__len__() == 13 — 'ensure_future' has 13 characters; verified with Python 3.14.3"]
    - [ensure_future_module_eq,   ensure_future.__module__.__eq__,   ["asyncio.tasks"],  true, "asyncio.ensure_future.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [ensure_future_qualname_eq, ensure_future.__qualname__.__eq__, ["ensure_future"],  true, "asyncio.ensure_future.__qualname__ == 'ensure_future'; verified with Python 3.14.3"]
    - [shield_name_eq,            shield.__name__.__eq__,            ["shield"],         true, "asyncio.shield.__name__ == 'shield'; verified with Python 3.14.3"]
    - [shield_name_len_6,         shield.__name__.__len__,           [],                 6,    "asyncio.shield.__name__.__len__() == 6 — 'shield' has 6 characters; verified with Python 3.14.3"]
    - [shield_module_eq,          shield.__module__.__eq__,          ["asyncio.tasks"],  true, "asyncio.shield.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [shield_qualname_eq,        shield.__qualname__.__eq__,        ["shield"],         true, "asyncio.shield.__qualname__ == 'shield'; verified with Python 3.14.3"]
