spec: abc_extra149
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc module __dict__ membership checks and __spec__ identity. In Python 3.14.3, abc is a frozen module and does NOT have a __all__ attribute (abc.__all__ raises AttributeError); instead we use abc.__dict__.__contains__() to verify which names are in the abc namespace. abc.__dict__.__contains__('ABC')==True; abc.__dict__.__contains__('ABCMeta')==True; abc.__dict__.__contains__('abstractmethod')==True; abc.__dict__.__contains__('abstractclassmethod')==True (deprecated since Python 3.3 but still present); abc.__dict__.__contains__('get_cache_token')==True; abc.__dict__.__contains__('update_abstractmethods')==True; abc.__spec__.__class__.__name__=='ModuleSpec' (the module spec is a ModuleSpec object); abc.__spec__.name=='abc' (the spec's .name attribute is 'abc'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc has no __all__ in Python 3.14.3 — abc is a frozen module (abc.__spec__.origin=='frozen'); frozen modules do not define __all__; abc.__dict__.__contains__ is used instead to check namespace membership; abc.__dict__.__contains__.__class__.__name__=='builtin_function_or_method' (it is a C-level builtin function, same type as dict.__contains__ for all dicts); compare: abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (also a C-level builtin from _abc.c); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('abstractclassmethod')==True — abc.abstractclassmethod is deprecated since Python 3.3 (use @classmethod @abstractmethod instead) but it is still present in the abc namespace on Python 3.14.3; abstractclassmethod.__name__=='abstractclassmethod' (len=19; established in abc_extra148); abstractclassmethod.__bases__[0].__name__=='classmethod' (inherits from builtin classmethod; established in abc_extra148); its continued presence in the abc dict despite deprecation confirms backward compatibility is maintained; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__spec__.__class__.__name__=='ModuleSpec' — abc.__spec__ is an instance of importlib.machinery.ModuleSpec (type name 'ModuleSpec'); abc.__spec__.name=='abc' (the .name attribute of the spec is the string 'abc', len=3); abc.__spec__.origin=='frozen' (abc is loaded from the frozen module cache, not from a .py file on disk); abc.__spec__.__class__.__name__ is 'ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__dict__ membership checks — extra149
#
# abc.__dict__.__contains__('ABC')                == True
# abc.__dict__.__contains__('ABCMeta')            == True
# abc.__dict__.__contains__('abstractmethod')     == True
# abc.__dict__.__contains__('abstractclassmethod') == True
# ---------------------------------------------------------------------------

table abc_extra149.abc_dict_membership:
  description: "abc.__dict__ membership checks in abcdict149 namespace — abc.__dict__.__contains__('ABC')==True (ABC is the convenience base class for abstract classes; established in abc_extra147); abc.__dict__.__contains__('ABCMeta')==True (ABCMeta is the metaclass for abstract base classes; established in abc_extra147); abc.__dict__.__contains__('abstractmethod')==True (abstractmethod is the primary abstract method decorator; established in abc_extra147); abc.__dict__.__contains__('abstractclassmethod')==True (deprecated since Python 3.3 but still present in abc namespace on Python 3.14.3 — confirmed here; abstractclassmethod.__bases__[0].__name__=='classmethod'; abstractclassmethod.__name__.__len__()==19; use @classmethod @abstractmethod instead); abc.__dict__.__contains__('get_cache_token')==True (get_cache_token from the _abc C extension; established in abc_extra148); note: in Python 3.14.3, abc is a frozen module and does NOT define __all__ (abc.__all__ raises AttributeError); abc.__dict__.__contains__.__class__.__name__=='builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdict149

  columns: [id, function, args, expected, description]
  rows:
    - [abc_contains_eq,     abc.__dict__.__contains__,  ["ABC"],                true,  "abc.__dict__.__contains__('ABC') == True (ABC convenience base class is in abc namespace); verified with Python 3.14.3"]
    - [abcmeta_contains_eq, abc.__dict__.__contains__,  ["ABCMeta"],            true,  "abc.__dict__.__contains__('ABCMeta') == True (ABCMeta metaclass is in abc namespace); verified with Python 3.14.3"]
    - [absm_contains_eq,    abc.__dict__.__contains__,  ["abstractmethod"],     true,  "abc.__dict__.__contains__('abstractmethod') == True (abstractmethod decorator is in abc namespace); verified with Python 3.14.3"]
    - [abscls_contains_eq,  abc.__dict__.__contains__,  ["abstractclassmethod"], true, "abc.__dict__.__contains__('abstractclassmethod') == True (deprecated since Python 3.3 but still present in abc namespace on Python 3.14.3); verified with Python 3.14.3"]
    - [token_contains_eq,   abc.__dict__.__contains__,  ["get_cache_token"],    true,  "abc.__dict__.__contains__('get_cache_token') == True (C-level builtin from _abc extension); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__dict__ for update_abstractmethods and __contains__ type — extra149
#
# abc.__dict__.__contains__('update_abstractmethods')          == True
# abc.__dict__.__contains__.__class__.__name__.__eq__('builtin_function_or_method') == True
# ---------------------------------------------------------------------------

table abc_extra149.abc_dict_contains_identity:
  description: "abc.__dict__ additional membership and contains-function type checks in abcdictid149 namespace — abc.__dict__.__contains__('update_abstractmethods')==True (update_abstractmethods was added in Python 3.10; it recalculates __abstractmethods__ for a class, useful when methods are added after class creation; its presence confirms Python 3.10+ is in use); abc.__dict__.__contains__.__class__.__name__=='builtin_function_or_method' (len=26; abc.__dict__.__contains__ is the dict's C-level __contains__ method, a builtin_function_or_method; the same class name as abc.get_cache_token.__class__.__name__=='builtin_function_or_method'); abc.__spec__.__class__.__name__=='ModuleSpec' (len=10; the module spec for abc is a ModuleSpec object from importlib.machinery; ModuleSpec.__name__: 'Module'=6+'Spec'=4=10); abc.__name__.__eq__('abc')==True (abc.__name__ is the module name 'abc', len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdictid149

  columns: [id, function, args, expected, description]
  rows:
    - [updabsm_contains_eq, abc.__dict__.__contains__,                        ["update_abstractmethods"],       true,  "abc.__dict__.__contains__('update_abstractmethods') == True (added in Python 3.10); verified with Python 3.14.3"]
    - [contains_cls_eq,     abc.__dict__.__contains__.__class__.__name__.__eq__, ["builtin_function_or_method"],  true,  "abc.__dict__.__contains__.__class__.__name__ == 'builtin_function_or_method' (len=26; C-level dict.__contains__); verified with Python 3.14.3"]
    - [spec_cls_eq,         abc.__spec__.__class__.__name__.__eq__,            ["ModuleSpec"],                   true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; abc module spec is a ModuleSpec); verified with Python 3.14.3"]
    - [abc_name_eq,         abc.__name__.__eq__,                               ["abc"],                          true,  "abc.__name__ == 'abc' (len=3; the module's __name__ attribute); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc deprecated abstractclassmethod identity — extra149
#
# abc.abstractclassmethod.__name__.__eq__('abstractclassmethod') == True
# abc.abstractclassmethod.__module__.__eq__('abc')               == True
# ---------------------------------------------------------------------------

table abc_extra149.abc_abstractclassmethod_in_dict:
  description: "abc.abstractclassmethod presence and identity checks in abcdep149 namespace — abc.abstractclassmethod.__name__=='abstractclassmethod' (len=19; deprecated since Python 3.3; still accessible in abc namespace on Python 3.14.3 as confirmed by abc.__dict__.__contains__('abstractclassmethod')==True above); abc.abstractclassmethod.__module__=='abc' (len=3; defined in Lib/abc.py — its __module__ is 'abc' same as ABCMeta, ABC, and abstractmethod); abc.abstractclassmethod.__name__.__len__()==19 (established in abc_extra148: abstractclassmethod(19) > abstractproperty(16) > ABCMeta(7)); abc.abstractclassmethod.__bases__[0].__name__=='classmethod' (inherits from builtin classmethod; established in abc_extra148); its continued presence in abc __dict__ even in Python 3.14.3 (9 major versions after Python 3.3 deprecation) demonstrates Python's strong backward compatibility policy; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdep149

  columns: [id, function, args, expected, description]
  rows:
    - [abscls_name_eq,   abc.abstractclassmethod.__name__.__eq__,                          ["abstractclassmethod"],  true,  "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19; deprecated since Python 3.3 but still present); verified with Python 3.14.3"]
    - [abscls_mod_eq,    abc.abstractclassmethod.__module__.__eq__,                         ["abc"],                  true,  "abc.abstractclassmethod.__module__ == 'abc' (len=3; defined in Lib/abc.py); verified with Python 3.14.3"]
    - [abscls_name_len,  abc.abstractclassmethod.__name__.__len__,                          [],                       19,    "abc.abstractclassmethod.__name__.__len__() == 19 ('abstractclassmethod'); verified with Python 3.14.3"]
    - [abscls_base_eq,   "abc.abstractclassmethod.__bases__[0].__name__.__eq__",            ["classmethod"],          true,  "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod' (inherits from builtin classmethod); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra149
# ---------------------------------------------------------------------------

invariant abc_extra149.abc_dict_contains_ABC:
  description: "abc.__dict__.__contains__('ABC') returns True — abc.ABC is present in the abc module namespace; abc.__dict__.__contains__('ABC')==True; ABC is the convenience class for creating abstract base classes (introduced in Python 3.4 via PEP 3119); ABC.__name__=='ABC' (len=3); ABC.__module__=='abc'; ABC.__bases__[0].__name__=='object'; ABC.__class__.__name__=='ABCMeta' (all established in abc_extra147); the frozen module status of abc (abc.__spec__.origin=='frozen') does not prevent abc.__dict__.__contains__ from working — dict membership check works regardless; in Python 3.14.3, abc has no __all__ attribute (abc is frozen), so abc.__dict__.__contains__ is used instead to check namespace membership; NEW in extra149: first standalone abc.__dict__.__contains__('ABC') membership invariant in abcdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra149.abc_dict_contains_abstractclassmethod:
  description: "abc.__dict__.__contains__('abstractclassmethod') returns True — abc.abstractclassmethod is still present in the abc namespace on Python 3.14.3 despite being deprecated since Python 3.3; this confirms Python's backward compatibility: deprecated symbols are not removed for many versions after deprecation; abstractclassmethod.__name__=='abstractclassmethod' (len=19; established in abc_extra148); abstractclassmethod.__module__=='abc' (same module as ABCMeta, ABC, abstractmethod); abstractclassmethod.__bases__[0].__name__=='classmethod' (inherits from builtin classmethod); the modern replacement is stacking @classmethod with @abstractmethod; abc.__dict__.__contains__('abstractclassmethod')==True also implies abc.__dict__.__contains__('abstractproperty')==True and abc.__dict__.__contains__('abstractstaticmethod')==True (all three deprecated decorators remain); NEW in extra149: first standalone abc.__dict__.__contains__('abstractclassmethod') membership invariant in abcdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra149.abc_spec_class_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__ is an instance of importlib.machinery.ModuleSpec; its __class__.__name__ is 'ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); the ModuleSpec object describes how to load the abc module; abc.__spec__.name=='abc' (the .name attribute is the string 'abc', len=3); abc.__spec__.origin=='frozen' (abc is a frozen module, loaded from the frozen module cache rather than from a .py file on disk); the frozen origin explains why abc lacks __all__ (frozen modules may not include optional dunder attributes); abc.__spec__.__class__.__name__=='ModuleSpec' distinguishes the spec from the module itself (abc.__class__.__name__=='module'); NEW in extra149: first standalone abc.__spec__.__class__.__name__ identity invariant in abcdictid149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra149.abc_dict_contains_get_cache_token:
  description: "abc.__dict__.__contains__('get_cache_token') returns True — abc.get_cache_token is present in the abc namespace; get_cache_token is a C-level builtin from Modules/_abc.c (abc.get_cache_token.__module__=='_abc' and abc.get_cache_token.__class__.__name__=='builtin_function_or_method'; both established in abc_extra148); get_cache_token's presence in abc.__dict__ despite having __module__=='_abc' shows that the abc Python module re-exports symbols from its C backing module (_abc); abc.__dict__.__contains__('get_cache_token')==True; abc.__dict__.__contains__('update_abstractmethods')==True as well (update_abstractmethods added in Python 3.10); NEW in extra149: first standalone abc.__dict__.__contains__('get_cache_token') membership invariant in abcdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra149.abc_name_eq:
  description: "abc.__name__.__eq__('abc') returns True — abc.__name__ is the module's name string 'abc' (len=3); abc.__name__=='abc' is the module's __name__ attribute, the canonical name used in import statements; abc.__name__.__len__()==3; abc.__spec__.name=='abc' (the spec .name also equals 'abc'); abc.__name__ and abc.__spec__.name are both 'abc' confirming the module identity; abc.__name__.__class__.__name__=='str' (it is a plain string); compare: abc.__module__ does not apply at module level — abc.__name__ is the module-level identity attribute; abc.__name__=='abc' (same 3-char string as abc.__module__ for classes defined in abc: ABCMeta.__module__=='abc', ABC.__module__=='abc', abstractmethod.__module__=='abc'); NEW in extra149: first standalone abc.__name__ identity invariant in abcdictid149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["abc"]
  expected: true
