spec: numbers_extra15
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra through numbers_extra14."
    - "numbers_extra14 covers Complex.__add__/__mul__/__neg__/__abs__/__pow__, Real.__lt__/__le__/__floor__/__ceil__/__float__, Integral.__and__/__or__/__xor__/__invert__/__int__ qualname."
    - "No prior spec covers __qualname__ for Complex reverse/reflected operators: __radd__, __rmul__, __rsub__, __rtruediv__."
    - "No prior spec covers __qualname__ for Complex.__bool__ and Complex.__pos__."
    - "No prior spec covers __qualname__ for Rational.__float__ (defined directly on Rational, not inherited)."
    - "No prior spec covers __qualname__ for Integral.__lshift__ and Integral.__rshift__."
    - "All covered methods are defined directly on their respective ABC; qualname follows '<ClassName>.<method>'."
    - "Focus: Complex reflected operator and utility method __qualname__ values, plus Rational.__float__ and Integral shift operators."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Complex reflected operator __qualname__ values
#
# numbers_extra14 records qualname for the forward operators (__add__, __mul__,
# __neg__, __abs__, __pow__).  No prior spec records qualname for the reflected
# operators __radd__, __rmul__, __rsub__, __rtruediv__, or for the unary
# utility methods __bool__ and __pos__.  All are defined on Complex.
# ---------------------------------------------------------------------------

table numbers_extra15.complex_reflected_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [radd,     Complex.__radd__.__qualname__.__eq__,     ["Complex.__radd__"],     true, "numbers.Complex.__radd__.__qualname__ == 'Complex.__radd__'"]
    - [rmul,     Complex.__rmul__.__qualname__.__eq__,     ["Complex.__rmul__"],     true, "numbers.Complex.__rmul__.__qualname__ == 'Complex.__rmul__'"]
    - [rsub,     Complex.__rsub__.__qualname__.__eq__,     ["Complex.__rsub__"],     true, "numbers.Complex.__rsub__.__qualname__ == 'Complex.__rsub__'"]
    - [rtruediv, Complex.__rtruediv__.__qualname__.__eq__, ["Complex.__rtruediv__"], true, "numbers.Complex.__rtruediv__.__qualname__ == 'Complex.__rtruediv__'"]
    - [bool,     Complex.__bool__.__qualname__.__eq__,     ["Complex.__bool__"],     true, "numbers.Complex.__bool__.__qualname__ == 'Complex.__bool__'"]
    - [pos,      Complex.__pos__.__qualname__.__eq__,      ["Complex.__pos__"],      true, "numbers.Complex.__pos__.__qualname__ == 'Complex.__pos__'"]

# ---------------------------------------------------------------------------
# Rational.__float__ __qualname__
#
# numbers.Rational defines __float__ directly (not inherited from a base ABC);
# its qualname is 'Rational.__float__'.  No prior spec records this.
# ---------------------------------------------------------------------------

invariant numbers_extra15.Rational.float_qualname:
  description: "numbers.Rational.__float__.__qualname__ == 'Rational.__float__' — defined directly on Rational"
  category: method_identity
  kind: python_call_eq
  function: Rational.__float__.__qualname__.__eq__
  args: ["Rational.__float__"]
  expected: true

# ---------------------------------------------------------------------------
# Integral shift operator __qualname__ values
#
# numbers_extra14 covers Integral.__and__, __or__, __xor__, __invert__, __int__.
# No prior spec covers __lshift__ and __rshift__, which are also abstract
# methods defined directly on Integral.
# ---------------------------------------------------------------------------

table numbers_extra15.integral_shift_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [lshift, Integral.__lshift__.__qualname__.__eq__, ["Integral.__lshift__"], true, "numbers.Integral.__lshift__.__qualname__ == 'Integral.__lshift__'"]
    - [rshift, Integral.__rshift__.__qualname__.__eq__, ["Integral.__rshift__"], true, "numbers.Integral.__rshift__.__qualname__ == 'Integral.__rshift__'"]

# ---------------------------------------------------------------------------
# Method __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant numbers_extra15.Complex.radd.qualname_len:
  description: "len(numbers.Complex.__radd__.__qualname__) == 16 — 'Complex.__radd__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Complex.__radd__.__qualname__.__len__
  args: []
  expected: 16

invariant numbers_extra15.Complex.rtruediv.qualname_len:
  description: "len(numbers.Complex.__rtruediv__.__qualname__) == 20 — 'Complex.__rtruediv__' is 20 chars"
  category: method_identity
  kind: python_call_eq
  function: Complex.__rtruediv__.__qualname__.__len__
  args: []
  expected: 20

invariant numbers_extra15.Rational.float.qualname_len:
  description: "len(numbers.Rational.__float__.__qualname__) == 18 — 'Rational.__float__' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: Rational.__float__.__qualname__.__len__
  args: []
  expected: 18

invariant numbers_extra15.Integral.lshift.qualname_len:
  description: "len(numbers.Integral.__lshift__.__qualname__) == 19 — 'Integral.__lshift__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Integral.__lshift__.__qualname__.__len__
  args: []
  expected: 19

invariant numbers_extra15.Integral.rshift.qualname_len:
  description: "len(numbers.Integral.__rshift__.__qualname__) == 19 — 'Integral.__rshift__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Integral.__rshift__.__qualname__.__len__
  args: []
  expected: 19
