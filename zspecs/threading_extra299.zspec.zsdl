spec: threading_extra299
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread class identity
#
# threading.Thread is the base thread class.
# __name__ == 'Thread', __module__ == 'threading', __bases__[0] == object.
# ---------------------------------------------------------------------------

invariant threading_extra299.Thread.name:
  description: "threading.Thread.__name__ == 'Thread'"
  category: Thread
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra299.Thread.module:
  description: "threading.Thread.__module__ == 'threading'"
  category: Thread
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra299.Thread.base_is_object:
  description: "threading.Thread.__bases__[0].__name__ == 'object'"
  category: Thread
  kind: python_call_eq
  function: Thread.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Timer class identity
#
# threading.Timer is a subclass of Thread.
# __bases__[0].__name__ == 'Thread'.
# ---------------------------------------------------------------------------

invariant threading_extra299.Timer.name:
  description: "threading.Timer.__name__ == 'Timer'"
  category: Timer
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra299.Timer.module:
  description: "threading.Timer.__module__ == 'threading'"
  category: Timer
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra299.Timer.base_is_Thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer extends Thread"
  category: Timer
  kind: python_call_eq
  function: Timer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Thread"

# ---------------------------------------------------------------------------
# threading.local identity
#
# threading.local is actually _thread.local (a C-level type).
# Its __name__ is '_local' and __module__ is '_thread'.
# ---------------------------------------------------------------------------

invariant threading_extra299.local.name:
  description: "threading.local.__name__ == '_local' — the underlying C type name"
  category: local
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra299.local.module:
  description: "threading.local.__module__ == '_thread' — local comes from C extension _thread"
  category: local
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# Barrier class identity
#
# threading.Barrier is a pure-Python class defined in threading.
# __bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant threading_extra299.Barrier.name:
  description: "threading.Barrier.__name__ == 'Barrier'"
  category: Barrier
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra299.Barrier.module:
  description: "threading.Barrier.__module__ == 'threading'"
  category: Barrier
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra299.Barrier.base_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object'"
  category: Barrier
  kind: python_call_eq
  function: Barrier.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# BrokenBarrierError class identity
#
# threading.BrokenBarrierError is a subclass of RuntimeError.
# __module__ == 'threading', __bases__[0].__name__ == 'RuntimeError'.
# ---------------------------------------------------------------------------

invariant threading_extra299.BrokenBarrierError.name:
  description: "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError'"
  category: BrokenBarrierError
  kind: python_call_eq
  function: BrokenBarrierError.__name__.__eq__
  args: ["BrokenBarrierError"]
  expected: true

invariant threading_extra299.BrokenBarrierError.module:
  description: "threading.BrokenBarrierError.__module__ == 'threading'"
  category: BrokenBarrierError
  kind: python_call_eq
  function: BrokenBarrierError.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra299.BrokenBarrierError.base_is_RuntimeError:
  description: "threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError'"
  category: BrokenBarrierError
  kind: python_call_eq
  function: BrokenBarrierError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RuntimeError"

# ---------------------------------------------------------------------------
# current_thread and main_thread module identity
#
# Both are Python-level functions defined in the threading module.
# __module__ == 'threading' for both.
# ---------------------------------------------------------------------------

invariant threading_extra299.current_thread.module:
  description: "threading.current_thread.__module__ == 'threading'"
  category: thread_functions
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra299.main_thread.module:
  description: "threading.main_thread.__module__ == 'threading'"
  category: thread_functions
  kind: python_call_eq
  function: main_thread.__module__.__eq__
  args: ["threading"]
  expected: true
