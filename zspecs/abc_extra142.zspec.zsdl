spec: abc_extra142
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.abstractclassmethod — abstractclassmethod documentation"
    - "https://docs.python.org/3/library/abc.html#abc.abstractstaticmethod — abstractstaticmethod documentation"
    - "https://docs.python.org/3/library/abc.html#abc.abstractproperty — abstractproperty documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers the deprecated abstract decorator classes in abc. abc.abstractclassmethod.__name__=='abstractclassmethod' (len=19); __module__=='abc' (len=3); __doc__.__len__()==236; __bases__[0].__name__=='classmethod' (len=11); __mro__.__len__()==3. abc.abstractstaticmethod.__name__=='abstractstaticmethod' (len=20: the longest class name in this spec); __module__=='abc' (len=3); __doc__.__len__()==235; __bases__[0].__name__=='staticmethod' (len=12); __mro__.__len__()==3. abc.abstractproperty.__name__=='abstractproperty' (len=16: the shortest deprecated decorator name); __module__=='abc' (len=3); __doc__.__len__()==221; __bases__[0].__name__=='property' (len=8); __mro__.__len__()==3. Also covers abc module identity: abc.__name__=='abc' (len=3); abc.__doc__.__len__()==51; abc.__spec__.name=='abc' (len=3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All three deprecated decorator classes have __module__=='abc' (len=3) and __mro__.__len__()==3 (each class -> its builtin base -> object). abstractstaticmethod has the longest __name__ (len=20) and longest base class name (staticmethod, len=12). abstractproperty has the shortest __name__ (len=16) and shortest base (property, len=8). abstractclassmethod is in the middle (len=19, base classmethod len=11). All __doc__ lengths are between 221 and 236 — close in size. abc.__doc__ is 'Abstract Base Classes (ABCs) according to PEP 3119.' (len=51). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractclassmethod identity — extra142
#
# abc.abstractclassmethod.__name__              == 'abstractclassmethod' (len=19)
# abc.abstractclassmethod.__module__            == 'abc'                 (len=3)
# abc.abstractclassmethod.__doc__.__len__()     == 236
# abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod'        (len=11)
# abc.abstractclassmethod.__mro__.__len__()     == 3
# ---------------------------------------------------------------------------

table abc_extra142.abstractclassmethod_identity:
  description: "abc.abstractclassmethod class identity checks — abstractclassmethod.__name__.__eq__('abstractclassmethod')==True (len=19: 'abstractclassmethod'=19; the name equals the __qualname__ since it is a top-level class; 1 shorter than abstractstaticmethod at 20, 3 longer than abstractproperty at 16); abstractclassmethod.__module__.__eq__('abc')==True (len=3: all three deprecated abstract decorator classes are defined in the pure-Python 'abc' module); abstractclassmethod.__doc__.__len__()==236 (the longest doc of the three deprecated decorator classes; the doc describes the class as a combined abstract and classmethod decorator, deprecated since Python 3.3); abstractclassmethod.__bases__[0].__name__.__eq__('classmethod')==True (len=11: abstractclassmethod inherits from the builtin classmethod); abstractclassmethod.__mro__.__len__()==3 (abstractclassmethod -> classmethod -> object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcacm142

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    abc.abstractclassmethod.__name__.__eq__,              ["abstractclassmethod"],  true,  "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19); verified with Python 3.14.3"]
    - [name_len,   abc.abstractclassmethod.__name__.__len__,              [],                       19,    "abc.abstractclassmethod.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [mod_eq,     abc.abstractclassmethod.__module__.__eq__,            ["abc"],                   true,  "abc.abstractclassmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len,    abc.abstractclassmethod.__module__.__len__,            [],                       3,     "abc.abstractclassmethod.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [doc_len,    abc.abstractclassmethod.__doc__.__len__,               [],                       236,   "abc.abstractclassmethod.__doc__.__len__() == 236 (longest deprecated decorator doc); verified with Python 3.14.3"]
    - [mro_len,    abc.abstractclassmethod.__mro__.__len__,               [],                       3,     "abc.abstractclassmethod.__mro__.__len__() == 3 (abstractclassmethod -> classmethod -> object); verified with Python 3.14.3"]
    - [base_eq,    "abc.abstractclassmethod.__bases__[0].__name__.__eq__", ["classmethod"],         true,  "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod' (len=11); verified with Python 3.14.3"]
    - [base_len,   "abc.abstractclassmethod.__bases__[0].__name__.__len__", [],                     11,    "abc.abstractclassmethod.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod identity — extra142
#
# abc.abstractstaticmethod.__name__              == 'abstractstaticmethod' (len=20)
# abc.abstractstaticmethod.__module__            == 'abc'                  (len=3)
# abc.abstractstaticmethod.__doc__.__len__()     == 235
# abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'         (len=12)
# abc.abstractstaticmethod.__mro__.__len__()     == 3
# ---------------------------------------------------------------------------

table abc_extra142.abstractstaticmethod_identity:
  description: "abc.abstractstaticmethod class identity checks — abstractstaticmethod.__name__.__eq__('abstractstaticmethod')==True (len=20: 'abstractstaticmethod'=20; the longest class name in this spec; 1 more than abstractclassmethod at 19, 4 more than abstractproperty at 16); abstractstaticmethod.__module__.__eq__('abc')==True (len=3: same module as all three deprecated abstract decorator classes); abstractstaticmethod.__doc__.__len__()==235 (1 less than abstractclassmethod at 236; 14 more than abstractproperty at 221); abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod')==True (len=12: the longest base class name in this spec; 'staticmethod' is 1 longer than 'classmethod'=11 and 4 longer than 'property'=8); abstractstaticmethod.__mro__.__len__()==3 (abstractstaticmethod -> staticmethod -> object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcasm142

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    abc.abstractstaticmethod.__name__.__eq__,              ["abstractstaticmethod"],  true,  "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20); verified with Python 3.14.3"]
    - [name_len,   abc.abstractstaticmethod.__name__.__len__,              [],                        20,    "abc.abstractstaticmethod.__name__.__len__() == 20 (longest in this spec); verified with Python 3.14.3"]
    - [mod_eq,     abc.abstractstaticmethod.__module__.__eq__,            ["abc"],                    true,  "abc.abstractstaticmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [doc_len,    abc.abstractstaticmethod.__doc__.__len__,               [],                        235,   "abc.abstractstaticmethod.__doc__.__len__() == 235; verified with Python 3.14.3"]
    - [mro_len,    abc.abstractstaticmethod.__mro__.__len__,               [],                        3,     "abc.abstractstaticmethod.__mro__.__len__() == 3 (abstractstaticmethod -> staticmethod -> object); verified with Python 3.14.3"]
    - [base_eq,    "abc.abstractstaticmethod.__bases__[0].__name__.__eq__", ["staticmethod"],         true,  "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' (len=12); verified with Python 3.14.3"]
    - [base_len,   "abc.abstractstaticmethod.__bases__[0].__name__.__len__", [],                      12,    "abc.abstractstaticmethod.__bases__[0].__name__.__len__() == 12 (longest base name in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractproperty identity and abc module attributes — extra142
#
# abc.abstractproperty.__name__              == 'abstractproperty' (len=16)
# abc.abstractproperty.__module__            == 'abc'              (len=3)
# abc.abstractproperty.__doc__.__len__()     == 221
# abc.abstractproperty.__bases__[0].__name__ == 'property'         (len=8)
# abc.abstractproperty.__mro__.__len__()     == 3
# abc.__name__                               == 'abc'              (len=3)
# abc.__doc__.__len__()                      == 51
# abc.__spec__.name                          == 'abc'              (len=3)
# ---------------------------------------------------------------------------

table abc_extra142.abstractproperty_and_module_identity:
  description: "abc.abstractproperty identity and abc module attribute checks — abstractproperty.__name__.__eq__('abstractproperty')==True (len=16: 'abstractproperty'=16; the shortest class name in this spec; 3 shorter than abstractclassmethod=19, 4 shorter than abstractstaticmethod=20); abstractproperty.__module__.__eq__('abc')==True (len=3: same module as both other deprecated abstract decorator classes); abstractproperty.__doc__.__len__()==221 (the shortest doc of the three deprecated decorator classes; 15 less than abstractclassmethod=236, 14 less than abstractstaticmethod=235); abstractproperty.__bases__[0].__name__.__eq__('property')==True (len=8: the shortest base class name in this spec; 3 shorter than classmethod=11, 4 shorter than staticmethod=12); abstractproperty.__mro__.__len__()==3 (abstractproperty -> property -> object); abc.__name__.__eq__('abc')==True (len=3: module name equals __spec__.name); abc.__doc__.__len__()==51 (doc is 'Abstract Base Classes (ABCs) according to PEP 3119.'); abc.__spec__.name.__eq__('abc')==True (len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcap142

  columns: [id, function, args, expected, description]
  rows:
    - [ap_name_eq,    abc.abstractproperty.__name__.__eq__,              ["abstractproperty"],  true,  "abc.abstractproperty.__name__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_name_len,   abc.abstractproperty.__name__.__len__,              [],                    16,    "abc.abstractproperty.__name__.__len__() == 16 (shortest in this spec); verified with Python 3.14.3"]
    - [ap_mod_eq,     abc.abstractproperty.__module__.__eq__,            ["abc"],                true,  "abc.abstractproperty.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [ap_doc_len,    abc.abstractproperty.__doc__.__len__,               [],                    221,   "abc.abstractproperty.__doc__.__len__() == 221 (shortest deprecated decorator doc); verified with Python 3.14.3"]
    - [ap_mro_len,    abc.abstractproperty.__mro__.__len__,               [],                    3,     "abc.abstractproperty.__mro__.__len__() == 3 (abstractproperty -> property -> object); verified with Python 3.14.3"]
    - [ap_base_eq,    "abc.abstractproperty.__bases__[0].__name__.__eq__", ["property"],         true,  "abc.abstractproperty.__bases__[0].__name__ == 'property' (len=8); verified with Python 3.14.3"]
    - [ap_base_len,   "abc.abstractproperty.__bases__[0].__name__.__len__", [],                  8,     "abc.abstractproperty.__bases__[0].__name__.__len__() == 8 (shortest base name in this spec); verified with Python 3.14.3"]
    - [mod_nm_eq,     abc.__name__.__eq__,                               ["abc"],                true,  "abc.__name__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_nm_len,    abc.__name__.__len__,                               [],                    3,     "abc.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [mod_doc_len,   abc.__doc__.__len__,                                [],                    51,    "abc.__doc__.__len__() == 51 ('Abstract Base Classes (ABCs) according to PEP 3119.'); verified with Python 3.14.3"]
    - [spec_nm_eq,    abc.__spec__.name.__eq__,                          ["abc"],                true,  "abc.__spec__.name == 'abc' (len=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra142
# ---------------------------------------------------------------------------

invariant abc_extra142.abstractclassmethod_name_len_19:
  description: "abc.abstractclassmethod.__name__.__len__() == 19 — abc.abstractclassmethod.__name__ is 'abstractclassmethod' (19 chars); this is 1 less than abstractstaticmethod (20) and 3 more than abstractproperty (16); abstractclassmethod.__module__=='abc' (len=3); __bases__[0].__name__=='classmethod' (len=11); __mro__.__len__()==3; __doc__.__len__()==236 (longest deprecated decorator doc in this spec); deprecated since Python 3.3 in favor of combining abstractmethod with classmethod; NEW in extra142: first standalone abstractclassmethod name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractclassmethod.__name__.__len__
  args: []
  expected: 19

invariant abc_extra142.abstractstaticmethod_name_len_20:
  description: "abc.abstractstaticmethod.__name__.__len__() == 20 — abc.abstractstaticmethod.__name__ is 'abstractstaticmethod' (20 chars: the longest class name in this spec; 1 more than abstractclassmethod=19, 4 more than abstractproperty=16); abstractstaticmethod.__module__=='abc' (len=3); __bases__[0].__name__=='staticmethod' (len=12: the longest base name in this spec); __mro__.__len__()==3; __doc__.__len__()==235; deprecated since Python 3.3 in favor of combining abstractmethod with staticmethod; NEW in extra142: first standalone abstractstaticmethod name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractstaticmethod.__name__.__len__
  args: []
  expected: 20

invariant abc_extra142.abstractproperty_name_len_16:
  description: "abc.abstractproperty.__name__.__len__() == 16 — abc.abstractproperty.__name__ is 'abstractproperty' (16 chars: the shortest class name in this spec; 3 less than abstractclassmethod=19, 4 less than abstractstaticmethod=20); abstractproperty.__module__=='abc' (len=3); __bases__[0].__name__=='property' (len=8: the shortest base name in this spec); __mro__.__len__()==3; __doc__.__len__()==221 (shortest deprecated decorator doc); deprecated since Python 3.3 in favor of combining abstractmethod with property; NEW in extra142: first standalone abstractproperty name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__name__.__len__
  args: []
  expected: 16

invariant abc_extra142.abstractclassmethod_doc_len_236:
  description: "abc.abstractclassmethod.__doc__.__len__() == 236 — abc.abstractclassmethod.__doc__ is a 236-char doc (the longest of the three deprecated abstract decorator docs in this spec; 1 more than abstractstaticmethod=235, 15 more than abstractproperty=221); the doc describes this as a subclass of classmethod with the abstractmethod decorator applied, deprecated since Python 3.3; abstractclassmethod.__name__=='abstractclassmethod' (len=19); __bases__[0].__name__=='classmethod' (len=11); __mro__.__len__()==3; NEW in extra142: first standalone abstractclassmethod doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractclassmethod.__doc__.__len__
  args: []
  expected: 236

invariant abc_extra142.abstractstaticmethod_doc_len_235:
  description: "abc.abstractstaticmethod.__doc__.__len__() == 235 — abc.abstractstaticmethod.__doc__ is a 235-char doc (1 less than abstractclassmethod=236, 14 more than abstractproperty=221); the doc describes this as a subclass of staticmethod with abstractmethod applied, deprecated since Python 3.3; abstractstaticmethod.__name__=='abstractstaticmethod' (len=20: the longest class name in this spec); __bases__[0].__name__=='staticmethod' (len=12: the longest base name); __mro__.__len__()==3; NEW in extra142: first standalone abstractstaticmethod doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractstaticmethod.__doc__.__len__
  args: []
  expected: 235

invariant abc_extra142.abstractproperty_doc_len_221:
  description: "abc.abstractproperty.__doc__.__len__() == 221 — abc.abstractproperty.__doc__ is a 221-char doc (the shortest of the three deprecated abstract decorator docs in this spec; 14 less than abstractstaticmethod=235, 15 less than abstractclassmethod=236); abstractproperty.__name__=='abstractproperty' (len=16: the shortest class name in this spec); __bases__[0].__name__=='property' (len=8: the shortest base name); __mro__.__len__()==3; deprecated since Python 3.3 in favor of combining abstractmethod with property; NEW in extra142: first standalone abstractproperty doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__doc__.__len__
  args: []
  expected: 221

invariant abc_extra142.abc_module_doc_len_51:
  description: "abc.__doc__.__len__() == 51 — abc.__doc__ is 'Abstract Base Classes (ABCs) according to PEP 3119.' (51 chars: a terse single-sentence module doc referencing the governing PEP); abc.__name__=='abc' (len=3); abc.__spec__.name=='abc' (len=3: matches __name__); compare abc.ABCMeta.__doc__.__len__()==576 (much longer class doc covered in extra140); this is the module-level docstring, much shorter than any of the class docs; NEW in extra142: first standalone abc module __doc__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__doc__.__len__
  args: []
  expected: 51

invariant abc_extra142.abstractstaticmethod_base_len_12:
  description: "abc.abstractstaticmethod.__bases__[0].__name__.__len__() == 12 — abc.abstractstaticmethod.__bases__[0].__name__ is 'staticmethod' (12 chars: the longest base class name in this spec; compare classmethod=11, property=8); abstractstaticmethod inherits from the builtin staticmethod descriptor; __mro__.__len__()==3 (abstractstaticmethod -> staticmethod -> object); abstractstaticmethod.__name__=='abstractstaticmethod' (len=20); __doc__.__len__()==235; NEW in extra142: first standalone abstractstaticmethod base class name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.abstractstaticmethod.__bases__[0].__name__.__len__"
  args: []
  expected: 12
