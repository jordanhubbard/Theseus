spec: threading_extra251
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Timer and threading.local class identity, and threading.currentThread function identity behavioral contracts."
    - "threading.Timer.__name__ == 'Timer' — Timer is a pure-Python Thread subclass; its __name__ is 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread directly; __bases__[0].__name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.local.__name__ == '_local' — the threading.local alias resolves to _thread._local; its __name__ is '_local'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — the underlying implementation is in the _thread C extension; __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object' — _local inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "threading.local.__class__.__name__ == 'type' — threading.local is a type (class); __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "threading.currentThread.__name__ == 'currentThread' — currentThread is a deprecated alias function; its __name__ is 'currentThread'. Verified with Python 3.14.3."
    - "threading.currentThread.__module__ == 'threading' — currentThread is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.currentThread.__class__.__name__ == 'function' — currentThread is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer class identity
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__bases__[0].__name__ == 'Thread'
#
# Timer is a pure-Python Thread subclass that calls a function after a delay.
# New to extra251.
# ---------------------------------------------------------------------------

table threading_extra251.timer_class_identity:
  description: "threading.Timer class __name__, __module__, __bases__[0].__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: timer251cls

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a Thread subclass for delayed function calls; __name__ is 'Timer'; new to extra251"]
    - [timer_module_eq,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in the threading module; __module__ is 'threading'; new to extra251"]
    - [timer_bases0_name_eq,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits directly from Thread; __bases__[0].__name__ is 'Thread'; new to extra251"]
    - [timer_name_len_5,
       Timer.__name__.__len__,
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters; new to extra251"]
    - [timer_module_len_9,
       Timer.__module__.__len__,
       [],
       9,
       "threading.Timer.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Table 2: threading.local class identity
#
# threading.local.__name__ == '_local'
# threading.local.__module__ == '_thread'
# threading.local.__bases__[0].__name__ == 'object'
# threading.local.__class__.__name__ == 'type'
#
# threading.local is an alias for _thread._local, a C-level type implementing
# thread-local storage. Its __name__ is '_local' and __module__ is '_thread'.
# New to extra251.
# ---------------------------------------------------------------------------

table threading_extra251.local_class_identity:
  description: "threading.local class __name__, __module__, __bases__[0].__name__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: local251cls

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq,
       local.__name__.__eq__,
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local resolves to _thread._local; the C-level type's __name__ is '_local'; new to extra251"]
    - [local_module_eq,
       local.__module__.__eq__,
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — the implementation lives in the _thread C extension; __module__ is '_thread'; new to extra251"]
    - [local_bases0_name_eq,
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — _local inherits directly from object; __bases__[0].__name__ is 'object'; new to extra251"]
    - [local_class_name_eq,
       local.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — threading.local is a type (class); __class__.__name__ is 'type'; new to extra251"]
    - [local_module_len_7,
       local.__module__.__len__,
       [],
       7,
       "threading.local.__module__.__len__() == 7 — '_thread' has 7 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Table 3: threading.currentThread function identity
#
# threading.currentThread.__name__ == 'currentThread'
# threading.currentThread.__module__ == 'threading'
# threading.currentThread.__class__.__name__ == 'function'
#
# currentThread is a deprecated alias for current_thread, a plain Python
# function in the threading module. New to extra251.
# ---------------------------------------------------------------------------

table threading_extra251.currentthread_identity:
  description: "threading.currentThread __name__, __module__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: currt251

  columns: [id, function, args, expected, description]
  rows:
    - [currt_name_eq,
       currentThread.__name__.__eq__,
       ["currentThread"],
       true,
       "threading.currentThread.__name__.__eq__('currentThread') == True — currentThread is a deprecated alias function; __name__ is 'currentThread'; new to extra251"]
    - [currt_module_eq,
       currentThread.__module__.__eq__,
       ["threading"],
       true,
       "threading.currentThread.__module__.__eq__('threading') == True — currentThread is defined in the threading module; __module__ is 'threading'; new to extra251"]
    - [currt_class_name_eq,
       currentThread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.currentThread.__class__.__name__.__eq__('function') == True — currentThread is a plain Python function; __class__.__name__ is 'function'; new to extra251"]
    - [currt_name_len_13,
       currentThread.__name__.__len__,
       [],
       13,
       "threading.currentThread.__name__.__len__() == 13 — 'currentThread' has 13 characters; new to extra251"]
    - [currt_module_len_9,
       currentThread.__module__.__len__,
       [],
       9,
       "threading.currentThread.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra251
# ---------------------------------------------------------------------------

invariant threading_extra251.Timer.name_eq:
  description: "threading.Timer.__name__ == 'Timer' — Thread subclass for delayed calls; new to extra251"
  category: identity
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra251.Timer.module_eq:
  description: "threading.Timer.__module__ == 'threading' — defined in the threading module; new to extra251"
  category: identity
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra251.Timer.bases0_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits directly from Thread; new to extra251"
  category: identity
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra251.Timer.name_len_5:
  description: "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: Timer.__name__.__len__
  args: []
  expected: 5

invariant threading_extra251.local.name_eq:
  description: "threading.local.__name__ == '_local' — the underlying C type's __name__ is '_local'; new to extra251"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra251.local.module_eq:
  description: "threading.local.__module__ == '_thread' — implemented in the _thread C extension; new to extra251"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra251.local.bases0_is_object:
  description: "threading.local.__bases__[0].__name__ == 'object' — _local inherits directly from object; new to extra251"
  category: identity
  kind: python_call_eq
  function: "local.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra251.local.class_is_type:
  description: "threading.local.__class__.__name__ == 'type' — threading.local is a type object; new to extra251"
  category: identity
  kind: python_call_eq
  function: local.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra251.currentThread.name_eq:
  description: "threading.currentThread.__name__ == 'currentThread' — deprecated alias function; new to extra251"
  category: identity
  kind: python_call_eq
  function: currentThread.__name__.__eq__
  args: ["currentThread"]
  expected: true

invariant threading_extra251.currentThread.module_eq:
  description: "threading.currentThread.__module__ == 'threading' — defined in the threading module; new to extra251"
  category: identity
  kind: python_call_eq
  function: currentThread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra251.currentThread.class_is_function:
  description: "threading.currentThread.__class__.__name__ == 'function' — currentThread is a plain Python function; new to extra251"
  category: identity
  kind: python_call_eq
  function: currentThread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra251.currentThread.name_len_13:
  description: "threading.currentThread.__name__.__len__() == 13 — 'currentThread' has 13 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: currentThread.__name__.__len__
  args: []
  expected: 13
