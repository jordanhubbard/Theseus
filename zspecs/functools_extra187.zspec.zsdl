spec: functools_extra187
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.singledispatch and functools.singledispatchmethod identity — functools.singledispatch.__name__=='singledispatch' (len=14); functools.singledispatch.__module__=='functools'; functools.singledispatch.__qualname__=='singledispatch' (len=14, equals __name__); functools.singledispatchmethod.__name__=='singledispatchmethod' (len=20); functools.singledispatchmethod.__module__=='functools'; functools.singledispatchmethod.__qualname__=='singledispatchmethod'; functools.singledispatch.__class__.__name__=='function'; functools.singledispatchmethod.__bases__[0].__name__=='object' (singledispatchmethod is a class, not a function)."
    - "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a decorator factory defined as a Python function in Lib/functools.py that enables simple overloading on the type of the first argument; its __name__ is 'singledispatch', 14 characters. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in the pure-Python functools module (Lib/functools.py); its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — singledispatch is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'singledispatch', 14 characters. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is implemented as a regular Python function (not a class), so its __class__ is the built-in 'function' type. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — singledispatchmethod is a descriptor class in Lib/functools.py that enables single-dispatch on instance methods (the dispatch is on the type of the first non-self argument); its __name__ is 'singledispatchmethod', 20 characters. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' — singledispatchmethod is defined in the pure-Python functools module; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' — singledispatchmethod is a module-level class (not nested), so its __qualname__ equals its __name__ 'singledispatchmethod', 20 characters. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod is a descriptor class that directly subclasses object (not function), which is how it can be used as a non-data descriptor on class instances. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch __name__, __module__, __qualname__
#
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__name__.__len__() == 14
# functools.singledispatch.__module__ == 'functools'
# functools.singledispatch.__qualname__ == 'singledispatch'
#
# functools.singledispatch is a decorator factory (a regular Python function)
# in Lib/functools.py that transforms a function into a single-dispatch
# generic function. Its __name__ is 'singledispatch' (14 chars). New to extra187.
# ---------------------------------------------------------------------------

table functools_extra187.singledispatch_identity:
  description: "functools.singledispatch.__name__ 'singledispatch' len 14; __module__ 'functools'; __qualname__ 'singledispatch' equals __name__; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: functsingledis187

  columns: [id, function, args, expected, description]
  rows:
    - [sdispatch_name_eq,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a decorator factory in Lib/functools.py that transforms a function into a single-dispatch generic function dispatching on the type of the first argument; its __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra187"]
    - [sdispatch_name_len_14,
       singledispatch.__name__.__len__,
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — the name 'singledispatch' has exactly 14 characters: s-i-n-g-l-e-d-i-s-p-a-t-c-h; str.__len__() returns 14; new to extra187"]
    - [sdispatch_module_eq,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in the pure-Python functools module (Lib/functools.py), not the C extension _functools; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra187"]
    - [sdispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a module-level Python function (not nested or a method), so its __qualname__ equals its __name__ 'singledispatch' (14 chars); str.__eq__('singledispatch') returns True; new to extra187"]

