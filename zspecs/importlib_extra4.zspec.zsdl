spec: importlib_extra4
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
  notes:
    - "This spec extends importlib.zspec.zsdl, importlib_abc.zspec.zsdl, importlib_extra.zspec.zsdl, importlib_extra2.zspec.zsdl, importlib_extra3.zspec.zsdl, importlib_machinery.zspec.zsdl, importlib_metadata.zspec.zsdl, importlib_resources.zspec.zsdl, and importlib_util.zspec.zsdl."
    - "Focus: __qualname__ and __module__ for import_module, reload, invalidate_caches; module-level __name__, __package__, and __spec__ class name."
    - "importlib.__spec__ is a ModuleSpec instance (set by the import system); its class name is 'ModuleSpec'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level identity attributes
# ---------------------------------------------------------------------------

invariant importlib_extra4.module.name:
  description: "importlib.__name__ == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["importlib"]
  expected: true

invariant importlib_extra4.module.package:
  description: "importlib.__package__ == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["importlib"]
  expected: true

invariant importlib_extra4.module.spec_class:
  description: "importlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — import_module, reload, invalidate_caches
# ---------------------------------------------------------------------------

table importlib_extra4.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [import_module,      import_module.__qualname__.__eq__,      ["import_module"],      true]
    - [reload,             reload.__qualname__.__eq__,             ["reload"],             true]
    - [invalidate_caches,  invalidate_caches.__qualname__.__eq__,  ["invalidate_caches"],  true]

# ---------------------------------------------------------------------------
# __module__ checks — import_module, reload
# ---------------------------------------------------------------------------

invariant importlib_extra4.import_module.module_attr:
  description: "importlib.import_module.__module__ == 'importlib'"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__module__.__eq__
  args: ["importlib"]
  expected: true

invariant importlib_extra4.reload.module_attr:
  description: "importlib.reload.__module__ == 'importlib'"
  category: function_attrs
  kind: python_call_eq
  function: reload.__module__.__eq__
  args: ["importlib"]
  expected: true
