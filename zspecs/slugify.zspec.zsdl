spec: slugify
version: ">=1.6.0"
backend: node(slugify)

docs: https://www.npmjs.com/package/slugify

provenance:
  derived_from:
    - "slugify README — https://www.npmjs.com/package/slugify"
    - "Test vectors verified with slugify via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "slugify source"
  notes:
    - "slugify is an npm package. Install: npm install slugify"
    - "slugify(str) converts a string to a URL-friendly slug (title-cased by default)."
    - "slugify(str, {lower: true}) produces lowercase slugs."
    - "Accented characters are transliterated (e.g. é→e, &→and)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns URL slug string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table slugify.slugify:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: slgfy

  columns: [id, args, expected]
  rows:
    - [spaces,   ["Hello World"],              "Hello-World"]
    - [accented, ["Café & Bar"],               "Cafe-and-Bar"]
    - [lower,    ["Hello World", {"lower": true}], "hello-world"]
