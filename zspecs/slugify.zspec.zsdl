spec: slugify
version: ">=1.0.0"
backend: node(slugify)

docs: https://github.com/simov/slugify#readme

provenance:
  derived_from:
    - "slugify README — https://github.com/simov/slugify#readme"
    - "Test vectors verified with slugify@1.6.9 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "slugify source: slugify.js"
  notes:
    - "slugify exports the slugify function as the module default (CJS)."
    - "require('slugify') returns the function directly; fn_name is null (call module itself)."
    - "Converts strings to URL-safe slugs: spaces → hyphens, special chars removed."
    - "Case is preserved by default; use {lower: true} for lowercase output."
    - "Unicode/accented characters are transliterated to ASCII equivalents."
    - "Dots are preserved by default (file.txt → file.txt)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the slug string directly. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table slugify.basic:
  kind: node_module_call_eq
  function: ~
  category: basic
  id_prefix: slug

  columns: [id, args, expected]
  rows:
    - [spaces,     ["Hello World"],               "Hello-World"]
    - [lower,      ["Hello World", {"lower": true}], "hello-world"]
    - [dots,       ["file.name.txt"],             "file.name.txt"]

table slugify.unicode:
  kind: node_module_call_eq
  function: ~
  category: unicode
  id_prefix: slug_uni

  columns: [id, args, expected]
  rows:
    - [accents,   ["Ñoño"],  "Nono"]
