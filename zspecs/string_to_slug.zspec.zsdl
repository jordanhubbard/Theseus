spec: string_to_slug
version: ">=1.0.0"
backend: node(string-to-slug)

docs: https://www.npmjs.com/package/string-to-slug

provenance:
  derived_from:
    - "string-to-slug README — https://www.npmjs.com/package/string-to-slug"
    - "Test vectors verified with string-to-slug via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "string-to-slug source"
  notes:
    - "string-to-slug is an npm package. Install: npm install string-to-slug"
    - "Converts a string to a URL-friendly slug (lowercase, hyphen-separated, no special chars)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_to_slug.slugify:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: slug

  columns: [id, args, expected]
  rows:
    - [hello_world, ["Hello World"],  "hello-world"]
    - [multi_word,  ["foo bar baz"],  "foo-bar-baz"]
    - [special,     ["My Title!"],    "my-title"]
