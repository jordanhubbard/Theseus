spec: struct_extra19
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — pack/unpack/calcsize core vectors."
    - "struct_extra.zspec.zsdl through struct_extra18.zspec.zsdl — prior extras."
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra18.zspec.zsdl."
    - "Focus: module-level identity attributes and __qualname__ length cross-checks."
    - "struct_extra4 covers Struct.__qualname__=='Struct' and error.__qualname__=='error' and function __qualname__ table."
    - "struct_extra5 covers Struct.__qualname__ as a standalone invariant."
    - "This spec adds NEW axes:"
    - "  (1) struct module __name__ == 'struct' — module-level attribute (not Struct.__name__)."
    - "  (2) struct module __package__ == '' — struct has no parent package."
    - "  (3) struct.__name__.__class__.__name__ == 'str' — module __name__ is a plain string."
    - "  (4) struct.__package__.__class__.__name__ == 'str' — module __package__ is a plain string."
    - "  (5) struct.Struct.__qualname__.__len__() == 6 — len('Struct') == 6."
    - "  (6) struct.error.__qualname__.__len__() == 5 — len('error') == 5."
    - "struct module __name__ == 'struct' — Verified Python 3.12 macOS."
    - "struct module __package__ == '' — struct is a top-level module, no package prefix. Verified."
    - "type(struct.__name__).__name__ == 'str' — Verified."
    - "type(struct.__package__).__name__ == 'str' — Verified."
    - "struct.Struct.__qualname__.__len__() == 6 — len('Struct') == 6. Verified."
    - "struct.error.__qualname__.__len__() == 5 — len('error') == 5. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level __name__ attribute
#
# struct_extra4 checks Struct.__name__ == 'Struct' (class __name__).
# No prior struct spec checks the module's own __name__ attribute.
# In python_module(struct) backend, function: __name__.__eq__ accesses
# struct.__name__.__eq__, evaluating to 'struct'.
# ---------------------------------------------------------------------------

invariant struct_extra19.module.name:
  description: "struct module __name__ == 'struct' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct module-level __package__ attribute
#
# struct is a top-level module; its __package__ is an empty string.
# No prior struct spec checks __package__. Under python_module(struct),
# function: __package__.__eq__ accesses struct.__package__.__eq__('').
# ---------------------------------------------------------------------------

invariant struct_extra19.module.package:
  description: "struct module __package__ == '' — struct is a top-level module with no package prefix"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# struct module __name__ and __package__ type checks
#
# Both __name__ and __package__ are plain Python str objects.
# No prior struct spec checks the type of these module-level attributes.
# ---------------------------------------------------------------------------

invariant struct_extra19.module.name_is_str:
  description: "struct.__name__.__class__.__name__ == 'str' — module __name__ is a plain string"
  category: module_identity
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra19.module.package_is_str:
  description: "struct.__package__.__class__.__name__ == 'str' — module __package__ is a plain string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__len__() == 6
#
# struct_extra4 and struct_extra5 verify Struct.__qualname__ == 'Struct'.
# No prior spec checks the __len__() of Struct.__qualname__.
# len('Struct') == 6. This is a secondary cross-check from the extra19 namespace.
# ---------------------------------------------------------------------------

invariant struct_extra19.Struct.qualname_len:
  description: "struct.Struct.__qualname__.__len__() == 6 — len('Struct') == 6"
  category: class_identity
  kind: python_call_eq
  function: Struct.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__len__() == 5
#
# struct_extra4 verifies error.__qualname__ == 'error'.
# No prior spec checks the __len__() of error.__qualname__.
# len('error') == 5. Cross-check from the extra19 namespace.
# ---------------------------------------------------------------------------

invariant struct_extra19.error.qualname_len:
  description: "struct.error.__qualname__.__len__() == 5 — len('error') == 5"
  category: class_identity
  kind: python_call_eq
  function: error.__qualname__.__len__
  args: []
  expected: 5
