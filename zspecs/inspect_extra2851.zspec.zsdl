spec: inspect_extra2851
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "any proprietary source"
  notes:
    - "Wave 637 (_extra2851): __rlshift__, __rrshift__, __rpow__ dict-presence checks for inspect types."
    - "inspect classes and namedtuples model introspection structures — none define reflected shift or power operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars, inspect.ClassFoundException."
    - "inspect.FullArgSpec, inspect.ArgInfo, inspect.ClosureVars are namedtuple subclasses; FrameInfo and Traceback are named-tuple-derived classes (Python 3.11+)."
    - "inspect.ClassFoundException is an internal exception used by inspect.findclass; it defines no operator dunders."
    - "inspect.ModuleInfo is not available in Python 3.14; excluded from this spec."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

