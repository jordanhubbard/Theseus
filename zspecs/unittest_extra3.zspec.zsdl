spec: unittest_extra3
version: ">=3.9"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "unittest source: internal test runner implementation"
    - "unittest.zspec.zsdl — covers class __name__ table, function __name__ table, SkipTest base, TestLoader prefix, TestSuite/TestResult initial state"
    - "unittest_extra.zspec.zsdl — covers class __module__ table (TestCase/TestSuite/TestLoader/TestResult/TestProgram/FunctionTestCase/SkipTest), decorator __module__, main identity/module, TestCase base, FunctionTestCase base, TestLoader/TestResult state"
    - "unittest_extra2.zspec.zsdl — covers TextTestRunner/TextTestResult __module__, BaseTestSuite __name__+__module__, TestSuite/TextTestResult/TestResult/TestLoader/TextTestRunner/TestProgram __bases__[0]"
  notes:
    - "This spec extends unittest.zspec.zsdl, unittest_extra.zspec.zsdl, and unittest_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "unittest.TestCase.__module__ == 'unittest.case' is covered in unittest_extra; this spec targets the remaining __module__ gaps."
    - "unittest.TextTestRunner.__module__ == 'unittest.runner' is covered in unittest_extra2; listed for context only."
    - "unittest.TextTestResult.__module__ == 'unittest.runner' is covered in unittest_extra2; listed for context only."
    - "unittest.skip.__module__ == 'unittest.case' is covered in unittest_extra; listed for context only."
    - "unittest.skipIf.__module__ == 'unittest.case' is covered in unittest_extra; listed for context only."
    - "unittest.expectedFailure.__module__ == 'unittest.case' is covered in unittest_extra; listed for context only."
    - "unittest.TestCase.__bases__[0].__name__ == 'object' is covered in unittest_extra; listed for context only."
    - "unittest.TestSuite.__bases__[0].__name__ == 'BaseTestSuite' is covered in unittest_extra2; listed for context only."
    - "unittest.TestResult.__bases__[0].__name__ == 'object' is covered in unittest_extra2; listed for context only."
    - "unittest.FunctionTestCase.__bases__[0].__name__ == 'TestCase' is covered in unittest_extra; listed for context only."
    - "NEW invariants: SkipTest.__bases__[0].__name__ == 'Exception' (standalone, unittest.zspec.zsdl has this in a different form), TestLoader.__module__ and TestResult.__module__ standalone anchors, IsolatedAsyncioTestCase.__module__ == 'unittest.case', TestSuite.__bases__[0].__name__ checked against 'BaseTestSuite' from this spec's namespace, skip/__name__ type check, expectedFailure type check, TestCase method names (setUp, tearDown, assertEqual, assertTrue, assertRaises)."
    - "IsolatedAsyncioTestCase.__module__ == 'unittest.case' — added in Python 3.8, defined in Lib/unittest/case.py."
    - "unittest.TestCase has setUp and tearDown lifecycle methods; also assertEqual, assertTrue, assertRaises."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IsolatedAsyncioTestCase — module check
# Not covered in any prior unittest spec.
# ---------------------------------------------------------------------------

invariant unittest_extra3.IsolatedAsyncioTestCase.module:
  description: "unittest.IsolatedAsyncioTestCase.__module__ == 'unittest.case'"
  category: class_modules
  kind: python_call_eq
  function: IsolatedAsyncioTestCase.__module__.__eq__
  args: ["unittest.case"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone module anchors for TestLoader and TestResult
# unittest_extra has them in a table; here we add standalone invariants for
# cross-spec anchoring from the unittest_extra3 namespace.
# ---------------------------------------------------------------------------

invariant unittest_extra3.TestLoader.module:
  description: "unittest.TestLoader.__module__ == 'unittest.loader'"
  category: class_modules
  kind: python_call_eq
  function: TestLoader.__module__.__eq__
  args: ["unittest.loader"]
  expected: true

invariant unittest_extra3.TestResult.module:
  description: "unittest.TestResult.__module__ == 'unittest.result'"
  category: class_modules
  kind: python_call_eq
  function: TestResult.__module__.__eq__
  args: ["unittest.result"]
  expected: true

# ---------------------------------------------------------------------------
# TextTestRunner and TextTestResult — standalone module anchors
# Covered as a table in unittest_extra2; here we add standalone named invariants.
# ---------------------------------------------------------------------------

invariant unittest_extra3.TextTestRunner.module:
  description: "unittest.TextTestRunner.__module__ == 'unittest.runner'"
  category: class_modules
  kind: python_call_eq
  function: TextTestRunner.__module__.__eq__
  args: ["unittest.runner"]
  expected: true

invariant unittest_extra3.TextTestResult.module:
  description: "unittest.TextTestResult.__module__ == 'unittest.runner'"
  category: class_modules
  kind: python_call_eq
  function: TextTestResult.__module__.__eq__
  args: ["unittest.runner"]
  expected: true

# ---------------------------------------------------------------------------
# TestCase method names — setUp, tearDown, assertEqual, assertTrue, assertRaises
# Not covered in any prior unittest spec.
# ---------------------------------------------------------------------------

table unittest_extra3.TestCase.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [setUp,         TestCase.setUp.__name__.__eq__,         ["setUp"],         true]
    - [tearDown,      TestCase.tearDown.__name__.__eq__,      ["tearDown"],      true]
    - [assertEqual,   TestCase.assertEqual.__name__.__eq__,   ["assertEqual"],   true]
    - [assertTrue,    TestCase.assertTrue.__name__.__eq__,    ["assertTrue"],    true]
    - [assertRaises,  TestCase.assertRaises.__name__.__eq__,  ["assertRaises"],  true]
    - [assertFalse,   TestCase.assertFalse.__name__.__eq__,   ["assertFalse"],   true]
    - [assertIsNone,  TestCase.assertIsNone.__name__.__eq__,  ["assertIsNone"],  true]

# ---------------------------------------------------------------------------
# Decorator type checks — skip and expectedFailure are functions
# Not covered in any prior unittest spec.
# ---------------------------------------------------------------------------

invariant unittest_extra3.skip.class_is_function:
  description: "unittest.skip.__class__.__name__ == 'function' — skip is a plain function"
  category: function_types
  kind: python_call_eq
  function: skip.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant unittest_extra3.expectedFailure.class_is_function:
  description: "unittest.expectedFailure.__class__.__name__ == 'function' — expectedFailure is a plain function"
  category: function_types
  kind: python_call_eq
  function: expectedFailure.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# TestSuite base class — standalone anchor from unittest_extra3 namespace
# unittest_extra2 covers this; here we add it as an independent named invariant.
# ---------------------------------------------------------------------------

invariant unittest_extra3.TestSuite.base_is_BaseTestSuite:
  description: "unittest.TestSuite.__bases__[0].__name__ == 'BaseTestSuite'"
  category: class_hierarchy
  kind: python_call_eq
  function: TestSuite.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseTestSuite"

# ---------------------------------------------------------------------------
# SkipTest — base class standalone anchor
# unittest.zspec.zsdl has this check via method_chain form; here we add it
# as a simple __bases__.__getitem__ form for cross-spec consistency.
# ---------------------------------------------------------------------------

invariant unittest_extra3.SkipTest.base_is_Exception:
  description: "unittest.SkipTest.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: SkipTest.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# TestCase — additional assertion method names
# assertIn, assertNotEqual, assertIsInstance are common TestCase methods.
# Not covered in any prior unittest spec.
# ---------------------------------------------------------------------------

invariant unittest_extra3.TestCase.assertIn_name:
  description: "unittest.TestCase.assertIn.__name__ == 'assertIn'"
  category: method_names
  kind: python_call_eq
  function: TestCase.assertIn.__name__.__eq__
  args: ["assertIn"]
  expected: true

invariant unittest_extra3.TestCase.assertNotEqual_name:
  description: "unittest.TestCase.assertNotEqual.__name__ == 'assertNotEqual'"
  category: method_names
  kind: python_call_eq
  function: TestCase.assertNotEqual.__name__.__eq__
  args: ["assertNotEqual"]
  expected: true

invariant unittest_extra3.TestCase.assertIsInstance_name:
  description: "unittest.TestCase.assertIsInstance.__name__ == 'assertIsInstance'"
  category: method_names
  kind: python_call_eq
  function: TestCase.assertIsInstance.__name__.__eq__
  args: ["assertIsInstance"]
  expected: true
