spec: functools_extra219
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra218.zspec.zsdl — covers functools __doc__.__contains__ and __doc__.__len__ checks"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES and callable type checks"
  notes:
    - "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache has two defaulted params: maxsize=128, typed=False. Verified with Python 3.14.3."
    - "functools.lru_cache.__defaults__[0].__eq__(128) == True — the maxsize default is exactly 128. Verified with Python 3.14.3."
    - "functools.lru_cache.__defaults__[1].__eq__(False) == True — the typed default is exactly False. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__.__len__() == 2 — wraps has two defaulted params: assigned and updated. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__[0].__len__() == 6 — the assigned tuple (WRAPPER_ASSIGNMENTS) contains 6 attribute names. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__[0].__contains__('__name__') == True — '__name__' is one of the 6 WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__[0].__contains__('__doc__') == True — '__doc__' is one of the 6 WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__[0].__contains__('__qualname__') == True — '__qualname__' is one of the 6 WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__[1].__len__() == 1 — the updated tuple (WRAPPER_UPDATES) contains exactly 1 entry: '__dict__'. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__[1].__contains__('__dict__') == True — '__dict__' is the sole WRAPPER_UPDATES entry. Verified with Python 3.14.3."
    - "functools.recursive_repr.__defaults__.__len__() == 1 — recursive_repr has one defaulted param: fillvalue='...'. Verified with Python 3.14.3."
    - "functools.recursive_repr.__defaults__[0].__eq__('...') == True — the fillvalue default is exactly '...'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools lru_cache __defaults__ checks
#
# lru_cache.__defaults__.__len__()          == 2
# lru_cache.__defaults__[0].__eq__(128)     == True
# lru_cache.__defaults__[1].__eq__(False)   == True
# lru_cache.__defaults__[0].__class__.__name__ == 'int'
# ---------------------------------------------------------------------------

table functools_extra219.lru_cache_defaults:
  description: "functools.lru_cache __defaults__ tuple checks in functlrudefs219 namespace — lru_cache.__defaults__ has len 2, element [0] equals 128 (int), element [1] equals False (bool); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: functlrudefs219

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_defaults_len,
       lru_cache.__defaults__.__len__,
       [],
       2,
       "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache takes maxsize=128 and typed=False as defaults; __len__() returns 2; verified with Python 3.14.3"]
    - [lru_cache_defaults_0_eq_128,
       "lru_cache.__defaults__[0].__eq__",
       [128],
       true,
       "functools.lru_cache.__defaults__[0].__eq__(128) == True — the maxsize parameter defaults to 128; __eq__(128) returns True; verified with Python 3.14.3"]
    - [lru_cache_defaults_1_eq_false,
       "lru_cache.__defaults__[1].__eq__",
       [false],
       true,
       "functools.lru_cache.__defaults__[1].__eq__(False) == True — the typed parameter defaults to False; __eq__(False) returns True; verified with Python 3.14.3"]
    - [lru_cache_defaults_0_classname,
       "lru_cache.__defaults__[0].__class__.__name__.__eq__",
       ["int"],
       true,
       "functools.lru_cache.__defaults__[0].__class__.__name__.__eq__('int') == True — the maxsize default 128 is an int; __class__.__name__ is 'int'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: functools wraps __defaults__ tuple membership checks
#
# wraps.__defaults__.__len__()                     == 2
# wraps.__defaults__[0].__len__()                  == 6
# wraps.__defaults__[0].__contains__('__name__')   == True
# wraps.__defaults__[0].__contains__('__doc__')    == True
# wraps.__defaults__[0].__contains__('__qualname__') == True
# wraps.__defaults__[1].__len__()                  == 1
# wraps.__defaults__[1].__contains__('__dict__')   == True
# ---------------------------------------------------------------------------

table functools_extra219.wraps_defaults:
  description: "functools.wraps __defaults__ tuple checks in functwrapsdefs219 namespace — wraps.__defaults__ has len 2; element [0] (WRAPPER_ASSIGNMENTS) has len 6 and contains '__name__', '__doc__', '__qualname__'; element [1] (WRAPPER_UPDATES) has len 1 and contains '__dict__'; all rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: functwrapsdefs219

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_defaults_len,
       wraps.__defaults__.__len__,
       [],
       2,
       "functools.wraps.__defaults__.__len__() == 2 — wraps takes assigned and updated as defaults; __len__() returns 2; verified with Python 3.14.3"]
    - [wraps_defaults_0_len,
       "wraps.__defaults__[0].__len__",
       [],
       6,
       "functools.wraps.__defaults__[0].__len__() == 6 — the assigned default (WRAPPER_ASSIGNMENTS) contains 6 dunder attribute names; __len__() returns 6; verified with Python 3.14.3"]
    - [wraps_defaults_0_contains_name,
       "wraps.__defaults__[0].__contains__",
       ["__name__"],
       true,
       "functools.wraps.__defaults__[0].__contains__('__name__') == True — '__name__' is one of the six WRAPPER_ASSIGNMENTS entries; __contains__('__name__') returns True; verified with Python 3.14.3"]
    - [wraps_defaults_0_contains_doc,
       "wraps.__defaults__[0].__contains__",
       ["__doc__"],
       true,
       "functools.wraps.__defaults__[0].__contains__('__doc__') == True — '__doc__' is one of the six WRAPPER_ASSIGNMENTS entries; __contains__('__doc__') returns True; verified with Python 3.14.3"]
    - [wraps_defaults_0_contains_qualname,
       "wraps.__defaults__[0].__contains__",
       ["__qualname__"],
       true,
       "functools.wraps.__defaults__[0].__contains__('__qualname__') == True — '__qualname__' is one of the six WRAPPER_ASSIGNMENTS entries; __contains__('__qualname__') returns True; verified with Python 3.14.3"]
    - [wraps_defaults_1_len,
       "wraps.__defaults__[1].__len__",
       [],
       1,
       "functools.wraps.__defaults__[1].__len__() == 1 — the updated default (WRAPPER_UPDATES) contains only '__dict__'; __len__() returns 1; verified with Python 3.14.3"]
    - [wraps_defaults_1_contains_dict,
       "wraps.__defaults__[1].__contains__",
       ["__dict__"],
       true,
       "functools.wraps.__defaults__[1].__contains__('__dict__') == True — '__dict__' is the sole WRAPPER_UPDATES entry; __contains__('__dict__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: functools recursive_repr __defaults__ checks
#
# recursive_repr.__defaults__.__len__()         == 1
# recursive_repr.__defaults__[0].__eq__('...')  == True
# recursive_repr.__defaults__[0].__class__.__name__ == 'str'
# update_wrapper.__defaults__[0].__len__()      == 6
# update_wrapper.__defaults__[1].__contains__('__dict__') == True
# ---------------------------------------------------------------------------

table functools_extra219.recursive_repr_and_update_wrapper_defaults:
  description: "functools.recursive_repr and update_wrapper __defaults__ checks in functrecreprdefs219 namespace — recursive_repr.__defaults__ has len 1 and element [0] equals '...'; update_wrapper.__defaults__[0] has len 6 and [1] contains '__dict__'; all rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: functrecreprdefs219

  columns: [id, function, args, expected, description]
  rows:
    - [recursive_repr_defaults_len,
       recursive_repr.__defaults__.__len__,
       [],
       1,
       "functools.recursive_repr.__defaults__.__len__() == 1 — recursive_repr takes one default: fillvalue='...'; __len__() returns 1; verified with Python 3.14.3"]
    - [recursive_repr_defaults_0_eq_ellipsis,
       "recursive_repr.__defaults__[0].__eq__",
       ["..."],
       true,
       "functools.recursive_repr.__defaults__[0].__eq__('...') == True — the fillvalue default is the string '...'; __eq__('...') returns True; verified with Python 3.14.3"]
    - [recursive_repr_defaults_0_classname,
       "recursive_repr.__defaults__[0].__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.recursive_repr.__defaults__[0].__class__.__name__.__eq__('str') == True — the fillvalue default '...' is a str; __class__.__name__ is 'str'; verified with Python 3.14.3"]
    - [update_wrapper_defaults_0_len,
       "update_wrapper.__defaults__[0].__len__",
       [],
       6,
       "functools.update_wrapper.__defaults__[0].__len__() == 6 — the assigned default for update_wrapper (WRAPPER_ASSIGNMENTS) has 6 entries; __len__() returns 6; verified with Python 3.14.3"]
    - [update_wrapper_defaults_1_contains_dict,
       "update_wrapper.__defaults__[1].__contains__",
       ["__dict__"],
       true,
       "functools.update_wrapper.__defaults__[1].__contains__('__dict__') == True — the updated default for update_wrapper contains '__dict__'; __contains__('__dict__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra219
# ---------------------------------------------------------------------------

invariant functools_extra219.lru_cache_defaults_len:
  description: "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache has exactly two default arguments: maxsize and typed; new to extra219; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: lru_cache.__defaults__.__len__
  args: []
  expected: 2

invariant functools_extra219.lru_cache_maxsize_default:
  description: "functools.lru_cache.__defaults__[0].__eq__(128) == True — the maxsize default value is 128; new to extra219; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "lru_cache.__defaults__[0].__eq__"
  args: [128]
  expected: true

invariant functools_extra219.wraps_defaults_len:
  description: "functools.wraps.__defaults__.__len__() == 2 — wraps has exactly two default arguments: assigned and updated; new to extra219; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: wraps.__defaults__.__len__
  args: []
  expected: 2

invariant functools_extra219.wraps_assignments_len:
  description: "functools.wraps.__defaults__[0].__len__() == 6 — WRAPPER_ASSIGNMENTS contains exactly 6 dunder names; new to extra219; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "wraps.__defaults__[0].__len__"
  args: []
  expected: 6

invariant functools_extra219.wraps_updates_contains_dict:
  description: "functools.wraps.__defaults__[1].__contains__('__dict__') == True — WRAPPER_UPDATES contains '__dict__' as its sole entry; new to extra219; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "wraps.__defaults__[1].__contains__"
  args: ["__dict__"]
  expected: true

invariant functools_extra219.recursive_repr_fillvalue:
  description: "functools.recursive_repr.__defaults__[0].__eq__('...') == True — the fillvalue default for recursive_repr is exactly '...'; new to extra219; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "recursive_repr.__defaults__[0].__eq__"
  args: ["..."]
  expected: true
