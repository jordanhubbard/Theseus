spec: pathlib_extra2371
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib exposes six public classes at module level; all have __class__.__name__ == 'type'."
    - "PurePath and PurePosixPath/PureWindowsPath are pure path types (no I/O); they can be instantiated on any platform."
    - "Path, PosixPath, WindowsPath are concrete path types; PosixPath and WindowsPath cannot be instantiated on the wrong OS but their class objects are accessible as 'type' on any platform."
    - "All six classes report __module__ == 'pathlib' (verified Python 3.12)."
  created_at: "2026-04-12"

table pathlib_extra2371.object_types:
  description: "pathlib module-level class type classification via __class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: pp2371
  columns: [id, function, args, expected]
  rows:
    - ["pp2371001", "pathlib.PurePath.__class__.__name__", [], "type"]
    - ["pp2371002", "pathlib.PurePosixPath.__class__.__name__", [], "type"]
    - ["pp2371003", "pathlib.PureWindowsPath.__class__.__name__", [], "type"]
    - ["pp2371004", "pathlib.Path.__class__.__name__", [], "type"]
    - ["pp2371005", "pathlib.PosixPath.__class__.__name__", [], "type"]
    - ["pp2371006", "pathlib.WindowsPath.__class__.__name__", [], "type"]

table pathlib_extra2371.class_names:
  description: "pathlib class __name__ attributes — each class reports its own simple name"
  kind: python_call_eq
  category: classnames
  id_prefix: pp2371
  columns: [id, function, args, expected]
  rows:
    - ["pp2371007", "pathlib.PurePath.__name__.__eq__", ["PurePath"], true]
    - ["pp2371008", "pathlib.PurePosixPath.__name__.__eq__", ["PurePosixPath"], true]
    - ["pp2371009", "pathlib.PureWindowsPath.__name__.__eq__", ["PureWindowsPath"], true]
    - ["pp2371010", "pathlib.Path.__name__.__eq__", ["Path"], true]
    - ["pp2371011", "pathlib.PosixPath.__name__.__eq__", ["PosixPath"], true]
    - ["pp2371012", "pathlib.WindowsPath.__name__.__eq__", ["WindowsPath"], true]

table pathlib_extra2371.class_modules:
  description: "pathlib class __module__ attributes — all classes report 'pathlib'"
  kind: python_call_eq
  category: classnames
  id_prefix: pp2371
  columns: [id, function, args, expected]
  rows:
    - ["pp2371013", "pathlib.PurePath.__module__.__eq__", ["pathlib"], true]
    - ["pp2371014", "pathlib.PurePosixPath.__module__.__eq__", ["pathlib"], true]
    - ["pp2371015", "pathlib.PureWindowsPath.__module__.__eq__", ["pathlib"], true]
    - ["pp2371016", "pathlib.Path.__module__.__eq__", ["pathlib"], true]
    - ["pp2371017", "pathlib.PosixPath.__module__.__eq__", ["pathlib"], true]
    - ["pp2371018", "pathlib.WindowsPath.__module__.__eq__", ["pathlib"], true]

table pathlib_extra2371.inheritance:
  description: "pathlib class hierarchy — subclass relationships"
  kind: python_call_eq
  category: type_identity
  id_prefix: pp2371
  columns: [id, function, args, expected]
  rows:
    - ["pp2371019", "pathlib.PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"], true]
    - ["pp2371020", "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true]
    - ["pp2371021", "pathlib.Path.__bases__[0].__name__.__eq__", ["PurePath"], true]
