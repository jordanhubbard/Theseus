spec: inspect_extra128
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.FrameInfo and inspect.Traceback namedtuple identity (Wave 260)."
    - "inspect.FrameInfo.__name__ == 'FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo extends the private _FrameInfo namedtuple. Verified with Python 3.14.3."
    - "inspect.FrameInfo._fields.__class__.__name__ == 'tuple' — _fields is a tuple of field name strings. Verified with Python 3.14.3."
    - "len(inspect.FrameInfo._fields) == 6 — fields: frame, filename, lineno, function, code_context, index. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__qualname__ == 'FrameInfo'. Verified with Python 3.14.3."
    - "len(inspect.FrameInfo.__mro__) == 4 — MRO is [FrameInfo, _FrameInfo, tuple, object]. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Traceback.__name__ == 'Traceback'. Verified with Python 3.14.3."
    - "inspect.Traceback.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Traceback._fields has 5 fields: filename, lineno, function, code_context, index. Verified with Python 3.14.3."
    - "inspect.Traceback.__bases__[0].__name__ == '_Traceback'. Verified with Python 3.14.3."
    - "inspect.Traceback.__qualname__ == 'Traceback'. Verified with Python 3.14.3."
    - "len(inspect.Traceback.__mro__) == 4 — MRO is [Traceback, _Traceback, tuple, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FrameInfo namedtuple class identity and _fields
#
# Wave 260 theme: inspect.FrameInfo class identity.
#
# inspect.FrameInfo.__name__.__eq__('FrameInfo') == True
# inspect.FrameInfo.__module__.__eq__('inspect') == True
# inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True
# inspect.FrameInfo._fields.__class__.__name__.__eq__('tuple') == True
# inspect.FrameInfo._fields.__len__() == 6
# inspect.FrameInfo.__qualname__.__eq__('FrameInfo') == True
#
# FrameInfo is a namedtuple subclass defined in Lib/inspect.py.
# It extends the private _FrameInfo namedtuple (hence __bases__[0] is
# '_FrameInfo', not 'tuple'). MRO has 4 entries:
# [FrameInfo, _FrameInfo, tuple, object]. _fields has 6 entries.
# New to extra128.
# ---------------------------------------------------------------------------

table inspect_extra128.frameinfo_identity:
  description: "inspect.FrameInfo class identity: __name__, __module__, __bases__[0]=='_FrameInfo', _fields len==6, __qualname__; wave 260; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectframeinfo128

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq,
       "FrameInfo.__name__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a namedtuple subclass defined in Lib/inspect.py; its __name__ is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra128"]
    - [frameinfo_module_eq_inspect,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra128"]
    - [frameinfo_bases_first_eq_FrameInfo_private,
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo is a subclass of the private _FrameInfo namedtuple defined in Lib/inspect.py; __bases__[0].__name__ is '_FrameInfo', not 'tuple'; str.__eq__('_FrameInfo') returns True; new to extra128"]
    - [frameinfo_fields_class_name_eq_tuple,
       "FrameInfo._fields.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FrameInfo._fields.__class__.__name__.__eq__('tuple') == True — the _fields attribute of any namedtuple is a plain tuple of field name strings; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra128"]
    - [frameinfo_fields_len_eq_6,
       "FrameInfo._fields.__len__",
       [],
       6,
       "inspect.FrameInfo._fields.__len__() == 6 — FrameInfo has 6 fields: 'frame', 'filename', 'lineno', 'function', 'code_context', 'index'; _fields is a tuple of these 6 field names; len(_fields) is 6; new to extra128"]
    - [frameinfo_qualname_eq,
       "FrameInfo.__qualname__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__qualname__.__eq__('FrameInfo') == True — FrameInfo is defined at module scope in Lib/inspect.py; __qualname__ equals the simple class name 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Table 2: inspect.FrameInfo __mro__ length and class name
#
# Wave 260 theme: inspect.FrameInfo MRO length and metaclass identity.
#
# inspect.FrameInfo.__mro__.__len__() == 4
# inspect.FrameInfo.__class__.__name__.__eq__('type') == True
# inspect.Traceback.__name__.__eq__('Traceback') == True
# inspect.Traceback.__module__.__eq__('inspect') == True
# inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True
#
# FrameInfo has MRO [FrameInfo, _FrameInfo, tuple, object] (length 4) because
# it subclasses the private intermediate _FrameInfo namedtuple.
# Traceback likewise subclasses _Traceback. New to extra128.
# ---------------------------------------------------------------------------

table inspect_extra128.frameinfo_mro_traceback_identity:
  description: "inspect.FrameInfo __mro__ len==4, __class__.__name__=='type'; Traceback __name__, __module__, __bases__[0]=='_Traceback'; wave 260; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectframeinfo128

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_mro_len_eq_4,
       "FrameInfo.__mro__.__len__",
       [],
       4,
       "inspect.FrameInfo.__mro__.__len__() == 4 — the MRO of FrameInfo is [FrameInfo, _FrameInfo, tuple, object]; FrameInfo subclasses _FrameInfo which subclasses tuple which subclasses object; len(__mro__) is 4; new to extra128"]
    - [frameinfo_class_name_eq_type,
       "FrameInfo.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FrameInfo.__class__.__name__.__eq__('type') == True — FrameInfo is a Python class (a namedtuple subclass); its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra128"]
    - [traceback_name_eq,
       "Traceback.__name__.__eq__",
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — Traceback is a namedtuple subclass defined in Lib/inspect.py; its __name__ is 'Traceback'; str.__eq__('Traceback') returns True; new to extra128"]
    - [traceback_module_eq_inspect,
       "Traceback.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra128"]
    - [traceback_bases_first_eq_Traceback_private,
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — Traceback subclasses the private _Traceback namedtuple defined in Lib/inspect.py; __bases__[0].__name__ is '_Traceback'; str.__eq__('_Traceback') returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Traceback _fields, __qualname__, and __mro__ length
#
# Wave 260 theme: inspect.Traceback _fields and MRO identity.
#
# inspect.Traceback._fields.__len__() == 5
# inspect.Traceback._fields.__class__.__name__.__eq__('tuple') == True
# inspect.Traceback.__qualname__.__eq__('Traceback') == True
# inspect.Traceback.__mro__.__len__() == 4
# inspect.Traceback.__class__.__name__.__eq__('type') == True
#
# Traceback has 5 fields: filename, lineno, function, code_context, index.
# Its MRO is [Traceback, _Traceback, tuple, object] (length 4). New to extra128.
# ---------------------------------------------------------------------------

table inspect_extra128.traceback_fields_mro:
  description: "inspect.Traceback _fields len==5, _fields class=='tuple', __qualname__=='Traceback', __mro__ len==4, __class__.__name__=='type'; wave 260; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectframeinfo128

  columns: [id, function, args, expected, description]
  rows:
    - [traceback_fields_len_eq_5,
       "Traceback._fields.__len__",
       [],
       5,
       "inspect.Traceback._fields.__len__() == 5 — Traceback has 5 fields: 'filename', 'lineno', 'function', 'code_context', 'index'; _fields is a tuple of these 5 field names; len(_fields) is 5; new to extra128"]
    - [traceback_fields_class_name_eq_tuple,
       "Traceback._fields.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.Traceback._fields.__class__.__name__.__eq__('tuple') == True — the _fields attribute of any namedtuple is a plain tuple of field name strings; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra128"]
    - [traceback_qualname_eq,
       "Traceback.__qualname__.__eq__",
       ["Traceback"],
       true,
       "inspect.Traceback.__qualname__.__eq__('Traceback') == True — Traceback is defined at module scope; __qualname__ equals the simple class name 'Traceback'; str.__eq__('Traceback') returns True; new to extra128"]
    - [traceback_mro_len_eq_4,
       "Traceback.__mro__.__len__",
       [],
       4,
       "inspect.Traceback.__mro__.__len__() == 4 — the MRO of Traceback is [Traceback, _Traceback, tuple, object]; Traceback subclasses _Traceback which subclasses tuple; len(__mro__) is 4; new to extra128"]
    - [traceback_class_name_eq_type,
       "Traceback.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Traceback.__class__.__name__.__eq__('type') == True — Traceback is a Python class (a namedtuple subclass); its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra128
# ---------------------------------------------------------------------------

invariant inspect_extra128.frameinfo_name:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' — namedtuple subclass in Lib/inspect.py; wave 260; new to extra128"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra128.frameinfo_fields_len:
  description: "len(inspect.FrameInfo._fields) == 6 — fields: frame, filename, lineno, function, code_context, index; wave 260; new to extra128"
  kind: python_call_eq
  function: FrameInfo._fields.__len__
  args: []
  expected: 6

invariant inspect_extra128.frameinfo_mro_len:
  description: "len(inspect.FrameInfo.__mro__) == 4 — MRO is [FrameInfo, _FrameInfo, tuple, object]; wave 260; new to extra128"
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra128.traceback_fields_len:
  description: "len(inspect.Traceback._fields) == 5 — fields: filename, lineno, function, code_context, index; wave 260; new to extra128"
  kind: python_call_eq
  function: Traceback._fields.__len__
  args: []
  expected: 5

invariant inspect_extra128.traceback_mro_len:
  description: "len(inspect.Traceback.__mro__) == 4 — MRO is [Traceback, _Traceback, tuple, object]; wave 260; new to extra128"
  kind: python_call_eq
  function: Traceback.__mro__.__len__
  args: []
  expected: 4
