invariant re_extra172.Pattern_doc_class_is_str:
  description: "re.Pattern.__doc__.__class__.__name__ == 'str' — Pattern.__doc__ is a non-None string in Python 3.14.3; 'str' has 3 characters; Pattern.__doc__.__class__.__name__ (3: 'str') is NOT 'NoneType' (8 chars) — the re.Pattern C type provides a docstring; the doc class name 'str' (3 chars) == len('sub') (3 chars): coincidental tie with the shortest re function name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra172.Match_doc_class_is_str:
  description: "re.Match.__doc__.__class__.__name__ == 'str' — Match.__doc__ is a non-None string in Python 3.14.3; 'str' has 3 characters; Match.__doc__.__class__.__name__ (3: 'str') == Pattern.__doc__.__class__.__name__ (3: 'str'): both re C extension types have str docstrings; 'str' (3) < 'NoneType' (8) by 5: if the doc were absent, the class name would be 5 characters longer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra172.compile_doc_class_is_str:
  description: "re.compile.__doc__.__class__.__name__ == 'str' — compile.__doc__ is a non-None string; 'str' has 3 characters; compile is a Python-level function, so a str docstring is expected and common; compile.__doc__.__class__.__name__ (3: 'str') == Pattern.__doc__.__class__.__name__ (3: 'str') == Match.__doc__.__class__.__name__ (3: 'str'): all three objects in this spec share the 3-character doc class name 'str'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra172.Pattern_dict_has_match:
  description: "re.Pattern.__dict__.__contains__('match') == True — match() is defined directly on the Pattern type; 'match' has 5 characters; Pattern.match() is the bound-method equivalent of the top-level re.match() function; match (5 chars) == len('Match') (5 chars): the method name ties with the Match class name in length; sub(3) < match(5) < search(6) < findall(7): match sits at the second level in the ascending method name sequence; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["match"]
  expected: true

invariant re_extra172.Pattern_dict_has_search:
  description: "re.Pattern.__dict__.__contains__('search') == True — search() is defined directly on the Pattern type; 'search' has 6 characters; Pattern.search() scans the entire string for the first match; search (6 chars) == len(re.search.__name__) (6 chars) — Pattern method name matches top-level function name length; search (6) > match (5) by 1 and < findall (7) by 1: search is consecutive with both neighbors in the ascending sequence; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["search"]
  expected: true

invariant re_extra172.Pattern_dict_has_findall:
  description: "re.Pattern.__dict__.__contains__('findall') == True — findall() is defined directly on the Pattern type; 'findall' has 7 characters: 'find'(4)+'all'(3)=7; findall (7) is the maximum in the four-method name length group: sub(3) < match(5) < search(6) < findall(7); findall (7 chars) == len('Pattern') (7 chars): the container class name and the longest method name tie at 7 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["findall"]
  expected: true

invariant re_extra172.Pattern_dict_has_sub:
  description: "re.Pattern.__dict__.__contains__('sub') == True — sub() is defined directly on the Pattern type; 'sub' has 3 characters — the minimum in the four-method name length group: sub(3) < match(5) < search(6) < findall(7); Pattern.sub() replaces matches in a string; sub (3 chars) == len('sub') (3 chars) == doc class name 'str' (3 chars): a coincidental 3-character tie within the re spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["sub"]
  expected: true

invariant re_extra172.Pattern_dict_class_is_mappingproxy:
  description: "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy' — Pattern.__dict__ is a read-only mappingproxy (12 chars); 'mappingproxy' = 'mapping'(7)+'proxy'(5) = 12; 'mapping' (7 chars) == len('Pattern') (7 chars): the first component of 'mappingproxy' ties with the Pattern class name in length; re.Pattern.__dict__.__class__.__name__ (12: 'mappingproxy') == pathlib.Path.__dict__.__class__.__name__ (12: 'mappingproxy'): uniform class namespace type across Python modules; confirmed Python 3.14.3 macOS"
  category: identity
