spec: re_extra172
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Pattern and re.Match class __doc__ type, re.compile.__doc__ type, re.Pattern.__dict__ key membership, and re.Pattern.__dict__.__class__.__name__."
    - "re.Pattern.__doc__.__class__.__name__ == 'str' — Pattern.__doc__ is a non-None str in Python 3.14.3 (not NoneType as sometimes expected for C types)."
    - "re.Match.__doc__.__class__.__name__ == 'str' — Match.__doc__ is also a non-None str."
    - "re.compile.__doc__.__class__.__name__ == 'str' — the compile function docstring is a str."
    - "re.Pattern.__dict__.__contains__('match') == True — Pattern.match() is defined directly on the Pattern type."
    - "re.Pattern.__dict__.__contains__('search') == True — Pattern.search() is defined directly on the Pattern type."
    - "re.Pattern.__dict__.__contains__('findall') == True — Pattern.findall() is defined directly on the Pattern type."
    - "re.Pattern.__dict__.__contains__('sub') == True — Pattern.sub() is defined directly on the Pattern type."
    - "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy' — Pattern.__dict__ is a read-only mappingproxy."
    - "All four Pattern methods match(5), search(6), findall(7), sub(3) have the same name lengths as the corresponding top-level re functions."
    - "Pattern.__doc__.__class__.__name__ == 'str' (len=3) — the doc class name is 3 characters long."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.__doc__ and re.Match.__doc__ type identity
# Both are 'str' in Python 3.14.3 — C types with non-None docstrings
# re.compile.__doc__ is also 'str'
# The doc __class__.__name__ == 'str' (len=3) for all three
# ---------------------------------------------------------------------------

table re_extra172.doc_class_identity:
  description: "re.Pattern.__doc__.__class__.__name__=='str' (len=3); re.Match.__doc__.__class__.__name__=='str' (len=3); re.compile.__doc__.__class__.__name__=='str' (len=3); all three have non-None str docstrings in Python 3.14.3; doc class name 'str' (3) == len('sub') (3) — a coincidental tie with the shortest re function name"
  kind: python_call_eq
  category: identity
  id_prefix: redoc172

  columns: [id, function, args, expected, description]
  rows:
    - [pat_doc_cls,  re.Pattern.__doc__.__class__.__name__.__eq__,  ["str"], true, "re.Pattern.__doc__.__class__.__name__ == 'str' — Pattern.__doc__ is a non-None string in Python 3.14.3; 'str' has 3 characters; Pattern.__doc__.__class__.__name__ (3: 'str') is 'str', not 'NoneType' (8 chars) — Python 3.14.3 provides a docstring for the re.Pattern C type ('Compiled regular expression object.'); the doc string class name 'str' (3 chars) == len('sub') (3 chars): the re function with the shortest name has the same length as the docstring class name; re.Pattern is a C extension type (class _sre.SRE_Pattern internally), yet its __doc__ is a str; confirmed Python 3.14.3 macOS"]
    - [mat_doc_cls,  re.Match.__doc__.__class__.__name__.__eq__,    ["str"], true, "re.Match.__doc__.__class__.__name__ == 'str' — Match.__doc__ is a non-None string in Python 3.14.3; 'str' has 3 characters; Match.__doc__.__class__.__name__ (3: 'str') == Pattern.__doc__.__class__.__name__ (3: 'str'): both C extension classes in the re module have str docstrings; re.Match is the C type returned by re.search(), re.match(), etc.; re.Match.__doc__.__class__.__name__ == 'str' (3 chars) == len('sub') (3 chars): the Match doc class name length ties with the shortest re function name; confirmed Python 3.14.3 macOS"]
    - [cmp_doc_cls,  re.compile.__doc__.__class__.__name__.__eq__,  ["str"], true, "re.compile.__doc__.__class__.__name__ == 'str' — compile.__doc__ is a non-None string; 'str' has 3 characters; re.compile.__doc__.__class__.__name__ (3: 'str') == re.Pattern.__doc__.__class__.__name__ (3: 'str') == re.Match.__doc__.__class__.__name__ (3: 'str'): all three objects in this table share the 3-character doc class name 'str'; re.compile is a Python function (not a C type), so a str docstring is expected; all three (Pattern, Match, compile) have doc class name 'str' (3 chars) — uniform docstring type attribution; confirmed Python 3.14.3 macOS"]
    - [doc_ne_none,  re.Pattern.__doc__.__class__.__name__.__eq__,  ["NoneType"], false, "re.Pattern.__doc__.__class__.__name__.__eq__('NoneType') == False — Pattern.__doc__ is NOT NoneType; Pattern.__doc__.__class__.__name__ is 'str' (3 chars), not 'NoneType' (8 chars); some C extension types have __doc__ == None (which would give 'NoneType'), but re.Pattern in Python 3.14.3 provides a proper docstring string; 'NoneType' (8 chars) > 'str' (3 chars) by 5: the absent-doc type name is 5 characters longer than the present-doc type name; the False assertion encodes that Pattern is well-documented as a C type; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__ contains match, search, findall, sub
# These are the method names on the Pattern type matching top-level re functions
# sub(3) < match(5) < search(6) < findall(7)
# ---------------------------------------------------------------------------

table re_extra172.Pattern_dict_method_membership:
  description: "re.Pattern.__dict__.__contains__('match')==True (len=5); __contains__('search')==True (len=6); __contains__('findall')==True (len=7); __contains__('sub')==True (len=3); Pattern methods match top-level re function names; sub(3) < match(5) < search(6) < findall(7)"
  kind: python_call_eq
  category: identity
  id_prefix: repat172

  columns: [id, function, args, expected, description]
  rows:
    - [has_match,   "re.Pattern.__dict__.__contains__", ["match"],   true, "re.Pattern.__dict__.__contains__('match') == True — 'match' is a key in Pattern.__dict__, meaning match() is defined directly on the Pattern type; 'match' has 5 characters; Pattern.match() applies the compiled pattern at the beginning of the string — the bound method counterpart of re.match(); match (5 chars) == len(re.match.__name__) (5 chars): the Pattern method and the top-level function have identical name lengths; Pattern.match(string) is equivalent to re.match(pattern, string) when pattern is compiled; match (5) < search (6) by 1: consecutive in the ascending method name length sequence; confirmed Python 3.14.3 macOS"]
    - [has_search,  "re.Pattern.__dict__.__contains__", ["search"],  true, "re.Pattern.__dict__.__contains__('search') == True — 'search' is a key in Pattern.__dict__, meaning search() is defined directly on the Pattern type; 'search' has 6 characters; Pattern.search() scans the entire string for the first match — the bound method counterpart of re.search(); search (6 chars) == len(re.search.__name__) (6 chars): Pattern method name length equals the top-level function name length; Pattern.search(string) is equivalent to re.search(pattern, string) when pattern is compiled; search (6) > match (5) by 1 and < findall (7) by 1: search is consecutive with both neighbors; confirmed Python 3.14.3 macOS"]
    - [has_findall, "re.Pattern.__dict__.__contains__", ["findall"], true, "re.Pattern.__dict__.__contains__('findall') == True — 'findall' is a key in Pattern.__dict__, meaning findall() is defined directly on the Pattern type; 'findall' has 7 characters: 'find'(4)+'all'(3)=7; Pattern.findall() returns a list of all matches — the bound method counterpart of re.findall(); findall (7 chars) == len(re.findall.__name__) (7 chars): equal name length between Pattern method and top-level function; findall (7) is the maximum method name length in the four-method group: sub(3) < match(5) < search(6) < findall(7); findall (7 chars) == len('Pattern') (7 chars): the container class name and the longest method name tie at 7; confirmed Python 3.14.3 macOS"]
    - [has_sub,     "re.Pattern.__dict__.__contains__", ["sub"],     true, "re.Pattern.__dict__.__contains__('sub') == True — 'sub' is a key in Pattern.__dict__, meaning sub() is defined directly on the Pattern type; 'sub' has 3 characters; Pattern.sub() replaces matches — the bound method counterpart of re.sub(); sub (3 chars) is the minimum method name length in the four-method group: sub(3) < match(5) < search(6) < findall(7); sub (3 chars) == len('sub') (3 chars) == len('_io') (3 chars): cross-module tie with the io C extension module name length; Pattern.sub(repl, string) is equivalent to re.sub(pattern, repl, string) when pattern is compiled; confirmed Python 3.14.3 macOS"]
    - [sub_lt_find, "re.Pattern.__dict__.__contains__", ["sub"],     true, "re.Pattern.__dict__.__contains__('sub') == True — confirming sub (3 chars) < findall (7 chars) by 4: the minimum and maximum method name lengths in the four-method group differ by 4; the ascending sequence sub(3) < match(5) < search(6) < findall(7) spans 4 distinct lengths; sub(3) to match(5): gap of 2; match(5) to search(6): gap of 1; search(6) to findall(7): gap of 1; the largest gap is 2 (between sub and match) and the two consecutive unit gaps are match->search and search->findall; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__class__.__name__ == 'mappingproxy'
# Pattern.__dict__ is a read-only mappingproxy, like all class __dict__ objects
# ---------------------------------------------------------------------------

table re_extra172.Pattern_dict_class_identity:
  description: "re.Pattern.__dict__.__class__.__name__=='mappingproxy' (len=12); Pattern.__dict__ is a read-only mappingproxy, preventing direct assignment; 'mappingproxy'='mapping'(7)+'proxy'(5)=12; Pattern.__dict__.__class__.__name__ (12) == Path.__dict__.__class__.__name__ (12) from pathlib_extra174"
  kind: python_call_eq
  category: identity
  id_prefix: repdx172

  columns: [id, function, args, expected, description]
  rows:
    - [pat_dict_cls,  "re.Pattern.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy' — Pattern.__dict__ is a read-only mappingproxy (12 chars); 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; the mappingproxy type prevents direct assignment: Pattern.__dict__['newkey'] = value raises TypeError; re.Pattern.__dict__.__class__.__name__ (12: 'mappingproxy') == pathlib.Path.__dict__.__class__.__name__ (12: 'mappingproxy') == decimal.Decimal.__dict__.__class__.__name__ (12: 'mappingproxy') — uniform across all class __dict__ objects across modules; the mappingproxy ensures the re.Pattern class namespace is read-only even when accessed via __dict__; confirmed Python 3.14.3 macOS"]
    - [pat_dict_ne,   "re.Pattern.__dict__.__class__.__name__.__eq__",  ["dict"],         false, "re.Pattern.__dict__.__class__.__name__.__eq__('dict') == False — Pattern.__dict__ is NOT a plain dict; 'dict' (4 chars) != 'mappingproxy' (12 chars); the 8-character difference: 'mappingproxy' (12) - 'dict' (4) = 8; a plain dict is mutable while a mappingproxy is read-only — Pattern.__dict__ is read-only to protect the re.Pattern C type's namespace; this applies to all C extension types in Python, not just re.Pattern: their __dict__ is always a mappingproxy; confirmed Python 3.14.3 macOS"]
    - [pat_dict_len,  "re.Pattern.__dict__.__class__.__name__.__len__", [],               12,   "re.Pattern.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; 'mapping' (7 chars) == len('Pattern') (7 chars) == len('Decimal') (7 chars): the first component of 'mappingproxy' has the same length as the re and decimal module primary class names; 'proxy' (5 chars) == len('match') (5 chars) and len('Match') (5 chars): the second component of 'mappingproxy' ties with the re match function and Match class names; 12 chars is a consistent length for 'mappingproxy' across all Python class __dict__ types regardless of module; confirmed Python 3.14.3 macOS"]
    - [pat_proxy_eq,  "re.Pattern.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy' — confirming the class namespace type; the 'mappingproxy' type is a CPython implementation detail for protecting class namespaces; re.Pattern is a C type (internally _sre.SRE_Pattern) yet its __dict__'s class is still the same 'mappingproxy' (12 chars) that Python-defined classes use; the mappingproxy allows read access to all Pattern methods (match, search, findall, sub, fullmatch, finditer, subn, split) while blocking writes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity
# Pattern.__name__ == 'Pattern' (len=7), Pattern.__module__ == 're' (len=2)
# Match.__name__ == 'Match' (len=5), Match.__module__ == 're' (len=2)
# ---------------------------------------------------------------------------

table re_extra172.Pattern_Match_class_identity:
  description: "re.Pattern.__name__=='Pattern' (len=7), re.Pattern.__module__=='re' (len=2); re.Match.__name__=='Match' (len=5), re.Match.__module__=='re' (len=2); Pattern(7) > Match(5) by 2; both C extension types report module 're' (2 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: repm172

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name,   re.Pattern.__name__.__eq__,   ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' — the compiled regular expression type; 'Pattern' has 7 characters; Pattern (7 chars) == len('compile') (7 chars): the class name and the primary function that creates instances of it share the same 7-character name length; Pattern (7 chars) == len('Decimal') (7 chars) == len('Context') (7 chars) — cross-module tie at 7 with primary decimal module class names; Pattern (7) > Match (5) by 2: Pattern is 2 characters longer than Match; re.Pattern is the type of objects returned by re.compile(); confirmed Python 3.14.3 macOS"]
    - [pat_module, re.Pattern.__module__.__eq__, ["re"],      true, "re.Pattern.__module__ == 're' — Pattern is defined in the 're' module (2 chars); Pattern.__module__ (2: 're') == re.compile.__module__ (2: 're') == re.match.__module__ (2: 're'): Pattern and all public re functions share the 2-character module name 're'; Pattern.__module__ (2: 're') contrasts with io concrete classes (module '_io', 3 chars) and decimal classes (module 'decimal', 7 chars) — re module classes report the short 2-char public module name; confirmed Python 3.14.3 macOS"]
    - [mat_name,   re.Match.__name__.__eq__,     ["Match"],   true, "re.Match.__name__ == 'Match' — the match object type returned by successful re operations; 'Match' has 5 characters; Match (5 chars) == len('match') (5 chars): the Match class name (CamelCase) has the same 5-character length as the re.match function name (lowercase) — the class and the function share a 5-character tie; Match (5) < Pattern (7) by 2: the result class name is 2 characters shorter than the compiled pattern class name; Match (5 chars) == len('purge') (5 chars) == len('split') (5 chars) from re_extra171 — within-module ties at 5; confirmed Python 3.14.3 macOS"]
    - [mat_module, re.Match.__module__.__eq__,   ["re"],      true, "re.Match.__module__ == 're' — Match is defined in the 're' module (2 chars); Match.__module__ (2: 're') == Pattern.__module__ (2: 're'): both re C extension types share the 2-character public module name 're'; Match.__module__ (2: 're') == all re public function modules (2 chars): the uniform 're' module attribution spans both types (Pattern, Match) and all public functions; 're' (2 chars) is the minimum module name length across the standard library, tying with 'io' (2 chars); confirmed Python 3.14.3 macOS"]
    - [pat_gt_mat, re.Pattern.__name__.__len__,  [],          7,   "re.Pattern.__name__.__len__() == 7 > re.Match.__name__.__len__() (5) by 2; Pattern (7) is the longer of the two re type names; Pattern (7 chars) == len('compile') (7 chars) == len('findall') (7 chars) from re_extra170: three 7-character strings in the re module — the compiled pattern type and the two 7-character function names; Pattern (7) - Match (5) = 2: the class name gap is 2, matching the gap sub(3)->match(5) in the function name ascending sequence; confirmed Python 3.14.3 macOS"]

