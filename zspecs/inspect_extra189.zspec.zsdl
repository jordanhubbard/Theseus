spec: inspect_extra189
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Signature.parameters.fget.__name__ == 'parameters' (len=10); verified with Python 3.14.3."
    - "inspect.Signature.return_annotation.fget.__name__ == 'return_annotation' (len=17); verified with Python 3.14.3."
    - "inspect.Signature.parameters.fget.__module__ == 'inspect'; verified with Python 3.14.3."
    - "inspect.Signature.parameters.fget.__qualname__ == 'Signature.parameters' (len=20); verified with Python 3.14.3."
    - "inspect.Signature.return_annotation.fget.__qualname__ == 'Signature.return_annotation' (len=27); verified with Python 3.14.3."
    - "inspect.Signature.empty.__class__.__name__ == 'type' — Signature.empty is a class (the sentinel _empty); verified with Python 3.14.3."
    - "inspect.BoundArguments.args.fget.__name__ == 'args' (len=4); verified with Python 3.14.3."
    - "inspect.BoundArguments.kwargs.fget.__name__ == 'kwargs' (len=6); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature property getter __name__ and __module__
#
# inspect.Signature.parameters.fget.__name__    == 'parameters'  (len=10)
# inspect.Signature.return_annotation.fget.__name__ == 'return_annotation' (len=17)
# inspect.Signature.parameters.fget.__module__ == 'inspect'
#
# Signature.parameters and Signature.return_annotation are properties;
# .fget gives the underlying getter function. New to extra189.
# ---------------------------------------------------------------------------

table inspect_extra189.signature_property_names:
  description: "Signature.parameters.fget.__name__=='parameters' (len=10); Signature.return_annotation.fget.__name__=='return_annotation' (len=17); Signature.parameters.fget.__module__=='inspect'; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsigprops189

  columns: [id, function, args, expected, description]
  rows:
    - [params_name_eq,
       Signature.parameters.fget.__name__.__eq__,
       ["parameters"],
       true,
       "inspect.Signature.parameters.fget.__name__.__eq__('parameters') == True — the getter function's __name__ is 'parameters' (len=10); str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [params_name_len,
       Signature.parameters.fget.__name__.__len__,
       [],
       10,
       "inspect.Signature.parameters.fget.__name__.__len__() == 10 — 'parameters' has 10 characters: p-a-r-a-m-e-t-e-r-s; str.__len__() returns 10; verified with Python 3.14.3; new to extra189"]
    - [ret_ann_name_eq,
       Signature.return_annotation.fget.__name__.__eq__,
       ["return_annotation"],
       true,
       "inspect.Signature.return_annotation.fget.__name__.__eq__('return_annotation') == True — the getter function's __name__ is 'return_annotation' (len=17); str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [ret_ann_name_len,
       Signature.return_annotation.fget.__name__.__len__,
       [],
       17,
       "inspect.Signature.return_annotation.fget.__name__.__len__() == 17 — 'return_annotation' has 17 characters: r-e-t-u-r-n-_-a-n-n-o-t-a-t-i-o-n; str.__len__() returns 17; verified with Python 3.14.3; new to extra189"]
    - [params_module_eq,
       Signature.parameters.fget.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.parameters.fget.__module__.__eq__('inspect') == True — getter is defined in the inspect module; str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature property getter __qualname__ values
#
# inspect.Signature.parameters.fget.__qualname__         == 'Signature.parameters'  (len=20)
# inspect.Signature.return_annotation.fget.__qualname__  == 'Signature.return_annotation'  (len=27)
#
# The __qualname__ of a property getter includes the class name as prefix.
# New to extra189.
# ---------------------------------------------------------------------------

table inspect_extra189.signature_property_qualnames:
  description: "Signature.parameters.fget.__qualname__=='Signature.parameters' (len=20); Signature.return_annotation.fget.__qualname__=='Signature.return_annotation' (len=27); new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsigprops189

  columns: [id, function, args, expected, description]
  rows:
    - [params_qual_eq,
       Signature.parameters.fget.__qualname__.__eq__,
       ["Signature.parameters"],
       true,
       "inspect.Signature.parameters.fget.__qualname__.__eq__('Signature.parameters') == True — qualified name includes class prefix; str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [params_qual_len,
       Signature.parameters.fget.__qualname__.__len__,
       [],
       20,
       "inspect.Signature.parameters.fget.__qualname__.__len__() == 20 — 'Signature.parameters' has 20 characters; str.__len__() returns 20; verified with Python 3.14.3; new to extra189"]
    - [ret_ann_qual_eq,
       Signature.return_annotation.fget.__qualname__.__eq__,
       ["Signature.return_annotation"],
       true,
       "inspect.Signature.return_annotation.fget.__qualname__.__eq__('Signature.return_annotation') == True — qualified name includes class prefix; str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [ret_ann_qual_len,
       Signature.return_annotation.fget.__qualname__.__len__,
       [],
       27,
       "inspect.Signature.return_annotation.fget.__qualname__.__len__() == 27 — 'Signature.return_annotation' has 27 characters; str.__len__() returns 27; verified with Python 3.14.3; new to extra189"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature.empty and BoundArguments property getter names
#
# inspect.Signature.empty.__class__.__name__    == 'type'
# inspect.BoundArguments.args.fget.__name__     == 'args'    (len=4)
# inspect.BoundArguments.kwargs.fget.__name__   == 'kwargs'  (len=6)
#
# Signature.empty is a class-level sentinel whose __class__ is 'type'.
# BoundArguments.args and BoundArguments.kwargs are properties.
# New to extra189.
# ---------------------------------------------------------------------------

table inspect_extra189.empty_and_boundarguments:
  description: "Signature.empty.__class__.__name__=='type'; BoundArguments.args.fget.__name__=='args' (len=4); BoundArguments.kwargs.fget.__name__=='kwargs' (len=6); new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsigprops189

  columns: [id, function, args, expected, description]
  rows:
    - [empty_class_eq,
       Signature.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Signature.empty.__class__.__name__.__eq__('type') == True — Signature.empty is a class (the _empty sentinel type); __class__.__name__ is 'type'; str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [ba_args_name_eq,
       BoundArguments.args.fget.__name__.__eq__,
       ["args"],
       true,
       "inspect.BoundArguments.args.fget.__name__.__eq__('args') == True — getter function's __name__ is 'args' (len=4); str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [ba_args_name_len,
       BoundArguments.args.fget.__name__.__len__,
       [],
       4,
       "inspect.BoundArguments.args.fget.__name__.__len__() == 4 — 'args' has 4 characters: a-r-g-s; str.__len__() returns 4; verified with Python 3.14.3; new to extra189"]
    - [ba_kwargs_name_eq,
       BoundArguments.kwargs.fget.__name__.__eq__,
       ["kwargs"],
       true,
       "inspect.BoundArguments.kwargs.fget.__name__.__eq__('kwargs') == True — getter function's __name__ is 'kwargs' (len=6); str.__eq__ returns True; verified with Python 3.14.3; new to extra189"]
    - [ba_kwargs_name_len,
       BoundArguments.kwargs.fget.__name__.__len__,
       [],
       6,
       "inspect.BoundArguments.kwargs.fget.__name__.__len__() == 6 — 'kwargs' has 6 characters: k-w-a-r-g-s; str.__len__() returns 6; verified with Python 3.14.3; new to extra189"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra189
# ---------------------------------------------------------------------------

invariant inspect_extra189.signature_params_fget_name_eq:
  description: "inspect.Signature.parameters.fget.__name__.__eq__('parameters') == True — property getter's __name__ is 'parameters' (len=10: p-a-r-a-m-e-t-e-r-s); verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: Signature.parameters.fget.__name__.__eq__
  args: ["parameters"]
  expected: true

invariant inspect_extra189.signature_ret_ann_fget_name_eq:
  description: "inspect.Signature.return_annotation.fget.__name__.__eq__('return_annotation') == True — property getter's __name__ is 'return_annotation' (len=17); verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: Signature.return_annotation.fget.__name__.__eq__
  args: ["return_annotation"]
  expected: true

invariant inspect_extra189.signature_params_fget_module_eq:
  description: "inspect.Signature.parameters.fget.__module__.__eq__('inspect') == True — getter function is defined in the inspect module; verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: Signature.parameters.fget.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra189.signature_params_fget_qualname_eq:
  description: "inspect.Signature.parameters.fget.__qualname__.__eq__('Signature.parameters') == True — qualname includes class prefix; len=20; verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: Signature.parameters.fget.__qualname__.__eq__
  args: ["Signature.parameters"]
  expected: true

invariant inspect_extra189.signature_ret_ann_fget_qualname_eq:
  description: "inspect.Signature.return_annotation.fget.__qualname__.__eq__('Signature.return_annotation') == True — qualname includes class prefix; len=27; verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: Signature.return_annotation.fget.__qualname__.__eq__
  args: ["Signature.return_annotation"]
  expected: true

invariant inspect_extra189.signature_empty_class_name_eq:
  description: "inspect.Signature.empty.__class__.__name__.__eq__('type') == True — Signature.empty is a class-level sentinel whose metaclass is type; verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: Signature.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra189.boundarguments_args_fget_name_eq:
  description: "inspect.BoundArguments.args.fget.__name__.__eq__('args') == True — property getter's __name__ is 'args' (len=4: a-r-g-s); verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: BoundArguments.args.fget.__name__.__eq__
  args: ["args"]
  expected: true

invariant inspect_extra189.boundarguments_kwargs_fget_name_eq:
  description: "inspect.BoundArguments.kwargs.fget.__name__.__eq__('kwargs') == True — property getter's __name__ is 'kwargs' (len=6: k-w-a-r-g-s); verified with Python 3.14.3; new to extra189"
  category: identity
  kind: python_call_eq
  function: BoundArguments.kwargs.fget.__name__.__eq__
  args: ["kwargs"]
  expected: true
