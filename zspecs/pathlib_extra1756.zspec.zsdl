spec: pathlib_extra1756
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "pathlib.PurePath: defines __truediv__ and __rtruediv__ for the path-joining / operator (e.g. PurePath('/a') / 'b' == PurePath('/a/b')); these are path-concatenation operators, NOT numeric division — __truediv__ is repurposed for path joining, not arithmetic."
    - "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — path-joining operator is present."
    - "pathlib.PurePath.__dict__.__contains__('__rtruediv__') == True — reflected path-joining operator is present."
    - "pathlib.PurePath.__dict__.__contains__('__add__') == False — no numeric addition."
    - "pathlib.PurePath.__dict__.__contains__('__sub__') == False — no numeric subtraction."
    - "pathlib.PurePath.__dict__.__contains__('__mul__') == False — no numeric multiplication."
    - "pathlib.PurePath.__dict__.__contains__('__floordiv__') == False — no floor division (// is not used for paths)."
    - "pathlib.PurePath.__dict__.__contains__('__pow__') == False — no exponentiation."
    - "pathlib.PurePath.__dict__.__contains__('__neg__') == False — no unary negation."
    - "pathlib.PurePath.__dict__.__contains__('__pos__') == False — no unary positive."
    - "pathlib.PurePosixPath: subclass of PurePath — does not redefine __truediv__ or __rtruediv__ in its own __dict__."
    - "pathlib.PureWindowsPath: subclass of PurePath — does not redefine __truediv__ or __rtruediv__ in its own __dict__."
    - "pathlib.Path: concrete path type — inherits __truediv__/__rtruediv__ from PurePath but does not redefine them in its own __dict__."
    - "The __truediv__ in PurePath is semantically a path-join operator, not a numeric operator; it raises TypeError on non-path arguments."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence for pathlib.PurePath
#
# Wave 564 theme: which pathlib types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# pathlib.PurePath defines __truediv__ and __rtruediv__ for the / path-joining
# operator. These are the ONLY arithmetic-protocol dunders present. They are
# NOT numeric operators: PurePath.__truediv__ implements path concatenation
# (PurePath('/a') / 'b') and raises TypeError for non-path right-hand sides.
# __floordiv__ is NOT defined — the // operator is not used for paths.
# All other arithmetic dunders (__add__, __sub__, __mul__, __pow__, __neg__,
# __pos__) are absent.
# ---------------------------------------------------------------------------

table pathlib_extra1756.PurePath_arithmetic_operators:
  description: "pathlib.PurePath arithmetic operator dict-presence: __truediv__==True (path-join, not numeric), __rtruediv__==True (reflected path-join); all other arithmetic dunders False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1756

  columns: [id, function, args, expected]
  rows:
    - ["pl1756001", "pathlib.PurePath.__dict__.__contains__", ["__add__"], false]
    - ["pl1756002", "pathlib.PurePath.__dict__.__contains__", ["__sub__"], false]
    - ["pl1756003", "pathlib.PurePath.__dict__.__contains__", ["__mul__"], false]
    - ["pl1756004", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pl1756005", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pl1756006", "pathlib.PurePath.__dict__.__contains__", ["__floordiv__"], false]
    - ["pl1756007", "pathlib.PurePath.__dict__.__contains__", ["__pow__"], false]
    - ["pl1756008", "pathlib.PurePath.__dict__.__contains__", ["__neg__"], false]
    - ["pl1756009", "pathlib.PurePath.__dict__.__contains__", ["__pos__"], false]

# ---------------------------------------------------------------------------
# Table 2: arithmetic operator protocol dict-presence for pathlib subclasses
#
# pathlib.PurePosixPath and pathlib.PureWindowsPath are subclasses of
# PurePath. They inherit __truediv__ and __rtruediv__ from PurePath but do
# NOT redefine them in their own __dict__. pathlib.Path (concrete) also
# inherits from PurePath and does not redefine the path-join operators.
# All subclasses have all arithmetic dunders absent from their own __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra1756.subclass_arithmetic_operators:
  description: "pathlib subclass arithmetic operator dict-presence: PurePosixPath, PureWindowsPath, Path do not redefine path-join operators or any arithmetic dunders in their own __dict__ — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1756

  columns: [id, function, args, expected]
  rows:
    - ["pl1756010", "pathlib.PurePosixPath.__dict__.__contains__", ["__truediv__"], false]
    - ["pl1756011", "pathlib.PurePosixPath.__dict__.__contains__", ["__rtruediv__"], false]
    - ["pl1756012", "pathlib.PurePosixPath.__dict__.__contains__", ["__add__"], false]
    - ["pl1756013", "pathlib.PurePosixPath.__dict__.__contains__", ["__mul__"], false]
    - ["pl1756014", "pathlib.PureWindowsPath.__dict__.__contains__", ["__truediv__"], false]
    - ["pl1756015", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rtruediv__"], false]
    - ["pl1756016", "pathlib.PureWindowsPath.__dict__.__contains__", ["__add__"], false]
    - ["pl1756017", "pathlib.Path.__dict__.__contains__", ["__truediv__"], false]
    - ["pl1756018", "pathlib.Path.__dict__.__contains__", ["__rtruediv__"], false]
    - ["pl1756019", "pathlib.Path.__dict__.__contains__", ["__add__"], false]
    - ["pl1756020", "pathlib.Path.__dict__.__contains__", ["__sub__"], false]
    - ["pl1756021", "pathlib.Path.__dict__.__contains__", ["__floordiv__"], false]
    - ["pl1756022", "pathlib.Path.__dict__.__contains__", ["__neg__"], false]
    - ["pl1756023", "pathlib.Path.__dict__.__contains__", ["__pos__"], false]
