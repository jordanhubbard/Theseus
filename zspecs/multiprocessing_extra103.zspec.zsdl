spec: multiprocessing_extra103
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra102.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing Queue method qualnames and code attributes, Pool method qualnames, and Process method qualnames. NEW in extra103: multiprocessing.queues.Queue.get.__qualname__=='Queue.get' (len=9, co_argcount=3); multiprocessing.queues.Queue.put.__qualname__=='Queue.put' (len=9, co_argcount=4); multiprocessing.queues.Queue.empty.__qualname__=='Queue.empty' (len=11, co_argcount=1); multiprocessing.pool.Pool.apply_async.__qualname__=='Pool.apply_async' (len=16, longest Pool method qualname); multiprocessing.pool.Pool.__init__.__qualname__=='Pool.__init__' (len=13, co_argcount=6); multiprocessing.pool.Pool.map.__qualname__=='Pool.map' (len=8, shortest Pool method qualname); multiprocessing.Process.__init__.__qualname__=='BaseProcess.__init__' (len=20, longest Process method qualname); multiprocessing.Process.start.__qualname__=='BaseProcess.start' (len=17); multiprocessing.Process.run.__qualname__=='BaseProcess.run' (len=15, shortest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__qualname__ == 'BaseProcess.__init__'. Process.__init__ is inherited from BaseProcess (Lib/multiprocessing/process.py), so the qualname uses 'BaseProcess.' as prefix, not 'Process.'. The same applies to start, run, and join. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.queues.Queue is the correct class for multiprocessing Queue method introspection. The top-level multiprocessing.Queue is a function that returns a Queue instance, not the class itself. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.apply_async.__qualname__.__len__() == 16. 'Pool.apply_async' = 'Pool.'=5 + 'apply_async'=11 = 16. This is the longest Pool method qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue method __qualname__ and co_argcount — extra103
#
# Wave 254 theme: multiprocessing Queue method qualnames and code attributes.
#
# multiprocessing.queues.Queue.get.__qualname__    == 'Queue.get'    (len=9,  co_argcount=3)
# multiprocessing.queues.Queue.put.__qualname__    == 'Queue.put'    (len=9,  co_argcount=4)
# multiprocessing.queues.Queue.empty.__qualname__  == 'Queue.empty'  (len=11, co_argcount=1)
# multiprocessing.queues.Queue.full.__qualname__   == 'Queue.full'   (len=10, co_argcount=1)
# multiprocessing.queues.Queue.qsize.__qualname__  == 'Queue.qsize'  (len=11, co_argcount=1)
# ---------------------------------------------------------------------------

table multiprocessing_extra103.mp_queue_method_qualnames:
  description: "multiprocessing.queues.Queue method __qualname__ and co_argcount checks in mpqpool103 namespace — wave 254 theme: multiprocessing Queue methods are Python functions (class='function') defined in Lib/multiprocessing/queues.py; Queue.get.__qualname__.__eq__('Queue.get')==True (len=9: 'Queue.'=6+'get'=3; co_argcount=3: self, block, timeout); Queue.put.__qualname__.__eq__('Queue.put')==True (len=9: tied with get; co_argcount=4: self, obj, block, timeout); Queue.empty.__qualname__.__eq__('Queue.empty')==True (len=11: 'Queue.'=6+'empty'=5; co_argcount=1: self only); Queue.full.__qualname__.__eq__('Queue.full')==True (len=10: 'Queue.'=6+'full'=4; co_argcount=1); Queue.qsize.__qualname__.__eq__('Queue.qsize')==True (len=11: tied with empty; co_argcount=1); Queue.__module__=='multiprocessing.queues'; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: mpqpool103

  columns: [id, function, args, expected, description]
  rows:
    - [q_get_qn_eq,    multiprocessing.queues.Queue.get.__qualname__.__eq__,    ["Queue.get"],   true, "multiprocessing.queues.Queue.get.__qualname__ == 'Queue.get' (len=9, co_argcount=3); verified with Python 3.14.3"]
    - [q_get_qn_len,   multiprocessing.queues.Queue.get.__qualname__.__len__,   [],              9,    "multiprocessing.queues.Queue.get.__qualname__.__len__() == 9 ('Queue.'=6+'get'=3); verified with Python 3.14.3"]
    - [q_get_argc,     multiprocessing.queues.Queue.get.__code__.co_argcount.__eq__, [3],        true, "multiprocessing.queues.Queue.get.__code__.co_argcount == 3 (self, block, timeout); verified with Python 3.14.3"]
    - [q_put_qn_eq,    multiprocessing.queues.Queue.put.__qualname__.__eq__,    ["Queue.put"],   true, "multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put' (len=9, tied with get; co_argcount=4); verified with Python 3.14.3"]
    - [q_put_argc,     multiprocessing.queues.Queue.put.__code__.co_argcount.__eq__, [4],        true, "multiprocessing.queues.Queue.put.__code__.co_argcount == 4 (self, obj, block, timeout); verified with Python 3.14.3"]
    - [q_empty_qn_eq,  multiprocessing.queues.Queue.empty.__qualname__.__eq__,  ["Queue.empty"], true, "multiprocessing.queues.Queue.empty.__qualname__ == 'Queue.empty' (len=11, co_argcount=1); verified with Python 3.14.3"]
    - [q_empty_qn_len, multiprocessing.queues.Queue.empty.__qualname__.__len__, [],              11,   "multiprocessing.queues.Queue.empty.__qualname__.__len__() == 11 (tied with qsize); verified with Python 3.14.3"]
    - [q_full_qn_eq,   multiprocessing.queues.Queue.full.__qualname__.__eq__,   ["Queue.full"],  true, "multiprocessing.queues.Queue.full.__qualname__ == 'Queue.full' (len=10); verified with Python 3.14.3"]
    - [q_qsize_qn_eq,  multiprocessing.queues.Queue.qsize.__qualname__.__eq__,  ["Queue.qsize"], true, "multiprocessing.queues.Queue.qsize.__qualname__ == 'Queue.qsize' (len=11, tied with empty); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method __qualname__ and co_argcount — extra103
#
# Wave 254 theme: multiprocessing Pool method qualnames.
#
# multiprocessing.pool.Pool.map.__qualname__         == 'Pool.map'         (len=8,  co_argcount=4)
# multiprocessing.pool.Pool.apply.__qualname__       == 'Pool.apply'       (len=10, co_argcount=4)
# multiprocessing.pool.Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16, longest)
# multiprocessing.pool.Pool.close.__qualname__       == 'Pool.close'       (len=10, co_argcount=1)
# multiprocessing.pool.Pool.__init__.__qualname__    == 'Pool.__init__'    (len=13, co_argcount=6)
# ---------------------------------------------------------------------------

table multiprocessing_extra103.mp_pool_method_qualnames:
  description: "multiprocessing.pool.Pool method __qualname__ checks in mpqpool103 namespace — wave 254 theme: Pool methods are Python functions defined in Lib/multiprocessing/pool.py; Pool.map.__qualname__.__eq__('Pool.map')==True (len=8: 'Pool.'=5+'map'=3; co_argcount=4: self, func, iterable, chunksize); Pool.apply.__qualname__.__eq__('Pool.apply')==True (len=10: 'Pool.'=5+'apply'=5; co_argcount=4: self, func, args, kwds); Pool.apply_async.__qualname__.__eq__('Pool.apply_async')==True (len=16: 'Pool.'=5+'apply_async'=11; co_argcount=6: self, func, args, kwds, callback, error_callback; longest Pool method qualname); Pool.close.__qualname__.__eq__('Pool.close')==True (len=10: tied with apply; co_argcount=1: self only); Pool.__init__.__qualname__.__eq__('Pool.__init__')==True (len=13: 'Pool.'=5+'__init__'=8; co_argcount=6); Pool.__module__=='multiprocessing.pool'; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: mpqpool103a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_map_qn_eq,    multiprocessing.pool.Pool.map.__qualname__.__eq__,          ["Pool.map"],         true, "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map' (len=8, shortest Pool method qualname; co_argcount=4); verified with Python 3.14.3"]
    - [pool_map_qn_len,   multiprocessing.pool.Pool.map.__qualname__.__len__,          [],                   8,    "multiprocessing.pool.Pool.map.__qualname__.__len__() == 8 (shortest Pool method qualname); verified with Python 3.14.3"]
    - [pool_apply_qn_eq,  multiprocessing.pool.Pool.apply.__qualname__.__eq__,         ["Pool.apply"],       true, "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply' (len=10; co_argcount=4); verified with Python 3.14.3"]
    - [pool_aasync_qn_eq, multiprocessing.pool.Pool.apply_async.__qualname__.__eq__,   ["Pool.apply_async"], true, "multiprocessing.pool.Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16, longest Pool method qualname; co_argcount=6); verified with Python 3.14.3"]
    - [pool_aasync_qn_ln, multiprocessing.pool.Pool.apply_async.__qualname__.__len__,  [],                   16,   "multiprocessing.pool.Pool.apply_async.__qualname__.__len__() == 16 ('Pool.'=5+'apply_async'=11, longest); verified with Python 3.14.3"]
    - [pool_close_qn_eq,  multiprocessing.pool.Pool.close.__qualname__.__eq__,         ["Pool.close"],       true, "multiprocessing.pool.Pool.close.__qualname__ == 'Pool.close' (len=10, tied with apply; co_argcount=1); verified with Python 3.14.3"]
    - [pool_init_qn_eq,   multiprocessing.pool.Pool.__init__.__qualname__.__eq__,      ["Pool.__init__"],    true, "multiprocessing.pool.Pool.__init__.__qualname__ == 'Pool.__init__' (len=13; co_argcount=6); verified with Python 3.14.3"]
    - [pool_init_qn_len,  multiprocessing.pool.Pool.__init__.__qualname__.__len__,     [],                   13,   "multiprocessing.pool.Pool.__init__.__qualname__.__len__() == 13 ('Pool.'=5+'__init__'=8); verified with Python 3.14.3"]
    - [pool_init_argc,    multiprocessing.pool.Pool.__init__.__code__.co_argcount.__eq__, [6],               true, "multiprocessing.pool.Pool.__init__.__code__.co_argcount == 6 (self, processes, initializer, initargs, maxtasksperchild, context); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process method __qualname__ values — extra103
#
# Process methods are inherited from BaseProcess (Lib/multiprocessing/process.py).
#
# multiprocessing.Process.__init__.__qualname__  == 'BaseProcess.__init__'  (len=20, longest)
# multiprocessing.Process.start.__qualname__     == 'BaseProcess.start'     (len=17)
# multiprocessing.Process.join.__qualname__      == 'BaseProcess.join'      (len=16)
# multiprocessing.Process.run.__qualname__       == 'BaseProcess.run'       (len=15, shortest)
# ---------------------------------------------------------------------------

table multiprocessing_extra103.mp_process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ checks in mpqpool103 namespace — wave 254 theme: Process methods are inherited from BaseProcess in Lib/multiprocessing/process.py so their qualnames use 'BaseProcess.' prefix; Process.__init__.__qualname__.__eq__('BaseProcess.__init__')==True (len=20: 'BaseProcess.'=12+'__init__'=8=20; co_argcount=6: self, group, target, name, args, kwargs); Process.start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess.'=12+'start'=5=17; co_argcount=1); Process.join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess.'=12+'join'=4=16; co_argcount=2: self, timeout); Process.run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess.'=12+'run'=3=15, shortest; co_argcount=1); Process.__module__=='multiprocessing.context'; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: mpqpool103b

  columns: [id, function, args, expected, description]
  rows:
    - [proc_init_qn_eq,  multiprocessing.Process.__init__.__qualname__.__eq__,  ["BaseProcess.__init__"], true, "multiprocessing.Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20, longest; inherited from BaseProcess); verified with Python 3.14.3"]
    - [proc_init_qn_len, multiprocessing.Process.__init__.__qualname__.__len__, [],                       20,   "multiprocessing.Process.__init__.__qualname__.__len__() == 20 (longest Process method qualname: 'BaseProcess.'=12+'__init__'=8); verified with Python 3.14.3"]
    - [proc_init_argc,   multiprocessing.Process.__init__.__code__.co_argcount.__eq__, [6],               true, "multiprocessing.Process.__init__.__code__.co_argcount == 6 (self, group, target, name, args, kwargs); verified with Python 3.14.3"]
    - [proc_start_qn_eq, multiprocessing.Process.start.__qualname__.__eq__,     ["BaseProcess.start"],   true, "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start' (len=17; inherited from BaseProcess); verified with Python 3.14.3"]
    - [proc_join_qn_eq,  multiprocessing.Process.join.__qualname__.__eq__,      ["BaseProcess.join"],    true, "multiprocessing.Process.join.__qualname__ == 'BaseProcess.join' (len=16; co_argcount=2: self, timeout); verified with Python 3.14.3"]
    - [proc_run_qn_eq,   multiprocessing.Process.run.__qualname__.__eq__,       ["BaseProcess.run"],     true, "multiprocessing.Process.run.__qualname__ == 'BaseProcess.run' (len=15, shortest Process method qualname; co_argcount=1); verified with Python 3.14.3"]
    - [proc_run_qn_len,  multiprocessing.Process.run.__qualname__.__len__,      [],                      15,   "multiprocessing.Process.run.__qualname__.__len__() == 15 (shortest: 'BaseProcess.'=12+'run'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra103
# ---------------------------------------------------------------------------

invariant multiprocessing_extra103.Process_init_qualname_uses_BaseProcess:
  description: "multiprocessing.Process.__init__.__qualname__.__eq__('BaseProcess.__init__') returns True — Process.__init__ is inherited from BaseProcess (Lib/multiprocessing/process.py); the qualname 'BaseProcess.__init__' (len=20: 'BaseProcess.'=12 + '__init__'=8 = 20) uses 'BaseProcess.' as prefix, not 'Process.'; all four Process methods examined in this spec (start, run, join, __init__) have 'BaseProcess.' prefix because Process is a subclass of BaseProcess; Process.__init__.__code__.co_argcount==6 (self, group, target, name, args, kwargs); Process.__module__ is 'multiprocessing.context'; NEW in extra103: first standalone Process.__init__ qualname invariant in mpqpool103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__qualname__.__eq__
  args: ["BaseProcess.__init__"]
  expected: true

invariant multiprocessing_extra103.Pool_apply_async_qualname_longest:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__len__() == 16 — Pool.apply_async.__qualname__ is 'Pool.apply_async' (16 chars: 'Pool.'=5 + 'apply_async'=11 = 16); this is the longest Pool method qualname in this spec; compare Pool method qualname lengths: map=8, apply=10, close=10, __init__=13, apply_async=16 (longest); Pool.apply_async.__code__.co_argcount==6 (self, func, args, kwds, callback, error_callback); Pool.apply_async is the non-blocking variant of apply — it submits a call to the pool worker and immediately returns an AsyncResult; Pool.__module__ is 'multiprocessing.pool'; NEW in extra103: first standalone Pool.apply_async qualname length invariant in mpqpool103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.pool.Pool.apply_async.__qualname__.__len__
  args: []
  expected: 16

invariant multiprocessing_extra103.Queue_get_co_argcount_3:
  description: "multiprocessing.queues.Queue.get.__code__.co_argcount == 3 — Queue.get is defined as 'def get(self, block=True, timeout=None)' in Lib/multiprocessing/queues.py; co_argcount==3 (self, block, timeout); compare: Queue.put.__code__.co_argcount==4 (self, obj, block, timeout — one more than get); Queue.empty and Queue.qsize have co_argcount==1 (self only); Queue.get.__qualname__ is 'Queue.get' (len=9); Queue.__module__ is 'multiprocessing.queues'; get() removes and returns an item from the queue, blocking by default; NEW in extra103: first standalone Queue.get co_argcount invariant in mpqpool103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.queues.Queue.get.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant multiprocessing_extra103.Process_run_qualname_shortest:
  description: "multiprocessing.Process.run.__qualname__.__len__() == 15 — Process.run.__qualname__ is 'BaseProcess.run' (15 chars: 'BaseProcess.'=12 + 'run'=3 = 15); this is the shortest Process method qualname in this spec; compare Process method qualname lengths: run=15 (shortest), join=16, start=17, __init__=20 (longest); Process.run.__code__.co_argcount==1 (self only); run() overrides should call the target function — it is invoked by start() in the child process; Process.run inherits from BaseProcess.run (Lib/multiprocessing/process.py); NEW in extra103: first standalone Process.run qualname shortest invariant in mpqpool103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.Process.run.__qualname__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra103.Pool_map_qualname_shortest:
  description: "multiprocessing.pool.Pool.map.__qualname__.__len__() == 8 — Pool.map.__qualname__ is 'Pool.map' (8 chars: 'Pool.'=5 + 'map'=3 = 8); this is the shortest Pool method qualname in this spec; compare Pool method qualname lengths: map=8 (shortest), apply=10, close=10, __init__=13, apply_async=16 (longest); Pool.map.__code__.co_argcount==4 (self, func, iterable, chunksize); map() applies func to every item in iterable, blocking until all results are ready; Pool.__module__ is 'multiprocessing.pool'; NEW in extra103: first standalone Pool.map qualname shortest invariant in mpqpool103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map.__qualname__.__len__
  args: []
  expected: 8
