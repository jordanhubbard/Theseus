invariant io_extra201.bytesio_getvalue_qualname_eq:
  description: "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — the qualified name (len=16) confirms getvalue belongs to BytesIO; getvalue returns the entire contents of the buffer; confirmed Python 3.14.3 macOS"
