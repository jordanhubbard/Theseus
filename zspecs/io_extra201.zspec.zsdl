spec: io_extra201
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers io.BytesIO class identity attributes not covered by io_extra.zspec.zsdl or other io_extra specs."
    - "io.BytesIO.__name__ == 'BytesIO' (len=7); BytesIO is the in-memory binary stream class; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__module__ == '_io' (len=3); BytesIO is implemented in the C extension module _io; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (len=15); BytesIO's direct base class is _BufferedIOBase; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__class__.__name__ == 'type' (len=4); BytesIO is a class object using the plain type metaclass; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' (len=16); qualified name confirms the method belongs to BytesIO; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read' (len=12); qualified name of the read method; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.write.__qualname__ == 'BytesIO.write' (len=13); qualified name of the write method; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (len=16); qualified name of the getvalue method; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

