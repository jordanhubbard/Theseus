    - [module_eq,      BytesIO.__module__.__eq__,             ["_io"],     true, "io.BytesIO.__module__ == '_io' (len=3); BytesIO is implemented in the C extension module _io; confirmed Python 3.14.3 macOS"]
    - [class_name_eq,  BytesIO.__class__.__name__.__eq__,     ["type"],    true, "io.BytesIO.__class__.__name__ == 'type' (len=4); BytesIO is a class using the plain type metaclass; confirmed Python 3.14.3 macOS"]
    - [name_len,       BytesIO.__name__.__len__,              [],          7,    "io.BytesIO.__name__.__len__() == 7 — B(1)y(2)t(3)e(4)s(5)I(6)O(7); confirmed Python 3.14.3 macOS"]
    - [module_len,     BytesIO.__module__.__len__,            [],          3,    "io.BytesIO.__module__.__len__() == 3 — _(1)i(2)o(3); confirmed Python 3.14.3 macOS"]

