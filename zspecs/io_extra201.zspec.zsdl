# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra201.bytesio_name_eq:
  description: "io.BytesIO.__name__ == 'BytesIO' — BytesIO is the in-memory binary stream class; __name__ confirms the public class name (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra201.bytesio_module_eq:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the C extension module _io (len=3); the public io module re-exports it; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra201.bytesio_base_name_eq:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO's direct base class is _BufferedIOBase (len=15); this is the C-level abstract buffered I/O base; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra201.bytesio_class_name_type:
  description: "io.BytesIO.__class__.__name__ == 'type' — BytesIO uses the plain type metaclass (len=4); it is a regular Python class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra201.bytesio_init_qualname_eq:
  description: "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' — the qualified name (len=16) confirms the __init__ method belongs to the BytesIO class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__init__.__qualname__.__eq__
  args: ["BytesIO.__init__"]
  expected: true

invariant io_extra201.bytesio_read_qualname_eq:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read' — the qualified name (len=12) confirms the read method belongs to BytesIO; confirmed Python 3.14.3 macOS"
  category: identity
