invariant io_extra201.bytesio_write_qualname_eq:
  description: "io.BytesIO.write.__qualname__ == 'BytesIO.write' — the qualified name (len=13) confirms the write method belongs to BytesIO; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
