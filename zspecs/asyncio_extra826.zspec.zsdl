spec: asyncio_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython asyncio source"
    - "Python docs: asyncio.Task"
    - "Python docs: asyncio.Future"
  not_derived_from:
    - "any third-party asyncio wrapper"
  notes:
    - "Covers method __qualname__ identity for Task and Future classes"
    - "All rows verify string equality via __qualname__.__eq__"
  created_at: "2026-04-12"

table asyncio_extra826.task_qualnames:
  description: "asyncio.Task method __qualname__ identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: as826tt
  columns: [id, function, args, expected]
  rows:
    - [as826tt001, asyncio.Task.cancel.__qualname__.__eq__, ["Task.cancel"], true]
    - [as826tt002, asyncio.Task.result.__qualname__.__eq__, ["Task.result"], true]
    - [as826tt003, asyncio.Task.exception.__qualname__.__eq__, ["Task.exception"], true]
    - [as826tt004, asyncio.Task.done.__qualname__.__eq__, ["Task.done"], true]
    - [as826tt005, asyncio.Task.cancelled.__qualname__.__eq__, ["Task.cancelled"], true]
    - [as826tt006, asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true]

