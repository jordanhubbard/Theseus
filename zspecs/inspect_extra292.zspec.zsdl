spec: inspect_extra292
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — FullArgSpec, Attribute, FrameInfo, Traceback namedtuple field counts; Parameter kind enum values"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "FullArgSpec has 7 fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations"
    - "Attribute has 4 fields: name, kind, defining_class, object"
    - "FrameInfo has 6 fields: frame, filename, lineno, function, code_context, index"
    - "Traceback has 5 fields: filename, lineno, function, code_context, index"
    - "ArgSpec was removed in Python 3.11; not covered here"
    - "Parameter kind values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra292.parameter_kinds:
  description: "inspect.Parameter kind enum integer values"
  kind: python_call_eq
  category: identity
  id_prefix: ine292a

  columns: [id, function, args, expected, description]
  rows:
    - [ine292a001, inspect.Parameter.POSITIONAL_ONLY.__eq__, [0], true, "POSITIONAL_ONLY == 0"]
    - [ine292a002, inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__, [1], true, "POSITIONAL_OR_KEYWORD == 1"]
    - [ine292a003, inspect.Parameter.VAR_POSITIONAL.__eq__, [2], true, "VAR_POSITIONAL == 2"]
    - [ine292a004, inspect.Parameter.KEYWORD_ONLY.__eq__, [3], true, "KEYWORD_ONLY == 3"]
    - [ine292a005, inspect.Parameter.VAR_KEYWORD.__eq__, [4], true, "VAR_KEYWORD == 4"]

table inspect_extra292.namedtuple_field_counts:
  description: "Field counts for inspect namedtuple classes"
  kind: python_call_eq
  category: identity
  id_prefix: ine292b

  columns: [id, function, args, expected, description]
  rows:
    - [ine292b001, inspect.FullArgSpec._fields.__len__, [], 7, "FullArgSpec has 7 fields"]
    - [ine292b002, inspect.Attribute._fields.__len__, [], 4, "Attribute has 4 fields"]
    - [ine292b003, inspect.FrameInfo._fields.__len__, [], 6, "FrameInfo has 6 fields"]
    - [ine292b004, inspect.Traceback._fields.__len__, [], 5, "Traceback has 5 fields"]

invariant inspect_extra292.positional_only_is_zero:
  description: "inspect.Parameter.POSITIONAL_ONLY == 0"
  category: identity
  kind: python_call_eq
  function: inspect.Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra292.var_keyword_is_four:
  description: "inspect.Parameter.VAR_KEYWORD == 4"
  category: identity
  kind: python_call_eq
  function: inspect.Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true

invariant inspect_extra292.fullargspec_seven_fields:
  description: "inspect.FullArgSpec._fields has 7 elements"
  category: identity
  kind: python_call_eq
  function: inspect.FullArgSpec._fields.__len__
  args: []
  expected: 7

invariant inspect_extra292.attribute_four_fields:
  description: "inspect.Attribute._fields has 4 elements"
  category: identity
  kind: python_call_eq
  function: inspect.Attribute._fields.__len__
  args: []
  expected: 4
