spec: struct_extra2626
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 struct documentation — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — covers struct.pack/unpack/calcsize correctness and error handling"
    - "struct_extra26.zspec.zsdl — covers struct module and Struct class identity"
  notes:
    - "Wave 622 (struct_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "Neither struct.Struct nor struct.error define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is a protocol method for sized iterators; Struct objects are format-string wrappers, not iterators."
    - "__missing__ is a dict subclass hook; neither Struct nor struct.error is a dict subclass."
    - "__reversed__ is an iterator protocol method; Struct objects do not support reverse iteration."
    - "struct.Struct DOES define pack/unpack/pack_into/unpack_from/size/format in its __dict__."
    - "struct.error is an exception class; its __dict__ contains __doc__ but not args/__str__/__repr__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — struct.Struct and struct.error
# ---------------------------------------------------------------------------

table struct_extra2626.no_length_hint_in_struct_classes:
  description: "__length_hint__ is absent from struct.Struct and struct.error __dict__s — struct objects are binary format wrappers, not sized iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2626

  columns: [id, function, args, expected]
  rows:
    - ["st2626001", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st2626002", "struct.error.__dict__.__contains__",  ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — struct.Struct and struct.error
# ---------------------------------------------------------------------------

table struct_extra2626.no_missing_in_struct_classes:
  description: "__missing__ is absent from struct.Struct and struct.error __dict__s — neither class is a dict subclass implementing missing-key lookup"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2626

  columns: [id, function, args, expected]
  rows:
    - ["st2626003", "struct.Struct.__dict__.__contains__", ["__missing__"], false]
    - ["st2626004", "struct.error.__dict__.__contains__",  ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — struct.Struct and struct.error
# ---------------------------------------------------------------------------

table struct_extra2626.no_reversed_in_struct_classes:
  description: "__reversed__ is absent from struct.Struct and struct.error __dict__s — struct classes do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2626

  columns: [id, function, args, expected]
  rows:
    - ["st2626005", "struct.Struct.__dict__.__contains__", ["__reversed__"], false]
    - ["st2626006", "struct.error.__dict__.__contains__",  ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: struct.Struct defines its core packing methods;
# struct.error defines __doc__ — confirming the classes are populated
# even though the three protocol methods are absent.
# ---------------------------------------------------------------------------

table struct_extra2626.struct_classes_have_core_attrs:
  description: "struct.Struct defines pack/unpack/pack_into/unpack_from/size/format in __dict__; struct.error defines __doc__ — but neither class defines __length_hint__/__missing__/__reversed__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2626

  columns: [id, function, args, expected]
  rows:
    - ["st2626007", "struct.Struct.__dict__.__contains__", ["pack"],            true]
    - ["st2626008", "struct.Struct.__dict__.__contains__", ["unpack"],          true]
    - ["st2626009", "struct.Struct.__dict__.__contains__", ["pack_into"],       true]
    - ["st2626010", "struct.Struct.__dict__.__contains__", ["unpack_from"],     true]
    - ["st2626011", "struct.Struct.__dict__.__contains__", ["size"],            true]
    - ["st2626012", "struct.Struct.__dict__.__contains__", ["format"],          true]
    - ["st2626013", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st2626014", "struct.Struct.__dict__.__contains__", ["__missing__"],     false]
    - ["st2626015", "struct.Struct.__dict__.__contains__", ["__reversed__"],    false]
    - ["st2626016", "struct.error.__dict__.__contains__",  ["__doc__"],         true]
    - ["st2626017", "struct.error.__dict__.__contains__",  ["__length_hint__"], false]
    - ["st2626018", "struct.error.__dict__.__contains__",  ["__missing__"],     false]
    - ["st2626019", "struct.error.__dict__.__contains__",  ["__reversed__"],    false]
