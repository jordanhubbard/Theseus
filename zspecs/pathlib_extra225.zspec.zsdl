spec: pathlib_extra225
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "This spec covers: Path method __name__ values for is_absolute, is_file, is_dir, exists; Path descriptor __class__.__name__ for stem, suffix, parent (all 'property'); PurePath.__module__; Path('/nonexistent/path/file.txt').exists() == False."
    - "pathlib.Path.is_absolute.__name__ == 'is_absolute' — defined on PurePath, accessible from Path."
    - "pathlib.Path.is_file.__name__ == 'is_file'."
    - "pathlib.Path.is_dir.__name__ == 'is_dir'."
    - "pathlib.Path.exists.__name__ == 'exists'."
    - "pathlib.Path.stem.__class__.__name__ == 'property' — stem is a property descriptor on PurePath."
    - "pathlib.Path.suffix.__class__.__name__ == 'property' — suffix is a property descriptor on PurePath."
    - "pathlib.Path.parent.__class__.__name__ == 'property' — parent is a property descriptor on PurePath."
    - "pathlib.PurePath.__module__ == 'pathlib'."
    - "pathlib.Path('/nonexistent/path/file.txt').exists() == False — non-existent path returns False."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path method __name__ values
# is_absolute is defined on PurePath and accessible on Path.
# is_file, is_dir, exists are defined on Path itself.
# ---------------------------------------------------------------------------

table pathlib_extra225.path_method_names:
  description: "Path method __name__ attribute values for is_absolute, is_file, is_dir, exists"
  kind: python_call_eq
  category: method_names
  id_prefix: plmethodnames225

  columns: [id, function, args, expected]
  rows:
    - [is_absolute_name, Path.is_absolute.__name__.__eq__, ["is_absolute"], true]
    - [is_file_name,     Path.is_file.__name__.__eq__,     ["is_file"],     true]
    - [is_dir_name,      Path.is_dir.__name__.__eq__,      ["is_dir"],      true]
    - [exists_name,      Path.exists.__name__.__eq__,      ["exists"],      true]

# ---------------------------------------------------------------------------
# Path property descriptor class names
# Path.stem, Path.suffix, and Path.parent are Python property descriptors
# defined on PurePath. Their __class__.__name__ is 'property'.
# ---------------------------------------------------------------------------

table pathlib_extra225.path_property_descriptor_types:
  description: "Path.stem, Path.suffix, Path.parent are all property descriptors"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plpropdesc225

  columns: [id, function, args, expected]
  rows:
    - [stem_is_property,   Path.stem.__class__.__name__.__eq__,   ["property"], true]
    - [suffix_is_property, Path.suffix.__class__.__name__.__eq__, ["property"], true]
    - [parent_is_property, Path.parent.__class__.__name__.__eq__, ["property"], true]

# ---------------------------------------------------------------------------
# PurePath module metadata
# ---------------------------------------------------------------------------

invariant pathlib_extra225.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib' — defined in the pathlib module"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# Path.exists() on non-existent path returns False
# Path('/nonexistent/path/file.txt') is a concrete path that does not exist.
# exists() performs a stat() syscall and returns False when the path is absent.
# ---------------------------------------------------------------------------

invariant pathlib_extra225.Path.exists.nonexistent:
  description: "Path('/nonexistent/path/file.txt').exists() == False — stat fails for absent path"
  category: predicates
  kind: python_call_eq
  function: Path
  args: ["/nonexistent/path/file.txt"]
  method: exists
  expected: false

# ---------------------------------------------------------------------------
# Standalone invariants confirming key method names
# ---------------------------------------------------------------------------

invariant pathlib_extra225.Path.is_absolute.name:
  description: "pathlib.Path.is_absolute.__name__ == 'is_absolute' — method defined on PurePath"
  category: method_names
  kind: python_call_eq
  function: Path.is_absolute.__name__.__eq__
  args: ["is_absolute"]
  expected: true

invariant pathlib_extra225.Path.exists.name:
  description: "pathlib.Path.exists.__name__ == 'exists'"
  category: method_names
  kind: python_call_eq
  function: Path.exists.__name__.__eq__
  args: ["exists"]
  expected: true

invariant pathlib_extra225.Path.stem.is_property:
  description: "pathlib.Path.stem.__class__.__name__ == 'property' — stem is a data descriptor"
  category: class_metadata
  kind: python_call_eq
  function: Path.stem.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra225.Path.suffix.is_property:
  description: "pathlib.Path.suffix.__class__.__name__ == 'property' — suffix is a data descriptor"
  category: class_metadata
  kind: python_call_eq
  function: Path.suffix.__class__.__name__.__eq__
  args: ["property"]
  expected: true
