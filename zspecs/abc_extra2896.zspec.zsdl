spec: ab2896
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [abc source, Python docs, https://docs.python.org/3/library/abc.html]
  not_derived_from: [abc_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, abc_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, abc_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence, any external dataset]
  notes: [Wave 640 theme — __itruediv__/__ifloordiv__/__imod__ dict-presence checks for abc module types. In-place divide, floor-divide, and modulo operators. ABC/ABCMeta/abstractmethod/abstractclassmethod/abstractstaticmethod are abstract base class infrastructure not numeric types — none define these dunders. abstractproperty excluded per campaign rules for 3.13+ removal. abstractclassmethod and abstractstaticmethod are deprecated but still present in Python 3.14.3. type(abc.abstractmethod(lambda: None)) yields function whose __dict__ also lacks these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table ab2896.itruediv:
