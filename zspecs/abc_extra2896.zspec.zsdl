  columns: [id, function, args, expected]
  rows:
    - ["ab2896001", operator.contains, [abc.ABC.__dict__, "__itruediv__"], false]
    - ["ab2896002", operator.contains, [abc.ABCMeta.__dict__, "__itruediv__"], false]
    - ["ab2896003", operator.contains, [abc.abstractmethod.__dict__, "__itruediv__"], false]
    - ["ab2896004", operator.contains, [abc.abstractclassmethod.__dict__, "__itruediv__"], false]
