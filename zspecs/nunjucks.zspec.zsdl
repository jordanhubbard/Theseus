spec: nunjucks
version: ">=3.0.0"
backend: node(nunjucks)

docs: https://mozilla.github.io/nunjucks/

provenance:
  derived_from:
    - "Nunjucks documentation — https://mozilla.github.io/nunjucks/"
    - "Test vectors verified with nunjucks via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "nunjucks source"
  notes:
    - "nunjucks is an npm package. Install: npm install nunjucks"
    - "nunjucks.renderString(template, context) renders a Nunjucks template with the given context."
    - "{{ val }} interpolates; {% for x in xs %}...{% endfor %} loops; {% if %}...{% endif %} conditionals."
    - "Filters: {{ val | upper }}, {{ val | lower }}, {{ val | trim }}, etc."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns rendered string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table nunjucks.renderString:
  kind: node_module_call_eq
  function: renderString
  category: renderString
  id_prefix: njr

  columns: [id, args, expected]
  rows:
    - [basic,  ["Hello {{ name }}!", {"name": "World"}],                              "Hello World!"]
    - [loop,   ["{% for x in items %}{{ x }} {% endfor %}", {"items": ["a","b","c"]}], "a b c "]
    - [cond,   ["{% if x > 0 %}pos{% else %}neg{% endif %}", {"x": 1}],               "pos"]
    - [upper,  ["{{ name | upper }}", {"name": "world"}],                             "WORLD"]
    - [lower,  ["{{ name | lower }}", {"name": "HELLO"}],                             "hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:06:17Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
