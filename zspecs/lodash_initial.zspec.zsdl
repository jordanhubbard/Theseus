spec: lodash_initial
version: ">=4.0.0"
backend: node(lodash.initial)

docs: https://lodash.com/docs/#initial

provenance:
  derived_from:
    - "lodash.initial README — https://www.npmjs.com/package/lodash.initial"
    - "Test vectors verified with lodash.initial@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.initial exports the _.initial function directly as module.exports."
    - "initial(array) returns all elements except the last."
    - "Returns [] for a single-element array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array. Returns [] for empty or single-element array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_initial.initial:
  kind: node_module_call_eq
  function: ~
  category: initial
  id_prefix: linit

  columns: [id, args, expected]
  rows:
    - [three_ints,  [[1, 2, 3]],       [1, 2]]
    - [single,      [[42]],            []]
    - [strings,     [["a", "b", "c"]], ["a", "b"]]

