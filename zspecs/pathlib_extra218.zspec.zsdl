spec: pathlib_extra218
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra.zspec.zsdl — covers pathlib.Path class metadata, PurePath, PosixPath, WindowsPath"
    - "pathlib_extra217.zspec.zsdl — covers pathlib.Path.__dict__ resolution and I/O methods"
  notes:
    - "pathlib.Path.__qualname__ == 'Path'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__qualname__ == 'PurePath'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'; confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath'; confirmed Python 3.14.3 macOS."
    - "__qualname__ is a plain str attribute on all pathlib classes; __qualname__.__class__.__name__ == 'str'."
    - "For top-level (non-nested) classes, __qualname__ equals __name__; both are 'Path', 'PurePath', etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __qualname__ equality for pure path classes
# PurePath, PurePosixPath, PureWindowsPath __qualname__ attribute checks
# ---------------------------------------------------------------------------

table pathlib_extra218.pure_path_qualname:
  description: "pathlib.PurePath, PurePosixPath, PureWindowsPath __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: pathlibqualname218

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_qualname,          pathlib.PurePath.__qualname__.__eq__,          ["PurePath"],          true,  "pathlib.PurePath.__qualname__.__eq__('PurePath') == True; PurePath is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_qualname,     pathlib.PurePosixPath.__qualname__.__eq__,     ["PurePosixPath"],     true,  "pathlib.PurePosixPath.__qualname__.__eq__('PurePosixPath') == True; PurePosixPath is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_qualname,   pathlib.PureWindowsPath.__qualname__.__eq__,   ["PureWindowsPath"],   true,  "pathlib.PureWindowsPath.__qualname__.__eq__('PureWindowsPath') == True; PureWindowsPath is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [purepath_qualname_false,    pathlib.PurePath.__qualname__.__eq__,          ["purepath"],          false, "pathlib.PurePath.__qualname__.__eq__('purepath') == False; qualname is case-sensitive; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __qualname__ equality for concrete path classes
# Path and PosixPath __qualname__ attribute checks
# ---------------------------------------------------------------------------

table pathlib_extra218.concrete_path_qualname:
  description: "pathlib.Path and PosixPath __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: pathlibqualname218

  columns: [id, function, args, expected, description]
  rows:
    - [path_qualname,            pathlib.Path.__qualname__.__eq__,      ["Path"],       true,  "pathlib.Path.__qualname__.__eq__('Path') == True; Path is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [posixpath_qualname,       pathlib.PosixPath.__qualname__.__eq__,  ["PosixPath"],  true,  "pathlib.PosixPath.__qualname__.__eq__('PosixPath') == True; PosixPath is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [path_qualname_false,      pathlib.Path.__qualname__.__eq__,      ["pathlib.Path"], false, "pathlib.Path.__qualname__.__eq__('pathlib.Path') == False; qualname does not include the module prefix; confirmed Python 3.14.3 macOS"]
    - [posixpath_qualname_false, pathlib.PosixPath.__qualname__.__eq__,  ["posixpath"],  false, "pathlib.PosixPath.__qualname__.__eq__('posixpath') == False; qualname is case-sensitive; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __qualname__ is a str — type checks for pathlib classes
# __qualname__ on all pathlib classes is a plain str object
# ---------------------------------------------------------------------------

table pathlib_extra218.qualname_type_checks:
  description: "pathlib class __qualname__ attributes are plain str objects"
  kind: python_call_eq
  category: class_metadata
  id_prefix: pathlibqualname218

  columns: [id, function, args, expected, description]
  rows:
    - [path_qualname_type,          pathlib.Path.__qualname__.__class__.__name__,          [],  "str",  "pathlib.Path.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on Path; confirmed Python 3.14.3 macOS"]
    - [purepath_qualname_type,      pathlib.PurePath.__qualname__.__class__.__name__,      [],  "str",  "pathlib.PurePath.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on PurePath; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_qualname_type, pathlib.PurePosixPath.__qualname__.__class__.__name__,  [],  "str",  "pathlib.PurePosixPath.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on PurePosixPath; confirmed Python 3.14.3 macOS"]
    - [posixpath_qualname_type,     pathlib.PosixPath.__qualname__.__class__.__name__,     [],  "str",  "pathlib.PosixPath.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on PosixPath; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra218.path_qualname:
  description: "pathlib.Path.__qualname__.__eq__('Path') == True — Path is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.Path.__qualname__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra218.purepath_qualname:
  description: "pathlib.PurePath.__qualname__.__eq__('PurePath') == True — PurePath is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.PurePath.__qualname__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra218.pureposixpath_qualname:
  description: "pathlib.PurePosixPath.__qualname__.__eq__('PurePosixPath') == True — PurePosixPath is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.PurePosixPath.__qualname__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra218.purewindowspath_qualname:
  description: "pathlib.PureWindowsPath.__qualname__.__eq__('PureWindowsPath') == True — PureWindowsPath is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__qualname__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra218.posixpath_qualname:
  description: "pathlib.PosixPath.__qualname__.__eq__('PosixPath') == True — PosixPath is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.PosixPath.__qualname__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra218.path_qualname_type:
  description: "pathlib.Path.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain str attribute on Path; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.Path.__qualname__.__class__.__name__
  args: []
  expected: "str"

invariant pathlib_extra218.path_qualname_not_dotted:
  description: "pathlib.Path.__qualname__.__eq__('pathlib.Path') == False — __qualname__ does not include the module prefix for top-level classes; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.Path.__qualname__.__eq__
  args: ["pathlib.Path"]
  expected: false

invariant pathlib_extra218.purepath_qualname_type:
  description: "pathlib.PurePath.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain str attribute on PurePath; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: pathlib.PurePath.__qualname__.__class__.__name__
  args: []
  expected: "str"
