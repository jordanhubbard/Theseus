spec: numbers_extra16
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra through numbers_extra15."
    - "numbers_extra15 covers Complex reflected operators, Rational.__float__, and Integral shift operators."
    - "No prior spec covers __qualname__ for the five ABC classes (Number, Complex, Real, Rational, Integral) as standalone invariants."
    - "No prior spec covers __module__ for any of the five ABC classes."
    - "No prior spec covers __bases__[0].__name__ for the five ABCs (inheritance chain: object→Number→Complex→Real→Rational→Integral)."
    - "No prior spec covers __abstractmethods__.__class__.__name__ (frozenset) or len(__abstractmethods__) for any ABC."
    - "Number has zero abstract methods; the count increases up the hierarchy to Integral (34)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC class __qualname__ values
#
# No prior numbers spec records __qualname__ for the five ABC classes as
# standalone invariants via __qualname__.__eq__.  Each is a top-level class
# in the numbers module; qualname equals the simple class name.
# ---------------------------------------------------------------------------

table numbers_extra16.abc_qualnames:
  kind: python_call_eq
  category: class_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__qualname__.__eq__,   ["Number"],   true, "numbers.Number.__qualname__ == 'Number'"]
    - [Complex,  Complex.__qualname__.__eq__,  ["Complex"],  true, "numbers.Complex.__qualname__ == 'Complex'"]
    - [Real,     Real.__qualname__.__eq__,     ["Real"],     true, "numbers.Real.__qualname__ == 'Real'"]
    - [Rational, Rational.__qualname__.__eq__, ["Rational"], true, "numbers.Rational.__qualname__ == 'Rational'"]
    - [Integral, Integral.__qualname__.__eq__, ["Integral"], true, "numbers.Integral.__qualname__ == 'Integral'"]

# ---------------------------------------------------------------------------
# ABC class __module__ values
#
# No prior spec records __module__ for any of the five ABC classes.
# All five are defined in the numbers module.
# ---------------------------------------------------------------------------

table numbers_extra16.abc_modules:
  kind: python_call_eq
  category: class_identity
  id_prefix: module

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__module__.__eq__,   ["numbers"], true, "numbers.Number.__module__ == 'numbers'"]
    - [Complex,  Complex.__module__.__eq__,  ["numbers"], true, "numbers.Complex.__module__ == 'numbers'"]
    - [Real,     Real.__module__.__eq__,     ["numbers"], true, "numbers.Real.__module__ == 'numbers'"]
    - [Rational, Rational.__module__.__eq__, ["numbers"], true, "numbers.Rational.__module__ == 'numbers'"]
    - [Integral, Integral.__module__.__eq__, ["numbers"], true, "numbers.Integral.__module__ == 'numbers'"]

# ---------------------------------------------------------------------------
# ABC inheritance chain via __bases__[0].__name__
#
# No prior spec records __bases__[0].__name__ for any of the five ABCs.
# The chain is: Number←object, Complex←Number, Real←Complex,
# Rational←Real, Integral←Rational.
# ---------------------------------------------------------------------------

table numbers_extra16.abc_base_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: base_name

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   "Number.__bases__[0].__name__.__eq__",   ["object"],   true, "numbers.Number.__bases__[0].__name__ == 'object'"]
    - [Complex,  "Complex.__bases__[0].__name__.__eq__",  ["Number"],   true, "numbers.Complex.__bases__[0].__name__ == 'Number'"]
    - [Real,     "Real.__bases__[0].__name__.__eq__",     ["Complex"],  true, "numbers.Real.__bases__[0].__name__ == 'Complex'"]
    - [Rational, "Rational.__bases__[0].__name__.__eq__", ["Real"],     true, "numbers.Rational.__bases__[0].__name__ == 'Real'"]
    - [Integral, "Integral.__bases__[0].__name__.__eq__", ["Rational"], true, "numbers.Integral.__bases__[0].__name__ == 'Rational'"]

# ---------------------------------------------------------------------------
# __abstractmethods__ type identity
#
# No prior spec records that __abstractmethods__ is a frozenset.
# This is true for all five ABCs.
# ---------------------------------------------------------------------------

invariant numbers_extra16.Number.abstractmethods_type:
  description: "numbers.Number.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: type_identity
  kind: python_call_eq
  function: Number.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant numbers_extra16.Integral.abstractmethods_type:
  description: "numbers.Integral.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: type_identity
  kind: python_call_eq
  function: Integral.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

# ---------------------------------------------------------------------------
# __abstractmethods__ length (abstract method count per ABC)
#
# No prior spec records the count of abstract methods for any of the five
# ABCs.  Number has 0 (it is a marker class), and the count rises through
# the hierarchy.
# ---------------------------------------------------------------------------

invariant numbers_extra16.Number.abstractmethods_len:
  description: "len(numbers.Number.__abstractmethods__) == 0 — Number is a marker ABC with no abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Number.__abstractmethods__.__len__
  args: []
  expected: 0

invariant numbers_extra16.Complex.abstractmethods_len:
  description: "len(numbers.Complex.__abstractmethods__) == 16 — Complex declares 16 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Complex.__abstractmethods__.__len__
  args: []
  expected: 16

invariant numbers_extra16.Real.abstractmethods_len:
  description: "len(numbers.Real.__abstractmethods__) == 23 — Real declares 23 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Real.__abstractmethods__.__len__
  args: []
  expected: 23

invariant numbers_extra16.Rational.abstractmethods_len:
  description: "len(numbers.Rational.__abstractmethods__) == 24 — Rational declares 24 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Rational.__abstractmethods__.__len__
  args: []
  expected: 24

invariant numbers_extra16.Integral.abstractmethods_len:
  description: "len(numbers.Integral.__abstractmethods__) == 34 — Integral declares 34 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Integral.__abstractmethods__.__len__
  args: []
  expected: 34

# ---------------------------------------------------------------------------
# __qualname__ length invariants for the five ABCs
# ---------------------------------------------------------------------------

invariant numbers_extra16.Number.qualname_len:
  description: "len(numbers.Number.__qualname__) == 6 — 'Number' is 6 chars"
  category: class_identity
  kind: python_call_eq
  function: Number.__qualname__.__len__
  args: []
  expected: 6

invariant numbers_extra16.Complex.qualname_len:
  description: "len(numbers.Complex.__qualname__) == 7 — 'Complex' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Complex.__qualname__.__len__
  args: []
  expected: 7

invariant numbers_extra16.Real.qualname_len:
  description: "len(numbers.Real.__qualname__) == 4 — 'Real' is 4 chars"
  category: class_identity
  kind: python_call_eq
  function: Real.__qualname__.__len__
  args: []
  expected: 4

invariant numbers_extra16.Rational.qualname_len:
  description: "len(numbers.Rational.__qualname__) == 8 — 'Rational' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Rational.__qualname__.__len__
  args: []
  expected: 8

invariant numbers_extra16.Integral.qualname_len:
  description: "len(numbers.Integral.__qualname__) == 8 — 'Integral' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Integral.__qualname__.__len__
  args: []
  expected: 8
