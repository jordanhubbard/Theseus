spec: pickle_extra23
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle_extra22.zspec.zsdl."
    - "Prior specs covered: Pickler/Unpickler __name__/__module__/__qualname__/__bases__[0].__name__, PickleError/PicklingError/UnpicklingError __name__/__module__/__bases__, pickle.dumps/loads/dump/load __name__/__module__/__qualname__, Pickler/Unpickler __init__.__name__, DEFAULT_PROTOCOL/HIGHEST_PROTOCOL type, __module__.__len__() and __name__.__len__() for Pickler/Unpickler/PickleError/PicklingError/UnpicklingError/dumps/loads."
    - "This spec covers: __qualname__.__len__() for Pickler, Unpickler, PickleError, PicklingError, UnpicklingError; __qualname__.__len__() for Pickler.dump/persistent_id methods; __qualname__.__len__() for Unpickler.load method; __name__.__len__() and __module__.__len__() for dump/load; __qualname__.__len__() for dumps/loads/dump/load."
    - "No prior pickle spec checks pickle.Pickler.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.Unpickler.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.PickleError.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.PicklingError.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.UnpicklingError.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.Pickler.dump.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.Pickler.persistent_id.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.Unpickler.load.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.dump.__name__.__len__()."
    - "No prior pickle spec checks pickle.load.__name__.__len__()."
    - "No prior pickle spec checks pickle.dump.__module__.__len__()."
    - "No prior pickle spec checks pickle.load.__module__.__len__()."
    - "No prior pickle spec checks pickle.dumps.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.loads.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.dump.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.load.__qualname__.__len__()."
    - "pickle.Pickler.__qualname__ == 'Pickler' — len 7 (flat, same as __name__)."
    - "pickle.Unpickler.__qualname__ == 'Unpickler' — len 9 (flat, same as __name__)."
    - "pickle.PickleError.__qualname__ == 'PickleError' — len 11 (flat, same as __name__)."
    - "pickle.PicklingError.__qualname__ == 'PicklingError' — len 13 (flat, same as __name__)."
    - "pickle.UnpicklingError.__qualname__ == 'UnpicklingError' — len 15 (flat, same as __name__)."
    - "pickle.Pickler.dump.__qualname__ == 'Pickler.dump' — len 12."
    - "pickle.Pickler.persistent_id.__qualname__ == 'Pickler.persistent_id' — len 21."
    - "pickle.Unpickler.load.__qualname__ == 'Unpickler.load' — len 14."
    - "pickle.dump.__name__ == 'dump' — len 4; __module__ == '_pickle' — len 7."
    - "pickle.load.__name__ == 'load' — len 4; __module__ == '_pickle' — len 7."
    - "pickle.dumps.__qualname__ == 'dumps' — len 5 (flat, same as __name__)."
    - "pickle.loads.__qualname__ == 'loads' — len 5 (flat, same as __name__)."
    - "pickle.dump.__qualname__ == 'dump' — len 4 (flat, same as __name__)."
    - "pickle.load.__qualname__ == 'load' — len 4 (flat, same as __name__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Pickler, Unpickler, PickleError, PicklingError,
# UnpicklingError
#
# All five classes are defined in the C extension module '_pickle' and have
# flat __qualname__ values equal to their __name__. Lengths:
#   Pickler         -> 7
#   Unpickler       -> 9
#   PickleError     -> 11
#   PicklingError   -> 13
#   UnpicklingError -> 15
# Prior spec pickle_extra22 established the matching __name__ lengths; these
# invariants anchor the __qualname__ lengths in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant pickle_extra23.Pickler.qualname.len:
  description: "pickle.Pickler.__qualname__.__len__() == 7 — 'Pickler' has 7 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: Pickler.__qualname__.__len__
  args: []
  expected: 7

invariant pickle_extra23.Unpickler.qualname.len:
  description: "pickle.Unpickler.__qualname__.__len__() == 9 — 'Unpickler' has 9 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: Unpickler.__qualname__.__len__
  args: []
  expected: 9

invariant pickle_extra23.PickleError.qualname.len:
  description: "pickle.PickleError.__qualname__.__len__() == 11 — 'PickleError' has 11 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: PickleError.__qualname__.__len__
  args: []
  expected: 11

invariant pickle_extra23.PicklingError.qualname.len:
  description: "pickle.PicklingError.__qualname__.__len__() == 13 — 'PicklingError' has 13 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: PicklingError.__qualname__.__len__
  args: []
  expected: 13

invariant pickle_extra23.UnpicklingError.qualname.len:
  description: "pickle.UnpicklingError.__qualname__.__len__() == 15 — 'UnpicklingError' has 15 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: UnpicklingError.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Pickler and Unpickler methods
#
# The dotted qualnames for Pickler.dump and Unpickler.load are formed as
# 'ClassName.method_name'. Pickler.persistent_id carries a longer method
# name. Lengths:
#   Pickler.dump          -> 'Pickler.dump'          -> 12
#   Unpickler.load        -> 'Unpickler.load'        -> 14
#   Pickler.persistent_id -> 'Pickler.persistent_id' -> 21
# No prior pickle spec checks any method's __qualname__ length.
# ---------------------------------------------------------------------------

invariant pickle_extra23.Pickler.dump.qualname.len:
  description: "pickle.Pickler.dump.__qualname__.__len__() == 12 — 'Pickler.dump' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Pickler.dump.__qualname__.__len__"
  args: []
  expected: 12

invariant pickle_extra23.Unpickler.load.qualname.len:
  description: "pickle.Unpickler.load.__qualname__.__len__() == 14 — 'Unpickler.load' has 14 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Unpickler.load.__qualname__.__len__"
  args: []
  expected: 14

invariant pickle_extra23.Pickler.persistent_id.qualname.len:
  description: "pickle.Pickler.persistent_id.__qualname__.__len__() == 21 — 'Pickler.persistent_id' has 21 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Pickler.persistent_id.__qualname__.__len__"
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# Consolidated table — class __qualname__ lengths
#
# All five are first covered in this spec (pickle_extra23). Lengths match
# the __name__ lengths established by pickle_extra22 because qualnames are
# flat (no enclosing class scope).
# ---------------------------------------------------------------------------

table pickle_extra23.class_qualname_lengths:
  description: "pickle class __qualname__.__len__() — Pickler through UnpicklingError (flat qualnames matching __name__)"
  kind: python_call_eq
  category: string_lengths
  id_prefix: pfa23a

  columns: [id, function, args, expected]
  rows:
    - [Pickler_qualname_len,         Pickler.__qualname__.__len__,         [],  7]
    - [Unpickler_qualname_len,       Unpickler.__qualname__.__len__,       [],  9]
    - [PickleError_qualname_len,     PickleError.__qualname__.__len__,     [], 11]
    - [PicklingError_qualname_len,   PicklingError.__qualname__.__len__,   [], 13]
    - [UnpicklingError_qualname_len, UnpicklingError.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Consolidated table — method qualname lengths and dump/load __name__ /
# __module__ / __qualname__ lengths
#
# Covers Pickler.dump, Unpickler.load, Pickler.persistent_id method
# qualnames plus dump/load function lengths — all first in extra23.
# ---------------------------------------------------------------------------

table pickle_extra23.method_and_function_lengths:
  description: "pickle method __qualname__ lengths and dump/load function __name__/__module__/__qualname__ lengths"
  kind: python_call_eq
  category: string_lengths
  id_prefix: pfa23b

  columns: [id, function, args, expected]
  rows:
    - [Pickler_dump_qualname_len,           "Pickler.dump.__qualname__.__len__",           [], 12]
    - [Unpickler_load_qualname_len,         "Unpickler.load.__qualname__.__len__",         [], 14]
    - [Pickler_persistent_id_qualname_len,  "Pickler.persistent_id.__qualname__.__len__",  [], 21]
    - [dump_name_len,                       dump.__name__.__len__,                         [],  4]
    - [load_name_len,                       load.__name__.__len__,                         [],  4]
    - [dump_module_len,                     dump.__module__.__len__,                       [],  7]
    - [load_module_len,                     load.__module__.__len__,                       [],  7]
    - [dumps_qualname_len,                  dumps.__qualname__.__len__,                    [],  5]
    - [loads_qualname_len,                  loads.__qualname__.__len__,                    [],  5]
    - [dump_qualname_len,                   dump.__qualname__.__len__,                     [],  4]
    - [load_qualname_len,                   load.__qualname__.__len__,                     [],  4]
