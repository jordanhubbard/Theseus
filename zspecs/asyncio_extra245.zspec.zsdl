spec: asyncio_extra245
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py (internal implementation)"
  notes:
    - "This spec covers asyncio.ensure_future, asyncio.shield, and asyncio.wait_for function identity."
    - "asyncio.ensure_future.__module__ == 'asyncio.tasks' (len=13) — defined in Lib/asyncio/tasks.py."
    - "asyncio.shield.__module__ == 'asyncio.tasks' (len=13) — defined in Lib/asyncio/tasks.py."
    - "asyncio.wait_for.__module__ == 'asyncio.tasks' (len=13) — defined in Lib/asyncio/tasks.py."
    - "asyncio.ensure_future.__name__.__len__() == 13 ('ensure_future' is 13 chars)."
    - "asyncio.shield.__name__.__len__() == 6 ('shield' is 6 chars)."
    - "asyncio.wait_for.__name__.__len__() == 8 ('wait_for' is 8 chars)."
    - "All three functions have __class__.__name__ == 'function' — Python functions, not C extensions."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.ensure_future function identity
#
# asyncio.ensure_future is a Python function defined in asyncio.tasks.
# __name__ == 'ensure_future' (len=13)
# __module__ == 'asyncio.tasks' (len=13)
# __qualname__ == 'ensure_future' (len=13)
# __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra245.ensure_future_identity:
  description: "asyncio.ensure_future function identity checks — ensure_future is a Python function defined in asyncio.tasks; ensure_future.__name__.__eq__('ensure_future')==True (len=13); ensure_future.__module__.__eq__('asyncio.tasks')==True (len=13, same module as shield and wait_for); ensure_future.__qualname__.__eq__('ensure_future')==True (len=13, module-level function so qualname equals name); ensure_future.__class__.__name__.__eq__('function')==True; ensure_future.__name__.__len__()==13 (same length as __module__.__len__()==13); verified with Python 3.14.3"
  kind: python_call_eq
  category: ensure_future_identity
  id_prefix: aiofns245

  columns: [id, function, args, expected, description]
  rows:
    - [ef_name_eq,    ensure_future.__name__.__eq__,          ["ensure_future"],  true, "asyncio.ensure_future.__name__ == 'ensure_future'; verified with Python 3.14.3"]
    - [ef_name_len,   ensure_future.__name__.__len__,         [],                 13,   "asyncio.ensure_future.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [ef_module_eq,  ensure_future.__module__.__eq__,        ["asyncio.tasks"],  true, "asyncio.ensure_future.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [ef_module_len, ensure_future.__module__.__len__,       [],                 13,   "asyncio.ensure_future.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [ef_qname_eq,   ensure_future.__qualname__.__eq__,      ["ensure_future"],  true, "asyncio.ensure_future.__qualname__ == 'ensure_future' (len=13, qualname equals name); verified with Python 3.14.3"]
    - [ef_qname_len,  ensure_future.__qualname__.__len__,     [],                 13,   "asyncio.ensure_future.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [ef_cls_nm,     ensure_future.__class__.__name__.__eq__, ["function"],      true, "asyncio.ensure_future.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.shield function identity
#
# asyncio.shield is a Python function defined in asyncio.tasks.
# __name__ == 'shield' (len=6)
# __module__ == 'asyncio.tasks' (len=13)
# __qualname__ == 'shield' (len=6)
# __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra245.shield_identity:
  description: "asyncio.shield function identity checks — shield is a Python function defined in asyncio.tasks; shield.__name__.__eq__('shield')==True (len=6); shield.__module__.__eq__('asyncio.tasks')==True (len=13, same module as ensure_future and wait_for); shield.__qualname__.__eq__('shield')==True (len=6, module-level function so qualname equals name); shield.__class__.__name__.__eq__('function')==True; shield.__name__.__len__()==6 (shorter than ensure_future.__name__.__len__()==13); verified with Python 3.14.3"
  kind: python_call_eq
  category: shield_identity
  id_prefix: aiofns245

  columns: [id, function, args, expected, description]
  rows:
    - [sh_name_eq,    shield.__name__.__eq__,          ["shield"],         true, "asyncio.shield.__name__ == 'shield'; verified with Python 3.14.3"]
    - [sh_name_len,   shield.__name__.__len__,         [],                 6,    "asyncio.shield.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [sh_module_eq,  shield.__module__.__eq__,        ["asyncio.tasks"],  true, "asyncio.shield.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [sh_module_len, shield.__module__.__len__,       [],                 13,   "asyncio.shield.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [sh_qname_eq,   shield.__qualname__.__eq__,      ["shield"],         true, "asyncio.shield.__qualname__ == 'shield' (len=6, qualname equals name); verified with Python 3.14.3"]
    - [sh_qname_len,  shield.__qualname__.__len__,     [],                 6,    "asyncio.shield.__qualname__.__len__() == 6; verified with Python 3.14.3"]
    - [sh_cls_nm,     shield.__class__.__name__.__eq__, ["function"],      true, "asyncio.shield.__class__.__name__ == 'function'; verified with Python 3.14.3"]

