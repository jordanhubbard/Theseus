# ---------------------------------------------------------------------------

table asyncio_extra245.wait_for_identity:
  description: "asyncio.wait_for function identity checks — wait_for is a Python function defined in asyncio.tasks; wait_for.__name__.__eq__('wait_for')==True (len=8); wait_for.__module__.__eq__('asyncio.tasks')==True (len=13, same module as ensure_future and shield); wait_for.__qualname__.__eq__('wait_for')==True (len=8, module-level function so qualname equals name); wait_for.__class__.__name__.__eq__('function')==True; wait_for.__name__.__len__()==8 (between shield.__name__.__len__()==6 and ensure_future.__name__.__len__()==13); verified with Python 3.14.3"
  kind: python_call_eq
  category: wait_for_identity
  id_prefix: aiofns245

  columns: [id, function, args, expected, description]
  rows:
    - [wf_name_eq,    wait_for.__name__.__eq__,          ["wait_for"],       true, "asyncio.wait_for.__name__ == 'wait_for'; verified with Python 3.14.3"]
    - [wf_name_len,   wait_for.__name__.__len__,         [],                 8,    "asyncio.wait_for.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [wf_module_eq,  wait_for.__module__.__eq__,        ["asyncio.tasks"],  true, "asyncio.wait_for.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [wf_module_len, wait_for.__module__.__len__,       [],                 13,   "asyncio.wait_for.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [wf_qname_eq,   wait_for.__qualname__.__eq__,      ["wait_for"],       true, "asyncio.wait_for.__qualname__ == 'wait_for' (len=8, qualname equals name); verified with Python 3.14.3"]
    - [wf_qname_len,  wait_for.__qualname__.__len__,     [],                 8,    "asyncio.wait_for.__qualname__.__len__() == 8; verified with Python 3.14.3"]
    - [wf_cls_nm,     wait_for.__class__.__name__.__eq__, ["function"],      true, "asyncio.wait_for.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra245
# ---------------------------------------------------------------------------

invariant asyncio_extra245.ensure_future_module_is_asyncio_tasks:
  description: "asyncio.ensure_future.__module__.__eq__('asyncio.tasks') returns True — ensure_future is defined in Lib/asyncio/tasks.py; __module__ == 'asyncio.tasks' (len=13); notably ensure_future.__name__.__len__()==13 equals __module__.__len__()==13 (coincidence of lengths); __class__.__name__ == 'function'; qualname equals name ('ensure_future', len=13); NEW in extra245: first standalone ensure_future module invariant in aiofns245 namespace; verified with Python 3.14.3"
  category: ensure_future_identity
  kind: python_call_eq
  function: ensure_future.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra245.ensure_future_name_len_13:
  description: "asyncio.ensure_future.__name__.__len__() == 13 — 'ensure_future' has 13 chars: e-n-s-u-r-e-_-f-u-t-u-r-e; same numerical value as __module__.__len__()==13 ('asyncio.tasks' is also 13 chars); compare shield.__name__.__len__()==6 and wait_for.__name__.__len__()==8; ensure_future.__qualname__.__len__()==13 (same as __name__.__len__()); NEW in extra245: first standalone ensure_future name length invariant; verified with Python 3.14.3"
  category: ensure_future_identity
  kind: python_call_eq
  function: ensure_future.__name__.__len__
  args: []
  expected: 13

invariant asyncio_extra245.shield_module_is_asyncio_tasks:
  description: "asyncio.shield.__module__.__eq__('asyncio.tasks') returns True — shield is defined in Lib/asyncio/tasks.py alongside ensure_future and wait_for; all three share __module__ == 'asyncio.tasks' (len=13); shield.__name__ is 'shield' (len=6, shortest of the three); shield.__class__.__name__ == 'function'; qualname equals name ('shield', len=6); NEW in extra245: first standalone shield module invariant in aiofns245 namespace; verified with Python 3.14.3"
  category: shield_identity
  kind: python_call_eq
  function: shield.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra245.shield_name_len_6:
  description: "asyncio.shield.__name__.__len__() == 6 — 'shield' has 6 chars: s-h-i-e-l-d; shortest name among the three functions in this spec (ensure_future=13, wait_for=8, shield=6); shield.__module__.__len__()==13 ('asyncio.tasks'); shield.__qualname__.__len__()==6 (same as __name__.__len__()); shield.__class__.__name__ == 'function'; NEW in extra245: first standalone shield name length invariant; verified with Python 3.14.3"
  category: shield_identity
  kind: python_call_eq
  function: shield.__name__.__len__
  args: []
  expected: 6

invariant asyncio_extra245.wait_for_module_is_asyncio_tasks:
  description: "asyncio.wait_for.__module__.__eq__('asyncio.tasks') returns True — wait_for is defined in Lib/asyncio/tasks.py alongside ensure_future and shield; all three share __module__ == 'asyncio.tasks' (len=13); wait_for.__name__ is 'wait_for' (len=8, middle length of the three); wait_for.__class__.__name__ == 'function'; qualname equals name ('wait_for', len=8); NEW in extra245: first standalone wait_for module invariant in aiofns245 namespace; verified with Python 3.14.3"
  category: wait_for_identity
  kind: python_call_eq
  function: wait_for.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra245.wait_for_name_len_8:
  description: "asyncio.wait_for.__name__.__len__() == 8 — 'wait_for' has 8 chars: w-a-i-t-_-f-o-r; middle length among the three functions in this spec (ensure_future=13, wait_for=8, shield=6); wait_for.__module__.__len__()==13 ('asyncio.tasks'); wait_for.__qualname__.__len__()==8 (same as __name__.__len__()); wait_for.__class__.__name__ == 'function'; NEW in extra245: first standalone wait_for name length invariant; verified with Python 3.14.3"
  category: wait_for_identity
  kind: python_call_eq
  function: wait_for.__name__.__len__
  args: []
  expected: 8

invariant asyncio_extra245.all_three_same_module:
  description: "asyncio.ensure_future.__module__.__eq__(asyncio.shield.__module__) — all three functions (ensure_future, shield, wait_for) share the same __module__ value 'asyncio.tasks' (len=13); this is verified by checking ensure_future.__module__.__eq__('asyncio.tasks')==True, shield.__module__.__eq__('asyncio.tasks')==True, and wait_for.__module__.__eq__('asyncio.tasks')==True; they are all defined in Lib/asyncio/tasks.py; standalone check: ensure_future.__module__.__eq__('asyncio.tasks'); NEW in extra245; verified with Python 3.14.3"
  category: ensure_future_identity
  kind: python_call_eq
  function: ensure_future.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra245.wait_for_qualname_eq_name:
  description: "asyncio.wait_for.__qualname__.__eq__('wait_for') returns True — wait_for is a module-level function so qualname equals name; wait_for.__qualname__ is 'wait_for' (len=8), same as __name__; compare: a method's qualname would be 'ClassName.method_name'; wait_for.__name__.__len__()==8 and wait_for.__qualname__.__len__()==8 both equal 8; wait_for.__module__ is 'asyncio.tasks' (len=13); wait_for.__class__.__name__ is 'function'; NEW in extra245; verified with Python 3.14.3"
  category: wait_for_identity
  kind: python_call_eq
  function: wait_for.__qualname__.__eq__
  args: ["wait_for"]
  expected: true
