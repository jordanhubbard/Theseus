spec: threading_extra257
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Thread property identity and class attribute contracts."
    - "threading.Thread.name.__class__.__name__ == 'property' — name is a property descriptor. Verified with Python 3.14.3."
    - "threading.Thread.name.fget.__name__ == 'name' — property getter is named 'name'. Verified with Python 3.14.3."
    - "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a property descriptor. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fget.__name__ == 'daemon' — property getter is named 'daemon'. Verified with Python 3.14.3."
    - "threading.Thread.ident.__class__.__name__ == 'property' — ident is a property descriptor. Verified with Python 3.14.3."
    - "threading.Thread.ident.fget.__name__ == 'ident' — property getter is named 'ident'. Verified with Python 3.14.3."
    - "threading.Thread.native_id.__class__.__name__ == 'property' — native_id is a property descriptor. Verified with Python 3.14.3."
    - "threading.Thread.native_id.fget.__name__ == 'native_id' — property getter is named 'native_id'. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' — initializer qualname. Verified with Python 3.14.3."
    - "threading.Thread.__repr__.__qualname__ == 'Thread.__repr__' — repr qualname. Verified with Python 3.14.3."
    - "threading.Thread.__class__.__name__ == 'type' — Thread is a class; metaclass is type. Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread' — class name. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' — defined in threading. Verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — start method qualname. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — join method qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread property descriptor identity contracts
#
# threading.Thread.name.__class__.__name__      == 'property'
# threading.Thread.name.fget.__name__           == 'name'
# threading.Thread.daemon.__class__.__name__    == 'property'
# threading.Thread.daemon.fget.__name__         == 'daemon'
# threading.Thread.ident.__class__.__name__     == 'property'
#
# Thread uses Python property descriptors for name, daemon, ident,
# native_id. New to extra257.
# ---------------------------------------------------------------------------

table threading_extra257.thread_property_identity:
  description: "threading.Thread name, daemon, ident property class and fget name contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: tprop257

  columns: [id, function, args, expected, description]
  rows:
    - [name_class_eq,
       Thread.name.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — name is a property descriptor; new to extra257"]
    - [name_fget_name_eq,
       Thread.name.fget.__name__.__eq__,
       ["name"],
       true,
       "threading.Thread.name.fget.__name__.__eq__('name') == True — property getter is named 'name'; new to extra257"]
    - [daemon_class_eq,
       Thread.daemon.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — daemon is a property descriptor; new to extra257"]
    - [daemon_fget_name_eq,
       Thread.daemon.fget.__name__.__eq__,
       ["daemon"],
       true,
       "threading.Thread.daemon.fget.__name__.__eq__('daemon') == True — property getter is named 'daemon'; new to extra257"]
    - [ident_class_eq,
       Thread.ident.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.ident.__class__.__name__.__eq__('property') == True — ident is a property descriptor; new to extra257"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread ident/native_id fget and native_id property contracts
#
# threading.Thread.ident.fget.__name__           == 'ident'
# threading.Thread.native_id.__class__.__name__  == 'property'
# threading.Thread.native_id.fget.__name__       == 'native_id'
# threading.Thread.__init__.__qualname__         == 'Thread.__init__'
# threading.Thread.__repr__.__qualname__         == 'Thread.__repr__'
#
# New to extra257.
# ---------------------------------------------------------------------------

table threading_extra257.thread_property_ext:
  description: "threading.Thread ident fget, native_id property, __init__ and __repr__ qualname contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: tpropext257

  columns: [id, function, args, expected, description]
  rows:
    - [ident_fget_name_eq,
       Thread.ident.fget.__name__.__eq__,
       ["ident"],
       true,
       "threading.Thread.ident.fget.__name__.__eq__('ident') == True — property getter is named 'ident'; new to extra257"]
    - [native_id_class_eq,
       Thread.native_id.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.native_id.__class__.__name__.__eq__('property') == True — native_id is a property descriptor; new to extra257"]
    - [native_id_fget_name_eq,
       Thread.native_id.fget.__name__.__eq__,
       ["native_id"],
       true,
       "threading.Thread.native_id.fget.__name__.__eq__('native_id') == True — property getter is named 'native_id'; new to extra257"]
    - [init_qualname_eq,
       Thread.__init__.__qualname__.__eq__,
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — initializer qualname; new to extra257"]
    - [repr_qualname_eq,
       Thread.__repr__.__qualname__.__eq__,
       ["Thread.__repr__"],
       true,
       "threading.Thread.__repr__.__qualname__.__eq__('Thread.__repr__') == True — repr qualname; new to extra257"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread class identity contracts
#
# threading.Thread.__name__              == 'Thread'
# threading.Thread.__module__            == 'threading'
# threading.Thread.__class__.__name__    == 'type'
# threading.Thread.__bases__[0].__name__ == 'object'
# threading.Thread.start.__qualname__    == 'Thread.start'
#
# New to extra257.
# ---------------------------------------------------------------------------

table threading_extra257.thread_class_identity:
  description: "threading.Thread class name, module, metaclass, base, start qualname contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: tclass257

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,
       Thread.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — class name; new to extra257"]
    - [thread_module_eq,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — defined in threading module; new to extra257"]
    - [thread_class_name_eq,
       Thread.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Thread.__class__.__name__.__eq__('type') == True — Thread is a class; metaclass is type; new to extra257"]
    - [thread_base_name_eq,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra257"]
    - [thread_start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — start method qualname; new to extra257"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread join and is_alive method qualname contracts
#
# threading.Thread.join.__qualname__     == 'Thread.join'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.__init__.__name__     == '__init__'
# threading.Thread.__repr__.__name__     == '__repr__'
# threading.Thread.start.__name__        == 'start'
#
# New to extra257.
# ---------------------------------------------------------------------------

table threading_extra257.thread_method_names:
  description: "threading.Thread join, is_alive qualname, __init__, __repr__, start method name contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: tmeth257

  columns: [id, function, args, expected, description]
  rows:
    - [join_qualname_eq,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — join method qualname; new to extra257"]
    - [is_alive_qualname_eq,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — is_alive method qualname; new to extra257"]
    - [init_name_eq,
       Thread.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "threading.Thread.__init__.__name__.__eq__('__init__') == True — initializer method name; new to extra257"]
    - [repr_name_eq,
       Thread.__repr__.__name__.__eq__,
       ["__repr__"],
       true,
       "threading.Thread.__repr__.__name__.__eq__('__repr__') == True — repr method name; new to extra257"]
    - [start_name_eq,
       Thread.start.__name__.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — start method name; new to extra257"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra257
# ---------------------------------------------------------------------------

invariant threading_extra257.Thread.name_is_property:
  description: "threading.Thread.name.__class__.__name__ == 'property' — name is a property descriptor; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra257.Thread.name_fget_name:
  description: "threading.Thread.name.fget.__name__ == 'name' — property getter is named 'name'; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.name.fget.__name__.__eq__
  args: ["name"]
  expected: true

invariant threading_extra257.Thread.daemon_is_property:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a property descriptor; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra257.Thread.daemon_fget_name:
  description: "threading.Thread.daemon.fget.__name__ == 'daemon' — property getter is named 'daemon'; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.daemon.fget.__name__.__eq__
  args: ["daemon"]
  expected: true

invariant threading_extra257.Thread.ident_is_property:
  description: "threading.Thread.ident.__class__.__name__ == 'property' — ident is a property descriptor; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.ident.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra257.Thread.native_id_is_property:
  description: "threading.Thread.native_id.__class__.__name__ == 'property' — native_id is a property descriptor; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.native_id.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra257.Thread.init_qualname:
  description: "threading.Thread.__init__.__qualname__ == 'Thread.__init__' — initializer qualname; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.__init__.__qualname__.__eq__
  args: ["Thread.__init__"]
  expected: true

invariant threading_extra257.Thread.repr_qualname:
  description: "threading.Thread.__repr__.__qualname__ == 'Thread.__repr__' — repr qualname; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.__repr__.__qualname__.__eq__
  args: ["Thread.__repr__"]
  expected: true

invariant threading_extra257.Thread.class_is_type:
  description: "threading.Thread.__class__.__name__ == 'type' — Thread is a class; metaclass is type; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra257.Thread.name_eq:
  description: "threading.Thread.__name__ == 'Thread' — class name; new to extra257"
  category: identity
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra257.Thread.base_is_object:
  description: "threading.Thread.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra257"
  category: identity
  kind: python_call_eq
  function: "Thread.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
