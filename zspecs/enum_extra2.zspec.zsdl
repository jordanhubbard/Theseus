spec: enum_extra2
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/enum.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
    - "enum.zspec.zsdl — covers Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique names and functional API"
    - "enum_flags.zspec.zsdl — covers EnumType/EnumMeta, auto/unique modules, Flag/IntFlag modules and hierarchies"
    - "enum_extra.zspec.zsdl — covers IntEnum module/base, EnumMeta alias, Enum/IntEnum/Flag bases, auto instance, StrEnum module/base, unique type"
  notes:
    - "This spec covers Python 3.11+ additions to enum not found in the three earlier enum specs."
    - "global_enum is a decorator function added in Python 3.11 that promotes enum members to the global scope."
    - "member is a descriptor added in Python 3.11 that forces a value to be treated as an enum member."
    - "nonmember is a descriptor added in Python 3.11 that prevents a value from being treated as an enum member."
    - "enum.property is a Python 3.11+ addition: a property class that works correctly inside enum bodies."
    - "FlagBoundary is an enum (StrEnum) added in Python 3.11 that controls how out-of-range flag values are handled."
    - "CONFORM, EJECT, KEEP, STRICT are the four FlagBoundary members; their __class__.__name__ is 'FlagBoundary'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# global_enum — decorator that exports enum members to the module's globals
# (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra2.global_enum.name:
  description: "enum.global_enum.__name__ == 'global_enum' (Python 3.11+)"
  category: decorators
  kind: python_call_eq
  function: global_enum.__name__.__eq__
  args: ["global_enum"]
  expected: true

# ---------------------------------------------------------------------------
# member — descriptor that forces a value to be an enum member (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra2.member.name:
  description: "enum.member.__name__ == 'member' (Python 3.11+)"
  category: descriptors
  kind: python_call_eq
  function: member.__name__.__eq__
  args: ["member"]
  expected: true

# ---------------------------------------------------------------------------
# nonmember — descriptor that excludes a value from enum membership (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra2.nonmember.name:
  description: "enum.nonmember.__name__ == 'nonmember' (Python 3.11+)"
  category: descriptors
  kind: python_call_eq
  function: nonmember.__name__.__eq__
  args: ["nonmember"]
  expected: true

# ---------------------------------------------------------------------------
# enum.property — property class for use inside enum bodies (Python 3.11+)
#
# enum.property shadows the builtin property inside enum definitions so that
# property-decorated methods are not treated as enum members.
# ---------------------------------------------------------------------------

invariant enum_extra2.property.name:
  description: "enum.property.__name__ == 'property' (Python 3.11+)"
  category: property_class
  kind: python_call_eq
  function: property.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# FlagBoundary — StrEnum controlling out-of-range Flag behavior (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra2.FlagBoundary.name:
  description: "enum.FlagBoundary.__name__ == 'FlagBoundary' (Python 3.11+)"
  category: flag_boundary
  kind: python_call_eq
  function: FlagBoundary.__name__.__eq__
  args: ["FlagBoundary"]
  expected: true

# ---------------------------------------------------------------------------
# FlagBoundary members — CONFORM, EJECT, KEEP, STRICT
#
# Each member's __class__.__name__ is 'FlagBoundary' because they are
# instances of the FlagBoundary enum class.
# ---------------------------------------------------------------------------

invariant enum_extra2.CONFORM.class_name:
  description: "enum.CONFORM.__class__.__name__ == 'FlagBoundary' (Python 3.11+)"
  category: flag_boundary_members
  kind: python_call_eq
  function: CONFORM.__class__.__name__.__eq__
  args: ["FlagBoundary"]
  expected: true

invariant enum_extra2.EJECT.class_name:
  description: "enum.EJECT.__class__.__name__ == 'FlagBoundary' (Python 3.11+)"
  category: flag_boundary_members
  kind: python_call_eq
  function: EJECT.__class__.__name__.__eq__
  args: ["FlagBoundary"]
  expected: true

invariant enum_extra2.KEEP.class_name:
  description: "enum.KEEP.__class__.__name__ == 'FlagBoundary' (Python 3.11+)"
  category: flag_boundary_members
  kind: python_call_eq
  function: KEEP.__class__.__name__.__eq__
  args: ["FlagBoundary"]
  expected: true

invariant enum_extra2.STRICT.class_name:
  description: "enum.STRICT.__class__.__name__ == 'FlagBoundary' (Python 3.11+)"
  category: flag_boundary_members
  kind: python_call_eq
  function: STRICT.__class__.__name__.__eq__
  args: ["FlagBoundary"]
  expected: true
