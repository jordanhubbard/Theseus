spec: contextlib_extra17
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra16.zspec.zsdl."
    - "contextlib_extra16 covers: suppress/closing/ExitStack __qualname__; suppress MRO[1]/[2]; nullcontext MRO[3]/[4]; redirect_stderr.__module__."
    - "contextlib_extra15 covers: redirect_stdout/redirect_stderr MRO[1]/[2]; nullcontext MRO[1]/[2]; AsyncExitStack MRO len/[1]/[2]/[3]; aclosing MRO[2]; suppress.__name__ standalone."
    - "contextlib_extra14 covers: ExitStack MRO[1]/[2]/[3]; aclosing MRO len and MRO[1]; nullcontext/closing/redirect_stdout __module__."
    - "contextlib_extra12 covers: standalone __name__ for contextmanager/asynccontextmanager/closing/nullcontext/suppress/ExitStack/AsyncExitStack; contextmanager/__module__ and ExitStack/__module__ standalone."
    - "contextlib_extra11 covers: MRO lengths for closing(4)/ExitStack(5)/AsyncExitStack(5)/aclosing(4)/suppress(4)/nullcontext(5)."
    - "contextlib_extra10 covers: closing mro length == 4."
    - "NOT yet covered: contextlib.closing.__mro__[0].__name__ == 'closing' as a standalone invariant."
    - "NOT yet covered: contextlib.closing.__mro__[1].__name__ == 'AbstractContextManager'."
    - "NOT yet covered: contextlib.closing.__mro__[2].__name__ == 'ABC'."
    - "NOT yet covered: contextlib.closing.__mro__[3].__name__ == 'object'."
    - "NOT yet covered: contextlib.ExitStack.__mro__[4].__name__ == 'object' (tail of ExitStack MRO)."
    - "NOT yet covered: contextlib.aclosing.__mro__[0].__name__ == 'aclosing' (head of aclosing MRO)."
    - "NOT yet covered: contextlib.aclosing.__mro__[3].__name__ == 'object' (tail of aclosing MRO)."
    - "closing MRO is [closing, AbstractContextManager, ABC, object] — extra14 covers length only."
    - "ExitStack MRO is [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object] — extra14 covers [1][2][3]; [4] is object."
    - "aclosing MRO is [aclosing, AbstractAsyncContextManager, ABC, object] — extra14/15 cover [1][2]; [0] and [3] remain."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# closing MRO entries by index
#
# contextlib_extra10 records closing.__mro__.__len__() == 4.
# No prior spec accesses any closing MRO entry by index via __getitem__.
# The full MRO is [closing, AbstractContextManager, ABC, object].
# ---------------------------------------------------------------------------

invariant contextlib_extra17.closing.mro_0:
  description: "contextlib.closing.__mro__[0].__name__ == 'closing' — the class itself"
  category: closing_mro
  kind: python_call_eq
  function: closing.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "closing"

invariant contextlib_extra17.closing.mro_1:
  description: "contextlib.closing.__mro__[1].__name__ == 'AbstractContextManager' — direct abstract base"
  category: closing_mro
  kind: python_call_eq
  function: closing.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra17.closing.mro_2:
  description: "contextlib.closing.__mro__[2].__name__ == 'ABC' — ABC in closing MRO"
  category: closing_mro
  kind: python_call_eq
  function: closing.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "ABC"

invariant contextlib_extra17.closing.mro_3:
  description: "contextlib.closing.__mro__[3].__name__ == 'object' — root of closing MRO"
  category: closing_mro
  kind: python_call_eq
  function: closing.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ExitStack MRO[4] — tail entry
#
# contextlib_extra14 covers ExitStack.__mro__[1] (_BaseExitStack),
# ExitStack.__mro__[2] (AbstractContextManager), and ExitStack.__mro__[3] (ABC).
# The MRO length is 5 (confirmed in extra11). The last entry, MRO[4], is object.
# No prior spec records this tail entry as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra17.ExitStack.mro_4:
  description: "contextlib.ExitStack.__mro__[4].__name__ == 'object' — root of ExitStack MRO"
  category: ExitStack_mro
  kind: python_call_eq
  function: ExitStack.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# aclosing MRO head and tail entries
#
# contextlib_extra14 covers aclosing.__mro__[1] (AbstractAsyncContextManager).
# contextlib_extra15 covers aclosing.__mro__[2] (ABC).
# No prior spec records aclosing.__mro__[0] (the class itself) or
# aclosing.__mro__[3] (object) as standalone invariants.
# The full MRO is [aclosing, AbstractAsyncContextManager, ABC, object].
# ---------------------------------------------------------------------------

invariant contextlib_extra17.aclosing.mro_0:
  description: "contextlib.aclosing.__mro__[0].__name__ == 'aclosing' — the class itself"
  category: aclosing_mro
  kind: python_call_eq
  function: aclosing.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "aclosing"

invariant contextlib_extra17.aclosing.mro_3:
  description: "contextlib.aclosing.__mro__[3].__name__ == 'object' — root of aclosing MRO"
  category: aclosing_mro
  kind: python_call_eq
  function: aclosing.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# AsyncExitStack MRO[4] — tail entry
#
# contextlib_extra15 covers AsyncExitStack.__mro__[1] (_BaseExitStack),
# [2] (AbstractAsyncContextManager), and [3] (ABC).
# The MRO length is 5 (confirmed in extra11). The last entry, MRO[4], is object.
# No prior spec records this tail entry as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra17.AsyncExitStack.mro_4:
  description: "contextlib.AsyncExitStack.__mro__[4].__name__ == 'object' — root of AsyncExitStack MRO"
  category: AsyncExitStack_mro
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# suppress MRO[0] — the class itself
#
# contextlib_extra16 covers suppress.__mro__[1] (AbstractContextManager) and
# [2] (ABC). contextlib_extra11 records the MRO length == 4. No prior spec
# records MRO[0] (suppress itself) or MRO[3] (object) by index.
# ---------------------------------------------------------------------------

invariant contextlib_extra17.suppress.mro_0:
  description: "contextlib.suppress.__mro__[0].__name__ == 'suppress' — the class itself"
  category: suppress_mro
  kind: python_call_eq
  function: suppress.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "suppress"

invariant contextlib_extra17.suppress.mro_3:
  description: "contextlib.suppress.__mro__[3].__name__ == 'object' — root of suppress MRO"
  category: suppress_mro
  kind: python_call_eq
  function: suppress.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"
