spec: multiprocessing_extra2311
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#managers — BaseManager reference"
    - "Test vectors verified with Python 3.13.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks for multiprocessing classes."
    - "multiprocessing.managers.BaseManager is a plain class (no ABCMeta) — __abstractmethods__ absent from __dict__."
    - "multiprocessing.managers.SyncManager inherits from BaseManager — also not an ABC, __abstractmethods__ absent."
    - "multiprocessing.managers.BaseProxy is a plain class — __abstractmethods__ absent."
    - "multiprocessing.process.BaseProcess uses 'raise NotImplementedError' for _Popen — not ABCMeta."
    - "multiprocessing.pool.Pool is a concrete class — __abstractmethods__ absent from __dict__."
    - "multiprocessing.queues.Queue, SimpleQueue, JoinableQueue are concrete classes — __abstractmethods__ absent."
    - "No multiprocessing class in the public API uses ABCMeta or has __abstractmethods__ populated."
    - "Direct access to .__abstractmethods__ on any multiprocessing class raises AttributeError."
    - "All values verified with Python 3.13.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2311.managers_abstract_methods:
  description: "multiprocessing.managers classes — __abstractmethods__ absent from __dict__"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: mp2311

  columns: [id, function, args, expected]
  rows:
    - ["mp2311001", "multiprocessing.managers.BaseManager.__dict__.__contains__",  ["__abstractmethods__"], false]
    - ["mp2311002", "multiprocessing.managers.SyncManager.__dict__.__contains__",  ["__abstractmethods__"], false]
    - ["mp2311003", "multiprocessing.managers.BaseProxy.__dict__.__contains__",    ["__abstractmethods__"], false]

table multiprocessing_extra2311.process_pool_abstract_methods:
  description: "multiprocessing.process.BaseProcess and pool classes — __abstractmethods__ absent from __dict__"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: mp2311

  columns: [id, function, args, expected]
  rows:
    - ["mp2311004", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2311005", "multiprocessing.pool.Pool.__dict__.__contains__",           ["__abstractmethods__"], false]

table multiprocessing_extra2311.queues_abstract_methods:
  description: "multiprocessing.queues classes — __abstractmethods__ absent from __dict__"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: mp2311

  columns: [id, function, args, expected]
  rows:
    - ["mp2311006", "multiprocessing.queues.Queue.__dict__.__contains__",          ["__abstractmethods__"], false]
    - ["mp2311007", "multiprocessing.queues.SimpleQueue.__dict__.__contains__",    ["__abstractmethods__"], false]
    - ["mp2311008", "multiprocessing.queues.JoinableQueue.__dict__.__contains__",  ["__abstractmethods__"], false]

table multiprocessing_extra2311.abstract_methods_raises:
  description: "Direct .__abstractmethods__ access on multiprocessing classes raises AttributeError"
  kind: python_call_raises
  category: abstract_methods
  id_prefix: mp2311

  columns: [id, function, args, expected]
  rows:
    - ["mp2311009", "multiprocessing.managers.BaseManager.__abstractmethods__.__len__",  [], "AttributeError"]
    - ["mp2311010", "multiprocessing.managers.SyncManager.__abstractmethods__.__len__",  [], "AttributeError"]
    - ["mp2311011", "multiprocessing.process.BaseProcess.__abstractmethods__.__len__",   [], "AttributeError"]
    - ["mp2311012", "multiprocessing.pool.Pool.__abstractmethods__.__len__",             [], "AttributeError"]
    - ["mp2311013", "multiprocessing.queues.Queue.__abstractmethods__.__len__",          [], "AttributeError"]
    - ["mp2311014", "multiprocessing.queues.JoinableQueue.__abstractmethods__.__len__",  [], "AttributeError"]

table multiprocessing_extra2311.baseprocess_methods_present:
  description: "multiprocessing.process.BaseProcess has concrete methods but no __abstractmethods__"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: mp2311

  columns: [id, function, args, expected]
  rows:
    - ["mp2311015", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["run"],    true]
    - ["mp2311016", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["start"],  true]
    - ["mp2311017", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["_Popen"], true]
    - ["mp2311018", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2311019", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["start"],    true]
    - ["mp2311020", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["register"], true]
    - ["mp2311021", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__abstractmethods__"], false]
