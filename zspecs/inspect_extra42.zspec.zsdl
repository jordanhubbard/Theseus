spec: inspect_extra42
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra41.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__; Signature/__name__/__module__; isfunction/__name__/__module__; isbuiltin/__name__/__module__; isclass/__name__/__module__; ismodule/__name__/__module__; ismethod/__name__/__module__; getcallargs/__name__/__module__; getfile/__name__/__module__; getdoc/__name__/__module__; getsource/__name__/__module__; getmembers/__name__/__module__; signature/__name__/__module__; cleandoc/__name__/__module__."
    - "This spec covers: inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction'; inspect.iscoroutinefunction.__module__ == 'inspect'; inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction'; inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction'; inspect.isgenerator.__name__ == 'isgenerator'; inspect.isawaitable.__name__ == 'isawaitable'; inspect.stack.__name__ == 'stack'; inspect.currentframe.__name__ == 'currentframe'; inspect.currentframe.__module__ == 'inspect'."
    - "Key findings: inspect.iscoroutinefunction.__name__ is 'iscoroutinefunction' (19 chars) and __module__ is 'inspect' (7 chars) — pure-Python function defined in Lib/inspect.py. inspect.isasyncgenfunction.__name__ is 'isasyncgenfunction' (18 chars) and __module__ is 'inspect'. inspect.isgeneratorfunction.__name__ is 'isgeneratorfunction' (19 chars) and __module__ is 'inspect' — same 19-char length as iscoroutinefunction. inspect.isgenerator.__name__ is 'isgenerator' (11 chars) and __module__ is 'inspect'. inspect.isawaitable.__name__ is 'isawaitable' (11 chars) and __module__ is 'inspect' — same 11-char length as isgenerator. inspect.stack.__name__ is 'stack' (5 chars) and __module__ is 'inspect'. inspect.currentframe.__name__ is 'currentframe' (12 chars) and __module__ is 'inspect' — all pure-Python functions in Lib/inspect.py share __module__ == 'inspect'. Notable: iscoroutinefunction (19) and isgeneratorfunction (19) share the same length; isgenerator (11) and isawaitable (11) share the same length. Prior specs recorded __name__.__len__() and __qualname__.__len__() for these functions but not the string equality invariants for __name__ or __module__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.iscoroutinefunction identity metadata — extra42 namespace
#
# inspect.iscoroutinefunction.__name__ is 'iscoroutinefunction' (19 chars)
# and inspect.iscoroutinefunction.__module__ is 'inspect' (7 chars).
# iscoroutinefunction is a pure-Python predicate defined in Lib/inspect.py
# that tests whether an object is a coroutine function. Its 19-char name
# matches isgeneratorfunction.__name__ length (19 chars). Prior specs
# recorded __name__.__len__()==19 and __qualname__.__len__()==19 but not
# the string equality invariants. These two invariants are new to extra42.
# ---------------------------------------------------------------------------

invariant inspect_extra42.iscoroutinefunction_name:
  description: "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' — pure-Python predicate; 19-char name; same length as isgeneratorfunction.__name__; tests if object is a coroutine function"
  category: identity
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect_extra42.iscoroutinefunction_module:
  description: "inspect.iscoroutinefunction.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; 7-char module name; same as all inspect predicates"
  category: module_metadata
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect async/generator predicate names — extra42 namespace
#
# inspect.isasyncgenfunction.__name__ is 'isasyncgenfunction' (18 chars),
# inspect.isgeneratorfunction.__name__ is 'isgeneratorfunction' (19 chars),
# inspect.isgenerator.__name__ is 'isgenerator' (11 chars), and
# inspect.isawaitable.__name__ is 'isawaitable' (11 chars). All have
# __module__ == 'inspect'. Notable: isgeneratorfunction (19) matches
# iscoroutinefunction (19); isgenerator (11) matches isawaitable (11).
# Prior specs recorded __len__() values but not string equality invariants.
# ---------------------------------------------------------------------------

table inspect_extra42.async_gen_predicate_names:
  description: "inspect async/generator predicate __name__ string equality — isasyncgenfunction/isgeneratorfunction/isgenerator/isawaitable; all pure-Python in Lib/inspect.py"
  kind: python_call_eq
  category: identity
  id_prefix: agpname42

  columns: [id, function, args, expected, description]
  rows:
    - [isasyncgenfunction_name,
       isasyncgenfunction.__name__.__eq__,
       ["isasyncgenfunction"],
       true,
       "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction' — pure-Python predicate; 18-char name; tests if object is an async generator function"]
    - [isgeneratorfunction_name,
       isgeneratorfunction.__name__.__eq__,
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' — pure-Python predicate; 19-char name; same length as iscoroutinefunction.__name__; tests if object is a generator function"]
    - [isgenerator_name,
       isgenerator.__name__.__eq__,
       ["isgenerator"],
       true,
       "inspect.isgenerator.__name__ == 'isgenerator' — pure-Python predicate; 11-char name; same length as isawaitable.__name__; tests if object is a generator"]
    - [isawaitable_name,
       isawaitable.__name__.__eq__,
       ["isawaitable"],
       true,
       "inspect.isawaitable.__name__ == 'isawaitable' — pure-Python predicate; 11-char name; same length as isgenerator.__name__; tests if object is awaitable"]

# ---------------------------------------------------------------------------
# inspect.stack and inspect.currentframe identity metadata — extra42 namespace
#
# inspect.stack.__name__ is 'stack' (5 chars) and inspect.stack.__module__
# is 'inspect' (7 chars). inspect.currentframe.__name__ is 'currentframe'
# (12 chars) and inspect.currentframe.__module__ is 'inspect' (7 chars).
# Both are pure-Python functions in Lib/inspect.py. Prior specs recorded
# __qualname__.__len__() for both but not the string equality invariants for
# __name__ or __module__. These four equality invariants are new to extra42.
# ---------------------------------------------------------------------------

table inspect_extra42.stack_currentframe_names:
  description: "inspect.stack and inspect.currentframe __name__ and __module__ string equality — both pure-Python functions in Lib/inspect.py"
  kind: python_call_eq
  category: identity
  id_prefix: scfname42

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name,
       stack.__name__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__name__ == 'stack' — pure-Python utility; 5-char name; returns list of FrameInfo records for caller's stack"]
    - [stack_module,
       stack.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.stack.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name"]
    - [currentframe_name,
       currentframe.__name__.__eq__,
       ["currentframe"],
       true,
       "inspect.currentframe.__name__ == 'currentframe' — pure-Python utility; 12-char name; returns the frame object of the caller"]
    - [currentframe_module,
       currentframe.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.currentframe.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name; same as stack.__module__"]
