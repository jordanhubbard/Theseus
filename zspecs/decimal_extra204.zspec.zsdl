spec: decimal_extra204
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "_decimal_extra.zspec.zsdl — covers _decimal C-extension class identity"
  notes:
    - "decimal.Decimal.__dict__ is a mappingproxy; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__dict__.__contains__('__add__') == True; arithmetic operators are defined on Decimal; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__dict__.__contains__('__mul__') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__dict__.__contains__('__sub__') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__dict__.__contains__('create_decimal') == True; create_decimal() creates a Decimal from the given value using the context's settings; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__dict__.__contains__('add') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__dict__.__contains__('multiply') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__dict__.__contains__('__matmul__') == False; matrix multiplication is not defined for Decimal; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__dict__.__contains__('__add__') == False; arithmetic operators are not defined on Context itself; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal.__dict__ membership — arithmetic dunder methods
# __add__, __mul__, __sub__ are defined on Decimal; __matmul__ is absent
# ---------------------------------------------------------------------------

table decimal_extra204.decimal_dict_arithmetic:
  description: "decimal.Decimal.__dict__ contains arithmetic dunder method names"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimaldict204

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_has_add,      decimal.Decimal.__dict__.__contains__,  ["__add__"],     true,   "decimal.Decimal.__dict__.__contains__('__add__') == True; __add__ implements the + operator on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_has_mul,      decimal.Decimal.__dict__.__contains__,  ["__mul__"],     true,   "decimal.Decimal.__dict__.__contains__('__mul__') == True; __mul__ implements the * operator on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_has_sub,      decimal.Decimal.__dict__.__contains__,  ["__sub__"],     true,   "decimal.Decimal.__dict__.__contains__('__sub__') == True; __sub__ implements the - operator on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_no_matmul,    decimal.Decimal.__dict__.__contains__,  ["__matmul__"],  false,  "decimal.Decimal.__dict__.__contains__('__matmul__') == False; matrix multiplication is not defined for Decimal; confirmed Python 3.14.3 macOS"]

