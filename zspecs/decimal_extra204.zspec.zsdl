    - [decimal_has_neg,      decimal.Decimal.__dict__.__contains__,  ["__neg__"],      true,  "decimal.Decimal.__dict__.__contains__('__neg__') == True; __neg__ implements unary negation on Decimal; confirmed Python 3.14.3 macOS"]
