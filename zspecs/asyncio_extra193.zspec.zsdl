invariant asyncio_extra193.asyncio_Semaphore_name_eq:
  description: "asyncio.Semaphore.__name__.__eq__('Semaphore') returns True — asyncio.Semaphore is the counting coroutine semaphore; Semaphore.__name__=='Semaphore' (len=9: S(1)e(2)m(3)a(4)p(5)h(6)o(7)r(8)e(9)); a Semaphore with value N allows up to N concurrent 'await sem.acquire()' calls before blocking; 'sem.release()' increments the counter and wakes a waiter if any; Semaphore.__name__ (9) < BoundedSemaphore.__name__ (16) by 7; compare asyncio.Lock.__name__=='Lock' (4) and asyncio.Event.__name__=='Event' (5); NEW in extra193: first standalone Semaphore.__name__.__eq__ invariant in asynciosema193 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra193.asyncio_Semaphore_module_eq:
  description: "asyncio.Semaphore.__module__.__eq__('asyncio.locks') returns True — asyncio.Semaphore is defined in Lib/asyncio/locks.py; Semaphore.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); asyncio.locks also contains Lock, BoundedSemaphore, Event, and Condition — all the asyncio synchronization primitives; Semaphore.__module__ (13) == BoundedSemaphore.__module__ (13) — identical because they share the same source file; compare asyncio.Task.__module__=='asyncio.tasks' (13) — also len 13 but a different submodule; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra193.asyncio_Semaphore_base_is_ContextManagerMixin:
  description: "asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Semaphore inherits from _ContextManagerMixin (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20); _ContextManagerMixin provides __aenter__ and __aexit__ enabling 'async with sem:' syntax; Semaphore and Lock both use _ContextManagerMixin while Event and asyncio.Queue use _LoopBoundMixin; Semaphore.__bases__[0].__name__ (20) — same base mixin as asyncio.Lock; BoundedSemaphore.__bases__[0].__name__=='Semaphore' (9) — BoundedSemaphore inherits from Semaphore, not directly from _ContextManagerMixin; NEW in extra193: standalone Semaphore base class invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra193.asyncio_Semaphore_init_qualname_eq:
  description: "asyncio.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__') returns True — Semaphore.__init__.__qualname__=='Semaphore.__init__' (len=18: 'Semaphore'=9+'.'=1+'__init__'=8=18); Semaphore.__init__ accepts optional 'value' parameter (default 1) setting the initial counter; Semaphore.__init__.__qualname__ (18) < BoundedSemaphore.__init__.__qualname__ (25) by 7 — matching the __name__ gap (9 vs 16); the qualname pattern 'ClassName.__init__' means qualname_len == name_len + 1 + 8 == name_len + 9; NEW in extra193: standalone Semaphore.__init__.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Semaphore.__init__.__qualname__.__eq__"
  args: ["Semaphore.__init__"]
  expected: true

invariant asyncio_extra193.asyncio_BoundedSemaphore_name_eq:
  description: "asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') returns True — asyncio.BoundedSemaphore is the bounded counting semaphore; BoundedSemaphore.__name__=='BoundedSemaphore' (len=16: 'Bounded'=7+'Semaphore'=9=16); BoundedSemaphore raises ValueError in release() if the internal counter would exceed the initial value — this prevents programming errors where release() is called more times than acquire(); BoundedSemaphore.__name__ (16) > Semaphore.__name__ (9) by 7; NEW in extra193: first standalone BoundedSemaphore.__name__.__eq__ invariant in asynciosema193 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra193.asyncio_BoundedSemaphore_module_eq:
  description: "asyncio.BoundedSemaphore.__module__.__eq__('asyncio.locks') returns True — asyncio.BoundedSemaphore is defined alongside asyncio.Semaphore in Lib/asyncio/locks.py; BoundedSemaphore.__module__=='asyncio.locks' (len=13); BoundedSemaphore.__module__ (13) == Semaphore.__module__ (13) — both in asyncio.locks, same length; both classes share the module despite BoundedSemaphore inheriting from Semaphore and adding the value-bound enforcement; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra193.asyncio_BoundedSemaphore_base_is_Semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — asyncio.BoundedSemaphore inherits directly from asyncio.Semaphore (len=9); BoundedSemaphore overrides release() to check that the counter does not exceed _bound_value, raising ValueError if it does; BoundedSemaphore.__bases__[0].__name__=='Semaphore' confirms the single-level inheritance chain: BoundedSemaphore → Semaphore → _ContextManagerMixin; BoundedSemaphore.__bases__[0].__name__ (9) < Lock.__bases__[0].__name__ (20) — Semaphore base (9) is much shorter than _ContextManagerMixin (20); NEW in extra193: standalone BoundedSemaphore base class invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra193.asyncio_BoundedSemaphore_init_qualname_eq:
  description: "asyncio.BoundedSemaphore.__init__.__qualname__.__eq__('BoundedSemaphore.__init__') returns True — BoundedSemaphore.__init__.__qualname__=='BoundedSemaphore.__init__' (len=25: 'BoundedSemaphore'=16+'.'=1+'__init__'=8=25); BoundedSemaphore.__init__ calls super().__init__(value) and additionally sets self._bound_value=value for use in the overridden release() guard; BoundedSemaphore.__init__.__qualname__ (25) > Semaphore.__init__.__qualname__ (18) by 7 — directly reflecting BoundedSemaphore.__name__ (16) > Semaphore.__name__ (9); NEW in extra193: standalone BoundedSemaphore.__init__.__qualname__ invariant completing 8-invariant coverage for asyncio Semaphore and BoundedSemaphore; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.BoundedSemaphore.__init__.__qualname__.__eq__"
  args: ["BoundedSemaphore.__init__"]
  expected: true

