    - [bsema_name_len,   asyncio.BoundedSemaphore.__name__.__len__,   [],                    16,   "asyncio.BoundedSemaphore.__name__.__len__() == 16 ('BoundedSemaphore'=16: 'Bounded'=7+'Semaphore'=9=16); verified Python 3.14.3"]
