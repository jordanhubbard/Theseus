spec: asyncio_extra193
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Semaphore.__name__ == 'Semaphore' (len=9: S(1)e(2)m(3)a(4)p(5)h(6)o(7)r(8)e(9)); Semaphore is the asyncio counting semaphore for coroutines."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); pure Python, not C-accelerated."
    - "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' (len=20); Semaphore supports 'async with' via this mixin."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16: 'Bounded'=7+'Semaphore'=9=16); raises ValueError if released more than acquired."
    - "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' (len=13); shares module with Semaphore."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (len=9); BoundedSemaphore inherits directly from Semaphore."
    - "asyncio.Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len=18: 'Semaphore'=9+'.'=1+'__init__'=8=18)."
    - "asyncio.BoundedSemaphore.__init__.__qualname__ == 'BoundedSemaphore.__init__' (len=25: 'BoundedSemaphore'=16+'.'=1+'__init__'=8=25)."
    - "Length ordering: Semaphore.__name__ (9) < BoundedSemaphore.__name__ (16); Semaphore.__init__.__qualname__ (18) < BoundedSemaphore.__init__.__qualname__ (25)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

