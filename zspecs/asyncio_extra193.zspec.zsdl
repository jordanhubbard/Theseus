    - [sema_module_eq,  asyncio.Semaphore.__module__.__eq__,  ["asyncio.locks"],    true, "asyncio.Semaphore.__module__ == 'asyncio.locks' (len=13; pure Python in Lib/asyncio/locks.py); verified Python 3.14.3"]
