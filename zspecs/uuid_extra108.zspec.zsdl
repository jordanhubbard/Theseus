spec: uuid_extra108
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra107.zspec.zsdl — covers UUID property fget __name__/__module__/__class__.__name__ equality and __name__ lengths (table + invariants)."
    - "uuid_extra103.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __module__ equality / uuid module __name__/__package__/__spec__ identity / UUID.__new__.__qualname__=='object.__new__' (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__.__code__.co_name/__eq__('__init__') / UUID.__init__.__code__.co_argcount/__eq__(7) / UUID.__init__.__qualname__ equality and length / UUID.__str__/__repr__/__eq__/__hash__/__lt__ qualname equality and lengths (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__.__code__.co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra107; it does NOT duplicate invariants present in those files."
    - "Wave 276 theme: UUID.__init__.__code__ attributes not yet covered — co_nlocals, co_kwonlyargcount, co_posonlyargcount, co_varnames.__len__(), and code object class identity. Also: UUID.__new__.__name__ length not yet covered (extra103 anchors __qualname__=='object.__new__' but not __name__ length)."
    - "uuid.UUID.__init__.__code__.co_nlocals == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_kwonlyargcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_posonlyargcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.__class__.__name__ == 'code'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__name__ == '__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__qualname__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__init__ has co_kwonlyargcount==1 because 'is_safe' is a keyword-only argument (introduced in Python 3.7 PEP 568). co_posonlyargcount==0 means no positional-only parameters. co_nlocals==15 equals co_varnames.__len__() (all locals including arguments). The code object's __class__.__name__ is 'code' (a built-in type in the 'builtins' module)."
    - "Note: UUID.__new__ is object.__new__ (the default __new__). It is a builtin_function_or_method with __name__=='__new__' (7 chars). Its __qualname__ is 'object.__new__' (14 chars, anchored in uuid_extra103). __name__.__len__()==7 and __qualname__.__len__()==14 differ by 7 chars ('object.' prefix = 7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_nlocals == 15
# uuid.UUID.__init__.__code__.co_kwonlyargcount == 1
# uuid.UUID.__init__.__code__.co_posonlyargcount == 0
# uuid.UUID.__init__.__code__.co_varnames.__len__() == 15
# uuid.UUID.__init__.__code__.__class__.__name__.__eq__('code')
#
# Wave 276 theme: UUID.__init__.__code__ extended code object attributes.
#
# uuid_extra86 and uuid_extra99 anchor co_name=='__init__' and co_argcount==7.
# This spec anchors the remaining key code object attributes: co_nlocals (15),
# co_kwonlyargcount (1 — 'is_safe' is keyword-only), co_posonlyargcount (0 — no
# positional-only params in UUID.__init__), co_varnames.__len__()==15, and the
# code object's own class identity ('code' from builtins). None of these are
# in prior uuid specs. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra108.UUID_init_code_extended_attributes:
  description: "UUID.__init__.__code__.co_nlocals==15 / UUID.__init__.__code__.co_kwonlyargcount==1 / UUID.__init__.__code__.co_posonlyargcount==0 / UUID.__init__.__code__.co_varnames.__len__()==15 / UUID.__init__.__code__.__class__.__name__.__eq__('code')==True — co_nlocals=co_varnames len=15 (all locals equal all varnames); co_kwonlyargcount=1 ('is_safe' is keyword-only, PEP 568); co_posonlyargcount=0 (no positional-only params); code class is 'code' (built-in type); extra86/extra99 anchor co_name/co_argcount; first uuidcode108 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcode108

  columns: [id, function, args, expected, description]
  rows:
    - [co_nlocals_15,       "UUID.__init__.__code__.co_nlocals.__eq__",       [15], true, "UUID.__init__.__code__.co_nlocals is 15 (all local variables including arguments; equals co_varnames.__len__())"]
    - [co_kwonlyargcount_1, "UUID.__init__.__code__.co_kwonlyargcount.__eq__",[1],  true, "UUID.__init__.__code__.co_kwonlyargcount is 1 ('is_safe' is keyword-only argument; introduced Python 3.7 PEP 568)"]
    - [co_posonlyargcount_0,"UUID.__init__.__code__.co_posonlyargcount.__eq__",[0],  true, "UUID.__init__.__code__.co_posonlyargcount is 0 (no positional-only parameters in UUID.__init__)"]
    - [co_varnames_len_15,  "UUID.__init__.__code__.co_varnames.__len__",     [],   15,   "UUID.__init__.__code__.co_varnames.__len__() is 15 (all named variables: 7 args + 1 kwonly + 7 internal locals)"]
    - [code_class_name_eq,  "UUID.__init__.__code__.__class__.__name__.__eq__",["code"],true,"UUID.__init__.__code__.__class__.__name__ is 'code' (the code object type; built-in to CPython)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.__class__.__name__.__eq__('code')
# uuid.UUID.__init__.__code__.__class__.__module__.__eq__('builtins')
# uuid.UUID.__init__.__code__.__class__.__name__.__len__() == 4
# uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.__init__.__code__.co_varnames[0].__len__() == 4
#
# Wave 276 theme: UUID.__init__ code object class identity and co_varnames[0].
#
# The code object's class is 'code' from the 'builtins' module (4-char class name,
# 8-char module name). co_varnames[0] is always 'self' for instance methods (the
# first positional argument). 'self' is 4 chars. No prior uuid spec anchors
# code object class identity or co_varnames indexing as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra108.UUID_init_code_class_identity_and_varnames:
  description: "UUID.__init__.__code__.__class__.__name__.__eq__('code')==True / UUID.__init__.__code__.__class__.__module__.__eq__('builtins')==True / UUID.__init__.__code__.__class__.__name__.__len__()==4 / UUID.__init__.__code__.co_varnames[0].__eq__('self')==True / UUID.__init__.__code__.co_varnames[0].__len__()==4 — code class is 'code' (4 chars) from 'builtins' (8 chars); co_varnames[0]=='self' (first arg of instance method; 4 chars); no prior spec anchors code class identity or varnames indexing; first uuidcode108 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcode108

  columns: [id, function, args, expected, description]
  rows:
    - [code_class_name_eq2,   "UUID.__init__.__code__.__class__.__name__.__eq__",   ["code"],     true, "UUID.__init__.__code__.__class__.__name__ is 'code' (4 chars; the code object type; internal to CPython)"]
    - [code_class_module_eq,  "UUID.__init__.__code__.__class__.__module__.__eq__", ["builtins"], true, "UUID.__init__.__code__.__class__.__module__ is 'builtins' (code type is a built-in; no import needed)"]
    - [code_class_name_len,   "UUID.__init__.__code__.__class__.__name__.__len__",  [],           4,    "UUID.__init__.__code__.__class__.__name__.__len__() is 4 (len('code')==4; very short built-in type name)"]
    - [co_varnames_0_eq,      "UUID.__init__.__code__.co_varnames.__getitem__",     [0],          "self","UUID.__init__.__code__.co_varnames[0] is 'self' (first argument of instance method; 4 chars)"]
    - [co_varnames_len_15b,   "UUID.__init__.__code__.co_varnames.__len__",         [],           15,   "UUID.__init__.__code__.co_varnames.__len__() is 15 (cross-check; co_varnames has 15 entries equaling co_nlocals)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__new__.__name__.__eq__('__new__')
# uuid.UUID.__new__.__name__.__len__() == 7
# uuid.UUID.__new__.__qualname__.__len__() == 14
# uuid.UUID.__new__.__class__.__name__.__eq__('builtin_function_or_method')
# uuid.UUID.__init__.__code__.co_nlocals.__eq__(15)
#
# Wave 276 theme: UUID.__new__ name and qualname lengths.
#
# UUID.__new__ is object.__new__ (the default __new__ from object). Its __name__
# is '__new__' (7 chars). Its __qualname__ is 'object.__new__' (14 chars, anchored
# in uuid_extra103). The difference between name and qualname lengths is 7 chars
# ('object.' prefix = 7 chars). __new__ is a builtin_function_or_method (C-level).
# No prior uuid spec anchors __new__.__name__.__len__() or qualname length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra108.UUID_new_name_and_qualname_lengths:
  description: "UUID.__new__.__name__.__eq__('__new__')==True / UUID.__new__.__name__.__len__()==7 / UUID.__new__.__qualname__.__len__()==14 / UUID.__new__.__class__.__name__.__eq__('builtin_function_or_method')==True / UUID.__init__.__code__.co_nlocals.__eq__(15)==True — __new__ name is '__new__' (7 chars; standard dunder); qualname is 'object.__new__' (14 chars; 7 more than __name__ due to 'object.' prefix); __new__ is builtin_function_or_method (C-level); extra103 anchors qualname equality; first uuidcode108 anchor for name/qualname lengths"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidcode108

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,       "UUID.__new__.__name__.__eq__",              ["__new__"],                   true, "UUID.__new__.__name__ is '__new__' (7 chars; standard dunder for object construction)"]
    - [new_name_len_7,    "UUID.__new__.__name__.__len__",             [],                            7,    "UUID.__new__.__name__.__len__() is 7 (len('__new__')==7; two underscores each side of 'new'=3)"]
    - [new_qualname_len,  "UUID.__new__.__qualname__.__len__",         [],                            14,   "UUID.__new__.__qualname__.__len__() is 14 (len('object.__new__')==14; 7 more than __name__ due to 'object.' prefix)"]
    - [new_class_eq,      "UUID.__new__.__class__.__name__.__eq__",    ["builtin_function_or_method"],true, "UUID.__new__.__class__.__name__ is 'builtin_function_or_method' (C-level builtin; object.__new__ is from the C runtime)"]
    - [co_nlocals_eq_15,  "UUID.__init__.__code__.co_nlocals.__eq__",  [15],                          true, "UUID.__init__.__code__.co_nlocals is 15 (cross-check; number of local variables including all arguments)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_nlocals == 15 — standalone
#
# uuid.UUID.__init__.__code__.co_nlocals is 15. co_nlocals counts the number of
# local variables used by the function, including arguments. UUID.__init__ has
# 7 positional args (self, hex, bytes, bytes_le, fields, int, version), 1
# keyword-only arg (is_safe), and 7 additional locals (time_low, time_mid,
# time_hi_version, clock_seq_hi_variant, clock_seq_low, node, clock_seq) used
# internally. 7 + 1 + 7 = 15 equals co_nlocals. No prior uuid spec anchors
# co_nlocals as a standalone under uuidcode108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra108.UUID_init_co_nlocals_15:
  description: "uuid.UUID.__init__.__code__.co_nlocals.__eq__(15) == True — 15 local variables: 7 positional args (self/hex/bytes/bytes_le/fields/int/version) + 1 kwonly (is_safe) + 7 internal locals (time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/clock_seq); co_nlocals==co_varnames.__len__()==15; no prior spec anchors co_nlocals as standalone; first standalone under uuidcode108"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_nlocals.__eq__"
  args: [15]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_kwonlyargcount == 1 — standalone
#
# uuid.UUID.__init__.__code__.co_kwonlyargcount is 1. The single keyword-only
# argument is 'is_safe', which was added in Python 3.7 (PEP 568) to mark UUID
# objects as having been generated using a UUID generator that is safe for
# multiprocessing. Keyword-only arguments follow a bare '*' in the signature
# or all args after '*args'. co_kwonlyargcount counts these separately from
# co_argcount. No prior uuid spec anchors co_kwonlyargcount as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra108.UUID_init_co_kwonlyargcount_1:
  description: "uuid.UUID.__init__.__code__.co_kwonlyargcount.__eq__(1) == True — 1 keyword-only arg: 'is_safe' (added Python 3.7 PEP 568; marks safe multiprocessing UUID generation); keyword-only args are separate from co_argcount=7; co_kwonlyargcount counts args after '*' separator; no prior spec anchors co_kwonlyargcount as standalone; first standalone under uuidcode108"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_kwonlyargcount.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self') — standalone
#
# uuid.UUID.__init__.__code__.co_varnames[0] is 'self'. By Python convention,
# the first argument to an instance method is always 'self' (the instance being
# constructed or operated on). co_varnames is a tuple of all local variable names
# in order: positional args first, then keyword-only args, then regular locals.
# 'self' at index 0 is 4 chars. No prior uuid spec anchors co_varnames indexing
# as a standalone under uuidcode108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra108.UUID_init_co_varnames_0_self:
  description: "uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self') == True — co_varnames[0] is 'self' (4 chars; first argument of instance method by Python convention); co_varnames tuple order: positional args, then kwonly, then locals; 'self' is always first for non-static instance methods; no prior spec anchors co_varnames indexing as standalone; first standalone under uuidcode108"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "self"

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.__class__.__name__.__eq__('code') — standalone
#
# uuid.UUID.__init__.__code__.__class__.__name__ is 'code'. The code object type
# is a CPython implementation detail representing compiled bytecode. It is a
# built-in type (from 'builtins') with the short name 'code' (4 chars). Code
# objects contain co_argcount, co_varnames, co_code (bytecode), and many other
# fields used by the CPython interpreter. No prior uuid spec anchors the code
# object's class name as a standalone under uuidcode108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra108.UUID_init_code_class_name_code:
  description: "uuid.UUID.__init__.__code__.__class__.__name__.__eq__('code') == True — code object type is 'code' (4 chars; CPython built-in type; contains bytecode + co_argcount/co_varnames/etc.); __class__.__module__=='builtins' (no import needed); no prior spec anchors code class name as standalone; first standalone under uuidcode108"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__init__.__code__.__class__.__name__.__eq__"
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__new__.__name__.__len__() == 7 — standalone
#
# uuid.UUID.__new__.__name__.__len__() is 7. '__new__' has 7 chars: two leading
# underscores (2) + 'new' (3) + two trailing underscores (2) = 7. UUID.__new__
# is object.__new__ — the default implementation that allocates a new instance.
# Its __qualname__ is 'object.__new__' (14 chars = 'object.' (7) + '__new__' (7)),
# anchored in uuid_extra103. The difference between qualname and name lengths
# is exactly 7 (the 'object.' prefix). No prior uuid spec anchors
# UUID.__new__.__name__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra108.UUID_new_name_len_7:
  description: "uuid.UUID.__new__.__name__.__len__() == 7 — len('__new__')==7 (2+3+2; double underscores around 'new'); qualname len is 14 ('object.__new__'); difference is 7 chars ('object.' prefix); extra103 anchors qualname equality; no prior spec anchors __new__ name length as standalone; first standalone under uuidcode108"
  category: function_identity
  kind: python_call_eq
  function: "UUID.__new__.__name__.__len__"
  args: []
  expected: 7
