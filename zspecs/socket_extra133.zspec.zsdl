spec: socket_extra133
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra132.zspec.zsdl — covers socket.socket.bind/connect/listen qualname equality / send/recv qualname equality / bind/connect/listen/send/recv __class__.__name__=='method_descriptor' / __init__ and accept qualname equality (table + invariants)."
    - "socket_extra131.zspec.zsdl — covers socket.AF_INET/AF_INET6/AF_UNIX and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW enum value equality / AddressFamily and SocketKind class name lengths (table + invariants)."
    - "socket_extra130.zspec.zsdl — covers socket module Python function code attributes — create_connection/getfqdn/getaddrinfo co_name/co_argcount/co_varnames[0]/co_varnames.__len__() (table + invariants)."
    - "socket_extra129.zspec.zsdl — covers socket.__all__ list membership / socket.socket C method __objclass__.__name__ equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / gethostname/gethostbyname builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 348 theme: socket.gethostname/__name__/__qualname__/__module__ equality / socket.gethostbyname identity / socket.getfqdn __name__/__module__/co_varnames[0] / socket.getaddrinfo co_varnames.__len__() and co_varnames[0] / socket.socket.__name__/__qualname__/__module__ class identity."
    - "socket.gethostname.__name__ == 'gethostname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__ == 'gethostname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket'. gethostname is a C builtin from the _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__name__ == 'gethostbyname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__name__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. getfqdn is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_varnames[0] == 'name'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_varnames.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__code__.co_varnames[0] == 'host'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra96 anchors gethostname/gethostbyname as builtins (class name) at table level; extra94 anchors module-level function __qualname__ and __module__; extra130 anchors getfqdn/getaddrinfo co_name/co_argcount/co_varnames[0]/__len__. This spec anchors gethostname/gethostbyname __name__/__qualname__/__module__ equality, getfqdn co_varnames[0] and __module__, getaddrinfo co_varnames.__len__(), and socket.socket class identity via __eq__ calls under sockident133."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostname.__name__.__eq__('gethostname')
# socket.gethostname.__qualname__.__eq__('gethostname')
# socket.gethostname.__module__.__eq__('_socket')
# socket.gethostbyname.__name__.__eq__('gethostbyname')
# socket.gethostbyname.__module__.__eq__('_socket')
#
# Wave 348 theme: gethostname and gethostbyname C builtin identity.
#
# socket.gethostname and socket.gethostbyname are C builtin functions from the
# _socket extension (class 'builtin_function_or_method'). Their __module__ is
# '_socket' (not 'socket'). socket_extra96 anchors their class as
# 'builtin_function_or_method' at table level; socket_extra94 anchors their
# __qualname__ and __module__ at table level. This spec anchors __name__/
# __qualname__/__module__ via __eq__ method calls under sockident133 as a
# cross-check. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra133.gethostname_gethostbyname_identity:
  description: "socket.gethostname/__name__.__eq__('gethostname')==True / gethostname/__qualname__.__eq__('gethostname')==True / gethostname/__module__.__eq__('_socket')==True / gethostbyname/__name__.__eq__('gethostbyname')==True / gethostbyname/__module__.__eq__('_socket')==True — gethostname/gethostbyname are C builtins from _socket; extra96 anchors class name; extra94 anchors __qualname__/__module__; first sockident133 anchor via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockident133

  columns: [id, function, args, expected, description]
  rows:
    - [hostname_name,     gethostname.__name__.__eq__,     ["gethostname"],  true, "gethostname.__name__ is 'gethostname' (11 chars)"]
    - [hostname_qualname, gethostname.__qualname__.__eq__,  ["gethostname"],  true, "gethostname.__qualname__ is 'gethostname' (top-level C builtin, no class prefix)"]
    - [hostname_module,   gethostname.__module__.__eq__,   ["_socket"],      true, "gethostname.__module__ is '_socket' (C extension origin)"]
    - [hostbyname_name,   gethostbyname.__name__.__eq__,   ["gethostbyname"], true, "gethostbyname.__name__ is 'gethostbyname' (13 chars)"]
    - [hostbyname_module, gethostbyname.__module__.__eq__, ["_socket"],      true, "gethostbyname.__module__ is '_socket' (C extension origin)"]

# ---------------------------------------------------------------------------
# socket.getfqdn.__name__.__eq__('getfqdn')
# socket.getfqdn.__module__.__eq__('socket')
# socket.getfqdn.__code__.co_varnames[0].__eq__('name')
# socket.getaddrinfo.__code__.co_varnames[0].__eq__('host')
# socket.getaddrinfo.__code__.co_varnames.__len__().__eq__(12)
#
# Wave 348 theme: getfqdn and getaddrinfo pure-Python function code attributes.
#
# socket.getfqdn and socket.getaddrinfo are pure-Python functions defined in
# Lib/socket.py (class 'function'). getfqdn's first parameter is 'name' (the
# hostname to expand); getaddrinfo's first parameter is 'host'. getaddrinfo has
# 12 total co_varnames (6 parameters + 6 internal locals: addrlist, res, af,
# socktype, canonname, sa). socket_extra130 anchors getfqdn/getaddrinfo
# co_name/co_argcount at table level; this spec anchors co_varnames[0] and
# getaddrinfo.__code__.co_varnames.__len__()==12 under sockident133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra133.getfqdn_getaddrinfo_code_attrs:
  description: "socket.getfqdn/__name__.__eq__('getfqdn')==True / getfqdn/__module__.__eq__('socket')==True / getfqdn/__code__/co_varnames[0].__eq__('name')==True / getaddrinfo/__code__/co_varnames[0].__eq__('host')==True / getaddrinfo/__code__/co_varnames/__len__()==12 — getfqdn/getaddrinfo are pure-Python functions; getfqdn first param is 'name'; getaddrinfo first param is 'host'; getaddrinfo has 12 total locals (6 params + 6 internal); extra130 anchors co_name/co_argcount; first sockident133 anchor for co_varnames"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockident133

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_name,    getfqdn.__name__.__eq__,                       ["getfqdn"],  true, "getfqdn.__name__ is 'getfqdn' (7 chars)"]
    - [getfqdn_module,  getfqdn.__module__.__eq__,                     ["socket"],   true, "getfqdn.__module__ is 'socket' (pure-Python in Lib/socket.py)"]
    - [getfqdn_var0,    "getfqdn.__code__.co_varnames[0].__eq__",      ["name"],     true, "getfqdn first parameter is 'name' (the hostname to expand to FQDN)"]
    - [getaddrinfo_var0, "getaddrinfo.__code__.co_varnames[0].__eq__", ["host"],     true, "getaddrinfo first parameter is 'host'"]
    - [getaddrinfo_varlen, "getaddrinfo.__code__.co_varnames.__len__", [],           12,   "getaddrinfo has 12 total co_varnames (6 params: host,port,family,type,proto,flags + 6 locals)"]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket')
# socket.socket.__qualname__.__eq__('socket')
# socket.socket.__module__.__eq__('socket')
# socket.socket.__qualname__.__len__().__eq__(6)
# socket.gethostbyname.__qualname__.__eq__('gethostbyname')
#
# Wave 348 theme: socket.socket class identity and gethostbyname qualname.
#
# socket.socket is a Python class that subclasses _socket.socket (the C extension
# type). Its __name__ is 'socket' (the class name), __qualname__ is 'socket' (6
# chars, no nesting), and __module__ is 'socket' (defined in Lib/socket.py).
# Note: the socket module and the socket class share the attribute name 'socket'
# in the module namespace. socket_extra94 anchors module-level function qualnames
# and modules; this spec anchors socket.socket class identity under sockident133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra133.socket_class_identity:
  description: "socket.socket/__name__.__eq__('socket')==True / socket.socket/__qualname__.__eq__('socket')==True / socket.socket/__module__.__eq__('socket')==True / socket.socket/__qualname__/__len__()==6 / gethostbyname/__qualname__.__eq__('gethostbyname')==True — socket.socket is a Python subclass of C _socket.socket; __name__/__qualname__ are both 'socket' (6 chars); first sockident133 anchor for socket.socket class identity and gethostbyname qualname via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockident133

  columns: [id, function, args, expected, description]
  rows:
    - [socket_name,         "socket.__name__.__eq__",         ["socket"], true, "socket.socket.__name__ is 'socket' (the class name, same as the module attribute name)"]
    - [socket_qualname,     "socket.__qualname__.__eq__",     ["socket"], true, "socket.socket.__qualname__ is 'socket' (top-level, no nesting)"]
    - [socket_module,       "socket.__module__.__eq__",       ["socket"], true, "socket.socket.__module__ is 'socket' (Python subclass defined in Lib/socket.py)"]
    - [socket_qualname_len, "socket.__qualname__.__len__",    [],         6,    "len('socket') == 6"]
    - [hostbyname_qualname, gethostbyname.__qualname__.__eq__, ["gethostbyname"], true, "gethostbyname.__qualname__ is 'gethostbyname' (13 chars)"]

# ---------------------------------------------------------------------------
# socket.gethostname.__name__.__eq__('gethostname') — standalone
#
# socket.gethostname.__name__ is 'gethostname' (11 chars). gethostname is a C
# builtin that wraps the POSIX gethostname(3) system call. It returns the hostname
# of the current machine. Its __name__ equals its __qualname__ (both 'gethostname')
# since it is a top-level C builtin without class nesting. socket_extra94 anchors
# gethostname __qualname__ and __module__ at table level; this is the first
# standalone for gethostname.__name__.__eq__('gethostname') under sockident133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra133.gethostname_name:
  description: "socket.gethostname.__name__.__eq__('gethostname') == True — gethostname wraps POSIX gethostname(3); __name__ == __qualname__ == 'gethostname' (11 chars); extra94 anchors __qualname__/__module__ at table level; first standalone for gethostname.__name__.__eq__ under sockident133"
  category: type_identity
  kind: python_call_eq
  function: gethostname.__name__.__eq__
  args: ["gethostname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__module__.__eq__('_socket') — standalone
#
# socket.gethostname.__module__ is '_socket'. Like struct.pack whose __module__
# is '_struct', socket.gethostname comes from the _socket C extension but is
# re-exported in the 'socket' namespace. Its __module__ attribute reveals the
# C-level origin. This two-layer architecture (socket.py / _socket.so) allows
# Python code in Lib/socket.py to wrap and extend the C primitives.
# socket_extra94 anchors gethostname __module__=='_socket' at table level; this
# is the first standalone for gethostname.__module__.__eq__('_socket')
# under sockident133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra133.gethostname_module:
  description: "socket.gethostname.__module__.__eq__('_socket') == True — gethostname comes from _socket C extension (re-exported in socket namespace); same pattern as struct.pack/__module__=='_struct'; extra94 anchors __module__ at table level; first standalone for gethostname.__module__.__eq__ under sockident133"
  category: type_identity
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket'. The socket.socket class is a Python subclass
# of _socket.socket that adds pure-Python methods like __init__, accept, makefile,
# and close. Its __name__ is 'socket' — the class name — which is the same as
# the module attribute name 'socket'. This creates the notation socket.socket
# (module.class) where both names are 'socket'. socket_extra94 anchors module-
# level function qualnames; this is the first standalone for
# socket.socket.__name__.__eq__('socket') under sockident133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra133.socket_class_name:
  description: "socket.socket.__name__.__eq__('socket') == True — socket.socket class __name__ is 'socket' (same as module attribute name, creating socket.socket notation); Python subclass of _socket.socket; first standalone for socket.socket.__name__.__eq__ under sockident133"
  category: type_identity
  kind: python_call_eq
  function: "socket.__name__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__code__.co_varnames[0].__eq__('name') — standalone
#
# socket.getfqdn.__code__.co_varnames[0] is 'name'. The getfqdn function's
# first (and only explicit) parameter is 'name', the hostname to expand into
# a fully qualified domain name. If 'name' is empty, getfqdn uses gethostname()
# to obtain the local hostname. socket_extra130 anchors getfqdn co_argcount==1
# at table level; this is the first standalone for getfqdn co_varnames[0]
# under sockident133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra133.getfqdn_co_varnames_0:
  description: "socket.getfqdn.__code__.co_varnames[0].__eq__('name') == True — getfqdn's only explicit parameter is 'name' (hostname to expand); empty string causes gethostname() lookup; extra130 anchors co_argcount==1; first standalone for getfqdn co_varnames[0] under sockident133"
  category: type_identity
  kind: python_call_eq
  function: "getfqdn.__code__.co_varnames[0].__eq__"
  args: ["name"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_varnames.__len__().__eq__(12) — standalone
#
# socket.getaddrinfo.__code__.co_varnames.__len__() is 12. getaddrinfo has 6
# formal parameters (host, port, family, type, proto, flags) plus 6 internal
# local variables (addrlist, res, af, socktype, canonname, sa) used during
# resolution iteration. This high local count reflects getaddrinfo's role as
# a comprehensive address resolution function that iterates over multiple
# results from the OS resolver. socket_extra130 anchors getaddrinfo co_argcount==6;
# this is the first standalone for co_varnames.__len__()==12 under sockident133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra133.getaddrinfo_co_varnames_len:
  description: "socket.getaddrinfo.__code__.co_varnames.__len__() == 12 — getaddrinfo has 12 locals (6 params: host/port/family/type/proto/flags + 6 internal: addrlist/res/af/socktype/canonname/sa); reflects comprehensive OS resolver iteration; extra130 anchors co_argcount==6; first standalone for co_varnames.__len__()==12 under sockident133"
  category: type_identity
  kind: python_call_eq
  function: "getaddrinfo.__code__.co_varnames.__len__"
  args: []
  expected: 12

