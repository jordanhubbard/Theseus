spec: asyncio_extra1741
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "Theme: which asyncio stdlib types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "All asyncio types are pure Python synchronization/task classes with no descriptor protocol semantics."
    - "asyncio.Future: represents an eventual computation result; no descriptor methods in own __dict__ -> all False."
    - "asyncio.Task: subclass of Future; no descriptor methods in own __dict__ -> all False."
    - "asyncio.Lock: synchronization primitive; no descriptor methods in own __dict__ -> all False."
    - "asyncio.Event: synchronization primitive; no descriptor methods in own __dict__ -> all False."
    - "asyncio.Semaphore: synchronization primitive; no descriptor methods in own __dict__ -> all False."
    - "asyncio.Queue: FIFO queue; no descriptor methods in own __dict__ -> all False."
    - "asyncio.Condition: synchronization primitive; no descriptor methods in own __dict__ -> all False."
    - "Rationale: asyncio types model async execution state, not attribute access protocols."
    - "Cross-check: __get__ is the key data-model hook that makes a class a non-data or data descriptor. None of the asyncio types are designed to be used as descriptors on other classes."
    - "Cross-check: __set_name__ is called when a descriptor is assigned to a class body; asyncio types are instantiated at runtime, not at class definition time."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks (__get__, __set__, __delete__)
#
# Wave 563 theme: do asyncio types define descriptor dunders in their own
# __dict__? asyncio.Future and asyncio.Task are concrete task-tracking classes;
# they carry state about a pending computation result, not attribute-access
# protocol logic. asyncio.Lock and asyncio.Event are synchronization primitives
# modelled after threading.Lock/Event. None of these types are intended to be
# used as descriptors on other classes, so none define __get__, __set__, or
# __delete__ in their own __dict__. All checks return False.
# ---------------------------------------------------------------------------

table asyncio_extra1741.descriptor_protocol:
  description: "asyncio types: __get__, __set__, __delete__ dict-presence checks (all False — no descriptor protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1741

  columns: [id, function, args, expected]
  rows:
    - ["as1741001", "asyncio.Future.__dict__.__contains__",    ["__get__"],    false]
    - ["as1741002", "asyncio.Future.__dict__.__contains__",    ["__set__"],    false]
    - ["as1741003", "asyncio.Future.__dict__.__contains__",    ["__delete__"], false]
    - ["as1741004", "asyncio.Task.__dict__.__contains__",      ["__get__"],    false]
    - ["as1741005", "asyncio.Task.__dict__.__contains__",      ["__set__"],    false]
    - ["as1741006", "asyncio.Task.__dict__.__contains__",      ["__delete__"], false]
    - ["as1741007", "asyncio.Lock.__dict__.__contains__",      ["__get__"],    false]
    - ["as1741008", "asyncio.Lock.__dict__.__contains__",      ["__set__"],    false]
    - ["as1741009", "asyncio.Lock.__dict__.__contains__",      ["__delete__"], false]
    - ["as1741010", "asyncio.Event.__dict__.__contains__",     ["__get__"],    false]

# ---------------------------------------------------------------------------
# Table 2: __set_name__ dict-presence cross-checks
#
# Wave 563 cross-check: __set_name__ is called by the metaclass (type.__new__)
# when a descriptor is stored as a class attribute. Since asyncio types are not
# descriptors, none of them implement __set_name__ in their own __dict__. This
# table extends the cross-check to all major asyncio synchronization primitives
# and also confirms __get__ absence for Semaphore, Queue, and Condition (which
# were not covered in Table 1). Together the two tables give complete coverage
# of __get__, __set__, __delete__, and __set_name__ across seven asyncio types.
# ---------------------------------------------------------------------------

table asyncio_extra1741.set_name_protocol:
  description: "asyncio types: __set_name__ dict-presence cross-checks and __get__ extension (all False — not descriptors)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1741

  columns: [id, function, args, expected]
  rows:
    - ["as1741011", "asyncio.Future.__dict__.__contains__",    ["__set_name__"], false]
    - ["as1741012", "asyncio.Task.__dict__.__contains__",      ["__set_name__"], false]
    - ["as1741013", "asyncio.Lock.__dict__.__contains__",      ["__set_name__"], false]
    - ["as1741014", "asyncio.Event.__dict__.__contains__",     ["__set_name__"], false]
    - ["as1741015", "asyncio.Semaphore.__dict__.__contains__", ["__set_name__"], false]
    - ["as1741016", "asyncio.Queue.__dict__.__contains__",     ["__set_name__"], false]
    - ["as1741017", "asyncio.Condition.__dict__.__contains__", ["__set_name__"], false]
    - ["as1741018", "asyncio.Semaphore.__dict__.__contains__", ["__get__"],      false]
    - ["as1741019", "asyncio.Queue.__dict__.__contains__",     ["__get__"],      false]
    - ["as1741020", "asyncio.Condition.__dict__.__contains__", ["__get__"],      false]
    - ["as1741021", "asyncio.Event.__dict__.__contains__",     ["__set__"],      false]
    - ["as1741022", "asyncio.Semaphore.__dict__.__contains__", ["__set__"],      false]
    - ["as1741023", "asyncio.Queue.__dict__.__contains__",     ["__delete__"],   false]
    - ["as1741024", "asyncio.Condition.__dict__.__contains__", ["__delete__"],   false]
    - ["as1741025", "asyncio.Condition.__dict__.__contains__", ["__set__"],      false]
