spec: uuid_extra150
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra149.zspec.zsdl — covers uuid.UUID.__init__/__qualname__/__code__.co_argcount==7/__code__.co_name / __str__/__repr__/__hash__/__eq__ co_name and co_argcount ordering (table + invariants)."
    - "uuid_extra148.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') / NAMESPACE_URL/__class__.__name__.__eq__('UUID') / NAMESPACE_OID/__class__.__name__.__eq__('UUID') / NAMESPACE_X500/__class__.__name__.__eq__('UUID') / NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__') / SafeUUID.__name__.__eq__('SafeUUID') / SafeUUID.__module__.__eq__('uuid') (table + invariants)."
    - "uuid_extra147.zspec.zsdl — covers uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__contains__('int'/'is_safe'/'__weakref__') / UUID.__slots__.__len__()==3 / UUID.__hash__/__str__/__repr__/__eq__ qualname lengths (table + invariants)."
    - "uuid_extra145.zspec.zsdl — covers uuid.UUID.hex/__bytes/__version/__variant/__node/__time/__class__.__name__.__eq__('property') / UUID.int/__class__.__name__.__eq__('member_descriptor') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra149."
    - "Wave 340 theme: uuid.UUID property fget qualnames — UUID.hex.fget.__qualname__ / UUID.bytes.fget.__qualname__ / UUID.version.fget.__qualname__ / UUID.variant.fget.__qualname__ / UUID.urn.fget.__qualname__ / UUID.fields.fget.__qualname__; all follow 'UUID.' prefix pattern; fget is a plain Python 'function'."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int is a member_descriptor (not a property), so it has no fget attribute. uuid.UUID.is_safe is also a member_descriptor. The actual property attributes (with fget) are: hex, bytes, bytes_le, fields, time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node, time, clock_seq, version, variant, urn. All are defined as @property in Lib/uuid.py."
    - "Note: uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (8 chars = 'UUID.'=5 + 'hex'=3). The property getter functions are plain Python functions (fget.__class__.__name__ == 'function'). Their qualnames follow 'UUID.' + property_name. 'hex' (3 chars) and 'urn' (3 chars) are the shortest property names. 'version'/'variant' (7 chars each) give 12-char qualnames, the longest in this spec."
    - "Note: uuid.UUID.version.fget.__qualname__ == 'UUID.version' (12 chars) and uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (12 chars). Both version and variant are 7-char property names giving 12-char qualnames (5+7). version returns the UUID version number (1-5) or None for non-RFC 4122 UUIDs. variant returns the UUID variant (RFC 4122, reserved NCS, reserved Microsoft, or reserved future)."
    - "Note: uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (8 chars = 'UUID.'=5 + 'urn'=3). urn returns the UUID as a URN string in the form 'urn:uuid:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX'. 'urn' ties 'hex' at 3 chars as the shortest property name. UUID.urn.fget.__qualname__ (8) < UUID.fields.fget.__qualname__ (11) < UUID.version.fget.__qualname__ (12)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex')
# uuid.UUID.bytes.fget.__qualname__.__eq__('UUID.bytes')
# uuid.UUID.version.fget.__qualname__.__eq__('UUID.version')
# uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant')
#
# Wave 340 theme: UUID property getter function qualnames.
#
# UUID.hex.fget.__qualname__ == 'UUID.hex' (8 chars = 'UUID.'=5 + 'hex'=3).
# UUID.bytes.fget.__qualname__ == 'UUID.bytes' (10 chars = 'UUID.'=5 + 'bytes'=5).
# UUID.version.fget.__qualname__ == 'UUID.version' (12 chars = 'UUID.'=5 + 'version'=7).
# UUID.variant.fget.__qualname__ == 'UUID.variant' (12 chars = 'UUID.'=5 + 'variant'=7).
# All fget functions are Python 'function' objects (not C builtins).
# extra145 anchors UUID.hex.__class__.__name__=='property'; no prior uuid spec anchors
# hex/bytes/version/variant fget qualname strings as a table under uuidfget150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra150.UUID_property_fget_qualnames_part1:
  description: "uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex')==True / UUID.bytes.fget.__qualname__.__eq__('UUID.bytes')==True / UUID.version.fget.__qualname__.__eq__('UUID.version')==True / UUID.variant.fget.__qualname__.__eq__('UUID.variant')==True — hex.fget.__qualname__ is 'UUID.hex' (8 chars = 'UUID.'=5 + 'hex'=3; hex returns UUID as 32-char hex string without hyphens); bytes.fget.__qualname__ is 'UUID.bytes' (10 chars = 'UUID.'=5 + 'bytes'=5; returns UUID as 16-byte string); version.fget.__qualname__ is 'UUID.version' (12 chars = 'UUID.'=5 + 'version'=7; UUID version 1-5 or None); variant.fget.__qualname__ is 'UUID.variant' (12 chars = 'UUID.'=5 + 'variant'=7; RFC 4122/reserved NCS/reserved Microsoft/reserved future); all fget are Python 'function' objects; first uuidfget150 anchor for these property fget qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfget150

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_qualname,      "hex.fget.__qualname__.__eq__",      ["UUID.hex"],      true, "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (8 chars = 'UUID.'=5 + 'hex'=3; returns 32-char hex string without hyphens)"]
    - [bytes_fget_qualname,    "bytes.fget.__qualname__.__eq__",    ["UUID.bytes"],    true, "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (10 chars = 'UUID.'=5 + 'bytes'=5; returns UUID as 16-byte big-endian bytes)"]
    - [version_fget_qualname,  "version.fget.__qualname__.__eq__",  ["UUID.version"],  true, "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (12 chars = 'UUID.'=5 + 'version'=7; UUID RFC 4122 version 1-5 or None)"]
    - [variant_fget_qualname,  "variant.fget.__qualname__.__eq__",  ["UUID.variant"],  true, "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (12 chars = 'UUID.'=5 + 'variant'=7; ties version at 12 chars)"]

# ---------------------------------------------------------------------------
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn')
# uuid.UUID.fields.fget.__qualname__.__eq__('UUID.fields')
# uuid.UUID.hex.fget.__qualname__.__len__()==8
# uuid.UUID.bytes.fget.__qualname__.__len__()==10
#
# Wave 340 theme: more UUID property fget qualnames and length ordering.
#
# UUID.urn.fget.__qualname__ == 'UUID.urn' (8 chars = 'UUID.'=5 + 'urn'=3; ties hex=8).
# UUID.fields.fget.__qualname__ == 'UUID.fields' (11 chars = 'UUID.'=5 + 'fields'=6).
# Length ordering: hex==urn(8) < bytes(10) < fields(11) < version==variant(12).
# No prior uuid spec anchors urn/fields fget qualname strings as a table under uuidfget150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra150.UUID_property_fget_qualnames_part2:
  description: "uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn')==True / UUID.fields.fget.__qualname__.__eq__('UUID.fields')==True / UUID.hex.fget.__qualname__.__len__()==8 / UUID.bytes.fget.__qualname__.__len__()==10 — urn.fget.__qualname__ is 'UUID.urn' (8 chars = 'UUID.'=5 + 'urn'=3; urn returns 'urn:uuid:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX'; ties hex=8); fields.fget.__qualname__ is 'UUID.fields' (11 chars = 'UUID.'=5 + 'fields'=6; fields returns tuple of six integers); hex.fget.__qualname__.__len__() is 8; bytes.fget.__qualname__.__len__() is 10; length ordering: hex==urn(8) < bytes(10) < fields(11) < version==variant(12); first uuidfget150 anchor for urn/fields fget qualnames and these length values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfget150

  columns: [id, function, args, expected, description]
  rows:
    - [urn_fget_qualname,       "urn.fget.__qualname__.__eq__",       ["UUID.urn"],    true, "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (8 chars = 'UUID.'=5 + 'urn'=3; returns URN string; ties hex at 8 chars)"]
    - [fields_fget_qualname,    "fields.fget.__qualname__.__eq__",    ["UUID.fields"], true, "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' (11 chars = 'UUID.'=5 + 'fields'=6; returns tuple of six integers)"]
    - [hex_fget_qualname_len,   "hex.fget.__qualname__.__len__",      [],              8,    "uuid.UUID.hex.fget.__qualname__.__len__() is 8 ('UUID.hex' = 'UUID.'=5 + 'hex'=3 = 8 chars)"]
    - [bytes_fget_qualname_len, "bytes.fget.__qualname__.__len__",    [],              10,   "uuid.UUID.bytes.fget.__qualname__.__len__() is 10 ('UUID.bytes' = 'UUID.'=5 + 'bytes'=5 = 10 chars)"]

# ---------------------------------------------------------------------------
# qualname length ordering table for UUID property fget qualnames
#
# Wave 340 theme: length ordering across all six fget qualnames in this spec.
#
# hex==urn(8) < bytes(10) < fields(11) < version==variant(12).
# uuid.UUID.version.fget.__qualname__.__len__() == 12.
# uuid.UUID.variant.fget.__qualname__.__len__() == 12.
# uuid.UUID.fields.fget.__qualname__.__len__() == 11.
# No prior uuid spec anchors these fget qualname lengths as a combined table under uuidfget150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra150.UUID_property_fget_qualname_lengths:
  description: "uuid.UUID.version.fget.__qualname__.__len__()==12 / UUID.variant.fget.__qualname__.__len__()==12 / UUID.fields.fget.__qualname__.__len__()==11 / UUID.urn.fget.__qualname__.__len__()==8 — version.fget.__qualname__ is 12 chars ('UUID.version' = 'UUID.'=5 + 'version'=7; ties variant); variant.fget.__qualname__ is 12 chars ('UUID.variant' = 'UUID.'=5 + 'variant'=7; ties version); fields.fget.__qualname__ is 11 chars ('UUID.fields' = 'UUID.'=5 + 'fields'=6); urn.fget.__qualname__ is 8 chars ('UUID.urn' = 'UUID.'=5 + 'urn'=3; ties hex); length ordering: urn==hex(8) < bytes(10) < fields(11) < version==variant(12); first uuidfget150 anchor for these fget qualname length values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfget150

  columns: [id, function, args, expected, description]
  rows:
    - [version_fget_qualname_len,  "version.fget.__qualname__.__len__",  [], 12, "uuid.UUID.version.fget.__qualname__.__len__() is 12 ('UUID.version' = 'UUID.'=5 + 'version'=7 = 12 chars)"]
    - [variant_fget_qualname_len,  "variant.fget.__qualname__.__len__",  [], 12, "uuid.UUID.variant.fget.__qualname__.__len__() is 12 ('UUID.variant' = 'UUID.'=5 + 'variant'=7 = 12 chars; ties version)"]
    - [fields_fget_qualname_len,   "fields.fget.__qualname__.__len__",   [], 11, "uuid.UUID.fields.fget.__qualname__.__len__() is 11 ('UUID.fields' = 'UUID.'=5 + 'fields'=6 = 11 chars)"]
    - [urn_fget_qualname_len,      "urn.fget.__qualname__.__len__",      [], 8,  "uuid.UUID.urn.fget.__qualname__.__len__() is 8 ('UUID.urn' = 'UUID.'=5 + 'urn'=3 = 8 chars; ties hex)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') — standalone
#
# uuid.UUID.hex.fget.__qualname__ is 'UUID.hex' (8 chars). UUID.hex is a property
# defined in Lib/uuid.py. Its getter function (fget) is a plain Python function
# (fget.__class__.__name__ == 'function') with qualname 'UUID.hex'. The hex property
# returns the UUID as a 32-character hexadecimal string without hyphens (e.g.,
# '6ba7b8109dad11d180b400c04fd430c8'). UUID.hex.fget.__qualname__ follows the standard
# pattern 'ClassName.property_name'. 'UUID.hex' = 'UUID.'=5 chars + 'hex'=3 chars = 8 chars.
# This is the shortest qualname among the properties in this spec (ties with 'UUID.urn'=8).
# Note: uuid.UUID.int is a member_descriptor (not a property) and has no fget attribute.
# No prior uuid spec anchors UUID.hex.fget.__qualname__ as a standalone under uuidfget150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra150.UUID_hex_fget_qualname:
  description: "uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') == True — 8 chars = 'UUID.'=5 + 'hex'=3; hex is a property (@property in Lib/uuid.py); fget is a Python 'function' (not C builtin); returns 32-char hex string without hyphens; UUID.int is member_descriptor (no fget); UUID.hex.__class__.__name__=='property' (extra145 anchors this); 'UUID.hex' ties 'UUID.urn' at 8 chars; no prior uuid spec anchors this as a standalone; first standalone under uuidfget150"
  category: identity
  kind: python_call_eq
  function: hex.fget.__qualname__.__eq__
  args: ["UUID.hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.version.fget.__qualname__.__eq__('UUID.version') — standalone
#
# uuid.UUID.version.fget.__qualname__ is 'UUID.version' (12 chars = 'UUID.'=5 + 'version'=7).
# UUID.version is a property that returns the UUID version number (1, 2, 3, 4, or 5)
# for RFC 4122 UUIDs, or raises ValueError if the UUID variant is not RFC 4122. Version
# identifies the algorithm used to generate the UUID: 1=time-based, 3=MD5 name-based,
# 4=random, 5=SHA-1 name-based. The fget getter function is a pure Python function with
# qualname 'UUID.version'. 'UUID.version' (12 chars) ties with 'UUID.variant' (12 chars)
# as the longest fget qualname in this spec. No prior uuid spec anchors
# UUID.version.fget.__qualname__ as a standalone under uuidfget150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra150.UUID_version_fget_qualname:
  description: "uuid.UUID.version.fget.__qualname__.__eq__('UUID.version') == True — 12 chars = 'UUID.'=5 + 'version'=7; version property returns UUID version 1-5 for RFC 4122 UUIDs (1=time, 3=MD5, 4=random, 5=SHA-1); raises ValueError if variant is not RFC 4122; fget is Python 'function'; qualname ties UUID.variant at 12 chars; longest fget qualname in this spec; extra145 anchors UUID.version.__class__.__name__=='property'; no prior uuid spec anchors this as a standalone; first standalone under uuidfget150"
  category: identity
  kind: python_call_eq
  function: version.fget.__qualname__.__eq__
  args: ["UUID.version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant') — standalone
#
# uuid.UUID.variant.fget.__qualname__ is 'UUID.variant' (12 chars = 'UUID.'=5 + 'variant'=7).
# UUID.variant is a property that returns the UUID variant as one of the constants:
# RFC_4122, RESERVED_NCS, RESERVED_MICROSOFT, or RESERVED_FUTURE. The variant is encoded
# in bits 62-63 of the UUID. RFC 4122 UUIDs (the most common type) have variant bits 10.
# The fget getter function is a plain Python function with qualname 'UUID.variant'.
# 'UUID.variant' ties 'UUID.version' at 12 chars (both have 7-char property names).
# No prior uuid spec anchors UUID.variant.fget.__qualname__ as a standalone under
# uuidfget150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra150.UUID_variant_fget_qualname:
  description: "uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant') == True — 12 chars = 'UUID.'=5 + 'variant'=7; variant property returns RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE based on bits 62-63; RFC 4122 UUIDs (uuid1/uuid3/uuid4/uuid5) have RFC_4122 variant; fget is Python 'function'; qualname ties UUID.version at 12 chars; extra145 anchors UUID.variant.__class__.__name__=='property'; no prior uuid spec anchors this as a standalone; first standalone under uuidfget150"
  category: identity
  kind: python_call_eq
  function: variant.fget.__qualname__.__eq__
  args: ["UUID.variant"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') — standalone
#
# uuid.UUID.urn.fget.__qualname__ is 'UUID.urn' (8 chars = 'UUID.'=5 + 'urn'=3). The
# UUID.urn property returns the UUID as a Uniform Resource Name (URN) string in the
# standard form 'urn:uuid:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX'. URNs are defined in
# RFC 4122 and RFC 2141. The 'urn:uuid:' prefix adds 9 chars, followed by the 36-char
# standard UUID string (with hyphens), for a total of 45 chars. The fget function is
# a plain Python function with qualname 'UUID.urn'. 'UUID.urn' (8 chars) ties
# 'UUID.hex' (8 chars) as the shortest fget qualname in this spec. No prior uuid spec
# anchors UUID.urn.fget.__qualname__ as a standalone under uuidfget150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra150.UUID_urn_fget_qualname:
  description: "uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') == True — 8 chars = 'UUID.'=5 + 'urn'=3; urn property returns 'urn:uuid:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX' (RFC 4122 + RFC 2141; 45 chars total); fget is Python 'function'; 'UUID.urn' ties 'UUID.hex' at 8 chars (both have 3-char property names); shortest fget qualnames in this spec; extra145 anchors UUID.urn.__class__.__name__=='property'; no prior uuid spec anchors this as a standalone; first standalone under uuidfget150"
  category: identity
  kind: python_call_eq
  function: urn.fget.__qualname__.__eq__
  args: ["UUID.urn"]
  expected: true
