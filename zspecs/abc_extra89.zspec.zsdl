spec: abc_extra89
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra88

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra88.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc module identity (__name__, __package__, __loader__, __spec__) + ABCMeta.__dict__ membership. NEW in extra89: abc.__name__=='abc'; abc.__package__=='' (empty string — abc is a top-level frozen module, not a package); abc.__loader__.__class__.__name__=='type' (frozen module loaded by FrozenImporter whose __class__ is type); abc.__spec__.__class__.__name__=='ModuleSpec'; ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; ABCMeta.__dict__.__contains__('__init__')==False; ABCMeta.__dict__.__contains__('__prepare__')==False; ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABC.__dict__.__class__.__name__=='mappingproxy'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__name__ == 'abc'. The module's __name__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__package__ == '' (empty string). abc is a top-level module (not a package), so __package__ is the empty string. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__loader__.__class__.__name__ == 'type'. In Python 3.14, abc is a frozen module. Its __loader__ is an instance of _frozen_importlib.FrozenImporter. FrozenImporter is itself a type (class), so __loader__.__class__.__name__ == 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec'. The module spec is a ModuleSpec instance even for frozen modules. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__contains__('__new__') == True. ABCMeta defines __new__ to set up the _abc_data. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__contains__('register') == True. ABCMeta defines the register() method for virtual subclass registration. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__contains__('__instancecheck__') == True. ABCMeta overrides __instancecheck__ for isinstance() support. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__contains__('__subclasscheck__') == True. ABCMeta overrides __subclasscheck__ for issubclass() support. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__contains__('__init__') == False. ABCMeta does not define __init__; it is inherited from type. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__contains__('__prepare__') == False. ABCMeta does not define __prepare__; it is inherited from type. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of ABCMeta is a read-only mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABC.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of ABC (a class using ABCMeta as its metaclass) is also a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module string identity — extra89
#
# Wave 254 theme: abc module identity + ABCMeta.__dict__ membership.
#
# abc.__name__ == 'abc'
# abc.__package__ == ''  (empty string — top-level module, not a package)
# ---------------------------------------------------------------------------

table abc_extra89.module_string_identity:
  description: "abc module string identity checks in abcmoduledict89 namespace — wave 254 theme: abc module identity and ABCMeta.__dict__ membership; __name__.__eq__('abc')==True; __package__.__eq__('')==True (abc is a top-level module with empty __package__); abc is a frozen module in Python 3.14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduledict89

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name,    __name__.__eq__,    ["abc"], true, "__name__ == 'abc' — module name; verified with Python 3.14.3"]
    - [mod_package, __package__.__eq__, [""],    true, "__package__ == '' — top-level module (not a package), __package__ is the empty string; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __spec__ and __loader__ class names — extra89
#
# abc.__spec__.__class__.__name__ == 'ModuleSpec'
# abc.__loader__.__class__.__name__ == 'type'  (FrozenImporter is a type/class)
# abc.__doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table abc_extra89.spec_and_loader_class_names:
  description: "abc __spec__ and __loader__ class name checks in abcmoduledict89 namespace — wave 254 theme: abc module identity; __spec__.__class__.__name__.__eq__('ModuleSpec')==True; __loader__.__class__.__name__.__eq__('type')==True (abc is a frozen module; its loader is FrozenImporter which is a class/type, so __loader__.__class__.__name__ == 'type'); __doc__.__class__.__name__.__eq__('str')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduledict89a

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,   "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"], true, "__spec__.__class__.__name__ == 'ModuleSpec' — module spec is a ModuleSpec instance; verified with Python 3.14.3"]
    - [loader_class_name, "__loader__.__class__.__name__.__eq__", ["type"],       true, "__loader__.__class__.__name__ == 'type' — abc is frozen; FrozenImporter is a class so __loader__.__class__ is type; verified with Python 3.14.3"]
    - [doc_class_name,    "__doc__.__class__.__name__.__eq__",    ["str"],        true, "__doc__.__class__.__name__ == 'str' — module docstring is a str; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta.__dict__ membership for key methods — extra89
#
# __new__, register, __instancecheck__, __subclasscheck__ are present (True)
# __init__, __subclasshook__, __prepare__, __getattribute__ are absent (False)
# ---------------------------------------------------------------------------

table abc_extra89.ABCMeta_dict_membership:
  description: "ABCMeta.__dict__ membership checks for key methods in abcmoduledict89 namespace — wave 254 theme: abc module identity and ABCMeta.__dict__ membership; __dict__.__contains__('__new__')==True (ABCMeta defines __new__); __dict__.__contains__('register')==True (defines register()); __dict__.__contains__('__instancecheck__')==True; __dict__.__contains__('__subclasscheck__')==True; __dict__.__contains__('__init__')==False (inherited from type); __dict__.__contains__('__prepare__')==False (inherited from type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduledict89b

  columns: [id, function, args, expected, description]
  rows:
    - [has_new,             "ABCMeta.__dict__.__contains__",  ["__new__"],             true,  "ABCMeta.__dict__.__contains__('__new__') == True — ABCMeta defines __new__; verified with Python 3.14.3"]
    - [has_register,        "ABCMeta.__dict__.__contains__",  ["register"],            true,  "ABCMeta.__dict__.__contains__('register') == True — ABCMeta defines register(); verified with Python 3.14.3"]
    - [has_instancecheck,   "ABCMeta.__dict__.__contains__",  ["__instancecheck__"],   true,  "ABCMeta.__dict__.__contains__('__instancecheck__') == True — ABCMeta overrides __instancecheck__; verified with Python 3.14.3"]
    - [has_subclasscheck,   "ABCMeta.__dict__.__contains__",  ["__subclasscheck__"],   true,  "ABCMeta.__dict__.__contains__('__subclasscheck__') == True — ABCMeta overrides __subclasscheck__; verified with Python 3.14.3"]
    - [no_init,             "ABCMeta.__dict__.__contains__",  ["__init__"],            false, "ABCMeta.__dict__.__contains__('__init__') == False — __init__ inherited from type, not defined by ABCMeta; verified with Python 3.14.3"]
    - [no_prepare,          "ABCMeta.__dict__.__contains__",  ["__prepare__"],         false, "ABCMeta.__dict__.__contains__('__prepare__') == False — __prepare__ inherited from type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta.__dict__ and ABC.__dict__ class names ('mappingproxy') — extra89
#
# ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# ABC.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table abc_extra89.ABCMeta_and_ABC_dict_class_names:
  description: "ABCMeta.__dict__ and ABC.__dict__ class name checks in abcmoduledict89 namespace — wave 254 theme: ABCMeta.__dict__ membership; ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')==True (class __dict__ is always a read-only mappingproxy); ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True (cross-check); ABCMeta.__dict__.__contains__('__init__')==False (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduledict89c

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_class,  "ABCMeta.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true,  "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a read-only mappingproxy; verified with Python 3.14.3"]
    - [abc_dict_class,      "ABC.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true,  "ABC.__dict__.__class__.__name__ == 'mappingproxy' — ABC's __dict__ is also a mappingproxy; verified with Python 3.14.3"]
    - [has_instancecheck_x, "ABCMeta.__dict__.__contains__",               ["__instancecheck__"], true,  "ABCMeta.__dict__.__contains__('__instancecheck__') == True — cross-check; verified with Python 3.14.3"]
    - [no_init_x,           "ABCMeta.__dict__.__contains__",               ["__init__"],          false, "ABCMeta.__dict__.__contains__('__init__') == False — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra89
# ---------------------------------------------------------------------------

invariant abc_extra89.module_name_is_abc:
  description: "abc.__name__.__eq__('abc') returns True — the module's __name__ attribute is 'abc'; abc is a top-level module so __package__ is the empty string (unlike packages where __package__ equals __name__); in Python 3.14 abc is a frozen module; NEW in extra89: first standalone __name__ invariant for abc module in abcmoduledict89 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra89.loader_class_is_type:
  description: "abc.__loader__.__class__.__name__.__eq__('type') returns True — in Python 3.14, abc is a frozen module; its __loader__ is _frozen_importlib.FrozenImporter; FrozenImporter is a class (a type), so its __class__ is type and __class__.__name__ is 'type'; this contrasts with asyncio and concurrent.futures which have __loader__.__class__.__name__ == 'SourceFileLoader'; NEW in extra89: first standalone __loader__.__class__.__name__ invariant for abc in abcmoduledict89 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra89.ABCMeta_dict_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — ABCMeta defines the register() method in its own __dict__; register() allows virtual subclasses to be declared without actual inheritance; ABCMeta.__dict__ also contains __new__, __instancecheck__, and __subclasscheck__ but NOT __init__, __prepare__, __subclasshook__, __getattribute__, __setattr__, or __delattr__; NEW in extra89: first standalone __dict__.__contains__ invariant for ABCMeta in abcmoduledict89 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["register"]
  expected: true

invariant abc_extra89.ABCMeta_dict_no_init:
  description: "abc.ABCMeta.__dict__.__contains__('__init__') returns False — ABCMeta does not define __init__ in its own __dict__; __init__ is inherited from type (ABCMeta's parent metaclass); this contrasts with __new__ which IS defined in ABCMeta.__dict__; the absence of __init__ means ABCMeta does not override the type initialization protocol beyond what __new__ provides; NEW in extra89: first standalone negative __dict__.__contains__ invariant for ABCMeta in abcmoduledict89 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant abc_extra89.ABCMeta_dict_class_is_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — every class's __dict__ is a read-only mappingproxy (not a plain dict); mappingproxy wraps the underlying dict to prevent direct modification; this applies to ABCMeta itself and also to ABC (the abstract base class defined using ABCMeta); NEW in extra89: first standalone mappingproxy class name invariant for ABCMeta.__dict__ in abcmoduledict89 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true
