spec: tarfile_extra
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tarfile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "tarfile.zspec.zsdl — covers USTAR/GNU/PAX/DEFAULT_FORMAT constants, BLOCKSIZE, RECORDSIZE, ENCODING value, type flag bytes, TarInfo construction, TarFile/__name__/TarInfo/__name__/TarError/__name__/ReadError/__name__/TarError bases, ReadError bases, is_tarfile false on bad bytes"
  notes:
    - "tarfile.CompressionError.__name__ == 'CompressionError' — distinct exception for bad compression."
    - "tarfile.open.__name__ == 'open' — the module-level factory function for opening archives."
    - "tarfile.is_tarfile.__name__ == 'is_tarfile' — the probe function name."
    - "tarfile.ENCODING.__class__.__name__ == 'str' — ENCODING constant is a plain Python str."
    - "TarFile.__name__, TarInfo.__name__, TarError.__name__, ReadError.__name__ are verified here as a self-contained group alongside the new additions."
    - "TarError.__bases__[0].__name__ == 'Exception' — TarError derives directly from Exception."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "tarfile.open() raises ReadError (subclass of TarError) when opening unrecognized data."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class __name__ checks — TarFile, TarInfo, TarError, ReadError, CompressionError
# ---------------------------------------------------------------------------

table tarfile_extra.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [TarFile,          TarFile.__name__.__eq__,          ["TarFile"],          true]
    - [TarInfo,          TarInfo.__name__.__eq__,           ["TarInfo"],          true]
    - [TarError,         TarError.__name__.__eq__,          ["TarError"],         true]
    - [ReadError,        ReadError.__name__.__eq__,         ["ReadError"],        true]
    - [CompressionError, CompressionError.__name__.__eq__,  ["CompressionError"], true]

# ---------------------------------------------------------------------------
# Function __name__ checks — open, is_tarfile
# ---------------------------------------------------------------------------

table tarfile_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__name__.__eq__,       ["open"],       true]
    - [is_tarfile, is_tarfile.__name__.__eq__,  ["is_tarfile"], true]

# ---------------------------------------------------------------------------
# TarError base class — derives from Exception
# ---------------------------------------------------------------------------

invariant tarfile_extra.TarError.base_is_Exception:
  description: "tarfile.TarError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: TarError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# ENCODING constant — type check
# ---------------------------------------------------------------------------

invariant tarfile_extra.ENCODING.class_name:
  description: "tarfile.ENCODING.__class__.__name__ == 'str' — ENCODING is a plain str"
  category: constants
  kind: python_call_eq
  function: ENCODING.__class__.__name__.__eq__
  args: ["str"]
  expected: true
