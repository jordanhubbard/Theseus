spec: itertools_extra6
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras."
    - "itertools_extra5 covers __qualname__ for all 16 public itertools C types."
    - "itertools_extra4 covers __name__ (via .__name__.__eq__) for chain/accumulate/combinations/permutations/product/zip_longest/groupby/starmap/repeat/count; islice.__class__.__name__=='type'; compress.__module__."
    - "Focus: (1) chain.from_iterable.__qualname__ and __name__ — the only class method on any itertools type; (2) __class__.__name__ == 'type' for all itertools iterator classes not already checked in extra4."
    - "itertools_extra4 checked islice.__class__.__name__ == 'type' only. All other iterator classes are also instances of 'type' (they are C-level type objects); this spec records that fact for the remaining types."
    - "chain.from_iterable is a classmethod descriptor; its __qualname__ is 'chain.from_iterable' and __name__ is 'from_iterable'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain.from_iterable — qualname and name
#
# chain.from_iterable is the only publicly documented classmethod on any
# itertools type. Its __qualname__ follows the nested descriptor pattern
# 'chain.from_iterable', distinct from the flat qualnames of the class objects
# themselves.  itertools_extra5 records chain.__qualname__ == 'chain'; this
# spec adds the from_iterable descriptor attributes not covered anywhere else.
# ---------------------------------------------------------------------------

invariant itertools_extra6.chain.from_iterable.qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'"
  category: chain
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra6.chain.from_iterable.name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable'"
  category: chain
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

# ---------------------------------------------------------------------------
# __class__.__name__ == 'type' for all public itertools C-level type objects
#
# Every public symbol in itertools is a C-level type (not a function); each is
# therefore an instance of 'type'. itertools_extra4 verified this for islice
# only. This table adds the check for the remaining 15 types, confirming the
# uniform class-membership pattern across the module.
# ---------------------------------------------------------------------------

table itertools_extra6.class_type_checks:
  kind: python_call_eq
  category: class_identity
  id_prefix: istype

  columns: [id, function, args, expected]
  rows:
    - [chain,                         chain.__class__.__name__.__eq__,                         ["type"], true]
    - [compress,                      compress.__class__.__name__.__eq__,                      ["type"], true]
    - [dropwhile,                     dropwhile.__class__.__name__.__eq__,                     ["type"], true]
    - [takewhile,                     takewhile.__class__.__name__.__eq__,                     ["type"], true]
    - [filterfalse,                   filterfalse.__class__.__name__.__eq__,                   ["type"], true]
    - [groupby,                       groupby.__class__.__name__.__eq__,                       ["type"], true]
    - [starmap,                       starmap.__class__.__name__.__eq__,                       ["type"], true]
    - [zip_longest,                   zip_longest.__class__.__name__.__eq__,                   ["type"], true]
    - [accumulate,                    accumulate.__class__.__name__.__eq__,                    ["type"], true]
    - [combinations,                  combinations.__class__.__name__.__eq__,                  ["type"], true]
    - [combinations_with_replacement, combinations_with_replacement.__class__.__name__.__eq__, ["type"], true]
    - [permutations,                  permutations.__class__.__name__.__eq__,                  ["type"], true]
    - [product,                       product.__class__.__name__.__eq__,                       ["type"], true]
    - [count,                         count.__class__.__name__.__eq__,                         ["type"], true]
    - [cycle,                         cycle.__class__.__name__.__eq__,                         ["type"], true]
    - [repeat,                        repeat.__class__.__name__.__eq__,                        ["type"], true]
