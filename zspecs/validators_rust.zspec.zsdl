spec: validators_rust
version: ">=3.9"
backend: rust_module(validators_rust)

docs: https://validators.readthedocs.io/

provenance:
  derived_from:
    - "https://validators.readthedocs.io/ — validators library"
  notes:
    - "validators provides data validation functions."
    - "validators.email('test@example.com') is True."
    - "validators.email('notanemail') is not True (ValidationError)."
    - "validators.url('http://example.com') is True."
    - "validators.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant validators_rust.email_valid:
  description: "validators.email('test@example.com') is True"
  category: email
  kind: python_call_eq
  function: validators_email_valid
  args: ["test@example.com"]
  expected: true

invariant validators_rust.url_valid:
  description: "validators.url('http://example.com') is True"
  category: url
  kind: python_call_eq
  function: validators_url_valid
  args: ["http://example.com"]
  expected: true

invariant validators_rust.version_nonempty:
  description: "validators.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: validators_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:41:55Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
