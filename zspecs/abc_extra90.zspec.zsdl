spec: abc_extra90
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra89

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra89.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc ABCMeta method __qualname__ lengths and ABC/module-level function __qualname__ values. NEW in extra90: ABCMeta.__new__.__qualname__ len==15; ABCMeta.register.__qualname__ len==16; ABCMeta.__instancecheck__.__qualname__ len==25; ABCMeta.__subclasscheck__.__qualname__ len==25; ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20); ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21); update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); get_cache_token.__qualname__=='get_cache_token' (len=15); abstractmethod.__qualname__=='abstractmethod' (len=14); abstractproperty.__qualname__=='abstractproperty' (len=16). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22). Module-level function, no class prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "get_cache_token.__qualname__ == 'get_cache_token' (len=15). Module-level function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractmethod.__qualname__ == 'abstractmethod' (len=14). abstractmethod is a class; its __qualname__ is its class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractproperty.__qualname__ == 'abstractproperty' (len=16). abstractproperty is a class; its __qualname__ is its class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta Python-function method __qualname__ lengths — extra90
#
# Wave 254 theme: abc ABCMeta method __qualname__ lengths.
#
# ABCMeta.__new__.__qualname__.__len__() == 15
# ABCMeta.register.__qualname__.__len__() == 16
# ABCMeta.__instancecheck__.__qualname__.__len__() == 25
# ABCMeta.__subclasscheck__.__qualname__.__len__() == 25
# ---------------------------------------------------------------------------

table abc_extra90.ABCMeta_method_qualname_lengths:
  description: "ABCMeta Python-function method __qualname__ length checks in abcqualnames90 namespace — wave 254 theme: abc ABCMeta method qualnames; ABCMeta.__new__.__qualname__.__len__()==15 ('ABCMeta.__new__'); ABCMeta.register.__qualname__.__len__()==16 ('ABCMeta.register'); ABCMeta.__instancecheck__.__qualname__.__len__()==25 ('ABCMeta.__instancecheck__'); ABCMeta.__subclasscheck__.__qualname__.__len__()==25 ('ABCMeta.__subclasscheck__'); __instancecheck__ and __subclasscheck__ share the same qualname length (25); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcqualnames90

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_new_len,          "ABCMeta.__new__.__qualname__.__len__",          [], 15, "ABCMeta.__new__.__qualname__.__len__() == 15 — qualname is 'ABCMeta.__new__'; verified with Python 3.14.3"]
    - [abcmeta_register_len,     "ABCMeta.register.__qualname__.__len__",         [], 16, "ABCMeta.register.__qualname__.__len__() == 16 — qualname is 'ABCMeta.register'; verified with Python 3.14.3"]
    - [abcmeta_instcheck_len,    "ABCMeta.__instancecheck__.__qualname__.__len__", [], 25, "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — qualname is 'ABCMeta.__instancecheck__'; verified with Python 3.14.3"]
    - [abcmeta_subclscheck_len,  "ABCMeta.__subclasscheck__.__qualname__.__len__", [], 25, "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — qualname is 'ABCMeta.__subclasscheck__'; same len as __instancecheck__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC class method __qualname__ equality — extra90
#
# ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'
# ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'
# ---------------------------------------------------------------------------

table abc_extra90.ABC_method_qualname_eq:
  description: "ABC class method __qualname__ equality checks in abcqualnames90 namespace — wave 254 theme: abc ABC class method qualnames; ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20); ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (len=21); both methods are defined on the ABC class (which uses ABCMeta as its metaclass); __init_subclass__ is one char longer than __subclasshook__ due to 'init_' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcqualnames90a

  columns: [id, function, args, expected, description]
  rows:
    - [abc_subclasshook_eq,    "ABC.__subclasshook__.__qualname__.__eq__",    ["ABC.__subclasshook__"],    true, "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [abc_init_subclass_eq,   "ABC.__init_subclass__.__qualname__.__eq__",   ["ABC.__init_subclass__"],   true, "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [abc_subclasshook_len,   "ABC.__subclasshook__.__qualname__.__len__",   [],                          20,   "ABC.__subclasshook__.__qualname__.__len__() == 20; verified with Python 3.14.3"]
    - [abc_init_subclass_len,  "ABC.__init_subclass__.__qualname__.__len__",  [],                          21,   "ABC.__init_subclass__.__qualname__.__len__() == 21; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# update_abstractmethods and get_cache_token __qualname__ equality — extra90
#
# update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22)
# get_cache_token.__qualname__ == 'get_cache_token' (len=15)
# ---------------------------------------------------------------------------

table abc_extra90.module_function_qualname_eq:
  description: "update_abstractmethods and get_cache_token __qualname__ equality checks in abcqualnames90 namespace — wave 254 theme: abc module-level function qualnames; update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22; module-level function, qualname equals function name with no class prefix); get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15; module-level function); module-level functions have __qualname__ identical to __name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcqualnames90b

  columns: [id, function, args, expected, description]
  rows:
    - [update_am_eq,   update_abstractmethods.__qualname__.__eq__,   ["update_abstractmethods"], true, "update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22); module-level function; verified with Python 3.14.3"]
    - [get_ct_eq,      get_cache_token.__qualname__.__eq__,           ["get_cache_token"],        true, "get_cache_token.__qualname__ == 'get_cache_token' (len=15); module-level function; verified with Python 3.14.3"]
    - [update_am_len,  update_abstractmethods.__qualname__.__len__,   [],                         22,   "update_abstractmethods.__qualname__.__len__() == 22; verified with Python 3.14.3"]
    - [get_ct_len,     get_cache_token.__qualname__.__len__,          [],                         15,   "get_cache_token.__qualname__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abstractmethod and abstractproperty __qualname__ equality and lengths — extra90
#
# abstractmethod.__qualname__ == 'abstractmethod' (len=14)
# abstractproperty.__qualname__ == 'abstractproperty' (len=16)
# ---------------------------------------------------------------------------

table abc_extra90.decorator_qualname_eq:
  description: "abstractmethod and abstractproperty __qualname__ equality and length checks in abcqualnames90 namespace — wave 254 theme: abc decorator class qualnames; abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14; abstractmethod is a class used as a decorator); abstractproperty.__qualname__.__eq__('abstractproperty')==True (len=16; abstractproperty is a deprecated class subclassing property); abstractmethod.__qualname__.__len__()==14; abstractproperty.__qualname__.__len__()==16; for classes __qualname__ equals the class name when defined at module level; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcqualnames90c

  columns: [id, function, args, expected, description]
  rows:
    - [absmeth_eq,   abstractmethod.__qualname__.__eq__,    ["abstractmethod"],   true, "abstractmethod.__qualname__ == 'abstractmethod' (len=14); class used as decorator; verified with Python 3.14.3"]
    - [absprop_eq,   abstractproperty.__qualname__.__eq__,  ["abstractproperty"], true, "abstractproperty.__qualname__ == 'abstractproperty' (len=16); deprecated class subclassing property; verified with Python 3.14.3"]
    - [absmeth_len,  abstractmethod.__qualname__.__len__,   [],                   14,   "abstractmethod.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [absprop_len,  abstractproperty.__qualname__.__len__, [],                   16,   "abstractproperty.__qualname__.__len__() == 16; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra90
# ---------------------------------------------------------------------------

invariant abc_extra90.ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — ABCMeta.__instancecheck__ is defined directly on ABCMeta; its qualname is 'ABCMeta.__instancecheck__' (len=25); this is the longest qualname among ABCMeta's Python-function methods; __instancecheck__ is called by isinstance() and ABCMeta uses it to support virtual subclasses registered via register(); NEW in extra90: first standalone __qualname__.__eq__ invariant for ABCMeta.__instancecheck__ in abcqualnames90 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__instancecheck__.__qualname__.__eq__"
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra90.ABCMeta_subclasscheck_qualname_len_eq_instancecheck:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — ABCMeta.__subclasscheck__ and ABCMeta.__instancecheck__ share the same __qualname__ length (25); __subclasscheck__ is called by issubclass() and also supports virtual subclass checking; the qualnames differ only in 'instance' vs 'subclass' (both 8 chars: 'instance' and 'subclass'); NEW in extra90: first standalone __qualname__ length invariant for ABCMeta.__subclasscheck__ in abcqualnames90 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__subclasscheck__.__qualname__.__len__"
  args: []
  expected: 25

invariant abc_extra90.update_abstractmethods_qualname_eq:
  description: "abc.update_abstractmethods.__qualname__.__eq__('update_abstractmethods') returns True — update_abstractmethods is a module-level function; its __qualname__ is identical to its __name__ (no class prefix); it was added in Python 3.10 to recompute __abstractmethods__ after class creation; its qualname length is 22, making it the longest unqualified name among the abc module functions; NEW in extra90: first standalone __qualname__.__eq__ invariant for update_abstractmethods in abcqualnames90 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra90.abstractmethod_qualname_eq:
  description: "abc.abstractmethod.__qualname__.__eq__('abstractmethod') returns True — abstractmethod is a class (not a plain function) used as a decorator; its __qualname__ is 'abstractmethod' (len=14), identical to its __name__; this is shorter than abstractproperty.__qualname__ ('abstractproperty', len=16) by 2 chars; abstractmethod is the primary decorator for marking abstract methods in ABCMeta-based classes; NEW in extra90: first standalone __qualname__.__eq__ invariant for abstractmethod in abcqualnames90 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra90.ABC_subclasshook_qualname_eq:
  description: "abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__') returns True — ABC.__subclasshook__ has qualname 'ABC.__subclasshook__' (len=20); it is a classmethod defined on ABC that returns NotImplemented by default; subclasses can override __subclasshook__ to customize virtual subclass checks without calling register(); its qualname length (20) is one less than ABC.__init_subclass__ (21); NEW in extra90: first standalone __qualname__.__eq__ invariant for ABC.__subclasshook__ in abcqualnames90 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__subclasshook__.__qualname__.__eq__"
  args: ["ABC.__subclasshook__"]
  expected: true
