spec: yaml_extra_rust
version: ">=3.9"
backend: rust_module(yaml_extra_rust)

docs: https://pyyaml.org/wiki/PyYAMLDocumentation

provenance:
  derived_from:
    - "https://pyyaml.org/wiki/PyYAMLDocumentation — PyYAML documentation"
  not_derived_from:
    - "pyyaml source: lib/yaml/__init__.py"
  notes:
    - "PyYAML provides YAML parsing and serialization."
    - "yaml.safe_load('key: value')['key'] == 'value'."
    - "yaml.safe_load('x: 42')['x'] == 42."
    - "yaml.safe_dump({'a': 1}) == 'a: 1\\n'."
    - "yaml.safe_dump({'z': 'hello'}) == 'z: hello\\n'."
    - "Expose yaml_extra_loads_str(yaml_str, key) -> str: yaml.safe_load(yaml_str)[key]."
    - "Expose yaml_extra_loads_int(yaml_str, key) -> int: yaml.safe_load(yaml_str)[key]."
    - "Expose yaml_extra_dumps_contains(d, substr) -> bool: substr in yaml.safe_dump(d)."
    - "All test vectors verified against PyYAML 6.0.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# yaml_extra_loads_str — string value from YAML
table yaml_extra_rust.parse.loads_str:
  kind: python_call_eq
  category: loads_str
  id_prefix: yml_s
  function: yaml_extra_loads_str

  columns: [id, args, expected]
  rows:
    - [simple, ["key: value", "key"],  "value"]
    - [name,   ["name: Alice", "name"], "Alice"]

# yaml_extra_loads_int — integer value from YAML
table yaml_extra_rust.parse.loads_int:
  kind: python_call_eq
  category: loads_int
  id_prefix: yml_i
  function: yaml_extra_loads_int

  columns: [id, args, expected]
  rows:
    - [forty2, ["x: 42", "x"], 42]
    - [zero,   ["n: 0",  "n"],  0]

# yaml_extra_dumps_contains — dump contains key
table yaml_extra_rust.serialize.dumps_contains:
  kind: python_call_eq
  category: dumps_contains
  id_prefix: yml_dc
  function: yaml_extra_dumps_contains

  columns: [id, args, expected]
  rows:
    - [key_a,   [{"a": 1}, "a"],     true]
    - [val_one, [{"a": 1}, "1"],     true]
    - [absent,  [{"a": 1}, "zzz"],   false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:50:26Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
