spec: threading_extra177
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading module-level functions — threading.current_thread.__name__=='current_thread' (len=14); threading.current_thread.__module__=='threading'; threading.main_thread.__name__=='main_thread' (len=11); threading.active_count.__name__=='active_count' (len=12); threading.enumerate.__name__=='enumerate' (len=9); threading.settrace.__name__=='settrace' (len=8); threading.setprofile.__name__=='setprofile' (len=10); threading.stack_size.__name__=='stack_size' (len=10; same as setprofile)."
    - "threading.current_thread.__name__ == 'current_thread' — current_thread is a Python function in Lib/threading.py returning the Thread object corresponding to the caller's thread of control; its __name__ is 'current_thread', 14 characters. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' — current_thread is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' — main_thread is a Python function in Lib/threading.py returning the main Thread object; its __name__ is 'main_thread', 11 characters. Verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' — active_count is a Python function in Lib/threading.py returning the number of Thread objects currently alive; its __name__ is 'active_count', 12 characters. Verified with Python 3.14.3."
    - "threading.enumerate.__name__ == 'enumerate' — threading.enumerate is a Python function in Lib/threading.py returning a list of all currently alive Thread objects; its __name__ is 'enumerate', 9 characters. Verified with Python 3.14.3."
    - "threading.settrace.__name__ == 'settrace' — settrace is a Python function in Lib/threading.py setting a trace function for all threads; its __name__ is 'settrace', 8 characters. Verified with Python 3.14.3."
    - "threading.setprofile.__name__ == 'setprofile' — setprofile is a Python function in Lib/threading.py setting a profile function for all threads; its __name__ is 'setprofile', 10 characters. Verified with Python 3.14.3."
    - "threading.stack_size.__name__ == 'stack_size' — stack_size is a Python function in Lib/threading.py returning or setting the thread stack size; its __name__ is 'stack_size', 10 characters, same length as 'setprofile'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.current_thread and threading.main_thread __name__
#
# threading.current_thread.__name__ == 'current_thread'
# threading.current_thread.__name__.__len__() == 14
# threading.current_thread.__module__ == 'threading'
# threading.main_thread.__name__ == 'main_thread'
#
# threading.current_thread is a Python function in Lib/threading.py that
# returns the Thread object corresponding to the caller's thread of control.
# Its __name__ is 'current_thread' (14 chars) and its __module__ is
# 'threading'. threading.main_thread returns the main Thread object and has
# __name__ 'main_thread' (11 chars). New to extra177.
# ---------------------------------------------------------------------------

table threading_extra177.current_thread_and_main_thread_name:
  description: "threading.current_thread.__name__ 'current_thread' len 14; __module__ 'threading'; main_thread.__name__ 'main_thread' len 11; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfns177

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_name_eq,
       "current_thread.__name__.__eq__",
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — threading.current_thread is a Python function in Lib/threading.py returning the Thread object corresponding to the caller's thread of control; its __name__ is 'current_thread'; str.__eq__('current_thread') returns True; new to extra177"]
    - [current_thread_name_len_14,
       "current_thread.__name__.__len__",
       [],
       14,
       "threading.current_thread.__name__.__len__() == 14 — the name 'current_thread' has exactly 14 characters: c-u-r-r-e-n-t-_-t-h-r-e-a-d; str.__len__() returns 14; new to extra177"]
    - [current_thread_module_threading,
       "current_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — threading.current_thread is a Python function defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__('threading') returns True; new to extra177"]
    - [main_thread_name_eq,
       "main_thread.__name__.__eq__",
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — threading.main_thread is a Python function in Lib/threading.py returning the main Thread object (the Thread corresponding to the interpreter's main thread of control); its __name__ is 'main_thread'; str.__eq__('main_thread') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: threading.main_thread name length and threading.active_count __name__
#
# threading.main_thread.__name__.__len__() == 11
# threading.active_count.__name__ == 'active_count'
# threading.active_count.__name__.__len__() == 12
# threading.active_count.__module__ == 'threading'
#
# main_thread has __name__ 'main_thread' (11 chars). active_count is a Python
# function returning the number of Thread objects currently alive; its __name__
# is 'active_count' (12 chars). New to extra177.
# ---------------------------------------------------------------------------

table threading_extra177.main_thread_len_and_active_count_name:
  description: "threading.main_thread.__name__ len 11; active_count.__name__ 'active_count' len 12; __module__ 'threading'; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfns177

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_name_len_11,
       "main_thread.__name__.__len__",
       [],
       11,
       "threading.main_thread.__name__.__len__() == 11 — the name 'main_thread' has exactly 11 characters: m-a-i-n-_-t-h-r-e-a-d; str.__len__() returns 11; new to extra177"]
    - [active_count_name_eq,
       "active_count.__name__.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — threading.active_count is a Python function in Lib/threading.py returning the number of Thread objects currently alive (daemonic and non-daemonic); its __name__ is 'active_count'; str.__eq__('active_count') returns True; new to extra177"]
    - [active_count_name_len_12,
       "active_count.__name__.__len__",
       [],
       12,
       "threading.active_count.__name__.__len__() == 12 — the name 'active_count' has exactly 12 characters: a-c-t-i-v-e-_-c-o-u-n-t; str.__len__() returns 12; new to extra177"]
    - [active_count_module_threading,
       "active_count.__module__.__eq__",
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — threading.active_count is a Python function defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__('threading') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: threading.enumerate and threading.settrace __name__
#
# threading.enumerate.__name__ == 'enumerate'
# threading.enumerate.__name__.__len__() == 9
# threading.settrace.__name__ == 'settrace'
# threading.settrace.__name__.__len__() == 8
#
# threading.enumerate is a Python function returning a list of all alive Thread
# objects (note: shadows the built-in enumerate within the threading module
# namespace); __name__ is 'enumerate' (9 chars). settrace sets a trace function
# for all threads; __name__ is 'settrace' (8 chars). New to extra177.
# ---------------------------------------------------------------------------

table threading_extra177.enumerate_and_settrace_name:
  description: "threading.enumerate.__name__ 'enumerate' len 9; settrace.__name__ 'settrace' len 8; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfns177

  columns: [id, function, args, expected, description]
  rows:
    - [enumerate_name_eq,
       "enumerate.__name__.__eq__",
       ["enumerate"],
       true,
       "threading.enumerate.__name__.__eq__('enumerate') == True — threading.enumerate is a Python function in Lib/threading.py returning a list of all Thread objects currently alive; it shadows the built-in enumerate within the threading namespace; its __name__ is 'enumerate'; str.__eq__('enumerate') returns True; new to extra177"]
    - [enumerate_name_len_9,
       "enumerate.__name__.__len__",
       [],
       9,
       "threading.enumerate.__name__.__len__() == 9 — the name 'enumerate' has exactly 9 characters: e-n-u-m-e-r-a-t-e; str.__len__() returns 9; new to extra177"]
    - [settrace_name_eq,
       "settrace.__name__.__eq__",
       ["settrace"],
       true,
       "threading.settrace.__name__.__eq__('settrace') == True — threading.settrace is a Python function in Lib/threading.py that sets a trace function to be called at the start of each thread's execution; its __name__ is 'settrace'; str.__eq__('settrace') returns True; new to extra177"]
    - [settrace_name_len_8,
       "settrace.__name__.__len__",
       [],
       8,
       "threading.settrace.__name__.__len__() == 8 — the name 'settrace' has exactly 8 characters: s-e-t-t-r-a-c-e; str.__len__() returns 8; new to extra177"]

# ---------------------------------------------------------------------------
# Table 4: threading.setprofile and threading.stack_size __name__
#
# threading.setprofile.__name__ == 'setprofile'
# threading.setprofile.__name__.__len__() == 10
# threading.stack_size.__name__ == 'stack_size'
# threading.stack_size.__name__.__len__() == 10
#
# setprofile sets a profile function for all threads; __name__ is 'setprofile'
# (10 chars). stack_size returns or sets the thread stack size; __name__ is
# 'stack_size' (10 chars, same length as 'setprofile'). New to extra177.
# ---------------------------------------------------------------------------

table threading_extra177.setprofile_and_stack_size_name:
  description: "threading.setprofile.__name__ 'setprofile' len 10; stack_size.__name__ 'stack_size' len 10 (same); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfns177

  columns: [id, function, args, expected, description]
  rows:
    - [setprofile_name_eq,
       "setprofile.__name__.__eq__",
       ["setprofile"],
       true,
       "threading.setprofile.__name__.__eq__('setprofile') == True — threading.setprofile is a Python function in Lib/threading.py that sets a profile function to be called at the start of each thread's execution; its __name__ is 'setprofile'; str.__eq__('setprofile') returns True; new to extra177"]
    - [setprofile_name_len_10,
       "setprofile.__name__.__len__",
       [],
       10,
       "threading.setprofile.__name__.__len__() == 10 — the name 'setprofile' has exactly 10 characters: s-e-t-p-r-o-f-i-l-e; str.__len__() returns 10; new to extra177"]
    - [stack_size_name_eq,
       "stack_size.__name__.__eq__",
       ["stack_size"],
       true,
       "threading.stack_size.__name__.__eq__('stack_size') == True — threading.stack_size is a Python function in Lib/threading.py that returns or sets the thread stack size used when creating new threads; its __name__ is 'stack_size'; str.__eq__('stack_size') returns True; new to extra177"]
    - [stack_size_name_len_10,
       "stack_size.__name__.__len__",
       [],
       10,
       "threading.stack_size.__name__.__len__() == 10 — the name 'stack_size' has exactly 10 characters: s-t-a-c-k-_-s-i-z-e; same length as 'setprofile' (10); str.__len__() returns 10; new to extra177"]

