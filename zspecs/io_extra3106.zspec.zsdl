spec: io3106
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (io3106): __lt__, __le__, __gt__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IOBase."
    - "None of the io stream classes define __lt__, __le__, or __gt__ in their own __dict__: all are absent."
    - "io classes are I/O stream abstractions; ordering operators are not defined by any io class — streams do not support comparison ordering."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# No io stream class defines __lt__ in its own __dict__; all false.
# io classes do not override less-than ordering; no comparison ordering is defined.
# ---------------------------------------------------------------------------

table io3106.lt:
  description: "io types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3106

