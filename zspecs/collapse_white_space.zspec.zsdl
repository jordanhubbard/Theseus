spec: collapse_white_space
version: ">=2.1.0"
backend: node(collapse-white-space)

docs: https://www.npmjs.com/package/collapse-white-space

provenance:
  derived_from:
    - "collapse-white-space README — https://www.npmjs.com/package/collapse-white-space"
    - "Test vectors verified with collapse-white-space via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "collapse-white-space source"
  notes:
    - "collapse-white-space is an npm package. Install: npm install collapse-white-space"
    - "Collapses runs of whitespace into a single space."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table collapse_white_space.collapseWhiteSpace:
  kind: node_module_call_eq
  function: collapseWhiteSpace
  category: string
  id_prefix: collws

  columns: [id, args, expected]
  rows:
    - [double_space,   ["hi  there"],    "hi there"]
    - [multi_space,    ["a   b   c"],    "a b c"]
    - [single_space,   ["hello world"],  "hello world"]
    - [leading,        ["  hello"],      " hello"]

