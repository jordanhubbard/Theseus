spec: concurrent_futures_extra270
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; it inherits from Executor."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; it also inherits from Executor."
    - "Executor.__module__ == 'concurrent.futures._base'; Executor.__bases__[0].__name__ == 'object'."
    - "Future.__module__ == 'concurrent.futures._base'; all Future methods carry __qualname__ prefixed with 'Future.'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor class identity — table
#
# Both executors live in their own submodules and inherit from Executor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra270.executor_identity:
  description: "ThreadPoolExecutor and ProcessPoolExecutor class identity"
  kind: python_call_eq
  category: identity
  id_prefix: exid

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name,      ThreadPoolExecutor.__name__.__eq__,              ["ThreadPoolExecutor"],          true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"]
    - [tpe_module,    ThreadPoolExecutor.__module__.__eq__,            ["concurrent.futures.thread"],   true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"]
    - [tpe_base,      "ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                  true, "ThreadPoolExecutor inherits from Executor"]
    - [tpe_submit,    ThreadPoolExecutor.submit.__name__.__eq__,       ["submit"],                      true, "ThreadPoolExecutor.submit.__name__ == 'submit'"]
    - [tpe_shutdown,  ThreadPoolExecutor.shutdown.__name__.__eq__,     ["shutdown"],                    true, "ThreadPoolExecutor.shutdown.__name__ == 'shutdown'"]
    - [ppe_name,      ProcessPoolExecutor.__name__.__eq__,             ["ProcessPoolExecutor"],         true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'"]
    - [ppe_module,    ProcessPoolExecutor.__module__.__eq__,           ["concurrent.futures.process"],  true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"]
    - [ppe_base,      "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                 true, "ProcessPoolExecutor inherits from Executor"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future class identity — table
#
# Future lives in concurrent.futures._base and has its own method set.
# ---------------------------------------------------------------------------

table concurrent_futures_extra270.future_identity:
  description: "concurrent.futures.Future class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: fid

  columns: [id, function, args, expected, description]
  rows:
    - [f_name,               Future.__name__.__eq__,                  ["Future"],                       true, "Future.__name__ == 'Future'"]
    - [f_module,             Future.__module__.__eq__,                ["concurrent.futures._base"],     true, "Future.__module__ == 'concurrent.futures._base'"]
    - [f_result_name,        Future.result.__name__.__eq__,           ["result"],                       true, "Future.result.__name__ == 'result'"]
    - [f_done_name,          Future.done.__name__.__eq__,             ["done"],                         true, "Future.done.__name__ == 'done'"]
    - [f_cancel_name,        Future.cancel.__name__.__eq__,           ["cancel"],                       true, "Future.cancel.__name__ == 'cancel'"]
    - [f_callback_name,      Future.add_done_callback.__name__.__eq__, ["add_done_callback"],           true, "Future.add_done_callback.__name__ == 'add_done_callback'"]

# ---------------------------------------------------------------------------
# Executor base class identity — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra270.Executor.name:
  description: "concurrent.futures.Executor.__name__ == 'Executor'"
  category: identity
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra270.Executor.module:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra270.Executor.bases0_name:
  description: "concurrent.futures.Executor.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra270.ThreadPoolExecutor.submit_qualname:
  description: "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra270.ThreadPoolExecutor.shutdown_qualname:
  description: "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# Future method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra270.Future.result_qualname:
  description: "Future.result.__qualname__ == 'Future.result'"
  category: identity
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra270.Future.done_qualname:
  description: "Future.done.__qualname__ == 'Future.done'"
  category: identity
  kind: python_call_eq
  function: Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

invariant concurrent_futures_extra270.Future.cancel_qualname:
  description: "Future.cancel.__qualname__ == 'Future.cancel'"
  category: identity
  kind: python_call_eq
  function: Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra270.Future.add_done_callback_qualname:
  description: "Future.add_done_callback.__qualname__ == 'Future.add_done_callback'"
  category: identity
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__eq__
  args: ["Future.add_done_callback"]
  expected: true
