spec: uuid_extra52
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra51.zspec.zsdl — covers uuid.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / UUID.__ne__.__qualname__.__eq__('object.__ne__') (table + invariants)."
    - "uuid_extra50.zspec.zsdl — covers uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version .fget.__qualname__.__eq__."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values for time/node/clock_seq/time_hi_version/clock_seq_hi_variant."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__.__qualname__.__eq__ and __qualname__.__len__()."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra51; it does NOT duplicate invariants present in those files."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "uuid_extra16 covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__. uuid_extra17 covers UUID.__lt__/__gt__/__le__/__ge__ __qualname__.__eq__. uuid_extra51 covers UUID.__ne__.__qualname__.__eq__('object.__ne__'). No prior uuid spec checks __qualname__.__eq__ for UUID.__setattr__, UUID.__getstate__, UUID.__setstate__, UUID.__init_subclass__, or UUID.__subclasshook__. All five are defined directly on UUID (qualname prefix 'UUID.') and are entirely novel for the qualname string equality axis. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "UUID.__setattr__.__qualname__ == 'UUID.__setattr__' (len 16). UUID defines __setattr__ directly to enforce immutability (raises TypeError on attribute assignment). Its __qualname__ has the 'UUID.' prefix. No prior uuid spec checks UUID.__setattr__.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "UUID.__getstate__.__qualname__ == 'UUID.__getstate__' (len 17). UUID defines __getstate__ for pickling support. No prior uuid spec checks UUID.__getstate__.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "UUID.__setstate__.__qualname__ == 'UUID.__setstate__' (len 17). UUID defines __setstate__ for unpickling support. No prior uuid spec checks UUID.__setstate__.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "UUID.__init_subclass__.__qualname__ == 'UUID.__init_subclass__' (len 22). __init_subclass__ is defined on UUID (via the standard Python hook); its qualname includes the 'UUID.' prefix. No prior uuid spec checks UUID.__init_subclass__.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "UUID.__subclasshook__.__qualname__ == 'UUID.__subclasshook__' (len 21). __subclasshook__ is defined on UUID; its qualname includes the 'UUID.' prefix. No prior uuid spec checks UUID.__subclasshook__.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID method __qualname__.__eq__ string values — novel dunders
#
# Wave 227 theme: Class method __qualname__ string equality checks for methods
# not yet covered.
#
# Prior coverage:
#   uuid_extra16: UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__
#   uuid_extra17: UUID.__lt__/__gt__/__le__/__ge__
#   uuid_extra51: UUID.__ne__ (qualname 'object.__ne__', inherited)
#
# Novel: UUID.__setattr__/__getstate__/__setstate__/__init_subclass__/
#        __subclasshook__ — all defined directly on UUID (qualname 'UUID.*').
# ---------------------------------------------------------------------------

table uuid_extra52.UUID_novel_method_qualname_eq:
  description: "UUID.__setattr__/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__.__eq__ string values — all defined directly on UUID with 'UUID.' prefix; uuid_extra16 covers __str__/__repr__/__eq__/__hash__/__init__/__int__; uuid_extra17 covers __lt__/__gt__/__le__/__ge__; no prior uuid spec checks __qualname__.__eq__ for any of these five methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidqual52

  columns: [id, function, args, expected]
  rows:
    - [setattr_qualname_eq,       "UUID.__setattr__.__qualname__.__eq__",       ["UUID.__setattr__"],       true]
    - [getstate_qualname_eq,      "UUID.__getstate__.__qualname__.__eq__",      ["UUID.__getstate__"],      true]
    - [setstate_qualname_eq,      "UUID.__setstate__.__qualname__.__eq__",      ["UUID.__setstate__"],      true]
    - [init_subclass_qualname_eq, "UUID.__init_subclass__.__qualname__.__eq__", ["UUID.__init_subclass__"], true]
    - [subclasshook_qualname_eq,  "UUID.__subclasshook__.__qualname__.__eq__",  ["UUID.__subclasshook__"],  true]

# ---------------------------------------------------------------------------
# UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') — standalone
#
# UUID defines __setattr__ directly to enforce immutability: attempting to set
# any attribute on a UUID instance raises TypeError. Because UUID defines
# __setattr__ directly (not inheriting from object), its __qualname__ is
# 'UUID.__setattr__' (with the 'UUID.' prefix), not 'object.__setattr__'.
# No prior uuid spec checks UUID.__setattr__.__qualname__.__eq__ in any form.
# ---------------------------------------------------------------------------

invariant uuid_extra52.UUID_setattr_qualname_str:
  description: "uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') == True — UUID defines __setattr__ directly to enforce immutability (raises TypeError on attribute assignment); qualname has 'UUID.' prefix confirming direct definition on UUID; no prior uuid spec checks UUID.__setattr__.__qualname__.__eq__"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.__setattr__.__qualname__.__eq__"
  args: ["UUID.__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__') — standalone
#
# UUID defines __getstate__ for pickle support. The __qualname__ 'UUID.__getstate__'
# confirms that the pickle state accessor is a method defined directly on UUID,
# not inherited. No prior uuid spec checks UUID.__getstate__.__qualname__.__eq__
# in any form.
# ---------------------------------------------------------------------------

invariant uuid_extra52.UUID_getstate_qualname_str:
  description: "uuid.UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__') == True — UUID defines __getstate__ directly for pickling support; qualname 'UUID.__getstate__' confirms direct definition on UUID class; no prior uuid spec checks UUID.__getstate__.__qualname__.__eq__"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.__getstate__.__qualname__.__eq__"
  args: ["UUID.__getstate__"]
  expected: true
