spec: typing_extra36
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra35.zspec.zsdl."
    - "Prior specs covered: TypeVar/__name__/__module__/__qualname__/__init__.__name__, Protocol/__module__/__qualname__/__bases__[0].__name__, Generic/__module__/__qualname__/__bases__[0].__name__, NamedTuple/__name__/__module__, TypedDict/__name__/__module__, get_type_hints/__name__, overload/__name__, cast/__name__, TYPE_CHECKING value, TypeVar/Protocol/Generic __module__.__len__() and __name__.__len__(), __qualname__.__len__() for overload/cast/get_type_hints/no_type_check/get_args/get_origin, __module__.__len__() and __name__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal, __mro__.__len__() for Protocol(3)/Generic(2)/TypeVar(2), __bases__[0].__name__.__len__() for Generic(6) and TypeVar(6), Protocol.__slots__/__abstractmethods__/__class__.__name__, TYPE_CHECKING.__class__.__name__.__len__() (4), AnyStr.__class__.__name__.__len__() (7), typing.__all__.__len__() (105) and .__class__.__name__.__len__() (4), __dict__.__class__.__name__.__len__() for TypeVar/Generic/Protocol (mappingproxy=12) and NamedTuple (dict=4), __qualname__.__len__() for final(5)/runtime_checkable(17), TypeVar.__init__.__qualname__.__len__() (15), Protocol.__init_subclass__.__qualname__.__len__() (26); __qualname__.__len__() for TypeVar(7)/Generic(7)/Protocol(8)/ParamSpec(9)/TypeVarTuple(12); __class__.__name__.__len__() for Union(4)/Optional(12)/Any(8)/ClassVar(12)/Final(12)/Literal(22)/TYPE_CHECKING(4)."
    - "This spec covers: __name__.__len__() for TypeVar(7)/Generic(7)/Protocol(8)/ParamSpec(9)/TypeVarTuple(12); TypeVar.__module__.__len__()==6; get_type_hints.__name__.__len__()==14; get_type_hints.__qualname__.__len__()==14; overload.__name__.__len__()==8; cast.__name__.__len__()==4."
    - "TypeVar.__module__ == 'typing' (len 6) — the module that defines TypeVar is the typing module itself."
    - "get_type_hints.__name__ and __qualname__ both equal 'get_type_hints' (len 14) — a flat top-level function."
    - "overload.__name__ == 'overload' (len 8); cast.__name__ == 'cast' (len 4) — the two shortest/longest decorator-adjacent helpers."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for TypeVar family classes
#
# typing.TypeVar.__name__ == 'TypeVar' (length 7). typing.Generic.__name__
# == 'Generic' (length 7). typing.Protocol.__name__ == 'Protocol' (length 8).
# typing.ParamSpec.__name__ == 'ParamSpec' (length 9). typing.TypeVarTuple.
# __name__ == 'TypeVarTuple' (length 12). These mirror the __qualname__ values
# covered in typing_extra35, confirming that __name__ and __qualname__ agree
# for all five top-level parameterization classes.
# ---------------------------------------------------------------------------

table typing_extra36.typevar_family_name_lens:
  description: "__name__.__len__() for TypeVar (7), Generic (7), Protocol (8), ParamSpec (9), TypeVarTuple (12)"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected, description]
  rows:
    - [TypeVar,
       TypeVar.__name__.__len__,
       [],
       7,
       "len(typing.TypeVar.__name__) == 7 — 'TypeVar'"]
    - [Generic,
       Generic.__name__.__len__,
       [],
       7,
       "len(typing.Generic.__name__) == 7 — 'Generic'"]
    - [Protocol,
       Protocol.__name__.__len__,
       [],
       8,
       "len(typing.Protocol.__name__) == 8 — 'Protocol'"]
    - [ParamSpec,
       ParamSpec.__name__.__len__,
       [],
       9,
       "len(typing.ParamSpec.__name__) == 9 — 'ParamSpec'"]
    - [TypeVarTuple,
       TypeVarTuple.__name__.__len__,
       [],
       12,
       "len(typing.TypeVarTuple.__name__) == 12 — 'TypeVarTuple'"]

# ---------------------------------------------------------------------------
# Helper function __name__.__len__() — get_type_hints, overload, cast
#
# get_type_hints.__name__ == 'get_type_hints' (length 14). The __qualname__
# also equals 'get_type_hints' (14) — this is a flat top-level function with
# no enclosing class. overload.__name__ == 'overload' (8). cast.__name__
# == 'cast' (4) — the shortest name of the major typing helpers.
# No prior typing spec records __name__.__len__() specifically for these three
# functions side-by-side in a single table.
# ---------------------------------------------------------------------------

table typing_extra36.helper_function_name_lens:
  description: "__name__.__len__() for get_type_hints (14), overload (8), cast (4)"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: helper_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [get_type_hints,
       get_type_hints.__name__.__len__,
       [],
       14,
       "len(typing.get_type_hints.__name__) == 14 — 'get_type_hints'"]
    - [overload,
       overload.__name__.__len__,
       [],
       8,
       "len(typing.overload.__name__) == 8 — 'overload'"]
    - [cast,
       cast.__name__.__len__,
       [],
       4,
       "len(typing.cast.__name__) == 4 — 'cast'"]

# ---------------------------------------------------------------------------
# typing.TypeVar.__module__.__len__() == 6 — standalone invariant
#
# typing.TypeVar.__module__ == 'typing' (6 characters). TypeVar is defined
# in the typing module itself, so its __module__ attribute is 'typing'.
# This confirms the module-of-origin for the primary type-variable class.
# ---------------------------------------------------------------------------

invariant typing_extra36.TypeVar.module_len:
  description: "typing.TypeVar.__module__.__len__() == 6 — __module__ is 'typing' (6 characters)"
  category: name_attr_lengths
  kind: python_call_eq
  function: TypeVar.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# typing.get_type_hints.__qualname__.__len__() == 14 — standalone invariant
#
# typing.get_type_hints.__qualname__ == 'get_type_hints' (14 characters).
# The qualname equals the name for this top-level function, confirming it is
# not a nested or class-bound method. This is the longest name of any typing
# utility function covered in this spec.
# ---------------------------------------------------------------------------

invariant typing_extra36.get_type_hints.qualname_len:
  description: "typing.get_type_hints.__qualname__.__len__() == 14 — qualname 'get_type_hints' has 14 characters; equals __name__, confirming flat top-level scope"
  category: name_attr_lengths
  kind: python_call_eq
  function: get_type_hints.__qualname__.__len__
  args: []
  expected: 14
