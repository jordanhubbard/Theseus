spec: socket_extra339
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__package__ == '' (empty string — socket is a top-level module, not a package). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.name == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__class__.__name__ == 'list'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__len__() == 238 (Python 3.14.3 macOS/Darwin 25.4.0 — platform-specific; macOS provides more symbols than the minimum). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('AF_INET') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('SOCK_STREAM') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.__all__.__len__()==238 is the macOS/Darwin 25.4.0 value. This count is platform-specific because socket.__all__ includes platform-dependent constants from the C extension (e.g., AF_UNIX on Unix, various SO_* and IP_* constants that vary by OS). The portable subset is smaller."
    - "Note: socket.__all__ is a list (constructed dynamically in Lib/socket.py by appending names from _socket.__all__ and additional Python-level names)."
    - "Note: 'socket' in socket.__all__ refers to the socket class (socket.socket), not the module itself."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__name__.__eq__('socket')
# socket.__package__.__eq__('')
# socket.__spec__.name.__eq__('socket')
# socket.__doc__.__class__.__name__.__eq__('str')
#
# Wave 339 theme: socket module-level identity attributes.
#
# socket.__name__ is 'socket' — the canonical module name. socket.__package__
# is '' confirming socket is a top-level module. socket.__spec__.name is
# 'socket'. socket.__doc__.__class__.__name__ is 'str' — the module has a
# docstring. The socket module is a Python wrapper (Lib/socket.py) over the
# C extension _socket (Modules/socketmodule.c).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra339.module_identity_attrs:
  description: "socket.__name__.__eq__('socket')==True / __package__.__eq__('')==True / __spec__.name.__eq__('socket')==True / __doc__.__class__.__name__.__eq__('str')==True — socket is a top-level module (__package__==''); Python wrapper Lib/socket.py over C extension _socket; __spec__.name matches __name__; __doc__ is a str object; first socketid339 anchor for module identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketid339

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      "__name__.__eq__",               ["socket"], true, "socket.__name__ is 'socket' — canonical module name (Python wrapper over _socket C extension)"]
    - [package_eq,   "__package__.__eq__",            [""],       true, "socket.__package__ is '' (empty string) — socket is a top-level module, not a subpackage"]
    - [spec_name_eq, "__spec__.name.__eq__",          ["socket"], true, "socket.__spec__.name is 'socket' — ModuleSpec name matches __name__"]
    - [doc_class_eq, "__doc__.__class__.__name__.__eq__", ["str"], true, "socket.__doc__.__class__.__name__ is 'str' — module has a docstring"]

# ---------------------------------------------------------------------------
# socket.__all__.__class__.__name__.__eq__('list')
# socket.__all__.__len__()==238
# socket.__all__.__contains__('socket')==True
# socket.__all__.__contains__('AF_INET')==True
# socket.__all__.__contains__('SOCK_STREAM')==True
#
# Wave 339 theme: socket.__all__ list attributes on macOS/Darwin 25.4.0.
#
# socket.__all__ is a list (not a tuple). On macOS/Darwin 25.4.0 with
# Python 3.14.3, socket.__all__.__len__() is 238. This count is platform-
# specific: Lib/socket.py constructs __all__ by starting from _socket's
# exported names and appending additional Python-level names. The macOS
# value of 238 includes platform-specific constants not available on all
# Unix systems. 'socket' (the class), 'AF_INET', and 'SOCK_STREAM' are
# universally present on all platforms.
# socket_extra95 anchors __all__ class name and length; this table re-anchors
# under socketid339 for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra339.all_list_attrs:
  description: "socket.__all__.__class__.__name__.__eq__('list')==True / __all__.__len__()==238 / __all__.__contains__('socket')==True / __all__.__contains__('AF_INET')==True / __all__.__contains__('SOCK_STREAM')==True — socket.__all__ is a list; 238 entries on macOS/Darwin 25.4.0 (platform-specific count; includes macOS-specific constants); 'socket' refers to socket.socket class; AF_INET and SOCK_STREAM are universally present; first socketid339 anchor for __all__ attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketid339

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_eq,       "__all__.__class__.__name__.__eq__", ["list"],        true, "socket.__all__.__class__.__name__ is 'list' — constructed dynamically in Lib/socket.py"]
    - [all_len,            "__all__.__len__",                   [],              238,  "socket.__all__ has 238 entries on macOS/Darwin 25.4.0 (platform-specific count)"]
    - [all_has_socket,     "__all__.__contains__",              ["socket"],      true, "socket.__all__ contains 'socket' (the socket.socket class, not the module)"]
    - [all_has_af_inet,    "__all__.__contains__",              ["AF_INET"],     true, "socket.__all__ contains 'AF_INET' (IPv4 address family; universally present)"]
    - [all_has_sock_stream, "__all__.__contains__",             ["SOCK_STREAM"], true, "socket.__all__ contains 'SOCK_STREAM' (TCP stream socket type; universally present)"]

# ---------------------------------------------------------------------------
# socket.__name__.__eq__('socket') — standalone
#
# socket.__name__ is 'socket'. This is the canonical module name. The module
# has two layers: a pure Python wrapper (Lib/socket.py) and a C extension
# (_socket, Modules/socketmodule.c). The public-facing name is 'socket'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra339.name_is_socket:
  description: "socket.__name__.__eq__('socket') == True — socket.__name__ is the canonical module name 'socket'; the module has a Python layer (Lib/socket.py) over a C extension (_socket); both share the public-facing name 'socket'; first standalone for socket.__name__ under socketid339"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__package__.__eq__('') — standalone
#
# socket.__package__ is '' (empty string). This confirms socket is a top-level
# module. Despite its complexity (Python wrapper + C extension), socket is
# not a package — it does not have a __init__.py and submodules.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra339.package_is_empty:
  description: "socket.__package__.__eq__('') == True — socket.__package__ is empty string confirming socket is a top-level module (not a package or subpackage); despite its Python+C layered implementation, socket has no submodules or __init__.py; first standalone for socket.__package__ under socketid339"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# socket.__all__.__len__()==238 — standalone
#
# socket.__all__.__len__() is 238 on macOS/Darwin 25.4.0 with Python 3.14.3.
# This count is platform-specific. The list includes address families (AF_*),
# socket types (SOCK_*), socket options (SO_*, IP_*, TCP_*, etc.), error
# codes, protocol numbers, flags, and class/function names. macOS provides
# a richer set of constants than the minimum portable Unix set.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra339.all_len_238:
  description: "socket.__all__.__len__() == 238 — 238 entries on macOS/Darwin 25.4.0 (platform-specific; includes AF_* address families, SOCK_* types, SO_*/IP_*/TCP_* options, protocol numbers, flags, and class/function names; macOS provides richer constant set than minimum portable Unix); first standalone for socket.__all__.__len__() under socketid339"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 238

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('AF_INET')==True — standalone
#
# socket.__all__ contains 'AF_INET'. AF_INET is the IPv4 address family
# constant, one of the most fundamental socket constants. It is present on
# all platforms that support TCP/IP (which is all modern systems). AF_INET
# is an IntEnum member (AddressFamily.AF_INET) in Python 3.4+.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra339.all_contains_AF_INET:
  description: "socket.__all__.__contains__('AF_INET') == True — socket.__all__ includes 'AF_INET' (IPv4 address family); present on all platforms supporting TCP/IP; an IntEnum member (AddressFamily.AF_INET) since Python 3.4; first standalone for __all__.__contains__('AF_INET') under socketid339"
  category: module_identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["AF_INET"]
  expected: true
