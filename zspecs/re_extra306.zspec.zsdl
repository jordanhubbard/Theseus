spec: re_extra306
version: ">=3.6"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.match() returns a Match object on success or None on failure."
    - "group(0) returns the entire match; group(N) returns the Nth capturing group."
    - "lastindex is an integer attribute equal to the index of the last matched group."
    - "Named groups accessed via group('name') return the matched substring."
    - "re.match(r'\\d+', 'hello') returns None — no match; type is NoneType."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Match object — group() access
# ---------------------------------------------------------------------------

invariant re_extra306.match.group0:
  description: "re.match(r'(\\w+)\\s(\\w+)', 'hello world').group(0).__eq__('hello world')"
  category: match_groups
  kind: python_call_eq
  function: match
  args: ["(\\w+)\\s(\\w+)", "hello world"]
  method: group
  method_args: [0]
  method_chain: __eq__
  method_chain_args: ["hello world"]
  expected: true

invariant re_extra306.match.group1:
  description: "re.match(r'(\\w+)\\s(\\w+)', 'hello world').group(1).__eq__('hello')"
  category: match_groups
  kind: python_call_eq
  function: match
  args: ["(\\w+)\\s(\\w+)", "hello world"]
  method: group
  method_args: [1]
  method_chain: __eq__
  method_chain_args: ["hello"]
  expected: true

invariant re_extra306.match.group2:
  description: "re.match(r'(\\w+)\\s(\\w+)', 'hello world').group(2).__eq__('world')"
  category: match_groups
  kind: python_call_eq
  function: match
  args: ["(\\w+)\\s(\\w+)", "hello world"]
  method: group
  method_args: [2]
  method_chain: __eq__
  method_chain_args: ["world"]
  expected: true

# ---------------------------------------------------------------------------
# Match object — lastindex attribute
# ---------------------------------------------------------------------------

invariant re_extra306.match.lastindex:
  description: "re.match(r'(\\w+)\\s(\\w+)', 'hello world').lastindex.__eq__(2)"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["(\\w+)\\s(\\w+)", "hello world"]
  method: lastindex
  method_chain: __eq__
  method_chain_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Match object — start() and end() positions
# ---------------------------------------------------------------------------

invariant re_extra306.match.start:
  description: "re.match(r'(\\w+)', 'hello').start().__eq__(0)"
  category: match_span
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello"]
  method: start
  method_chain: __eq__
  method_chain_args: [0]
  expected: true

invariant re_extra306.match.end:
  description: "re.match(r'(\\w+)', 'hello').end().__eq__(5)"
  category: match_span
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello"]
  method: end
  method_chain: __eq__
  method_chain_args: [5]
  expected: true

# ---------------------------------------------------------------------------
# Named groups
# ---------------------------------------------------------------------------

invariant re_extra306.match.named_group:
  description: "re.match(r'(?P<word>\\w+)', 'hello').group('word').__eq__('hello')"
  category: match_groups
  kind: python_call_eq
  function: match
  args: ["(?P<word>\\w+)", "hello"]
  method: group
  method_args: ["word"]
  method_chain: __eq__
  method_chain_args: ["hello"]
  expected: true

# ---------------------------------------------------------------------------
# No match — re.match returns None; __class__.__name__ == 'NoneType'
# ---------------------------------------------------------------------------

invariant re_extra306.match.no_match_none_type:
  description: "re.match(r'\\d+', 'hello') returns None; type.__name__ == 'NoneType'"
  category: no_match
  kind: python_call_eq
  function: match
  args: ["\\d+", "hello"]
  method: __class__
  method_chain: __name__
  expected: "NoneType"
