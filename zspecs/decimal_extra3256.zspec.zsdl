spec: dc3256
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (dc3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __rpow__, __rlshift__, __rrshift__ dict-presence (reflected power/shift)."
    - "Key finding: decimal.Decimal.__rpow__ = true (consistent with wave 660 __pow__ = true); __rlshift__/__rrshift__ = false (no bitwise shift on Decimal)."
    - "decimal.Decimal.__rpow__ = True: Decimal is a full numeric type implementing IEEE 754 decimal arithmetic; it defines __rpow__ so that expressions like (int ** Decimal) work correctly by delegating to Decimal.__rpow__."
    - "decimal.Decimal.__rlshift__ = False: Decimal does not support bitwise left-shift; shift operators are defined only for integer types, and IEEE 754 decimal arithmetic has no bitwise shift semantics."
    - "decimal.Decimal.__rrshift__ = False: Decimal does not support bitwise right-shift for the same reason; __rrshift__ is absent from Decimal.__dict__."
    - "decimal.Context does NOT define __rpow__, __rlshift__, or __rrshift__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rpow__ dict-presence — operator.contains(Cls.__dict__, '__rpow__')
#
# decimal.Decimal defines __rpow__ in its own __dict__: true.
# Decimal is a complete numeric type implementing IEEE 754; __rpow__ enables
# right-hand exponentiation so that (int ** Decimal) dispatches to Decimal.__rpow__.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3256.rpow:
  description: "decimal types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3256

  columns: [id, function, args, expected]
  rows:
    - ["dc3256001", operator.contains, [decimal.Decimal.__dict__,          "__rpow__"], true]
    - ["dc3256002", operator.contains, [decimal.Context.__dict__,           "__rpow__"], false]
    - ["dc3256003", operator.contains, [decimal.DecimalException.__dict__,  "__rpow__"], false]
    - ["dc3256004", operator.contains, [decimal.InvalidOperation.__dict__,  "__rpow__"], false]
    - ["dc3256005", operator.contains, [decimal.Overflow.__dict__,          "__rpow__"], false]
    - ["dc3256006", operator.contains, [decimal.Underflow.__dict__,         "__rpow__"], false]

# ---------------------------------------------------------------------------
# __rlshift__ dict-presence — operator.contains(Cls.__dict__, '__rlshift__')
#
# decimal.Decimal does NOT define __rlshift__ in its own __dict__: false.
# Bitwise left-shift is an integer-only operation; IEEE 754 decimal arithmetic
# has no bitwise shift semantics. All decimal classes: false.
# ---------------------------------------------------------------------------

