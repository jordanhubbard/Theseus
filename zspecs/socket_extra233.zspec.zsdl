spec: socket_extra233
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket.zspec.zsdl — covers getdefaulttimeout()==None (expected: ~); getdefaulttimeout.__name__.__eq__('getdefaulttimeout')"
    - "socket_extra.zspec.zsdl — covers setdefaulttimeout(None)==None (return_is_none invariant)"
    - "socket_extra7.zspec.zsdl — covers getdefaulttimeout().__class__.__name__=='NoneType'"
    - "socket_extra11.zspec.zsdl — covers getdefaulttimeout.__module__.__eq__('_socket')"
    - "socket_extra40.zspec.zsdl — covers getdefaulttimeout.__qualname__.__eq__('getdefaulttimeout')"
    - "socket_extra99.zspec.zsdl — covers getdefaulttimeout.__qualname__.__len__()==17; setdefaulttimeout.__qualname__.__len__()==17"
    - "socket_extra141.zspec.zsdl — covers getdefaulttimeout.__doc__.__len__()==232; setdefaulttimeout.__doc__.__len__()==224"
    - "socket_extra175.zspec.zsdl — covers getdefaulttimeout.__name__.__eq__('getdefaulttimeout') standalone; setdefaulttimeout.__name__.__eq__"
    - "socket_extra212.zspec.zsdl — covers setdefaulttimeout.__doc__.__contains__('seconds') standalone"
    - "socket_extra213.zspec.zsdl — covers setdefaulttimeout.__doc__.__contains__('default','float','None','imported') table"
    - "socket_extra196.zspec.zsdl — covers setdefaulttimeout.__name__.__eq__; setdefaulttimeout.__module__.__eq__('_socket')"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.getdefaulttimeout.__doc__ contains 'Returns' — unique to getter vs setter which uses 'Set'."
    - "socket.getdefaulttimeout.__doc__ contains 'seconds' — timeout measured in seconds."
    - "socket.getdefaulttimeout.__doc__ contains 'float' — return type is float."
    - "socket.getdefaulttimeout.__doc__ contains 'None' — None means no timeout."
    - "socket.getdefaulttimeout.__doc__ contains 'imported' — default is None when module is first imported."
    - "socket.getdefaulttimeout.__doc__ contains 'timeout' — the function is about timeouts."
    - "socket.getdefaulttimeout.__doc__.__contains__ contracts have NOT been covered in any prior socket spec (socket_extra213 covers setdefaulttimeout.__doc__.__contains__ only)."
    - "socket.getdefaulttimeout().__class__.__name__ == 'NoneType' — covered in extra7; this spec covers doc contains contracts."
    - "socket.setdefaulttimeout.__doc__ contains 'new' — 'new socket objects' is in the docstring."
    - "socket.setdefaulttimeout.__doc__ contains 'socket' — 'new socket objects' is in the docstring."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.getdefaulttimeout.__doc__.__contains__ contracts
#
# socket.getdefaulttimeout.__doc__ ==
#   'getdefaulttimeout() -> timeout\n\nReturns the default timeout in
#    seconds (float) for new socket objects.\nA value of None indicates
#    that new socket objects have no timeout.\nWhen the socket module is
#    first imported, the default is None.'
#
# The docstring contains: 'Returns', 'timeout', 'seconds', 'float',
# 'None', 'imported'.
#
# Novel: socket_extra213 covers setdefaulttimeout.__doc__.__contains__ for
# 'default', 'float', 'None', 'imported'; socket_extra212 covers
# setdefaulttimeout.__doc__.__contains__('seconds') standalone.
# NO prior socket spec covers getdefaulttimeout.__doc__.__contains__ for
# any word. All six contains checks below are novel to socket_extra233.
# ---------------------------------------------------------------------------

table socket_extra233.getdefaulttimeout_doc_contains:
  description: "getdefaulttimeout.__doc__ contains 'Returns','timeout','seconds','float','None','imported'; doc contains contracts; new to socket_extra233"
  kind: python_call_eq
  category: doc_content
  id_prefix: socket233

  columns: [id, function, args, expected, description]
  rows:
    - [getdt_doc_has_Returns,
       "getdefaulttimeout.__doc__.__contains__",
       ["Returns"],
       true,
       "socket.getdefaulttimeout.__doc__.__contains__('Returns') == True — docstring begins 'Returns the default timeout'; 'Returns' distinguishes getter from setter (which uses 'Set'); novel: no prior spec checks getdefaulttimeout.__doc__.__contains__; new anchor in socket_extra233; verified Python 3.14.3"]
    - [getdt_doc_has_timeout,
       "getdefaulttimeout.__doc__.__contains__",
       ["timeout"],
       true,
       "socket.getdefaulttimeout.__doc__.__contains__('timeout') == True — the word 'timeout' appears in the docstring; the function name itself contains 'timeout'; novel anchor in socket_extra233; verified Python 3.14.3"]
    - [getdt_doc_has_seconds,
       "getdefaulttimeout.__doc__.__contains__",
       ["seconds"],
       true,
       "socket.getdefaulttimeout.__doc__.__contains__('seconds') == True — docstring reads 'Returns the default timeout in seconds (float)'; 'seconds' specifies the unit; novel anchor in socket_extra233; verified Python 3.14.3"]
    - [getdt_doc_has_float,
       "getdefaulttimeout.__doc__.__contains__",
       ["float"],
       true,
       "socket.getdefaulttimeout.__doc__.__contains__('float') == True — docstring reads 'seconds (float)'; the return type is float when a timeout is set; novel anchor in socket_extra233; verified Python 3.14.3"]
    - [getdt_doc_has_None,
       "getdefaulttimeout.__doc__.__contains__",
       ["None"],
       true,
       "socket.getdefaulttimeout.__doc__.__contains__('None') == True — docstring reads 'A value of None indicates that new socket objects have no timeout'; None means blocking mode; novel anchor in socket_extra233; verified Python 3.14.3"]
    - [getdt_doc_has_imported,
       "getdefaulttimeout.__doc__.__contains__",
       ["imported"],
       true,
       "socket.getdefaulttimeout.__doc__.__contains__('imported') == True — docstring reads 'When the socket module is first imported, the default is None'; sets expectations for initial state; novel anchor in socket_extra233; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__doc__.__contains__ contracts
#
# socket.setdefaulttimeout.__doc__ ==
#   'setdefaulttimeout(timeout)\n\nSet the default timeout in seconds
#    (float) for new socket objects.\nA value of None indicates that new
#    socket objects have no timeout.\nWhen the socket module is first
#    imported, the default is None.'
#
# socket_extra213 covers: 'default', 'float', 'None', 'imported'.
# socket_extra212 covers: 'seconds' (standalone).
# Novel words not yet checked: 'new', 'socket', 'Set'.
# ---------------------------------------------------------------------------

table socket_extra233.setdefaulttimeout_doc_contains_novel:
  description: "setdefaulttimeout.__doc__ contains 'new','socket','Set'; novel words not covered by extra212/extra213; new to socket_extra233"
  kind: python_call_eq
  category: doc_content
  id_prefix: socket233a

  columns: [id, function, args, expected, description]
  rows:
    - [setdt_doc_has_new,
       "setdefaulttimeout.__doc__.__contains__",
       ["new"],
       true,
       "socket.setdefaulttimeout.__doc__.__contains__('new') == True — docstring reads 'for new socket objects'; 'new' is novel: not in extra212/extra213 coverage; new anchor in socket_extra233; verified Python 3.14.3"]
    - [setdt_doc_has_socket,
       "setdefaulttimeout.__doc__.__contains__",
       ["socket"],
       true,
       "socket.setdefaulttimeout.__doc__.__contains__('socket') == True — docstring reads 'for new socket objects'; 'socket' appears as a noun; novel anchor in socket_extra233; verified Python 3.14.3"]
    - [setdt_doc_has_Set,
       "setdefaulttimeout.__doc__.__contains__",
       ["Set"],
       true,
       "socket.setdefaulttimeout.__doc__.__contains__('Set') == True — docstring begins 'Set the default timeout'; 'Set' with capital S distinguishes setter from getter ('Returns'); novel anchor in socket_extra233; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra233.getdefaulttimeout_doc_has_Returns:
  description: "socket.getdefaulttimeout.__doc__.__contains__('Returns') == True — getdefaulttimeout is a C-extension function from _socket that retrieves the current module-level default socket timeout; its docstring reads 'Returns the default timeout in seconds (float) for new socket objects'; the word 'Returns' (capital R) distinguishes the getter docstring from the setter (which begins 'Set the default timeout'); this is the only identifier in getdefaulttimeout's docstring that is absent from setdefaulttimeout's docstring; no prior socket spec checks getdefaulttimeout.__doc__.__contains__ for any word; socket_extra233 is the first namespace to anchor this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: "getdefaulttimeout.__doc__.__contains__"
  args: ["Returns"]
  expected: true

invariant socket_extra233.getdefaulttimeout_doc_has_seconds:
  description: "socket.getdefaulttimeout.__doc__.__contains__('seconds') == True — the docstring reads 'Returns the default timeout in seconds (float) for new socket objects'; 'seconds' specifies the time unit for the timeout value; this makes clear the return value is in seconds (not milliseconds or microseconds); socket_extra212 covers setdefaulttimeout.__doc__.__contains__('seconds') as a standalone; no prior spec covers getdefaulttimeout.__doc__.__contains__('seconds'); socket_extra233 is the first namespace to anchor this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: "getdefaulttimeout.__doc__.__contains__"
  args: ["seconds"]
  expected: true

invariant socket_extra233.getdefaulttimeout_doc_has_None:
  description: "socket.getdefaulttimeout.__doc__.__contains__('None') == True — the docstring reads 'A value of None indicates that new socket objects have no timeout'; None is the sentinel value for 'no timeout' (blocking mode) and is the default when the module is first imported; socket_extra7 confirms getdefaulttimeout() == None (returns None by default); this spec confirms that 'None' appears in the docstring text itself; no prior spec checks getdefaulttimeout.__doc__.__contains__('None'); socket_extra233 is the first namespace to anchor this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: "getdefaulttimeout.__doc__.__contains__"
  args: ["None"]
  expected: true
