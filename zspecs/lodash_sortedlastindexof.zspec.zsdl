spec: lodash_sortedlastindexof
version: ">=4.0.0"
backend: node(lodash.sortedlastindexof)

docs: https://lodash.com/docs/#sortedLastIndexOf

provenance:
  derived_from:
    - "lodash.sortedlastindexof README — https://www.npmjs.com/package/lodash.sortedlastindexof"
    - "Test vectors verified with lodash.sortedlastindexof@4.1.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sortedlastindexof exports the _.sortedLastIndexOf function directly as module.exports."
    - "sortedLastIndexOf(array, value) uses binary search to find the last index of value."
    - "Returns -1 if not found."
    - "Array must be sorted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns last index of value using binary search, or -1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sortedlastindexof.sortedlastindexof:
  kind: node_module_call_eq
  function: ~
  category: sortedlastindexof
  id_prefix: lsliof

  columns: [id, args, expected]
  rows:
    - [last_dup,   [[4, 5, 5, 5, 6], 5],   3]
    - [only,       [[1, 2, 3, 4, 5], 3],   2]
    - [not_found,  [[1, 2, 3], 0],         -1]
