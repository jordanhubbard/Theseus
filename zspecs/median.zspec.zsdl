provenance:
  derived_from:
    - "median README — https://www.npmjs.com/package/median"
    - "Test vectors verified with median via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "median source"
  notes:
    - "median is an npm package. Install: npm install median"
    - "Returns the median value of an array of numbers."
    - "For even-length arrays, returns the average of the two middle values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table median.median:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: med

  columns: [id, args, expected]
  rows:
    - [five,  [[1, 2, 3, 4, 5]],  3]
    - [four,  [[1, 2, 3, 4]],     2.5]
    - [one,   [[5]],              5]

