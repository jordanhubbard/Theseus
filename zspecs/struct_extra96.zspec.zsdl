spec: struct_extra96
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra95

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') for all six functions (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth and entry names / module-level function __qualname__.__len__() for pack/unpack/calcsize (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
    - "struct_extra90.zspec.zsdl — covers struct module-level function __qualname__ / Struct method __qualname__ and class names (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra95; it does NOT duplicate invariants present in those files."
    - "Wave 263 theme: struct Struct method __name__.__len__() values / module-level function __name__.__len__() values / Struct.__name__.__len__() and error.__name__.__len__()."
    - "struct.Struct.pack.__name__.__len__() == 4 ('pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__name__.__len__() == 6 ('unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__.__len__() == 9 ('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__.__len__() == 11 ('unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__.__len__() == 11 ('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__name__.__len__() == 4 ('pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__.__len__() == 6 ('unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__.__len__() == 8 ('calcsize'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__.__len__() == 9 ('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__.__len__() == 11 ('unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__.__len__() == 11 ('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__.__len__() == 5 ('error'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__.__len__() == 6 ('Struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct method __name__.__len__() values match module-level function __name__.__len__() because method __name__ equals the simple function name (no class prefix). This contrasts with __qualname__.__len__() which includes the 'Struct.' prefix (7 extra chars)."
    - "Note: Struct.pack and struct.pack share __name__ 'pack' and __name__.__len__()==4; similarly for unpack (6), pack_into (9), unpack_from/iter_unpack (11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__name__.__len__()==4
# struct.Struct.unpack.__name__.__len__()==6
# struct.Struct.pack_into.__name__.__len__()==9
# struct.Struct.unpack_from.__name__.__len__()==11
# struct.Struct.iter_unpack.__name__.__len__()==11
#
# Wave 263 theme: Struct method __name__.__len__() values.
#
# Struct method __name__ gives the simple function name (no class prefix), so
# __name__.__len__() is the length of the method name alone: pack (4), unpack (6),
# pack_into (9), unpack_from (11), iter_unpack (11). This contrasts with
# __qualname__.__len__() (anchored in extra94) which adds 7 chars for 'Struct.'.
# struct_extra93 anchors Struct method __name__.__eq__; no prior spec anchors
# __name__.__len__() for Struct methods under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra96.Struct_method_name_lengths:
  description: "struct.Struct.pack/__name__/__len__()==4 / unpack/__name__/__len__()==6 / pack_into/__name__/__len__()==9 / unpack_from/__name__/__len__()==11 / iter_unpack/__name__/__len__()==11 — Struct method __name__ is the simple name (no 'Struct.' prefix); __name__.__len__() matches module-level function __name__.__len__(); unpack_from/iter_unpack share length 11; extra93 anchors __name__.__eq__; extra94 anchors __qualname__.__len__(); first structnamelen96 anchor for Struct method __name__.__len__()"
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelen96

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_pack_nlen,         Struct.pack.__name__.__len__,         [], 4,  "'pack' is 4 chars"]
    - [Struct_unpack_nlen,       Struct.unpack.__name__.__len__,       [], 6,  "'unpack' is 6 chars"]
    - [Struct_pack_into_nlen,    Struct.pack_into.__name__.__len__,    [], 9,  "'pack_into' is 9 chars"]
    - [Struct_unpack_from_nlen,  Struct.unpack_from.__name__.__len__,  [], 11, "'unpack_from' is 11 chars, same length as 'iter_unpack'"]
    - [Struct_iter_unpack_nlen,  Struct.iter_unpack.__name__.__len__,  [], 11, "'iter_unpack' is 11 chars, same length as 'unpack_from'"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__len__()==4
# struct.unpack.__name__.__len__()==6
# struct.calcsize.__name__.__len__()==8
# struct.pack_into.__name__.__len__()==9
# struct.unpack_from.__name__.__len__()==11
# struct.iter_unpack.__name__.__len__()==11
#
# Wave 263 theme: module-level function __name__.__len__() values.
#
# Module-level struct functions have __name__ equal to the simple function name:
# pack (4), unpack (6), calcsize (8), pack_into (9), unpack_from (11), iter_unpack (11).
# struct_extra95 anchors module-level function __qualname__.__len__() for these;
# __name__.__len__() is new territory (for module-level C builtins, __name__ ==
# __qualname__ because there is no enclosing class). No prior spec anchors
# __name__.__len__() for module-level functions under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra96.struct_module_fn_name_lengths:
  description: "struct.pack/__name__/__len__()==4 / unpack/__name__/__len__()==6 / calcsize/__name__/__len__()==8 / pack_into/__name__/__len__()==9 / unpack_from/__name__/__len__()==11 / iter_unpack/__name__/__len__()==11 — module-level C builtins: __name__ == __qualname__ (no class prefix); these match Struct method __name__.__len__() values; extra95 anchors __qualname__.__len__() for most; first structnamelen96 anchor for module-level __name__.__len__()"
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelen96

  columns: [id, function, args, expected, description]
  rows:
    - [pack_nlen,        pack.__name__.__len__,        [], 4,  "'pack' is 4 chars; __name__ == __qualname__ for top-level C builtins"]
    - [unpack_nlen,      unpack.__name__.__len__,      [], 6,  "'unpack' is 6 chars"]
    - [calcsize_nlen,    calcsize.__name__.__len__,    [], 8,  "'calcsize' is 8 chars"]
    - [pack_into_nlen,   pack_into.__name__.__len__,   [], 9,  "'pack_into' is 9 chars"]
    - [unpack_from_nlen, unpack_from.__name__.__len__, [], 11, "'unpack_from' is 11 chars, same length as 'iter_unpack'"]
    - [iter_unpack_nlen, iter_unpack.__name__.__len__, [], 11, "'iter_unpack' is 11 chars, same length as 'unpack_from'"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__len__()==5
# struct.Struct.__name__.__len__()==6
#
# Wave 263 theme: Struct class and error exception __name__.__len__().
#
# error.__name__ is 'error' (5 chars) — same as __qualname__ since error is a
# top-level exception class. Struct.__name__ is 'Struct' (6 chars) — same as
# __qualname__ since Struct is a top-level class. For top-level class/type objects,
# __name__ == __qualname__. struct_extra95 anchors __qualname__.__len__() for both;
# no prior spec anchors __name__.__len__() for Struct and error under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra96.struct_Struct_error_name_lengths:
  description: "struct.error/__name__/__len__()==5 / Struct/__name__/__len__()==6 — top-level class/exception __name__ == __qualname__; error is 'error' (5 chars), Struct is 'Struct' (6 chars); extra95 anchors __qualname__.__len__(); first structnamelen96 anchor for Struct and error __name__.__len__()"
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelen96

  columns: [id, function, args, expected, description]
  rows:
    - [error_nlen,  error.__name__.__len__,  [], 5, "'error' is 5 chars; __name__ == __qualname__ for top-level exception"]
    - [Struct_nlen, Struct.__name__.__len__, [], 6, "'Struct' is 6 chars; __name__ == __qualname__ for top-level class"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__name__.__len__()==4 — standalone
#
# struct.Struct.pack.__name__.__len__() is 4. Struct.pack.__name__ is 'pack'
# (4 chars), the simple method name without a class prefix. For method_descriptor
# objects (which is what Struct.pack is), __name__ gives the method name alone,
# not the qualified name. This contrasts with __qualname__ ('Struct.pack', 11 chars,
# anchored in extra94). pack is used to pack values into a bytes object according
# to the format string stored in the Struct instance. struct_extra93 anchors
# Struct.pack.__name__.__eq__('pack'); no prior spec anchors
# Struct.pack.__name__.__len__()==4 as a standalone under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra96.Struct_pack_name_len_4:
  description: "struct.Struct.pack.__name__.__len__() == 4 — Struct.pack.__name__ is 'pack' (4 chars); method_descriptor __name__ gives the simple name without class prefix, contrasting __qualname__ ('Struct.pack', 11 chars from extra94); pack packs values into bytes per format string; extra93 anchors __name__.__eq__('pack'); first standalone for Struct.pack.__name__.__len__() under structnamelen96"
  category: name_lengths
  kind: python_call_eq
  function: Struct.pack.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__name__.__len__()==11 — standalone
#
# struct.Struct.unpack_from.__name__.__len__() is 11. Struct.unpack_from.__name__
# is 'unpack_from' (11 chars). unpack_from unpacks from a buffer starting at
# a given offset position without requiring the buffer to be exactly the right
# size. It shares __name__.__len__()==11 with iter_unpack. struct_extra94 anchors
# Struct.unpack_from.__qualname__.__len__()==18; no prior spec anchors
# Struct.unpack_from.__name__.__len__()==11 as a standalone under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra96.Struct_unpack_from_name_len_11:
  description: "struct.Struct.unpack_from.__name__.__len__() == 11 — Struct.unpack_from.__name__ is 'unpack_from' (11 chars); unpacks from buffer at given offset without requiring exact buffer size; shares __name__.__len__()==11 with iter_unpack; extra94 anchors __qualname__.__len__()==18; first standalone for Struct.unpack_from.__name__.__len__() under structnamelen96"
  category: name_lengths
  kind: python_call_eq
  function: Struct.unpack_from.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.calcsize.__name__.__len__()==8 — standalone
#
# struct.calcsize.__name__.__len__() is 8. calcsize.__name__ is 'calcsize'
# (8 chars). For module-level C builtins, __name__ == __qualname__, so
# calcsize.__name__.__len__() == calcsize.__qualname__.__len__() (both 8).
# struct.calcsize returns the size of the struct (as bytes) corresponding to
# a format string, without creating a Struct object. struct_extra94 anchors
# calcsize.__qualname__.__len__()==8; no prior spec anchors
# calcsize.__name__.__len__()==8 as a standalone under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra96.calcsize_name_len_8:
  description: "struct.calcsize.__name__.__len__() == 8 — calcsize.__name__ is 'calcsize' (8 chars); for module-level C builtins __name__ == __qualname__ so both __len__() are 8; calcsize returns the byte size of a format string without creating a Struct object; extra94 anchors __qualname__.__len__()==8; first standalone for calcsize.__name__.__len__() under structnamelen96"
  category: name_lengths
  kind: python_call_eq
  function: calcsize.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.error.__name__.__len__()==5 — standalone
#
# struct.error.__name__.__len__() is 5. error.__name__ is 'error' (5 chars).
# For top-level exception classes, __name__ == __qualname__, so both lengths
# are 5. struct.error is raised by packing/unpacking operations when the data
# does not match the format string (e.g., values out of range, buffer too short).
# struct_extra95 anchors error.__qualname__.__len__()==5; no prior spec anchors
# error.__name__.__len__()==5 as a standalone under structnamelen96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra96.error_name_len_5:
  description: "struct.error.__name__.__len__() == 5 — error.__name__ is 'error' (5 chars); top-level exception class: __name__ == __qualname__, so both __len__() are 5; struct.error is raised for packing/unpacking failures (values out of range, buffer too short); extra95 anchors __qualname__.__len__()==5; first standalone for error.__name__.__len__() under structnamelen96"
  category: name_lengths
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5
