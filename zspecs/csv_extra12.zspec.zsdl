spec: csv_extra12
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra11."
    - "csv_extra11 covers: QUOTE_STRINGS/QUOTE_NOTNULL values+types; field_size_limit __name__/__module__; excel_tab doublequote/skipinitialspace; unix_dialect doublequote; DictReader/excel/excel_tab __bases__.__len__."
    - "csv_extra10 covers: Dialect/Error/Sniffer __class__.__name__; get_dialect.__name__."
    - "csv_extra9 covers: DictReader/DictWriter __bases__[0]; reader/writer/DictReader/DictWriter __class__.__name__; list_dialects return type; unregister_dialect/__module__."
    - "csv_extra8 covers: QUOTE_ALL/__ne__(0); QUOTE_MINIMAL/__lt__(1); QUOTE_NONNUMERIC/__gt__(1); QUOTE_NONE/__gt__(2)."
    - "Focus: new axes not yet covered in any prior csv spec."
    - "csv.reader.__name__ == 'reader' — the C builtin reader callable __name__ attribute."
    - "csv.writer.__name__ == 'writer' — the C builtin writer callable __name__ attribute."
    - "csv.DictReader.__name__ == 'DictReader' — Python class __name__ attribute."
    - "csv.DictWriter.__name__ == 'DictWriter' — Python class __name__ attribute."
    - "csv.QUOTE_ALL == 1 and class is int — value + type for the four classic QUOTE constants."
    - "csv.QUOTE_MINIMAL == 0, QUOTE_NONNUMERIC == 2, QUOTE_NONE == 3."
    - "csv.Error.__name__ == 'Error' — exception class __name__ attribute."
    - "csv.excel.__name__ == 'excel' — dialect class __name__ attribute."
    - "csv.excel_tab.__name__ == 'excel_tab' — dialect class __name__ attribute."
    - "csv.unix_dialect.__name__ == 'unix_dialect' — dialect class __name__ attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# csv.reader and csv.writer __name__ attributes
#
# csv_extra9 checks reader/writer __class__.__name__ (both are
# 'builtin_function_or_method'). No prior spec checks reader.__name__ or
# writer.__name__ directly.
# ---------------------------------------------------------------------------

invariant csv_extra12.reader.name:
  description: "csv.reader.__name__ == 'reader'"
  category: function_names
  kind: python_call_eq
  function: reader.__name__.__eq__
  args: ["reader"]
  expected: true

invariant csv_extra12.writer.name:
  description: "csv.writer.__name__ == 'writer'"
  category: function_names
  kind: python_call_eq
  function: writer.__name__.__eq__
  args: ["writer"]
  expected: true

# ---------------------------------------------------------------------------
# csv.DictReader and csv.DictWriter __name__ attributes
#
# csv_extra9 checks DictReader/DictWriter __bases__[0].__name__ and
# __class__.__name__. No prior spec checks DictReader.__name__ or
# DictWriter.__name__ directly.
# ---------------------------------------------------------------------------

invariant csv_extra12.DictReader.name:
  description: "csv.DictReader.__name__ == 'DictReader'"
  category: class_names
  kind: python_call_eq
  function: DictReader.__name__.__eq__
  args: ["DictReader"]
  expected: true

invariant csv_extra12.DictWriter.name:
  description: "csv.DictWriter.__name__ == 'DictWriter'"
  category: class_names
  kind: python_call_eq
  function: DictWriter.__name__.__eq__
  args: ["DictWriter"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE constants — exact integer values
#
# csv_extra5/6/8 check QUOTE constants via __class__.__name__ and inequality
# comparisons. No prior csv spec checks the exact integer values via __eq__
# for all four classic QUOTE constants in a single spec.
# ---------------------------------------------------------------------------

table csv_extra12.quote_constants_eq:
  kind: python_call_eq
  category: constants
  id_prefix: qceq12

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_MINIMAL,    QUOTE_MINIMAL.__eq__,    [0], true]
    - [QUOTE_ALL,        QUOTE_ALL.__eq__,        [1], true]
    - [QUOTE_NONNUMERIC, QUOTE_NONNUMERIC.__eq__,  [2], true]
    - [QUOTE_NONE,       QUOTE_NONE.__eq__,       [3], true]

# ---------------------------------------------------------------------------
# csv.Error.__name__
#
# csv_extra10 checks csv.Error.__class__.__name__ (== 'type', the metaclass).
# No prior csv spec checks csv.Error.__name__ (the class name itself).
# ---------------------------------------------------------------------------

invariant csv_extra12.Error.name:
  description: "csv.Error.__name__ == 'Error'"
  category: class_names
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# csv.excel, csv.excel_tab, csv.unix_dialect __name__ attributes
#
# Prior specs check dialect attributes (doublequote, skipinitialspace, delimiter)
# and __class__.__name__. No prior spec checks the dialect classes' own __name__
# attribute for excel, excel_tab, or unix_dialect.
# ---------------------------------------------------------------------------

invariant csv_extra12.excel.name:
  description: "csv.excel.__name__ == 'excel'"
  category: class_names
  kind: python_call_eq
  function: excel.__name__.__eq__
  args: ["excel"]
  expected: true

invariant csv_extra12.excel_tab.name:
  description: "csv.excel_tab.__name__ == 'excel_tab'"
  category: class_names
  kind: python_call_eq
  function: excel_tab.__name__.__eq__
  args: ["excel_tab"]
  expected: true

invariant csv_extra12.unix_dialect.name:
  description: "csv.unix_dialect.__name__ == 'unix_dialect'"
  category: class_names
  kind: python_call_eq
  function: unix_dialect.__name__.__eq__
  args: ["unix_dialect"]
  expected: true
