    - [gct_doc_has_opaque,  abc.get_cache_token.__doc__.__contains__, ["opaque"],  true, "abc.get_cache_token.__doc__.__contains__('opaque') == True; verified with Python 3.14.3"]
    - [gct_doc_has_token,   abc.get_cache_token.__doc__.__contains__, ["token"],   true, "abc.get_cache_token.__doc__.__contains__('token') == True; verified with Python 3.14.3"]
