  description: "abc.get_cache_token.__doc__ contains checks in abce208gct namespace — wave 208 theme: get_cache_token.__doc__.__contains__('cache')==True (docstring: 'Returns the current ABC cache token.' — 'cache' in 'cache token'); get_cache_token.__doc__.__contains__('opaque')==True ('The token is an opaque object...'); get_cache_token.__doc__.__contains__('token')==True ('cache token'); get_cache_token.__doc__.__contains__('Returns')==True (docstring opens with 'Returns the current...'); get_cache_token.__doc__.__len__()==230; doc length ordering: ABC=78 < get_cache_token=230 < abstractmethod=537 < ABCMeta=576; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce208gct

  columns: [id, function, args, expected, description]
