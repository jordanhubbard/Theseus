# ---------------------------------------------------------------------------
# Standalone invariants — extra208
# ---------------------------------------------------------------------------

invariant abc_extra208.ABC_doc_len_78:
  description: "abc.ABC.__doc__.__len__() == 78 — abc.ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (78 chars including the embedded newline and trailing newline); ABC.__doc__.__contains__('ABC') is True; ABC.__doc__.__contains__('inheritance') is True; ABC.__doc__.__contains__('Helper') is True; ABC.__doc__.__contains__('base') is False (lowercase 'base' absent); doc length ordering: ABC=78 < get_cache_token=230 < abstractmethod=537 < ABCMeta=576; abc.ABC is the simplest way to define an abstract base class in Python — just inherit from it instead of setting metaclass=ABCMeta explicitly; NEW in extra208: first standalone ABC __doc__ length invariant; wave 208; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__len__
  args: []
  expected: 78

invariant abc_extra208.ABCMeta_doc_has_Abstract:
  description: "abc.ABCMeta.__doc__.__contains__('Abstract') returns True — ABCMeta.__doc__ opens with 'Metaclass for defining Abstract Base Classes (ABCs).' (len=576); 'Abstract' (capital A) appears in 'Abstract Base Classes'; ABCMeta.__doc__.__contains__('abstract') is False (lowercase 'abstract' absent — unlike abstractmethod.__doc__ which uses lowercase 'abstract'); ABCMeta.__doc__.__contains__('Metaclass') is True; ABCMeta.__doc__.__len__()==576 (longest in spec); ABCMeta is the metaclass for abstract base classes — it can be used directly as metaclass=ABCMeta or via inheritance from abc.ABC; NEW in extra208: first standalone ABCMeta __doc__ Abstract contains invariant; wave 208; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__contains__
  args: ["Abstract"]
  expected: true

invariant abc_extra208.abstractmethod_doc_len_537:
  description: "abc.abstractmethod.__doc__.__len__() == 537 — abstractmethod has the second-longest __doc__ in this spec (537 chars); abstractmethod.__doc__.__contains__('abstract') is True (lowercase); abstractmethod.__doc__.__contains__('decorator') is True; abstractmethod.__doc__.__contains__('Abstract') is False (capital A absent, contrasting with ABCMeta.__doc__ which uses 'Abstract'); abstractmethod.__doc__.__contains__('indicating') is True; doc length ordering: ABC=78 < get_cache_token=230 < abstractmethod=537 < ABCMeta=576 (ABCMeta is 39 chars longer); abc.abstractmethod is a decorator that marks a method as abstract, preventing instantiation of classes that do not override it; NEW in extra208: first standalone abstractmethod __doc__ length invariant; wave 208; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__len__
  args: []
  expected: 537

invariant abc_extra208.get_cache_token_doc_has_opaque:
  description: "abc.get_cache_token.__doc__.__contains__('opaque') returns True — get_cache_token.__doc__ contains 'The token is an opaque object (supporting equality testing)'; __contains__('cache') is True; __contains__('token') is True; __contains__('Returns') is True; get_cache_token.__doc__.__len__()==230; abc.get_cache_token() returns the current ABC cache token — an integer that is incremented each time the ABC caching machinery is invalidated (e.g., by calling ABCMeta.register()); the token supports equality testing and can be used to detect stale cached ABC checks; NEW in extra208: first standalone get_cache_token __doc__ opaque contains invariant; wave 208; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__doc__.__contains__
  args: ["opaque"]
  expected: true
