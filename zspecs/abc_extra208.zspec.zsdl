spec: abc_extra208
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: __doc__ string contains checks for abc module classes and functions. NEW in extra208: abc.ABC.__doc__.__contains__('ABC')==True (len=78); abc.ABC.__doc__.__contains__('inheritance')==True; abc.ABCMeta.__doc__.__contains__('Abstract')==True (len=576); abc.ABCMeta.__doc__.__contains__('Metaclass')==True; abc.abstractmethod.__doc__.__contains__('abstract')==True (len=537); abc.abstractmethod.__doc__.__contains__('decorator')==True; abc.get_cache_token.__doc__.__contains__('cache')==True (len=230); abc.get_cache_token.__doc__.__contains__('opaque')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__doc__ == 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (len=78). __contains__('ABC')==True; __contains__('inheritance')==True; __contains__('Helper')==True; __contains__('base')==False (lowercase 'base' not in ABC docstring); __contains__('Base')==False (capital 'Base' not in ABC docstring). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__doc__ starts with 'Metaclass for defining Abstract Base Classes (ABCs).' (len=576). __contains__('Abstract')==True; __contains__('Metaclass')==True; __contains__('abstract')==False (lowercase 'abstract' does not appear — only 'Abstract' with capital A). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__doc__ starts with 'A decorator indicating abstract methods.' (len=537). __contains__('abstract')==True (lowercase); __contains__('decorator')==True; __contains__('Abstract')==False (capital 'Abstract' does not appear). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__doc__ starts with 'Returns the current ABC cache token.' (len=230). __contains__('cache')==True; __contains__('opaque')==True; __contains__('token')==True; __contains__('Returns')==True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC __doc__ contains checks — extra208
#
# abc.ABC.__doc__ == 'Helper class that provides a standard way to create an ABC using\ninheritance.\n'
# len == 78
# __contains__('ABC') == True
# __contains__('inheritance') == True
# __contains__('Helper') == True
# __contains__('base') == False
# ---------------------------------------------------------------------------

table abc_extra208.abc_ABC_doc_contains:
  description: "abc.ABC.__doc__ contains checks in abce208abc namespace — wave 208 theme: abc __doc__ string inspection; ABC.__doc__.__contains__('ABC')==True (docstring: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' — 'ABC' appears in the text); ABC.__doc__.__contains__('inheritance')==True ('create an ABC using\\ninheritance'); ABC.__doc__.__contains__('Helper')==True (docstring opens with 'Helper class'); ABC.__doc__.__contains__('base')==False (lowercase 'base' does not appear — only 'ABC' as an acronym); ABC.__doc__.__len__()==78 (includes trailing newline); doc length ordering: ABC=78 < get_cache_token=230 < abstractmethod=537 < ABCMeta=576; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce208abc

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_has_ABC,         abc.ABC.__doc__.__contains__, ["ABC"],         true,  "abc.ABC.__doc__.__contains__('ABC') == True; verified with Python 3.14.3"]
    - [abc_doc_has_inheritance, abc.ABC.__doc__.__contains__, ["inheritance"], true,  "abc.ABC.__doc__.__contains__('inheritance') == True; verified with Python 3.14.3"]
    - [abc_doc_has_Helper,      abc.ABC.__doc__.__contains__, ["Helper"],      true,  "abc.ABC.__doc__.__contains__('Helper') == True; verified with Python 3.14.3"]
    - [abc_doc_no_base,         abc.ABC.__doc__.__contains__, ["base"],        false, "abc.ABC.__doc__.__contains__('base') == False — lowercase 'base' not in docstring; verified with Python 3.14.3"]
    - [abc_doc_len,             abc.ABC.__doc__.__len__,       [],              78,    "abc.ABC.__doc__.__len__() == 78 (includes trailing newline); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
