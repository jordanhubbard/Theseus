# ---------------------------------------------------------------------------

table abc_extra208.abc_abstractmethod_doc_contains:
  description: "abc.abstractmethod.__doc__ contains checks in abce208am namespace — wave 208 theme: abstractmethod.__doc__.__contains__('abstract')==True (docstring opens: 'A decorator indicating abstract methods.' — 'abstract' lowercase appears); abstractmethod.__doc__.__contains__('decorator')==True ('A decorator indicating...'); abstractmethod.__doc__.__contains__('Abstract')==False (capital 'Abstract' does not appear — uses lowercase 'abstract' throughout, in contrast to ABCMeta.__doc__ which uses 'Abstract' with capital A); abstractmethod.__doc__.__contains__('indicating')==True ('A decorator indicating'); abstractmethod.__doc__.__len__()==537 (second-longest in this spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce208am

  columns: [id, function, args, expected, description]
  rows:
    - [am_doc_has_abstract,   abc.abstractmethod.__doc__.__contains__, ["abstract"],   true,  "abc.abstractmethod.__doc__.__contains__('abstract') == True; verified with Python 3.14.3"]
    - [am_doc_has_decorator,  abc.abstractmethod.__doc__.__contains__, ["decorator"],  true,  "abc.abstractmethod.__doc__.__contains__('decorator') == True; verified with Python 3.14.3"]
    - [am_doc_has_indicating, abc.abstractmethod.__doc__.__contains__, ["indicating"], true,  "abc.abstractmethod.__doc__.__contains__('indicating') == True; verified with Python 3.14.3"]
    - [am_doc_no_Abstract,    abc.abstractmethod.__doc__.__contains__, ["Abstract"],   false, "abc.abstractmethod.__doc__.__contains__('Abstract') == False — capital 'Abstract' not in abstractmethod docstring; verified with Python 3.14.3"]
    - [am_doc_len,            abc.abstractmethod.__doc__.__len__,      [],             537,   "abc.abstractmethod.__doc__.__len__() == 537; verified with Python 3.14.3"]

