# len == 576
# __contains__('Abstract') == True
# __contains__('Metaclass') == True
# __contains__('abstract') == False   (capital A only)
# ---------------------------------------------------------------------------

table abc_extra208.abc_ABCMeta_doc_contains:
  description: "abc.ABCMeta.__doc__ contains checks in abce208abcmeta namespace — wave 208 theme: ABCMeta.__doc__.__contains__('Abstract')==True (docstring opens: 'Metaclass for defining Abstract Base Classes (ABCs).' — 'Abstract' with capital A); ABCMeta.__doc__.__contains__('Metaclass')==True ('Metaclass for defining...'); ABCMeta.__doc__.__contains__('abstract')==False (lowercase 'abstract' does not appear — the docstring uses 'Abstract' with capital A throughout); ABCMeta.__doc__.__len__()==576 (longest __doc__ in this spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce208abcmeta

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_doc_has_Abstract,  abc.ABCMeta.__doc__.__contains__, ["Abstract"],  true,  "abc.ABCMeta.__doc__.__contains__('Abstract') == True; verified with Python 3.14.3"]
    - [abcmeta_doc_has_Metaclass, abc.ABCMeta.__doc__.__contains__, ["Metaclass"],  true,  "abc.ABCMeta.__doc__.__contains__('Metaclass') == True; verified with Python 3.14.3"]
    - [abcmeta_doc_no_abstract,   abc.ABCMeta.__doc__.__contains__, ["abstract"],  false, "abc.ABCMeta.__doc__.__contains__('abstract') == False — lowercase 'abstract' not in ABCMeta docstring; verified with Python 3.14.3"]
    - [abcmeta_doc_len,           abc.ABCMeta.__doc__.__len__,      [],             576,   "abc.ABCMeta.__doc__.__len__() == 576 (longest __doc__ in this spec); verified with Python 3.14.3"]

