spec: inspect_extra197
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter class method qualnames and descriptor attribute class names."
    - "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' — __init__ is an instance method defined in class Parameter; qualified name includes the class prefix. Verified with Python 3.14.3."
    - "inspect.Parameter.replace.__qualname__ == 'Parameter.replace' — replace is an instance method that creates a modified copy of the Parameter. Verified with Python 3.14.3."
    - "inspect.Parameter.__repr__.__qualname__ == 'Parameter.__repr__' — __repr__ is the string representation method for Parameter instances. Verified with Python 3.14.3."
    - "inspect.Parameter.__eq__.__qualname__ == 'Parameter.__eq__' — __eq__ implements equality comparison for Parameter instances. Verified with Python 3.14.3."
    - "inspect.Parameter.__hash__.__qualname__ == 'Parameter.__hash__' — __hash__ enables Parameter to be used in sets and as dict keys. Verified with Python 3.14.3."
    - "inspect.Parameter.kind.__class__.__name__ == 'property' — kind is a read-only property descriptor on the Parameter class. Verified with Python 3.14.3."
    - "inspect.Parameter.default.__class__.__name__ == 'property' — default is a read-only property descriptor. Verified with Python 3.14.3."
    - "inspect.Parameter.annotation.__class__.__name__ == 'property' — annotation is a read-only property descriptor. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter method qualnames — __init__, replace, __repr__
#
# inspect.Parameter.__init__.__qualname__.__eq__('Parameter.__init__') == True
# inspect.Parameter.replace.__qualname__.__eq__('Parameter.replace') == True
# inspect.Parameter.__repr__.__qualname__.__eq__('Parameter.__repr__') == True
#
# Parameter is a pure-Python class in Lib/inspect.py. Methods defined in a
# class body get __qualname__ of the form 'ClassName.method_name'.
# New to extra197.
# ---------------------------------------------------------------------------

table inspect_extra197.parameter_method_qualnames_1:
  description: "inspect.Parameter __init__/replace/__repr__ __qualname__; pure-Python class methods with 'Parameter.' prefix qualname; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparammethod197

  columns: [id, function, args, expected, description]
  rows:
    - [param_init_qualname,
       Parameter.__init__.__qualname__.__eq__,
       ["Parameter.__init__"],
       true,
       "inspect.Parameter.__init__.__qualname__.__eq__('Parameter.__init__') == True — __init__ is defined inside class Parameter in Lib/inspect.py; its __qualname__ is 'Parameter.__init__' (class name dot method name); str.__eq__('Parameter.__init__') returns True; new to extra197"]
    - [param_replace_qualname,
       Parameter.replace.__qualname__.__eq__,
       ["Parameter.replace"],
       true,
       "inspect.Parameter.replace.__qualname__.__eq__('Parameter.replace') == True — replace is a method of class Parameter that returns a new Parameter with selected fields changed; __qualname__ is 'Parameter.replace'; str.__eq__('Parameter.replace') returns True; new to extra197"]
    - [param_repr_qualname,
       Parameter.__repr__.__qualname__.__eq__,
       ["Parameter.__repr__"],
       true,
       "inspect.Parameter.__repr__.__qualname__.__eq__('Parameter.__repr__') == True — __repr__ is defined inside class Parameter; it returns a string like '<Parameter \\\"name\\\">'; __qualname__ is 'Parameter.__repr__'; str.__eq__('Parameter.__repr__') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter method qualnames — __eq__, __hash__
#
# inspect.Parameter.__eq__.__qualname__.__eq__('Parameter.__eq__') == True
# inspect.Parameter.__hash__.__qualname__.__eq__('Parameter.__hash__') == True
#
# __eq__ compares Parameter instances by (name, kind, default, annotation).
# __hash__ is defined so Parameters are hashable. New to extra197.
# ---------------------------------------------------------------------------

table inspect_extra197.parameter_method_qualnames_2:
  description: "inspect.Parameter __eq__ and __hash__ __qualname__; equality and hash methods with 'Parameter.' prefix qualname; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparammethod197

  columns: [id, function, args, expected, description]
  rows:
    - [param_eq_qualname,
       Parameter.__eq__.__qualname__.__eq__,
       ["Parameter.__eq__"],
       true,
       "inspect.Parameter.__eq__.__qualname__.__eq__('Parameter.__eq__') == True — __eq__ is defined in class Parameter; it enables equality comparison of parameter objects by name/kind/default/annotation; __qualname__ is 'Parameter.__eq__'; str.__eq__('Parameter.__eq__') returns True; new to extra197"]
    - [param_hash_qualname,
       Parameter.__hash__.__qualname__.__eq__,
       ["Parameter.__hash__"],
       true,
       "inspect.Parameter.__hash__.__qualname__.__eq__('Parameter.__hash__') == True — __hash__ is defined in class Parameter; it enables Parameter objects to be stored in sets and used as dict keys; __qualname__ is 'Parameter.__hash__'; str.__eq__('Parameter.__hash__') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter descriptor attribute class names
#
# inspect.Parameter.kind.__class__.__name__.__eq__('property') == True
# inspect.Parameter.default.__class__.__name__.__eq__('property') == True
# inspect.Parameter.annotation.__class__.__name__.__eq__('property') == True
#
# kind, default, and annotation are all read-only property descriptors on the
# Parameter class; they are defined with @property in Lib/inspect.py.
# New to extra197.
# ---------------------------------------------------------------------------

table inspect_extra197.parameter_descriptor_class_names:
  description: "inspect.Parameter.kind/default/annotation are all 'property' descriptors; read-only properties defined with @property in Lib/inspect.py; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparammethod197

  columns: [id, function, args, expected, description]
  rows:
    - [param_kind_class_name,
       Parameter.kind.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.Parameter.kind.__class__.__name__.__eq__('property') == True — kind is a read-only property descriptor defined with @property in Lib/inspect.py; it returns the parameter kind (POSITIONAL_ONLY etc.); __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra197"]
    - [param_default_class_name,
       Parameter.default.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.Parameter.default.__class__.__name__.__eq__('property') == True — default is a read-only property descriptor defined with @property; it returns the default value or Parameter.empty; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra197"]
    - [param_annotation_class_name,
       Parameter.annotation.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.Parameter.annotation.__class__.__name__.__eq__('property') == True — annotation is a read-only property descriptor defined with @property; it returns the annotation or Parameter.empty; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra197
# ---------------------------------------------------------------------------

invariant inspect_extra197.param_init_qualname:
  description: "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' — class method qualname includes class prefix; new to extra197"
  kind: python_call_eq
  function: Parameter.__init__.__qualname__.__eq__
  args: ["Parameter.__init__"]
  expected: true

invariant inspect_extra197.param_replace_qualname:
  description: "inspect.Parameter.replace.__qualname__ == 'Parameter.replace' — class method qualname includes class prefix; new to extra197"
  kind: python_call_eq
  function: Parameter.replace.__qualname__.__eq__
  args: ["Parameter.replace"]
  expected: true

invariant inspect_extra197.param_repr_qualname:
  description: "inspect.Parameter.__repr__.__qualname__ == 'Parameter.__repr__' — class method qualname includes class prefix; new to extra197"
  kind: python_call_eq
  function: Parameter.__repr__.__qualname__.__eq__
  args: ["Parameter.__repr__"]
  expected: true

invariant inspect_extra197.param_eq_qualname:
  description: "inspect.Parameter.__eq__.__qualname__ == 'Parameter.__eq__' — class method qualname includes class prefix; new to extra197"
  kind: python_call_eq
  function: Parameter.__eq__.__qualname__.__eq__
  args: ["Parameter.__eq__"]
  expected: true

invariant inspect_extra197.param_hash_qualname:
  description: "inspect.Parameter.__hash__.__qualname__ == 'Parameter.__hash__' — class method qualname includes class prefix; new to extra197"
  kind: python_call_eq
  function: Parameter.__hash__.__qualname__.__eq__
  args: ["Parameter.__hash__"]
  expected: true

invariant inspect_extra197.param_kind_property:
  description: "inspect.Parameter.kind.__class__.__name__ == 'property' — read-only property descriptor defined with @property; new to extra197"
  kind: python_call_eq
  function: Parameter.kind.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant inspect_extra197.param_default_property:
  description: "inspect.Parameter.default.__class__.__name__ == 'property' — read-only property descriptor defined with @property; new to extra197"
  kind: python_call_eq
  function: Parameter.default.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant inspect_extra197.param_annotation_property:
  description: "inspect.Parameter.annotation.__class__.__name__ == 'property' — read-only property descriptor defined with @property; new to extra197"
  kind: python_call_eq
  function: Parameter.annotation.__class__.__name__.__eq__
  args: ["property"]
  expected: true
