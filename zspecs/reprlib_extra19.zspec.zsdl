spec: reprlib_extra19
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl through reprlib_extra18.zspec.zsdl."
    - "reprlib_extra17 covers: Repr.__init__/__repr__ qualnames; repr_frozenset/repr_deque/repr_array qualnames; recursive_repr.__qualname__ standalone."
    - "reprlib_extra18 covers: aRepr.__class__.__module__; Repr.__init__.__module__; Repr() maxother/maxlong/maxlevel/maxdict type checks."
    - "No prior spec verifies Repr.repr_str.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr_int.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr_list.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr_tuple.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr_set.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr_dict.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr_instance.__qualname__ as a standalone invariant."
    - "No prior spec verifies Repr.repr.__qualname__ as a standalone invariant."
    - "reprlib.Repr does NOT have a repr_float method — verified at runtime; 'repr_float' is not in dir(reprlib.Repr)."
    - "reprlib.Repr does NOT have a repr_bytes method — verified at runtime; 'repr_bytes' is not in dir(reprlib.Repr)."
    - "The repr_* methods present in reprlib.Repr are: repr_array, repr_deque, repr_dict, repr_frozenset, repr_instance, repr_int, repr_list, repr_set, repr_str, repr_tuple."
    - "All __qualname__ values follow the pattern 'Repr.<method_name>'. Verified at runtime."
    - "reprlib.Repr.repr.__qualname__ == 'Repr.repr' — the core dispatch method. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr.repr_str.__qualname__
#
# reprlib_extra17 covers repr_frozenset/repr_deque/repr_array qualnames.
# No prior spec verifies Repr.repr_str.__qualname__ as a standalone invariant.
# Verified: Repr.repr_str.__qualname__ == 'Repr.repr_str'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_str_qualname:
  description: "reprlib.Repr.repr_str.__qualname__ == 'Repr.repr_str' — string type repr method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_str.__qualname__.__eq__
  args: ["Repr.repr_str"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_int.__qualname__
#
# No prior spec verifies Repr.repr_int.__qualname__ as a standalone invariant.
# Verified: Repr.repr_int.__qualname__ == 'Repr.repr_int'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_int_qualname:
  description: "reprlib.Repr.repr_int.__qualname__ == 'Repr.repr_int' — integer type repr method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_int.__qualname__.__eq__
  args: ["Repr.repr_int"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_list.__qualname__
#
# No prior spec verifies Repr.repr_list.__qualname__ as a standalone invariant.
# Verified: Repr.repr_list.__qualname__ == 'Repr.repr_list'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_list_qualname:
  description: "reprlib.Repr.repr_list.__qualname__ == 'Repr.repr_list' — list type repr method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_list.__qualname__.__eq__
  args: ["Repr.repr_list"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_tuple.__qualname__
#
# No prior spec verifies Repr.repr_tuple.__qualname__ as a standalone invariant.
# Verified: Repr.repr_tuple.__qualname__ == 'Repr.repr_tuple'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_tuple_qualname:
  description: "reprlib.Repr.repr_tuple.__qualname__ == 'Repr.repr_tuple' — tuple type repr method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_tuple.__qualname__.__eq__
  args: ["Repr.repr_tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_set.__qualname__
#
# No prior spec verifies Repr.repr_set.__qualname__ as a standalone invariant.
# Verified: Repr.repr_set.__qualname__ == 'Repr.repr_set'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_set_qualname:
  description: "reprlib.Repr.repr_set.__qualname__ == 'Repr.repr_set' — set type repr method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_set.__qualname__.__eq__
  args: ["Repr.repr_set"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_dict.__qualname__
#
# No prior spec verifies Repr.repr_dict.__qualname__ as a standalone invariant.
# Verified: Repr.repr_dict.__qualname__ == 'Repr.repr_dict'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_dict_qualname:
  description: "reprlib.Repr.repr_dict.__qualname__ == 'Repr.repr_dict' — dict type repr method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_dict.__qualname__.__eq__
  args: ["Repr.repr_dict"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_instance.__qualname__
#
# No prior spec verifies Repr.repr_instance.__qualname__ as a standalone invariant.
# This is the fallback method used for arbitrary object instances.
# Verified: Repr.repr_instance.__qualname__ == 'Repr.repr_instance'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_instance_qualname:
  description: "reprlib.Repr.repr_instance.__qualname__ == 'Repr.repr_instance' — fallback repr method for arbitrary instances"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_instance.__qualname__.__eq__
  args: ["Repr.repr_instance"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr.__qualname__
#
# No prior spec verifies Repr.repr.__qualname__ as a standalone invariant.
# This is the core public dispatch method that routes to repr_<typename> handlers.
# Verified: Repr.repr.__qualname__ == 'Repr.repr'.
# ---------------------------------------------------------------------------

invariant reprlib_extra19.Repr.repr_qualname:
  description: "reprlib.Repr.repr.__qualname__ == 'Repr.repr' — core dispatch method qualname"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr.__qualname__.__eq__
  args: ["Repr.repr"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Repr type-specific repr_* method __qualname__ attributes
#
# Groups repr_str, repr_int, repr_list, repr_tuple, repr_set, repr_dict,
# repr_instance, and the core repr dispatch method in one indexed table.
# reprlib_extra17 covered repr_frozenset/repr_deque/repr_array; no prior
# table covers the remaining type-specific methods or Repr.repr itself.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra19.Repr_repr_method_qualnames:
  description: "reprlib.Repr repr_* method __qualname__ attributes — str, int, list, tuple, set, dict, instance, and core repr"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl19rmq

  columns: [id, function, args, expected]
  rows:
    - [repr_str,      Repr.repr_str.__qualname__.__eq__,      ["Repr.repr_str"],      true]
    - [repr_int,      Repr.repr_int.__qualname__.__eq__,      ["Repr.repr_int"],      true]
    - [repr_list,     Repr.repr_list.__qualname__.__eq__,     ["Repr.repr_list"],     true]
    - [repr_tuple,    Repr.repr_tuple.__qualname__.__eq__,    ["Repr.repr_tuple"],    true]
    - [repr_set,      Repr.repr_set.__qualname__.__eq__,      ["Repr.repr_set"],      true]
    - [repr_dict,     Repr.repr_dict.__qualname__.__eq__,     ["Repr.repr_dict"],     true]
    - [repr_instance, Repr.repr_instance.__qualname__.__eq__, ["Repr.repr_instance"], true]
    - [repr,          Repr.repr.__qualname__.__eq__,          ["Repr.repr"],          true]
