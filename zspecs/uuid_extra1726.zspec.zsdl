spec: uuid_extra1726
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "uuid.UUID defines a full comparison suite via @functools.total_ordering in its own __dict__."
    - "uuid.UUID.__dict__.__contains__('__lt__') is True — UUID defines __lt__ directly for lexicographic ordering."
    - "uuid.UUID.__dict__.__contains__('__le__') is True — added by @functools.total_ordering into the class __dict__."
    - "uuid.UUID.__dict__.__contains__('__gt__') is True — added by @functools.total_ordering into the class __dict__."
    - "uuid.UUID.__dict__.__contains__('__ge__') is True — added by @functools.total_ordering into the class __dict__."
    - "uuid.UUID.__dict__.__contains__('__eq__') is True — UUID defines __eq__ comparing the 128-bit integer value."
    - "uuid.UUID.__dict__.__contains__('__hash__') is True — UUID is immutable and hashable."
    - "uuid.SafeUUID is an IntEnum subclass; comparison methods are inherited from int/IntEnum, not in SafeUUID's own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1726.comparison_protocol:
  description: "uuid types comparison/ordering dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1726

  columns: [id, function, args, expected]
  rows:
    - ["uu1726001", "uuid.UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu1726002", "uuid.UUID.__dict__.__contains__", ["__le__"], true]
    - ["uu1726003", "uuid.UUID.__dict__.__contains__", ["__gt__"], true]
    - ["uu1726004", "uuid.UUID.__dict__.__contains__", ["__ge__"], true]
    - ["uu1726005", "uuid.UUID.__dict__.__contains__", ["__ne__"], false]
    - ["uu1726006", "uuid.SafeUUID.__dict__.__contains__", ["__lt__"], false]
    - ["uu1726007", "uuid.SafeUUID.__dict__.__contains__", ["__le__"], false]
    - ["uu1726008", "uuid.SafeUUID.__dict__.__contains__", ["__gt__"], false]
    - ["uu1726009", "uuid.SafeUUID.__dict__.__contains__", ["__ge__"], false]
    - ["uu1726010", "uuid.SafeUUID.__dict__.__contains__", ["__ne__"], false]

table uuid_extra1726.eq_hash_protocol:
  description: "uuid types __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1726

  columns: [id, function, args, expected]
  rows:
    - ["uu1726011", "uuid.UUID.__dict__.__contains__", ["__eq__"], true]
    - ["uu1726012", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu1726013", "uuid.SafeUUID.__dict__.__contains__", ["__eq__"], false]
    - ["uu1726014", "uuid.SafeUUID.__dict__.__contains__", ["__hash__"], false]
