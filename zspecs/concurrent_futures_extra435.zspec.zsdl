spec: concurrent_futures_extra435
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Future, ThreadPoolExecutor, ProcessPoolExecutor, and exception class identity"
    - "__bases__[0] function fields are double-quoted per ZSDL rules"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra435.class_name:
  description: "concurrent.futures class __name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: CFXN

  columns: [id, function, args, expected]
  rows:
    - [id001, concurrent.futures.Future.__name__.__eq__,               ["Future"],               true]
    - [id002, concurrent.futures.ThreadPoolExecutor.__name__.__eq__,   ["ThreadPoolExecutor"],   true]
    - [id003, concurrent.futures.ProcessPoolExecutor.__name__.__eq__,  ["ProcessPoolExecutor"],  true]
    - [id004, concurrent.futures.CancelledError.__name__.__eq__,       ["CancelledError"],       true]
    - [id005, concurrent.futures.TimeoutError.__name__.__eq__,         ["TimeoutError"],         true]
    - [id006, concurrent.futures.InvalidStateError.__name__.__eq__,    ["InvalidStateError"],    true]

table concurrent_futures_extra435.class_module:
  description: "concurrent.futures class __module__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: CFXM

  columns: [id, function, args, expected]
  rows:
    - [id001, concurrent.futures.Future.__module__.__eq__,              ["concurrent.futures._base"],  true]
    - [id002, concurrent.futures.ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"], true]
    - [id003, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true]

table concurrent_futures_extra435.class_bases:
  description: "concurrent.futures class __bases__[0].__name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: CFXB

  columns: [id, function, args, expected]
  rows:
    - [id001, "concurrent.futures.Future.__bases__[0].__name__.__eq__", ["object"], true]
