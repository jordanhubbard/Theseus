spec: multiprocessing_extra138
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.ProcessError — multiprocessing exception hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing exception classes — AuthenticationError, ProcessError, BufferTooShort, TimeoutError — all defined in multiprocessing.context. AuthenticationError.__name__=='AuthenticationError' (len=19); AuthenticationError.__bases__[0].__name__=='ProcessError'. ProcessError.__name__=='ProcessError' (len=12); ProcessError.__bases__[0].__name__=='Exception'. BufferTooShort.__name__=='BufferTooShort' (len=14); TimeoutError.__name__=='TimeoutError' (len=12). All share __module__=='multiprocessing.context' (len=23). Also multiprocessing.Event and multiprocessing.Semaphore — bound methods of BaseContext with __class__.__name__=='method'. Event.__qualname__=='BaseContext.Event' (len=17); Semaphore.__qualname__=='BaseContext.Semaphore' (len=21). Also BaseContext.__name__=='BaseContext' (len=11). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.AuthenticationError is a subclass of ProcessError (not directly of Exception); ProcessError is the root of the multiprocessing exception hierarchy (subclass of Exception). multiprocessing.TimeoutError.__bases__[0].__name__=='ProcessError' (distinct from Python's built-in TimeoutError which inherits from OSError). multiprocessing.Event is a bound method (type.__name__=='method') with __qualname__=='BaseContext.Event' (len=17); __func__.__code__.co_argcount==1. multiprocessing.Semaphore is similarly a bound method with __func__.__code__.co_argcount==2 ('self','value'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing exception hierarchy — extra138
#
# multiprocessing.ProcessError.__name__              == 'ProcessError'  (len=12)
# multiprocessing.ProcessError.__module__            == 'multiprocessing.context' (len=23)
# multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'
#
# multiprocessing.AuthenticationError.__name__              == 'AuthenticationError' (len=19)
# multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# ---------------------------------------------------------------------------

table multiprocessing_extra138.process_error_identity:
  description: "multiprocessing.ProcessError class identity checks — ProcessError.__name__.__eq__('ProcessError')==True (len=12: 'Process'=7+'Error'=5=12); ProcessError.__qualname__.__eq__('ProcessError')==True (len=12, same as __name__); ProcessError.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); ProcessError.__bases__[0].__name__.__eq__('Exception')==True (root of the multiprocessing exception hierarchy, direct subclass of Exception); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mprocerr138

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    multiprocessing.ProcessError.__name__.__eq__,              ["ProcessError"],             true, "ProcessError.__name__ == 'ProcessError' (len=12); verified with Python 3.14.3"]
    - [name_len,   multiprocessing.ProcessError.__name__.__len__,              [],                          12,   "ProcessError.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [qn_eq,      multiprocessing.ProcessError.__qualname__.__eq__,          ["ProcessError"],             true, "ProcessError.__qualname__ == 'ProcessError' (len=12, same as __name__); verified with Python 3.14.3"]
    - [mod_eq,     multiprocessing.ProcessError.__module__.__eq__,            ["multiprocessing.context"],  true, "ProcessError.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [mod_len,    multiprocessing.ProcessError.__module__.__len__,            [],                          23,   "ProcessError.__module__.__len__() == 23; verified with Python 3.14.3"]
    - ["base_name", "multiprocessing.ProcessError.__bases__[0].__name__.__eq__", ["Exception"],               true, "ProcessError.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]

table multiprocessing_extra138.authentication_error_identity:
  description: "multiprocessing.AuthenticationError class identity checks — AuthenticationError.__name__.__eq__('AuthenticationError')==True (len=19: 'Authentication'=14+'Error'=5=19, longest exception name in this spec); AuthenticationError.__qualname__.__eq__('AuthenticationError')==True (len=19); AuthenticationError.__module__.__eq__('multiprocessing.context')==True (len=23: same module as all other exceptions in this spec); AuthenticationError.__bases__[0].__name__.__eq__('ProcessError')==True (inherits from ProcessError, not directly from Exception); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpauthherr138

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    multiprocessing.AuthenticationError.__name__.__eq__,              ["AuthenticationError"],       true, "AuthenticationError.__name__ == 'AuthenticationError' (len=19); verified with Python 3.14.3"]
    - [name_len,   multiprocessing.AuthenticationError.__name__.__len__,              [],                           19,   "AuthenticationError.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [mod_eq,     multiprocessing.AuthenticationError.__module__.__eq__,            ["multiprocessing.context"],   true, "AuthenticationError.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - ["base_name", "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"],              true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.BufferTooShort and TimeoutError — extra138
#
# multiprocessing.BufferTooShort.__name__              == 'BufferTooShort' (len=14)
# multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# multiprocessing.TimeoutError.__name__                == 'TimeoutError'   (len=12)
# multiprocessing.TimeoutError.__bases__[0].__name__   == 'ProcessError'
# ---------------------------------------------------------------------------

table multiprocessing_extra138.buffer_timeout_error_identity:
  description: "multiprocessing.BufferTooShort and TimeoutError class identity checks — BufferTooShort.__name__.__eq__('BufferTooShort')==True (len=14: 'Buffer'=6+'Too'=3+'Short'=5=14); BufferTooShort.__module__.__eq__('multiprocessing.context')==True (len=23); BufferTooShort.__bases__[0].__name__.__eq__('ProcessError')==True. TimeoutError.__name__.__eq__('TimeoutError')==True (len=12: 'Timeout'=7+'Error'=5=12; same length as ProcessError); TimeoutError.__module__.__eq__('multiprocessing.context')==True (len=23; distinct from builtins.TimeoutError which has __module__=='builtins'); TimeoutError.__bases__[0].__name__.__eq__('ProcessError')==True (multiprocessing.TimeoutError inherits from ProcessError, NOT from OSError like the builtin); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbufto138

  columns: [id, function, args, expected, description]
  rows:
    - [bts_name_eq,    multiprocessing.BufferTooShort.__name__.__eq__,              ["BufferTooShort"],            true, "BufferTooShort.__name__ == 'BufferTooShort' (len=14); verified with Python 3.14.3"]
    - [bts_name_len,   multiprocessing.BufferTooShort.__name__.__len__,              [],                           14,   "BufferTooShort.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [bts_mod_eq,     multiprocessing.BufferTooShort.__module__.__eq__,            ["multiprocessing.context"],   true, "BufferTooShort.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - ["bts_base_name", "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__", ["ProcessError"],              true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [te_name_eq,     multiprocessing.TimeoutError.__name__.__eq__,                ["TimeoutError"],              true, "multiprocessing.TimeoutError.__name__ == 'TimeoutError' (len=12); verified with Python 3.14.3"]
    - [te_name_len,    multiprocessing.TimeoutError.__name__.__len__,                [],                           12,   "multiprocessing.TimeoutError.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [te_mod_eq,      multiprocessing.TimeoutError.__module__.__eq__,              ["multiprocessing.context"],   true, "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - ["te_base_name",  "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__",  ["ProcessError"],              true, "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Event and Semaphore as bound methods — extra138
#
# multiprocessing.Event.__class__.__name__    == 'method' (len=6)
# multiprocessing.Event.__qualname__          == 'BaseContext.Event' (len=17)
# multiprocessing.Semaphore.__class__.__name__== 'method' (len=6)
# multiprocessing.Semaphore.__qualname__      == 'BaseContext.Semaphore' (len=21)
# ---------------------------------------------------------------------------

table multiprocessing_extra138.event_semaphore_bound_methods:
  description: "multiprocessing.Event and Semaphore as bound methods of BaseContext — Event.__class__.__name__.__eq__('method')==True (len=6: like Lock and Queue, Event is a bound method of the default context, not a class); Event.__qualname__.__eq__('BaseContext.Event')==True (len=17: 'BaseContext'=11+'.'=1+'Event'=5=17); Event.__func__.__code__.co_argcount==1 ('self' only, no other positional args). Semaphore.__class__.__name__.__eq__('method')==True (len=6: same type as Event); Semaphore.__qualname__.__eq__('BaseContext.Semaphore')==True (len=21: 'BaseContext'=11+'.'=1+'Semaphore'=9=21, longer than Event len=17); Semaphore.__func__.__code__.co_argcount==2 ('self','value'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpevsem138

  columns: [id, function, args, expected, description]
  rows:
    - [ev_cls_eq,    multiprocessing.Event.__class__.__name__.__eq__,         ["method"],             true, "multiprocessing.Event.__class__.__name__ == 'method' (len=6); verified with Python 3.14.3"]
    - [ev_cls_len,   multiprocessing.Event.__class__.__name__.__len__,         [],                    6,    "multiprocessing.Event.__class__.__name__.__len__() == 6 ('method' is 6 chars); verified with Python 3.14.3"]
    - [ev_qn_eq,     multiprocessing.Event.__qualname__.__eq__,               ["BaseContext.Event"],  true, "multiprocessing.Event.__qualname__ == 'BaseContext.Event' (len=17); verified with Python 3.14.3"]
    - [ev_qn_len,    multiprocessing.Event.__qualname__.__len__,               [],                    17,   "multiprocessing.Event.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [ev_argc,      multiprocessing.Event.__func__.__code__.co_argcount.__eq__, [1],                 true, "multiprocessing.Event.__func__.__code__.co_argcount == 1 ('self' only); verified with Python 3.14.3"]
    - [sem_cls_eq,   multiprocessing.Semaphore.__class__.__name__.__eq__,      ["method"],            true, "multiprocessing.Semaphore.__class__.__name__ == 'method' (len=6); verified with Python 3.14.3"]
    - [sem_qn_eq,    multiprocessing.Semaphore.__qualname__.__eq__,            ["BaseContext.Semaphore"], true, "multiprocessing.Semaphore.__qualname__ == 'BaseContext.Semaphore' (len=21); verified with Python 3.14.3"]
    - [sem_qn_len,   multiprocessing.Semaphore.__qualname__.__len__,            [],                   21,   "multiprocessing.Semaphore.__qualname__.__len__() == 21; verified with Python 3.14.3"]
    - [sem_argc,     multiprocessing.Semaphore.__func__.__code__.co_argcount.__eq__, [2],             true, "multiprocessing.Semaphore.__func__.__code__.co_argcount == 2 ('self','value'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra138
# ---------------------------------------------------------------------------

invariant multiprocessing_extra138.process_error_name_len_12:
  description: "multiprocessing.ProcessError.__name__.__len__() == 12 — ProcessError.__name__ is 'ProcessError' (12 chars: 'Process'=7+'Error'=5=12); ProcessError.__module__=='multiprocessing.context' (len=23); ProcessError.__bases__[0].__name__=='Exception' (root of the multiprocessing exception hierarchy); name len (12) equals multiprocessing.TimeoutError name len (12) and is less than BufferTooShort len (14) and AuthenticationError len (19); NEW in extra138: first standalone ProcessError name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.ProcessError.__name__.__len__
  args: []
  expected: 12

invariant multiprocessing_extra138.authentication_error_name_len_19:
  description: "multiprocessing.AuthenticationError.__name__.__len__() == 19 — AuthenticationError.__name__ is 'AuthenticationError' (19 chars: 'Authentication'=14+'Error'=5=19); this is the longest exception name in this spec (compare: ProcessError=12, TimeoutError=12, BufferTooShort=14); AuthenticationError.__bases__[0].__name__=='ProcessError' (not directly Exception); NEW in extra138: first standalone AuthenticationError name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__name__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra138.context_module_len_23:
  description: "multiprocessing.ProcessError.__module__.__len__() == 23 — ProcessError.__module__ is 'multiprocessing.context' (23 chars: 'multiprocessing'=15+'.'=1+'context'=7=23); all four exception classes in this spec (ProcessError, AuthenticationError, BufferTooShort, TimeoutError) share this module string; module len (23) is 3 less than connection module len (26, from extra137); NEW in extra138: first standalone multiprocessing.context module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.ProcessError.__module__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra138.event_qualname_len_17:
  description: "multiprocessing.Event.__qualname__.__len__() == 17 — multiprocessing.Event.__qualname__ is 'BaseContext.Event' (17 chars: 'BaseContext'=11+'.'=1+'Event'=5=17); Event.__class__.__name__=='method' (len=6); Event.__func__.__code__.co_argcount==1; qualname len (17) is 4 less than Semaphore qualname len (21); NEW in extra138: first standalone Event qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Event.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra138.semaphore_qualname_len_21:
  description: "multiprocessing.Semaphore.__qualname__.__len__() == 21 — multiprocessing.Semaphore.__qualname__ is 'BaseContext.Semaphore' (21 chars: 'BaseContext'=11+'.'=1+'Semaphore'=9=21); Semaphore.__class__.__name__=='method' (len=6); Semaphore.__func__.__code__.co_argcount==2 ('self','value'); qualname len (21) is 4 more than Event qualname len (17); NEW in extra138: first standalone Semaphore qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Semaphore.__qualname__.__len__
  args: []
  expected: 21
