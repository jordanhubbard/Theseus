spec: gzip_extra3
version: ">=3.9"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends prior gzip specs."
    - "Focus: class names and compress/decompress function behavior."
    - "gzip.GzipFile.__name__ == 'GzipFile'."
    - "gzip.BadGzipFile.__name__ == 'BadGzipFile'."
    - "gzip.compress.__name__ == 'compress'."
    - "gzip.decompress.__name__ == 'decompress'."
    - "gzip.open.__name__ == 'open'."
    - "gzip.compress(b'hello').__class__.__name__ == 'bytes'."
    - "gzip.decompress(gzip.compress(b'hello')) == b'hello'."
    - "gzip.GzipFile.__module__ == 'gzip'."
    - "gzip.BadGzipFile.__bases__[0].__name__ == 'OSError'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table gzip_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__name__.__eq__,    ["GzipFile"],    true]
    - [BadGzipFile, BadGzipFile.__name__.__eq__, ["BadGzipFile"], true]

table gzip_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__name__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__name__.__eq__, ["decompress"], true]
    - [open,       open.__name__.__eq__,       ["open"],       true]

invariant gzip_extra3.GzipFile.module:
  description: "gzip.GzipFile.__module__ == 'gzip'"
  category: module
  kind: python_call_eq
  function: GzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

invariant gzip_extra3.BadGzipFile.base:
  description: "gzip.BadGzipFile.__bases__[0].__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: BadGzipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant gzip_extra3.compress.returns_bytes:
  description: "gzip.compress(b'hello').__class__.__name__ == 'bytes'"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!hex 68656c6c6f]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant gzip_extra3.compress.header_magic:
  description: "gzip.compress(b'hello')[:2] == b'\\x1f\\x8b' (gzip magic bytes)"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!hex 68656c6c6f]
  method: __getitem__
  method_args: [0]
  expected: 31

invariant gzip_extra3.compress.module:
  description: "gzip.compress.__module__ == 'gzip'"
  category: module
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["gzip"]
  expected: true

invariant gzip_extra3.decompress.returns_bytes:
  description: "gzip.decompress.__module__ == 'gzip'"
  category: decompress
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["gzip"]
  expected: true

invariant gzip_extra3.open.module:
  description: "gzip.open.__module__ == 'gzip'"
  category: module
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["gzip"]
  expected: true
