spec: uuid_extra50
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra49.zspec.zsdl — covers UUID/uuid4/uuid1 __doc__.__class__.__qualname__.__eq__('str') (table); uuid.__dict__.__contains__ for UUID/uuid4/NAMESPACE_DNS/getnode/uuid1 (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra44.zspec.zsdl — covers uuid.__name__.__eq__('uuid') and uuid.__name__.__len__()==4."
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low .fget.__qualname__.__eq__; getnode.__module__.__eq__('uuid'); uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra25.zspec.zsdl — covers uuid.__spec__.__name__.__len__()==4 and uuid.__loader__.__class__.__name__.__len__()==16."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra49; it does NOT duplicate invariants present in those files."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "uuid is a pure-Python module (Lib/uuid.py). Its loader is SourceFileLoader. It has a __file__ path and a __cached__ .pyc path. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: uuid_extra25 checks uuid.__loader__.__class__.__name__.__len__()==16 (length axis). No prior uuid spec checks uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') (the equality axis). The two axes are independent: __len__ catches renames to a same-length name while __eq__ checks exact identity. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader'. uuid.py is loaded by importlib.machinery.SourceFileLoader. uuid_extra25 covers __loader__.__class__.__name__.__len__()==16 but NOT __eq__('SourceFileLoader'). No prior uuid spec checks __loader__.__class__.__name__.__eq__('SourceFileLoader'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks uuid.__spec__.__class__.__name__.__eq__('ModuleSpec'). uuid_extra25 covers uuid.__spec__.__name__.__len__()==4 (the name inside the ModuleSpec) but not the type of the __spec__ object itself. The ModuleSpec class is the standard container for module import metadata. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec'. The uuid module's __spec__ attribute is an importlib.machinery.ModuleSpec instance. uuid_extra25 probes __spec__.__name__.__len__ but NOT __spec__.__class__.__name__.__eq__('ModuleSpec'). No prior uuid spec checks __spec__.__class__.__name__.__eq__('ModuleSpec'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks uuid.__file__.__class__.__name__.__eq__('str'). uuid.py is loaded from a Python source file; its __file__ attribute is a str path. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__file__.__class__.__name__ == 'str'. uuid is loaded from a .py source file; its __file__ attribute is a Python str path. No prior uuid spec checks uuid.__file__.__class__.__name__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior uuid spec checks uuid.__cached__.__class__.__name__.__eq__('str'). uuid.py is compiled to a .pyc bytecode cache; its __cached__ attribute is a str path to that .pyc file. Distinct from __file__ (source) vs __cached__ (bytecode). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__cached__.__class__.__name__ == 'str'. uuid.py has a compiled bytecode cache; its __cached__ attribute is a Python str path to the .pyc file. No prior uuid spec checks uuid.__cached__.__class__.__name__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 5: uuid_extra48 covers UUID.__eq__.__class__.__name__.__eq__('function') (the class name of the __eq__ method object). No prior uuid spec checks UUID.__eq__.__qualname__.__eq__('UUID.__eq__') — the qualname of UUID's __eq__ method. UUID.__eq__ is defined as a regular Python function in Lib/uuid.py; its __qualname__ is 'UUID.__eq__'. uuid_extra17 covers __qualname__.__eq__ for __lt__/__gt__/__le__/__ge__ but NOT for __eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__'. UUID.__eq__ is a Python function defined in Lib/uuid.py; its __qualname__ is the class-qualified name 'UUID.__eq__'. uuid_extra48 covers UUID.__eq__.__class__.__name__.__eq__('function') (the object type) and uuid_extra17 covers __qualname__.__eq__ for comparison methods but NOT for __eq__. No prior uuid spec checks UUID.__eq__.__qualname__.__eq__('UUID.__eq__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid loader identity + module spec/file/cached class name checks
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ class name checks.
#
# uuid is a pure-Python module (Lib/uuid.py) loaded by SourceFileLoader.
# uuid_extra25 covers __len__ axes; this spec covers __eq__ axes for loader
# class name, spec class name, file class name, and cached class name.
# All four are novel equality anchors for the uuid module.
# ---------------------------------------------------------------------------

table uuid_extra50.loader_spec_file_cached:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') — loader/spec/file/cached class identity for the uuid pure-Python module; uuid_extra25 covers __loader__.__class__.__name__.__len__()==16 and __spec__.__name__.__len__()==4 (length axes) but no prior uuid spec checks these via __eq__; all four are novel equality anchors"
  kind: python_call_eq
  category: module_structure
  id_prefix: uuidload50

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq,  __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [spec_class_name_eq,    __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [file_class_name_eq,    __file__.__class__.__name__.__eq__,    ["str"],              true]
    - [cached_class_name_eq,  __cached__.__class__.__name__.__eq__,  ["str"],              true]

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__')
#
# uuid_extra48 covers UUID.__eq__.__class__.__name__.__eq__('function') — the
# type axis for the __eq__ method object. uuid_extra17 covers __qualname__.__eq__
# for __lt__, __gt__, __le__, __ge__ — but NOT for __eq__. The qualname of a
# method is distinct from its class name: qualname encodes the class scope
# ('UUID.__eq__') while class name identifies the object type ('function').
# UUID.__eq__.__qualname__ == 'UUID.__eq__' confirms that the method is defined
# directly on the UUID class (not inherited or renamed).
# ---------------------------------------------------------------------------

table uuid_extra50.UUID_eq_qualname:
  description: "uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__') — qualname of UUID's __eq__ method confirms class-scoped definition; uuid_extra48 covers UUID.__eq__.__class__.__name__.__eq__('function') (type axis) and uuid_extra17 covers __qualname__.__eq__ for __lt__/__gt__/__le__/__ge__ but NOT for __eq__; no prior uuid spec checks UUID.__eq__.__qualname__.__eq__('UUID.__eq__')"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidload50

  columns: [id, function, args, expected]
  rows:
    - [UUID_eq_qualname_eq, "UUID.__eq__.__qualname__.__eq__", ["UUID.__eq__"], true]

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# uuid_extra25 covers __loader__.__class__.__name__.__len__()==16 (length axis).
# No prior uuid spec checks the equality axis for the loader class name.
# SourceFileLoader identity is the primary confirmation that uuid.py is
# loaded as a pure-Python source file, not as a C extension or built-in.
# ---------------------------------------------------------------------------

invariant uuid_extra50.loader_class_name_sourcefileloader:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — uuid.py is a pure-Python module loaded by SourceFileLoader; uuid_extra25 covers __loader__.__class__.__name__.__len__()==16 (length axis) but no prior uuid spec checks __eq__('SourceFileLoader'); primary loader identity anchor for uuid"
  category: module_structure
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
