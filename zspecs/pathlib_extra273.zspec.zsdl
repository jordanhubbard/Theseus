spec: pathlib_extra273
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "All pathlib.Path methods (open, read_text, write_text, read_bytes, write_bytes, exists, is_file, is_dir, mkdir, unlink) are plain Python functions."
    - "Each method's __class__.__name__ == 'function'."
    - "All qualnames are 'Path.<method_name>' with no inheritance prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Path method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra273.path_method_names:
  description: "pathlib.Path method __name__ for open, read_text, write_text, read_bytes, write_bytes, exists, is_file, is_dir, mkdir, unlink"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,        Path.open.__name__.__eq__,        ["open"],        true, "pathlib.Path.open.__name__ == 'open'"]
    - [read_text_name,   Path.read_text.__name__.__eq__,   ["read_text"],   true, "pathlib.Path.read_text.__name__ == 'read_text'"]
    - [write_text_name,  Path.write_text.__name__.__eq__,  ["write_text"],  true, "pathlib.Path.write_text.__name__ == 'write_text'"]
    - [read_bytes_name,  Path.read_bytes.__name__.__eq__,  ["read_bytes"],  true, "pathlib.Path.read_bytes.__name__ == 'read_bytes'"]
    - [write_bytes_name, Path.write_bytes.__name__.__eq__, ["write_bytes"], true, "pathlib.Path.write_bytes.__name__ == 'write_bytes'"]
    - [exists_name,      Path.exists.__name__.__eq__,      ["exists"],      true, "pathlib.Path.exists.__name__ == 'exists'"]
    - [is_file_name,     Path.is_file.__name__.__eq__,     ["is_file"],     true, "pathlib.Path.is_file.__name__ == 'is_file'"]
    - [is_dir_name,      Path.is_dir.__name__.__eq__,      ["is_dir"],      true, "pathlib.Path.is_dir.__name__ == 'is_dir'"]
    - [mkdir_name,       Path.mkdir.__name__.__eq__,       ["mkdir"],       true, "pathlib.Path.mkdir.__name__ == 'mkdir'"]
    - [unlink_name,      Path.unlink.__name__.__eq__,      ["unlink"],      true, "pathlib.Path.unlink.__name__ == 'unlink'"]

# ---------------------------------------------------------------------------
# Table: Path method __class__.__name__ (all 'function')
# ---------------------------------------------------------------------------

table pathlib_extra273.path_method_classes:
  description: "pathlib.Path method __class__.__name__ for open, read_text, write_text, read_bytes, write_bytes, exists, is_file, is_dir, mkdir, unlink"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [open_class,        Path.open.__class__.__name__.__eq__,        ["function"], true, "pathlib.Path.open.__class__.__name__ == 'function'"]
    - [read_text_class,   Path.read_text.__class__.__name__.__eq__,   ["function"], true, "pathlib.Path.read_text.__class__.__name__ == 'function'"]
    - [write_text_class,  Path.write_text.__class__.__name__.__eq__,  ["function"], true, "pathlib.Path.write_text.__class__.__name__ == 'function'"]
    - [read_bytes_class,  Path.read_bytes.__class__.__name__.__eq__,  ["function"], true, "pathlib.Path.read_bytes.__class__.__name__ == 'function'"]
    - [write_bytes_class, Path.write_bytes.__class__.__name__.__eq__, ["function"], true, "pathlib.Path.write_bytes.__class__.__name__ == 'function'"]
    - [exists_class,      Path.exists.__class__.__name__.__eq__,      ["function"], true, "pathlib.Path.exists.__class__.__name__ == 'function'"]
    - [is_file_class,     Path.is_file.__class__.__name__.__eq__,     ["function"], true, "pathlib.Path.is_file.__class__.__name__ == 'function'"]
    - [is_dir_class,      Path.is_dir.__class__.__name__.__eq__,      ["function"], true, "pathlib.Path.is_dir.__class__.__name__ == 'function'"]
    - [mkdir_class,       Path.mkdir.__class__.__name__.__eq__,       ["function"], true, "pathlib.Path.mkdir.__class__.__name__ == 'function'"]
    - [unlink_class,      Path.unlink.__class__.__name__.__eq__,      ["function"], true, "pathlib.Path.unlink.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Table: Path method __qualname__ identity
# ---------------------------------------------------------------------------

table pathlib_extra273.path_method_qualnames:
  description: "pathlib.Path method __qualname__ for open, read_text, write_text, exists, mkdir, unlink"
  kind: python_call_eq
  category: identity
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [open_qualname,        Path.open.__qualname__.__eq__,        ["Path.open"],        true, "pathlib.Path.open.__qualname__ == 'Path.open'"]
    - [read_text_qualname,   Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true, "pathlib.Path.read_text.__qualname__ == 'Path.read_text'"]
    - [write_text_qualname,  Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true, "pathlib.Path.write_text.__qualname__ == 'Path.write_text'"]
    - [exists_qualname,      Path.exists.__qualname__.__eq__,      ["Path.exists"],      true, "pathlib.Path.exists.__qualname__ == 'Path.exists'"]
    - [mkdir_qualname,       Path.mkdir.__qualname__.__eq__,       ["Path.mkdir"],       true, "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir'"]
    - [unlink_qualname,      Path.unlink.__qualname__.__eq__,      ["Path.unlink"],      true, "pathlib.Path.unlink.__qualname__ == 'Path.unlink'"]

# ---------------------------------------------------------------------------
# Standalone invariants: cross-checks for key Path methods
# ---------------------------------------------------------------------------

invariant pathlib_extra273.Path.open.is_function:
  description: "pathlib.Path.open is a plain Python function, not a C-extension descriptor"
  category: identity
  kind: python_call_eq
  function: Path.open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra273.Path.exists.is_function:
  description: "pathlib.Path.exists is a plain Python function"
  category: identity
  kind: python_call_eq
  function: Path.exists.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra273.Path.read_text.qualname:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text'"
  category: identity
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra273.Path.write_bytes.name:
  description: "pathlib.Path.write_bytes.__name__ == 'write_bytes'"
  category: identity
  kind: python_call_eq
  function: Path.write_bytes.__name__.__eq__
  args: ["write_bytes"]
  expected: true
