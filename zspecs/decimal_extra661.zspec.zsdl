spec: decimal_extra661
backend: python_module(decimal)
description: "decimal.Context additional method qualname identity checks"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ values for Context methods and module-level functions in the decimal module"]
  created_at: "2026-04-12T00:00:00Z"

table decimal_extra661.context_method_qualnames:
  description: "decimal.Context method __qualname__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: dc661cq
  columns: [id, function, args, expected]
  rows:
    - [dc661cq001, "decimal.Context.normalize.__qualname__.__eq__", ["Context.normalize"], true]
    - [dc661cq002, "decimal.Context.to_eng_string.__qualname__.__eq__", ["Context.to_eng_string"], true]
    - [dc661cq003, "decimal.Context.is_nan.__qualname__.__eq__", ["Context.is_nan"], true]
    - [dc661cq004, "decimal.Context.is_infinite.__qualname__.__eq__", ["Context.is_infinite"], true]
    - [dc661cq005, "decimal.Context.is_zero.__qualname__.__eq__", ["Context.is_zero"], true]
    - [dc661cq006, "decimal.Context.is_signed.__qualname__.__eq__", ["Context.is_signed"], true]
    - [dc661cq007, "decimal.Context.is_normal.__qualname__.__eq__", ["Context.is_normal"], true]
    - [dc661cq008, "decimal.Context.is_subnormal.__qualname__.__eq__", ["Context.is_subnormal"], true]
    - [dc661cq009, "decimal.Context.is_qnan.__qualname__.__eq__", ["Context.is_qnan"], true]
    - [dc661cq010, "decimal.Context.is_snan.__qualname__.__eq__", ["Context.is_snan"], true]
    - [dc661cq011, "decimal.Context.is_canonical.__qualname__.__eq__", ["Context.is_canonical"], true]
    - [dc661cq012, "decimal.Context.is_finite.__qualname__.__eq__", ["Context.is_finite"], true]

table decimal_extra661.module_function_qualnames:
  description: "decimal module-level function __qualname__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: dc661mq
  columns: [id, function, args, expected]
  rows:
    - [dc661mq001, "decimal.getcontext.__qualname__.__eq__", ["getcontext"], true]
    - [dc661mq002, "decimal.setcontext.__qualname__.__eq__", ["setcontext"], true]
