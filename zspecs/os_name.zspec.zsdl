spec: os_name
version: ">=7.0.0"
backend: node(os-name)

docs: https://github.com/sindresorhus/os-name#readme

provenance:
  derived_from:
    - "os-name README — https://github.com/sindresorhus/os-name#readme"
    - "Test vectors verified with os-name via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "os-name source"
  notes:
    - "Get human-readable OS name — 'macOS Tahoe', 'Windows 11', 'Ubuntu 24.04'."
    - "Install: npm install os-name"
    - "v7 ESM only; default export is the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; returns a string for any platform."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant os_name.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant os_name.default_arity:
  description: "osName(platform?, release?) — declared length is 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 2

invariant os_name.returns_string:
  description: "osName() returns a String"
  category: usage
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant os_name.returns_nonempty:
  description: "osName() returns a non-empty result (length > 0)"
  category: usage
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: []
  chain:
    - {get: length}
    - {method: toString, args: []}
    - {method: includes, args: ["0"]}
  expected: false

invariant os_name.linux_explicit:
  description: "osName('linux', '5.15.0') yields a Linux name"
  category: usage
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["linux", "5.15.0"]
  chain:
    - {method: toLowerCase, args: []}
    - {method: includes, args: ["linux"]}
  expected: true
