spec: theseus_atexit_cr
version: ">=3.9"
backend: python_cleanroom(theseus_atexit_cr)
blocks: atexit

docs: https://docs.python.org/3/library/atexit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/atexit.html"
  notes:
    - "Clean-room exit handler registry. Do NOT import atexit."
    - "register(fn, *args, **kwargs): register fn to be called at interpreter exit."
    - "unregister(fn): remove fn from the exit handler list."
    - "_run_exitfuncs(): call all registered handlers in LIFO order (for testing)."
    - "atexit_register_called(): register handler; _run_exitfuncs(); handler was called."
    - "atexit_unregister(): register then unregister; not called after _run_exitfuncs."
    - "atexit_lifo_order(): two handlers run in reverse registration order."
    - "Export: register, unregister, _run_exitfuncs."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_atexit_cr.register_called:
  description: "registered handler is called by _run_exitfuncs"
  category: register
  kind: python_call_eq
  function: atexit_register_called
  args: []
  expected: true

invariant theseus_atexit_cr.unregister:
  description: "unregistered handler is not called"
  category: unregister
  kind: python_call_eq
  function: atexit_unregister
  args: []
  expected: false

invariant theseus_atexit_cr.lifo_order:
  description: "handlers called in LIFO order"
  category: order
  kind: python_call_eq
  function: atexit_lifo_order
  args: []
  expected: [2, 1]
