spec: concurrent_futures_extra2791
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra.zspec.zsdl — covers class names, module checks, function names, constant type checks"
    - "concurrent_futures_extra2.zspec.zsdl — covers module checks, constant values, method names"
    - "concurrent_futures_extra2776.zspec.zsdl — covers __isub__, __imul__, __itruediv__ dict-presence checks"
  notes:
    - "Wave 633 theme: __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise operators)."
    - "None of the concurrent.futures public classes define __iand__, __ior__, or __ixor__ in their __dict__."
    - "Future is a pure-Python result container; ThreadPoolExecutor and ProcessPoolExecutor are executor pool classes."
    - "'__iand__' in Future.__dict__ == False; likewise for __ior__ and __ixor__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — __iand__/__ior__/__ixor__
# dict-presence checks
#
# Future is a pure-Python result container (Lib/concurrent/futures/_base.py).
# It wraps the result of an async computation. It does not define in-place
# bitwise operator dunders: __iand__, __ior__, or __ixor__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2791.future_operator_dict:
  description: "concurrent.futures.Future __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2791f

  columns: [id, function, args, expected]
  rows:
    - ["cf2791f_iand",  Future.__dict__.__contains__, ["__iand__"],  false]
    - ["cf2791f_ior",   Future.__dict__.__contains__, ["__ior__"],   false]
    - ["cf2791f_ixor",  Future.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor — __iand__/__ior__/__ixor__
# dict-presence checks
#
# ThreadPoolExecutor manages a pool of threads and dispatches callables to them.
# It does not implement in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2791.threadpoolexecutor_operator_dict:
  description: "concurrent.futures.ThreadPoolExecutor __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2791tpe

  columns: [id, function, args, expected]
  rows:
    - ["cf2791tpe_iand",  ThreadPoolExecutor.__dict__.__contains__, ["__iand__"],  false]
    - ["cf2791tpe_ior",   ThreadPoolExecutor.__dict__.__contains__, ["__ior__"],   false]
    - ["cf2791tpe_ixor",  ThreadPoolExecutor.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor — __iand__/__ior__/__ixor__
# dict-presence checks
#
# ProcessPoolExecutor manages a pool of worker processes. Like ThreadPoolExecutor,
# it is a task dispatching class and does not define in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2791.processpoolexecutor_operator_dict:
  description: "concurrent.futures.ProcessPoolExecutor __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2791ppe

  columns: [id, function, args, expected]
  rows:
    - ["cf2791ppe_iand",  ProcessPoolExecutor.__dict__.__contains__, ["__iand__"],  false]
    - ["cf2791ppe_ior",   ProcessPoolExecutor.__dict__.__contains__, ["__ior__"],   false]
    - ["cf2791ppe_ixor",  ProcessPoolExecutor.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — all concurrent.futures types, all three in-place bitwise operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Future, ThreadPoolExecutor, and ProcessPoolExecutor
# do not define &=, |=, or ^= operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2791.all_types_iand_ior_ixor_matrix:
  description: "Full 3×3 dict-presence matrix for concurrent.futures types vs __iand__/__ior__/__ixor__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2791mx

  columns: [id, function, args, expected]
  rows:
    - ["cf2791mx_f_ia",   Future.__dict__.__contains__,              ["__iand__"],  false]
    - ["cf2791mx_f_io",   Future.__dict__.__contains__,              ["__ior__"],   false]
    - ["cf2791mx_f_ix",   Future.__dict__.__contains__,              ["__ixor__"],  false]
    - ["cf2791mx_tpe_ia", ThreadPoolExecutor.__dict__.__contains__,  ["__iand__"],  false]
    - ["cf2791mx_tpe_io", ThreadPoolExecutor.__dict__.__contains__,  ["__ior__"],   false]
    - ["cf2791mx_tpe_ix", ThreadPoolExecutor.__dict__.__contains__,  ["__ixor__"],  false]
    - ["cf2791mx_ppe_ia", ProcessPoolExecutor.__dict__.__contains__, ["__iand__"],  false]
    - ["cf2791mx_ppe_io", ProcessPoolExecutor.__dict__.__contains__, ["__ior__"],   false]
    - ["cf2791mx_ppe_ix", ProcessPoolExecutor.__dict__.__contains__, ["__ixor__"],  false]
