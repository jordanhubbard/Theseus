spec: fractions_extra2
version: ">=3.2"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "Python 3 fractions documentation — https://docs.python.org/3/library/fractions.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
    - "fractions.zspec.zsdl — covers constructor, arithmetic, comparison, and limit_denominator"
    - "fractions_extra.zspec.zsdl — covers Fraction.__name__, __module__, __bases__, (3,6) reduction, from_string/float class, addition"
  notes:
    - "This spec extends fractions_extra.zspec.zsdl with coverage not already present there."
    - "Fraction(1, 3).__class__.__name__ == 'Fraction' — verifies instance class identity."
    - "Fraction(0).numerator == 0 — zero is a valid Fraction; numerator is 0."
    - "Fraction(0).denominator == 1 — the denominator of zero is always 1 (canonical form)."
    - "Fraction(3, 6) auto-reduces to 1/2; __str__ returns '1/2' — complements numerator/denominator checks."
    - "Fraction.__name__ and __module__ verified again here for completeness as additional coverage."
    - "All expected values verified by running Python 3.12 fractions module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — __name__ and __module__
# ---------------------------------------------------------------------------

invariant fractions_extra2.Fraction.class_name:
  description: "Fraction.__name__ == 'Fraction'"
  category: class_metadata
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra2.Fraction.module:
  description: "Fraction.__module__ == 'fractions'"
  category: class_metadata
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — Fraction.__bases__[0].__name__ == 'Rational'
# ---------------------------------------------------------------------------

invariant fractions_extra2.Fraction.base_is_Rational:
  description: "Fraction.__bases__[0].__name__ == 'Rational' — inherits from numbers.Rational"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Rational"

# ---------------------------------------------------------------------------
# Instance class identity — Fraction(1, 3).__class__.__name__ == 'Fraction'
# ---------------------------------------------------------------------------

invariant fractions_extra2.Fraction.instance_class_name:
  description: "Fraction(1, 3).__class__.__name__ == 'Fraction'"
  category: class_metadata
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "Fraction"

# ---------------------------------------------------------------------------
# Auto-reduction: Fraction(3, 6) reduces to 1/2
# Numerator and denominator checks plus __str__ verification
# ---------------------------------------------------------------------------

invariant fractions_extra2.Fraction.reduced_numerator:
  description: "Fraction(3, 6).numerator == 1 — 3/6 auto-reduces to 1/2"
  category: auto_reduction
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: numerator
  expected: 1

invariant fractions_extra2.Fraction.reduced_denominator:
  description: "Fraction(3, 6).denominator == 2 — 3/6 auto-reduces to 1/2"
  category: auto_reduction
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Zero: Fraction(0).numerator and denominator
# ---------------------------------------------------------------------------

invariant fractions_extra2.Fraction.zero_numerator:
  description: "Fraction(0).numerator == 0"
  category: zero
  kind: python_call_eq
  function: Fraction
  args: [0]
  method: numerator
  expected: 0

invariant fractions_extra2.Fraction.zero_denominator:
  description: "Fraction(0).denominator == 1 — canonical form for zero"
  category: zero
  kind: python_call_eq
  function: Fraction
  args: [0]
  method: denominator
  expected: 1
