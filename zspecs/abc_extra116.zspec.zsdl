docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra115.zspec.zsdl."
    - "This spec covers: wave 260 theme — abc.abstractmethod.__code__.co_consts and co_freevars/co_cellvars element-level checks not previously covered. Prior specs covered: extra61 covered abstractmethod/__code__.co_consts.__class__.__name__=='tuple' (type identity only); extra63 covered ABCMeta.__subclasscheck__/__code__.co_consts.__class__.__name__=='tuple'; extra115 covered ABCMeta.__new__ co_varnames elements and abstractclassmethod/abstractstaticmethod __init__ co_varnames[1]. NOT previously covered: abstractmethod.__code__.co_consts.__len__()==2; abstractmethod.__code__.co_consts[1].__eq__(True); abstractmethod.__code__.co_freevars.__len__()==0; abstractmethod.__code__.co_cellvars.__len__()==0; ABCMeta.__instancecheck__.__code__.co_consts.__len__()==1; ABCMeta.__subclasscheck__.__code__.co_consts.__len__()==1; update_abstractmethods.__code__.co_freevars.__len__()==0. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__code__.co_consts == (docstring, True): len=2. co_consts[0] is the docstring (type=str). co_consts[1] is True (type=bool). co_freevars == (): len=0. co_cellvars == (): len=0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__.__code__.co_consts has len=1. abc.ABCMeta.__subclasscheck__.__code__.co_consts has len=1. abc.update_abstractmethods.__code__.co_freevars.__len__()==0. abc.update_abstractmethods.__code__.co_cellvars.__len__()==0. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Note: abc.get_cache_token is a builtin_function_or_method and has no __code__ attribute (verified: AttributeError). All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod co_consts element checks — extra116
#
# Wave 260 theme: abstractmethod co_consts length and element[1] value.
#
# abstractmethod.__code__.co_consts[0]  == docstring (str, not checked directly)
# abstractmethod.__code__.co_consts[1]  == True
# abstractmethod.__code__.co_consts.__len__() == 2
# abstractmethod.__code__.co_freevars.__len__() == 0
# abstractmethod.__code__.co_cellvars.__len__() == 0
# ---------------------------------------------------------------------------

table abc_extra116.abc_abstractmethod_co_consts:
  description: "abc.abstractmethod co_consts element checks and co_freevars/co_cellvars length checks in abcconsts116 namespace — wave 260 theme: abstractmethod co_consts content and closure attribute sizes; abstractmethod.__code__.co_consts.__len__()==2 (first coverage of co_consts length for abstractmethod; co_consts[0] is the docstring (str), co_consts[1] is True (bool); only 2 constants needed: the docstring loaded at function definition time and the boolean True which is stored into funcobj.__isabstractmethod__); abstractmethod.__code__.co_consts[1].__eq__(True)==True (co_consts[1] is the literal True that abstractmethod stores into the decorated function's __isabstractmethod__ attribute; abstractmethod.__code__.co_consts[1] is True because abstractmethod sets funcobj.__isabstractmethod__ = True and uses True as a constant in the bytecode); abstractmethod.__code__.co_freevars.__len__()==0 (co_freevars is the tuple of names used by nested scopes (closures); abstractmethod has no closure variables — it is a standalone function not defined inside another function; len=0 means abstractmethod does not capture any variables from an enclosing scope); abstractmethod.__code__.co_cellvars.__len__()==0 (co_cellvars is the tuple of names that are referenced by nested functions; abstractmethod itself has no nested functions, so no cell variables; len=0 is consistent with co_freevars=0); update_abstractmethods.__code__.co_freevars.__len__()==0 (same closure behavior: update_abstractmethods is also a standalone function with no closures); update_abstractmethods.__code__.co_cellvars.__len__()==0 (no nested function references); all len==0 freevars/cellvars confirm these are flat functions with no closure state; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcconsts116

  columns: [id, function, args, expected, description]
  rows:
    - [am_consts_len,   abstractmethod.__code__.co_consts.__len__,                [],     2,    "abstractmethod co_consts.__len__() == 2 (docstring + True; first length coverage); verified with Python 3.14.3"]
    - [am_consts1_eq,   "abstractmethod.__code__.co_consts[1].__eq__",            [true], true, "abstractmethod co_consts[1] == True (bool True stored into funcobj.__isabstractmethod__); verified with Python 3.14.3"]
    - [am_freevars_len, abstractmethod.__code__.co_freevars.__len__,              [],     0,    "abstractmethod co_freevars.__len__() == 0 (no closure variables; standalone function); verified with Python 3.14.3"]
    - [am_cellvars_len, abstractmethod.__code__.co_cellvars.__len__,              [],     0,    "abstractmethod co_cellvars.__len__() == 0 (no nested function references); verified with Python 3.14.3"]
    - [uam_freevars_len, update_abstractmethods.__code__.co_freevars.__len__,     [],     0,    "update_abstractmethods co_freevars.__len__() == 0 (no closure; standalone function); verified with Python 3.14.3"]
    - [uam_cellvars_len, update_abstractmethods.__code__.co_cellvars.__len__,     [],     0,    "update_abstractmethods co_cellvars.__len__() == 0 (no nested function references); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta method co_consts lengths — extra116
#
# Wave 260 theme: ABCMeta.__instancecheck__ and __subclasscheck__ co_consts lengths.
#
# ABCMeta.__instancecheck__.__code__.co_consts.__len__()  == 1
# ABCMeta.__subclasscheck__.__code__.co_consts.__len__()  == 1
# Both methods have a single co_consts entry (the docstring).
# ---------------------------------------------------------------------------

table abc_extra116.abc_abcmeta_methods_co_consts_len:
  description: "abc.ABCMeta method co_consts length checks in abcconsts116a namespace — wave 260 theme: ABCMeta.__instancecheck__ and __subclasscheck__ co_consts lengths; ABCMeta.__instancecheck__.__code__.co_consts.__len__()==1 (co_consts has only 1 element: the docstring; __instancecheck__ is a thin wrapper that delegates to the C-level ABC registry; it uses no literal constants in its bytecode beyond the docstring because the logic is implemented in C via _abc module); ABCMeta.__subclasscheck__.__code__.co_consts.__len__()==1 (co_consts has only 1 element: the docstring 'Override for issubclass(subclass, cls).'; same structure as __instancecheck__=1; both ABCMeta hook methods have minimal bytecode since they delegate to C implementation); compare: abstractmethod co_consts.__len__()==2 (1 more: abstractmethod has both a docstring and the literal True; __instancecheck__/__subclasscheck__ need no literal constants in bytecode); ABCMeta.__instancecheck__.__code__.co_freevars.__len__()==0 (no closures; consistent with abstractmethod=0); ABCMeta.__subclasscheck__.__code__.co_freevars.__len__()==0 (no closures; tied with __instancecheck__=0); ABCMeta.__instancecheck__.__code__.co_cellvars.__len__()==0 (no nested functions); ABCMeta.__subclasscheck__.__code__.co_cellvars.__len__()==0 (no nested functions; tied with __instancecheck__=0); all abc functions in this spec have co_freevars==co_cellvars==0 (none define closures or nested functions); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcconsts116a

  columns: [id, function, args, expected, description]
  rows:
    - [ic_consts_len,   ABCMeta.__instancecheck__.__code__.co_consts.__len__,  [],  1,  "ABCMeta.__instancecheck__ co_consts.__len__() == 1 (docstring only; no literal constants); verified with Python 3.14.3"]
    - [ic_freevars_len, ABCMeta.__instancecheck__.__code__.co_freevars.__len__, [], 0,  "ABCMeta.__instancecheck__ co_freevars.__len__() == 0 (no closures); verified with Python 3.14.3"]
    - [ic_cellvars_len, ABCMeta.__instancecheck__.__code__.co_cellvars.__len__, [], 0,  "ABCMeta.__instancecheck__ co_cellvars.__len__() == 0 (no nested functions); verified with Python 3.14.3"]
    - [sc_consts_len,   ABCMeta.__subclasscheck__.__code__.co_consts.__len__,  [],  1,  "ABCMeta.__subclasscheck__ co_consts.__len__() == 1 (docstring only; tied with __instancecheck__=1); verified with Python 3.14.3"]
    - [sc_freevars_len, ABCMeta.__subclasscheck__.__code__.co_freevars.__len__, [], 0,  "ABCMeta.__subclasscheck__ co_freevars.__len__() == 0 (no closures; tied with __instancecheck__=0); verified with Python 3.14.3"]
    - [sc_cellvars_len, ABCMeta.__subclasscheck__.__code__.co_cellvars.__len__, [], 0,  "ABCMeta.__subclasscheck__ co_cellvars.__len__() == 0 (no nested functions; tied with __instancecheck__=0); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc co_consts and closure attribute cross-comparison — extra116
#
# Wave 260 theme: compare co_consts lengths and closure attribute lengths
#                 across abstractmethod, ABCMeta.__instancecheck__, and
#                 ABCMeta.__subclasscheck__.
#
# abstractmethod co_consts len=2 (docstring + True).
# ABCMeta.__instancecheck__ co_consts len=1 (docstring only).
# ABCMeta.__subclasscheck__ co_consts len=1 (docstring only, tied).
# All three have co_freevars==co_cellvars==0.
# ---------------------------------------------------------------------------

table abc_extra116.abc_co_consts_cross_compare:
  description: "abc module co_consts and closure attribute cross-comparison in abcconsts116b namespace — wave 260 theme: comparing co_consts lengths and closure attributes (co_freevars, co_cellvars) across abc functions; abstractmethod.__code__.co_consts.__len__()==2 (has docstring + True; the literal True is needed because abstractmethod stores funcobj.__isabstractmethod__ = True using it as a bytecode constant); ABCMeta.__instancecheck__.__code__.co_consts.__len__()==1 (docstring only; 1 fewer than abstractmethod=2; __instancecheck__ delegates to _abc._abc_instancecheck() in C so it needs no Python literal constants beyond its docstring); ABCMeta.__subclasscheck__.__code__.co_consts.__len__()==1 (tied with __instancecheck__=1; docstring 'Override for issubclass(subclass, cls).' is the only constant; __subclasscheck__ delegates to _abc._abc_subclasscheck() in C); co_freevars lengths: abstractmethod=0 == ABCMeta.__instancecheck__=0 == ABCMeta.__subclasscheck__=0 (all three are flat non-closure functions); co_cellvars lengths: all three==0 (none define nested functions that would require cell variables); abstractmethod.__code__.co_consts[1].__class__.__name__=='bool' (co_consts[1] is the literal True, a bool; True.__class__.__name__=='bool'); the pattern: co_consts.__len__()==2 for simple decorators (abstractmethod) vs ==1 for delegation wrappers (__instancecheck__, __subclasscheck__); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcconsts116b

  columns: [id, function, args, expected, description]
  rows:
    - [am_consts2,      abstractmethod.__code__.co_consts.__len__,                [],       2,    "abstractmethod co_consts.__len__() == 2 (docstring + True; 1 more than instancecheck/subclasscheck); verified with Python 3.14.3"]
    - [ic_consts1,      ABCMeta.__instancecheck__.__code__.co_consts.__len__,     [],       1,    "ABCMeta.__instancecheck__ co_consts.__len__() == 1 (docstring only; 1 fewer than abstractmethod=2); verified with Python 3.14.3"]
    - [sc_consts1,      ABCMeta.__subclasscheck__.__code__.co_consts.__len__,     [],       1,    "ABCMeta.__subclasscheck__ co_consts.__len__() == 1 (tied with __instancecheck__=1); verified with Python 3.14.3"]
    - [am_consts1_bool, "abstractmethod.__code__.co_consts[1].__class__.__name__.__eq__", ["bool"], true, "abstractmethod co_consts[1].__class__.__name__ == 'bool' (co_consts[1] is True, a bool literal); verified with Python 3.14.3"]
    - [am_fv0,          abstractmethod.__code__.co_freevars.__len__,              [],       0,    "abstractmethod co_freevars.__len__() == 0 (no closures; tied with all other abc functions=0); verified with Python 3.14.3"]
    - [ic_cv0,          ABCMeta.__instancecheck__.__code__.co_cellvars.__len__,   [],       0,    "ABCMeta.__instancecheck__ co_cellvars.__len__() == 0 (no nested functions; all abc functions=0); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra116
# ---------------------------------------------------------------------------

invariant abc_extra116.abstractmethod_co_consts_len_2:
  description: "abc.abstractmethod.__code__.co_consts.__len__() == 2 — co_consts==(docstring, True): len=2; first coverage of the actual length of abstractmethod.__code__.co_consts (extra61 only covered co_consts.__class__.__name__=='tuple', not the length); co_consts[0] is the abstractmethod docstring (str: 'A decorator indicating abstract methods.\\n\\nRequires...'); co_consts[1] is the literal True (bool): abstractmethod's bytecode includes the instruction LOAD_CONST True (or equivalent) which it stores into funcobj.__isabstractmethod__ = True; the implementation is: def abstractmethod(funcobj): funcobj.__isabstractmethod__ = True; return funcobj; 'True' appears as a constant in co_consts because Python compiles the literal True into the code object's constant pool; compare: ABCMeta.__instancecheck__ co_consts.__len__()==1 (1 fewer: no literal constants beyond docstring because the function body delegates to C); ABCMeta.__subclasscheck__ co_consts.__len__()==1 (same as __instancecheck__=1); update_abstractmethods co_consts.__len__()==6 (most in abc module pure-Python functions: 6 constants including None, frozenset, etc.); first standalone abstractmethod co_consts length invariant in abcconsts116 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abstractmethod.__code__.co_consts.__len__
  args: []
  expected: 2

invariant abc_extra116.abstractmethod_co_consts1_true:
  description: "abc.abstractmethod.__code__.co_consts[1].__eq__(True) returns True — abstractmethod co_consts[1] is the boolean literal True; abstractmethod sets funcobj.__isabstractmethod__ = True in its body; Python compiles this literal True into co_consts[1] of the code object; co_consts[0] is the docstring (str) and co_consts[1] is True (bool); co_consts[1].__class__.__name__=='bool' (True is a bool, not an int, even though bool is a subclass of int; True.__eq__(True)==True); co_consts[1] is exactly True (not 1 or any other value); this invariant confirms the bytecode-level representation of abstractmethod's core operation: it stores True into __isabstractmethod__; ABCMeta.__instancecheck__ and ABCMeta.__subclasscheck__ have no such boolean constant in co_consts (their co_consts.__len__()==1, docstring only); first standalone abstractmethod co_consts[1] equality invariant in abcconsts116 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abstractmethod.__code__.co_consts[1].__eq__"
  args: [true]
  expected: true

invariant abc_extra116.abstractmethod_co_freevars_len_0:
  description: "abc.abstractmethod.__code__.co_freevars.__len__() == 0 — co_freevars is the tuple of names used by the function from enclosing scopes (closure variables); len=0 means abstractmethod is a flat function with no closure state; abstractmethod is defined at module level in abc.py, not inside another function, so it cannot capture any variables from an enclosing scope; co_freevars.__len__()==0 is consistent across all abc module pure-Python functions: abstractmethod=0, update_abstractmethods=0, ABCMeta.__instancecheck__=0, ABCMeta.__subclasscheck__=0, ABCMeta.__new__=0; no abc function captures closure variables because all are defined at class or module scope; compare: co_cellvars.__len__()==0 (closely related: cell vars are variables in the current function captured by nested functions; abstractmethod has no nested functions so co_cellvars=0); co_freevars and co_cellvars are both 0 iff the function has no closure relationship with any other function; first standalone abstractmethod co_freevars length invariant in abcconsts116 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abstractmethod.__code__.co_freevars.__len__
  args: []
  expected: 0

invariant abc_extra116.abstractmethod_co_cellvars_len_0:
  description: "abc.abstractmethod.__code__.co_cellvars.__len__() == 0 — co_cellvars is the tuple of names in the current function's scope that are referenced by nested functions (inner functions or lambdas defined within abstractmethod); len=0 means abstractmethod defines no nested functions that capture its local variables; the abstractmethod body is: funcobj.__isabstractmethod__ = True; return funcobj — no inner functions, no lambdas; co_cellvars.__len__()==0 is tied with co_freevars.__len__()==0 (both 0 for the same reason: no closure relationship); all abc pure-Python functions have co_cellvars=0: abstractmethod=0, update_abstractmethods=0, ABCMeta.__instancecheck__=0, ABCMeta.__subclasscheck__=0; this is expected for well-structured non-closure utility functions; contrast: if abstractmethod had a pattern like 'def wrapper(*args): return funcobj(*args)' internally, wrapper would be a nested function causing co_cellvars to be non-zero; abstractmethod avoids this pattern; first standalone abstractmethod co_cellvars length invariant in abcconsts116 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abstractmethod.__code__.co_cellvars.__len__
  args: []
  expected: 0

invariant abc_extra116.ABCMeta_instancecheck_co_consts_len_1:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_consts.__len__() == 1 — co_consts has only 1 element (the docstring); 1 fewer than abstractmethod co_consts.__len__()==2 (abstractmethod has both docstring and literal True); ABCMeta.__instancecheck__ is the hook method called by isinstance(obj, cls) for any ABC; it delegates to the C-level _abc._abc_instancecheck() function which handles the ABC registry lookup efficiently; because the body is essentially: return _abc._abc_instancecheck(cls, instance) with no literal constants (no True, None, numeric literals, or string literals in the body), co_consts contains only the docstring; ABCMeta.__subclasscheck__ has co_consts.__len__()==1 (tied: same docstring-only pattern); ABCMeta.__instancecheck__.__code__.co_freevars.__len__()==0 (no closures); ABCMeta.__instancecheck__.__code__.co_cellvars.__len__()==0 (no nested functions); ABCMeta.__instancecheck__.__code__.co_qualname=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25; covered in earlier abc specs); first standalone ABCMeta.__instancecheck__ co_consts length invariant in abcconsts116a namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_consts.__len__
  args: []
  expected: 1

