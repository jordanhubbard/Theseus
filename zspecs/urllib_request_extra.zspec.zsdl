spec: urllib_request_extra
version: ">=3.0"
backend: python_module(urllib.request)

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "Python 3 urllib.request documentation — https://docs.python.org/3/library/urllib.request.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/request.py"
    - "urllib_request.zspec.zsdl — covers Request class_names, function_names (urlopen, build_opener, install_opener, pathname2url), Request construction (type, host, full_url, get_method), pathname2url absolute path, URLError/HTTPError attributes"
    - "urllib_error.zspec.zsdl — covers URLError/HTTPError/ContentTooShortError from urllib.error module"
  notes:
    - "This spec covers urllib.request symbols not yet checked in urllib_request.zspec.zsdl."
    - "urlretrieve is a legacy function (still present) that downloads a URL to a local file."
    - "url2pathname is the inverse of pathname2url; converts URL path to local filesystem path."
    - "Request.__module__ == 'urllib.request' — the class is defined in that module."
    - "HTTPError is re-exported in urllib.request from urllib.error; its __module__ is 'urllib.error'."
    - "URLError is re-exported in urllib.request from urllib.error; its __module__ is 'urllib.error'."
    - "HTTPError.__bases__[0].__name__ == 'URLError' — HTTPError is a subclass of URLError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — symbols not covered in urllib_request.zspec.zsdl
# ---------------------------------------------------------------------------

invariant urllib_request_extra.urlretrieve.name:
  description: "urlretrieve.__name__ == 'urlretrieve'"
  category: function_names
  kind: python_call_eq
  function: urlretrieve.__name__.__eq__
  args: ["urlretrieve"]
  expected: true

invariant urllib_request_extra.url2pathname.name:
  description: "url2pathname.__name__ == 'url2pathname'"
  category: function_names
  kind: python_call_eq
  function: url2pathname.__name__.__eq__
  args: ["url2pathname"]
  expected: true

invariant urllib_request_extra.pathname2url.name:
  description: "pathname2url.__name__ == 'pathname2url'"
  category: function_names
  kind: python_call_eq
  function: pathname2url.__name__.__eq__
  args: ["pathname2url"]
  expected: true

invariant urllib_request_extra.urlopen.name:
  description: "urlopen.__name__ == 'urlopen'"
  category: function_names
  kind: python_call_eq
  function: urlopen.__name__.__eq__
  args: ["urlopen"]
  expected: true

# ---------------------------------------------------------------------------
# Class name checks — symbols not covered in urllib_request.zspec.zsdl
# ---------------------------------------------------------------------------

invariant urllib_request_extra.Request.name:
  description: "Request.__name__ == 'Request'"
  category: class_names
  kind: python_call_eq
  function: Request.__name__.__eq__
  args: ["Request"]
  expected: true

invariant urllib_request_extra.HTTPError.name:
  description: "HTTPError.__name__ == 'HTTPError'"
  category: class_names
  kind: python_call_eq
  function: HTTPError.__name__.__eq__
  args: ["HTTPError"]
  expected: true

invariant urllib_request_extra.URLError.name:
  description: "URLError.__name__ == 'URLError'"
  category: class_names
  kind: python_call_eq
  function: URLError.__name__.__eq__
  args: ["URLError"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — __module__ of classes exported from urllib.request
# ---------------------------------------------------------------------------

invariant urllib_request_extra.Request.module:
  description: "Request.__module__ == 'urllib.request'"
  category: modules
  kind: python_call_eq
  function: Request.__module__.__eq__
  args: ["urllib.request"]
  expected: true

invariant urllib_request_extra.URLError.module:
  description: "URLError.__module__ == 'urllib.error' (re-exported from urllib.error)"
  category: modules
  kind: python_call_eq
  function: URLError.__module__.__eq__
  args: ["urllib.error"]
  expected: true

invariant urllib_request_extra.HTTPError.module:
  description: "HTTPError.__module__ == 'urllib.error' (re-exported from urllib.error)"
  category: modules
  kind: python_call_eq
  function: HTTPError.__module__.__eq__
  args: ["urllib.error"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance — HTTPError is a subclass of URLError
# ---------------------------------------------------------------------------

invariant urllib_request_extra.HTTPError.base_is_URLError:
  description: "HTTPError.__bases__[0].__name__ == 'URLError'"
  category: hierarchy
  kind: python_call_eq
  function: HTTPError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "URLError"
