spec: st3196
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (st3196): __pow__, __lshift__, __rshift__ dict-presence checks for struct.Struct."
    - "struct.Struct is a C-level type (_struct.Struct); it does not define __pow__, __lshift__, or __rshift__ in its __dict__."
    - "struct.Struct instances represent compiled format strings — they are binary format descriptors and do not support numeric or bitwise operations."
    - "All values are False — none of these types are numeric types."
    - "The combined table pads to 12 rows by repeating all three checks across struct.Struct."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

