spec: inspect_extra181
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter class identity and Parameter.empty sentinel — inspect.Parameter.__name__=='Parameter' (len=9); inspect.Parameter.__module__=='inspect'; inspect.Parameter.__qualname__=='Parameter'; inspect.Parameter.empty.__class__.__name__=='type' (it is the class _empty itself, used as a sentinel); inspect.Parameter.POSITIONAL_ONLY.__class__.__name__=='_ParameterKind'; inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__=='_ParameterKind'; inspect.Parameter.VAR_POSITIONAL.__class__.__name__=='_ParameterKind'; inspect.Parameter.KEYWORD_ONLY.__class__.__name__=='_ParameterKind'."
    - "inspect.Parameter.__name__ == 'Parameter' — Parameter is a class in Lib/inspect.py representing a parameter in a function signature; its __name__ is 'Parameter', 9 characters. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in the pure-Python inspect module (Lib/inspect.py); its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' — Parameter is a module-level class (not nested), so its __qualname__ equals its __name__ 'Parameter'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the class inspect._empty itself (not an instance of _empty); it serves as a sentinel value indicating that a parameter has no default; since _empty is a class, its __class__ is 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — POSITIONAL_ONLY is an enum member of the private _ParameterKind enum; its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — POSITIONAL_OR_KEYWORD is an enum member of _ParameterKind; its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — VAR_POSITIONAL is an enum member of _ParameterKind (corresponds to *args); its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — KEYWORD_ONLY is an enum member of _ParameterKind (corresponds to keyword-only parameters after *args); its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter __name__, __module__, __qualname__
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__name__.__len__() == 9
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter'
#
# Parameter is a class in Lib/inspect.py representing a parameter in a
# function signature. Its __name__ is 'Parameter' (9 chars). New to extra181.
# ---------------------------------------------------------------------------

table inspect_extra181.parameter_class_identity:
  description: "inspect.Parameter.__name__ 'Parameter' len 9; __module__ 'inspect'; __qualname__ 'Parameter' equals __name__; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam181

  columns: [id, function, args, expected, description]
  rows:
    - [param_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a class in Lib/inspect.py representing a single parameter in a function signature, including its name, kind, default value, and annotation; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra181"]
    - [param_name_len_9,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — the name 'Parameter' has exactly 9 characters: P-a-r-a-m-e-t-e-r; str.__len__() returns 9; new to extra181"]
    - [param_module_eq,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in the pure-Python inspect module Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra181"]
    - [param_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a module-level class (not nested inside another class or function), so its __qualname__ equals its __name__ 'Parameter'; str.__eq__('Parameter') returns True; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.empty sentinel class identity
#
# inspect.Parameter.empty.__class__.__name__ == 'type'
#
# Parameter.empty is the class inspect._empty itself (not an instance).
# It serves as a sentinel indicating a parameter has no default or annotation.
# Since _empty is a class, its __class__ is 'type'. New to extra181.
# ---------------------------------------------------------------------------

table inspect_extra181.parameter_empty_sentinel:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — empty is the _empty class itself used as sentinel; class objects have __class__ == type; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam181

  columns: [id, function, args, expected, description]
  rows:
    - [empty_class_is_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is the class inspect._empty itself (not an instance of _empty); it is used as a sentinel to indicate a parameter has no default value or annotation; since _empty is a class, type(_empty).__name__ is 'type'; str.__eq__('type') returns True; new to extra181"]
    - [empty_is_sentinel,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty is a class used as sentinel — empty holds the class _empty itself, making it a unique identity-based sentinel; its __class__.__name__ is 'type' confirming it is a class object; new to extra181"]
    - [empty_class_name_eq_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__ is type — class objects in Python are instances of type (the metaclass); _empty is an ordinary class defined in inspect.py; its __class__ is type; __class__.__name__.__eq__('type') returns True; new to extra181"]
    - [empty_not_instance_str,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty is not an instance of str, int, or any other value type — it is a class object; its __class__.__name__ == 'type' distinguishes it from instance-based sentinel patterns; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind enum members class identity
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'
#
# All Parameter kind constants are members of the _ParameterKind enum defined
# in Lib/inspect.py. The enum class is private (_ParameterKind). New to extra181.
# ---------------------------------------------------------------------------

table inspect_extra181.parameter_kind_enum_class:
  description: "POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY all have __class__.__name__ '_ParameterKind'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam181

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an enum member of the private _ParameterKind enum in Lib/inspect.py, representing parameters that can only be passed positionally (before a / in the signature); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra181"]
    - [positional_or_keyword_class,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is an enum member of _ParameterKind representing the default parameter kind that can be passed either positionally or by keyword; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra181"]
    - [var_positional_class,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is an enum member of _ParameterKind representing *args parameters that capture excess positional arguments; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra181"]
    - [keyword_only_class,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is an enum member of _ParameterKind representing parameters that must be passed by keyword (appearing after *args or a bare * in the signature); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra181
# ---------------------------------------------------------------------------

invariant inspect_extra181.parameter_name_is_parameter:
  description: "inspect.Parameter.__name__ == 'Parameter' — class in Lib/inspect.py representing a function signature parameter with __name__ 'Parameter' (9 chars); new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra181.parameter_module_is_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in the pure-Python inspect module Lib/inspect.py; its __module__ is 'inspect'; new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra181.parameter_qualname_equals_name:
  description: "inspect.Parameter.__qualname__ == 'Parameter' — module-level class has __qualname__ == __name__ == 'Parameter' (9 chars); new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.__qualname__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra181.parameter_empty_class_is_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — empty holds the class _empty itself as a sentinel; class objects have __class__ == type; new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra181.positional_only_class_is_parameter_kind:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — enum member of private _ParameterKind enum in inspect; new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra181.positional_or_keyword_class_is_parameter_kind:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — default parameter kind enum member of _ParameterKind; new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra181.var_positional_class_is_parameter_kind:
  description: "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — *args parameter kind enum member of _ParameterKind; new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra181.keyword_only_class_is_parameter_kind:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — keyword-only parameter kind enum member of _ParameterKind; new to extra181"
  category: identity
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true
