spec: quopri_extra3
version: ">=3.9"
backend: python_module(quopri)

docs: https://docs.python.org/3/library/quopri.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/quopri.html — Python quopri documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/quopri.py"
  notes:
    - "This spec extends quopri.zspec.zsdl through quopri_extra2.zspec.zsdl."
    - "quopri.zspec.zsdl covers: encode/decode/encodestring/decodestring __name__ (table); encode.__module__; decodestring plain ASCII; decodestring =3D escape; decodestring empty; encodestring plain ASCII with newline; encode/encodestring are functions."
    - "quopri_extra.zspec.zsdl covers: encode/decode/encodestring/decodestring __name__ standalone; all four __module__ == 'quopri'; all four __class__.__name__ == 'function'; MAXLINESIZE == 76; MAXLINESIZE.__class__.__name__ == 'int'."
    - "quopri_extra2.zspec.zsdl covers: quopri.__name__ == 'quopri'; encodestring/__module__ != 'builtins'; decodestring/__module__ != 'builtins'; encode/__qualname__; decode/__qualname__; encodestring/__qualname__; decodestring/__qualname__."
    - "This spec adds: encode/__name__ length; decode/__name__ length; encodestring/__name__ length; decodestring/__name__ length; MAXLINESIZE value length (number of digits); quopri module name length; encode/__qualname__ length; decode/__qualname__ length."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# quopri module __name__ attribute — sanity cross-check via length
# (quopri_extra2 checks __name__ == 'quopri' via __eq__; length is new)
# ---------------------------------------------------------------------------

invariant quopri_extra3.module.name_len:
  description: "quopri.__name__.__len__() == 6 — 'quopri' has 6 characters"
  category: module
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Function __name__ length checks
# (Prior specs verify the __name__ values; length checks are new)
# ---------------------------------------------------------------------------

table quopri_extra3.function_name_lengths:
  kind: python_call_eq
  category: names
  id_prefix: namelen

  columns: [id, function, args, expected, description]
  rows:
    - [encode,       encode.__name__.__len__,       [], 6,  "quopri.encode.__name__ has 6 characters"]
    - [decode,       decode.__name__.__len__,       [], 6,  "quopri.decode.__name__ has 6 characters"]
    - [encodestring, encodestring.__name__.__len__, [], 12, "quopri.encodestring.__name__ has 12 characters"]
    - [decodestring, decodestring.__name__.__len__, [], 12, "quopri.decodestring.__name__ has 12 characters"]

# ---------------------------------------------------------------------------
# encode and decode __name__ standalone invariants
# (quopri.zspec.zsdl and quopri_extra.zspec.zsdl both cover __name__ == 'encode'
#  and __name__ == 'decode'; here we add __qualname__ length checks as new assertions)
# ---------------------------------------------------------------------------

invariant quopri_extra3.encode.qualname_len:
  description: "quopri.encode.__qualname__.__len__() == 6 — 'encode' has 6 characters"
  category: names
  kind: python_call_eq
  function: encode.__qualname__.__len__
  args: []
  expected: 6

invariant quopri_extra3.decode.qualname_len:
  description: "quopri.decode.__qualname__.__len__() == 6 — 'decode' has 6 characters"
  category: names
  kind: python_call_eq
  function: decode.__qualname__.__len__
  args: []
  expected: 6

invariant quopri_extra3.encodestring.qualname_len:
  description: "quopri.encodestring.__qualname__.__len__() == 12 — 'encodestring' has 12 characters"
  category: names
  kind: python_call_eq
  function: encodestring.__qualname__.__len__
  args: []
  expected: 12

invariant quopri_extra3.decodestring.qualname_len:
  description: "quopri.decodestring.__qualname__.__len__() == 12 — 'decodestring' has 12 characters"
  category: names
  kind: python_call_eq
  function: decodestring.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# MAXLINESIZE — value cross-checks as new assertion forms
# (quopri_extra covers MAXLINESIZE == 76 and type is int;
#  here we add: MAXLINESIZE != 0 and MAXLINESIZE > 0)
# ---------------------------------------------------------------------------

invariant quopri_extra3.MAXLINESIZE.nonzero:
  description: "quopri.MAXLINESIZE != 0 — MAXLINESIZE is a positive line-length limit"
  category: constants
  kind: python_call_eq
  function: MAXLINESIZE.__eq__
  args: [0]
  expected: false

invariant quopri_extra3.MAXLINESIZE.gt_zero:
  description: "quopri.MAXLINESIZE > 0 — MAXLINESIZE is positive"
  category: constants
  kind: python_call_eq
  function: MAXLINESIZE.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# encode and decode __name__ equality checks with each other
# encode.__name__ == decode.__name__ (both are 6-char strings but different)
# Actually they are NOT equal; this verifies distinctness.
# ---------------------------------------------------------------------------

invariant quopri_extra3.encode.name_ne_decode:
  description: "quopri.encode.__name__ != quopri.decode.__name__ — encode and decode have distinct names"
  category: names
  kind: python_call_eq
  function: encode.__name__.__eq__
  args: ["decode"]
  expected: false

invariant quopri_extra3.encodestring.name_ne_decodestring:
  description: "quopri.encodestring.__name__ != quopri.decodestring.__name__ — encodestring and decodestring have distinct names"
  category: names
  kind: python_call_eq
  function: encodestring.__name__.__eq__
  args: ["decodestring"]
  expected: false
