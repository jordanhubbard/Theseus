spec: concurrent_futures_extra2311
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#executor-objects — Executor class reference"
    - "Test vectors verified with Python 3.13.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks for concurrent.futures classes."
    - "concurrent.futures.Executor does NOT use ABCMeta; submit() uses 'raise NotImplementedError()' directly."
    - "Consequently Executor.__dict__ does not contain '__abstractmethods__' in any tested Python version."
    - "concurrent.futures.Future is a concrete class — __abstractmethods__ absent from __dict__."
    - "concurrent.futures.ThreadPoolExecutor is a concrete class — __abstractmethods__ absent."
    - "concurrent.futures.ProcessPoolExecutor is a concrete class — __abstractmethods__ absent."
    - "concurrent.futures.BrokenExecutor is an exception class — __abstractmethods__ absent."
    - "concurrent.futures.InvalidStateError is an exception class — __abstractmethods__ absent."
    - "All __dict__.__contains__('__abstractmethods__') checks return False for every concurrent.futures class."
    - "Direct access to .__abstractmethods__ on any concurrent.futures class raises AttributeError."
    - "All values verified with Python 3.13.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2311.executor_abstract_methods:
  description: "concurrent.futures.Executor — __abstractmethods__ absent from __dict__; not an ABC"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: cf2311

  columns: [id, function, args, expected]
  rows:
    - ["cf2311001", "concurrent.futures.Executor.__dict__.__contains__",             ["__abstractmethods__"], false]
    - ["cf2311002", "concurrent.futures.Future.__dict__.__contains__",               ["__abstractmethods__"], false]
    - ["cf2311003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__abstractmethods__"], false]
    - ["cf2311004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__abstractmethods__"], false]

table concurrent_futures_extra2311.exception_abstract_methods:
  description: "concurrent.futures exception classes — __abstractmethods__ absent from __dict__"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: cf2311

  columns: [id, function, args, expected]
  rows:
    - ["cf2311005", "concurrent.futures.BrokenExecutor.__dict__.__contains__",   ["__abstractmethods__"], false]
    - ["cf2311006", "concurrent.futures.InvalidStateError.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["cf2311007", "concurrent.futures.CancelledError.__dict__.__contains__",    ["__abstractmethods__"], false]
    - ["cf2311008", "concurrent.futures.TimeoutError.__dict__.__contains__",      ["__abstractmethods__"], false]

table concurrent_futures_extra2311.abstract_methods_raises:
  description: "Direct .__abstractmethods__ access on concurrent.futures classes raises AttributeError"
  kind: python_call_raises
  category: abstract_methods
  id_prefix: cf2311

  columns: [id, function, args, expected]
  rows:
    - ["cf2311009", "concurrent.futures.Executor.__abstractmethods__.__len__",            [], "AttributeError"]
    - ["cf2311010", "concurrent.futures.Executor.__abstractmethods__.__contains__",       ["submit"], "AttributeError"]
    - ["cf2311011", "concurrent.futures.Future.__abstractmethods__.__len__",              [], "AttributeError"]
    - ["cf2311012", "concurrent.futures.ThreadPoolExecutor.__abstractmethods__.__len__",  [], "AttributeError"]
    - ["cf2311013", "concurrent.futures.ProcessPoolExecutor.__abstractmethods__.__len__", [], "AttributeError"]
    - ["cf2311014", "concurrent.futures.BrokenExecutor.__abstractmethods__.__len__",      [], "AttributeError"]

table concurrent_futures_extra2311.submit_map_shutdown_not_abstract:
  description: "Executor submit/map/shutdown are concrete (raise NotImplementedError), not ABC abstract — dict key absent"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: cf2311

  columns: [id, function, args, expected]
  rows:
    - ["cf2311015", "concurrent.futures.Executor.__dict__.__contains__", ["submit"],   true]
    - ["cf2311016", "concurrent.futures.Executor.__dict__.__contains__", ["map"],      true]
    - ["cf2311017", "concurrent.futures.Executor.__dict__.__contains__", ["shutdown"], true]
    - ["cf2311018", "concurrent.futures.Executor.__dict__.__contains__", ["__enter__"], true]
    - ["cf2311019", "concurrent.futures.Executor.__dict__.__contains__", ["__exit__"],  true]
    - ["cf2311020", "concurrent.futures.Executor.__dict__.__contains__", ["__abstractmethods__"], false]
