spec: inspect_extra242
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra241.zspec.zsdl — covers getsource and getfile identity"
    - "inspect_extra.zspec.zsdl — covers ismethod/isgenerator/iscoroutine/getsourcefile names and modules; isclass/isbuiltin/isfunction behavior; Parameter/Signature __name__"
    - "inspect_signature.zspec.zsdl — covers BoundArguments/__name__/__module__, Signature/__module__, Parameter/__module__, Parameter kind names, Parameter.empty, Signature.empty, signature(len)"
    - "inspect.zspec.zsdl — covers isfunction/isbuiltin/isclass/ismodule/isroutine/isgeneratorfunction/iscoroutinefunction/isasyncgenfunction/signature/getmembers/getdoc __name__ checks"
  notes:
    - "This spec covers inspect.signature behavioral contracts and Signature class identity."
    - "inspect.signature.__name__ == 'signature' (len=9) — signature is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.signature.__module__ == 'inspect' (len=7) — signature is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.signature.__qualname__ == 'signature' (len=9) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "inspect.signature.__class__.__name__ == 'function' — signature is a plain Python function. Verified with Python 3.14.3."
    - "inspect.signature(inspect.isfunction).__class__.__name__ == 'Signature' — calling signature() returns a Signature object. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' (len=9) — Signature is a class in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' (len=7) — Signature is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' (len=9) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "inspect.Signature.__class__.__name__ == 'type' — Signature is a class; its metaclass is type. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Signature.__doc__.__contains__('Signature') == True — docstring says 'A Signature object represents the overall signature of a function'. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' (len=9) — Parameter is a class in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' (len=7) — Parameter is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.signature function identity contracts
#
# inspect.signature.__name__ == 'signature' (len=9)
# inspect.signature.__module__ == 'inspect' (len=7)
# inspect.signature.__qualname__ == 'signature' (len=9)
# inspect.signature.__class__.__name__ == 'function'
# inspect.signature.__name__.__len__() == 9
#
# signature is a Python function in Lib/inspect.py. New to extra242.
# ---------------------------------------------------------------------------

table inspect_extra242.inspsig242_identity:
  description: "inspect.signature function identity: name, module, qualname, class; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: inspsig242

  columns: [id, function, args, expected, description]
  rows:
    - [sig_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__.__eq__('signature') == True — signature is a Python function in Lib/inspect.py; __name__ is 'signature' (len=9); new to extra242"]
    - [sig_name_len_9,
       signature.__name__.__len__,
       [],
       9,
       "inspect.signature.__name__.__len__() == 9 — 'signature' has exactly 9 characters; str.__len__() returns 9; new to extra242"]
    - [sig_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra242"]
    - [sig_module_len_7,
       signature.__module__.__len__,
       [],
       7,
       "inspect.signature.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra242"]
    - [sig_qualname_eq,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — __qualname__ is 'signature' (len=9); same as __name__ for top-level function; new to extra242"]

# ---------------------------------------------------------------------------
# Table 2: inspect.signature class and doc contracts
#
# inspect.signature.__class__.__name__ == 'function'
# inspect.signature.__qualname__.__len__() == 9
# inspect.signature.__module__.__len__() == 7
# inspect.signature.__doc__.__contains__('signature') == True
# inspect.signature.__doc__.__class__.__name__ == 'str'
#
# New to extra242.
# ---------------------------------------------------------------------------

table inspect_extra242.inspsig242_class:
  description: "inspect.signature class, qualname len, doc checks; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: inspsig242cls

  columns: [id, function, args, expected, description]
  rows:
    - [sig_class_is_function,
       signature.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.signature.__class__.__name__.__eq__('function') == True — signature is a plain Python function; its __class__ is the built-in function type; new to extra242"]
    - [sig_qualname_len_9,
       signature.__qualname__.__len__,
       [],
       9,
       "inspect.signature.__qualname__.__len__() == 9 — 'signature' has exactly 9 characters; str.__len__() returns 9; new to extra242"]
    - [sig_doc_contains_signature,
       signature.__doc__.__contains__,
       ["signature"],
       true,
       "inspect.signature.__doc__.__contains__('signature') == True — docstring says 'Get a signature object for the passed callable'; new to extra242"]
    - [sig_doc_class_is_str,
       signature.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.signature.__doc__.__class__.__name__.__eq__('str') == True — the signature docstring is a plain Python str object; new to extra242"]
    - [sig_module_contains_inspect,
       signature.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__contains__('inspect') == True — 'inspect' contains the substring 'inspect'; new to extra242"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature class identity contracts
#
# inspect.Signature.__name__ == 'Signature' (len=9)
# inspect.Signature.__module__ == 'inspect' (len=7)
# inspect.Signature.__bases__[0].__name__ == 'object'
# inspect.Signature.__class__.__name__ == 'type'
# inspect.Signature.__qualname__ == 'Signature' (len=9)
#
# Signature is a class in Lib/inspect.py. New to extra242.
# ---------------------------------------------------------------------------

table inspect_extra242.inspsigcls242_identity:
  description: "inspect.Signature class identity: name, module, bases, class, qualname; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: inspsigcls242

  columns: [id, function, args, expected, description]
  rows:
    - [sigcls_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a class in Lib/inspect.py; __name__ is 'Signature' (len=9); new to extra242"]
    - [sigcls_name_len_9,
       Signature.__name__.__len__,
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — 'Signature' has exactly 9 characters; str.__len__() returns 9; new to extra242"]
    - [sigcls_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra242"]
    - [sigcls_bases_0_is_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object; __bases__[0] is object; new to extra242"]
    - [sigcls_class_is_type,
       Signature.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — Signature is a class; its metaclass is the built-in type; new to extra242"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Signature class qualname, doc, and Parameter checks
#
# inspect.Signature.__qualname__ == 'Signature' (len=9)
# inspect.Signature.__doc__.__contains__('Signature') == True
# inspect.Signature.__module__.__len__() == 7
# inspect.Parameter.__name__ == 'Parameter' (len=9)
# inspect.Parameter.__module__ == 'inspect' (len=7)
#
# New to extra242.
# ---------------------------------------------------------------------------

table inspect_extra242.inspsigcls242_param:
  description: "inspect.Signature qualname/doc checks and Parameter class identity; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: inspsigcls242p

  columns: [id, function, args, expected, description]
  rows:
    - [sigcls_qualname_eq,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — __qualname__ is 'Signature' (len=9); same as __name__ for top-level class; new to extra242"]
    - [sigcls_doc_contains_Signature,
       Signature.__doc__.__contains__,
       ["Signature"],
       true,
       "inspect.Signature.__doc__.__contains__('Signature') == True — docstring says 'A Signature object represents the overall signature of a function'; new to extra242"]
    - [sigcls_module_len_7,
       Signature.__module__.__len__,
       [],
       7,
       "inspect.Signature.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra242"]
    - [param_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a class in Lib/inspect.py; __name__ is 'Parameter' (len=9); new to extra242"]
    - [param_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra242"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra242
# ---------------------------------------------------------------------------

invariant inspect_extra242.sig_name_eq:
  description: "inspect.signature.__name__ == 'signature' (len=9); new to extra242"
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra242.sig_module_eq:
  description: "inspect.signature.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra242"
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra242.sig_qualname_eq:
  description: "inspect.signature.__qualname__ == 'signature' (len=9); new to extra242"
  kind: python_call_eq
  function: signature.__qualname__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra242.sig_class_is_function:
  description: "inspect.signature.__class__.__name__ == 'function' — plain Python function; new to extra242"
  kind: python_call_eq
  function: signature.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra242.sigcls_name_eq:
  description: "inspect.Signature.__name__ == 'Signature' (len=9); new to extra242"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra242.sigcls_module_eq:
  description: "inspect.Signature.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra242"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra242.sigcls_bases_0_is_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits from object; new to extra242"
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra242.sigcls_class_is_type:
  description: "inspect.Signature.__class__.__name__ == 'type'; new to extra242"
  kind: python_call_eq
  function: Signature.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra242.sigcls_qualname_eq:
  description: "inspect.Signature.__qualname__ == 'Signature' (len=9); new to extra242"
  kind: python_call_eq
  function: Signature.__qualname__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra242.param_name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter' (len=9); new to extra242"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true
