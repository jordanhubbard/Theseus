spec: asyncio_extra96
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra95

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra95.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio Task and Future method __qualname__ lengths. asyncio.Task and asyncio.Future are C extension types from _asyncio; their methods are method_descriptor objects that nonetheless expose __qualname__. NEW in extra96: Task.cancel.__qualname__ len==11; Task.cancelled.__qualname__ len==14; Task.done.__qualname__ len==9; Task.result.__qualname__ len==11; Task.exception.__qualname__ len==14; Task.add_done_callback.__qualname__ len==22; Task.remove_done_callback.__qualname__ len==25; Task.get_coro.__qualname__ len==13; Task.get_name.__qualname__ len==13; Task.set_name.__qualname__ len==13; Task.get_context.__qualname__ len==16; Future.cancel.__qualname__ len==13; Future.cancelled.__qualname__ len==16; Future.done.__qualname__ len==11; Future.result.__qualname__ len==13; Future.exception.__qualname__ len==16; Future.add_done_callback.__qualname__ len==24; Future.remove_done_callback.__qualname__ len==27; Future.set_result.__qualname__ len==17; Future.set_exception.__qualname__ len==20. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.cancel.__qualname__ == 'Task.cancel' (len=11). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.remove_done_callback.__qualname__ == 'Task.remove_done_callback' (len=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.get_context.__qualname__ == 'Task.get_context' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.cancel.__qualname__ == 'Future.cancel' (len=13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.remove_done_callback.__qualname__ == 'Future.remove_done_callback' (len=27). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.set_exception.__qualname__ == 'Future.set_exception' (len=20). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Task core method __qualname__ lengths — extra96
#
# Wave 254 theme: asyncio Task and Future method __qualname__ lengths.
# asyncio.Task is a C extension type; methods are method_descriptor objects
# that still expose __qualname__.
#
# Task.cancel.__qualname__.__len__() == 11
# Task.cancelled.__qualname__.__len__() == 14
# Task.done.__qualname__.__len__() == 9
# Task.result.__qualname__.__len__() == 11
# Task.exception.__qualname__.__len__() == 14
# ---------------------------------------------------------------------------

table asyncio_extra96.task_core_method_qualname_lengths:
  description: "asyncio Task core method __qualname__ length checks in asynciotaskmethods96 namespace — wave 254 theme: asyncio Task and Future method qualnames; asyncio.Task is a C extension type from _asyncio; its methods are method_descriptor objects that expose __qualname__; Task.cancel.__qualname__.__len__()==11 ('Task.cancel'); Task.cancelled.__qualname__.__len__()==14 ('Task.cancelled'); Task.done.__qualname__.__len__()==9 ('Task.done', shortest); Task.result.__qualname__.__len__()==11 ('Task.result'); Task.exception.__qualname__.__len__()==14 ('Task.exception'); Task.done and Task.cancel/Task.result share length 9 and 11 respectively; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskmethods96

  columns: [id, function, args, expected, description]
  rows:
    - [task_cancel_len,    Task.cancel.__qualname__.__len__,    [], 11, "Task.cancel.__qualname__.__len__() == 11 — qualname is 'Task.cancel'; verified with Python 3.14.3"]
    - [task_cancelled_len, Task.cancelled.__qualname__.__len__, [], 14, "Task.cancelled.__qualname__.__len__() == 14 — qualname is 'Task.cancelled'; verified with Python 3.14.3"]
    - [task_done_len,      Task.done.__qualname__.__len__,      [], 9,  "Task.done.__qualname__.__len__() == 9 — qualname is 'Task.done'; shortest Task method qualname; verified with Python 3.14.3"]
    - [task_result_len,    Task.result.__qualname__.__len__,    [], 11, "Task.result.__qualname__.__len__() == 11 — qualname is 'Task.result'; verified with Python 3.14.3"]
    - [task_exception_len, Task.exception.__qualname__.__len__, [], 14, "Task.exception.__qualname__.__len__() == 14 — qualname is 'Task.exception'; same len as Task.cancelled; verified with Python 3.14.3"]

