# Future.remove_done_callback.__qualname__.__len__() == 27
# Future.set_result.__qualname__.__len__() == 17
# Future.set_exception.__qualname__.__len__() == 20
# ---------------------------------------------------------------------------

table asyncio_extra96.future_callback_mutation_qualname_lengths:
  description: "asyncio Future callback and mutation method __qualname__ length checks in asynciotaskmethods96 namespace — wave 254 theme: asyncio Future method qualnames; Future.add_done_callback.__qualname__.__len__()==24 ('Future.add_done_callback'); Future.remove_done_callback.__qualname__.__len__()==27 ('Future.remove_done_callback', longest Future method qualname); Future.set_result.__qualname__.__len__()==17 ('Future.set_result'); Future.set_exception.__qualname__.__len__()==20 ('Future.set_exception'); these mutation methods are absent from asyncio.Task (Task inherits them from Future); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskmethods96c

  columns: [id, function, args, expected, description]
  rows:
    - [fut_adc_len,         Future.add_done_callback.__qualname__.__len__,    [], 24, "Future.add_done_callback.__qualname__.__len__() == 24 — qualname is 'Future.add_done_callback'; verified with Python 3.14.3"]
    - [fut_rdc_len,         Future.remove_done_callback.__qualname__.__len__, [], 27, "Future.remove_done_callback.__qualname__.__len__() == 27 — qualname is 'Future.remove_done_callback'; longest Future qualname; verified with Python 3.14.3"]
    - [fut_set_result_len,  Future.set_result.__qualname__.__len__,           [], 17, "Future.set_result.__qualname__.__len__() == 17 — qualname is 'Future.set_result'; verified with Python 3.14.3"]
    - [fut_set_exc_len,     Future.set_exception.__qualname__.__len__,        [], 20, "Future.set_exception.__qualname__.__len__() == 20 — qualname is 'Future.set_exception'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant asyncio_extra96.Task_done_qualname_eq:
  description: "asyncio.Task.done.__qualname__.__eq__('Task.done') returns True — Task.done is the shortest qualname among all Task public methods (len=9); it consists of the 'Task.' prefix (5 chars) and 'done' (4 chars); asyncio.Task is a C extension type from _asyncio and Task.done is a method_descriptor; despite being a C method it still exposes __qualname__; NEW in extra96: first standalone __qualname__.__eq__ invariant for Task.done in asynciotaskmethods96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.done.__qualname__.__eq__
  args: ["Task.done"]
  expected: true

invariant asyncio_extra96.Task_remove_done_callback_qualname_eq:
  description: "asyncio.Task.remove_done_callback.__qualname__.__eq__('Task.remove_done_callback') returns True — Task.remove_done_callback has the longest __qualname__ of all Task public methods (len=25); it is 3 chars longer than Task.add_done_callback (len=22) due to the 'remove_' vs 'add_' prefix; NEW in extra96: first standalone __qualname__.__eq__ invariant for Task.remove_done_callback in asynciotaskmethods96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.remove_done_callback.__qualname__.__eq__
  args: ["Task.remove_done_callback"]
  expected: true

invariant asyncio_extra96.Future_done_qualname_eq:
  description: "asyncio.Future.done.__qualname__.__eq__('Future.done') returns True — Future.done is the shortest qualname among all Future public methods (len=11); it is 2 chars longer than Task.done (len=9) because 'Future.' (7 chars) vs 'Task.' (5 chars); asyncio.Future is also a C extension type from _asyncio; NEW in extra96: first standalone __qualname__.__eq__ invariant for Future.done in asynciotaskmethods96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

invariant asyncio_extra96.Future_remove_done_callback_qualname_eq:
  description: "asyncio.Future.remove_done_callback.__qualname__.__eq__('Future.remove_done_callback') returns True — Future.remove_done_callback has the longest __qualname__ of all Future public methods (len=27); it is 2 chars longer than Task.remove_done_callback (len=25) due to the 'Future.' vs 'Task.' prefix; NEW in extra96: first standalone __qualname__.__eq__ invariant for Future.remove_done_callback in asynciotaskmethods96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.remove_done_callback.__qualname__.__eq__
  args: ["Future.remove_done_callback"]
  expected: true

invariant asyncio_extra96.Task_get_name_qualname_len_eq_get_coro:
  description: "asyncio.Task.get_name.__qualname__.__len__() == 13 — Task.get_name, Task.get_coro, and Task.set_name all share the same __qualname__ length of 13; this symmetry arises because 'get_name', 'get_coro', and 'set_name' are all 8-char method names, yielding 'Task.' (5) + method (8) == 13; this is the only group of three Task methods sharing the same qualname length; NEW in extra96: first standalone length-equality invariant for Task.get_name in asynciotaskmethods96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.get_name.__qualname__.__len__
  args: []
  expected: 13
