# Future.done.__qualname__.__len__() == 11
# Future.result.__qualname__.__len__() == 13
# Future.exception.__qualname__.__len__() == 16
# ---------------------------------------------------------------------------

table asyncio_extra96.future_core_method_qualname_lengths:
  description: "asyncio Future core method __qualname__ length checks in asynciotaskmethods96 namespace — wave 254 theme: asyncio Future method qualnames; asyncio.Future is a C extension type from _asyncio; Future.cancel.__qualname__.__len__()==13 ('Future.cancel'); Future.cancelled.__qualname__.__len__()==16 ('Future.cancelled'); Future.done.__qualname__.__len__()==11 ('Future.done', shortest Future method); Future.result.__qualname__.__len__()==13 ('Future.result'); Future.exception.__qualname__.__len__()==16 ('Future.exception'); Future prefix ('Future.') is 7 chars vs Task prefix ('Task.') 5 chars, so Future methods are 2 chars longer than Task counterparts; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskmethods96b

  columns: [id, function, args, expected, description]
  rows:
    - [fut_cancel_len,    Future.cancel.__qualname__.__len__,    [], 13, "Future.cancel.__qualname__.__len__() == 13 — qualname is 'Future.cancel'; 2 more than Task.cancel (11); verified with Python 3.14.3"]
    - [fut_cancelled_len, Future.cancelled.__qualname__.__len__, [], 16, "Future.cancelled.__qualname__.__len__() == 16 — qualname is 'Future.cancelled'; verified with Python 3.14.3"]
    - [fut_done_len,      Future.done.__qualname__.__len__,      [], 11, "Future.done.__qualname__.__len__() == 11 — qualname is 'Future.done'; shortest Future method qualname; verified with Python 3.14.3"]
    - [fut_result_len,    Future.result.__qualname__.__len__,    [], 13, "Future.result.__qualname__.__len__() == 13 — qualname is 'Future.result'; verified with Python 3.14.3"]
    - [fut_exception_len, Future.exception.__qualname__.__len__, [], 16, "Future.exception.__qualname__.__len__() == 16 — qualname is 'Future.exception'; same len as Future.cancelled; verified with Python 3.14.3"]

