#
# Task.add_done_callback.__qualname__.__len__() == 22
# Task.remove_done_callback.__qualname__.__len__() == 25
# Task.get_coro.__qualname__.__len__() == 13
# Task.get_name.__qualname__.__len__() == 13
# Task.set_name.__qualname__.__len__() == 13
# Task.get_context.__qualname__.__len__() == 16
# ---------------------------------------------------------------------------

table asyncio_extra96.task_callback_introspect_qualname_lengths:
  description: "asyncio Task callback and introspection method __qualname__ length checks in asynciotaskmethods96 namespace — wave 254 theme: asyncio Task method qualnames; Task.add_done_callback.__qualname__.__len__()==22 ('Task.add_done_callback'); Task.remove_done_callback.__qualname__.__len__()==25 ('Task.remove_done_callback', longest Task method qualname); Task.get_coro.__qualname__.__len__()==13 ('Task.get_coro'); Task.get_name.__qualname__.__len__()==13 ('Task.get_name'); Task.set_name.__qualname__.__len__()==13 ('Task.set_name'); Task.get_context.__qualname__.__len__()==16 ('Task.get_context'); get_coro/get_name/set_name all share length 13; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskmethods96a

  columns: [id, function, args, expected, description]
  rows:
    - [task_adc_len,     Task.add_done_callback.__qualname__.__len__,    [], 22, "Task.add_done_callback.__qualname__.__len__() == 22 — qualname is 'Task.add_done_callback'; verified with Python 3.14.3"]
    - [task_rdc_len,     Task.remove_done_callback.__qualname__.__len__, [], 25, "Task.remove_done_callback.__qualname__.__len__() == 25 — qualname is 'Task.remove_done_callback'; longest Task qualname; verified with Python 3.14.3"]
    - [task_get_coro_len, Task.get_coro.__qualname__.__len__,            [], 13, "Task.get_coro.__qualname__.__len__() == 13 — qualname is 'Task.get_coro'; verified with Python 3.14.3"]
    - [task_get_name_len, Task.get_name.__qualname__.__len__,            [], 13, "Task.get_name.__qualname__.__len__() == 13 — qualname is 'Task.get_name'; same len as get_coro; verified with Python 3.14.3"]
    - [task_set_name_len, Task.set_name.__qualname__.__len__,            [], 13, "Task.set_name.__qualname__.__len__() == 13 — qualname is 'Task.set_name'; same len as get_coro/get_name; verified with Python 3.14.3"]
    - [task_get_ctx_len,  Task.get_context.__qualname__.__len__,         [], 16, "Task.get_context.__qualname__.__len__() == 16 — qualname is 'Task.get_context'; verified with Python 3.14.3"]

