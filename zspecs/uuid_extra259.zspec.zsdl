spec: uuid_extra259
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra258.zspec.zsdl — covers UUID.__str__/__repr__/__hash__/__eq__ method identity; UUID comparison method identity; UUID qualnames; UUID.bytes/hex/version fget identity."
    - "uuid_extra257.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 function identity; NAMESPACE_* class names; UUID.__name__/__module__/__bases__."
    - "uuid_extra.zspec.zsdl — covers UUID class name/module; uuid1/3/4/5 function names; uuid4 return class and version; NAMESPACE_* class names; UUID.int and hex class names."
  notes:
    - "uuid.UUID.urn is a property — type(uuid.UUID.urn).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.urn.fget.__name__ == 'urn' and fget.__qualname__ == 'UUID.urn' — pure-Python fget in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.bytes_le is a property — type(uuid.UUID.bytes_le).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.bytes_le.fget.__name__ == 'bytes_le' and fget.__qualname__ == 'UUID.bytes_le' — pure-Python fget. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.fields is a property — type(uuid.UUID.fields).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.fields.fget.__name__ == 'fields' and fget.__qualname__ == 'UUID.fields' — pure-Python fget. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.version is a property — type(uuid.UUID.version).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.version.fget.__name__ == 'version' and fget.__qualname__ == 'UUID.version' — pure-Python fget. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.variant is a property — type(uuid.UUID.variant).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.variant.fget.__name__ == 'variant' and fget.__qualname__ == 'UUID.variant' — pure-Python fget. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.int is a member_descriptor (not a property) — it has no fget attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All fget functions have __class__.__name__ == 'function' — pure-Python functions in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID property fget __name__ identity — urn, bytes_le, fields, version, variant
# These UUID attributes are property objects with pure-Python fget functions.
# fget.__name__ matches the property name; fget.__class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table uuid_extra259.UUID_property_fget_names:
  description: "uuid.UUID urn/bytes_le/fields/version/variant property fget.__name__ equality — all pure-Python fget functions in Lib/uuid.py; fget.__name__ matches property name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfgetn259

  columns: [id, function, args, expected, description]
  rows:
    - [urn_fget_name,      UUID.urn.fget.__name__.__eq__,      ["urn"],      true, "uuid.UUID.urn.fget.__name__ == 'urn' — property fget name matches attribute"]
    - [bytes_le_fget_name, UUID.bytes_le.fget.__name__.__eq__, ["bytes_le"], true, "uuid.UUID.bytes_le.fget.__name__ == 'bytes_le' — property fget name matches attribute"]
    - [fields_fget_name,   UUID.fields.fget.__name__.__eq__,   ["fields"],   true, "uuid.UUID.fields.fget.__name__ == 'fields' — property fget name matches attribute"]
    - [version_fget_name,  UUID.version.fget.__name__.__eq__,  ["version"],  true, "uuid.UUID.version.fget.__name__ == 'version' — property fget name matches attribute"]
    - [variant_fget_name,  UUID.variant.fget.__name__.__eq__,  ["variant"],  true, "uuid.UUID.variant.fget.__name__ == 'variant' — property fget name matches attribute"]

# ---------------------------------------------------------------------------
# UUID property fget __qualname__ identity — urn, bytes_le, fields, version, variant
# All qualnames have the 'UUID.' prefix confirming class membership.
# ---------------------------------------------------------------------------

table uuid_extra259.UUID_property_fget_qualnames:
  description: "uuid.UUID urn/bytes_le/fields/version/variant property fget.__qualname__ equality — all have 'UUID.' prefix confirming class membership in Lib/uuid.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfgetq259

  columns: [id, function, args, expected, description]
  rows:
    - [urn_fget_qualname,      UUID.urn.fget.__qualname__.__eq__,      ["UUID.urn"],      true, "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' — 'UUID.' prefix confirms class membership"]
    - [bytes_le_fget_qualname, UUID.bytes_le.fget.__qualname__.__eq__, ["UUID.bytes_le"], true, "uuid.UUID.bytes_le.fget.__qualname__ == 'UUID.bytes_le' — 'UUID.' prefix confirms class membership"]
    - [fields_fget_qualname,   UUID.fields.fget.__qualname__.__eq__,   ["UUID.fields"],   true, "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' — 'UUID.' prefix confirms class membership"]
    - [version_fget_qualname,  UUID.version.fget.__qualname__.__eq__,  ["UUID.version"],  true, "uuid.UUID.version.fget.__qualname__ == 'UUID.version' — 'UUID.' prefix confirms class membership"]
    - [variant_fget_qualname,  UUID.variant.fget.__qualname__.__eq__,  ["UUID.variant"],  true, "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' — 'UUID.' prefix confirms class membership"]

# ---------------------------------------------------------------------------
# UUID property type identity — urn, bytes_le, fields, version, variant
# All five attributes are property objects (type(attr).__name__ == 'property').
# ---------------------------------------------------------------------------

invariant uuid_extra259.UUID_urn_type_eq:
  description: "type(uuid.UUID.urn).__name__ == 'property' — UUID.urn is a property object with fget/fset/fdel attributes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.urn.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant uuid_extra259.UUID_bytes_le_type_eq:
  description: "type(uuid.UUID.bytes_le).__name__ == 'property' — UUID.bytes_le is a property object; fget returns the UUID bytes in little-endian format; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.bytes_le.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant uuid_extra259.UUID_fields_type_eq:
  description: "type(uuid.UUID.fields).__name__ == 'property' — UUID.fields is a property object; fget returns the UUID as a 6-tuple of integer fields; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.fields.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant uuid_extra259.UUID_version_type_eq:
  description: "type(uuid.UUID.version).__name__ == 'property' — UUID.version is a property object; fget returns the UUID version number (1-5) or None; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.version.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant uuid_extra259.UUID_variant_type_eq:
  description: "type(uuid.UUID.variant).__name__ == 'property' — UUID.variant is a property object; fget returns the UUID variant identifier; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.variant.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# UUID property fget __class__.__name__ identity — all are 'function'
# All fget functions are pure-Python functions in Lib/uuid.py.
# ---------------------------------------------------------------------------

invariant uuid_extra259.UUID_urn_fget_class_eq:
  description: "uuid.UUID.urn.fget.__class__.__name__ == 'function' — urn property fget is a pure-Python function in Lib/uuid.py; not a C-level descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.urn.fget.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra259.UUID_variant_fget_class_eq:
  description: "uuid.UUID.variant.fget.__class__.__name__ == 'function' — variant property fget is a pure-Python function in Lib/uuid.py; not a C-level descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.variant.fget.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra259.UUID_fields_fget_class_eq:
  description: "uuid.UUID.fields.fget.__class__.__name__ == 'function' — fields property fget is a pure-Python function in Lib/uuid.py; returns 6-tuple of integer components; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.fields.fget.__class__.__name__.__eq__
  args: ["function"]
  expected: true
