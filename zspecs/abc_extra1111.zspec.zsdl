spec: abc_extra1111
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.ABCMeta.__new__ qualname/module, abc.ABC class identity, ABC.__init_subclass__ qualname/class, ABCMeta.__init__/__repr__ class names, ABCMeta.__dict__/__mro__ class names documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks ABCMeta.__new__ qualname/module/class, ABC class module/qualname/name/metaclass identity, ABC.__init_subclass__ qualname/class/name, ABCMeta.__init__/__repr__ class names, ABCMeta.__dict__/__mro__ class names, ABC.__mro__/__dict__ class names — behaviors not covered by extra1081 or extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1111.abcmeta_new_qualname:
  description: "abc.ABCMeta.__new__ qualname, module, class, and name identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1111nw
  columns: [id, function, args, expected]
  rows:
    - [ab1111nw001, abc.ABCMeta.__new__.__qualname__.__eq__,          ["ABCMeta.__new__"],              true]
    - [ab1111nw002, abc.ABCMeta.__new__.__module__.__eq__,            ["abc"],                           true]
    - [ab1111nw003, abc.ABCMeta.__new__.__class__.__name__.__eq__,    ["function"],                      true]
    - [ab1111nw004, abc.ABCMeta.__new__.__name__.__eq__,              ["__new__"],                       true]
    - [ab1111nw005, abc.ABCMeta.__init__.__qualname__.__eq__,         ["type.__init__"],                 true]
    - [ab1111nw006, abc.ABCMeta.__init__.__class__.__name__.__eq__,   ["wrapper_descriptor"],            true]
    - [ab1111nw007, abc.ABCMeta.__init__.__name__.__eq__,             ["__init__"],                      true]
    - [ab1111nw008, abc.ABCMeta.__repr__.__qualname__.__eq__,         ["type.__repr__"],                 true]
    - [ab1111nw009, abc.ABCMeta.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"],            true]

table abc_extra1111.abc_class_identity:
  description: "abc.ABC class module, qualname, name, metaclass class name, dict, and mro identity"
