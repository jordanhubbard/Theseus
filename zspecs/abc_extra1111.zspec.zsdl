  category: class_identity
  id_prefix: ab1111ac
  columns: [id, function, args, expected]
  rows:
    - [ab1111ac001, abc.ABC.__module__.__eq__,                        ["abc"],                           true]
    - [ab1111ac002, abc.ABC.__qualname__.__eq__,                      ["ABC"],                           true]
    - [ab1111ac003, abc.ABC.__name__.__eq__,                          ["ABC"],                           true]
    - [ab1111ac004, abc.ABC.__class__.__name__.__eq__,                ["ABCMeta"],                       true]
    - [ab1111ac005, abc.ABC.__dict__.__class__.__name__.__eq__,       ["mappingproxy"],                  true]
    - [ab1111ac006, abc.ABC.__mro__.__class__.__name__.__eq__,        ["tuple"],                         true]
    - [ab1111ac007, abc.ABCMeta.__dict__.__class__.__name__.__eq__,   ["mappingproxy"],                  true]
    - [ab1111ac008, abc.ABCMeta.__mro__.__class__.__name__.__eq__,    ["tuple"],                         true]

