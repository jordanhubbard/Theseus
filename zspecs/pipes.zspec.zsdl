spec: pipes
version: ">=3.3,<3.13"
backend: python_module(pipes)

docs: https://docs.python.org/3/library/pipes.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pipes.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "pipes source: Lib/pipes.py (PSF; source inspection permitted)"
  not_derived_from:
    - "pipes internal shell quoting and pipeline execution internals"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "POSIX-only module; not available on Windows."
    - "The pipes module provides a single class, Template, used to describe a pipeline of shell commands."
    - "Template() can be instantiated with no arguments."
    - "Template instances have methods: reset, clone, debug, append, prepend, open, copy."
    - "Template.__bases__[0] is object — Template has no non-trivial base class."
    - "All expected values verified by running Python 3.12 pipes module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Template.open() raises ValueError if the pipeline is misconfigured. Underlying shell errors propagate through subprocess."
  stderr: "null"
  stickiness: "N/A — each Template instance is independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class name and hierarchy checks
# ---------------------------------------------------------------------------

invariant pipes.Template_name:
  description: "Template class name is 'Template'"
  category: classnames
  kind: python_call_eq
  function: Template.__name__.__eq__
  args: ["Template"]
  expected: true

invariant pipes.Template_module:
  description: "Template.__module__ is 'pipes'"
  category: classnames
  kind: python_call_eq
  function: Template.__module__.__eq__
  args: ["pipes"]
  expected: true

invariant pipes.Template_base:
  description: "Template.__bases__[0].__name__ == 'object'"
  category: classnames
  kind: python_call_eq
  function: Template.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Instance class checks
# ---------------------------------------------------------------------------

invariant pipes.Template_instance_class_name:
  description: "Template().__class__.__name__ == 'Template'"
  category: instance
  kind: python_call_eq
  function: Template
  args: []
  method: __class__.__name__.__eq__
  method_args: ["Template"]
  expected: true

