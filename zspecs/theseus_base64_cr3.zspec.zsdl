spec: theseus_base64_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_base64_cr3)
blocks: base64

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html"
  notes:
    - "Clean-room base85 and base32 encoding. Do NOT import base64."
    - "b85encode(s): encode bytes using base85 (ASCII85 variant, RFC 1924 variant)."
    - "b85decode(s): decode base85-encoded bytes."
    - "b32encode(s): encode bytes using base32 (RFC 4648 alphabet)."
    - "b32decode(s): decode base32-encoded bytes."
    - "base64_b32encode(): b32encode(b'hello').decode('ascii') == 'NBSWY3DPEB3W64TMMQ======' (RFC 4648)."
    - "base64_b32decode(): b32decode(b'NBSWY3DPEB3W64TMMQ======') == b'hello'."
    - "base64_b32_roundtrip(): b32decode(b32encode(b'test')) == b'test'."
    - "Base32 alphabet: ABCDEFGHIJKLMNOPQRSTUVWXYZ234567, pad with '=' to multiple of 8."
    - "Export: b32encode, b32decode, b85encode, b85decode."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_base64_cr3.b32encode:
  description: "b32encode(b'hello').decode() == 'NBSWY3DPEB3W64TMMQ======'"
  category: b32
  kind: python_call_eq
  function: base64_b32encode
  args: []
  expected: "NBSWY3DPEB3W64TMMQ======"

invariant theseus_base64_cr3.b32decode:
  description: "b32decode(b'NBSWY3DPEB3W64TMMQ======') == b'hello'"
  category: b32
  kind: python_call_eq
  function: base64_b32decode
  args: []
  expected: "hello"

invariant theseus_base64_cr3.b32_roundtrip:
  description: "b32decode(b32encode(b'test')) == b'test'"
  category: b32
  kind: python_call_eq
  function: base64_b32_roundtrip
  args: []
  expected: true
