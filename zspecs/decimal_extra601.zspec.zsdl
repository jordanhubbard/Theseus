spec: decimal_extra601
version: ">=3.9"
backend: python_module(decimal)
docs: "Behavioral spec for decimal.Decimal class method __doc__ type and ROUND constants"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers decimal.Decimal and Context __doc__ type, ROUND constant types, and precision limit types"
  created_at: "2026-04-12T00:00:00Z"

table decimal_extra601.de601dc:
  id_prefix: de601dc

  description: "decimal class and method __doc__ attributes are str instances"
  columns: [id, function, args, expected]
  rows:
    - [de601dc01, "decimal.Decimal.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [de601dc02, "decimal.Context.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [de601dc03, "decimal.Decimal.from_float.__doc__.__class__.__name__.__eq__", ["str"], true]

table decimal_extra601.de601fn:
