spec: threading_extra1171
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.excepthook __module__/__qualname__/__class__.__name__, threading.ExceptHookArgs __module__/__qualname__, threading.get_ident __module__/__qualname__, threading.get_native_id __module__ — not covered in _extra976/_extra991"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1171.excepthook_identity:
  description: "threading.excepthook __module__, __qualname__, and __class__.__name__ identity"
  kind: python_call_eq
  category: excepthook_identity
  id_prefix: th1171eh
  columns: [id, function, args, expected]
  rows:
    - [th1171eh001, threading.excepthook.__module__.__eq__,              ["threading"],   true]
    - [th1171eh002, threading.excepthook.__qualname__.__eq__,            ["excepthook"],  true]
    - [th1171eh003, threading.excepthook.__class__.__name__.__eq__,      ["function"],    true]
    - [th1171eh004, threading.excepthook.__doc__.__class__.__name__.__eq__, ["str"],      true]
    - [th1171eh005, threading.ExceptHookArgs.__module__.__eq__,          ["threading"],   true]
    - [th1171eh006, threading.ExceptHookArgs.__qualname__.__eq__,        ["ExceptHookArgs"], true]
    - [th1171eh007, threading.ExceptHookArgs.__class__.__name__.__eq__,  ["type"],        true]
    - [th1171eh008, threading.ExceptHookArgs._fields.__class__.__name__.__eq__, ["tuple"], true]

table threading_extra1171.get_ident_get_native_id_identity:
  description: "threading.get_ident and threading.get_native_id __module__ and __qualname__ identity"
  kind: python_call_eq
  category: get_ident_native_id_identity
  id_prefix: th1171gi
  columns: [id, function, args, expected]
  rows:
    - [th1171gi001, threading.get_ident.__module__.__eq__,               ["thread"],      true]
    - [th1171gi002, threading.get_ident.__qualname__.__eq__,             ["get_ident"],   true]
    - [th1171gi003, threading.get_ident.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [th1171gi004, threading.get_native_id.__module__.__eq__,           ["thread"],      true]
    - [th1171gi005, threading.get_native_id.__qualname__.__eq__,         ["get_native_id"], true]
    - [th1171gi006, threading.get_native_id.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [th1171gi007, threading.current_thread.__module__.__eq__,          ["threading"],   true]
    - [th1171gi008, threading.current_thread.__qualname__.__eq__,        ["current_thread"], true]

table threading_extra1171.excepthookargs_fields_and_main_thread:
  description: "threading.ExceptHookArgs namedtuple fields and main_thread identity"
  kind: python_call_eq
  category: excepthookargs_fields_main_thread
  id_prefix: th1171ef
  columns: [id, function, args, expected]
  rows:
    - [th1171ef001, threading.ExceptHookArgs._fields.__contains__,       ["exc_type"],     true]
    - [th1171ef002, threading.ExceptHookArgs._fields.__contains__,       ["exc_value"],    true]
    - [th1171ef003, threading.ExceptHookArgs._fields.__contains__,       ["exc_traceback"], true]
    - [th1171ef004, threading.ExceptHookArgs._fields.__contains__,       ["thread"],       true]
    - [th1171ef005, threading.ExceptHookArgs._fields.__len__,            [],               4]
    - [th1171ef006, threading.main_thread.__module__.__eq__,             ["threading"],    true]
    - [th1171ef007, threading.main_thread.__qualname__.__eq__,           ["main_thread"],  true]
    - [th1171ef008, threading.main_thread.__class__.__name__.__eq__,     ["function"],     true]
