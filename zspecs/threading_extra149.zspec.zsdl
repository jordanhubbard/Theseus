spec: threading_extra149
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.ExceptHookArgs — a C structseq (not a namedtuple), __name__ '_ExceptHookArgs' len 15, __qualname__ '_ExceptHookArgs', __module__ '_thread', __bases__[0]=='tuple', MRO len 3, n_fields 4, n_sequence_fields 4; threading.__loader__.__class__.__name__ 'SourceFileLoader'; threading.__spec__.name 'threading' len 9; threading.Thread — __name__ 'Thread' len 6, __module__ 'threading', __bases__[0]=='object', MRO len 2; threading.local — __name__ '_local', __module__ '_thread', __bases__[0]=='object', MRO len 2; threading.current_thread/__qualname__ len 14; threading.active_count/__qualname__ len 12 (Wave 277)."
    - "threading.ExceptHookArgs is a C structseq type (not a namedtuple) defined in Modules/_threadmodule.c; it is exposed as threading.ExceptHookArgs; __name__ == '_ExceptHookArgs' (len 15); __qualname__ == '_ExceptHookArgs'; __module__ == '_thread'; __bases__[0].__name__ == 'tuple'; MRO len == 3; n_fields == 4; n_sequence_fields == 4. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a source module. Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' (len 9). Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread' (len 6); __module__ == 'threading'; __bases__[0].__name__ == 'object'; MRO len == 2. Verified with Python 3.14.3."
    - "threading.local.__name__ == '_local'; __module__ == '_thread'; __bases__[0].__name__ == 'object'; MRO len == 2 — threading.local is actually _thread._local, a C extension type. Verified with Python 3.14.3."
    - "threading.current_thread.__qualname__ == 'current_thread' (len 14); threading.active_count.__qualname__ == 'active_count' (len 12). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.ExceptHookArgs — C structseq type identity
#
# Wave 277 theme: threading.ExceptHookArgs is a C structseq type (similar to
# but distinct from a namedtuple) defined in Modules/_threadmodule.c.
#
# threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' (len 15)
# threading.ExceptHookArgs.__qualname__ == '_ExceptHookArgs'
# threading.ExceptHookArgs.__module__ == '_thread'
# threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple'
# threading.ExceptHookArgs.__class__.__name__ == 'type'
# len(threading.ExceptHookArgs.__mro__) == 3
# threading.ExceptHookArgs.n_fields == 4
# threading.ExceptHookArgs.n_sequence_fields == 4
#
# ExceptHookArgs is a structseq type with 4 fields: exc_type, exc_value,
# exc_traceback, thread. It is passed to threading.excepthook.
# New to extra149.
# ---------------------------------------------------------------------------

table threading_extra149.excepthookargs_identity:
  description: "threading.ExceptHookArgs: C structseq type, __name__ '_ExceptHookArgs' len 15, __module__ '_thread', __bases__[0]=='tuple', MRO len 3, n_fields 4; wave 277; new to extra149"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingexcepthook149

  columns: [id, function, args, expected, description]
  rows:
    - [excepthookargs_class_eq_type,
       "ExceptHookArgs.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.ExceptHookArgs.__class__.__name__.__eq__('type') == True — ExceptHookArgs is a C structseq type defined in Modules/_threadmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra149"]
    - [excepthookargs_name_eq,
       "ExceptHookArgs.__name__.__eq__",
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__name__.__eq__('_ExceptHookArgs') == True — although exposed as threading.ExceptHookArgs, the type's internal name is '_ExceptHookArgs'; str.__eq__('_ExceptHookArgs') returns True; new to extra149"]
    - [excepthookargs_name_len_eq_15,
       "ExceptHookArgs.__name__.__len__",
       [],
       15,
       "threading.ExceptHookArgs.__name__.__len__() == 15 — __name__ is '_ExceptHookArgs' which has 15 characters; len('_ExceptHookArgs') == 15; new to extra149"]
    - [excepthookargs_module_eq_thread,
       "ExceptHookArgs.__module__.__eq__",
       ["_thread"],
       true,
       "threading.ExceptHookArgs.__module__.__eq__('_thread') == True — ExceptHookArgs is defined in Modules/_threadmodule.c; __module__ is '_thread' (the C extension module); str.__eq__('_thread') returns True; new to extra149"]
    - [excepthookargs_bases_first_eq_tuple,
       "ExceptHookArgs.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "threading.ExceptHookArgs.__bases__[0].__name__.__eq__('tuple') == True — structseq types in CPython inherit from tuple; ExceptHookArgs.__bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra149"]
    - [excepthookargs_mro_len_eq_3,
       "ExceptHookArgs.__mro__.__len__",
       [],
       3,
       "threading.ExceptHookArgs.__mro__.__len__() == 3 — the MRO of ExceptHookArgs is [_ExceptHookArgs, tuple, object]; len() == 3; new to extra149"]
    - [excepthookargs_n_fields_eq_4,
       "ExceptHookArgs.n_fields.__eq__",
       [4],
       true,
       "threading.ExceptHookArgs.n_fields.__eq__(4) == True — ExceptHookArgs is a structseq with 4 fields: exc_type, exc_value, exc_traceback, thread; n_fields is 4; int.__eq__(4) returns True; new to extra149"]
    - [excepthookargs_n_sequence_fields_eq_4,
       "ExceptHookArgs.n_sequence_fields.__eq__",
       [4],
       true,
       "threading.ExceptHookArgs.n_sequence_fields.__eq__(4) == True — all 4 fields of ExceptHookArgs are sequence fields (accessible by index); n_sequence_fields is 4; int.__eq__(4) returns True; new to extra149"]

# ---------------------------------------------------------------------------
# Table 2: threading.__loader__ and threading.__spec__
#
# Wave 277 theme: threading module loader and spec identity.
#
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# threading.__spec__.name == 'threading' (len 9)
#
# threading is a pure-Python source module; its loader is
# importlib.machinery.SourceFileLoader. New to extra149.
# ---------------------------------------------------------------------------

table threading_extra149.loader_spec_identity:
  description: "threading.__loader__.__class__.__name__ 'SourceFileLoader'; threading.__spec__.name 'threading' len 9; wave 277; new to extra149"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingloader149

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq_sourcefileloader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading is loaded from a .py source file; its loader is an instance of importlib.machinery.SourceFileLoader; __class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra149"]
    - [spec_class_eq_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the import system creates a ModuleSpec for threading; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra149"]
    - [spec_name_eq_threading,
       "__spec__.name.__eq__",
       ["threading"],
       true,
       "threading.__spec__.name.__eq__('threading') == True — the ModuleSpec name attribute is the fully-qualified module name 'threading'; str.__eq__('threading') returns True; new to extra149"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "threading.__spec__.name.__len__() == 9 — __spec__.name is 'threading' which has 9 characters; len('threading') == 9; new to extra149"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread and threading.local class identity
#
# Wave 277 theme: threading.Thread (Python class) and threading.local (C type).
#
# threading.Thread.__name__ == 'Thread' (len 6)
# threading.Thread.__module__ == 'threading'
# threading.Thread.__bases__[0].__name__ == 'object'
# len(threading.Thread.__mro__) == 2
# threading.local.__name__ == '_local'
# threading.local.__module__ == '_thread'
# threading.local.__bases__[0].__name__ == 'object'
# len(threading.local.__mro__) == 2
#
# Thread is a pure-Python class defined in Lib/threading.py; local is
# actually the C extension class _thread._local, exposed as threading.local.
# New to extra149.
# ---------------------------------------------------------------------------

table threading_extra149.thread_local_identity:
  description: "threading.Thread: Python class, __name__ 'Thread' len 6, __module__ 'threading', __bases__[0]=='object', MRO len 2; threading.local: C type _thread._local; wave 277; new to extra149"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread149

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq_thread,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is a Python class defined in Lib/threading.py; __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra149"]
    - [thread_name_len_eq_6,
       "Thread.__name__.__len__",
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — __name__ is 'Thread' which has 6 characters; len('Thread') == 6; new to extra149"]
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra149"]
    - [thread_bases_first_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra149"]
    - [thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread inherits directly from object; MRO is [Thread, object]; len() == 2; new to extra149"]
    - [local_name_eq__local,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is actually _thread._local, a C extension type; its __name__ is '_local' (with underscore); str.__eq__('_local') returns True; new to extra149"]
    - [local_module_eq__thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is the C extension class _thread._local; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra149"]
    - [local_mro_len_eq_2,
       "local.__mro__.__len__",
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — local (_thread._local) inherits directly from object; MRO is [_local, object]; len() == 2; new to extra149"]

