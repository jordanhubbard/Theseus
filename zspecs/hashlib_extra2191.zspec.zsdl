spec: hashlib_extra2191
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_blake2/"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2191: context manager protocol dict-presence — __enter__, __exit__ (sync context manager); __aenter__, __aexit__ (async context manager); acquire, release (lock-like protocol); __wrapped__ (decorator wrapper); __closure__ (function closure attribute)."
    - "hashlib.blake2b and hashlib.blake2s are C extension hash types from _blake2. They are NOT context managers, async context managers, lock-like objects, or decorated wrappers."
    - "Neither blake2b nor blake2s defines any of the context manager protocol dunders in its own __dict__."
    - "blake2b.__dict__ contains: copy, digest, hexdigest, update, name, block_size, digest_size, SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE — all hash-specific."
    - "blake2s.__dict__ contains the same set of keys as blake2b."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2191.blake2b_context_manager_protocol:
  description: "hashlib.blake2b context manager protocol dict-presence — blake2b is a C extension hash type, not a context manager"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2191

  columns: [id, function, args, expected]
  rows:
    - ["hl2191001", "hashlib.blake2b.__dict__.__contains__", ["__enter__"], false]
    - ["hl2191002", "hashlib.blake2b.__dict__.__contains__", ["__exit__"], false]
    - ["hl2191003", "hashlib.blake2b.__dict__.__contains__", ["__aenter__"], false]
    - ["hl2191004", "hashlib.blake2b.__dict__.__contains__", ["__aexit__"], false]
    - ["hl2191005", "hashlib.blake2b.__dict__.__contains__", ["acquire"], false]
    - ["hl2191006", "hashlib.blake2b.__dict__.__contains__", ["release"], false]
    - ["hl2191007", "hashlib.blake2b.__dict__.__contains__", ["__wrapped__"], false]
    - ["hl2191008", "hashlib.blake2b.__dict__.__contains__", ["__closure__"], false]

