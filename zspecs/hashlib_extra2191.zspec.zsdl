  columns: [id, function, args, expected]
  rows:
    - ["hl2191009", "hashlib.blake2s.__dict__.__contains__", ["__enter__"], false]
    - ["hl2191010", "hashlib.blake2s.__dict__.__contains__", ["__exit__"], false]
    - ["hl2191011", "hashlib.blake2s.__dict__.__contains__", ["__aenter__"], false]
    - ["hl2191012", "hashlib.blake2s.__dict__.__contains__", ["__aexit__"], false]
    - ["hl2191013", "hashlib.blake2s.__dict__.__contains__", ["acquire"], false]
    - ["hl2191014", "hashlib.blake2s.__dict__.__contains__", ["release"], false]
    - ["hl2191015", "hashlib.blake2s.__dict__.__contains__", ["__wrapped__"], false]
    - ["hl2191016", "hashlib.blake2s.__dict__.__contains__", ["__closure__"], false]

