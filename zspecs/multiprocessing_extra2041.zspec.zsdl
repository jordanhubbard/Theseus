    - ["mp2041009", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__ilshift__"], false]
    - ["mp2041010", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__lshift__"], false]
    - ["mp2041011", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__rlshift__"], false]
    - ["mp2041012", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__ilshift__"], false]
    - ["mp2041013", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__lshift__"], false]
