spec: multiprocessing_extra2041
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "multiprocessing.Process and synchronize types are process/IPC primitives, not bitwise types."
    - "multiprocessing.synchronize provides Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition."
    - "None of these types define bit-shift, bitwise AND/OR/XOR, or bitwise NOT protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2041.lshift_protocol:
  description: "multiprocessing.Process and synchronize types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2041

  columns: [id, function, args, expected]
  rows:
    - ["mp2041001", "multiprocessing.Process.__dict__.__contains__", ["__lshift__"], false]
    - ["mp2041002", "multiprocessing.Process.__dict__.__contains__", ["__rlshift__"], false]
    - ["mp2041003", "multiprocessing.Process.__dict__.__contains__", ["__ilshift__"], false]
