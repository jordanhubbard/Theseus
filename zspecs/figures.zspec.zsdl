spec: figures
version: ">=6.0.0"
backend: node(figures)

docs: https://github.com/sindresorhus/figures#readme

provenance:
  derived_from:
    - "figures README — https://github.com/sindresorhus/figures#readme"
    - "Test vectors verified with figures via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "figures source"
  notes:
    - "Cross-platform Unicode symbols for CLIs — fallbacks to ASCII on non-Unicode terminals."
    - "Install: npm install figures"
    - "v6 ESM with CJS shim; default export is the symbols object."
    - "Plus mainSymbols / fallbackSymbols / replaceSymbols for explicit fallback control."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Static data lookup; never throws."
  stderr: "null"
  stickiness: "N/A — pure data."
  codes: {}

# Default symbols (current platform — assume Unicode-capable)
invariant figures.tick:
  description: "figures.tick is the heavy check mark ✔"
  category: glyphs
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: tick}
  expected: "✔"

invariant figures.cross:
  description: "figures.cross is the heavy multiplication mark ✘"
  category: glyphs
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: cross}
  expected: "✘"

invariant figures.info:
  description: "figures.info is the information source ℹ"
  category: glyphs
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: info}
  expected: "ℹ"

invariant figures.warning:
  description: "figures.warning is ⚠"
  category: glyphs
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: warning}
  expected: "⚠"

# mainSymbols — Unicode set explicitly
invariant figures.mainSymbols_tick_is_unicode:
  description: "mainSymbols.tick is always the Unicode glyph regardless of platform"
  category: mainSymbols
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: mainSymbols}
    - {get: tick}
  expected: "✔"

# fallbackSymbols — ASCII set
invariant figures.fallbackSymbols_tick_is_ascii:
  description: "fallbackSymbols.tick is the ASCII fallback (√)"
  category: fallbackSymbols
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: fallbackSymbols}
    - {get: tick}
  expected: "√"

invariant figures.fallbackSymbols_cross_is_ascii:
  description: "fallbackSymbols.cross is the ASCII × fallback"
  category: fallbackSymbols
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: fallbackSymbols}
    - {get: cross}
  expected: "×"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:08:29Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
