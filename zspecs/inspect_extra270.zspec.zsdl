spec: inspect_extra270
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.FrameInfo is a NamedTuple subclass with 6 fields: ('frame', 'filename', 'lineno', 'function', 'code_context', 'index')."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — the private intermediate NamedTuple base class."
    - "inspect.FullArgSpec is a NamedTuple subclass with 7 fields; __bases__[0].__name__ == 'tuple' (direct tuple subclass)."
    - "FullArgSpec._fields: ('args', 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations') — 7 fields, len=7."
    - "inspect.Traceback has 5 fields: ('filename', 'lineno', 'function', 'code_context', 'index'); __bases__[0].__name__ == '_Traceback'."
    - "Both FrameInfo and Traceback have __module__ == 'inspect'; both have private intermediate base classes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.FrameInfo and inspect.Traceback namedtuple identity
#
# FrameInfo._fields has 6 elements; Traceback._fields has 5 elements.
# FrameInfo.__bases__[0].__name__ == '_FrameInfo'.
# Traceback.__bases__[0].__name__ == '_Traceback'.
# Both have __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra270.frameinfo_and_traceback_identity:
  description: "inspect.FrameInfo(6 fields) and Traceback(5 fields) namedtuple identity — FrameInfo base '_FrameInfo', Traceback base '_Traceback'; both module 'inspect'; fields verified; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex270fi

  columns: [id, function, args, expected, description]
  rows:
    - [fi_name_eq,           FrameInfo.__name__.__eq__,                   ["FrameInfo"],                  true, "inspect.FrameInfo.__name__ == 'FrameInfo'; verified with Python 3.14.3"]
    - [fi_name_len,          FrameInfo.__name__.__len__,                  [],                             9,    "inspect.FrameInfo.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [fi_mod_eq,            FrameInfo.__module__.__eq__,                 ["inspect"],                    true, "inspect.FrameInfo.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [fi_base_eq,           FrameInfo.__bases__.__getitem__(0).__name__.__eq__, ["_FrameInfo"],          true, "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — private intermediate NamedTuple base; verified with Python 3.14.3"]
    - [fi_fields_len,        FrameInfo._fields.__len__,                   [],                             6,    "inspect.FrameInfo._fields.__len__() == 6 — tuple has 6 field names; verified with Python 3.14.3"]
    - [fi_field0_eq,         FrameInfo._fields.__getitem__(0).__eq__,     ["frame"],                      true, "inspect.FrameInfo._fields[0] == 'frame'; verified with Python 3.14.3"]
    - [fi_field1_eq,         FrameInfo._fields.__getitem__(1).__eq__,     ["filename"],                   true, "inspect.FrameInfo._fields[1] == 'filename'; verified with Python 3.14.3"]
    - [fi_field2_eq,         FrameInfo._fields.__getitem__(2).__eq__,     ["lineno"],                     true, "inspect.FrameInfo._fields[2] == 'lineno'; verified with Python 3.14.3"]
    - [fi_field3_eq,         FrameInfo._fields.__getitem__(3).__eq__,     ["function"],                   true, "inspect.FrameInfo._fields[3] == 'function'; verified with Python 3.14.3"]
    - [fi_field5_eq,         FrameInfo._fields.__getitem__(5).__eq__,     ["index"],                      true, "inspect.FrameInfo._fields[5] == 'index' — last field; verified with Python 3.14.3"]
    - [tb_name_eq,           Traceback.__name__.__eq__,                   ["Traceback"],                  true, "inspect.Traceback.__name__ == 'Traceback'; verified with Python 3.14.3"]
    - [tb_name_len,          Traceback.__name__.__len__,                  [],                             9,    "inspect.Traceback.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [tb_mod_eq,            Traceback.__module__.__eq__,                 ["inspect"],                    true, "inspect.Traceback.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [tb_base_eq,           Traceback.__bases__.__getitem__(0).__name__.__eq__, ["_Traceback"],          true, "inspect.Traceback.__bases__[0].__name__ == '_Traceback' — private intermediate NamedTuple base; verified with Python 3.14.3"]
    - [tb_fields_len,        Traceback._fields.__len__,                   [],                             5,    "inspect.Traceback._fields.__len__() == 5 — one fewer field than FrameInfo; verified with Python 3.14.3"]
    - [tb_field0_eq,         Traceback._fields.__getitem__(0).__eq__,     ["filename"],                   true, "inspect.Traceback._fields[0] == 'filename'; verified with Python 3.14.3"]
    - [tb_field4_eq,         Traceback._fields.__getitem__(4).__eq__,     ["index"],                      true, "inspect.Traceback._fields[4] == 'index' — last field; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec namedtuple identity
#
# FullArgSpec._fields has 7 elements — largest namedtuple in this spec.
# __bases__[0].__name__ == 'tuple' (direct tuple subclass, no private base).
# Fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations.
# ---------------------------------------------------------------------------

table inspect_extra270.fullargspec_identity:
  description: "inspect.FullArgSpec 7-field namedtuple — base 'tuple', module 'inspect'; fields: args(0), varargs(1), varkw(2), defaults(3), kwonlyargs(4), kwonlydefaults(5), annotations(6 longest fieldname); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex270fas

  columns: [id, function, args, expected, description]
  rows:
    - [fas_name_eq,          FullArgSpec.__name__.__eq__,                 ["FullArgSpec"],                true, "inspect.FullArgSpec.__name__ == 'FullArgSpec'; verified with Python 3.14.3"]
    - [fas_name_len,         FullArgSpec.__name__.__len__,                [],                             11,   "inspect.FullArgSpec.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [fas_mod_eq,           FullArgSpec.__module__.__eq__,               ["inspect"],                    true, "inspect.FullArgSpec.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [fas_base_eq,          FullArgSpec.__bases__.__getitem__(0).__name__.__eq__, ["tuple"],             true, "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — direct tuple subclass; verified with Python 3.14.3"]
    - [fas_fields_len,       FullArgSpec._fields.__len__,                 [],                             7,    "inspect.FullArgSpec._fields.__len__() == 7 — 7 fields; verified with Python 3.14.3"]
    - [fas_field0_eq,        FullArgSpec._fields.__getitem__(0).__eq__,   ["args"],                       true, "inspect.FullArgSpec._fields[0] == 'args'; verified with Python 3.14.3"]
    - [fas_field1_eq,        FullArgSpec._fields.__getitem__(1).__eq__,   ["varargs"],                    true, "inspect.FullArgSpec._fields[1] == 'varargs'; verified with Python 3.14.3"]
    - [fas_field2_eq,        FullArgSpec._fields.__getitem__(2).__eq__,   ["varkw"],                      true, "inspect.FullArgSpec._fields[2] == 'varkw'; verified with Python 3.14.3"]
    - [fas_field3_eq,        FullArgSpec._fields.__getitem__(3).__eq__,   ["defaults"],                   true, "inspect.FullArgSpec._fields[3] == 'defaults'; verified with Python 3.14.3"]
    - [fas_field4_eq,        FullArgSpec._fields.__getitem__(4).__eq__,   ["kwonlyargs"],                 true, "inspect.FullArgSpec._fields[4] == 'kwonlyargs'; verified with Python 3.14.3"]
    - [fas_field5_eq,        FullArgSpec._fields.__getitem__(5).__eq__,   ["kwonlydefaults"],             true, "inspect.FullArgSpec._fields[5] == 'kwonlydefaults'; verified with Python 3.14.3"]
    - [fas_field6_eq,        FullArgSpec._fields.__getitem__(6).__eq__,   ["annotations"],               true, "inspect.FullArgSpec._fields[6] == 'annotations' — last field; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra270
# ---------------------------------------------------------------------------

invariant inspect_extra270.frameinfo_name_is_frameinfo:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' (len=9) — class name equals the export name"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra270.frameinfo_fields_len_is_six:
  description: "inspect.FrameInfo._fields.__len__() == 6 — FrameInfo has 6 namedtuple fields: frame, filename, lineno, function, code_context, index"
  category: identity
  kind: python_call_eq
  function: FrameInfo._fields.__len__
  args: []
  expected: 6

invariant inspect_extra270.traceback_fields_len_is_five:
  description: "inspect.Traceback._fields.__len__() == 5 — Traceback has 5 namedtuple fields: filename, lineno, function, code_context, index (no 'frame' field)"
  category: identity
  kind: python_call_eq
  function: Traceback._fields.__len__
  args: []
  expected: 5

invariant inspect_extra270.fullargspec_fields_len_is_seven:
  description: "inspect.FullArgSpec._fields.__len__() == 7 — FullArgSpec has 7 namedtuple fields; most fields of any namedtuple in this spec"
  category: identity
  kind: python_call_eq
  function: FullArgSpec._fields.__len__
  args: []
  expected: 7

invariant inspect_extra270.fullargspec_base_is_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a direct tuple subclass unlike FrameInfo(_FrameInfo) and Traceback(_Traceback)"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__bases__.__getitem__(0).__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra270.frameinfo_module_is_inspect:
  description: "inspect.FrameInfo.__module__ == 'inspect' — defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true
