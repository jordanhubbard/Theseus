spec: io_extra111
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec extends io_extra110.zspec.zsdl."
    - "This spec covers: io.BytesIO and io.StringIO method __qualname__ string equality and length values."
    - "io.BytesIO.read.__qualname__ = 'BytesIO.read' (length 12)."
    - "io.BytesIO.write.__qualname__ = 'BytesIO.write' (length 13)."
    - "io.BytesIO.seek.__qualname__ = 'BytesIO.seek' (length 12)."
    - "io.BytesIO.getvalue.__qualname__ = 'BytesIO.getvalue' (length 16)."
    - "io.BytesIO.tell.__qualname__ = 'BytesIO.tell' (length 12)."
    - "io.StringIO.read.__qualname__ = 'StringIO.read' (length 13)."
    - "io.StringIO.write.__qualname__ = 'StringIO.write' (length 14)."
    - "io.StringIO.getvalue.__qualname__ = 'StringIO.getvalue' (length 17)."
    - "All BytesIO and StringIO methods are of type method_descriptor (C extension methods)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ string equality
# BytesIO is a C extension type; its methods are method_descriptors.
# Each method's __qualname__ is 'BytesIO.<method_name>'.
# ---------------------------------------------------------------------------

table io_extra111.BytesIO_method_qualnames:
  description: "io.BytesIO method __qualname__ values: read='BytesIO.read', write='BytesIO.write', seek='BytesIO.seek', getvalue='BytesIO.getvalue', tell='BytesIO.tell'"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioqual111a

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_read_qn,     BytesIO.read.__qualname__.__eq__,     ["BytesIO.read"],     true,  "io.BytesIO.read.__qualname__ == 'BytesIO.read'"]
    - [bytesio_write_qn,    BytesIO.write.__qualname__.__eq__,    ["BytesIO.write"],    true,  "io.BytesIO.write.__qualname__ == 'BytesIO.write'"]
    - [bytesio_seek_qn,     BytesIO.seek.__qualname__.__eq__,     ["BytesIO.seek"],     true,  "io.BytesIO.seek.__qualname__ == 'BytesIO.seek'"]
    - [bytesio_getval_qn,   BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true,  "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue'"]
    - [bytesio_tell_qn,     BytesIO.tell.__qualname__.__eq__,     ["BytesIO.tell"],     true,  "io.BytesIO.tell.__qualname__ == 'BytesIO.tell'"]
    - [bytesio_read_not_sq, BytesIO.read.__qualname__.__eq__,     ["StringIO.read"],    false, "io.BytesIO.read.__qualname__ != 'StringIO.read' (BytesIO and StringIO are distinct classes)"]
    - [bytesio_write_not_s, BytesIO.write.__qualname__.__eq__,    ["StringIO.write"],   false, "io.BytesIO.write.__qualname__ != 'StringIO.write'"]

# ---------------------------------------------------------------------------
# io.StringIO method __qualname__ string equality
# StringIO is a C extension type; its methods are method_descriptors.
# Each method's __qualname__ is 'StringIO.<method_name>'.
# ---------------------------------------------------------------------------

table io_extra111.StringIO_method_qualnames:
  description: "io.StringIO method __qualname__ values: read='StringIO.read', write='StringIO.write', getvalue='StringIO.getvalue'"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioqual111b

  columns: [id, function, args, expected, description]
  rows:
    - [stringio_read_qn,    StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true,  "io.StringIO.read.__qualname__ == 'StringIO.read'"]
    - [stringio_write_qn,   StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true,  "io.StringIO.write.__qualname__ == 'StringIO.write'"]
    - [stringio_getval_qn,  StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true,  "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue'"]
    - [stringio_read_not_b, StringIO.read.__qualname__.__eq__,     ["BytesIO.read"],      false, "io.StringIO.read.__qualname__ != 'BytesIO.read' (StringIO and BytesIO are distinct classes)"]
    - [stringio_gv_not_b,   StringIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"],  false, "io.StringIO.getvalue.__qualname__ != 'BytesIO.getvalue'"]

# ---------------------------------------------------------------------------
# io.BytesIO and io.StringIO method __qualname__ lengths
# BytesIO.read/seek/tell len=12, BytesIO.write len=13, BytesIO.getvalue len=16
# StringIO.read len=13, StringIO.write len=14, StringIO.getvalue len=17
# ---------------------------------------------------------------------------

table io_extra111.method_qualname_lengths:
  description: "io.BytesIO and io.StringIO method __qualname__ lengths: read(12/13), write(13/14), seek(12), tell(12), getvalue(16/17)"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioqual111c

  columns: [id, function, args, expected, description]
  rows:
    - [br_read_len,   BytesIO.read.__qualname__.__len__,     [], 12, "io.BytesIO.read.__qualname__.__len__() == 12 ('BytesIO.read' has 12 chars)"]
    - [br_write_len,  BytesIO.write.__qualname__.__len__,    [], 13, "io.BytesIO.write.__qualname__.__len__() == 13 ('BytesIO.write' has 13 chars)"]
    - [br_seek_len,   BytesIO.seek.__qualname__.__len__,     [], 12, "io.BytesIO.seek.__qualname__.__len__() == 12 ('BytesIO.seek' has 12 chars)"]
    - [br_getval_len, BytesIO.getvalue.__qualname__.__len__, [], 16, "io.BytesIO.getvalue.__qualname__.__len__() == 16 ('BytesIO.getvalue' has 16 chars)"]
    - [br_tell_len,   BytesIO.tell.__qualname__.__len__,     [], 12, "io.BytesIO.tell.__qualname__.__len__() == 12 ('BytesIO.tell' has 12 chars)"]
    - [sr_read_len,   StringIO.read.__qualname__.__len__,    [], 13, "io.StringIO.read.__qualname__.__len__() == 13 ('StringIO.read' has 13 chars)"]
    - [sr_write_len,  StringIO.write.__qualname__.__len__,   [], 14, "io.StringIO.write.__qualname__.__len__() == 14 ('StringIO.write' has 14 chars)"]
    - [sr_getval_len, StringIO.getvalue.__qualname__.__len__,[], 17, "io.StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.getvalue' has 17 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra111.BytesIO.read_qualname:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read' (C extension method_descriptor; __qualname__ uses the class name 'BytesIO', not '_io.BytesIO' or 'io.BytesIO')"
  category: qualnames
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__eq__
  args: ["BytesIO.read"]
  expected: true

invariant io_extra111.BytesIO.getvalue_qualname_len:
  description: "io.BytesIO.getvalue.__qualname__.__len__() == 16 ('BytesIO.getvalue' is the longest __qualname__ among the BytesIO methods tested here)"
  category: qualnames
  kind: python_call_eq
  function: BytesIO.getvalue.__qualname__.__len__
  args: []
  expected: 16

invariant io_extra111.StringIO.getvalue_qualname:
  description: "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (StringIO-specific method for retrieving the full string contents; __qualname__ uses bare class name 'StringIO')"
  category: qualnames
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__eq__
  args: ["StringIO.getvalue"]
  expected: true

invariant io_extra111.StringIO.write_qualname_len:
  description: "io.StringIO.write.__qualname__.__len__() == 14 ('StringIO.write' has 14 characters; one more than 'BytesIO.write' because 'StringIO' is one character longer than 'BytesIO')"
  category: qualnames
  kind: python_call_eq
  function: StringIO.write.__qualname__.__len__
  args: []
  expected: 14

invariant io_extra111.BytesIO.seek_qualname:
  description: "io.BytesIO.seek.__qualname__ == 'BytesIO.seek' (seek is the random-access positioning method; its __qualname__ uses the bare class name 'BytesIO')"
  category: qualnames
  kind: python_call_eq
  function: BytesIO.seek.__qualname__.__eq__
  args: ["BytesIO.seek"]
  expected: true

