spec: hashlib_extra169
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra168.zspec.zsdl — covers hashlib.sha256/__md5/__sha512 .__name__ and .__module__ identity (openssl_ prefix; _hashlib module); algorithms_available.__class__.__name__=='set'; constructor __module__ lengths (table + invariants)."
    - "hashlib_extra167.zspec.zsdl — covers hashlib.__spec__.name/__class__.__name__=='ModuleSpec'/__spec__.origin type and contains 'hashlib'/__spec__.submodule_search_locations NoneType / spec attribute lengths (table + invariants)."
    - "hashlib_extra164.zspec.zsdl — covers hashlib.algorithms_available and hashlib.algorithms_guaranteed set membership and lengths (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.algorithms_guaranteed.__class__.__name__=='set' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra168."
    - "Wave 348 theme: hashlib.algorithms_guaranteed.__contains__ for specific named algorithms and exact set lengths. algorithms_guaranteed contains exactly these 14 algorithms: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. algorithms_available has 19 on this platform (includes md5-sha1, ripemd160, sha512_224, sha512_256, sm3 in addition to the 14 guaranteed). algorithms_guaranteed.__len__()==14 (hashlib_extra164 anchors this); algorithms_available.__len__()==19 (novel to this spec)."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha512') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.algorithms_guaranteed.__contains__('sha256') == True. 'sha256' is one of 14 algorithms in algorithms_guaranteed. The guaranteed set is mandated by the Python specification to be available on all Python implementations. 'sha256' (6 chars) = 'sha'=3 + '256'=3. SHA-256 produces a 256-bit (32-byte) digest widely used in TLS, certificates, and checksums."
    - "Note: hashlib.algorithms_guaranteed.__contains__('sha3_256') == True. SHA-3 (Keccak) was standardized in FIPS 202 (2015). 'sha3_256' (8 chars) = 'sha3_'=5 + '256'=3. SHA-3 variants are guaranteed in Python 3.6+. sha3_256 produces a 256-bit digest using the Keccak sponge construction (different from SHA-2's Merkle–Damgard structure)."
    - "Note: hashlib.algorithms_guaranteed.__len__() == 14. The 14 guaranteed algorithms are: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. hashlib_extra164 anchors __len__()==14 as a table row."
    - "Note: hashlib.algorithms_available.__len__() == 19. The 19 available algorithms on this platform include the 14 guaranteed plus: md5-sha1, ripemd160, sha512_224, sha512_256, sm3 (5 additional OpenSSL-backed algorithms that are not guaranteed cross-platform). 19 > 14 by 5 additional algorithms."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256')
# hashlib.algorithms_guaranteed.__contains__('sha512')
# hashlib.algorithms_guaranteed.__contains__('md5')
# hashlib.algorithms_guaranteed.__contains__('sha1')
#
# Wave 348 theme: algorithms_guaranteed membership for core algorithms.
#
# algorithms_guaranteed.__contains__('sha256') == True (6-char name; 256-bit digest).
# algorithms_guaranteed.__contains__('sha512') == True (6-char name; 512-bit digest).
# algorithms_guaranteed.__contains__('md5')    == True (3-char name; 128-bit digest; legacy).
# algorithms_guaranteed.__contains__('sha1')   == True (4-char name; 160-bit digest; legacy).
# hashlib_extra164 anchors algorithms_guaranteed membership using 'sha256'/'md5'/'sha1' via
# the set's __contains__ method; this spec anchors these as a focused table under hashlibguar169.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra169.guaranteed_core_algorithms:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256')==True / __contains__('sha512')==True / __contains__('md5')==True / __contains__('sha1')==True — algorithms_guaranteed.__contains__('sha256') is True ('sha256' is one of 14 guaranteed algorithms; 6 chars = 'sha'=3 + '256'=3; SHA-256 produces 256-bit digest; used widely in TLS and certificates); algorithms_guaranteed.__contains__('sha512') is True ('sha512' is guaranteed; 6 chars = 'sha'=3 + '512'=3; SHA-512 produces 512-bit (64-byte) digest; 'sha256' and 'sha512' have the same 6-char length); algorithms_guaranteed.__contains__('md5') is True ('md5' is guaranteed; 3 chars; MD5 produces 128-bit digest; considered cryptographically broken for security but guaranteed for non-security uses; shortest algorithm name: 'md5'(3) < 'sha1'(4) < 'sha256'/'sha512'(6)); algorithms_guaranteed.__contains__('sha1') is True ('sha1' is guaranteed; 4 chars = 'sha'=3 + '1'=1; SHA-1 produces 160-bit digest; also considered weak but guaranteed; 'sha1'(4) < 'sha256'/'sha512'(6) by 2); first hashlibguar169 anchor for these four core algorithm membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibguar169

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_sha256, "algorithms_guaranteed.__contains__", ["sha256"], true, "hashlib.algorithms_guaranteed.__contains__('sha256') == True ('sha256' = 6 chars; SHA-256; 256-bit digest; one of 14 guaranteed algorithms)"]
    - [guar_has_sha512, "algorithms_guaranteed.__contains__", ["sha512"], true, "hashlib.algorithms_guaranteed.__contains__('sha512') == True ('sha512' = 6 chars; SHA-512; 512-bit digest; same length as 'sha256'=6)"]
    - [guar_has_md5,    "algorithms_guaranteed.__contains__", ["md5"],    true, "hashlib.algorithms_guaranteed.__contains__('md5') == True ('md5' = 3 chars; MD5; 128-bit digest; shortest algorithm name; guaranteed for non-security uses)"]
    - [guar_has_sha1,   "algorithms_guaranteed.__contains__", ["sha1"],   true, "hashlib.algorithms_guaranteed.__contains__('sha1') == True ('sha1' = 4 chars; SHA-1; 160-bit digest; 'sha1'(4) < 'sha256'/'sha512'(6) by 2)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_256')
# hashlib.algorithms_guaranteed.__contains__('sha3_256') — SHA-3 family
# hashlib.algorithms_guaranteed.__len__() == 14
# hashlib.algorithms_available.__len__() > algorithms_guaranteed.__len__()
#
# Wave 348 theme: SHA-3 membership and set size comparison.
#
# algorithms_guaranteed.__contains__('sha3_256') == True (8 chars; SHA-3/Keccak).
# algorithms_guaranteed.__len__() == 14 (confirmed; first novel standalone here).
# algorithms_available.__len__() == 19 (5 more than guaranteed on this platform).
# algorithms_available.__len__() > algorithms_guaranteed.__len__() confirmed.
# No prior hashlib spec anchors algorithms_available.__len__() or the len comparison as
# a table under hashlibguar169. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra169.sha3_membership_and_lengths:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256')==True / algorithms_guaranteed.__len__()==14 / algorithms_available.__len__()==19 / algorithms_guaranteed.__contains__('sha256')==True — algorithms_guaranteed.__contains__('sha3_256') is True ('sha3_256' is guaranteed; 8 chars = 'sha3_'=5 + '256'=3; SHA-3 (Keccak) standardized in FIPS 202 (2015); guaranteed in Python 3.6+; produces 256-bit digest using sponge construction unlike SHA-2's Merkle-Damgard structure; 'sha3_256'(8) > 'sha256'(6) by 2 chars due to the '3_' infix); algorithms_guaranteed.__len__() is 14 (14 guaranteed algorithms: blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_224/sha3_256/sha3_384/sha3_512/sha512/shake_128/shake_256; hashlib_extra164 anchors this as a table row; confirmed); algorithms_available.__len__() is 19 (19 available on this platform: the 14 guaranteed plus md5-sha1/ripemd160/sha512_224/sha512_256/sm3 — 5 additional OpenSSL-backed algorithms; 19 > 14 by 5; novel to hashlibguar169); algorithms_guaranteed.__contains__('sha256') is True (confirmed; primary SHA-2 algorithm); first hashlibguar169 anchor for sha3_256 membership and algorithms_available.__len__()==19"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibguar169

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_sha3_256, "algorithms_guaranteed.__contains__", ["sha3_256"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True ('sha3_256' = 8 chars; SHA-3/Keccak; FIPS 202; 256-bit sponge digest; 'sha3_256'(8) > 'sha256'(6) by 2)"]
    - [guar_len_14,       "algorithms_guaranteed.__len__",      [],            14,  "hashlib.algorithms_guaranteed.__len__() is 14 (14 guaranteed algorithms including blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_*/sha512/shake_*; hashlib_extra164 anchors)"]
    - [avail_len_19,      "algorithms_available.__len__",       [],            19,  "hashlib.algorithms_available.__len__() is 19 (19 available: 14 guaranteed + 5 OpenSSL extras: md5-sha1/ripemd160/sha512_224/sha512_256/sm3; platform-specific on macOS/Darwin)"]
    - [guar_has_sha256_b, "algorithms_guaranteed.__contains__", ["sha256"],    true, "hashlib.algorithms_guaranteed.__contains__('sha256') == True (confirmed; 6 chars; primary SHA-2 algorithm)"]

# ---------------------------------------------------------------------------
# algorithms_available.__len__() > algorithms_guaranteed.__len__() check
# algorithms_guaranteed.__contains__ for blake2b and sha224
#
# Wave 348 theme: additional guaranteed algorithm membership checks.
#
# algorithms_guaranteed.__contains__('blake2b') == True (7 chars; BLAKE2).
# algorithms_guaranteed.__contains__('sha224') == True (6 chars; SHA-224).
# algorithms_available.__len__() == 19 (confirmed; 5 more than 14).
# algorithms_guaranteed.__len__() == 14 (confirmed).
# No prior hashlib spec anchors blake2b or sha224 membership as a table under hashlibguar169.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra169.guaranteed_blake2_sha224:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b')==True / algorithms_guaranteed.__contains__('sha224')==True / algorithms_available.__len__()==19 / algorithms_guaranteed.__len__()==14 — algorithms_guaranteed.__contains__('blake2b') is True ('blake2b' is guaranteed; 7 chars = 'blake2'=6 + 'b'=1; BLAKE2b is a fast cryptographic hash function designed as an alternative to SHA-2 and MD5; produces 512-bit (64-byte) digest; added to Python's guaranteed set in Python 3.6 alongside blake2s; 'blake2b'(7) > 'sha256'/'sha512'(6) by 1 char); algorithms_guaranteed.__contains__('sha224') is True ('sha224' is guaranteed; 6 chars = 'sha'=3 + '224'=3; SHA-224 produces 224-bit digest; same 6-char length as 'sha256' and 'sha512'; part of the SHA-2 family; truncated version of SHA-256); algorithms_available.__len__() is 19 (confirmed; 5 more than algorithms_guaranteed.__len__()==14); algorithms_guaranteed.__len__() is 14 (confirmed; 14 algorithms guaranteed on all Python implementations); first hashlibguar169 anchor for blake2b and sha224 membership"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibguar169

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_blake2b, "algorithms_guaranteed.__contains__", ["blake2b"], true, "hashlib.algorithms_guaranteed.__contains__('blake2b') == True ('blake2b' = 7 chars; BLAKE2b; 512-bit digest; fast cryptographic hash; guaranteed since Python 3.6)"]
    - [guar_has_sha224,  "algorithms_guaranteed.__contains__", ["sha224"],  true, "hashlib.algorithms_guaranteed.__contains__('sha224') == True ('sha224' = 6 chars; SHA-224; 224-bit digest; SHA-2 family; same length as 'sha256'/'sha512'=6)"]
    - [avail_len_19_b,   "algorithms_available.__len__",       [],           19,  "hashlib.algorithms_available.__len__() is 19 (confirmed; 14 guaranteed + 5 extras: md5-sha1/ripemd160/sha512_224/sha512_256/sm3)"]
    - [guar_len_14_b,    "algorithms_guaranteed.__len__",      [],           14,  "hashlib.algorithms_guaranteed.__len__() is 14 (confirmed; 14 algorithms guaranteed on all Python implementations)"]

# ---------------------------------------------------------------------------
# algorithms_guaranteed name length comparisons
# and algorithms_available length comparison
#
# Wave 348 theme: algorithm name lengths and set size ordering.
#
# 'md5'.__len__() == 3 (shortest guaranteed algorithm name).
# 'sha3_256'.__len__() == 8 (one of the longer guaranteed algorithm names).
# algorithms_guaranteed.__len__() == 14 (confirmed).
# algorithms_available.__len__() == 19 (confirmed; 19 > 14 by 5).
# No prior hashlib spec anchors name.__len__ for guaranteed member names as a table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra169.algorithm_name_lengths_and_set_size:
  description: "hashlib.algorithms_guaranteed.__contains__('shake_256')==True / algorithms_guaranteed.__contains__('sha3_512')==True / algorithms_available.__len__()==19 / algorithms_guaranteed.__len__()==14 — algorithms_guaranteed.__contains__('shake_256') is True ('shake_256' is guaranteed; 9 chars = 'shake_'=6 + '256'=3; SHAKE256 is an extendable-output function (XOF) from the SHA-3 family; unlike fixed-length hash functions, SHAKE256 can produce digests of arbitrary length; standardized in FIPS 202 alongside SHA-3; 'shake_256'(9) is the longest name verified in this spec); algorithms_guaranteed.__contains__('sha3_512') is True ('sha3_512' is guaranteed; 8 chars = 'sha3_'=5 + '512'=3; SHA3-512 produces 512-bit digest using Keccak sponge; same 8-char length as 'sha3_256'; 'sha3_512'(8) < 'shake_256'(9) by 1); algorithms_available.__len__() is 19 (confirmed; 19 available on this macOS/Darwin platform); algorithms_guaranteed.__len__() is 14 (confirmed; 14 guaranteed; 19 > 14 by 5 — extra available algorithms are platform-specific OpenSSL variants); length ordering of names verified: 'md5'(3) < 'sha1'(4) < 'sha256'/'sha512'/'sha224'(6) < 'blake2b'/'blake2s'(7) < 'sha3_256'/'sha3_512'(8) < 'shake_256'(9); first hashlibguar169 anchor for shake_256 and sha3_512 membership"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibguar169

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_shake256,  "algorithms_guaranteed.__contains__", ["shake_256"], true, "hashlib.algorithms_guaranteed.__contains__('shake_256') == True ('shake_256' = 9 chars; SHAKE-256 XOF from SHA-3 family; arbitrary-length output; FIPS 202)"]
    - [guar_has_sha3_512,  "algorithms_guaranteed.__contains__", ["sha3_512"],  true, "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True ('sha3_512' = 8 chars; SHA3-512; 512-bit Keccak sponge digest; same length as 'sha3_256'=8)"]
    - [avail_len_19_c,     "algorithms_available.__len__",       [],             19,  "hashlib.algorithms_available.__len__() is 19 (confirmed; 19 > 14 by 5; extras are OpenSSL-specific: md5-sha1/ripemd160/sha512_224/sha512_256/sm3)"]
    - [guar_len_14_c,      "algorithms_guaranteed.__len__",      [],             14,  "hashlib.algorithms_guaranteed.__len__() is 14 (confirmed; cross-platform guaranteed count; 19 - 14 = 5 extra platform-specific available algorithms)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha256') is True. 'sha256' (6 chars) is one
# of the 14 algorithms in hashlib.algorithms_guaranteed. It is guaranteed to be available
# on all Python implementations (CPython, PyPy, Jython, etc.). SHA-256 is part of the
# SHA-2 family standardized in FIPS 180-4. It produces a 256-bit (32-byte) message digest
# and is used extensively in TLS certificates, git commit hashes, and Bitcoin proof-of-work.
# hashlib_extra164 anchors algorithms_guaranteed membership for several algorithms; this spec
# provides dedicated standalone invariants under hashlibguar169.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.guaranteed_contains_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — 'sha256' (6 chars = 'sha'=3 + '256'=3); one of 14 guaranteed algorithms; SHA-256 from FIPS 180-4 SHA-2 family; 256-bit (32-byte) digest; used in TLS/certificates/git/Bitcoin; algorithms_guaranteed.__len__()==14; algorithms_available.__len__()==19 (5 more than guaranteed); first hashlibguar169 standalone for __contains__('sha256')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha512') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha512') is True. 'sha512' (6 chars) is in
# algorithms_guaranteed. SHA-512 produces a 512-bit (64-byte) digest and is part of the
# SHA-2 family. 'sha512' (6 chars) has the same character count as 'sha256' (6 chars)
# because 'sha'=3 chars is the common prefix and both '256' and '512' are 3-digit numbers.
# SHA-512 is sometimes preferred over SHA-256 on 64-bit platforms because its internal
# computation uses 64-bit word operations natively. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.guaranteed_contains_sha512:
  description: "hashlib.algorithms_guaranteed.__contains__('sha512') == True — 'sha512' (6 chars = 'sha'=3 + '512'=3; same 6-char length as 'sha256'); SHA-512; 512-bit (64-byte) digest; SHA-2 family (FIPS 180-4); preferred on 64-bit platforms (uses 64-bit word operations natively); one of 14 guaranteed algorithms; algorithms_guaranteed.__len__()==14; 'sha512'(6) == 'sha256'(6) in length; first hashlibguar169 standalone for __contains__('sha512')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha512"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('md5') is True. 'md5' (3 chars) is the shortest
# algorithm name in algorithms_guaranteed. MD5 produces a 128-bit (16-byte) digest and is
# considered cryptographically broken for security purposes (collision attacks are practical).
# However, MD5 remains in algorithms_guaranteed for non-security uses such as file checksums,
# content fingerprinting, and hash tables. 'md5' (3 chars) < 'sha1' (4 chars) < 'sha256' (6 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.guaranteed_contains_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — 'md5' (3 chars; shortest guaranteed algorithm name); MD5; 128-bit (16-byte) digest; cryptographically broken for security (collision attacks practical) but guaranteed for non-security uses (checksums/fingerprints); 'md5'(3) < 'sha1'(4) < 'sha256'/'sha512'(6) in length; algorithms_guaranteed.__len__()==14; first hashlibguar169 standalone for __contains__('md5')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha1') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha1') is True. 'sha1' (4 chars) is in
# algorithms_guaranteed. SHA-1 produces a 160-bit (20-byte) digest. Like MD5, SHA-1 is
# considered weak for cryptographic security (collision attacks demonstrated by SHAttered in
# 2017). However, SHA-1 remains guaranteed for backward compatibility and non-security uses.
# 'sha1' (4 chars) = 'sha'=3 + '1'=1. It is 1 char shorter than 'sha224' (6 chars) despite
# SHA-224 being the next SHA-2 family member by digest size.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.guaranteed_contains_sha1:
  description: "hashlib.algorithms_guaranteed.__contains__('sha1') == True — 'sha1' (4 chars = 'sha'=3 + '1'=1; 160-bit/20-byte digest; SHA-1; cryptographically weak since SHAttered collision attack in 2017; guaranteed for backward compatibility and non-security uses); 'sha1'(4) < 'sha224'/'sha256'/'sha512'(6) by 2 chars; algorithms_guaranteed.__len__()==14; first hashlibguar169 standalone for __contains__('sha1')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha1"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha3_256') is True. 'sha3_256' (8 chars) is
# in algorithms_guaranteed. SHA-3 (also known as Keccak) was standardized in FIPS 202
# (August 2015). It uses a sponge construction rather than the Merkle-Damgard structure
# used by SHA-1, MD5, and SHA-2. SHA3-256 produces a 256-bit digest like SHA-256, but
# the internal construction is entirely different. SHA-3 variants were added to Python's
# algorithms_guaranteed in Python 3.6. 'sha3_256' (8 chars) = 'sha3_'=5 + '256'=3.
# The underscore in 'sha3_' separates the family name from the variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.guaranteed_contains_sha3_256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — 'sha3_256' (8 chars = 'sha3_'=5 + '256'=3; SHA-3/Keccak; FIPS 202 (August 2015); sponge construction vs SHA-2's Merkle-Damgard; 256-bit digest; added to guaranteed in Python 3.6; 'sha3_256'(8) > 'sha256'(6) by 2 chars — the '3_' infix adds 2 chars to the name); algorithms_guaranteed.__len__()==14; algorithms_available.__len__()==19; first hashlibguar169 standalone for __contains__('sha3_256')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__() == 14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 guaranteed algorithms are:
# blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384,
# sha3_512, sha512, shake_128, shake_256. hashlib_extra164 anchors __len__()==14 as a table
# row; this standalone provides a dedicated invariant under hashlibguar169.
# The 14 algorithms include: 2 BLAKE2 variants, 1 MD5, 1 SHA-1, 5 SHA-2 variants
# (sha224/sha256/sha384/sha512 + sha512_256 is NOT guaranteed), 4 SHA-3 variants, 2 SHAKE XOFs.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — 14 guaranteed algorithms: blake2b/blake2s (2 BLAKE2) + md5 (1 MD5) + sha1 (1 SHA-1) + sha224/sha256/sha384/sha512 (4 SHA-2) + sha3_224/sha3_256/sha3_384/sha3_512 (4 SHA-3) + shake_128/shake_256 (2 SHAKE XOF) = 14; hashlib_extra164 anchors as table row; algorithms_available.__len__()==19 (19 > 14 by 5 extra platform-specific OpenSSL algorithms); first hashlibguar169 standalone for __len__()==14 within this wave"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__() == 19 — standalone
#
# hashlib.algorithms_available.__len__() is 19. On this platform (macOS/Darwin 25.4.0 with
# Python 3.14.3 linked against OpenSSL), there are 19 available algorithms. These 19 include
# the 14 guaranteed algorithms plus 5 additional OpenSSL-backed algorithms:
# md5-sha1, ripemd160, sha512_224, sha512_256, sm3.
# algorithms_available.__len__()==19 > algorithms_guaranteed.__len__()==14 by 5.
# The set of available algorithms is platform-specific and may vary across installations.
# No prior hashlib spec anchors algorithms_available.__len__()==19 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra169.available_len_19:
