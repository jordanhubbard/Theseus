       [],
       7,
       "uuid.UUID.__int__.__name__.__len__() == 7 — '__int__' has 7 characters; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID dunder method __name__ lengths — group of 8 chars and qualname
#
# uuid.UUID.__init__.__name__.__len__()   == 8
# uuid.UUID.__repr__.__name__.__len__()   == 8
# uuid.UUID.__hash__.__name__.__len__()   == 8
# uuid.UUID.__qualname__.__len__()        == 4
#
# __init__, __repr__, and __hash__ all have four-character stems flanked by
# double underscores (8 characters total).  The class __qualname__ is simply
# 'UUID', which is 4 characters.
# ---------------------------------------------------------------------------

table uuid_extra181.uuid_dunder_names_len8_and_qualname:
  description: "uuid.UUID dunder method __name__ lengths (len=8) and __qualname__ length; new to extra181"
