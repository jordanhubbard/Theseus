  rows:
    - [str_name_eq,
       uuid.UUID.__str__.__name__.__eq__,
       ["__str__"],
       true,
       "uuid.UUID.__str__.__name__.__eq__('__str__') == True — dunder method name; len=7; new to extra181"]
    - [str_name_len,
       uuid.UUID.__str__.__name__.__len__,
       [],
       7,
       "uuid.UUID.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; new to extra181"]
    - [int_name_eq,
       uuid.UUID.__int__.__name__.__eq__,
       ["__int__"],
       true,
       "uuid.UUID.__int__.__name__.__eq__('__int__') == True — dunder method name; len=7; new to extra181"]
    - [int_name_len,
