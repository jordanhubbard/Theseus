spec: uuid_extra181
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID.__init__.__name__ == '__init__' — len=8; dunder method name."
    - "uuid.UUID.__str__.__name__ == '__str__' — len=7; dunder method name."
    - "uuid.UUID.__repr__.__name__ == '__repr__' — len=8; dunder method name."
    - "uuid.UUID.__eq__.__name__ == '__eq__' — len=6; shortest dunder among the set."
    - "uuid.UUID.__hash__.__name__ == '__hash__' — len=8; dunder method name."
    - "uuid.UUID.__int__.__name__ == '__int__' — len=7; dunder method name."
    - "Length ordering: __eq__(6) < __str__(7)==__int__(7) < __init__(8)==__repr__(8)==__hash__(8)."
    - "uuid.UUID.__qualname__ == 'UUID' — len=4; simple unqualified class name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID dunder method __name__ length — group of 6 chars
#
# uuid.UUID.__eq__.__name__.__len__()  == 6
#
# __eq__ is the shortest dunder name in this set.  The five-character stem
# 'eq' flanked by double underscores gives exactly 6 characters.
# ---------------------------------------------------------------------------

table uuid_extra181.uuid_dunder_names_len6:
  description: "uuid.UUID dunder method __name__ identity and length — __eq__ group (len=6); new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: uuidnamelens181

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name_eq,
       uuid.UUID.__eq__.__name__.__eq__,
       ["__eq__"],
       true,
       "uuid.UUID.__eq__.__name__.__eq__('__eq__') == True — dunder method name; len=6; new to extra181"]
    - [eq_name_len,
       uuid.UUID.__eq__.__name__.__len__,
       [],
       6,
       "uuid.UUID.__eq__.__name__.__len__() == 6 — '__eq__' has 6 characters; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID dunder method __name__ lengths — group of 7 chars
#
# uuid.UUID.__str__.__name__.__len__()  == 7
# uuid.UUID.__int__.__name__.__len__()  == 7
#
# __str__ and __int__ each have a three-character stem flanked by double
# underscores, giving 7 characters total.
# ---------------------------------------------------------------------------

