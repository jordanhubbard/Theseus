table itertools_extra1156.package_loader_class_names:
  description: "itertools.__package__ and __loader__ class name identity"
  kind: python_call_eq
  category: package_loader_class_names
  id_prefix: it1156pl
  columns: [id, function, args, expected]
  rows:
    - [it1156pl001, itertools.__package__.__class__.__name__.__eq__,                ["str"],                          true]
    - [it1156pl002, itertools.__package__.__eq__,                                   ["itertools"],                    true]
    - [it1156pl003, itertools.__loader__.__class__.__name__.__eq__,                 ["BuiltinImporter"],              true]
    - [it1156pl004, itertools.__name__.__eq__,                                      ["itertools"],                    true]
    - [it1156pl005, itertools.__spec__.name.__eq__,                                 ["itertools"],                    true]
    - [it1156pl006, itertools.__doc__.__class__.__name__.__eq__,                    ["str"],                          true]
    - [it1156pl007, itertools.chain.__class__.__name__.__eq__,                      ["type"],                         true]
    - [it1156pl008, itertools.cycle.__class__.__name__.__eq__,                      ["type"],                         true]

