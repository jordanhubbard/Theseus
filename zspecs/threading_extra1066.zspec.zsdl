spec: threading_extra1066
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.local() qualnames, Timer method qualnames (start, cancel, run), Condition method qualnames (acquire, release, wait, notify), and Event method qualnames (set, clear, wait, is_set)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1066.local_and_timer_qualnames:
  description: "threading.local class qualnames and threading.Timer method __qualname__ checks"
  kind: python_call_eq
  category: local_timer_qualnames
  id_prefix: th1066lt
  columns: [id, function, args, expected]
  rows:
    - [th1066lt001, threading.local.__qualname__.__eq__,               ["local"],                  true]
    - [th1066lt002, threading.local.__module__.__eq__,                 ["_thread"],                true]
    - [th1066lt003, threading.local.__class__.__name__.__eq__,         ["type"],                   true]
    - [th1066lt004, threading.Timer.__qualname__.__eq__,               ["Timer"],                  true]
    - [th1066lt005, threading.Timer.__module__.__eq__,                 ["threading"],              true]
    - [th1066lt006, threading.Timer.start.__qualname__.__eq__,         ["Thread.start"],           true]
    - [th1066lt007, threading.Timer.cancel.__qualname__.__eq__,        ["Timer.cancel"],           true]
    - [th1066lt008, threading.Timer.run.__qualname__.__eq__,           ["Timer.run"],              true]

table threading_extra1066.condition_method_qualnames:
  description: "threading.Condition method __qualname__ identity checks"
  kind: python_call_eq
  category: condition_qualnames
  id_prefix: th1066co
  columns: [id, function, args, expected]
  rows:
    - [th1066co001, threading.Condition.__qualname__.__eq__,                 ["Condition"],                     true]
    - [th1066co002, threading.Condition.__module__.__eq__,                   ["threading"],                     true]
    - [th1066co003, threading.Condition.acquire.__qualname__.__eq__,         ["Condition.acquire"],             true]
    - [th1066co004, threading.Condition.release.__qualname__.__eq__,         ["Condition.release"],             true]
    - [th1066co005, threading.Condition.wait.__qualname__.__eq__,            ["Condition.wait"],                true]
    - [th1066co006, threading.Condition.notify.__qualname__.__eq__,          ["Condition.notify"],              true]
    - [th1066co007, threading.Condition.notify_all.__qualname__.__eq__,      ["Condition.notify_all"],          true]
    - [th1066co008, threading.Condition.__init__.__qualname__.__eq__,        ["Condition.__init__"],            true]

table threading_extra1066.event_method_qualnames:
  description: "threading.Event method __qualname__ identity checks"
  kind: python_call_eq
  category: event_qualnames
  id_prefix: th1066ev
  columns: [id, function, args, expected]
  rows:
    - [th1066ev001, threading.Event.__qualname__.__eq__,                     ["Event"],                         true]
    - [th1066ev002, threading.Event.__module__.__eq__,                       ["threading"],                     true]
    - [th1066ev003, threading.Event.set.__qualname__.__eq__,                  ["Event.set"],                     true]
    - [th1066ev004, threading.Event.clear.__qualname__.__eq__,               ["Event.clear"],                   true]
    - [th1066ev005, threading.Event.wait.__qualname__.__eq__,                ["Event.wait"],                    true]
    - [th1066ev006, threading.Event.is_set.__qualname__.__eq__,              ["Event.is_set"],                  true]
    - [th1066ev007, threading.Event.__init__.__qualname__.__eq__,            ["Event.__init__"],                true]
    - [th1066ev008, threading.Event.__class__.__name__.__eq__,               ["type"],                          true]
