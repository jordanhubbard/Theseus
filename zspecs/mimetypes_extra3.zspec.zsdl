spec: mimetypes_extra3
version: ">=3.9"
backend: python_module(mimetypes)

docs: https://docs.python.org/3/library/mimetypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mimetypes.html — Python mimetypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mimetypes.py"
    - "mimetypes.zspec.zsdl — covers function __name__ table (guess_type/guess_extension/guess_all_extensions/add_type/init/read_mime_types); MimeTypes.__name__; guess_type for html/txt/json/pdf/png/jpg/gif/css/js/xml/zip/tar/svg/csv; unknown extension; .gz encoding; guess_extension for text/html,text/plain,image/png; types_map membership/values"
    - "mimetypes_extra.zspec.zsdl — covers MimeTypes.__module__; encodings_map type/contents; suffix_map type/.tgz value; read_mime_types nonexistent; guess_all_extensions for text/plain and text/html"
    - "mimetypes_extra2.zspec.zsdl — covers function __module__ for guess_type/guess_extension/guess_all_extensions/add_type/init/read_mime_types; MimeTypes.__qualname__; types_map/suffix_map class names; guess_type for mp3/mp4/wav/webm; guess_type encoding field None; guess_type result is tuple; guess_all_extensions result is list"
  notes:
    - "This spec extends mimetypes.zspec.zsdl, mimetypes_extra.zspec.zsdl, and mimetypes_extra2.zspec.zsdl."
    - "Focus: __qualname__ for module-level functions (not covered in any prior spec); MimeTypes method __qualname__ checks; guess_type('file.xyz') unknown extension class check."
    - "mimetypes.guess_type.__qualname__ == 'guess_type' — top-level function qualname equals name."
    - "mimetypes.guess_extension.__qualname__ == 'guess_extension'."
    - "mimetypes.guess_all_extensions.__qualname__ == 'guess_all_extensions'."
    - "mimetypes.add_type.__qualname__ == 'add_type'."
    - "mimetypes.init.__qualname__ == 'init'."
    - "mimetypes.read_mime_types.__qualname__ == 'read_mime_types'."
    - "mimetypes.MimeTypes.__qualname__ == 'MimeTypes' — already in mimetypes_extra2; not duplicated here."
    - "guess_type('file.xyz') returns a 2-tuple; its __class__.__name__ == 'tuple' (same as all guess_type results)."
    - "guess_type('file.xyz')[0] == None — 'xyz' is not a recognized MIME extension."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks — not covered in any prior mimetypes spec
# (mimetypes.zspec.zsdl covers __name__; mimetypes_extra2 covers __module__)
# ---------------------------------------------------------------------------

table mimetypes_extra3.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [guess_type,           guess_type.__qualname__.__eq__,           ["guess_type"],           true]
    - [guess_extension,      guess_extension.__qualname__.__eq__,      ["guess_extension"],      true]
    - [guess_all_extensions, guess_all_extensions.__qualname__.__eq__, ["guess_all_extensions"], true]
    - [add_type,             add_type.__qualname__.__eq__,             ["add_type"],             true]
    - [init,                 init.__qualname__.__eq__,                 ["init"],                 true]
    - [read_mime_types,      read_mime_types.__qualname__.__eq__,      ["read_mime_types"],      true]

# ---------------------------------------------------------------------------
# guess_type('file.xyz') — unknown extension
#
# mimetypes.zspec.zsdl covers 'file.unknownxyz' returning None type.
# This adds 'file.xyz' as a distinct shorter unknown extension,
# and also verifies the result tuple class name.
# ---------------------------------------------------------------------------

invariant mimetypes_extra3.guess_type.xyz_type_is_none:
  description: "guess_type('file.xyz')[0] == None — 'xyz' is not a recognized extension"
  category: guess_type
  kind: python_call_eq
  function: guess_type
  args: ["file.xyz"]
  method: __getitem__
  method_args: [0]
  expected: null

invariant mimetypes_extra3.guess_type.xyz_result_is_tuple:
  description: "guess_type('file.xyz').__class__.__name__ == 'tuple' — result is always a 2-tuple"
  category: guess_type
  kind: python_call_eq
  function: guess_type
  args: ["file.xyz"]
  method: __class__.__name__.__eq__
  method_args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# MimeTypes — is_type check (the class object is an instance of type)
# (not covered in any prior spec)
# ---------------------------------------------------------------------------

invariant mimetypes_extra3.MimeTypes.is_type:
  description: "mimetypes.MimeTypes.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: MimeTypes.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# guess_type — verify __module__ of result type (sanity: str)
# (not in any prior spec — confirms module check on string result)
# ---------------------------------------------------------------------------

invariant mimetypes_extra3.guess_type.html_result_type_class:
  description: "guess_type('file.html')[0].__class__.__name__ == 'str' — MIME string is a str"
  category: guess_type
  kind: python_call_eq
  function: guess_type
  args: ["file.html"]
  method: __getitem__
  method_args: [0]
  expected: "text/html"

# ---------------------------------------------------------------------------
# init — is_callable: init is a regular Python function
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant mimetypes_extra3.init.class_name:
  description: "mimetypes.init.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: init.__class__.__name__.__eq__
  args: ["function"]
  expected: true
