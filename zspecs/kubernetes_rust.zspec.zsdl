spec: kubernetes_rust
version: ">=3.9"
backend: rust_module(kubernetes_rust)

docs: https://github.com/kubernetes-client/python

provenance:
  derived_from:
    - "https://github.com/kubernetes-client/python — kubernetes-client documentation"
  not_derived_from:
    - "kubernetes source: kubernetes/__init__.py"
  notes:
    - "kubernetes is the Python client for Kubernetes."
    - "kubernetes.client is available."
    - "kubernetes.client.CoreV1Api is available."
    - "kubernetes.config is available."
    - "kubernetes.__version__ is a non-empty string."
    - "Expose k8s_has_client() -> bool: hasattr(kubernetes, 'client')."
    - "Expose k8s_has_config() -> bool: hasattr(kubernetes, 'config')."
    - "Expose k8s_version_nonempty() -> bool: len(kubernetes.__version__) > 0."
    - "All test vectors verified against kubernetes 32.0.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# k8s_has_client — client module present
invariant kubernetes_rust.module.has_client:
  description: "kubernetes.client is available"
  category: module
  kind: python_call_eq
  function: k8s_has_client
  args: []
  expected: true

# k8s_has_config — config module present
invariant kubernetes_rust.module.has_config:
  description: "kubernetes.config is available"
  category: module
  kind: python_call_eq
  function: k8s_has_config
  args: []
  expected: true

# k8s_version_nonempty — version non-empty
invariant kubernetes_rust.version.nonempty:
  description: "kubernetes.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: k8s_version_nonempty
  args: []
  expected: true

