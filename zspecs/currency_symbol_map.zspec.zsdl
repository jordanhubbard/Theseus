spec: currency_symbol_map
version: ">=5.1.0"
backend: node(currency-symbol-map)

docs: https://www.npmjs.com/package/currency-symbol-map

provenance:
  derived_from:
    - "currency-symbol-map README — https://www.npmjs.com/package/currency-symbol-map"
    - "Test vectors verified with currency-symbol-map via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "currency-symbol-map source"
  notes:
    - "currency-symbol-map is an npm package. Install: npm install currency-symbol-map"
    - "Returns the currency symbol for a given ISO 4217 currency code."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string symbol or undefined for unknown codes."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table currency_symbol_map.getSymbol:
  kind: node_module_call_eq
  function: ~
  category: lookup
  id_prefix: cursym

  columns: [id, args, expected]
  rows:
    - [usd,  ["USD"],  "$"]
    - [eur,  ["EUR"],  "€"]
    - [gbp,  ["GBP"],  "£"]
    - [jpy,  ["JPY"],  "¥"]

