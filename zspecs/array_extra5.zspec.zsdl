spec: array_extra5
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl, array_extra.zspec.zsdl, array_extra2.zspec.zsdl, array_extra3.zspec.zsdl, and array_extra4.zspec.zsdl."
    - "array_extra covers: array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for b."
    - "array_extra2 covers: typecodes is str + min_length, typecodes.contains for b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr table."
    - "array_extra3 covers: ArrayType.__module__, itemsize H/I, typecode H/d/class_name_str, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4 covers: typecodes.contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, tolist Q/q, array.__qualname__, bases_object, getitem B[1]."
    - "This spec adds: ArrayType.__qualname__ (first __qualname__ check for the alias; extra4 added array.__qualname__); typecodes.__contains__('I') (unsigned int, not in extra2 or extra4 tables); tobytes() return type is bytes (new behavioral vector); array('i',[1,2,3]).itemsize >= 1 (lower-bound guard, new style); array('b',[1,2,3]).tobytes().__len__() == 3 (byte length equals element count for 'b')."
    - "array.ArrayType.__qualname__ == 'array' — ArrayType is an alias for array.array; its __qualname__ equals the class name."
    - "array.typecodes.__contains__('I') == True — unsigned int typecode is present on all platforms."
    - "array.array('b', [1,2,3]).tobytes().__class__.__name__ == 'bytes' — tobytes() always returns a bytes object."
    - "array.array('b', [1,2,3]).tobytes().__len__() == 3 — for 'b' (1 byte each), 3 elements produce 3 bytes."
    - "array.array('i', [1,2,3]).itemsize >= 1 — itemsize of any typecode is at least 1 byte."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ArrayType.__qualname__ — the alias shares the same C-level type; its
# __qualname__ is 'array' (same as array.array.__qualname__).
# array_extra has ArrayType.__name__ == 'array'; array_extra3 has
# ArrayType.__module__ == 'array'; __qualname__ is new.
# ---------------------------------------------------------------------------

invariant array_extra5.ArrayType.qualname:
  description: "array.ArrayType.__qualname__ == 'array' — ArrayType alias __qualname__ equals the type name"
  category: arraytype_alias
  kind: python_call_eq
  function: ArrayType.__qualname__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# typecodes.__contains__ — unsigned int 'I'
# array_extra2 table covers: b, B, h, i, l, q, f, d
# array_extra4 table covers: H, L, Q
# 'I' (unsigned int) is not in either table — new here.
# ---------------------------------------------------------------------------

invariant array_extra5.typecodes.contains_I:
  description: "array.typecodes.__contains__('I') == True — unsigned int typecode is present"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__contains__
  args: ["I"]
  expected: true

# ---------------------------------------------------------------------------
# tobytes() — return type is bytes, and byte length for 'b' equals element count
# Not covered in any prior array spec.
# ---------------------------------------------------------------------------

invariant array_extra5.tobytes.class_name:
  description: "array.array('b', [1,2,3]).tobytes().__class__.__name__ == 'bytes'"
  category: tobytes
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: tobytes
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant array_extra5.tobytes.length_b:
  description: "array.array('b', [1,2,3]).tobytes().__len__() == 3 — 'b' is 1 byte each, 3 elements → 3 bytes"
  category: tobytes
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: tobytes
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 3

# ---------------------------------------------------------------------------
# itemsize lower-bound guard — any valid typecode has itemsize >= 1
# Prior specs assert exact itemsize values; this is a new lower-bound-only check.
# ---------------------------------------------------------------------------

invariant array_extra5.itemsize.signed_int_ge1:
  description: "array.array('i', [1,2,3]).itemsize >= 1 — itemsize of any typecode is at least 1 byte"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: itemsize.__ge__
  method_args: [1]
  expected: true
