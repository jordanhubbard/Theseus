spec: lodash_sortedindexof
version: ">=4.0.0"
backend: node(lodash.sortedindexof)

docs: https://lodash.com/docs/#sortedIndexOf

provenance:
  derived_from:
    - "lodash.sortedindexof README — https://www.npmjs.com/package/lodash.sortedindexof"
    - "Test vectors verified with lodash.sortedindexof@4.1.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sortedindexof exports the _.sortedIndexOf function directly as module.exports."
    - "sortedIndexOf(array, value) uses binary search to find the first index of value."
    - "Returns -1 if not found."
    - "Array must be sorted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns first index of value using binary search, or -1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sortedindexof.sortedindexof:
  kind: node_module_call_eq
  function: ~
  category: sortedindexof
  id_prefix: lsiof

  columns: [id, args, expected]
  rows:
    - [first,      [[4, 5, 5, 5, 6], 5],   1]
    - [only,       [[1, 2, 3, 4, 5], 3],   2]
    - [not_found,  [[1, 2, 3], 0],         -1]
