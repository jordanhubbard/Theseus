spec: fractions_extra22
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra22.zspec.zsdl."
    - "Prior specs covered: Fraction class, arithmetic, __name__/__module__/__qualname__, Fraction.__bases__, fractions.__name__/__package__, Fraction(1,2).numerator/denominator, limit_denominator, from_float, from_decimal, Fraction.__init__.__name__, various arithmetic ops, Fraction.__add__ qualname, Fraction.__repr__/__str__/__format__ qualnames, limit_denominator/from_decimal/from_float qualnames."
    - "This spec covers: Fraction.__str__.__name__, Fraction.__repr__.__name__, Fraction.__repr__.__qualname__, Fraction.__abs__.__name__, Fraction.__neg__.__name__, Fraction.__pos__.__name__, Fraction.__name__ as proxy for instance __class__.__name__."
    - "Fraction.__str__.__name__ == '__str__' — the simple dunder name, not the qualname."
    - "Fraction.__repr__.__qualname__ == 'Fraction.__repr__' — already covered in fractions_extra21 via table; verified again here as standalone invariant."
    - "Fraction.__abs__, __neg__, __pos__ are all defined directly on Fraction; their __name__ values are '__abs__', '__neg__', '__pos__' respectively."
    - "Fraction.__name__ == 'Fraction' — this is also the value of Fraction(n,d).__class__.__name__ for any valid n,d."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__str__.__name__ and Fraction.__repr__.__name__
#
# fractions_extra21 records __qualname__ for __str__ and __repr__ but not
# their __name__ attributes.  The simple __name__ of each dunder method
# equals the bare dunder string (e.g. '__str__'), not the qualified form.
# ---------------------------------------------------------------------------

invariant fractions_extra22.Fraction.str_name:
  description: "fractions.Fraction.__str__.__name__ == '__str__'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

invariant fractions_extra22.Fraction.str_name_len:
  description: "len(fractions.Fraction.__str__.__name__) == 7 — '__str__' is 7 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__str__.__name__.__len__
  args: []
  expected: 7

invariant fractions_extra22.Fraction.repr_name:
  description: "fractions.Fraction.__repr__.__name__ == '__repr__'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant fractions_extra22.Fraction.repr_name_len:
  description: "len(fractions.Fraction.__repr__.__name__) == 8 — '__repr__' is 8 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Fraction.__repr__.__qualname__
#
# fractions_extra21 records this in a table row.  Covered here as a
# standalone invariant for direct attribution.
# ---------------------------------------------------------------------------

invariant fractions_extra22.Fraction.repr_qualname:
  description: "fractions.Fraction.__repr__.__qualname__ == 'Fraction.__repr__'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__qualname__.__eq__
  args: ["Fraction.__repr__"]
  expected: true

invariant fractions_extra22.Fraction.repr_qualname_len:
  description: "len(fractions.Fraction.__repr__.__qualname__) == 17 — 'Fraction.__repr__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# Unary arithmetic method __name__ values: __abs__, __neg__, __pos__
#
# No prior spec records __name__ for Fraction.__abs__, __neg__, or __pos__.
# All three are defined directly on Fraction; their __name__ equals the bare
# dunder string.
# ---------------------------------------------------------------------------

table fractions_extra22.unary_method_names:
  kind: python_call_eq
  category: method_identity
  id_prefix: name

  columns: [id, function, args, expected, description]
  rows:
    - [abs, Fraction.__abs__.__name__.__eq__, ["__abs__"], true, "fractions.Fraction.__abs__.__name__ == '__abs__'"]
    - [neg, Fraction.__neg__.__name__.__eq__, ["__neg__"], true, "fractions.Fraction.__neg__.__name__ == '__neg__'"]
    - [pos, Fraction.__pos__.__name__.__eq__, ["__pos__"], true, "fractions.Fraction.__pos__.__name__ == '__pos__'"]

# ---------------------------------------------------------------------------
# Unary arithmetic method __name__ length invariants
# (all three dunder names have the same length: 7 chars)
# ---------------------------------------------------------------------------

invariant fractions_extra22.Fraction.abs_name_len:
  description: "len(fractions.Fraction.__abs__.__name__) == 7 — '__abs__' is 7 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__abs__.__name__.__len__
  args: []
  expected: 7

invariant fractions_extra22.Fraction.neg_name_len:
  description: "len(fractions.Fraction.__neg__.__name__) == 7 — '__neg__' is 7 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__neg__.__name__.__len__
  args: []
  expected: 7

invariant fractions_extra22.Fraction.pos_name_len:
  description: "len(fractions.Fraction.__pos__.__name__) == 7 — '__pos__' is 7 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__pos__.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Fraction.__name__ as the canonical class name
#
# No prior spec records Fraction.__name__ as a standalone invariant verifying
# the class name string itself (prior specs use __qualname__ and __module__).
# Fraction.__name__ == 'Fraction' — this is also the value returned by
# Fraction(n,d).__class__.__name__ for any valid numerator/denominator pair.
# ---------------------------------------------------------------------------

invariant fractions_extra22.Fraction.class_name:
  description: "fractions.Fraction.__name__ == 'Fraction'"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra22.Fraction.class_name_len:
  description: "len(fractions.Fraction.__name__) == 8 — 'Fraction' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__name__.__len__
  args: []
  expected: 8
