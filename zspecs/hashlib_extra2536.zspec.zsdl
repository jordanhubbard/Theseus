spec: hashlib_extra2536
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "This spec focuses on __format__, __bytes__, and __fspath__ dict-presence for the HASH class and related hashlib classes."
    - "hashlib.zspec.zsdl covers: sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors; digest_size/block_size attrs; algorithms_guaranteed; digest_consistency, copy_independence, api_equivalence."
    - "hashlib_extra.zspec.zsdl covers: blake2b/blake2s/sha3_224/sha3_384 attrs; algorithms_available; pbkdf2_hmac."
    - "hashlib_extra2.zspec.zsdl covers: hexdigest known vectors; digest_size via python_call_eq; algorithms_guaranteed type; new() api."
    - "HASH = type(hashlib.md5()) — the concrete HASH class has __repr__ but NOT __format__, __bytes__, or __fspath__ in its __dict__."
    - "hashlib HASH.__dict__ contains: __repr__, update, digest, hexdigest, copy, digest_size, block_size, name, __doc__, __module__."
    - "No custom __format__ means format(h, '') falls back to object.__format__; no __bytes__ means bytes(h) raises TypeError."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH class __dict__ presence: __format__ absent
# ---------------------------------------------------------------------------

table hashlib_extra2536.HASH.format_absent:
  description: "HASH.__dict__ does NOT contain __format__ — no custom formatting protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2536

  columns: [id, function, args, expected]
  rows:
    - ["hl2536-fmt-absent", HASH.__dict__.__contains__, ["__format__"], false]

# ---------------------------------------------------------------------------
# HASH class __dict__ presence: __bytes__ absent
# ---------------------------------------------------------------------------

table hashlib_extra2536.HASH.bytes_absent:
  description: "HASH.__dict__ does NOT contain __bytes__ — no bytes-conversion protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2536

  columns: [id, function, args, expected]
  rows:
    - ["hl2536-bytes-absent", HASH.__dict__.__contains__, ["__bytes__"], false]

# ---------------------------------------------------------------------------
# HASH class __dict__ presence: __fspath__ absent
# ---------------------------------------------------------------------------

table hashlib_extra2536.HASH.fspath_absent:
  description: "HASH.__dict__ does NOT contain __fspath__ — no filesystem-path protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2536

  columns: [id, function, args, expected]
  rows:
    - ["hl2536-fspath-absent", HASH.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# HASH class __dict__ presence: members that ARE present (positive control)
# These confirm __dict__.__contains__ works correctly for HASH.
# ---------------------------------------------------------------------------

table hashlib_extra2536.HASH.dict_present:
  description: "HASH.__dict__ DOES contain these members (positive-control checks)"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2536

  columns: [id, function, args, expected]
  rows:
    - ["hl2536-repr-present",    HASH.__dict__.__contains__, ["__repr__"],    true]
    - ["hl2536-update-present",  HASH.__dict__.__contains__, ["update"],      true]
    - ["hl2536-digest-present",  HASH.__dict__.__contains__, ["digest"],      true]
    - ["hl2536-hexdigest-present", HASH.__dict__.__contains__, ["hexdigest"], true]
    - ["hl2536-copy-present",    HASH.__dict__.__contains__, ["copy"],        true]
    - ["hl2536-name-present",    HASH.__dict__.__contains__, ["name"],        true]

# ---------------------------------------------------------------------------
# HASH class __dict__ presence: all three protocols absent in one table
# Consolidates the three absent checks for compact cross-reference.
# ---------------------------------------------------------------------------

table hashlib_extra2536.HASH.protocol_dunders_absent:
  description: "HASH.__dict__ contains none of __format__, __bytes__, __fspath__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2536

  columns: [id, function, args, expected]
  rows:
    - ["hl2536-p1-fmt",   HASH.__dict__.__contains__, ["__format__"], false]
    - ["hl2536-p1-bytes", HASH.__dict__.__contains__, ["__bytes__"],  false]
    - ["hl2536-p1-fspath", HASH.__dict__.__contains__, ["__fspath__"], false]
