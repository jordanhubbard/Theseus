spec: inspect_extra1036
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ of inspect predicate functions covering frame, code, builtin, method-wrapper, and descriptor variants"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1036.frame_code_builtin_qualnames:
  description: "inspect.isframe, iscode, isbuiltin __qualname__ identity checks"
  kind: python_call_eq
  category: predicate_qualnames
  id_prefix: ip1036fb
  columns: [id, function, args, expected]
  rows:
    - [ip1036fb001, inspect.isframe.__qualname__.__eq__,            ["isframe"],            true]
    - [ip1036fb002, inspect.iscode.__qualname__.__eq__,             ["iscode"],             true]
    - [ip1036fb003, inspect.isbuiltin.__qualname__.__eq__,          ["isbuiltin"],          true]
    - [ip1036fb004, inspect.ismethodwrapper.__qualname__.__eq__,    ["ismethodwrapper"],    true]
    - [ip1036fb005, inspect.isabstract.__qualname__.__eq__,         ["isabstract"],         true]
    - [ip1036fb006, inspect.istraceback.__qualname__.__eq__,        ["istraceback"],        true]

table inspect_extra1036.descriptor_predicate_qualnames:
  description: "inspect descriptor-related predicate __qualname__ identity checks"
  kind: python_call_eq
  category: descriptor_qualnames
  id_prefix: ip1036dp
  columns: [id, function, args, expected]
  rows:
    - [ip1036dp001, inspect.ismethoddescriptor.__qualname__.__eq__,  ["ismethoddescriptor"],  true]
    - [ip1036dp002, inspect.isdatadescriptor.__qualname__.__eq__,    ["isdatadescriptor"],    true]
    - [ip1036dp003, inspect.isgetsetdescriptor.__qualname__.__eq__,  ["isgetsetdescriptor"],  true]
    - [ip1036dp004, inspect.ismemberdescriptor.__qualname__.__eq__,  ["ismemberdescriptor"],  true]
    - [ip1036dp005, inspect.isfunction.__qualname__.__eq__,          ["isfunction"],          true]
    - [ip1036dp006, inspect.ismethod.__qualname__.__eq__,            ["ismethod"],            true]

table inspect_extra1036.module_and_class_qualnames:
  description: "inspect module-level and class predicate __qualname__ identity checks"
  kind: python_call_eq
  category: module_class_qualnames
  id_prefix: ip1036mc
  columns: [id, function, args, expected]
  rows:
    - [ip1036mc001, inspect.ismodule.__qualname__.__eq__,            ["ismodule"],            true]
    - [ip1036mc002, inspect.isclass.__qualname__.__eq__,             ["isclass"],             true]
    - [ip1036mc003, inspect.isroutine.__qualname__.__eq__,           ["isroutine"],           true]
    - [ip1036mc004, inspect.isgenerator.__qualname__.__eq__,         ["isgenerator"],         true]
    - [ip1036mc005, inspect.iscoroutine.__qualname__.__eq__,         ["iscoroutine"],         true]
    - [ip1036mc006, inspect.__name__.__eq__,                         ["inspect"],             true]
