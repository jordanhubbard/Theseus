spec: struct_extra81
version: ">=3.9"
extends: struct_extra80
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra80.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack/__repr__/format/size __qualname__.__eq__ / Struct method __doc__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra79.zspec.zsdl — covers pack_into/unpack_from/calcsize/iter_unpack module-level __qualname__.__eq__ / error/Struct __qualname__.__eq__ / unpack/calcsize/pack_into/unpack_from __doc__.__len__() (table + invariants)."
    - "struct_extra78.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__.__class__.__name__=='str' / Struct.format/size/__class__.__name__=='getset_descriptor' / Struct method __class__.__name__=='method_descriptor' (table + invariants)."
    - "struct_extra77.zspec.zsdl — covers Struct/__dict__/__len__()==16 / error/__dict__/__len__()==3 / Struct/__doc__/__len__()==40 (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__() / pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra80; it does NOT duplicate invariants present in those files."
    - "Wave 251 theme: struct module __spec__/__loader__ identity and error class __qualname__ / error.__bases__ / error.__module__ / struct.__doc__.__class__.__name__ / struct.__package__."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance from importlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name.__eq__('struct') == True — the spec's name attribute is 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — struct is loaded from struct.py (which wraps _struct C ext). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__name__.__eq__('struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str' — the module docstring is a str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__.__eq__('') == True — struct is a top-level module; __package__ is empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__.__eq__('error') == True — error is a top-level class; struct_extra79 also anchors this. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__.__eq__('Struct') == True — Struct is top-level; struct_extra79 anchors this. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__.__eq__('pack') == True — pack is a module-level function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__.__eq__('Exception') == True — error inherits from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__eq__('struct') == True — error is defined in the struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__spec__/__class__/__name__ / struct.__spec__/name/__eq__('struct')
# struct.__loader__/__class__/__name__ / struct.__name__/__eq__('struct')
#
# Wave 251 theme: struct module __spec__ and __loader__ identity.
#
# struct.__spec__.__class__.__name__ == 'ModuleSpec'.
# struct.__spec__.name.__eq__('struct') == True.
# struct.__loader__.__class__.__name__ == 'SourceFileLoader' (struct is a pure-Python wrapper).
# struct.__name__.__eq__('struct') == True.
# No prior struct spec checks __spec__/__loader__ class names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra81.struct_spec_loader_identity:
  description: "struct/__spec__/__class__/__name__.__eq__('ModuleSpec')==True / struct/__spec__/name/__eq__('struct')==True / struct/__loader__/__class__/__name__.__eq__('SourceFileLoader')==True / struct/__name__/__eq__('struct')==True — struct module uses ModuleSpec from importlib; its loader is SourceFileLoader (struct.py wraps _struct C extension); no prior struct spec checks __spec__/__loader__ class names; first __spec__/__loader__ identity anchor for struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra81

  columns: [id, function, args, expected]
  rows:
    - [struct_spec_class_modulespec,     __spec__.__class__.__name__.__eq__,      ["ModuleSpec"],       true]
    - [struct_spec_name_eq,              __spec__.name.__eq__,                    ["struct"],           true]
    - [struct_loader_class_sourceloader, __loader__.__class__.__name__.__eq__,    ["SourceFileLoader"], true]
    - [struct_name_eq,                   __name__.__eq__,                         ["struct"],           true]

# ---------------------------------------------------------------------------
# struct.__doc__/__class__/__name__ / struct.__package__/__eq__('')
# struct.error/__qualname__/__eq__('error') / struct.Struct/__qualname__/__eq__('Struct')
#
# Wave 251 theme: struct module docstring type, package identity, and class qualnames.
#
# struct.__doc__.__class__.__name__ == 'str'.
# struct.__package__.__eq__('') == True (top-level module).
# struct.error.__qualname__.__eq__('error') == True.
# struct.Struct.__qualname__.__eq__('Struct') == True.
# No prior struct spec checks __doc__.__class__.__name__ for the module itself.
# struct_extra79 anchors error/__qualname__/__eq__ and Struct/__qualname__/__eq__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra81.struct_doc_package_and_qualnames:
  description: "struct/__doc__/__class__/__name__.__eq__('str')==True / struct/__package__/__eq__('')==True / struct/error/__qualname__/__eq__('error')==True / struct/Struct/__qualname__/__eq__('Struct')==True — the module docstring is a plain str; __package__ is empty string for a top-level module; error and Struct have simple unqualified __qualname__; struct_extra79 anchors error and Struct __qualname__.__eq__; this table cross-checks them alongside __doc__ type and __package__; first __doc__.__class__.__name__ anchor for struct module itself"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra81

  columns: [id, function, args, expected]
  rows:
    - [struct_doc_class_str,        __doc__.__class__.__name__.__eq__,         ["str"],    true]
    - [struct_package_eq_empty,     __package__.__eq__,                        [""],       true]
    - [struct_error_qualname_eq,    error.__qualname__.__eq__,                 ["error"],  true]
    - [struct_struct_qualname_eq,   Struct.__qualname__.__eq__,                ["Struct"], true]

# ---------------------------------------------------------------------------
# struct.pack/__qualname__/__eq__('pack') / struct.error/__bases__[0]/__name__/__eq__('Exception')
# struct.error/__module__/__eq__('struct') / struct.__spec__/name/__eq__('struct')
#
# Wave 251 theme: struct.pack qualname, error bases, error module.
#
# struct.pack.__qualname__.__eq__('pack') == True.
# struct.error.__bases__[0].__name__.__eq__('Exception') == True.
# struct.error.__module__.__eq__('struct') == True.
# struct.__spec__.name.__eq__('struct') cross-checks the spec name.
# struct_extra75 anchors error.__bases__[0].__name__ and error.__module__.
# No prior struct spec checks pack.__qualname__.__eq__ directly as an eq-call.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra81.struct_pack_qualname_and_error_attrs:
  description: "struct/pack/__qualname__/__eq__('pack')==True / struct/error/__bases__[0]/__name__/__eq__('Exception')==True / struct/error/__module__/__eq__('struct')==True / struct/__spec__/name/__eq__('struct')==True — pack is a module-level function with simple __qualname__; error inherits from Exception; error is defined in the struct module; spec name is 'struct'; struct_extra75 anchors error.__bases__[0].__name__ and error.__module__; this table cross-checks them with pack.__qualname__.__eq__; first pack.__qualname__.__eq__ anchor for struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra81

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_qualname_eq,          pack.__qualname__.__eq__,                    ["pack"],      true]
    - [struct_error_bases_exception,     "error.__bases__[0].__name__.__eq__",        ["Exception"], true]
    - [struct_error_module_eq,           error.__module__.__eq__,                     ["struct"],    true]
    - [struct_spec_name_eq2,             __spec__.name.__eq__,                        ["struct"],    true]

# ---------------------------------------------------------------------------
# struct.__loader__/__class__/__name__ / struct.__doc__/__class__/__name__
# struct.__package__/__eq__('') / struct.error/__qualname__/__eq__('error')
#
# Wave 251 theme: struct loader class cross-check and docstring type anchor.
#
# __loader__.__class__.__name__ == 'SourceFileLoader' (cross-check).
# __doc__.__class__.__name__ == 'str' (cross-check).
# __package__.__eq__('') (cross-check).
# error.__qualname__.__eq__('error') (cross-check).
# No prior struct spec checks __loader__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra81.struct_loader_and_doc_cross:
  description: "struct/__loader__/__class__/__name__.__eq__('SourceFileLoader')==True / struct/__doc__/__class__.__name__.__eq__('str')==True / struct/__package__/__eq__('')==True / struct/error/__qualname__/__eq__('error')==True — loader SourceFileLoader cross-check; module __doc__ is str; __package__ is empty for top-level; error.__qualname__ is 'error'; this table cross-anchors spec/loader/doc/package/error qualname relationships; first standalone cross-check group for struct module identity attributes"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra81

  columns: [id, function, args, expected]
  rows:
    - [struct_loader_class_src2,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [struct_doc_class_str2,       __doc__.__class__.__name__.__eq__,   ["str"],              true]
    - [struct_package_empty2,       __package__.__eq__,                  [""],                 true]
    - [struct_error_qualname_eq2,   error.__qualname__.__eq__,           ["error"],            true]

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# struct.__spec__.__class__.__name__ is 'ModuleSpec'. No prior struct spec
# checks struct.__spec__.__class__.__name__. First __spec__.__class__.__name__
# standalone for struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra81.struct_spec_class_modulespec:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the module spec for struct is a ModuleSpec instance from importlib._bootstrap; no prior struct spec checks struct.__spec__.__class__.__name__; first __spec__.__class__.__name__ standalone for struct"
  category: class_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is ''. No prior struct spec checks struct.__package__.__eq__('').
# First __package__.__eq__ standalone for struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra81.struct_package_eq_empty:
  description: "struct.__package__.__eq__('') == True — struct is a top-level module so __package__ is the empty string; no prior struct spec checks struct.__package__.__eq__(''); first __package__.__eq__ standalone for struct"
  category: class_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct'. No prior struct spec checks
# struct.error.__module__.__eq__. First __module__.__eq__ standalone for
# struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra81.struct_error_module_eq:
  description: "struct.error.__module__.__eq__('struct') == True — error is defined in the struct module; struct_extra75 anchors __module__ as a value; this standalone anchors __module__.__eq__; first __module__.__eq__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# struct.__loader__.__class__.__name__ is 'SourceFileLoader'. No prior struct
# spec checks struct.__loader__.__class__.__name__. First __loader__.__class__.__name__
# standalone for struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra81.struct_loader_class_sourceloader:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — struct is loaded by SourceFileLoader from struct.py (which imports from the _struct C extension); no prior struct spec checks struct.__loader__.__class__.__name__; first __loader__.__class__.__name__ standalone for struct"
  category: class_attrs
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. No prior struct spec checks
# struct.error.__bases__[0].__name__.__eq__. First __bases__[0].__name__.__eq__
# standalone for struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra81.struct_error_bases_exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error inherits directly from Exception; struct_extra75 anchors __bases__[0].__name__ as a value; this standalone anchors it as an __eq__ call; first __bases__[0].__name__.__eq__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
