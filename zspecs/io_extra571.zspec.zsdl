spec: io_extra571
version: ">=3.9"
backend: python_module(io)
docs: "Cover io module class and method qualname identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class hierarchy and constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that io abstract base classes and concrete classes are proper types, and that qualnames and constants match expected values"
  created_at: "2026-04-12T00:00:00Z"

table io_extra571.class_name_identity:
  description: "Verify that io module classes have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: IOEX571CN
  columns: [id, function, args, expected]
  rows:
    - [IOEX571CN001, io.IOBase.__class__.__name__.__eq__, ["type"], true]
    - [IOEX571CN002, io.RawIOBase.__class__.__name__.__eq__, ["type"], true]
    - [IOEX571CN003, io.BufferedIOBase.__class__.__name__.__eq__, ["type"], true]
    - [IOEX571CN004, io.TextIOBase.__class__.__name__.__eq__, ["type"], true]
    - [IOEX571CN005, io.FileIO.__class__.__name__.__eq__, ["type"], true]
    - [IOEX571CN006, io.BytesIO.__class__.__name__.__eq__, ["type"], true]
    - [IOEX571CN007, io.StringIO.__class__.__name__.__eq__, ["type"], true]
table io_extra571.qualname_identity:
  description: "Verify that io module classes have correct __qualname__ values"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: IOEX571QN
  columns: [id, function, args, expected]
  rows:
    - [IOEX571QN001, io.IOBase.__qualname__.__eq__, ["IOBase"], true]
    - [IOEX571QN002, io.RawIOBase.__qualname__.__eq__, ["RawIOBase"], true]
    - [IOEX571QN003, io.BufferedIOBase.__qualname__.__eq__, ["BufferedIOBase"], true]
    - [IOEX571QN004, io.TextIOBase.__qualname__.__eq__, ["TextIOBase"], true]
    - [IOEX571QN005, io.BytesIO.__qualname__.__eq__, ["BytesIO"], true]
    - [IOEX571QN006, io.StringIO.__qualname__.__eq__, ["StringIO"], true]
table io_extra571.constant_identity:
  description: "Verify that io module constants have expected types"
  kind: python_call_eq
  category: constant_identity
  id_prefix: IOEX571CI
  columns: [id, function, args, expected]
  rows:
    - [IOEX571CI001, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true]