invariant socket_extra266.shutdown_qualname_eq:
  description: "socket.socket.shutdown.__qualname__ == 'socket.shutdown' — C method_descriptor qualname has 'socket.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
