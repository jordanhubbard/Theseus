  category: identity
  kind: python_call_eq
  function: socket.listen.__qualname__.__eq__
  args: ["socket.listen"]
  expected: true

invariant socket_extra266.accept_qualname_eq:
  description: "socket.socket.accept.__qualname__ == 'socket.accept' — C method_descriptor qualname has 'socket.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.accept.__qualname__.__eq__
  args: ["socket.accept"]
