invariant socket_extra266.send_qualname_eq:
  description: "socket.socket.send.__qualname__ == 'socket.send' — C method_descriptor qualname has 'socket.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.send.__qualname__.__eq__
  args: ["socket.send"]
