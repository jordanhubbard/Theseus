spec: socket_extra266
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() values and socket.SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket'."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names; AddressFamily/SocketKind __bases__."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names; socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values; byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec — covers socket.__name__/__package__ (base spec)."
  notes:
    - "socket.socket.bind.__name__ == 'bind' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor on socket.socket from socketmodule.c. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.listen.__name__ == 'listen' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.accept.__name__ == 'accept' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.connect.__name__ == 'connect' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.send.__name__ == 'send' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.recv.__name__ == 'recv' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.close.__name__ == 'close' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.shutdown.__name__ == 'shutdown' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — qualname has 'socket.' prefix (lowercase class name). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — qualname has 'socket.' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.setsockopt.__name__ == 'setsockopt' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.getsockopt.__name__ == 'getsockopt' and __class__.__name__ == 'method_descriptor' — C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __name__ identity — bind, listen, accept, connect, send, recv, close, shutdown
# All are C-level method_descriptor objects on the socket.socket type.
# __class__.__name__ == 'method_descriptor' for all of them.
# ---------------------------------------------------------------------------

table socket_extra266.socket_method_name_identity:
  description: "socket.socket bind/listen/accept/connect/send/recv method __name__ equality — all C-level method_descriptor objects on socket.socket from socketmodule.c; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockmethod266

  columns: [id, function, args, expected, description]
  rows:
    - [bind_name,    socket.bind.__name__.__eq__,    ["bind"],    true, "socket.socket.bind.__name__ == 'bind' — C method_descriptor on socket.socket"]
    - [listen_name,  socket.listen.__name__.__eq__,  ["listen"],  true, "socket.socket.listen.__name__ == 'listen' — C method_descriptor on socket.socket"]
    - [accept_name,  socket.accept.__name__.__eq__,  ["accept"],  true, "socket.socket.accept.__name__ == 'accept' — C method_descriptor on socket.socket"]
    - [connect_name, socket.connect.__name__.__eq__, ["connect"], true, "socket.socket.connect.__name__ == 'connect' — C method_descriptor on socket.socket"]
    - [send_name,    socket.send.__name__.__eq__,    ["send"],    true, "socket.socket.send.__name__ == 'send' — C method_descriptor on socket.socket"]

# ---------------------------------------------------------------------------
# socket.socket method __name__ identity — recv, close, shutdown, setsockopt, getsockopt
# ---------------------------------------------------------------------------

table socket_extra266.socket_method_name_identity2:
  description: "socket.socket recv/close/shutdown/setsockopt/getsockopt method __name__ equality — all C-level method_descriptor objects on socket.socket from socketmodule.c; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockmethod266b

  columns: [id, function, args, expected, description]
  rows:
    - [recv_name,       socket.recv.__name__.__eq__,       ["recv"],       true, "socket.socket.recv.__name__ == 'recv' — C method_descriptor on socket.socket"]
    - [close_name,      socket.close.__name__.__eq__,      ["close"],      true, "socket.socket.close.__name__ == 'close' — C method_descriptor on socket.socket"]
    - [shutdown_name,   socket.shutdown.__name__.__eq__,   ["shutdown"],   true, "socket.socket.shutdown.__name__ == 'shutdown' — C method_descriptor on socket.socket"]
    - [setsockopt_name, socket.setsockopt.__name__.__eq__, ["setsockopt"], true, "socket.socket.setsockopt.__name__ == 'setsockopt' — C method_descriptor on socket.socket"]
    - [getsockopt_name, socket.getsockopt.__name__.__eq__, ["getsockopt"], true, "socket.socket.getsockopt.__name__ == 'getsockopt' — C method_descriptor on socket.socket"]

# ---------------------------------------------------------------------------
# socket.socket method __class__.__name__ identity — all are method_descriptor
# ---------------------------------------------------------------------------

invariant socket_extra266.bind_class_eq:
  description: "socket.socket.bind.__class__.__name__ == 'method_descriptor' — C-level descriptor from socketmodule.c; confirmed as method_descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.bind.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant socket_extra266.connect_class_eq:
  description: "socket.socket.connect.__class__.__name__ == 'method_descriptor' — C-level descriptor from socketmodule.c; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.connect.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant socket_extra266.setsockopt_class_eq:
  description: "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor' — C-level descriptor from socketmodule.c; sets a socket option; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.setsockopt.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant socket_extra266.getsockopt_class_eq:
  description: "socket.socket.getsockopt.__class__.__name__ == 'method_descriptor' — C-level descriptor from socketmodule.c; retrieves a socket option; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.getsockopt.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket method qualname identity — bind, connect, listen, accept, etc.
# All qualnames have the 'socket.' prefix (the socket class uses lowercase name).
# ---------------------------------------------------------------------------

invariant socket_extra266.bind_qualname_eq:
  description: "socket.socket.bind.__qualname__ == 'socket.bind' — C method_descriptor qualname has lowercase 'socket.' prefix (the class is named 'socket' same as the module); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.bind.__qualname__.__eq__
  args: ["socket.bind"]
  expected: true

invariant socket_extra266.connect_qualname_eq:
  description: "socket.socket.connect.__qualname__ == 'socket.connect' — C method_descriptor qualname has lowercase 'socket.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["socket.connect"]
  expected: true

invariant socket_extra266.listen_qualname_eq:
