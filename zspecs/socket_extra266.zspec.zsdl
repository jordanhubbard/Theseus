invariant socket_extra266.recv_qualname_eq:
  description: "socket.socket.recv.__qualname__ == 'socket.recv' — C method_descriptor qualname has 'socket.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.recv.__qualname__.__eq__
  args: ["socket.recv"]
