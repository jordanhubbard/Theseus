spec: itertools_extra85
version: ">=3.10"
backend: python_module(itertools)
extends: itertools_extra84

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra84.zspec.zsdl."
    - "This spec covers: itertools C type __qualname__ string equality — all 16 qualnames match their type name (Wave 249)."
    - "count.__qualname__.__eq__('count') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "cycle.__qualname__.__eq__('cycle') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "repeat.__qualname__.__eq__('repeat') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "accumulate.__qualname__.__eq__('accumulate') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "chain.__qualname__.__eq__('chain') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "compress.__qualname__.__eq__('compress') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "dropwhile.__qualname__.__eq__('dropwhile') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "filterfalse.__qualname__.__eq__('filterfalse') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "groupby.__qualname__.__eq__('groupby') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "islice.__qualname__.__eq__('islice') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "pairwise.__qualname__.__eq__('pairwise') == True — C extension type (added 3.10) qualname matches type name. Verified with Python 3.14.3."
    - "permutations.__qualname__.__eq__('permutations') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "product.__qualname__.__eq__('product') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "starmap.__qualname__.__eq__('starmap') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "takewhile.__qualname__.__eq__('takewhile') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "zip_longest.__qualname__.__eq__('zip_longest') == True — C extension type qualname matches type name. Verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# count/cycle/repeat/accumulate __qualname__ equality — extra85
#
# Wave 249 theme: all 16 itertools C types have __qualname__ matching their type name.
#
# itertools.count.__qualname__       == 'count'
# itertools.cycle.__qualname__       == 'cycle'
# itertools.repeat.__qualname__      == 'repeat'
# itertools.accumulate.__qualname__  == 'accumulate'
#
# No prior itertools spec checks count/cycle/repeat/accumulate __qualname__.__eq__ via itrtoolsextra85. New to extra85.
# ---------------------------------------------------------------------------

table itertools_extra85.qualname_eq_group1:
  description: "count/cycle/repeat/accumulate __qualname__.__eq__(typename)==True; wave 249 itertools C type __qualname__ equality; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra85

  columns: [id, function, args, expected, description]
  rows:
    - [count_qualname_eq_count,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C extension type defined in Modules/itertoolsmodule.c; its __qualname__ attribute is the string 'count' (5 chars); for C extension types at module scope, __qualname__ equals __name__; str.__eq__('count') returns True; no prior itertools spec checks count.__qualname__.__eq__ via itrtoolsextra85; new to extra85"]
    - [cycle_qualname_eq_cycle,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C extension type defined in Modules/itertoolsmodule.c; its __qualname__ attribute is the string 'cycle' (5 chars); for C extension types at module scope, __qualname__ equals __name__; str.__eq__('cycle') returns True; no prior itertools spec checks cycle.__qualname__.__eq__ via itrtoolsextra85; new to extra85"]
    - [repeat_qualname_eq_repeat,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — repeat is a C extension type defined in Modules/itertoolsmodule.c; its __qualname__ attribute is the string 'repeat' (6 chars); for C extension types at module scope, __qualname__ equals __name__; str.__eq__('repeat') returns True; no prior itertools spec checks repeat.__qualname__.__eq__ via itrtoolsextra85; new to extra85"]
    - [accumulate_qualname_eq_accumulate,
       accumulate.__qualname__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c; its __qualname__ attribute is the string 'accumulate' (10 chars); for C extension types at module scope, __qualname__ equals __name__; str.__eq__('accumulate') returns True; no prior itertools spec checks accumulate.__qualname__.__eq__ via itrtoolsextra85; new to extra85"]

