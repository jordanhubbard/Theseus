spec: signal_extra5
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "Python signal documentation — https://docs.python.org/3/library/signal.html"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra4.zspec.zsdl."
    - "signal.zspec covers: POSIX signal int values; Signals/Handlers class names; SIG_DFL/SIG_IGN values; strsignal strings for SIGINT/SIGTERM/SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE."
    - "signal_extra covers: getsignal/raise_signal/strsignal/valid_signals __name__; SIG_DFL/SIG_IGN/SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names; valid_signals() type and membership for SIGINT/SIGTERM."
    - "signal_extra2 covers: function __module__ table; signal/getsignal __name__; SIG_DFL/SIG_IGN/SIGTERM/SIGINT class names; Signals/Handlers __name__; Signals/Handlers __bases__[0].__name__."
    - "signal_extra3 covers: module __name__; NSIG >= 16; NSIG is_int; SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE class names; SIGHUP/SIGKILL .name; SIG_DFL/SIG_IGN .name."
    - "signal_extra4 covers: function __qualname__ table; Signals/Handlers __qualname__; Signals/Handlers __module__."
    - "This spec adds: .name attribute checks for SIGABRT/SIGFPE/SIGILL/SIGSEGV (not yet covered); strsignal strings for SIGABRT/SIGFPE/SIGILL/SIGSEGV (not yet covered); valid_signals() membership for SIGHUP/SIGKILL/SIGQUIT/SIGABRT (signal_extra only covers SIGINT/SIGTERM); Signals.SIGABRT.value and Signals.SIGHUP.value (not yet covered)."
    - "strsignal(6) == 'Abort trap: 6' on macOS/Darwin."
    - "strsignal(8) == 'Floating point exception: 8' on macOS/Darwin."
    - "strsignal(4) == 'Illegal instruction: 4' on macOS/Darwin."
    - "strsignal(11) == 'Segmentation fault: 11' on macOS/Darwin."
    - "SIGABRT.name == 'SIGABRT', SIGFPE.name == 'SIGFPE', SIGILL.name == 'SIGILL', SIGSEGV.name == 'SIGSEGV' — enum member names."
    - "Signals.SIGABRT.value == 6, Signals.SIGHUP.value == 1 — not covered by prior specs."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signals enum — .name attribute for SIGABRT, SIGFPE, SIGILL, SIGSEGV
# signal.zspec covers Signals.SIGINT.name and Signals.SIGTERM.name.
# signal_extra3 covers SIGHUP.name and SIGKILL.name.
# New here: SIGABRT/SIGFPE/SIGILL/SIGSEGV .name via top-level constant.
# ---------------------------------------------------------------------------

table signal_extra5.signal_enum_names:
  description: "SIGABRT/SIGFPE/SIGILL/SIGSEGV enum .name attributes match their symbol"
  kind: python_call_eq
  category: enum_names
  id_prefix: ename

  columns: [id, function, args, expected]
  rows:
    - [SIGABRT, SIGABRT.name.__eq__, ["SIGABRT"], true]
    - [SIGFPE,  SIGFPE.name.__eq__,  ["SIGFPE"],  true]
    - [SIGILL,  SIGILL.name.__eq__,  ["SIGILL"],  true]
    - [SIGSEGV, SIGSEGV.name.__eq__, ["SIGSEGV"], true]

# ---------------------------------------------------------------------------
# Signals enum — .value checks for SIGABRT and SIGHUP
# signal.zspec covers Signals.SIGINT.value and Signals.SIGTERM.value.
# No prior spec covers Signals.SIGABRT.value or Signals.SIGHUP.value.
# ---------------------------------------------------------------------------

invariant signal_extra5.Signals.SIGABRT_value:
  description: "signal.Signals.SIGABRT.value == 6 — SIGABRT integer value"
  category: enum
  kind: python_call_eq
  function: Signals.SIGABRT.value.__eq__
  args: [6]
  expected: true

invariant signal_extra5.Signals.SIGHUP_value:
  description: "signal.Signals.SIGHUP.value == 1 — SIGHUP integer value"
  category: enum
  kind: python_call_eq
  function: Signals.SIGHUP.value.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# strsignal — OS-level descriptions for SIGABRT, SIGFPE, SIGILL, SIGSEGV
# signal.zspec covers: SIGINT/SIGTERM/SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE.
# No prior spec covers strsignal for SIGABRT, SIGFPE, SIGILL, or SIGSEGV.
# These strings are macOS/Darwin-specific.
# ---------------------------------------------------------------------------

table signal_extra5.strsignal.fault_signals:
  kind: python_call_eq
  category: strsignal
  id_prefix: strsignal

  columns: [id, function, args, expected]
  rows:
    - [sigabrt, strsignal, [6],  "Abort trap: 6"          ]
    - [sigfpe,  strsignal, [8],  "Floating point exception: 8"]
    - [sigill,  strsignal, [4],  "Illegal instruction: 4" ]
    - [sigsegv, strsignal, [11], "Segmentation fault: 11" ]

# ---------------------------------------------------------------------------
# valid_signals() — membership for additional POSIX signals
# signal_extra covers: SIGINT (2) and SIGTERM (15).
# New here: SIGHUP (1), SIGKILL (9), SIGQUIT (3), SIGABRT (6).
# ---------------------------------------------------------------------------

table signal_extra5.valid_signals_membership:
  description: "SIGHUP/SIGKILL/SIGQUIT/SIGABRT are all in valid_signals()"
  kind: python_call_eq
  category: valid_signals
  id_prefix: vs

  columns: [id, function, args, expected]
  rows:
    - [sighup,  valid_signals().__contains__, [1], true]
    - [sigkill, valid_signals().__contains__, [9], true]
    - [sigquit, valid_signals().__contains__, [3], true]
    - [sigabrt, valid_signals().__contains__, [6], true]
