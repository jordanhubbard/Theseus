spec: pathlib_extra170
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath.__dict__ membership for the path component properties: parent, parents, name, stem, suffix, suffixes."
    - "pathlib.PurePath.__dict__.__contains__('parent') == True (len('parent')=6)."
    - "pathlib.PurePath.__dict__.__contains__('parents') == True (len('parents')=7)."
    - "pathlib.PurePath.__dict__.__contains__('name') == True (len('name')=4)."
    - "pathlib.PurePath.__dict__.__contains__('stem') == True (len('stem')=4)."
    - "pathlib.PurePath.__dict__.__contains__('suffix') == True (len('suffix')=6)."
    - "pathlib.PurePath.__dict__.__contains__('suffixes') == True (len('suffixes')=8)."
    - "len(pathlib.PurePath.__dict__) == 61 — the PurePath class dict has exactly 61 entries on Python 3.14.3."
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8: 'Pure' (4) + 'Path' (4) = 8)."
    - "pathlib.PurePath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' (len=6)."
    - "Key name length ranking: name=stem=4 (two-way tie), parent=suffix=6 (two-way tie), parents=7, suffixes=8."
    - "Two-way tie at 4: name and stem — both 4-character property names."
    - "Two-way tie at 6: parent and suffix — both 6-character property names."
    - "suffixes (8) is the longest of the six property names; it is the plural of suffix (6) with 'es' appended (2 chars added)."
    - "All six properties are defined directly on PurePath, not on Path or OS-specific subclasses."
    - "These are read-only properties (cached via functools.cached_property or property), not regular methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ membership for path component properties
# name=stem=4 (two-way tie), parent=suffix=6 (two-way tie), parents=7
# All are pure path properties (no filesystem I/O required)
# ---------------------------------------------------------------------------

table pathlib_extra170.PurePath_dict_component_properties:
  description: "pathlib.PurePath.__dict__ membership: name=stem (len=4, tie), parent=suffix (len=6, tie), parents (len=7) — all True; two-way tie at 4 for name and stem; two-way tie at 6 for parent and suffix"
  kind: python_call_eq
  category: identity
  id_prefix: pdict170

  columns: [id, function, args, expected, description]
  rows:
    - [pure_name_in,    "PurePath.__dict__.__contains__",  ["name"],    true, "pathlib.PurePath.__dict__.__contains__('name') == True (name is a cached_property directly defined on PurePath; PurePath.name returns the final component of the path string — the filename with extension: PurePath('/foo/bar/baz.txt').name == 'baz.txt'; 'name' has 4 characters — tied with 'stem' (also 4) as the shortest property name among the six in this spec; the two-way tie at 4 (name, stem) is the minimum key name length in this spec; 'name' (4 chars) is shorter than 'parent' (6), 'parents' (7), 'suffix' (6), and 'suffixes' (8); name is one of the most commonly used PurePath properties for extracting the filename component)"]
    - [pure_stem_in,    "PurePath.__dict__.__contains__",  ["stem"],    true, "pathlib.PurePath.__dict__.__contains__('stem') == True (stem is a cached_property directly defined on PurePath; PurePath.stem returns the final component of the path without its extension: PurePath('/foo/bar/baz.txt').stem == 'baz'; 'stem' has 4 characters — tied with 'name' (also 4) as the shortest property name in this spec; the two-way tie at 4 (name, stem) occupies the minimum key name length; stem and name are closely related: name includes the extension, stem excludes it; 'stem' (4 chars) is a metaphorical name: the stem of a filename is what remains after removing the suffix, like the stem of a plant after removing its extension/fruit)"]
    - [pure_parent_in,  "PurePath.__dict__.__contains__",  ["parent"],  true, "pathlib.PurePath.__dict__.__contains__('parent') == True (parent is a cached_property directly defined on PurePath; PurePath.parent returns the logical parent of the path: PurePath('/foo/bar/baz.txt').parent == PurePath('/foo/bar'); 'parent' has 6 characters — tied with 'suffix' (also 6) in key name length; the two-way tie at 6 (parent, suffix) is the second-longest pair in this spec; parent (6) > name=stem (4) by 2; parent (6) < parents (7) by 1 — parent is the singular form and parents is the plural; PurePath.parent follows the logical path upward exactly one level; for absolute paths, parent of the root is the root itself)"]
    - [pure_suffix_in,  "PurePath.__dict__.__contains__",  ["suffix"],  true, "pathlib.PurePath.__dict__.__contains__('suffix') == True (suffix is a cached_property directly defined on PurePath; PurePath.suffix returns the file extension of the final component including the leading dot: PurePath('/foo/bar/baz.txt').suffix == '.txt'; 'suffix' has 6 characters — tied with 'parent' (also 6) in key name length; the two-way tie at 6 (parent, suffix) pairs a hierarchical navigation property (parent) with a name-parsing property (suffix) — different purposes, same key name length; suffix (6) < suffixes (8) by 2 — the plural adds 'es' (2 chars); suffix returns only the last extension; for 'archive.tar.gz', suffix returns '.gz' not '.tar.gz')"]
    - [pure_parents_in, "PurePath.__dict__.__contains__",  ["parents"], true, "pathlib.PurePath.__dict__.__contains__('parents') == True (parents is a property directly defined on PurePath; PurePath.parents returns an immutable sequence of the logical ancestors of the path; PurePath('/foo/bar/baz').parents == (PurePath('/foo/bar'), PurePath('/foo'), PurePath('/')); 'parents' has 7 characters: 'parent' (6) + 's' (1) = 7; parents (7) stands alone at key name length 7 — the sole occupant of length 7 in this spec; parents (7) is exactly 1 longer than parent (6) — the 's' pluralizes to give all ancestors rather than just one; parents is an indexed sequence: parents[0] is the immediate parent, parents[-1] is the root)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ membership for 'suffixes'
# Also check PurePath.__dict__.__len__() == 61 and PurePath class identity.
# suffixes (len=8) is the longest of the six component property names.
# ---------------------------------------------------------------------------

table pathlib_extra170.PurePath_dict_suffixes_and_identity:
  description: "pathlib.PurePath.__dict__ membership: suffixes (len=8, longest property name in spec); also PurePath.__dict__.__len__()==61 and PurePath class identity: __name__='PurePath' (len=8), __module__='pathlib' (len=7), __bases__[0].__name__='object' (len=6)"
  kind: python_call_eq
  category: identity
  id_prefix: pdict170

  columns: [id, function, args, expected, description]
  rows:
    - [pure_suffixes_in,  "PurePath.__dict__.__contains__",  ["suffixes"],  true, "pathlib.PurePath.__dict__.__contains__('suffixes') == True (suffixes is a cached_property directly defined on PurePath; PurePath.suffixes returns a list of all file extensions of the final component: PurePath('/foo/bar/baz.tar.gz').suffixes == ['.tar', '.gz']; 'suffixes' has 8 characters: 'suffix' (6) + 'es' (2) = 8; suffixes (8) is the longest key name among the six component properties in this spec; the ascending key name length sequence: name=stem=4, parent=suffix=6, parents=7, suffixes=8; 'suffixes' (8 chars) contains 'suffix' (6 chars) as a prefix — the longer form returns all extensions while the shorter returns only the last; suffixes (8) == len('PurePath') == 8: the class name length equals the longest property name length)"]
    - [pure_dict_len,     "PurePath.__dict__.__len__",        [],           61,   "pathlib.PurePath.__dict__.__len__() == 61 — the PurePath class dictionary has exactly 61 entries on Python 3.14.3; this count includes properties (parent, parents, name, stem, suffix, suffixes, drive, root, anchor, parts), pure-path methods (as_posix, as_uri, is_absolute, is_relative_to, with_name, with_stem, with_suffix, joinpath, match, full_match, relative_to), operators (__truediv__, __rtruediv__, __lt__, __le__, __eq__, __gt__, __ge__, __hash__), and dunders (__init__, __new__, __repr__, __str__, __fspath__, __bytes__, etc.); 61 entries reflects the rich path manipulation API of PurePath; contrast with concrete Path.__dict__ (62 entries, from pathlib_extra169) which adds one I/O-specific method"]
    - [pure_name_eq,      PurePath.__name__.__eq__,           ["PurePath"],  true, "pathlib.PurePath.__name__ == 'PurePath' (PurePath is the abstract base class for all pathlib path classes that do not perform filesystem I/O; 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; PurePath (8) is the root of the pure path hierarchy, parent of PurePosixPath (13) and PureWindowsPath (15); 'Pure' (4 chars) signals no I/O; PurePath.__module__ == 'pathlib' (7 chars) — the public pathlib module; PurePath.__bases__[0].__name__ == 'object' (6 chars) — PurePath inherits directly from object, unlike concrete Path classes which have Path (4 chars) as a direct base; 'PurePath' (8 chars) equals len('suffixes') == 8 — a coincidental equality between the class name and the longest property key name in this spec)"]
    - [pure_module_eq,    PurePath.__module__.__eq__,         ["pathlib"],   true, "pathlib.PurePath.__module__ == 'pathlib' (PurePath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; PurePath.__module__ == 'pathlib' (7) is shared by all pathlib path classes: PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath — all have __module__ == 'pathlib'; the uniform 7-character module name across all pathlib classes contrasts with the io class hierarchy where some classes have __module__ == '_io' (3 chars) and others have __module__ == 'io' (2 chars); 'pathlib' (7) > 'io' (2) by 5 characters — pathlib uses a longer, more descriptive module name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra170.PurePath_name_stem_tie_at_4:
  description: "pathlib.PurePath.__dict__.__contains__('name') == True — 'name' and 'stem' both have 4 characters, forming a two-way tie at 4 in key name length among the six component properties checked in this spec; the two-way tie at 4 (name, stem) is the minimum key name length in this spec; name and stem are semantically related: name is the full final component (including extension), stem is the final component without extension; both are cached_property descriptors directly defined on PurePath, not inherited from object; key name length ranking: name=stem=4, parent=suffix=6, parents=7, suffixes=8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["name"]
  expected: true

invariant pathlib_extra170.PurePath_parent_suffix_tie_at_6:
  description: "pathlib.PurePath.__dict__.__contains__('parent') == True — 'parent' and 'suffix' both have 6 characters, forming a two-way tie at 6 in key name length; the two-way tie at 6 (parent, suffix) is the second-longest grouping in this spec; parent is a hierarchical navigation property (returns the path one level up) while suffix is a name-parsing property (returns the last extension); despite their different roles, parent (6) and suffix (6) share the same key name length; parent (6) is 1 shorter than parents (7) and 2 longer than name=stem (4); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["parent"]
  expected: true

invariant pathlib_extra170.PurePath_suffixes_is_longest_at_8:
  description: "pathlib.PurePath.__dict__.__contains__('suffixes') == True — 'suffixes' (8 chars) is the longest key name among the six component properties in this spec; it stands alone at the maximum length 8; the ascending key name length sequence: name=stem=4, parent=suffix=6, parents=7, suffixes=8; 'suffixes' (8) is exactly 2 characters longer than 'suffix' (6) — the plural 'suffixes' appends 'es' (2 chars); suffixes (8) == len('PurePath') == 8: the class name and the longest property name in this spec have equal length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["suffixes"]
  expected: true

invariant pathlib_extra170.PurePath_dict_len_61:
  description: "pathlib.PurePath.__dict__.__len__() == 61 — PurePath's class dict has exactly 61 entries on Python 3.14.3; compare with concrete Path.__dict__ (62 entries, from pathlib_extra169) which has 1 more entry; PurePath (61) has fewer entries than Path (62) because PurePath is the pure (no-I/O) abstract base while Path adds concrete filesystem methods; 61 entries covers the full pure path API: properties (parent, parents, name, stem, suffix, suffixes, drive, root, anchor, parts), string methods (as_posix, with_name, with_stem, with_suffix), and all the dunders and operators needed for path comparison, hashing, and string conversion; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__dict__.__len__"
  args: []
  expected: 61

