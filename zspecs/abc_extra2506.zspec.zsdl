spec: abc_extra2506
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc (Abstract Base Classes) documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence checks."
    - "abc.ABC and abc.ABCMeta define no arithmetic operators."
    - "__dict__.__contains__ returns False for __add__, __sub__, __mul__ on both classes."
    - "abc.ABC is a simple helper class using ABCMeta as its metaclass; neither defines arithmetic."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

