spec: io_extra219
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra218.zspec.zsdl — covers io class __qualname__ attribute checks"
  notes:
    - "io.BytesIO.__doc__ starts with 'Buffered I/O implementation using an in-memory bytes buffer.'; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__doc__ starts with 'Text I/O implementation using an in-memory buffer.'; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__doc__ starts with 'Open a file.'; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__doc__ starts with 'Create a new buffered reader using the given readable raw IO object.'; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__doc__ starts with 'A buffer for a writeable sequential RawIO object.'; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__doc__ starts with 'Character and line based layer over a BufferedIOBase object, buffer.'; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for in-memory I/O classes
# BytesIO and StringIO __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table io_extra219.memory_io_doc_contains:
  description: "io.BytesIO and io.StringIO __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: iodoccontains219

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_doc_contains_bytes,         io.BytesIO.__doc__.__contains__,    ["bytes"],         true,  "io.BytesIO.__doc__.__contains__('bytes') == True; doc describes in-memory bytes buffer; confirmed Python 3.14.3 macOS"]
    - [bytesio_doc_contains_memory,        io.BytesIO.__doc__.__contains__,    ["memory"],        true,  "io.BytesIO.__doc__.__contains__('memory') == True; doc mentions in-memory buffer; confirmed Python 3.14.3 macOS"]
    - [bytesio_doc_contains_Buffered,      io.BytesIO.__doc__.__contains__,    ["Buffered"],      true,  "io.BytesIO.__doc__.__contains__('Buffered') == True; doc starts with 'Buffered I/O implementation'; confirmed Python 3.14.3 macOS"]
    - [stringio_doc_contains_Text,         io.StringIO.__doc__.__contains__,   ["Text"],          true,  "io.StringIO.__doc__.__contains__('Text') == True; doc starts with 'Text I/O implementation'; confirmed Python 3.14.3 macOS"]
    - [stringio_doc_contains_buffer,       io.StringIO.__doc__.__contains__,   ["buffer"],        true,  "io.StringIO.__doc__.__contains__('buffer') == True; doc mentions in-memory buffer; confirmed Python 3.14.3 macOS"]
    - [stringio_doc_contains_initial_value, io.StringIO.__doc__.__contains__,  ["initial_value"], true,  "io.StringIO.__doc__.__contains__('initial_value') == True; doc mentions the initial_value constructor argument; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for file and buffered I/O classes
# FileIO, BufferedReader, BufferedWriter __doc__ string substring membership
# ---------------------------------------------------------------------------

table io_extra219.file_and_buffered_doc_contains:
  description: "io.FileIO, BufferedReader, and BufferedWriter __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: iodoccontains219

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_doc_contains_file,          io.FileIO.__doc__.__contains__,         ["file"],       true,  "io.FileIO.__doc__.__contains__('file') == True; doc describes opening a file; confirmed Python 3.14.3 macOS"]
    - [fileio_doc_contains_mode,          io.FileIO.__doc__.__contains__,         ["mode"],       true,  "io.FileIO.__doc__.__contains__('mode') == True; doc describes the mode parameter; confirmed Python 3.14.3 macOS"]
    - [fileio_doc_contains_reading,       io.FileIO.__doc__.__contains__,         ["reading"],    true,  "io.FileIO.__doc__.__contains__('reading') == True; doc mentions reading as one of the modes; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_doc_contains_read,  io.BufferedReader.__doc__.__contains__,  ["read"],       true,  "io.BufferedReader.__doc__.__contains__('read') == True; doc describes a buffered reader; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_doc_contains_buffer, io.BufferedReader.__doc__.__contains__, ["buffer"],     true,  "io.BufferedReader.__doc__.__contains__('buffer') == True; doc mentions buffer; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_doc_contains_readable, io.BufferedReader.__doc__.__contains__, ["readable"], true,  "io.BufferedReader.__doc__.__contains__('readable') == True; doc mentions readable raw IO object; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for TextIOWrapper and BufferedWriter
# TextIOWrapper and BufferedWriter __doc__ string substring membership
# ---------------------------------------------------------------------------

table io_extra219.text_and_bwriter_doc_contains:
  description: "io.TextIOWrapper and io.BufferedWriter __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: iodoccontains219

  columns: [id, function, args, expected, description]
  rows:
    - [textiowrapper_doc_contains_Character, io.TextIOWrapper.__doc__.__contains__, ["Character"],  true,  "io.TextIOWrapper.__doc__.__contains__('Character') == True; doc starts with 'Character and line based layer'; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_doc_contains_encoding,  io.TextIOWrapper.__doc__.__contains__, ["encoding"],   true,  "io.TextIOWrapper.__doc__.__contains__('encoding') == True; doc mentions the encoding parameter; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_doc_contains_buffer,    io.TextIOWrapper.__doc__.__contains__, ["buffer"],     true,  "io.TextIOWrapper.__doc__.__contains__('buffer') == True; doc mentions the buffer parameter; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_doc_contains_layer,     io.TextIOWrapper.__doc__.__contains__, ["layer"],      true,  "io.TextIOWrapper.__doc__.__contains__('layer') == True; doc describes it as a layer over BufferedIOBase; confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_doc_contains_write,    io.BufferedWriter.__doc__.__contains__, ["write"],     true,  "io.BufferedWriter.__doc__.__contains__('write') == True; doc describes a buffer for a writeable object; confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_doc_contains_sequential, io.BufferedWriter.__doc__.__contains__, ["sequential"], true, "io.BufferedWriter.__doc__.__contains__('sequential') == True; doc mentions sequential RawIO object; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra219.bytesio_doc_contains_bytes:
  description: "io.BytesIO.__doc__.__contains__('bytes') == True — BytesIO doc describes in-memory bytes buffer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BytesIO.__doc__.__contains__
  args: ["bytes"]
  expected: true

invariant io_extra219.bytesio_doc_contains_memory:
  description: "io.BytesIO.__doc__.__contains__('memory') == True — BytesIO doc mentions in-memory buffer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BytesIO.__doc__.__contains__
  args: ["memory"]
  expected: true

invariant io_extra219.stringio_doc_contains_Text:
  description: "io.StringIO.__doc__.__contains__('Text') == True — StringIO doc starts with 'Text I/O implementation'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__doc__.__contains__
  args: ["Text"]
  expected: true

invariant io_extra219.stringio_doc_contains_initial_value:
  description: "io.StringIO.__doc__.__contains__('initial_value') == True — StringIO doc mentions initial_value constructor argument; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__doc__.__contains__
  args: ["initial_value"]
  expected: true

invariant io_extra219.fileio_doc_contains_mode:
  description: "io.FileIO.__doc__.__contains__('mode') == True — FileIO doc describes the mode parameter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__doc__.__contains__
  args: ["mode"]
  expected: true

invariant io_extra219.bufferedreader_doc_contains_readable:
  description: "io.BufferedReader.__doc__.__contains__('readable') == True — BufferedReader doc mentions readable raw IO object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__doc__.__contains__
  args: ["readable"]
  expected: true

invariant io_extra219.textiowrapper_doc_contains_encoding:
  description: "io.TextIOWrapper.__doc__.__contains__('encoding') == True — TextIOWrapper doc mentions the encoding parameter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__doc__.__contains__
  args: ["encoding"]
  expected: true

invariant io_extra219.bufferedwriter_doc_contains_write:
  description: "io.BufferedWriter.__doc__.__contains__('write') == True — BufferedWriter doc describes a buffer for a writeable object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__doc__.__contains__
  args: ["write"]
  expected: true
