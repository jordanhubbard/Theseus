spec: difflib_extra2
version: ">=3.2"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "Complements difflib.zspec.zsdl and difflib_extra.zspec.zsdl."
    - "difflib_extra.zspec.zsdl covers: SequenceMatcher, Differ, HtmlDiff class names; unified_diff, context_diff, ndiff, get_close_matches function names; get_close_matches behavioral tests."
    - "This spec consolidates class and function __name__ checks in table form and adds the 'helllo' close-match test."
    - "get_close_matches('helllo', ['hello','help','world']) == ['hello','help'] with default n=3, cutoff=0.6."
    - "The typo 'helllo' is close to both 'hello' (ratio ~0.91) and 'help' (ratio ~0.73) but not 'world'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table difflib_extra2.class_names:
  description: "difflib classes have correct __name__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Differ,          Differ.__name__.__eq__,          ["Differ"],          true]
    - [HtmlDiff,        HtmlDiff.__name__.__eq__,        ["HtmlDiff"],        true]
    - [SequenceMatcher, SequenceMatcher.__name__.__eq__,  ["SequenceMatcher"], true]

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table difflib_extra2.function_names:
  description: "difflib functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [unified_diff,      unified_diff.__name__.__eq__,      ["unified_diff"],      true]
    - [context_diff,      context_diff.__name__.__eq__,      ["context_diff"],      true]
    - [ndiff,             ndiff.__name__.__eq__,             ["ndiff"],             true]
    - [get_close_matches, get_close_matches.__name__.__eq__,  ["get_close_matches"], true]

# ---------------------------------------------------------------------------
# get_close_matches — behavioral test
#
# 'helllo' (typo with doubled 'l') is close to 'hello' and 'help' with
# the default cutoff of 0.6 and n=3. 'world' is not close enough.
# ---------------------------------------------------------------------------

invariant difflib_extra2.get_close_matches.helllo:
  description: "get_close_matches('helllo', ['hello','help','world']) == ['hello','help']"
  category: close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["helllo", ["hello", "help", "world"]]
  expected: ["hello", "help"]
