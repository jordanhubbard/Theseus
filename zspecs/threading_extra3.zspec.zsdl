spec: threading_extra3
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec extends threading.zspec.zsdl, threading_extra.zspec.zsdl, threading_extra2.zspec.zsdl, threading_sync.zspec.zsdl, and threading_timer.zspec.zsdl."
    - "threading.zspec.zsdl covers: class __name__ checks (Thread/Lock/RLock/Condition/Semaphore/BoundedSemaphore/Event/Timer/Barrier), function __name__ checks (current_thread/main_thread/active_count/enumerate), TIMEOUT_MAX, active_count_ge_1, Lock behavior, Event, Semaphore._value, current_thread.is_alive."
    - "threading_extra.zspec.zsdl covers: class __module__ for BoundedSemaphore/Condition/Semaphore/Event/RLock; local.__name__/__module__; current_thread class name is str; get_ident returns int; TIMEOUT_MAX is float; stack_size returns int."
    - "threading_extra2.zspec.zsdl covers: class __name__ checks for all primitives in a table; current_thread/__name__, main_thread/__name__, active_count/__name__."
    - "threading_sync.zspec.zsdl covers: Barrier parties/n_waiting/broken, BoundedSemaphore._value/_initial_value, RLock, Condition runtime behavior."
    - "threading_timer.zspec.zsdl covers: Timer base class and module, ThreadError module and base, main_thread name/class, current_thread name, enumerate, active_count return type; Thread and Barrier __module__ in a table."
    - "This spec adds: Barrier __name__/__module__ as standalone invariants; BrokenBarrierError __name__ and __bases__[0].__name__; local __name__/__module__ as standalone invariants (complementing threading_extra table); excepthook/__name__, current_thread/__name__, main_thread/__name__ as standalone invariants."
    - "threading.Barrier.__name__ == 'Barrier' — confirmed on CPython 3.12."
    - "threading.Barrier.__module__ == 'threading' — confirmed on CPython 3.12."
    - "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError' — confirmed on CPython 3.12."
    - "threading.BrokenBarrierError.__bases__[0].__name__ == 'Exception' — BrokenBarrierError is a direct Exception subclass."
    - "threading.local.__name__ == 'local' — the C-level type's public name."
    - "threading.local.__module__ == '_thread' — the C extension provides local."
    - "threading.excepthook.__name__ == 'excepthook' — confirmed on CPython 3.12."
    - "threading.current_thread.__name__ == 'current_thread' — confirmed on CPython 3.12."
    - "threading.main_thread.__name__ == 'main_thread' — confirmed on CPython 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Barrier — __name__ and __module__
#
# threading_timer covers Barrier.__module__ in a table; threading_extra2 covers
# Barrier.__name__ in a table. This spec adds them as standalone named invariants
# for unambiguous traceability.
# ---------------------------------------------------------------------------

invariant threading_extra3.Barrier.name:
  description: "threading.Barrier.__name__ == 'Barrier'"
  category: class_names
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra3.Barrier.module:
  description: "threading.Barrier.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenBarrierError — __name__ and base class hierarchy
#
# BrokenBarrierError is raised when threading.Barrier.abort() is called or
# the barrier times out. It is a direct subclass of Exception.
# ---------------------------------------------------------------------------

invariant threading_extra3.BrokenBarrierError.name:
  description: "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError'"
  category: class_names
  kind: python_call_eq
  function: BrokenBarrierError.__name__.__eq__
  args: ["BrokenBarrierError"]
  expected: true

invariant threading_extra3.BrokenBarrierError.module:
  description: "threading.BrokenBarrierError.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: BrokenBarrierError.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra3.BrokenBarrierError.base:
  description: "threading.BrokenBarrierError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: BrokenBarrierError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant threading_extra3.BrokenBarrierError.is_exception_subclass:
  description: "threading.BrokenBarrierError.__bases__[0] is the Exception built-in"
  category: class_hierarchy
  kind: python_call_eq
  function: BrokenBarrierError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# threading.local — __name__ and __module__ as standalone invariants
#
# threading_extra covers these in a table alongside other class_modules rows.
# This spec adds them as standalone invariants for independent traceability.
# The local type is defined in the C-level _thread extension; its __module__
# is '_thread', not 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra3.local.name:
  description: "threading.local.__name__ == 'local' — the C-level type's public name"
  category: local
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["local"]
  expected: true

invariant threading_extra3.local.module:
  description: "threading.local.__module__ == '_thread' — local is implemented in the C extension"
  category: local
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# threading.excepthook — __name__
#
# threading.excepthook was added in Python 3.8 and handles exceptions raised
# in Thread.run(). Its __name__ must be 'excepthook'.
# ---------------------------------------------------------------------------

invariant threading_extra3.excepthook.name:
  description: "threading.excepthook.__name__ == 'excepthook'"
  category: function_names
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["excepthook"]
  expected: true

# ---------------------------------------------------------------------------
# current_thread and main_thread — __name__ as standalone invariants
#
# threading.zspec.zsdl and threading_extra2.zspec.zsdl cover these in tables.
# This spec adds them as standalone named invariants for clear traceability.
# ---------------------------------------------------------------------------

invariant threading_extra3.current_thread.name:
  description: "threading.current_thread.__name__ == 'current_thread'"
  category: function_names
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra3.main_thread.name:
  description: "threading.main_thread.__name__ == 'main_thread'"
  category: function_names
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenBarrierError — is-instance of Exception (via MRO)
# Verifies that BrokenBarrierError is reachable as an Exception in the MRO.
# ---------------------------------------------------------------------------

invariant threading_extra3.BrokenBarrierError.mro_index1:
  description: "threading.BrokenBarrierError.__mro__[1].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: BrokenBarrierError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# BrokenBarrierError — instantiation does not raise
# A newly constructed BrokenBarrierError is a valid exception object.
# ---------------------------------------------------------------------------

invariant threading_extra3.BrokenBarrierError.instantiation_class:
  description: "BrokenBarrierError('test').__class__.__name__ == 'BrokenBarrierError'"
  category: class_names
  kind: python_call_eq
  function: BrokenBarrierError
  args: ["test"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["BrokenBarrierError"]
  expected: true

# ---------------------------------------------------------------------------
# threading.local — instance creation
# threading.local() creates a thread-local storage object. Verify the class
# name of the returned instance.
# ---------------------------------------------------------------------------

invariant threading_extra3.local.instance_class:
  description: "threading.local().__class__.__name__ == 'local'"
  category: local
  kind: python_call_eq
  function: local
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["local"]
  expected: true
