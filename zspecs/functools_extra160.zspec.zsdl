spec: functools_extra160
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.__spec__.__class__.__name__ 'ModuleSpec'; functools.__spec__.name 'functools'; functools.__all__.__class__.__name__ 'list'; functools.__all__.__contains__ checks for 'reduce', 'partial', 'lru_cache', 'cached_property'; functools.__all__.__len__() 15 (Wave 284)."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec' — functools is a Python/C hybrid module; its __spec__ is an importlib.machinery.ModuleSpec instance; __class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' — the ModuleSpec records the fully-qualified module name 'functools'. Verified with Python 3.14.3."
    - "functools.__all__.__class__.__name__ == 'list' — __all__ is a module-level list of public names exported by functools. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('reduce') == True — 'reduce' is in functools.__all__; it is the standard functional reduce (moved from builtins in Python 3). Verified with Python 3.14.3."
    - "functools.__all__.__contains__('partial') == True — 'partial' is in functools.__all__; it creates partial function applications. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is in functools.__all__; it is the LRU memoization decorator. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('cached_property') == True — 'cached_property' is in functools.__all__; it is a class-level caching descriptor. Verified with Python 3.14.3."
    - "functools.__all__.__len__() == 15 — functools.__all__ contains 15 public names: update_wrapper, wraps, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, total_ordering, cache, cmp_to_key, lru_cache, reduce, partial, partialmethod, singledispatch, singledispatchmethod, cached_property, Placeholder. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__spec__ attributes
#
# Wave 284 theme: functools.__spec__ ModuleSpec class and name; functools.__all__
# class and membership.
#
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.name.__eq__('functools') == True
# functools.__all__.__class__.__name__ == 'list'
# functools.__all__.__contains__('reduce') == True
#
# functools is imported via importlib and its __spec__ is a ModuleSpec object
# recording the module name, origin file, and loader. __all__ is a list
# of public names that restricts 'from functools import *' to exactly those
# names. New to extra160.
# ---------------------------------------------------------------------------

table functools_extra160.spec_and_all_membership:
  description: "functools.__spec__: class 'ModuleSpec', name 'functools'; functools.__all__: class 'list', contains 'reduce'/'partial'/'lru_cache'/'cached_property'; wave 284; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsspecall160

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — functools.__spec__ is an importlib.machinery.ModuleSpec instance; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra160"]
    - [spec_name_eq_functools,
       "__spec__.name.__eq__",
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — the ModuleSpec for functools records the fully-qualified module name 'functools'; str.__eq__('functools') returns True; new to extra160"]
    - [all_class_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "functools.__all__.__class__.__name__.__eq__('list') == True — functools.__all__ is a module-level list of public export names; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra160"]
    - [all_contains_reduce,
       "__all__.__contains__",
       ["reduce"],
       true,
       "functools.__all__.__contains__('reduce') == True — 'reduce' is listed in functools.__all__; it is the functional reduce operation (moved from builtins in Python 3); list.__contains__('reduce') returns True; new to extra160"]

# ---------------------------------------------------------------------------
# Table 2: functools.__all__ membership checks and length
#
# Wave 284 theme: functools.__all__ contains key decorator names; total length.
#
# functools.__all__.__contains__('partial') == True
# functools.__all__.__contains__('lru_cache') == True
# functools.__all__.__contains__('cached_property') == True
# functools.__all__.__len__() == 15
#
# As of Python 3.14, functools.__all__ has 15 entries including the new
# 'Placeholder' sentinel and 'cache' alias. New to extra160.
# ---------------------------------------------------------------------------

table functools_extra160.all_more_members_and_len:
  description: "functools.__all__ contains 'partial', 'lru_cache', 'cached_property'; __len__() 15; wave 284; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsallmem160

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_partial,
       "__all__.__contains__",
       ["partial"],
       true,
       "functools.__all__.__contains__('partial') == True — 'partial' is listed in functools.__all__; it is the C-implemented partial function application object from _functoolsmodule.c; list.__contains__('partial') returns True; new to extra160"]
    - [all_contains_lru_cache,
       "__all__.__contains__",
       ["lru_cache"],
       true,
       "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is listed in functools.__all__; it is the LRU memoization decorator (bounded cache based on call arguments); list.__contains__('lru_cache') returns True; new to extra160"]
    - [all_contains_cached_property,
       "__all__.__contains__",
       ["cached_property"],
       true,
       "functools.__all__.__contains__('cached_property') == True — 'cached_property' is listed in functools.__all__; it is a descriptor that caches the result of a method as an instance attribute on first access; list.__contains__('cached_property') returns True; new to extra160"]
    - [all_len_eq_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — functools.__all__ contains 15 public names: update_wrapper, wraps, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, total_ordering, cache, cmp_to_key, lru_cache, reduce, partial, partialmethod, singledispatch, singledispatchmethod, cached_property, Placeholder; list.__len__() returns 15; new to extra160"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra160
# ---------------------------------------------------------------------------

invariant functools_extra160.spec_class_ModuleSpec:
  description: "functools.__spec__.__class__.__name__ == 'ModuleSpec' — functools.__spec__ is an importlib.machinery.ModuleSpec; wave 284; new to extra160"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant functools_extra160.spec_name_functools:
  description: "functools.__spec__.name == 'functools' — ModuleSpec records the module's fully-qualified name; wave 284; new to extra160"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra160.all_class_list:
  description: "functools.__all__.__class__.__name__ == 'list' — __all__ is a list of public exported names; wave 284; new to extra160"
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant functools_extra160.all_contains_reduce:
  description: "functools.__all__.__contains__('reduce') == True — 'reduce' is publicly exported from functools; wave 284; new to extra160"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra160.all_contains_partial:
  description: "functools.__all__.__contains__('partial') == True — 'partial' is publicly exported from functools; wave 284; new to extra160"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra160.all_contains_lru_cache:
  description: "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' LRU memoization decorator is in functools.__all__; wave 284; new to extra160"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra160.all_contains_cached_property:
  description: "functools.__all__.__contains__('cached_property') == True — 'cached_property' caching descriptor is in functools.__all__; wave 284; new to extra160"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["cached_property"]
  expected: true

invariant functools_extra160.all_len_15:
  description: "functools.__all__.__len__() == 15 — functools exports 15 public names as of Python 3.14; wave 284; new to extra160"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15
