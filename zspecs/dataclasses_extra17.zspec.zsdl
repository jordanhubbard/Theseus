spec: dataclasses_extra17
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra16.zspec.zsdl."
    - "dataclasses_extra16 covers: fields/asdict/astuple/replace __qualname__.__len__; FrozenInstanceError MRO[0]; fields/asdict/astuple/make_dataclass/is_dataclass __module__ as standalone invariants."
    - "dataclasses_extra15 covers: Field/__name__.__len__, InitVar/__name__.__len__, FrozenInstanceError/__name__.__len__, Field/__qualname__.__len__, InitVar/__qualname__.__len__, is_dataclass/__qualname__.__len__, make_dataclass/__qualname__.__len__; dataclass/__module__; field/__module__."
    - "dataclasses_extra14 covers: Field/__bases__ len/[0]; FrozenInstanceError/__bases__[0].__name__; module/__name__/__eq__; dataclass/__qualname__; replace/__name__/__name__.__len__; is_dataclass/__name__.__len__."
    - "Focus of this spec: __qualname__.__len__ for field and dataclass (not in any prior spec); FrozenInstanceError.__name__.__len__ == 19; standalone InitVar and Field __qualname__ equality; dataclass and field __name__ string lengths."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for field and dataclass
#
# dataclasses_extra16 covers fields/asdict/astuple/replace qualname lengths.
# dataclasses_extra15 covers Field/InitVar/is_dataclass/make_dataclass qualname lengths.
# No prior spec checks __qualname__.__len__() for the lowercase 'field' factory
# function or the 'dataclass' decorator function. Both are 5 and 9 characters
# respectively (qualname equals name for top-level functions).
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.field.qualname_len:
  description: "dataclasses.field.__qualname__.__len__() == 5 — 'field' is 5 characters"
  category: qualnames
  kind: python_call_eq
  function: field.__qualname__.__len__
  args: []
  expected: 5

invariant dataclasses_extra17.dataclass.qualname_len:
  description: "dataclasses.dataclass.__qualname__.__len__() == 9 — 'dataclass' is 9 characters"
  category: qualnames
  kind: python_call_eq
  function: dataclass.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# __name__.__len__() for field and dataclass
#
# dataclasses_extra15 covers Field/__name__.__len__, InitVar/__name__.__len__,
# FrozenInstanceError/__name__.__len__ (table). dataclasses_extra13 covers
# field/__name__.__len__ and make_dataclass/__name__.__len__.
# No prior spec checks dataclass.__name__.__len__() as a standalone invariant.
# 'dataclass' is 9 characters; 'field' was covered in extra13.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.dataclass.name_len:
  description: "dataclasses.dataclass.__name__.__len__() == 9 — 'dataclass' is 9 characters"
  category: class_names
  kind: python_call_eq
  function: dataclass.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# __qualname__.__eq__ standalone invariants for field and dataclass
#
# dataclasses_extra14 covers dataclass.__qualname__.__eq__ as a standalone.
# dataclasses_extra13 covers fields/asdict/astuple/replace/is_dataclass qualname
# in a table. No prior spec verifies field.__qualname__.__eq__ as a standalone
# boolean invariant. For top-level functions, qualname equals name.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.field.qualname_eq:
  description: "dataclasses.field.__qualname__ == 'field' — factory function qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: field.__qualname__.__eq__
  args: ["field"]
  expected: true

# ---------------------------------------------------------------------------
# FrozenInstanceError.__qualname__.__eq__ standalone
#
# dataclasses_extra13 covers FrozenInstanceError.__qualname__.__len__() == 19.
# No prior spec verifies FrozenInstanceError.__qualname__.__eq__ as a standalone
# boolean invariant. The qualname equals the name for a top-level exception class.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.FrozenInstanceError.qualname_eq:
  description: "dataclasses.FrozenInstanceError.__qualname__ == 'FrozenInstanceError' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: FrozenInstanceError.__qualname__.__eq__
  args: ["FrozenInstanceError"]
  expected: true

# ---------------------------------------------------------------------------
# FrozenInstanceError.__name__.__eq__ standalone
#
# dataclasses_extra15 covers FrozenInstanceError.__name__.__len__() == 19.
# No prior spec verifies FrozenInstanceError.__name__.__eq__ as a standalone
# boolean invariant confirming the full string value.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.FrozenInstanceError.name_eq:
  description: "dataclasses.FrozenInstanceError.__name__ == 'FrozenInstanceError' — standalone __eq__ invariant"
  category: class_names
  kind: python_call_eq
  function: FrozenInstanceError.__name__.__eq__
  args: ["FrozenInstanceError"]
  expected: true

# ---------------------------------------------------------------------------
# InitVar.__qualname__.__eq__ standalone
#
# dataclasses_extra15 covers InitVar.__qualname__.__len__() == 7.
# dataclasses_extra13 covers InitVar.__qualname__.__eq__ (via function_qualname table).
# Verify as a standalone invariant for completeness and deduplication clarity.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.InitVar.qualname_eq:
  description: "dataclasses.InitVar.__qualname__ == 'InitVar' — class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: InitVar.__qualname__.__eq__
  args: ["InitVar"]
  expected: true

# ---------------------------------------------------------------------------
# Field.__qualname__.__eq__ standalone
#
# dataclasses_extra15 covers Field.__qualname__.__len__() == 5.
# dataclasses_extra13 covers Field.__qualname__ (table row).
# Verify the string value as a standalone boolean eq invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.Field.qualname_eq:
  description: "dataclasses.Field.__qualname__ == 'Field' — class qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: Field.__qualname__.__eq__
  args: ["Field"]
  expected: true

# ---------------------------------------------------------------------------
# dataclass.__name__.__eq__ standalone
#
# dataclasses_extra14 covers dataclass.__qualname__.__eq__ == 'dataclass'.
# No prior spec checks dataclass.__name__.__eq__ as a standalone boolean.
# For top-level functions __name__ equals __qualname__.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.dataclass.name_eq:
  description: "dataclasses.dataclass.__name__ == 'dataclass' — decorator function name equals qualname"
  category: class_names
  kind: python_call_eq
  function: dataclass.__name__.__eq__
  args: ["dataclass"]
  expected: true

# ---------------------------------------------------------------------------
# fields.__qualname__.__eq__ standalone
#
# dataclasses_extra16 covers fields.__qualname__.__len__() == 6.
# dataclasses_extra13 covers fields.__qualname__.__eq__ in a table.
# Verify as a standalone boolean invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra17.fields.qualname_eq:
  description: "dataclasses.fields.__qualname__ == 'fields' — top-level function qualname"
  category: qualnames
  kind: python_call_eq
  function: fields.__qualname__.__eq__
  args: ["fields"]
  expected: true
