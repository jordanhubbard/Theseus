spec: nacl_rust
version: ">=3.9"
backend: rust_module(nacl_rust)

docs: https://pynacl.readthedocs.io/

provenance:
  derived_from:
    - "https://pynacl.readthedocs.io/ — PyNaCl library"
  notes:
    - "PyNaCl provides NaCl/libsodium cryptographic bindings."
    - "nacl.signing.SigningKey.generate() returns a SigningKey."
    - "nacl.hash.sha256(b'hello') returns bytes of length 32."
    - "nacl.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant nacl_rust.has_signing_key:
  description: "nacl.signing.SigningKey is a class"
  category: presence
  kind: python_call_eq
  function: nacl_has_signing_key
  args: []
  expected: true

invariant nacl_rust.sha256_len:
  description: "nacl.hash.sha256(b'hello') has length 32"
  category: hash
  kind: python_call_eq
  function: nacl_sha256_len
  args: []
  expected: 32

invariant nacl_rust.version_nonempty:
  description: "nacl.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: nacl_version_nonempty
  args: []
  expected: true

