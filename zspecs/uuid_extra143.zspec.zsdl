spec: uuid_extra143
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra142.zspec.zsdl — covers uuid.SafeUUID.__dict__.__len__()==19 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / SafeUUID.__dict__.__contains__('safe'/'unsafe'/'unknown'/'_member_names_') / UUID.__dict__.__contains__('__setattr__'/'is_safe') (table + invariants)."
    - "uuid_extra141.zspec.zsdl — covers uuid.__dict__.__contains__('UUID'/'uuid1'/'uuid3'/'uuid4'/'uuid5'/'NAMESPACE_DNS'/'NAMESPACE_URL') / uuid.__dict__.__len__()==75 / uuid.__dict__.__class__.__name__.__eq__('dict') (table + invariants)."
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') (all four namespace constants) / NAMESPACE_DNS.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra142."
    - "Wave 333 theme: uuid module reserved constant string values — RESERVED_NCS/'reserved for NCS compatibility' (len 30) / RFC_4122/'specified in RFC 4122' (len 21) / RESERVED_MICROSOFT/'reserved for Microsoft compatibility' (len 36) / RESERVED_FUTURE/'reserved for future definition' (len 30). Also type checks: all four are plain str (__class__.__name__=='str')."
    - "uuid.RESERVED_NCS == 'reserved for NCS compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122 == 'specified in RFC 4122'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE == 'reserved for future definition'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__len__() == 30. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__len__() == 21. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__len__() == 36. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__len__() == 30. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The four RESERVED_* and RFC_4122 string constants in uuid are used by the UUID.variant property to describe the variant of a UUID. UUID.variant returns one of these four strings depending on the top bits of the UUID's 'clock_seq_hi_variant' field. RESERVED_NCS (for NCS backward compatibility), RFC_4122 (the standard variant used by uuid1/uuid3/uuid4/uuid5), RESERVED_MICROSOFT (for Microsoft backward compatibility), and RESERVED_FUTURE (for future definition)."
    - "Note: RESERVED_NCS has len 30 ('reserved for NCS compatibility'), RESERVED_FUTURE also has len 30 ('reserved for future definition'). RFC_4122 is the shortest at 21 chars ('specified in RFC 4122'). RESERVED_MICROSOFT is the longest at 36 chars ('reserved for Microsoft compatibility'). Ordering by length: RFC_4122(21) < RESERVED_NCS(30) == RESERVED_FUTURE(30) < RESERVED_MICROSOFT(36)."
    - "Note: All four constants are plain Python str objects (__class__.__name__ == 'str', 3 chars). They are module-level string constants defined in uuid.py, not enum members or special types. They serve as human-readable labels for UUID variant identification."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility')
# uuid.RFC_4122.__eq__('specified in RFC 4122')
# uuid.RESERVED_MICROSOFT.__eq__('reserved for Microsoft compatibility')
# uuid.RESERVED_FUTURE.__eq__('reserved for future definition')
#
# Wave 333 theme: uuid reserved constant string equality.
#
# The four uuid variant constants are plain str objects with fixed values defined in
# uuid.py. They are returned by the UUID.variant property. No prior uuid spec anchors
# the string equality of any of these four constants as a table under uuidrsv143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra143.reserved_constants_string_equality:
  description: "uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility')==True / RFC_4122.__eq__('specified in RFC 4122')==True / RESERVED_MICROSOFT.__eq__('reserved for Microsoft compatibility')==True / RESERVED_FUTURE.__eq__('reserved for future definition')==True — four variant descriptor strings; returned by UUID.variant property; all plain str; NCS is oldest variant (pre-RFC 4122); RFC_4122 is the standard variant; MICROSOFT is for COM/DCOM backward compat; FUTURE is reserved; first uuidrsv143 anchor for these string equality checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidrsv143

  columns: [id, function, args, expected, description]
  rows:
    - [RESERVED_NCS_eq,       "RESERVED_NCS.__eq__",       ["reserved for NCS compatibility"],          true, "uuid.RESERVED_NCS == 'reserved for NCS compatibility' (NCS = Network Computing System; oldest UUID variant)"]
    - [RFC_4122_eq,           "RFC_4122.__eq__",           ["specified in RFC 4122"],                   true, "uuid.RFC_4122 == 'specified in RFC 4122' (the standard UUID variant used by uuid1/uuid3/uuid4/uuid5)"]
    - [RESERVED_MICROSOFT_eq, "RESERVED_MICROSOFT.__eq__", ["reserved for Microsoft compatibility"],    true, "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility' (COM/DCOM backward compatibility variant)"]
    - [RESERVED_FUTURE_eq,    "RESERVED_FUTURE.__eq__",    ["reserved for future definition"],          true, "uuid.RESERVED_FUTURE == 'reserved for future definition' (fourth UUID variant; reserved by RFC 4122)"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__class__.__name__.__eq__('str')
# uuid.RFC_4122.__class__.__name__.__eq__('str')
# uuid.RESERVED_NCS.__len__()==30
# uuid.RFC_4122.__len__()==21
#
# Wave 333 theme: reserved constants are plain str with specific lengths.
#
# All four uuid variant constants are plain Python str objects. RESERVED_NCS is 30 chars,
# RFC_4122 is 21 chars (shortest). The type name 'str' (3 chars) confirms these are
# ordinary string constants, not enum members or special types. No prior uuid spec anchors
# the class name or length of any variant constant as a table under uuidrsv143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra143.reserved_constants_type_and_len:
  description: "uuid.RESERVED_NCS.__class__.__name__.__eq__('str')==True / RFC_4122.__class__.__name__.__eq__('str')==True / RESERVED_NCS.__len__()==30 / RFC_4122.__len__()==21 — all four variant constants are plain 'str' (3 chars); RESERVED_NCS len 30 ('reserved for NCS compatibility'); RFC_4122 len 21 ('specified in RFC 4122'); length ordering: RFC_4122(21) < RESERVED_NCS(30) == RESERVED_FUTURE(30) < RESERVED_MICROSOFT(36); first uuidrsv143 anchor for class name and length of variant constants"
  kind: python_call_eq
  category: identity
  id_prefix: uuidrsv143

  columns: [id, function, args, expected, description]
  rows:
    - [RESERVED_NCS_class_str,  "RESERVED_NCS.__class__.__name__.__eq__", ["str"], true, "uuid.RESERVED_NCS.__class__.__name__ == 'str' (3 chars; plain Python string constant, not an enum member)"]
    - [RFC_4122_class_str,      "RFC_4122.__class__.__name__.__eq__",     ["str"], true, "uuid.RFC_4122.__class__.__name__ == 'str' (3 chars; plain Python string constant)"]
    - [RESERVED_NCS_len_30,     "RESERVED_NCS.__len__",                  [],       30, "uuid.RESERVED_NCS.__len__() is 30 ('reserved for NCS compatibility' = 30 chars)"]
    - [RFC_4122_len_21,         "RFC_4122.__len__",                      [],       21, "uuid.RFC_4122.__len__() is 21 ('specified in RFC 4122' = 21 chars; shortest of the four variant constants)"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT.__len__()==36
# uuid.RESERVED_FUTURE.__len__()==30
#
# Wave 333 theme: RESERVED_MICROSOFT is the longest variant constant; RESERVED_FUTURE ties NCS.
#
# RESERVED_MICROSOFT is 36 chars ('reserved for Microsoft compatibility') — the longest
# of the four variant constants. RESERVED_FUTURE is 30 chars ('reserved for future
# definition') — tied with RESERVED_NCS (30 chars). No prior uuid spec anchors the
# length of RESERVED_MICROSOFT or RESERVED_FUTURE as a table under uuidrsv143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra143.reserved_microsoft_future_len:
  description: "uuid.RESERVED_MICROSOFT.__len__()==36 / RESERVED_FUTURE.__len__()==30 / RESERVED_MICROSOFT.__class__.__name__.__eq__('str')==True / RESERVED_FUTURE.__class__.__name__.__eq__('str')==True — RESERVED_MICROSOFT is 36 chars (longest variant constant: 'reserved for Microsoft compatibility'); RESERVED_FUTURE is 30 chars (tied with RESERVED_NCS at 30); length ordering: RFC_4122(21) < RESERVED_NCS(30) == RESERVED_FUTURE(30) < RESERVED_MICROSOFT(36); all four are plain 'str'; first uuidrsv143 anchor for MICROSOFT/FUTURE len"
  kind: python_call_eq
  category: identity
  id_prefix: uuidrsv143

  columns: [id, function, args, expected, description]
  rows:
    - [RESERVED_MICROSOFT_len_36,    "RESERVED_MICROSOFT.__len__",                  [],       36, "uuid.RESERVED_MICROSOFT.__len__() is 36 ('reserved for Microsoft compatibility' = 36 chars; longest)"]
    - [RESERVED_FUTURE_len_30,       "RESERVED_FUTURE.__len__",                     [],       30, "uuid.RESERVED_FUTURE.__len__() is 30 ('reserved for future definition' = 30 chars; tied with RESERVED_NCS)"]
    - [RESERVED_MICROSOFT_class_str, "RESERVED_MICROSOFT.__class__.__name__.__eq__", ["str"], true, "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str' (3 chars; plain string)"]
    - [RESERVED_FUTURE_class_str,    "RESERVED_FUTURE.__class__.__name__.__eq__",   ["str"], true, "uuid.RESERVED_FUTURE.__class__.__name__ == 'str' (3 chars; plain string)"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility') — standalone
#
# uuid.RESERVED_NCS is the string 'reserved for NCS compatibility' (30 chars). It is
# returned by UUID.variant when the UUID's variant bits indicate an NCS-format UUID.
# NCS (Network Computing System) UUIDs predate RFC 4122. They are characterized by the
# most significant bit of octet 8 being 0. In modern practice, virtually all UUIDs are
# RFC 4122 format (variant == uuid.RFC_4122), but NCS-format UUIDs may be encountered
# in legacy systems. No prior uuid spec anchors RESERVED_NCS.__eq__ as a standalone
# under uuidrsv143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra143.RESERVED_NCS_eq:
  description: "uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility') == True — 30-char string; returned by UUID.variant for NCS-format UUIDs (MSB of octet 8 is 0); NCS predates RFC 4122; modern UUIDs are RFC_4122 variant; no prior uuid spec anchors RESERVED_NCS string equality as a standalone; first standalone under uuidrsv143"
  category: identity
  kind: python_call_eq
  function: RESERVED_NCS.__eq__
  args: ["reserved for NCS compatibility"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__eq__('specified in RFC 4122') — standalone
#
# uuid.RFC_4122 is the string 'specified in RFC 4122' (21 chars). It is the standard
# UUID variant used by all four UUID generation functions (uuid1, uuid3, uuid4, uuid5).
# RFC 4122 UUIDs are characterized by bits 10 in the most significant two bits of octet 8.
# UUID.variant returns uuid.RFC_4122 for all standard Python-generated UUIDs. The value
# 'specified in RFC 4122' is the shortest of the four variant constant strings (21 chars).
# No prior uuid spec anchors RFC_4122.__eq__ as a standalone under uuidrsv143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra143.RFC_4122_eq:
  description: "uuid.RFC_4122.__eq__('specified in RFC 4122') == True — 21-char string (shortest variant constant); returned by UUID.variant for all standard Python-generated UUIDs (uuid1/uuid3/uuid4/uuid5); RFC 4122 UUIDs have bits '10' in MSBs of octet 8; no prior uuid spec anchors RFC_4122 string equality as a standalone; first standalone under uuidrsv143"
  category: identity
  kind: python_call_eq
  function: RFC_4122.__eq__
  args: ["specified in RFC 4122"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT.__eq__('reserved for Microsoft compatibility') — standalone
#
# uuid.RESERVED_MICROSOFT is the string 'reserved for Microsoft compatibility' (36 chars).
# It is returned by UUID.variant when the UUID's variant bits indicate a Microsoft-format
# UUID (COM/DCOM GUIDs). Microsoft GUIDs use a variant code of 110 in the high bits of
# the clock_seq_hi_variant field. These GUIDs were used by Windows COM and DCOM for
# component identification. At 36 chars, RESERVED_MICROSOFT is the longest of the four
# variant constant strings. No prior uuid spec anchors RESERVED_MICROSOFT.__eq__ as a
# standalone under uuidrsv143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra143.RESERVED_MICROSOFT_eq:
  description: "uuid.RESERVED_MICROSOFT.__eq__('reserved for Microsoft compatibility') == True — 36-char string (longest variant constant); returned by UUID.variant for Microsoft COM/DCOM GUID-format UUIDs; variant code 110 in high bits of clock_seq_hi_variant; no prior uuid spec anchors RESERVED_MICROSOFT string equality as a standalone; first standalone under uuidrsv143"
  category: identity
  kind: python_call_eq
  function: RESERVED_MICROSOFT.__eq__
  args: ["reserved for Microsoft compatibility"]
  expected: true

