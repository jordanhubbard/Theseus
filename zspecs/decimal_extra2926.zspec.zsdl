spec: dc2926
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/decimal_extra2911.zspec.zsdl — wave 641 predecessor (covered __ilshift__, __irshift__, __ipow__)"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 642 theme: __iand__, __ior__, __ixor__ dict-presence checks (in-place bitwise AND, OR, XOR operators)."
    - "decimal.Decimal is a numeric type that defines __pow__ and __rpow__ (confirmed True in wave 637) but has no bitwise semantics at all."
    - "Decimal does not define __and__, __or__, or __xor__ (confirmed False), so the in-place variants __iand__, __ior__, __ixor__ are also absent."
    - "decimal.Context is a mutable configuration object that defines no bitwise operators on itself."
    - "decimal exception hierarchy classes (DecimalException and all subclasses) do NOT define any bitwise operators."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iand__ dict-presence
# Decimal has no bitwise AND operations — __iand__ absent from all types
# ---------------------------------------------------------------------------

table dc2926.iand:
  description: "__iand__ is absent from all decimal types — Decimal is not an integer type and has no bitwise AND semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2926

  columns: [id, function, args, expected]
  rows:
    - ["dc2926001", "decimal.Decimal.__dict__.__contains__",          ["__iand__"], false]
    - ["dc2926002", "decimal.Context.__dict__.__contains__",          ["__iand__"], false]
    - ["dc2926003", "decimal.DecimalException.__dict__.__contains__", ["__iand__"], false]
    - ["dc2926004", "decimal.InvalidOperation.__dict__.__contains__", ["__iand__"], false]
    - ["dc2926005", "decimal.DivisionByZero.__dict__.__contains__",   ["__iand__"], false]
    - ["dc2926006", "decimal.Overflow.__dict__.__contains__",         ["__iand__"], false]
    - ["dc2926007", "decimal.Decimal.__dict__.__contains__",          ["__and__"],  false]
    - ["dc2926008", "decimal.Context.__dict__.__contains__",          ["__and__"],  false]

