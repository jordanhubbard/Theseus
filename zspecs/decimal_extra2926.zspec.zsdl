# ---------------------------------------------------------------------------
# Table: Decimal bitwise profile — __pow__/__rpow__ present, all bitwise ops absent
# Key insight: Decimal supports ** but has no &, |, ^ support (inplace or otherwise)
# ---------------------------------------------------------------------------

table dc2926.combined:
  description: "decimal.Decimal defines __pow__ and __rpow__ (True) but has NO bitwise support — __and__/__or__/__xor__ and their in-place variants are all absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2926

  columns: [id, function, args, expected]
  rows:
    - ["dc2926025", "decimal.Decimal.__dict__.__contains__", ["__pow__"],  true]
    - ["dc2926026", "decimal.Decimal.__dict__.__contains__", ["__rpow__"], true]
    - ["dc2926027", "decimal.Decimal.__dict__.__contains__", ["__and__"],  false]
    - ["dc2926028", "decimal.Decimal.__dict__.__contains__", ["__or__"],   false]
    - ["dc2926029", "decimal.Decimal.__dict__.__contains__", ["__xor__"],  false]
    - ["dc2926030", "decimal.Decimal.__dict__.__contains__", ["__iand__"], false]
    - ["dc2926031", "decimal.Decimal.__dict__.__contains__", ["__ior__"],  false]
    - ["dc2926032", "decimal.Decimal.__dict__.__contains__", ["__ixor__"], false]
    - ["dc2926033", "decimal.Clamped.__dict__.__contains__",        ["__iand__"], false]
    - ["dc2926034", "decimal.Inexact.__dict__.__contains__",        ["__ior__"],  false]
    - ["dc2926035", "decimal.Rounded.__dict__.__contains__",        ["__ixor__"], false]
    - ["dc2926036", "decimal.Subnormal.__dict__.__contains__",      ["__iand__"], false]
    - ["dc2926037", "decimal.FloatOperation.__dict__.__contains__", ["__ior__"],  false]
