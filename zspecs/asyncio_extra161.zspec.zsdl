spec: asyncio_extra161
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: asyncio.Semaphore and asyncio.BoundedSemaphore class identity, plus asyncio.Condition base class. asyncio.Semaphore.__name__=='Semaphore' (len=9: 'S'+'e'+'m'+'a'+'p'+'h'+'o'+'r'+'e'=9); asyncio.Semaphore.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; pure Python, defined in Lib/asyncio/locks.py — same module as asyncio.Lock, asyncio.Event, asyncio.Condition); asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (len=20; Semaphore inherits from _ContextManagerMixin, the private mixin that provides async context manager support for asyncio synchronization primitives — established as the Lock base in extra158); asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16: 'Bounded'=7+'Semaphore'=9=16); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (len=9; BoundedSemaphore inherits from Semaphore — it IS-A Semaphore that additionally raises ValueError when release() would cause the count to exceed the initial value); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (Condition shares the same base as Lock and Semaphore). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20) — _ContextManagerMixin is the private mixin that provides async context manager support (__aenter__ and __aexit__) for asyncio synchronization primitives; asyncio.Lock also inherits from _ContextManagerMixin (established in prior specs); this is different from asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (established in extra160 — queues use a different mixin because they do not support async with); Semaphore._ContextManagerMixin (len=20) > Queue._LoopBoundMixin (len=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' — BoundedSemaphore inherits directly from Semaphore; BoundedSemaphore overrides release() to raise ValueError if the internal counter would exceed the initial value; this prevents 'releasing a semaphore too many times'; compare: Semaphore allows repeated release() beyond the initial value, BoundedSemaphore does not; asyncio.BoundedSemaphore.__name__.__len__()==16 vs Semaphore.__name__.__len__()==9 — 'Bounded'=7 prefix makes BoundedSemaphore name 7 chars longer. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' — Condition shares the same base class as Lock and Semaphore; Condition is used for producer-consumer synchronization where one coroutine needs to wait for a specific condition to be true while holding a lock; Condition.__bases__[0].__name__ == '_ContextManagerMixin' (len=20); compare: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (same base as Condition) and asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore is one level deeper: object -> _ContextManagerMixin -> Semaphore -> BoundedSemaphore). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Semaphore class identity — extra161
#
# asyncio.Semaphore.__name__.__eq__('Semaphore')                          == True
# asyncio.Semaphore.__module__.__eq__('asyncio.locks')                    == True
# asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin')  == True
# ---------------------------------------------------------------------------

table asyncio_extra161.asyncio_semaphore_identity:
  description: "asyncio.Semaphore class identity checks in asynciosema161 namespace — asyncio.Semaphore.__name__=='Semaphore' (len=9: 'S'+'e'+'m'+'a'+'p'+'h'+'o'+'r'+'e'=9; the asyncio counting semaphore class; controls access to a shared resource by maintaining a count; acquire() decrements the count and blocks if zero; release() increments the count and wakes waiting coroutines); asyncio.Semaphore.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; pure Python, defined in Lib/asyncio/locks.py alongside Lock, Event, and Condition — the same module established as Lock.__module__ in prior specs); asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20; Semaphore inherits from the private async context manager mixin — same as asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin'); Semaphore.__name__.__len__()==9; compare: BoundedSemaphore.__name__.__len__()==16 (7 longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosema161

  columns: [id, function, args, expected, description]
  rows:
    - [sema_name_eq,   asyncio.Semaphore.__name__.__eq__,                          ["Semaphore"],           true,  "asyncio.Semaphore.__name__ == 'Semaphore' (len=9; asyncio counting semaphore); verified with Python 3.14.3"]
    - [sema_mod_eq,    asyncio.Semaphore.__module__.__eq__,                          ["asyncio.locks"],       true,  "asyncio.Semaphore.__module__ == 'asyncio.locks' (len=13; pure Python, same module as Lock and Condition); verified with Python 3.14.3"]
    - [sema_base_eq,   "asyncio.Semaphore.__bases__[0].__name__.__eq__",             ["_ContextManagerMixin"], true, "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' (same base as Lock and Condition); verified with Python 3.14.3"]
    - [sema_name_len,  asyncio.Semaphore.__name__.__len__,                           [],                      9,    "asyncio.Semaphore.__name__.__len__() == 9 ('Semaphore'; 7 shorter than BoundedSemaphore=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore class identity — extra161
#
# asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore')              == True
# asyncio.BoundedSemaphore.__module__.__eq__('asyncio.locks')               == True
# asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')        == True
# ---------------------------------------------------------------------------

table asyncio_extra161.asyncio_bounded_semaphore_identity:
  description: "asyncio.BoundedSemaphore class identity checks in asynciobsema161 namespace — asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16: 'Bounded'=7+'Semaphore'=9=16; the asyncio bounded semaphore class that raises ValueError on release() if the count would exceed the initial value — preventing 'releasing too many times'); asyncio.BoundedSemaphore.__module__=='asyncio.locks' (len=13; same module as Semaphore, Lock, Event, Condition — all in Lib/asyncio/locks.py); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (len=9; BoundedSemaphore inherits from Semaphore — it IS-A Semaphore with an additional upper-bound check in release()); BoundedSemaphore.__name__.__len__()==16 is the longest asyncio locks class name: Lock(4) < Event(5) < Semaphore(9) < Condition(9) < BoundedSemaphore(16); compare: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (Semaphore base is the mixin) vs asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore base is Semaphore itself — one level deeper); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciobsema161

  columns: [id, function, args, expected, description]
  rows:
    - [bsema_name_eq,   asyncio.BoundedSemaphore.__name__.__eq__,                ["BoundedSemaphore"],    true,  "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16; adds upper-bound check to Semaphore); verified with Python 3.14.3"]
    - [bsema_mod_eq,    asyncio.BoundedSemaphore.__module__.__eq__,               ["asyncio.locks"],       true,  "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' (len=13; same module as Semaphore); verified with Python 3.14.3"]
    - [bsema_base_eq,   "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__",  ["Semaphore"],           true,  "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (inherits from Semaphore, not from _ContextManagerMixin directly); verified with Python 3.14.3"]
    - [bsema_name_len,  asyncio.BoundedSemaphore.__name__.__len__,                [],                      16,    "asyncio.BoundedSemaphore.__name__.__len__() == 16 ('BoundedSemaphore'; longest asyncio locks class name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Condition base and cross-comparison — extra161
#
# asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')   == True
# asyncio.Semaphore.__module__.__len__()                                    == 13
# ---------------------------------------------------------------------------

table asyncio_extra161.asyncio_condition_base_and_comparison:
  description: "asyncio.Condition base class and cross-comparison checks in asynciocond161 namespace — asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20; Condition inherits from the same _ContextManagerMixin as Lock and Semaphore — all asyncio synchronization primitives that support 'async with' share this mixin); asyncio.Semaphore.__module__.__len__()==13 ('asyncio.locks'=13: 'asyncio'=7+'.'=1+'locks'=5=13); asyncio.BoundedSemaphore.__module__.__len__()==13 (same module as Semaphore — BoundedSemaphore.__module__ == Semaphore.__module__ == 'asyncio.locks'); '_ContextManagerMixin'.__len__()==20 vs '_LoopBoundMixin'.__len__()==15 (asyncio.Queue base mixin is shorter by 5); the pattern: lock-like primitives (Lock, Semaphore, Condition) use _ContextManagerMixin while queue-like primitives (Queue, PriorityQueue, LifoQueue) use _LoopBoundMixin; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocond161

  columns: [id, function, args, expected, description]
  rows:
    - [cond_base_eq,    "asyncio.Condition.__bases__[0].__name__.__eq__",   ["_ContextManagerMixin"],  true,  "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin' (shared base with Lock and Semaphore); verified with Python 3.14.3"]
    - [sema_mod_len,    asyncio.Semaphore.__module__.__len__,               [],                         13,    "asyncio.Semaphore.__module__.__len__() == 13 ('asyncio.locks'); verified with Python 3.14.3"]
    - [bsema_mod_len,   asyncio.BoundedSemaphore.__module__.__len__,        [],                         13,    "asyncio.BoundedSemaphore.__module__.__len__() == 13 (same module as Semaphore); verified with Python 3.14.3"]
    - [bsema_base_len,  "asyncio.BoundedSemaphore.__bases__[0].__name__.__len__",  [],                  9,    "asyncio.BoundedSemaphore.__bases__[0].__name__.__len__() == 9 ('Semaphore'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra161
# ---------------------------------------------------------------------------

invariant asyncio_extra161.asyncio_Semaphore_name_eq:
  description: "asyncio.Semaphore.__name__.__eq__('Semaphore') returns True — asyncio.Semaphore is the pure-Python asyncio counting semaphore class defined in Lib/asyncio/locks.py; Semaphore.__name__=='Semaphore' (len=9: 'S'+'e'+'m'+'a'+'p'+'h'+'o'+'r'+'e'=9); a Semaphore maintains an internal counter initialized to a value (default 1); acquire() decrements the counter — if zero, it waits; release() increments the counter and wakes one waiting coroutine; Semaphore.__module__=='asyncio.locks' (len=13; NOT '_asyncio' — Semaphore is pure Python unlike asyncio.Future and asyncio.Task which are C-accelerated); Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (same base as Lock — both support 'async with'); compare: asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16; inherits from Semaphore, 7 chars longer); NEW in extra161: first standalone asyncio.Semaphore.__name__ identity invariant in asynciosema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra161.asyncio_Semaphore_module_eq:
  description: "asyncio.Semaphore.__module__.__eq__('asyncio.locks') returns True — asyncio.Semaphore is defined in Lib/asyncio/locks.py; its __module__ is 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); this is the same module as asyncio.Lock (established in prior specs) and asyncio.Condition — all asyncio synchronization primitives are in the locks submodule; 'asyncio.locks' (len=13) is shorter than 'asyncio.queues' (len=14) by 1 char because 'locks'=5 < 'queues'=6; Semaphore.__module__ is NOT '_asyncio' (the C extension) — Semaphore is a pure Python class, unlike asyncio.Future and asyncio.Task which are C-accelerated with __module__=='_asyncio' (len=8); NEW in extra161: first standalone asyncio.Semaphore.__module__ identity invariant in asynciosema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra161.asyncio_Semaphore_base_is_ContextManagerMixin:
  description: "asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Semaphore inherits from _ContextManagerMixin (a private mixin defined in Lib/asyncio/locks.py); __bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20); _ContextManagerMixin provides __aenter__ and __aexit__ so that asyncio synchronization primitives can be used with 'async with'; asyncio.Lock also inherits from _ContextManagerMixin (established in extra158); asyncio.Queue inherits from '_LoopBoundMixin' (established in extra160 — different mixin because queues use put/get not async with); compare: asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore is one level deeper — its immediate base is Semaphore, not _ContextManagerMixin directly); NEW in extra161: first standalone asyncio.Semaphore.__bases__[0].__name__ identity invariant in asynciosema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra161.asyncio_BoundedSemaphore_name_eq:
  description: "asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') returns True — asyncio.BoundedSemaphore is a Semaphore subclass that enforces an upper bound; BoundedSemaphore.__name__=='BoundedSemaphore' (len=16: 'Bounded'=7+'Semaphore'=9=16); BoundedSemaphore raises ValueError when release() is called more times than acquire() — specifically when the internal counter would exceed the initial value; 'BoundedSemaphore' (len=16) is the longest class name among asyncio synchronization primitives: Lock(4) < Event(5) < Condition(9) == Semaphore(9) < BoundedSemaphore(16); BoundedSemaphore.__module__=='asyncio.locks' (same pure Python module as Semaphore); BoundedSemaphore.__bases__[0].__name__=='Semaphore' (inherits from Semaphore — IS-A Semaphore with extra validation); NEW in extra161: first standalone asyncio.BoundedSemaphore.__name__ identity invariant in asynciobsema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra161.asyncio_BoundedSemaphore_base_is_Semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — asyncio.BoundedSemaphore inherits from asyncio.Semaphore; __bases__[0].__name__=='Semaphore' (len=9); this means BoundedSemaphore IS-A Semaphore: every BoundedSemaphore is also a Semaphore with the additional constraint that release() cannot increase the count beyond the initial value; compare: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (Semaphore's base is the mixin — Semaphore is the root asyncio semaphore class) vs asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore is one level deeper); inheritance chain: _ContextManagerMixin -> Semaphore -> BoundedSemaphore (similar to _LoopBoundMixin -> Queue -> PriorityQueue/LifoQueue established in extra160); NEW in extra161: first standalone asyncio.BoundedSemaphore.__bases__[0].__name__ identity invariant in asynciobsema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra161.asyncio_Condition_base_is_ContextManagerMixin:
  description: "asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Condition inherits from _ContextManagerMixin (len=20); Condition shares the same base as Lock and Semaphore — all three asyncio lock-like primitives that support 'async with' inherit from _ContextManagerMixin; Condition is used when one coroutine must wait for another to signal that a condition is met; Condition.__module__=='asyncio.locks' (same submodule as Lock and Semaphore); compare: asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore has Semaphore as its base, one level deeper than _ContextManagerMixin); the pattern: Lock, Semaphore, Condition all share _ContextManagerMixin as their direct base; BoundedSemaphore uniquely has Semaphore as its base; NEW in extra161: first standalone asyncio.Condition.__bases__[0].__name__ identity invariant in asynciocond161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true
