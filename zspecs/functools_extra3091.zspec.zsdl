spec: ft3091
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (ft3091): __hash__, __eq__, __bool__ dict-presence checks for functools types."
    - "None of the four functools types define __hash__, __eq__, or __bool__ in their own __dict__."
    - "functools.partial, functools.partialmethod, functools.cached_property, and functools._lru_cache_wrapper all inherit identity-based hash and equality from object."
    - "None define __bool__; truthiness falls back to the default (always True)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3091.hash:
  description: "functools types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3091
  columns: [id, function, args, expected]
  rows:
    - ["ft3091001", operator.contains, [functools.partial.__dict__,            "__hash__"], false]
    - ["ft3091002", operator.contains, [functools.partialmethod.__dict__,      "__hash__"], false]
    - ["ft3091003", operator.contains, [functools.cached_property.__dict__,    "__hash__"], false]
    - ["ft3091004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__hash__"], false]

