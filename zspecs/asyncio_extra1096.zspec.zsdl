spec: asyncio_extra1096
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio.run, asyncio.sleep, asyncio.gather, asyncio.wait_for, and asyncio.create_task function documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.run qualname/module/class, asyncio.sleep qualname/module/class, asyncio.gather qualname/module/class, asyncio.wait_for qualname/module/class, asyncio.create_task qualname/module — behaviors not covered by extra1066 or extra1081"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1096.run_sleep_identity:
  description: "asyncio.run and asyncio.sleep module, qualname, and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: as1096rs
  columns: [id, function, args, expected]
  rows:
    - [as1096rs001, asyncio.run.__module__.__eq__,             ["asyncio.runners"], true]
    - [as1096rs002, asyncio.run.__qualname__.__eq__,           ["run"],              true]
    - [as1096rs003, asyncio.run.__name__.__eq__,               ["run"],              true]
    - [as1096rs004, asyncio.run.__class__.__name__.__eq__,     ["function"],         true]
    - [as1096rs005, asyncio.sleep.__module__.__eq__,           ["asyncio.tasks"],    true]
    - [as1096rs006, asyncio.sleep.__qualname__.__eq__,         ["sleep"],            true]
    - [as1096rs007, asyncio.sleep.__name__.__eq__,             ["sleep"],            true]
    - [as1096rs008, asyncio.sleep.__class__.__name__.__eq__,   ["function"],         true]

table asyncio_extra1096.gather_wait_for_identity:
  description: "asyncio.gather and asyncio.wait_for module, qualname, and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: as1096gw
  columns: [id, function, args, expected]
  rows:
    - [as1096gw001, asyncio.gather.__module__.__eq__,           ["asyncio.tasks"], true]
    - [as1096gw002, asyncio.gather.__qualname__.__eq__,         ["gather"],         true]
    - [as1096gw003, asyncio.gather.__name__.__eq__,             ["gather"],         true]
    - [as1096gw004, asyncio.gather.__class__.__name__.__eq__,   ["function"],       true]
    - [as1096gw005, asyncio.wait_for.__module__.__eq__,         ["asyncio.tasks"], true]
    - [as1096gw006, asyncio.wait_for.__qualname__.__eq__,       ["wait_for"],       true]
    - [as1096gw007, asyncio.wait_for.__name__.__eq__,           ["wait_for"],       true]
    - [as1096gw008, asyncio.wait_for.__class__.__name__.__eq__, ["function"],       true]

table asyncio_extra1096.create_task_identity:
  description: "asyncio.create_task module, qualname, and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: as1096ct
  columns: [id, function, args, expected]
  rows:
    - [as1096ct001, asyncio.create_task.__module__.__eq__,           ["asyncio.tasks"], true]
    - [as1096ct002, asyncio.create_task.__qualname__.__eq__,         ["create_task"],    true]
    - [as1096ct003, asyncio.create_task.__name__.__eq__,             ["create_task"],    true]
    - [as1096ct004, asyncio.create_task.__class__.__name__.__eq__,   ["function"],       true]
    - [as1096ct005, asyncio.sleep.__doc__.__class__.__name__.__eq__, ["str"],            true]
    - [as1096ct006, asyncio.gather.__doc__.__class__.__name__.__eq__, ["str"],           true]
    - [as1096ct007, asyncio.run.__doc__.__class__.__name__.__eq__,   ["str"],            true]
