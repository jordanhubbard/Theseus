spec: io_extra1336
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BytesIO, StringIO, FileIO, UnsupportedOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 536 theme: __hash__ and __eq__ method descriptor checks for io module classes."
    - "All io classes (IOBase, RawIOBase, BytesIO, StringIO, FileIO, UnsupportedOperation) are hashable by identity; their __hash__ is inherited from object and is a wrapper_descriptor with qualname object.__hash__."
    - "All io classes inherit __eq__ from object; __eq__ is a wrapper_descriptor with qualname object.__eq__ — none of the io classes define a custom __eq__."
    - "io.IOBase.__hash__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__hash__); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.BytesIO.__hash__.__qualname__ == 'object.__hash__' (inherited, not overridden); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.UnsupportedOperation.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# io IOBase and RawIOBase __hash__ and __eq__ descriptor checks
#
# io.IOBase.__hash__.__class__.__name__  == 'wrapper_descriptor'
# io.IOBase.__hash__.__qualname__        == 'object.__hash__'
# io.RawIOBase.__hash__.__class__.__name__ == 'wrapper_descriptor'
# io.RawIOBase.__hash__.__qualname__     == 'object.__hash__'
# io.IOBase.__eq__.__class__.__name__    == 'wrapper_descriptor'
# io.IOBase.__eq__.__qualname__          == 'object.__eq__'
# io.RawIOBase.__eq__.__class__.__name__ == 'wrapper_descriptor'
# ---------------------------------------------------------------------------

table io_extra1336.iobase_hash_eq:
  description: "io.IOBase and io.RawIOBase __hash__ and __eq__ descriptor checks — wave 536 theme: all io base classes inherit __hash__ and __eq__ from object; __hash__.__class__.__name__=='wrapper_descriptor'; __hash__.__qualname__=='object.__hash__'; __eq__.__class__.__name__=='wrapper_descriptor'; __eq__.__qualname__=='object.__eq__'; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: io1336he

  columns: [id, function, args, expected, description]
  rows:
    - [io1336he001, io.IOBase.__hash__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "io.IOBase.__hash__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__hash__); verified with Python 3.12"]
    - [io1336he002, io.IOBase.__hash__.__qualname__.__eq__,            ["object.__hash__"],    true, "io.IOBase.__hash__.__qualname__ == 'object.__hash__' (not overridden); verified with Python 3.12"]
    - [io1336he003, io.IOBase.__eq__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true, "io.IOBase.__eq__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__eq__); verified with Python 3.12"]
    - [io1336he004, io.IOBase.__eq__.__qualname__.__eq__,              ["object.__eq__"],      true, "io.IOBase.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__ defined); verified with Python 3.12"]
    - [io1336he005, io.RawIOBase.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "io.RawIOBase.__hash__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__hash__); verified with Python 3.12"]
    - [io1336he006, io.RawIOBase.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "io.RawIOBase.__hash__.__qualname__ == 'object.__hash__' (not overridden); verified with Python 3.12"]
    - [io1336he007, io.RawIOBase.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "io.RawIOBase.__eq__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__eq__); verified with Python 3.12"]
    - [io1336he008, io.RawIOBase.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "io.RawIOBase.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__ defined); verified with Python 3.12"]

