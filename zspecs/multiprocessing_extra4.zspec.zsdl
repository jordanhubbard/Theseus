spec: multiprocessing_extra4
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends prior multiprocessing specs."
    - "Focus: class names and function names not yet covered."
    - "multiprocessing.Process.__name__ == 'Process'."
    - "multiprocessing.Pool.__name__ == 'Pool'."
    - "multiprocessing.Queue.__name__ == 'Queue'."
    - "multiprocessing.Pipe.__name__ == 'Pipe'."
    - "multiprocessing.Manager.__name__ == 'Manager'."
    - "multiprocessing.Lock.__name__ == 'Lock' (or 'SemLock' internally)."
    - "multiprocessing.Event.__name__ == 'Event'."
    - "multiprocessing.Value.__name__ == 'Value'."
    - "multiprocessing.Array.__name__ == 'Array'."
    - "multiprocessing.cpu_count.__name__ == 'cpu_count'."
    - "multiprocessing.current_process.__name__ == 'current_process'."
    - "multiprocessing.active_children.__name__ == 'active_children'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Process, Process.__name__.__eq__, ["Process"], true]
    - [Pool,    Pool.__name__.__eq__,    ["Pool"],    true]
    - [Value,   Value.__name__.__eq__,   ["Value"],   true]
    - [Array,   Array.__name__.__eq__,   ["Array"],   true]

table multiprocessing_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [cpu_count,       cpu_count.__name__.__eq__,       ["cpu_count"],       true]
    - [current_process, current_process.__name__.__eq__, ["current_process"], true]
    - [active_children, active_children.__name__.__eq__, ["active_children"], true]

invariant multiprocessing_extra4.Process.module:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.process'"
  category: module
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra4.cpu_count.returns_int:
  description: "multiprocessing.cpu_count().__class__.__name__ == 'int'"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant multiprocessing_extra4.cpu_count.ge_one:
  description: "multiprocessing.cpu_count() >= 1"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count
  args: []
  method: __ge__
  method_args: [1]
  expected: true

invariant multiprocessing_extra4.current_process.class_name:
  description: "multiprocessing.current_process().__class__.__name__ == 'MainProcess'"
  category: current_process
  kind: python_call_eq
  function: current_process
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["MainProcess"]
  expected: true

invariant multiprocessing_extra4.active_children.returns_list:
  description: "multiprocessing.active_children().__class__.__name__ == 'list'"
  category: active_children
  kind: python_call_eq
  function: active_children
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant multiprocessing_extra4.Process.bases:
  description: "multiprocessing.Process.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Process.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
