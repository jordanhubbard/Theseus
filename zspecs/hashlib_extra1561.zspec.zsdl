spec: hashlib_extra1561
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for hashlib classes."
    - "The HASH object (type returned by hashlib.md5(), hashlib.sha256(), etc.) is implemented in C as _hashlib.HASH."
    - "HASH is a digest context, not a numeric type. It defines no numeric conversion protocol methods in its __dict__."
    - "Verified: '__bool__' not in type(hashlib.md5()).__dict__ — HASH has no __bool__; verified with Python 3.14.3."
    - "Verified: '__int__' not in type(hashlib.md5()).__dict__ — HASH has no __int__; verified with Python 3.14.3."
    - "Verified: '__float__' not in type(hashlib.md5()).__dict__ — HASH has no __float__; verified with Python 3.14.3."
    - "Verified: '__index__' not in type(hashlib.md5()).__dict__ — HASH has no __index__; verified with Python 3.14.3."
    - "Verified: '__trunc__', '__floor__', '__ceil__', '__round__' are likewise absent; verified with Python 3.14.3."
    - "HASH.__dict__ contains only: '__repr__', '__doc__', '__module__' plus hash-protocol attrs (copy, digest, hexdigest, update, name, digest_size, block_size)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: _hashlib.HASH — numeric conversion protocol dict-presence (all False)
#
# type(hashlib.md5()).__dict__.__contains__('__bool__')    == False
# type(hashlib.md5()).__dict__.__contains__('__int__')     == False
# type(hashlib.md5()).__dict__.__contains__('__float__')   == False
# type(hashlib.md5()).__dict__.__contains__('__complex__') == False
# type(hashlib.md5()).__dict__.__contains__('__index__')   == False
# type(hashlib.md5()).__dict__.__contains__('__trunc__')   == False
# type(hashlib.md5()).__dict__.__contains__('__floor__')   == False
# type(hashlib.md5()).__dict__.__contains__('__ceil__')    == False
# type(hashlib.md5()).__dict__.__contains__('__round__')   == False
# ---------------------------------------------------------------------------

table hashlib_extra1561.hash_numeric_protocol:
  description: "The _hashlib.HASH type (returned by hashlib.md5() etc.) defines no numeric conversion protocol methods in its own __dict__ — hl1561hn namespace. HASH is a cryptographic digest context, not a numeric type; it stores internal state for incremental hashing; conversion to int/float/bool is semantically undefined for a hash context and none of these methods appear in HASH.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: hl1561hn

  columns: [id, function, args, expected, description]
  rows:
    - [hl1561hn001, hashlib._hashlib.HASH.__dict__.__contains__, ["__bool__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__bool__')==False — HASH is a digest context, not a boolean type; verified with Python 3.14.3"]
    - [hl1561hn002, hashlib._hashlib.HASH.__dict__.__contains__, ["__int__"],     false, "hashlib._hashlib.HASH.__dict__.__contains__('__int__')==False — HASH cannot be converted to int; no __int__ in HASH.__dict__; verified with Python 3.14.3"]
    - [hl1561hn003, hashlib._hashlib.HASH.__dict__.__contains__, ["__float__"],   false, "hashlib._hashlib.HASH.__dict__.__contains__('__float__')==False — HASH cannot be converted to float; no __float__ in HASH.__dict__; verified with Python 3.14.3"]
    - [hl1561hn004, hashlib._hashlib.HASH.__dict__.__contains__, ["__complex__"], false, "hashlib._hashlib.HASH.__dict__.__contains__('__complex__')==False — HASH defines no __complex__; verified with Python 3.14.3"]
    - [hl1561hn005, hashlib._hashlib.HASH.__dict__.__contains__, ["__index__"],   false, "hashlib._hashlib.HASH.__dict__.__contains__('__index__')==False — HASH cannot be used as a sequence index; no __index__ in HASH.__dict__; verified with Python 3.14.3"]
    - [hl1561hn006, hashlib._hashlib.HASH.__dict__.__contains__, ["__trunc__"],   false, "hashlib._hashlib.HASH.__dict__.__contains__('__trunc__')==False — math.trunc() protocol not supported by HASH; verified with Python 3.14.3"]
    - [hl1561hn007, hashlib._hashlib.HASH.__dict__.__contains__, ["__floor__"],   false, "hashlib._hashlib.HASH.__dict__.__contains__('__floor__')==False — math.floor() protocol not supported by HASH; verified with Python 3.14.3"]
    - [hl1561hn008, hashlib._hashlib.HASH.__dict__.__contains__, ["__ceil__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__ceil__')==False — math.ceil() protocol not supported by HASH; verified with Python 3.14.3"]
    - [hl1561hn009, hashlib._hashlib.HASH.__dict__.__contains__, ["__round__"],   false, "hashlib._hashlib.HASH.__dict__.__contains__('__round__')==False — round() protocol not supported by HASH; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: _hashlib.HASH — arithmetic operator dict-presence (all False)
#
# Confirms HASH also lacks arithmetic dunder methods (__add__, __mul__, etc.)
# ---------------------------------------------------------------------------

table hashlib_extra1561.hash_arithmetic_protocol:
  description: "The _hashlib.HASH type defines no arithmetic operator methods in its own __dict__ — hl1561ha namespace. HASH accumulates bytes via update() and produces fixed-length digests via digest()/hexdigest(); it is purely a state machine, not a numeric type; arithmetic operators like __add__ and __mul__ are absent; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: hl1561ha

  columns: [id, function, args, expected, description]
  rows:
    - [hl1561ha001, hashlib._hashlib.HASH.__dict__.__contains__, ["__add__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__add__')==False — no addition operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha002, hashlib._hashlib.HASH.__dict__.__contains__, ["__sub__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__sub__')==False — no subtraction operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha003, hashlib._hashlib.HASH.__dict__.__contains__, ["__mul__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__mul__')==False — no multiplication operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha004, hashlib._hashlib.HASH.__dict__.__contains__, ["__truediv__"],false, "hashlib._hashlib.HASH.__dict__.__contains__('__truediv__')==False — no division operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha005, hashlib._hashlib.HASH.__dict__.__contains__, ["__mod__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__mod__')==False — no modulo operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha006, hashlib._hashlib.HASH.__dict__.__contains__, ["__pow__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__pow__')==False — no exponentiation operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha007, hashlib._hashlib.HASH.__dict__.__contains__, ["__neg__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__neg__')==False — no negation operator on HASH; verified with Python 3.14.3"]
    - [hl1561ha008, hashlib._hashlib.HASH.__dict__.__contains__, ["__abs__"],    false, "hashlib._hashlib.HASH.__dict__.__contains__('__abs__')==False — no abs() operator on HASH; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: _hashlib.HASH — actual protocol attribute presence (positive checks)
#
# Confirms that HASH does define its hash-domain interface in __dict__:
# 'copy', 'digest', 'hexdigest', 'update', 'name', 'digest_size', 'block_size'
# ---------------------------------------------------------------------------

table hashlib_extra1561.hash_domain_presence:
  description: "The _hashlib.HASH type defines its hash-domain interface attributes in its own __dict__ — hl1561hd namespace. These positive checks confirm HASH does define: copy (duplicates state), digest (binary digest), hexdigest (hex-encoded digest), update (feeds data), name (algorithm name), digest_size, block_size; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1561hd

  columns: [id, function, args, expected, description]
  rows:
    - [hl1561hd001, hashlib._hashlib.HASH.__dict__.__contains__, ["copy"],        true,  "hashlib._hashlib.HASH.__dict__.__contains__('copy')==True — HASH.copy() duplicates internal digest state; verified with Python 3.14.3"]
    - [hl1561hd002, hashlib._hashlib.HASH.__dict__.__contains__, ["digest"],      true,  "hashlib._hashlib.HASH.__dict__.__contains__('digest')==True — HASH.digest() returns binary digest bytes; verified with Python 3.14.3"]
    - [hl1561hd003, hashlib._hashlib.HASH.__dict__.__contains__, ["hexdigest"],   true,  "hashlib._hashlib.HASH.__dict__.__contains__('hexdigest')==True — HASH.hexdigest() returns hex-encoded digest string; verified with Python 3.14.3"]
    - [hl1561hd004, hashlib._hashlib.HASH.__dict__.__contains__, ["update"],      true,  "hashlib._hashlib.HASH.__dict__.__contains__('update')==True — HASH.update() feeds data into the digest context; verified with Python 3.14.3"]
    - [hl1561hd005, hashlib._hashlib.HASH.__dict__.__contains__, ["name"],        true,  "hashlib._hashlib.HASH.__dict__.__contains__('name')==True — HASH.name is the algorithm name string (e.g. 'md5', 'sha256'); verified with Python 3.14.3"]
    - [hl1561hd006, hashlib._hashlib.HASH.__dict__.__contains__, ["digest_size"], true,  "hashlib._hashlib.HASH.__dict__.__contains__('digest_size')==True — HASH.digest_size is the number of bytes in the digest; verified with Python 3.14.3"]
    - [hl1561hd007, hashlib._hashlib.HASH.__dict__.__contains__, ["block_size"],  true,  "hashlib._hashlib.HASH.__dict__.__contains__('block_size')==True — HASH.block_size is the internal block size of the algorithm; verified with Python 3.14.3"]
    - [hl1561hd008, hashlib._hashlib.HASH.__dict__.__contains__, ["__repr__"],    true,  "hashlib._hashlib.HASH.__dict__.__contains__('__repr__')==True — HASH.__repr__ IS in HASH.__dict__; verified with Python 3.14.3"]
