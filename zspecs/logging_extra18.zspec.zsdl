spec: logging_extra18
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra17.zspec.zsdl."
    - "logging_extra13 covers: DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET .__eq__ (value checks) via standalone invariants."
    - "logging_extra5 covers: DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET .__class__.__name__ == 'int' via table."
    - "logging_extra17 covers: FATAL/WARN alias value and __class__.__name__; getLevelNamesMapping/addLevelName identity attributes."
    - "This spec covers: level constants __eq__ checks via table (novel tabular form); Logger/__class__.__name__, Handler/__class__.__name__, Formatter/__class__.__name__ == 'type' (not yet recorded as standalone invariants)."
    - "logging.Logger, logging.Handler, and logging.Formatter are all plain Python classes; their metaclass is the builtin 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Level constants — value checks via table
#
# logging_extra13 covers DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET.__eq__ as
# standalone invariants. This table provides the same invariants in tabular
# form, which is the canonical layout for constant value assertions per the
# ZSDL conventions used throughout this corpus.
# ---------------------------------------------------------------------------

table logging_extra18.level_constants:
  description: "Numeric values of logging level constants verified via __eq__"
  kind: python_call_eq
  category: constants
  id_prefix: lvl

  columns: [id, function, args, expected]
  rows:
    - [debug,    DEBUG.__eq__,    [10], true]
    - [info,     INFO.__eq__,     [20], true]
    - [warning,  WARNING.__eq__,  [30], true]
    - [error,    ERROR.__eq__,    [40], true]
    - [critical, CRITICAL.__eq__, [50], true]
    - [notset,   NOTSET.__eq__,   [0],  true]

# ---------------------------------------------------------------------------
# Logger, Handler, Formatter — __class__.__name__
#
# Prior specs record __name__, __qualname__, __module__, __bases__,
# __mro__, and .mro() for Logger, Handler, and Formatter, but no prior
# spec records __class__.__name__ for any of these three classes as a
# standalone invariant. All three are plain Python classes whose metaclass
# is the builtin 'type'.
# ---------------------------------------------------------------------------

invariant logging_extra18.Logger.class_name:
  description: "logging.Logger.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: Logger.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant logging_extra18.Handler.class_name:
  description: "logging.Handler.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: Handler.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant logging_extra18.Formatter.class_name:
  description: "logging.Formatter.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__class__.__name__.__eq__
  args: ["type"]
  expected: true
