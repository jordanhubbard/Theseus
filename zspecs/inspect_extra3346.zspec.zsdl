spec: in3346
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (in3346): __neg__, __pos__, __abs__ dict-presence checks for inspect types."
    - "Theme: __neg__/__pos__/__abs__ unary arithmetic dict-presence."
    - "Unary arithmetic operators (-x, +x, abs(x)) are defined by __neg__, __pos__, __abs__ respectively."
    - "All values False — callable/iterator/inspection/synchronization types have no unary arithmetic operators."
    - "No inspect type defines __neg__, __pos__, or __abs__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement unary arithmetic protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3346.neg:
  description: "inspect types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3346
  columns: [id, function, args, expected]
  rows:
    - ["in3346001", operator.contains, [inspect.Parameter.__dict__,           "__neg__"], false]
    - ["in3346002", operator.contains, [inspect.Signature.__dict__,           "__neg__"], false]
    - ["in3346003", operator.contains, [inspect.BoundArguments.__dict__,      "__neg__"], false]
    - ["in3346004", operator.contains, [inspect.FrameInfo.__dict__,           "__neg__"], false]
    - ["in3346005", operator.contains, [inspect.ArgInfo.__dict__,             "__neg__"], false]
    - ["in3346006", operator.contains, [inspect.FullArgSpec.__dict__,         "__neg__"], false]
    - ["in3346007", operator.contains, [inspect.Attribute.__dict__,           "__neg__"], false]
    - ["in3346008", operator.contains, [inspect.ClassFoundException.__dict__, "__neg__"], false]
    - ["in3346009", operator.contains, [inspect.EndOfBlock.__dict__,          "__neg__"], false]

