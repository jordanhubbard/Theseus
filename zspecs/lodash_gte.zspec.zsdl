spec: lodash_gte
version: ">=3.9.2"
backend: node(lodash.gte)

docs: https://lodash.com/docs/#gte

provenance:
  derived_from:
    - "lodash.gte README — https://www.npmjs.com/package/lodash.gte"
    - "Test vectors verified with lodash.gte@3.9.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.gte exports the _.gte function directly as module.exports."
    - "gte(value, other) checks if value is greater than or equal to other."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_gte.gte:
  kind: node_module_call_eq
  function: ~
  category: gte
  id_prefix: lgte

  columns: [id, args, expected]
  rows:
    - [greater,  [3, 1],    true]
    - [equal,    [3, 3],    true]
    - [less,     [1, 3],    false]

