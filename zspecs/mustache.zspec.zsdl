spec: mustache
version: ">=4.0.0"
backend: node(mustache)

docs: https://github.com/janl/mustache.js

provenance:
  derived_from:
    - "Mustache.js README — https://github.com/janl/mustache.js"
    - "Test vectors verified with mustache via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mustache source"
  notes:
    - "mustache is an npm package. Install: npm install mustache"
    - "Mustache.render(template, view) renders a Mustache template with the given view."
    - "{{name}} interpolates a variable; {{#items}}...{{/items}} iterates a list; {{.}} is the current item."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns rendered string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mustache.render:
  kind: node_module_call_eq
  function: render
  category: render
  id_prefix: mtr

  columns: [id, args, expected]
  rows:
    - [basic,  ["Hello {{name}}!", {"name": "World"}],                   "Hello World!"]
    - [list,   ["{{#items}}{{.}} {{/items}}", {"items": ["a","b","c"]}], "a b c "]
    - [cond,   ["{{#show}}yes{{/show}}", {"show": true}],                "yes"]
    - [empty,  ["{{#show}}yes{{/show}}", {"show": false}],               ""]
    - [nested, ["{{person.name}}", {"person": {"name": "Alice"}}],       "Alice"]
