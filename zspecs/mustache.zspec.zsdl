spec: mustache
version: ">=4.0.0"
backend: node(mustache)

docs: https://www.npmjs.com/package/mustache

provenance:
  derived_from:
    - "mustache README — https://www.npmjs.com/package/mustache"
    - "Test vectors verified with mustache via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mustache source"
  notes:
    - "mustache is an npm package. Install: npm install mustache"
    - "Mustache.render(template, view) renders a Mustache template with the given view data."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns rendered string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mustache.render:
  kind: node_module_call_eq
  function: render
  category: render
  id_prefix: mstch

  columns: [id, args, expected]
  rows:
    - [simple,   ["Hello, {{name}}!", {"name": "World"}],       "Hello, World!"]
    - [section,  ["{{#items}}{{.}} {{/items}}", {"items": ["a","b","c"]}], "a b c "]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:38:46Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
