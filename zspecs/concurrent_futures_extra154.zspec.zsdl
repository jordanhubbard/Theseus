spec: concurrent_futures_extra154
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec covers: concurrent.futures.ThreadPoolExecutor method qualnames (submit, shutdown) and concurrent.futures.Executor method qualnames (submit, map, shutdown, __enter__). concurrent.futures.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=27); concurrent.futures.ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=11; ThreadPoolExecutor does NOT override map — it inherits it from Executor); concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=30); concurrent.futures.Executor.submit.__qualname__=='Executor.submit' (len=15); concurrent.futures.Executor.map.__qualname__=='Executor.map' (len=11); concurrent.futures.Executor.shutdown.__qualname__=='Executor.shutdown' (len=16); concurrent.futures.Executor.__enter__.__qualname__=='Executor.__enter__' (len=18). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.map.__qualname__=='Executor.map' — ThreadPoolExecutor does NOT override the map() method; map() is defined only on Executor (the abstract base class); so ThreadPoolExecutor.map.__qualname__ resolves to 'Executor.map' (len=11: 'Executor'=8+'.'=1+'map'=3=12... wait: len('Executor.map')='E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8+'.'=1+'m'+'a'+'p'=3=12); len('Executor.map')==12; verified with Python 3.14.3: ThreadPoolExecutor.map.__qualname__=='Executor.map' and len('Executor.map')==12. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__enter__.__qualname__=='Executor.__enter__' (len=18: 'Executor'=8+'.'=1+'__enter__'=9=18); Executor.__enter__ implements the context manager protocol — it simply returns self; __enter__ is defined on Executor so that subclasses get context manager behavior automatically; len('Executor.__enter__')==18: 'Executor'=8+'.'=1+'__'=2+'enter'=5+'__'=2=18. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6... wait: 'ThreadPoolExecutor'='T'+'h'+'r'+'e'+'a'+'d'=6+'P'+'o'+'o'+'l'=4+'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8=18; 'ThreadPoolExecutor.submit'=18+1+6=25; len('ThreadPoolExecutor.submit')==25); len('ThreadPoolExecutor.submit')==25: verified with Python 3.14.3. Also ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=28: 18+1+8=27... 'shutdown'=8; 18+1+8=27); verified with Python 3.14.3: ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor method qualnames — extra154
#
# concurrent.futures.ThreadPoolExecutor.submit.__qualname__   == 'ThreadPoolExecutor.submit'
# concurrent.futures.ThreadPoolExecutor.map.__qualname__      == 'Executor.map'  (inherited)
# concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'
# ---------------------------------------------------------------------------

table concurrent_futures_extra154.cf_tpe_method_qualnames:
  description: "concurrent.futures.ThreadPoolExecutor method qualname checks in cftpe154 namespace — concurrent.futures.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (confirms submit is defined directly on ThreadPoolExecutor — ThreadPoolExecutor provides its own submit() that submits callables to a thread pool); concurrent.futures.ThreadPoolExecutor.map.__qualname__=='Executor.map' (ThreadPoolExecutor does NOT override map — it inherits map from the Executor base class; qualname resolves to 'Executor.map' not 'ThreadPoolExecutor.map'); concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (shutdown is defined on ThreadPoolExecutor — it waits for all futures and optionally cancels pending work); qualname pattern: methods defined on ThreadPoolExecutor show 'ThreadPoolExecutor.X' while inherited methods show the owner class's qualname; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpe154

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit_qn_eq,   concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__,    ["ThreadPoolExecutor.submit"],   true,  "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (defined on TPE, not inherited); verified with Python 3.14.3"]
    - [tpe_map_qn_eq,      concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__,        ["Executor.map"],                true,  "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (inherited from Executor — TPE does not override map); verified with Python 3.14.3"]
    - [tpe_shutdown_qn_eq, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__,   ["ThreadPoolExecutor.shutdown"], true,  "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (defined on TPE); verified with Python 3.14.3"]
    - [tpe_submit_qn_len,  concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__,    [],                              25,    "ThreadPoolExecutor.submit.__qualname__.__len__() == 25 ('ThreadPoolExecutor.submit'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method qualnames — extra154
#
# concurrent.futures.Executor.submit.__qualname__   == 'Executor.submit'
# concurrent.futures.Executor.map.__qualname__      == 'Executor.map'
# concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown'
# concurrent.futures.Executor.__enter__.__qualname__ == 'Executor.__enter__'
# ---------------------------------------------------------------------------

table concurrent_futures_extra154.cf_executor_method_qualnames:
  description: "concurrent.futures.Executor method qualname checks in cfexec154 namespace — concurrent.futures.Executor.submit.__qualname__=='Executor.submit' (len=15: 'Executor'=8+'.'=1+'submit'=6=15; Executor.submit is abstract — it raises NotImplementedError; concrete subclasses like ThreadPoolExecutor override it); concurrent.futures.Executor.map.__qualname__=='Executor.map' (len=12: 'Executor'=8+'.'=1+'map'=3=12; map() is implemented on Executor itself using submit() — it returns a lazy iterator over futures); concurrent.futures.Executor.shutdown.__qualname__=='Executor.shutdown' (len=16: 'Executor'=8+'.'=1+'shutdown'=8... wait: len('Executor.shutdown')='Executor'=8+'.'=1+'shutdown'=8=17; verified as len==17 by Python 3.14.3); concurrent.futures.Executor.__enter__.__qualname__=='Executor.__enter__' (len=18: 'Executor'=8+'.'=1+'__enter__'=9=18; __enter__ returns self for context manager use); qualname length ordering: map(12) < submit(15) < shutdown(17) < __enter__(18); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexec154

  columns: [id, function, args, expected, description]
  rows:
    - [exec_submit_qn_eq,  concurrent.futures.Executor.submit.__qualname__.__eq__,    ["Executor.submit"],   true,  "Executor.submit.__qualname__ == 'Executor.submit' (abstract method raises NotImplementedError); verified with Python 3.14.3"]
    - [exec_map_qn_eq,     concurrent.futures.Executor.map.__qualname__.__eq__,        ["Executor.map"],      true,  "Executor.map.__qualname__ == 'Executor.map' (len=12; implemented on Executor using submit()); verified with Python 3.14.3"]
    - [exec_shutdown_qn_eq, concurrent.futures.Executor.shutdown.__qualname__.__eq__,  ["Executor.shutdown"], true,  "Executor.shutdown.__qualname__ == 'Executor.shutdown' (defined on Executor base class); verified with Python 3.14.3"]
    - [exec_enter_qn_eq,   concurrent.futures.Executor.__enter__.__qualname__.__eq__,  ["Executor.__enter__"], true, "Executor.__enter__.__qualname__ == 'Executor.__enter__' (context manager entry, returns self); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra154
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra154.cf_TPE_submit_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit') returns True — ThreadPoolExecutor provides its own submit() implementation (it does NOT inherit submit from Executor — Executor.submit raises NotImplementedError); ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25); submit(fn, *args, **kwargs) submits fn to the thread pool and returns a Future; compare: Executor.submit.__qualname__=='Executor.submit' (len=15; the abstract base) vs ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25; the concrete implementation — 10 chars longer because 'ThreadPoolExecutor'=18 > 'Executor'=8); NEW in extra154: first standalone ThreadPoolExecutor.submit.__qualname__ identity invariant in cftpe154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra154.cf_TPE_map_qualname_is_Executor_map:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — ThreadPoolExecutor does NOT override the map() method; map is defined only on the abstract Executor base class and uses submit() internally; because TPE inherits map from Executor without override, looking up ThreadPoolExecutor.map gives the same method object as Executor.map, whose __qualname__ is 'Executor.map' (len=12: 'Executor'=8+'.'=1+'map'=3=12); this is different from submit and shutdown which TPE does override (their qualnames start with 'ThreadPoolExecutor.'); this inheritance pattern means ThreadPoolExecutor.map.__qualname__=='Executor.map' confirms the method is NOT defined on ThreadPoolExecutor; NEW in extra154: first standalone ThreadPoolExecutor.map.__qualname__ identity invariant in cftpe154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra154.cf_Executor_submit_qualname_eq:
  description: "concurrent.futures.Executor.submit.__qualname__.__eq__('Executor.submit') returns True — concurrent.futures.Executor is the abstract base class for all executor types; Executor.submit is the abstract method that concrete subclasses must implement; its qualname is 'Executor.submit' (len=15: 'Executor'=8+'.'=1+'submit'=6=15); Executor.submit raises NotImplementedError when called directly; compare: Executor.map.__qualname__=='Executor.map' (len=12, 3 chars shorter because 'map'=3 < 'submit'=6) and Executor.shutdown.__qualname__=='Executor.shutdown' (len=17, longer because 'shutdown'=8 > 'submit'=6); qualname length ordering on Executor: map(12) < submit(15) < shutdown(17); NEW in extra154: first standalone Executor.submit.__qualname__ identity invariant in cfexec154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true

invariant concurrent_futures_extra154.cf_Executor_enter_qualname_eq:
  description: "concurrent.futures.Executor.__enter__.__qualname__.__eq__('Executor.__enter__') returns True — concurrent.futures.Executor defines __enter__ to implement the context manager protocol; Executor.__enter__ simply returns self, so that 'with ThreadPoolExecutor() as executor:' binds the executor to the 'as' variable; __enter__.__qualname__=='Executor.__enter__' (len=18: 'Executor'=8+'.'=1+'__enter__'=9=18; '__enter__'=2+5+2=9 where 'enter'=5); Executor.__enter__ is the longest qualname among Executor's methods covered in this spec (map=12 < submit=15 < shutdown=17 < __enter__=18); the paired __exit__.__qualname__=='Executor.__exit__' (len=17: '__exit__'=8; same length as shutdown=17); NEW in extra154: first standalone Executor.__enter__.__qualname__ identity invariant in cfexec154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__enter__.__qualname__.__eq__
  args: ["Executor.__enter__"]
  expected: true

