spec: socket_extra1351
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "socket.socket defines __slots__ = ['__weakref__', '_io_refs', '_closed'] — so both '__slots__' and '__weakref__' appear in socket.socket.__dict__."
    - "socket.socket.__dict__.__contains__('__slots__') == True — socket.socket explicitly declares __slots__."
    - "socket.socket.__dict__.__contains__('__weakref__') == True — __weakref__ is listed in socket.socket.__slots__, making it a descriptor in socket.socket.__dict__."
    - "socket.socket.__dict__.__contains__('__dict__') == False — because socket.socket uses __slots__, instances have no instance __dict__."
    - "socket.error is an alias for OSError — a C builtin exception type; its __dict__ has no __slots__, __weakref__, or __dict__ descriptors."
    - "socket.error.__dict__.__contains__('__slots__') == False — OSError is a C type and does not use Python __slots__."
    - "socket.error.__dict__.__contains__('__weakref__') == False — OSError is a C type; no __weakref__ descriptor in its __dict__."
    - "socket.AddressFamily is an IntEnum subclass; its __dict__ has no __slots__, __weakref__, or __dict__ descriptors."
    - "socket.SocketKind is an IntEnum subclass; its __dict__ has no __slots__, __weakref__, or __dict__ descriptors."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra1351.socket_class_slot_weakref_dict_checks:
  description: "socket.socket class __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; socket.socket uses __slots__ so __slots__ and __weakref__ appear in its __dict__ but __dict__ does not"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: sk1351sc
  columns: [id, function, args, expected]
  rows:
    - [sk1351sc001, socket.socket.__dict__.__contains__, ["__slots__"],    true]
    - [sk1351sc002, socket.socket.__dict__.__contains__, ["__weakref__"],  true]
    - [sk1351sc003, socket.socket.__dict__.__contains__, ["__dict__"],     false]
    - [sk1351sc004, socket.socket.__dict__.__contains__, ["__init__"],     true]
    - [sk1351sc005, socket.socket.__dict__.__contains__, ["__repr__"],     true]
    - [sk1351sc006, socket.socket.__dict__.__contains__, ["__enter__"],    true]

table socket_extra1351.error_class_slot_weakref_dict_checks:
  description: "socket.error (alias for OSError) class __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; OSError is a C builtin exception type with no Python-level slot machinery"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: sk1351ec
  columns: [id, function, args, expected]
  rows:
    - [sk1351ec001, socket.error.__dict__.__contains__, ["__slots__"],    false]
    - [sk1351ec002, socket.error.__dict__.__contains__, ["__weakref__"],  false]
    - [sk1351ec003, socket.error.__dict__.__contains__, ["__dict__"],     false]
    - [sk1351ec004, socket.socket.__dict__.__contains__, ["__slots__"],   true]
    - [sk1351ec005, socket.socket.__dict__.__contains__, ["__weakref__"], true]
    - [sk1351ec006, socket.socket.__dict__.__contains__, ["__dict__"],    false]

table socket_extra1351.addressfamily_socketkind_slot_weakref_dict_checks:
  description: "socket.AddressFamily and socket.SocketKind (IntEnum subclasses) __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; IntEnum subclasses add no such descriptors to their own __dict__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: sk1351ak
  columns: [id, function, args, expected]
  rows:
    - [sk1351ak001, socket.AddressFamily.__dict__.__contains__, ["__slots__"],    false]
    - [sk1351ak002, socket.AddressFamily.__dict__.__contains__, ["__weakref__"],  false]
    - [sk1351ak003, socket.AddressFamily.__dict__.__contains__, ["__dict__"],     false]
    - [sk1351ak004, socket.SocketKind.__dict__.__contains__,    ["__slots__"],    false]
    - [sk1351ak005, socket.SocketKind.__dict__.__contains__,    ["__weakref__"],  false]
    - [sk1351ak006, socket.SocketKind.__dict__.__contains__,    ["__dict__"],     false]
