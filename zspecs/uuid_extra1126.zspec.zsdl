spec: uuid_extra1126
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.uuid1/uuid3/uuid4/uuid5 __doc__.__class__.__name__, uuid.UUID.bytes/bytes_le/fields/time __class__.__name__ (property), uuid.UUID property qualname and module attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1126.generator_doc_qualname_module:
  description: "uuid.uuid1, uuid3, uuid4, uuid5 __doc__.__class__.__name__ and qualname/module identity"
  kind: python_call_eq
  category: generator_doc_qualname_module
  id_prefix: uu1126gq
  columns: [id, function, args, expected]
  rows:
    - [uu1126gq001, uuid.uuid1.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1126gq002, uuid.uuid3.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1126gq003, uuid.uuid4.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1126gq004, uuid.uuid5.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1126gq005, uuid.uuid1.__qualname__.__eq__,                            ["uuid1"],    true]
    - [uu1126gq006, uuid.uuid3.__qualname__.__eq__,                            ["uuid3"],    true]
    - [uu1126gq007, uuid.uuid4.__qualname__.__eq__,                            ["uuid4"],    true]
    - [uu1126gq008, uuid.uuid5.__qualname__.__eq__,                            ["uuid5"],    true]
    - [uu1126gq009, uuid.uuid1.__qualname__.__class__.__name__.__eq__,         ["str"],      true]
    - [uu1126gq010, uuid.uuid3.__qualname__.__class__.__name__.__eq__,         ["str"],      true]

table uuid_extra1126.uuid_property_class_names:
