    - [uu1126pr003, uuid.UUID.fields.__class__.__name__.__eq__,             ["property"], true]
    - [uu1126pr004, uuid.UUID.time.__class__.__name__.__eq__,               ["property"], true]
    - [uu1126pr005, uuid.UUID.bytes.__class__.__qualname__.__eq__,          ["property"], true]
    - [uu1126pr006, uuid.UUID.bytes_le.__class__.__qualname__.__eq__,       ["property"], true]
    - [uu1126pr007, uuid.UUID.fields.__class__.__qualname__.__eq__,         ["property"], true]
    - [uu1126pr008, uuid.UUID.time.__class__.__qualname__.__eq__,           ["property"], true]
    - [uu1126pr009, uuid.UUID.bytes.__class__.__module__.__eq__,            ["builtins"], true]
    - [uu1126pr010, uuid.UUID.bytes_le.__class__.__module__.__eq__,         ["builtins"], true]

table uuid_extra1126.uuid_property_fget_class_names:
