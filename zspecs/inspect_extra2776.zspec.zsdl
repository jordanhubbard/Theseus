spec: inspect_extra2776
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place subtraction -=, in-place multiplication *=, in-place true division /=)."
    - "inspect.Parameter, inspect.BoundArguments, inspect.Signature are pure-Python classes defined in Lib/inspect.py."
    - "inspect.FullArgSpec is a namedtuple subclass created via collections.namedtuple; its __dict__ is a mappingproxy."
    - "None of the four inspect types (Parameter, BoundArguments, Signature, FullArgSpec) define __isub__, __imul__, or __itruediv__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter and inspect.BoundArguments — __isub__/__imul__/__itruediv__
# dict-presence checks
#
# Both are pure-Python classes defined in Lib/inspect.py.
# Neither implements in-place arithmetic operator dunders.
# All six checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2776.parameter_boundarguments_operator_dict:
  description: "inspect.Parameter and BoundArguments __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2776pb

  columns: [id, function, args, expected]
  rows:
    - ["in2776pb_pa_is",  Parameter.__dict__.__contains__,      ["__isub__"],      false]
    - ["in2776pb_pa_im",  Parameter.__dict__.__contains__,      ["__imul__"],      false]
    - ["in2776pb_pa_it",  Parameter.__dict__.__contains__,      ["__itruediv__"],  false]
    - ["in2776pb_ba_is",  BoundArguments.__dict__.__contains__,  ["__isub__"],      false]
    - ["in2776pb_ba_im",  BoundArguments.__dict__.__contains__,  ["__imul__"],      false]
    - ["in2776pb_ba_it",  BoundArguments.__dict__.__contains__,  ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# inspect.Signature — __isub__/__imul__/__itruediv__ dict-presence checks
#
# Signature is a pure-Python class; its instances represent callable signatures.
# Signature does not define in-place arithmetic operator dunders.
# All three checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2776.signature_operator_dict:
  description: "inspect.Signature __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2776sg

  columns: [id, function, args, expected]
  rows:
    - ["in2776sg_is",  Signature.__dict__.__contains__, ["__isub__"],      false]
    - ["in2776sg_im",  Signature.__dict__.__contains__, ["__imul__"],      false]
    - ["in2776sg_it",  Signature.__dict__.__contains__, ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec — __isub__/__imul__/__itruediv__ dict-presence checks
#
# FullArgSpec is a namedtuple subclass (collections.namedtuple).
# Its __dict__ is a mappingproxy that does not include in-place arithmetic dunders.
# All three checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2776.fullargspec_operator_dict:
  description: "inspect.FullArgSpec (namedtuple) __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2776fa

  columns: [id, function, args, expected]
  rows:
    - ["in2776fa_is",  FullArgSpec.__dict__.__contains__, ["__isub__"],      false]
    - ["in2776fa_im",  FullArgSpec.__dict__.__contains__, ["__imul__"],      false]
    - ["in2776fa_it",  FullArgSpec.__dict__.__contains__, ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# Cross-type summary — all four inspect types, all three operator dunders
#
# Consolidates the full 4×3 matrix confirming none of the inspect types
# define __isub__, __imul__, or __itruediv__ in their __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2776.all_types_operator_dict_matrix:
  description: "Full 4×3 dict-presence matrix for inspect types vs __isub__/__imul__/__itruediv__ — all 12 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2776mx

  columns: [id, function, args, expected]
  rows:
    - ["in2776mx_pa_is",  Parameter.__dict__.__contains__,      ["__isub__"],      false]
    - ["in2776mx_pa_im",  Parameter.__dict__.__contains__,      ["__imul__"],      false]
    - ["in2776mx_pa_it",  Parameter.__dict__.__contains__,      ["__itruediv__"],  false]
    - ["in2776mx_ba_is",  BoundArguments.__dict__.__contains__,  ["__isub__"],      false]
    - ["in2776mx_ba_im",  BoundArguments.__dict__.__contains__,  ["__imul__"],      false]
    - ["in2776mx_ba_it",  BoundArguments.__dict__.__contains__,  ["__itruediv__"],  false]
    - ["in2776mx_sg_is",  Signature.__dict__.__contains__,       ["__isub__"],      false]
    - ["in2776mx_sg_im",  Signature.__dict__.__contains__,       ["__imul__"],      false]
    - ["in2776mx_sg_it",  Signature.__dict__.__contains__,       ["__itruediv__"],  false]
    - ["in2776mx_fa_is",  FullArgSpec.__dict__.__contains__,     ["__isub__"],      false]
    - ["in2776mx_fa_im",  FullArgSpec.__dict__.__contains__,     ["__imul__"],      false]
    - ["in2776mx_fa_it",  FullArgSpec.__dict__.__contains__,     ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra2776
# ---------------------------------------------------------------------------

invariant inspect_extra2776.parameter_no_isub:
  description: "'__isub__' not in inspect.Parameter.__dict__ — Parameter is a descriptor class for callable parameters and does not implement -="
  category: behavior
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant inspect_extra2776.parameter_no_imul:
  description: "'__imul__' not in inspect.Parameter.__dict__ — Parameter does not implement the *= operator"
  category: behavior
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant inspect_extra2776.parameter_no_itruediv:
  description: "'__itruediv__' not in inspect.Parameter.__dict__ — Parameter does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

invariant inspect_extra2776.signature_no_isub:
  description: "'__isub__' not in inspect.Signature.__dict__ — Signature does not implement the -= operator"
  category: behavior
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant inspect_extra2776.fullargspec_no_imul:
  description: "'__imul__' not in inspect.FullArgSpec.__dict__ — FullArgSpec is a namedtuple and does not implement the *= operator"
  category: behavior
  kind: python_call_eq
  function: FullArgSpec.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant inspect_extra2776.boundarguments_no_itruediv:
  description: "'__itruediv__' not in inspect.BoundArguments.__dict__ — BoundArguments does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false
