spec: theseus_grp_cr
version: ">=3.8"
backend: python_cleanroom(theseus_grp_cr)
blocks: grp

docs: https://docs.python.org/3/library/grp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/grp.html"
  not_derived_from:
    - "CPython source: Modules/grpmodule.c"
  notes:
    - "Clean-room grp module. Do NOT import grp."

error_model: python_exceptions

invariant theseus_grp_cr.grp2_getgrall:
  description: "getgrall() returns a non-empty list of group entries"
  category: behavior
  kind: python_call_eq
  function: grp2_getgrall
  args: []
  expected: true

invariant theseus_grp_cr.grp2_struct_group:
  description: "struct_group has gr_name and gr_gid fields"
  category: behavior
  kind: python_call_eq
  function: grp2_struct_group
  args: []
  expected: true

invariant theseus_grp_cr.grp2_getgrgid:
  description: "getgrgid returns group by numeric ID"
  category: behavior
  kind: python_call_eq
  function: grp2_getgrgid
  args: []
  expected: true
