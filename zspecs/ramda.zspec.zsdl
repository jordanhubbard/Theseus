spec: ramda
version: ">=0.29.0"
backend: node(ramda)

docs: https://www.npmjs.com/package/ramda

provenance:
  derived_from:
    - "ramda README — https://www.npmjs.com/package/ramda"
    - "Test vectors verified with ramda via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ramda source"
  notes:
    - "ramda is an npm package. Install: npm install ramda"
    - "Provides functional programming utilities: add, reverse, uniq, sum, flatten."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns transformed value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ramda.add:
  kind: node_module_call_eq
  function: add
  category: math
  id_prefix: radd

  columns: [id, args, expected]
  rows:
    - [two_three, [2, 3], 5]
    - [neg,       [-1, 4], 3]

table ramda.reverse:
  kind: node_module_call_eq
  function: reverse
  category: array
  id_prefix: rrev

  columns: [id, args, expected]
  rows:
    - [list,   [[1,2,3]],       [3,2,1]]
    - [string, ["hello"],       "olleh"]

table ramda.uniq:
  kind: node_module_call_eq
  function: uniq
  category: array
  id_prefix: runiq

  columns: [id, args, expected]
  rows:
    - [dups,  [[1,2,1,3,2]],  [1,2,3]]

table ramda.sum:
  kind: node_module_call_eq
  function: sum
  category: math
  id_prefix: rsum

  columns: [id, args, expected]
  rows:
    - [five,  [[1,2,3,4,5]],  15]

table ramda.flatten:
  kind: node_module_call_eq
  function: flatten
  category: array
  id_prefix: rflatten

  columns: [id, args, expected]
  rows:
    - [nested,  [[[1,2],[3,[4]]]],  [1,2,3,4]]
