spec: ramda
version: ">=0.28.0"
backend: node(ramda)

docs: https://ramdajs.com/docs/

provenance:
  derived_from:
    - "Ramda documentation — https://ramdajs.com/docs/"
    - "Test vectors verified with ramda via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ramda source"
  notes:
    - "ramda is an npm package. Install: npm install ramda"
    - "All Ramda functions are auto-curried and handle args in data-last order."
    - "Only pure value-returning functions (no iteratee/predicate args) are specced here."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns computed value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ramda.add:
  kind: node_module_call_eq
  function: add
  category: arithmetic
  id_prefix: radd

  columns: [id, args, expected]
  rows:
    - [ints,    [1, 2],     3]
    - [floats,  [1.5, 2.5], 4]
    - [zero,    [0, 5],     5]
    - [neg,     [-3, 7],    4]

table ramda.max:
  kind: node_module_call_eq
  function: max
  category: arithmetic
  id_prefix: rmax

  columns: [id, args, expected]
  rows:
    - [larger,  [3, 5],  5]
    - [equal,   [4, 4],  4]
    - [neg,     [-1, 1], 1]

table ramda.sum:
  kind: node_module_call_eq
  function: sum
  category: arithmetic
  id_prefix: rsum

  columns: [id, args, expected]
  rows:
    - [basic,   [[1, 2, 3, 4, 5]],  15]
    - [single,  [[42]],             42]
    - [empty,   [[]],               0]

table ramda.flatten:
  kind: node_module_call_eq
  function: flatten
  category: lists
  id_prefix: rflat

  columns: [id, args, expected]
  rows:
    - [nested,  [[[1, 2], [3, 4]]],     [1, 2, 3, 4]]
    - [deep,    [[[1, [2]], [3, [4]]]],  [1, 2, 3, 4]]
    - [flat,    [[1, 2, 3]],            [1, 2, 3]]

table ramda.uniq:
  kind: node_module_call_eq
  function: uniq
  category: lists
  id_prefix: runiq

  columns: [id, args, expected]
  rows:
    - [dups,   [[1, 2, 1, 3, 2]],  [1, 2, 3]]
    - [unique, [[1, 2, 3]],        [1, 2, 3]]
    - [single, [[5]],              [5]]

table ramda.range:
  kind: node_module_call_eq
  function: range
  category: lists
  id_prefix: rrange

  columns: [id, args, expected]
  rows:
    - [basic,  [0, 5],   [0, 1, 2, 3, 4]]
    - [mid,    [3, 7],   [3, 4, 5, 6]]
    - [one,    [5, 6],   [5]]

table ramda.zip:
  kind: node_module_call_eq
  function: zip
  category: lists
  id_prefix: rzip

  columns: [id, args, expected]
  rows:
    - [basic,   [[1, 2, 3], ["a", "b", "c"]], [[1, "a"], [2, "b"], [3, "c"]]]
    - [short,   [[1, 2], [3, 4]],              [[1, 3], [2, 4]]]

table ramda.path:
  kind: node_module_call_eq
  function: path
  category: objects
  id_prefix: rpath

  columns: [id, args, expected]
  rows:
    - [nested,  [["a", "b"], {"a": {"b": 42}}],   42]
    - [shallow, [["x"], {"x": 1}],                1]
    - [string,  [["a"], {"a": "hello"}],          "hello"]

table ramda.take:
  kind: node_module_call_eq
  function: take
  category: lists
  id_prefix: rtake

  columns: [id, args, expected]
  rows:
    - [basic,  [3, [1, 2, 3, 4, 5]], [1, 2, 3]]
    - [all,    [5, [1, 2, 3]],        [1, 2, 3]]
    - [none,   [0, [1, 2, 3]],        []]
