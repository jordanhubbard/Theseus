spec: threading_extra166
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Lock.__class__.__name__ 'type'; threading.Lock.__module__ '_thread'; threading.Lock.__name__ 'lock'; threading.RLock.__class__.__name__ 'function'; threading.RLock.__module__ 'threading'; threading.RLock.__name__ 'RLock' (Wave 294)."
    - "threading.Lock.__class__.__name__ == 'type' — threading.Lock is NOT a Python function but a direct reference to the C extension type _thread.lock defined in Modules/_threadmodule.c; accessing threading.Lock.__class__.__name__ gives 'type' (it is a class object, not a function). Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — threading.Lock is an alias for _thread.lock, the C extension lock type; its __module__ is '_thread' (the private C module), not 'threading'. Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' — threading.Lock.__name__ is 'lock' (lowercase), the name of the C extension type in _thread; the public name 'Lock' (uppercase) is just the attribute name on the threading module. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — threading.RLock IS a Python function defined in Lib/threading.py that returns a reentrant lock object (either a C RLock or a Python fallback); its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' — threading.RLock is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' — threading.RLock is a Python factory function; its __name__ is 'RLock'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock identity — __class__, __module__, __name__
#
# Wave 294 theme: threading.Lock is the C extension type _thread.lock, not a
# Python function; its __class__.__name__ is 'type', __module__ is '_thread',
# and __name__ is 'lock'.
#
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__module__ == '_thread'
# threading.Lock.__name__ == 'lock'
# threading.Lock.__qualname__ == 'lock'
#
# threading.Lock is an attribute-level alias for the C extension type
# _thread.lock defined in Modules/_threadmodule.c. It is a class (type), NOT
# a function. Its __module__ is '_thread' (the private implementation module)
# rather than 'threading'. Its __name__ is the lowercase 'lock'. The public
# facing name 'Lock' (uppercase) is merely the attribute name used in the
# threading module namespace. New to extra166.
# ---------------------------------------------------------------------------

table threading_extra166.lock_class_identity:
  description: "threading.Lock: __class__.__name__ 'type', __module__ '_thread', __name__ 'lock', __qualname__ 'lock'; wave 294; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglci166

  columns: [id, function, args, expected, description]
  rows:
    - [lock_cls_name_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is the C extension type _thread.lock (not a Python function); it is a class object whose metaclass is 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra166"]
    - [lock_module_thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is an alias for _thread.lock, the C extension type implemented in Modules/_threadmodule.c; its __module__ is '_thread' (the private C implementation module), not 'threading'; str.__eq__('_thread') returns True; new to extra166"]
    - [lock_name_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is the C extension type _thread.lock; the type's internal __name__ is 'lock' (lowercase); the public-facing uppercase 'Lock' is just the attribute name in the threading namespace; str.__eq__('lock') returns True; new to extra166"]
    - [lock_qualname_lock,
       "Lock.__qualname__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__qualname__.__eq__('lock') == True — threading.Lock is _thread.lock; its __qualname__ is 'lock' (the same as __name__ for a top-level C extension type); str.__eq__('lock') returns True; new to extra166"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock identity — __class__, __module__, __name__
#
# Wave 294 theme: threading.RLock is a Python function (not a class); its
# __class__.__name__ is 'function', __module__ is 'threading', __name__ is 'RLock'.
#
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__module__ == 'threading'
# threading.RLock.__name__ == 'RLock'
# threading.Lock.__class__.__name__ != 'function' (cross-check)
#
# threading.RLock is a factory function defined in Lib/threading.py (unlike Lock
# which is a direct alias for a C extension type). RLock() returns a reentrant
# lock object that allows the same thread to acquire it multiple times without
# deadlocking. As a Python function its __class__.__name__ is 'function',
# __module__ is 'threading', and __name__ is 'RLock'. New to extra166.
# ---------------------------------------------------------------------------

table threading_extra166.rlock_function_identity:
  description: "threading.RLock: __class__.__name__ 'function', __module__ 'threading', __name__ 'RLock'; Lock.__class__.__name__ != 'function' cross-check; wave 294; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlfi166

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_cls_name_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a Python factory function defined in Lib/threading.py (unlike threading.Lock which is the C extension type _thread.lock); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra166"]
    - [rlock_module_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — threading.RLock is a Python function defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra166"]
    - [rlock_name_rlock,
       "RLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — threading.RLock is a Python factory function; its __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra166"]
    - [lock_cls_name_not_function,
       "Lock.__class__.__name__.__eq__",
       ["function"],
       false,
       "threading.Lock.__class__.__name__.__eq__('function') == False — threading.Lock is a C extension type (_thread.lock), NOT a Python function; its __class__.__name__ is 'type' not 'function'; str.__eq__('function') returns False; contrast with RLock which is a function; new to extra166"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra166
# ---------------------------------------------------------------------------

invariant threading_extra166.lock_class_name_type:
  description: "threading.Lock.__class__.__name__ == 'type' — Lock is the C extension type _thread.lock, not a function; wave 294; new to extra166"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra166.lock_module_thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is _thread.lock; its module is '_thread', not 'threading'; wave 294; new to extra166"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra166.lock_name_lock:
  description: "threading.Lock.__name__ == 'lock' — the C extension type name is lowercase 'lock'; the public 'Lock' is the attribute name; wave 294; new to extra166"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra166.lock_qualname_lock:
  description: "threading.Lock.__qualname__ == 'lock' — _thread.lock qualname is 'lock'; same as __name__ for this top-level C extension type; wave 294; new to extra166"
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra166.rlock_class_name_function:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a Python factory function in Lib/threading.py; wave 294; new to extra166"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra166.rlock_module_threading:
  description: "threading.RLock.__module__ == 'threading' — RLock factory function is defined in Lib/threading.py; wave 294; new to extra166"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra166.rlock_name_rlock:
  description: "threading.RLock.__name__ == 'RLock' — Python factory function name is 'RLock'; wave 294; new to extra166"
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra166.lock_not_function:
  description: "threading.Lock.__class__.__name__ != 'function' — Lock is a C type ('type'), not a Python function; contrast with RLock; wave 294; new to extra166"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["function"]
  expected: false

