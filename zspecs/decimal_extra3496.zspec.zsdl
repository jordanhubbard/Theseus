  notes:
    - "Wave 680 (io3496): __aenter__, __aexit__, __await__ dict-presence checks for io/pathlib/re/decimal types."
    - "All values False — these types are synchronous and do not implement the async context manager or awaitable protocols."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async context manager / awaitable protocol)."
    - "No decimal class defines __aenter__ in its own __dict__: decimal types are numeric and exception types, not async context managers."
    - "No decimal class defines __aexit__ in its own __dict__: decimal types do not implement the async context manager exit protocol."
    - "No decimal class defines __await__ in its own __dict__: decimal types are not awaitable objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all async context manager and awaitable protocols absent from decimal class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No decimal class defines __aenter__ in its own __dict__; all false.
# decimal.Decimal is a numeric type; decimal.Context is a precision/rounding
# configuration object; the exception subclasses are error types.
# None are async context managers.
# ---------------------------------------------------------------------------

table dc3496.aenter:
  description: "decimal types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3496

  columns: [id, function, args, expected]
  rows:
    - ["dc3496001", operator.contains, [decimal.Decimal.__dict__,          "__aenter__"], false]
    - ["dc3496002", operator.contains, [decimal.Context.__dict__,           "__aenter__"], false]
    - ["dc3496003", operator.contains, [decimal.DecimalException.__dict__,  "__aenter__"], false]
    - ["dc3496004", operator.contains, [decimal.InvalidOperation.__dict__,  "__aenter__"], false]
    - ["dc3496005", operator.contains, [decimal.Overflow.__dict__,          "__aenter__"], false]
    - ["dc3496006", operator.contains, [decimal.Underflow.__dict__,         "__aenter__"], false]

