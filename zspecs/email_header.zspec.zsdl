spec: email_header
version: ">=3.3"
backend: python_module(email.header)

docs: https://docs.python.org/3/library/email.header.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.header.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.header source: Lib/email/header.py (PSF; source inspection permitted)"
  not_derived_from:
    - "email.header source: RFC 2047 codec internals"
  notes:
    - "email.header provides the Header class and the decode_header / make_header helper functions."
    - "Header wraps a sequence of (string, charset) pairs and encodes them for use in an email header."
    - "decode_header(s) decodes a header string per RFC 2047 and returns a list of (decoded, charset) tuples."
    - "For plain ASCII input, decode_header returns [(str, None)] — no charset needed."
    - "make_header(decoded_seq) reconstructs a Header object from the list returned by decode_header."
    - "Header.__bases__[0].__name__ == 'object' — Header is a new-style class with no non-trivial base."
    - "All expected values verified by running Python 3.12 email.header module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name and module checks
# ---------------------------------------------------------------------------

table email_header.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Header, Header.__name__.__eq__, ["Header"], true]

table email_header.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Header, Header.__module__.__eq__, ["email.header"], true]

# ---------------------------------------------------------------------------
# Inheritance
# ---------------------------------------------------------------------------

invariant email_header.Header_base:
  description: "Header.__bases__[0].__name__ == 'object' — Header has no non-trivial base class"
  category: inheritance
  kind: python_call_eq
  function: Header.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table email_header.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [decode_header, decode_header.__name__.__eq__, ["decode_header"], true]
    - [make_header,   make_header.__name__.__eq__,   ["make_header"],   true]

# ---------------------------------------------------------------------------
# Instantiation
# ---------------------------------------------------------------------------

invariant email_header.Header_instantiable:
  description: "Header('Hello').__class__.__name__ == 'Header' — Header can be instantiated with a plain string"
  category: instantiation
  kind: python_call_eq
  function: Header
  args: ["Hello"]
  method: __class__.__name__.__eq__
  method_args: ["Header"]
  expected: true

# ---------------------------------------------------------------------------
# decode_header behaviour
# ---------------------------------------------------------------------------

invariant email_header.decode_header_returns_list:
  description: "decode_header('hello').__class__.__name__ == 'list'"
  category: behaviour
  kind: python_call_eq
  function: decode_header
  args: ["hello"]
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant email_header.decode_header_plain_ascii:
  description: "decode_header('hello') == [('hello', None)] — plain ASCII input returns [(str, None)]"
  category: behaviour
  kind: python_call_eq
  function: decode_header
  args: ["hello"]
  method: __eq__
  method_args: [["hello", null]]
  expected: true

# ---------------------------------------------------------------------------
# make_header behaviour
# ---------------------------------------------------------------------------

invariant email_header.make_header_returns_Header:
  description: "make_header(decode_header('hello')).__class__.__name__ == 'Header'"
  category: behaviour
  kind: python_call_eq
  function: make_header
  args: [["hello", null]]
  method: __class__.__name__.__eq__
  method_args: ["Header"]
  expected: true
