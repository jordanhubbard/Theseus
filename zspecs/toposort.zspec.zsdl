spec: toposort
version: ">=2.0.0"
backend: node(toposort)

docs: https://www.npmjs.com/package/toposort

provenance:
  derived_from:
    - "toposort README — https://www.npmjs.com/package/toposort"
    - "Test vectors verified with toposort via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "toposort source"
  notes:
    - "toposort is an npm package. Install: npm install toposort"
    - "toposort(edges) returns nodes in topological order (dependencies first)."
    - "toposort.array(nodes, edges) includes nodes not appearing in edges."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns topologically sorted array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table toposort.sort:
  kind: node_module_call_eq
  function: ~
  category: sort
  id_prefix: topo

  columns: [id, args, expected]
  rows:
    - [linear, [[["a","b"],["b","c"]]],                 ["a","b","c"]]
    - [dag,    [[["a","b"],["b","c"],["a","c"]]],        ["a","b","c"]]

table toposort.array:
  kind: node_module_call_eq
  function: array
  category: sort
  id_prefix: topoarr

  columns: [id, args, expected]
  rows:
    - [with_nodes, [["a","b","c"], [["a","b"],["b","c"]]], ["a","b","c"]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:50:09Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
