spec: toposort
version: ">=2.0.0"
backend: node(toposort)

docs: https://github.com/marcelklehr/toposort#readme

provenance:
  derived_from:
    - "toposort README — https://github.com/marcelklehr/toposort#readme"
    - "Test vectors verified with toposort@2.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "toposort source"
  notes:
    - "toposort exports a function with a .array sub-function."
    - "toposort(edges) infers nodes from edges and returns topologically sorted array."
    - "toposort.array(nodes, edges) takes explicit nodes list."
    - "Result is ordered from dependencies to dependents (DAG)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sorted array. Throws on cyclic graphs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table toposort.sort:
  kind: node_module_call_eq
  function: ~
  category: sort
  id_prefix: topo

  columns: [id, args, expected]
  rows:
    - [linear,  [[["a", "b"], ["b", "c"]]],  ["a", "b", "c"]]
    - [diamond, [[["a", "b"], ["a", "c"], ["b", "d"], ["c", "d"]]],  ["a", "b", "c", "d"]]
