spec: theseus_enum_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_enum_cr2)
blocks: enum

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html"
  notes:
    - "Clean-room extended enum utilities. Do NOT import enum."
    - "IntEnum: enum whose members are also ints (comparison with int works)."
    - "Flag: enum supporting bitwise OR combination."
    - "auto(): automatic value assignment."
    - "enum2_int_enum(): IntEnum member == its int value."
    - "enum2_flag_combine(): Flag.A | Flag.B has both bits set."
    - "enum2_auto_values(): auto() assigns sequential integers starting at 1."
    - "Export: IntEnum, Flag, auto, IntFlag."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_enum_cr2.int_enum:
  description: "IntEnum member compares equal to its int value"
  category: intenum
  kind: python_call_eq
  function: enum2_int_enum
  args: []
  expected: true

invariant theseus_enum_cr2.flag_combine:
  description: "Flag.A | Flag.B produces combined flag with value A.value | B.value"
  category: flag
  kind: python_call_eq
  function: enum2_flag_combine
  args: []
  expected: true

invariant theseus_enum_cr2.auto_values:
  description: "auto() assigns sequential values starting at 1"
  category: auto
  kind: python_call_eq
  function: enum2_auto_values
  args: []
  expected: [1, 2, 3]
