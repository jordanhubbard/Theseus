spec: concurrent_futures_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - concurrent.futures stdlib documentation
    - CPython Lib/concurrent/futures/_base.py
  not_derived_from:
    - any third-party executor implementations
    - asyncio executor wrappers
  notes:
    - Covers Executor and Future method doc class names
    - Checks that docstrings exist and are str instances
    - Stable across CPython 3.9+
  created_at: "2026-04-12"

table concurrent_futures_extra886.executor_future_doc_classnames:
  description: Verify __doc__.__class__.__name__ for concurrent.futures Executor and Future methods
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: cf886xx
  columns: [id, function, args, expected]
  rows:
    - [cf886xx001, concurrent.futures.Executor.submit.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx002, concurrent.futures.Executor.map.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx003, concurrent.futures.Executor.shutdown.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx004, concurrent.futures.Future.cancel.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx005, concurrent.futures.Future.result.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx006, concurrent.futures.Future.exception.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx007, concurrent.futures.Future.done.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx008, concurrent.futures.Future.running.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx009, concurrent.futures.Future.cancelled.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx010, concurrent.futures.Future.add_done_callback.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx011, concurrent.futures.Future.set_result.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf886xx012, concurrent.futures.Future.set_exception.__doc__.__class__.__name__.__eq__, ["str"], true]
