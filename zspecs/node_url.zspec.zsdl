spec: node_url
version: ">=12.0.0"
backend: node(url)

docs: https://nodejs.org/api/url.html

provenance:
  derived_from:
    - "Node.js url module documentation — https://nodejs.org/api/url.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "url is a Node.js built-in module. No npm install required."
    - "url.format(urlObject) serializes a URL object to a string."
    - "url.resolve(from, to) resolves a URL relative to a base URL."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string or object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_url.format:
  kind: node_module_call_eq
  function: format
  category: format
  id_prefix: urlfmt

  columns: [id, args, expected]
  rows:
    - [simple,    [{"protocol": "https:", "host": "example.com", "pathname": "/path"}],
       "https://example.com/path"]
    - [with_qs,   [{"protocol": "http:", "host": "example.com", "pathname": "/", "search": "?q=1"}],
       "http://example.com/?q=1"]

table node_url.resolve:
  kind: node_module_call_eq
  function: resolve
  category: resolve
  id_prefix: urlres

  columns: [id, args, expected]
  rows:
    - [relative, ["https://example.com/a/b", "../c"],  "https://example.com/c"]
    - [absolute, ["https://example.com/a/b", "/d"],    "https://example.com/d"]
    - [full,     ["https://example.com/a", "https://other.com/b"], "https://other.com/b"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:01:43Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
