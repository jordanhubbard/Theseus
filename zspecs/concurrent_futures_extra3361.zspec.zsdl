    - ["cf3361011", operator.contains, [concurrent.futures.Future.__dict__,              "__floor__"], false]
    - ["cf3361012", operator.contains, [concurrent.futures.Future.__dict__,              "__ceil__"], false]
    - ["cf3361013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__invert__"], false]
    - ["cf3361014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__floor__"], false]
    - ["cf3361015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ceil__"], false]
    - ["cf3361016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__invert__"], false]
    - ["cf3361017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__floor__"], false]
    - ["cf3361018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ceil__"], false]
