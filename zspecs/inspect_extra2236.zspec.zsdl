    - ["in2236027", "inspect.FullArgSpec.__dict__.__contains__", ["__new__"], true]
    - ["in2236028", "inspect.ArgInfo.__dict__.__contains__", ["__slots__"], true]
    - ["in2236029", "inspect.ArgInfo.__dict__.__contains__", ["__weakref__"], false]
    - ["in2236030", "inspect.ArgInfo.__dict__.__contains__", ["__dict__"], false]
    - ["in2236031", "inspect.ArgInfo.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in2236032", "inspect.ArgInfo.__dict__.__contains__", ["__init__"], false]
