spec: inspect_extra2236
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2236: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__ presence in class dicts."
    - "inspect.Parameter uses __slots__ = ('_name', '_kind', '_default', '_annotation'). No __weakref__ slot, no __dict__ key, defines __init__ but not __new__."
    - "inspect.Signature uses __slots__ = ('_return_annotation', '_parameters'). No __weakref__, no __dict__, defines __init__ but not __new__."
    - "inspect.BoundArguments uses __slots__ = ('arguments', '_signature', '__weakref__'). __weakref__ IS in __slots__ AND in the class dict as a slot descriptor. No __dict__ key, defines __init__ but not __new__."
    - "inspect.FullArgSpec is a namedtuple subclass: has __slots__ (empty tuple), no __weakref__ or __dict__ in class dict. Defines __new__ (namedtuple pattern), not __init__."
    - "inspect.ArgInfo is a namedtuple subclass: same pattern as FullArgSpec — empty __slots__, no __weakref__, no __dict__."
    - "inspect.FrameInfo is a pure-Python named-tuple-like class (subclass of _FrameInfo): no __slots__, has __dict__, no __weakref__, no __abstractmethods__."
    - "inspect.BlockFinder is a plain Python class: no __slots__, has both __weakref__ and __dict__, defines __init__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2236.parameter_slot_protocol:
  description: "inspect.Parameter slot descriptor protocol — uses __slots__, no __weakref__ or __dict__ in class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2236

  columns: [id, function, args, expected]
  rows:
    - ["in2236001", "inspect.Parameter.__dict__.__contains__", ["__slots__"], true]
    - ["in2236002", "inspect.Parameter.__dict__.__contains__", ["__weakref__"], false]
    - ["in2236003", "inspect.Parameter.__dict__.__contains__", ["__dict__"], false]
    - ["in2236004", "inspect.Parameter.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in2236005", "inspect.Parameter.__dict__.__contains__", ["__init__"], true]
    - ["in2236006", "inspect.Parameter.__dict__.__contains__", ["__new__"], false]
    - ["in2236007", "inspect.Parameter.__dict__.__contains__", ["__subclasshook__"], false]

table inspect_extra2236.signature_slot_protocol:
  description: "inspect.Signature slot descriptor protocol — uses __slots__, no __weakref__ or __dict__ in class dict"
  kind: python_call_eq
