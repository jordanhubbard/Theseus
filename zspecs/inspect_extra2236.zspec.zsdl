  rows:
    - ["in2236008", "inspect.Signature.__dict__.__contains__", ["__slots__"], true]
    - ["in2236009", "inspect.Signature.__dict__.__contains__", ["__weakref__"], false]
    - ["in2236010", "inspect.Signature.__dict__.__contains__", ["__dict__"], false]
    - ["in2236011", "inspect.Signature.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in2236012", "inspect.Signature.__dict__.__contains__", ["__init__"], true]
    - ["in2236013", "inspect.Signature.__dict__.__contains__", ["__new__"], false]
    - ["in2236014", "inspect.Signature.__dict__.__contains__", ["__subclasshook__"], false]

table inspect_extra2236.boundarguments_slot_protocol:
  description: "inspect.BoundArguments slot descriptor protocol — uses __slots__ including __weakref__, so __weakref__ IS in class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2236

  columns: [id, function, args, expected]
  rows:
    - ["in2236015", "inspect.BoundArguments.__dict__.__contains__", ["__slots__"], true]
    - ["in2236016", "inspect.BoundArguments.__dict__.__contains__", ["__weakref__"], true]
    - ["in2236017", "inspect.BoundArguments.__dict__.__contains__", ["__dict__"], false]
    - ["in2236018", "inspect.BoundArguments.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in2236019", "inspect.BoundArguments.__dict__.__contains__", ["__init__"], true]
    - ["in2236020", "inspect.BoundArguments.__dict__.__contains__", ["__new__"], false]
    - ["in2236021", "inspect.BoundArguments.__dict__.__contains__", ["__subclasshook__"], false]

