# ---------------------------------------------------------------------------
# io.IncrementalNewlineDecoder class identity: __name__, __module__, __mro__, __bases__
# IncrementalNewlineDecoder is a C extension type defined in Modules/_io/textio.c.
# It wraps another codec (typically a UTF-8 decoder) and translates newline
# sequences (\r\n, \r) into universal newline form (\n).
# Its MRO is the minimal 2-entry chain (IncrementalNewlineDecoder, object),
# meaning it does not participate in the io ABC hierarchy.
# __name__ has 25 characters — the longest name among the concrete io types.
# io_extra2-5 and io_extra13-17 covered instance behavior and method identity;
# no prior spec tested the class-level attributes via equality on the class object.
# ---------------------------------------------------------------------------

table io_extra122.IncrementalNewlineDecoder_name_and_module:
  description: "io.IncrementalNewlineDecoder class __name__='IncrementalNewlineDecoder'(25), __module__='_io'(3); C extension type in Modules/_io/textio.c; longest class name among concrete io types"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioindname122a

  columns: [id, function, args, expected, description]
  rows:
    - [ind_name_eq,    "IncrementalNewlineDecoder.__name__.__eq__",    ["IncrementalNewlineDecoder"], true,  "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' (25 chars; name of the universal newline translation wrapper codec)"]
    - [ind_name_len,   "IncrementalNewlineDecoder.__name__.__len__",   [],                            25,    "io.IncrementalNewlineDecoder.__name__.__len__() == 25 ('IncrementalNewlineDecoder' has 25 characters; the longest class name among concrete io types)"]
    - [ind_mod_eq,     "IncrementalNewlineDecoder.__module__.__eq__",  ["_io"],                       true,  "io.IncrementalNewlineDecoder.__module__ == '_io' (C extension implementation module; underscore marks the private C module)"]
    - [ind_mod_len,    "IncrementalNewlineDecoder.__module__.__len__", [],                            3,     "io.IncrementalNewlineDecoder.__module__.__len__() == 3 ('_io' has 3 characters; includes the underscore prefix)"]
    - [ind_name_ne,    "IncrementalNewlineDecoder.__name__.__eq__",    ["TextIOWrapper"],             false, "io.IncrementalNewlineDecoder.__name__ != 'TextIOWrapper' (distinct types; IncrementalNewlineDecoder(25) vs TextIOWrapper(13))"]
    - [ind_cls_type,   "IncrementalNewlineDecoder.__class__.__name__.__eq__", ["type"],              true,  "type(io.IncrementalNewlineDecoder).__name__ == 'type' (plain C extension type; no ABCMeta or custom metaclass)"]
    - [ind_name_gt_tw, "IncrementalNewlineDecoder.__name__.__len__.__gt__", [13],                    true,  "len('IncrementalNewlineDecoder') > len('TextIOWrapper') (25 > 13; IncrementalNewlineDecoder is the longest concrete io class name)"]

# ---------------------------------------------------------------------------
# io.IncrementalNewlineDecoder MRO: 2-entry minimal chain
# IncrementalNewlineDecoder.__mro__ == (IncrementalNewlineDecoder, object).
# This is the minimal MRO for a direct subtype of object.
# Unlike TextIOWrapper and BytesIO/StringIO (which have longer MROs through the
# io ABC chain), IncrementalNewlineDecoder skips the io ABC hierarchy entirely.
# Its __bases__[0] is object — it inherits directly from object with no ABC layer.
# ---------------------------------------------------------------------------

table io_extra122.IncrementalNewlineDecoder_mro:
  description: "io.IncrementalNewlineDecoder.__mro__ has 2 entries: (IncrementalNewlineDecoder, object); __bases__[0].__name__=='object'; minimal MRO bypasses the io ABC hierarchy entirely"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ioindmro122b

  columns: [id, function, args, expected, description]
  rows:
    - [ind_mro_len,   "IncrementalNewlineDecoder.__mro__.__len__",                [],                            2,     "io.IncrementalNewlineDecoder.__mro__.__len__() == 2 (IncrementalNewlineDecoder, object; minimal 2-entry MRO for a direct object subtype)"]
    - [ind_mro0,      "IncrementalNewlineDecoder.__mro__[0].__name__.__eq__",     ["IncrementalNewlineDecoder"], true,  "io.IncrementalNewlineDecoder.__mro__[0].__name__ == 'IncrementalNewlineDecoder' (the class itself is first in its own MRO)"]
    - [ind_mro1,      "IncrementalNewlineDecoder.__mro__[1].__name__.__eq__",     ["object"],                    true,  "io.IncrementalNewlineDecoder.__mro__[1].__name__ == 'object' (universal Python base class; IncrementalNewlineDecoder is a direct subtype of object)"]
    - [ind_mro1_len,  "IncrementalNewlineDecoder.__mro__[1].__name__.__len__",   [],                            6,     "io.IncrementalNewlineDecoder.__mro__[1].__name__.__len__() == 6 ('object' has 6 characters)"]
    - [ind_base0,     "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__",  ["object"],                    true,  "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' (direct base is object; no ABC layer between IncrementalNewlineDecoder and object)"]
    - [ind_mro1_ne,   "IncrementalNewlineDecoder.__mro__[1].__name__.__eq__",    ["_IOBase"],                   false, "io.IncrementalNewlineDecoder.__mro__[1].__name__ != '_IOBase' (slot 1 is 'object', not '_IOBase'; unlike concrete io types that have _IOBase at slot 1 or 2)"]
    - [ind_mro_not3,  "IncrementalNewlineDecoder.__mro__.__len__.__eq__",        [2],                           true,  "io.IncrementalNewlineDecoder.__mro__.__len__() == 2 (not 3 or 4; the io ABC types have 3-4 entry MROs; IncrementalNewlineDecoder uses the minimal 2-entry chain)"]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE constant
# io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; 2^17).
# It is an int used as the default argument to BufferedReader, BufferedWriter,
# and BufferedRandom when no explicit buffer_size is provided.
# DEFAULT_BUFFER_SIZE.bit_length() == 18 (2^17 needs 18 bits: 1 followed by 17 zeros).
# DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' (plain integer constant).
# No prior io_extra spec has verified DEFAULT_BUFFER_SIZE's actual integer value,
# its class name, or its bit_length.
# ---------------------------------------------------------------------------

table io_extra122.DEFAULT_BUFFER_SIZE:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB, 2^17); type 'int'; bit_length()==18; used as default buffer_size for BufferedReader/BufferedWriter/BufferedRandom"
  kind: python_call_eq
  category: module_constants
  id_prefix: iodefbuf122c

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_eq,       "DEFAULT_BUFFER_SIZE.__eq__",              [131072], true,  "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; 2^17; the default buffer size for all buffered io classes)"]
    - [dbs_cls,      "DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__",  ["int"],  true,  "type(io.DEFAULT_BUFFER_SIZE).__name__ == 'int' (DEFAULT_BUFFER_SIZE is a plain Python integer constant)"]
    - [dbs_bit_len,  "DEFAULT_BUFFER_SIZE.bit_length",         [],       18,    "io.DEFAULT_BUFFER_SIZE.bit_length() == 18 (2^17 == 131072; the integer 131072 requires 18 bits to represent in binary)"]
    - [dbs_gt,       "DEFAULT_BUFFER_SIZE.__gt__",             [8191],   true,  "io.DEFAULT_BUFFER_SIZE > 8191 (131072 is much larger than 8192-1; it is a generous default chosen to minimize syscall overhead for sequential I/O)"]
    - [dbs_ne8192,   "DEFAULT_BUFFER_SIZE.__eq__",             [8192],   false, "io.DEFAULT_BUFFER_SIZE != 8192 (the default is 131072, not 8192; 8192 was used in older CPython versions but DEFAULT_BUFFER_SIZE is 128 KiB on modern CPython)"]
    - [dbs_clsmod,   "DEFAULT_BUFFER_SIZE.__class__.__module__.__eq__", ["builtins"], true, "io.DEFAULT_BUFFER_SIZE.__class__.__module__ == 'builtins' (int is a builtin type; its __module__ is 'builtins' not 'io')"]
    - [dbs_pos,      "DEFAULT_BUFFER_SIZE.__gt__",             [0],      true,  "io.DEFAULT_BUFFER_SIZE > 0 (DEFAULT_BUFFER_SIZE is a positive integer; negative or zero buffer sizes are not meaningful)"]
    - [dbs_cls_len,  "DEFAULT_BUFFER_SIZE.__class__.__name__.__len__",  [],       3,     "io.DEFAULT_BUFFER_SIZE.__class__.__name__.__len__() == 3 ('int' has 3 characters; same class name length as '_io'.__len__()==3)"]

