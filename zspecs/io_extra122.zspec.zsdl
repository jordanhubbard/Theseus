# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra122.IncrementalNewlineDecoder.name_len_25:
  description: "io.IncrementalNewlineDecoder.__name__.__len__() == 25 (the class is named 'IncrementalNewlineDecoder'; it wraps an underlying codec and translates all newline sequences — \\r\\n, \\r — into the universal newline form \\n; it is defined in Modules/_io/textio.c as part of the C implementation of the io module; at 25 characters it is the longest class name among the concrete types exported by the io module; no prior io_extra spec has checked IncrementalNewlineDecoder.__name__.__len__() on the class object itself)"
  category: class_identity
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__name__.__len__"
  args: []
  expected: 25

invariant io_extra122.IncrementalNewlineDecoder.module_is_underscore_io:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' (length 3; IncrementalNewlineDecoder is a C extension type defined in Modules/_io/textio.c; like all concrete io types — FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, BytesIO, StringIO — it has __module__ == '_io' because the C extension is compiled as the private module _io; the public io module in Lib/io.py re-exports it; the underscore prefix on '_io' marks it as an implementation detail; no prior io_extra spec has checked IncrementalNewlineDecoder.__module__ via equality)"
  category: class_identity
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__module__.__eq__"
  args: ["_io"]
  expected: true

invariant io_extra122.IncrementalNewlineDecoder.mro_len_2:
  description: "io.IncrementalNewlineDecoder.__mro__.__len__() == 2 (the MRO is (IncrementalNewlineDecoder, object) — the minimal 2-entry chain for a direct subtype of object; unlike FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, BytesIO, and StringIO which all have MRO lengths of 4 or 5 entries through the io ABC hierarchy, IncrementalNewlineDecoder is not part of the io stream ABC chain at all; it is a standalone codec wrapper; no prior io_extra spec has checked IncrementalNewlineDecoder.__mro__.__len__())"
  category: class_hierarchy
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__mro__.__len__"
  args: []
  expected: 2

invariant io_extra122.IncrementalNewlineDecoder.bases0_is_object:
  description: "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' (IncrementalNewlineDecoder inherits directly from object with no intermediate base class; this means it is NOT part of the io type hierarchy that runs through _IOBase -> _RawIOBase/_BufferedIOBase/_TextIOBase; it is a standalone universal-newline translation codec that wraps another incremental codec; its __bases__ has exactly one entry — object; no prior io_extra spec has checked IncrementalNewlineDecoder.__bases__[0].__name__)"
  category: class_hierarchy
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant io_extra122.DEFAULT_BUFFER_SIZE_eq_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; 2^17; the integer constant that specifies the default buffer size for io.BufferedReader, io.BufferedWriter, and io.BufferedRandom when no explicit buffer_size argument is provided; 131072 is large enough to minimize the number of OS system calls for sequential I/O while being small enough to avoid excessive memory use; DEFAULT_BUFFER_SIZE.bit_length() == 18 because 2^17 requires 18 bits in binary representation; DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — it is a plain Python integer constant exported from the _io C extension module; no prior io_extra spec has verified the exact integer value 131072)"
  category: module_constants
  kind: python_call_eq
  function: "DEFAULT_BUFFER_SIZE.__eq__"
  args: [131072]
  expected: true

