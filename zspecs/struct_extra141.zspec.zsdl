spec: struct_extra141
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra140.zspec.zsdl — covers struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / __class__.__name__.__len__()==17 / format/__qualname__.__eq__('Struct.format') / size/__qualname__.__eq__('Struct.size') / struct.__doc__.__len__()==1278 / struct.error/__doc__ is None (table + invariants)."
    - "struct_extra139.zspec.zsdl — covers struct module-level function __qualname__ string equality (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / all six + Struct/__module__.__eq__('_struct') / full __doc__ length ordering (calcsize=66 < unpack=173 < pack=176 < unpack_from=188 < iter_unpack=239 < pack_into=274) (table + invariants)."
    - "struct_extra138.zspec.zsdl — covers Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / __qualname__ length ordering / error.__name__/__qualname__/__bases__[0].__name__/__bases__[0].__name__.__len__() (table + invariants)."
    - "struct_extra137.zspec.zsdl — covers struct.pack/__doc__/__class__.__name__.__eq__('str') / Struct.format/__doc__/__len__()==20 / Struct.size/__doc__/__len__()==20 / module function __doc__ length ordering (calcsize/unpack/pack/pack_into)."
    - "struct_extra136.zspec.zsdl — covers struct.Struct method __doc__ lengths (pack/pack_into/unpack/unpack_from/iter_unpack) / module-level pack_into/unpack_from/iter_unpack __doc__ lengths."
    - "struct_extra135.zspec.zsdl — covers struct.Struct.__eq__ inherited from object / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (all six) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() / error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra140."
    - "Wave 310 theme: struct.Struct class identity at a deeper level — Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') and __len__()==6 / Struct.__bases__[0].__name__.__eq__('object') and __len__()==6 / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / struct.error.__qualname__.__eq__('error') and __len__()==5."
    - "struct.Struct.__module__ == '_struct' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.Struct.__mro__) == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.Struct.__doc__) == 40. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error' (len 5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__qualname__ == 'Struct' (6 chars) and struct.Struct.__bases__[0].__name__ == 'object' (6 chars). Both are 6 chars despite being very different things: the qualname 'Struct' identifies the class within its module, while 'object' names the single base class. The length tie is coincidental."
    - "Note: struct.Struct.__mro__.__len__() == 2. The MRO is (struct.Struct, object) — just two entries because Struct directly inherits from object with no intermediate C classes. This is simpler than socket.socket's 3-entry MRO (socket.socket, _socket.socket, object) which has an intermediate C-level base class."
    - "Note: struct.Struct.__doc__ is 40 chars — 'Struct(fmt) --> compiled struct object\\n\\n'. This is one of the shortest class docstrings among the stdlib classes covered in this spec series, since the Struct class relies on the module-level docstring (1278 chars) for its format-character documentation."
    - "Note: struct.error.__qualname__ == 'error' (5 chars). The error class has a simple (non-qualified) qualname because it is a top-level class within the struct module. At 5 chars it is one char shorter than the Struct class qualname ('Struct', 6 chars). struct_extra93 anchors error.__bases__/__module__; this spec anchors the qualname equality string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__qualname__.__eq__('Struct')
# struct.Struct.__qualname__.__len__()==6
# struct.Struct.__bases__[0].__name__.__eq__('object')
#
# Wave 310 theme: struct.Struct class module and qualname identity.
#
# Struct.__module__ is '_struct' (7 chars, with underscore prefix) and
# Struct.__qualname__ is 'Struct' (6 chars, simple non-qualified name).
# Struct.__bases__[0].__name__ is 'object' (6 chars), showing direct object
# inheritance. extra93 anchors Struct __module__/__qualname__/__bases__; no prior
# struct spec anchors these equality strings together as a table under structcls141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra141.Struct_class_module_and_qualname:
  description: "struct.Struct.__module__.__eq__('_struct')==True / Struct.__qualname__.__eq__('Struct')==True / __qualname__.__len__()==6 / Struct.__bases__[0].__name__.__eq__('object')==True — Struct is from _struct C extension (7 chars with underscore); qualname 'Struct' (6 chars) matches class name; bases[0] is 'object' (6 chars, same length as qualname); extra93 anchors these broadly; first structcls141 anchor for equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: structcls141

  columns: [id, function, args, expected, description]
  rows:
    - [module_eq,         Struct.__module__.__eq__,              ["_struct"], true, "struct.Struct.__module__ == '_struct' (7 chars; private C extension with underscore prefix)"]
    - [qualname_eq,       Struct.__qualname__.__eq__,            ["Struct"],  true, "struct.Struct.__qualname__ == 'Struct' (6 chars; simple non-class-qualified name)"]
    - [qualname_len,      Struct.__qualname__.__len__,           [],          6,    "struct.Struct.__qualname__.__len__() is 6 ('Struct' = 6 chars; matches __bases__[0].__name__ length)"]
    - [bases_0_name_eq,   "Struct.__bases__[0].__name__.__eq__", ["object"],  true, "struct.Struct.__bases__[0].__name__ == 'object' (6 chars; direct object inheritance, no intermediate class)"]

# ---------------------------------------------------------------------------
# struct.Struct.__mro__.__len__()==2
# struct.Struct.__doc__.__len__()==40
# struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy')
#
# Wave 310 theme: struct.Struct MRO depth, doc length, and dict class name.
#
# Struct.__mro__.__len__() == 2 (Struct, object) — simpler than socket.socket's
# 3-entry MRO. Struct.__doc__ is 40 chars — one of the shortest class docstrings
# in this spec series. Struct.__dict__ is a mappingproxy with 16 entries.
# extra93 anchors Struct.__mro__.__len__()==2; extra140 anchors Struct.format
# getset_descriptor; no prior struct spec anchors Struct.__doc__.__len__()==40 or
# Struct.__dict__.__class__.__name__ as a table under structcls141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra141.Struct_mro_doc_and_dict_identity:
  description: "struct.Struct.__mro__/__len__()==2 / Struct.__doc__/__len__()==40 / Struct.__dict__/__class__.__name__.__eq__('mappingproxy')==True — MRO is (Struct, object) with just 2 entries (simpler than socket.socket's 3-entry MRO); __doc__ is 40 chars ('Struct(fmt) --> compiled struct object'); __dict__ is a mappingproxy with 16 entries; extra93 anchors MRO depth; first structcls141 anchor for __doc__ length and __dict__ class"
  kind: python_call_eq
  category: identity
  id_prefix: structcls141

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len_2,            Struct.__mro__.__len__,                    [],              2,    "struct.Struct.__mro__.__len__() is 2 (just Struct and object; no intermediate C base class)"]
    - [doc_len_40,           Struct.__doc__.__len__,                    [],              40,   "struct.Struct.__doc__.__len__() is 40 ('Struct(fmt) --> compiled struct object' + newlines)"]
    - [dict_class_mapping,   Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy' (16-entry read-only class namespace view)"]

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error')
# struct.error.__qualname__.__len__()==5
# struct.Struct.__bases__[0].__name__.__len__()==6
# struct.Struct.__module__.__len__()==7
#
# Wave 310 theme: struct.error qualname identity and length comparisons.
#
# struct.error.__qualname__ is 'error' (5 chars), one char shorter than Struct's
# qualname 'Struct' (6 chars). The length ordering is: error(5) < Struct(6) < 'Struct.'
# prefix(7). struct_extra95 anchors error.__qualname__.__len__()==5; no prior struct
# spec anchors error.__qualname__ == 'error' as a table together with Struct bases
# and module lengths under structcls141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra141.error_qualname_and_length_comparisons:
  description: "struct.error.__qualname__.__eq__('error')==True / __qualname__.__len__()==5 / Struct.__bases__[0].__name__.__len__()==6 / Struct.__module__.__len__()==7 — error qualname 'error' (5 chars) is shorter than Struct qualname 'Struct' (6 chars) which is shorter than '_struct' module (7 chars); length ordering: error(5) < Struct(6) < _struct(7); extra95 anchors error qualname length; first structcls141 anchor for error qualname equality string"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: structcls141

  columns: [id, function, args, expected, description]
  rows:
    - [error_qualname_eq,       error.__qualname__.__eq__,              ["error"], true, "struct.error.__qualname__ == 'error' (5 chars; simple non-qualified name; top-level exception class)"]
    - [error_qualname_len,      error.__qualname__.__len__,             [],        5,    "struct.error.__qualname__.__len__() is 5 ('error' = 5 chars; 1 char shorter than Struct qualname)"]
    - [bases_0_name_len,        "Struct.__bases__[0].__name__.__len__", [],        6,    "struct.Struct.__bases__[0].__name__.__len__() is 6 ('object' = 6 chars; ties with Struct qualname)"]
    - [module_len,              Struct.__module__.__len__,              [],        7,    "struct.Struct.__module__.__len__() is 7 ('_struct' = underscore + 6-char 'struct')"]

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct' (7 chars). The '_struct' C extension uses
# the standard CPython private-extension naming convention (underscore prefix + the
# public module name). Struct.__module__ is '_struct' (7 chars, with underscore),
# while struct.error.__module__ is 'struct' (6 chars, WITHOUT underscore). This
# contrast — Struct uses the private name while error uses the public name — reflects
# the different ways C extension objects report their module. extra93 anchors
# Struct.__module__ broadly; no prior struct spec anchors Struct.__module__.__eq__
# ('_struct') as a standalone under structcls141. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra141.Struct_module_eq:
  description: "struct.Struct.__module__.__eq__('_struct') == True — '_struct' (7 chars; private C extension with underscore prefix); contrasts with error.__module__ == 'struct' (6 chars, no underscore); both Struct and module-level functions share '_struct' as their __module__; extra93 anchors broadly; first standalone under structcls141"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.__qualname__ is 'Struct' (6 chars). The qualname equals the class
# name because Struct is a top-level class defined in the _struct C extension and
# exported to the struct module namespace. At 6 chars it ties in length with
# Struct.__bases__[0].__name__ ('object', also 6 chars). This coincidental length
# tie means that Struct.__qualname__.__len__() == Struct.__bases__[0].__name__.__len__()
# even though the two strings ('Struct' vs 'object') are different. extra93 anchors
# Struct.__qualname__ broadly; no prior struct spec anchors Struct.__qualname__.__eq__
# ('Struct') as a standalone under structcls141. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra141.Struct_qualname_eq:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — 'Struct' (6 chars; simple class name, same as __name__); coincidentally same length as __bases__[0].__name__ ('object', also 6 chars); top-level C extension class; extra93 anchors broadly; first standalone under structcls141"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__mro__.__len__()==2 — standalone
#
# struct.Struct.__mro__.__len__() is 2. The MRO is (struct.Struct, object) — the
# simplest possible non-trivial MRO. Struct has no intermediate C-level base class
# between itself and object, unlike socket.socket (3-entry MRO with _socket.socket
# in between). This 2-entry MRO indicates that Struct is a direct C extension type
# that inherits from object. extra93 anchors Struct.__mro__.__len__()==2; this
# standalone cross-checks it under structcls141. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra141.Struct_mro_len_2:
  description: "struct.Struct.__mro__.__len__() == 2 — MRO is (struct.Struct, object); simplest non-trivial MRO with no intermediate class; contrasts with socket.socket's 3-entry MRO (Python class, C base, object); extra93 anchors this; cross-check standalone under structcls141"
  category: identity
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error.__qualname__ is 'error' (5 chars). The exception class is named
# 'error' (lowercase, following Python's historic convention for exceptions in
# C extension modules like struct and socket). Its qualname is 'error' (5 chars),
# one char shorter than Struct's qualname 'Struct' (6 chars). struct_extra95
# anchors error.__qualname__.__len__()==5; no prior struct spec anchors
# error.__qualname__ == 'error' as a standalone under structcls141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra141.error_qualname_eq:
  description: "struct.error.__qualname__.__eq__('error') == True — 'error' (5 chars; 1 char shorter than Struct qualname 'Struct' at 6 chars); lowercase exception following historic C extension convention; top-level exception class with simple qualname; extra95 anchors the length; first standalone under structcls141"
  category: qualname_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__len__()==40 — standalone
#
# struct.Struct.__doc__.__len__() is 40. The class docstring is
# 'Struct(fmt) --> compiled struct object\n\n' (40 chars including trailing newlines).
# At 40 chars it is one of the shortest class docstrings in the stdlib module series.
# The module-level docstring (1278 chars, anchored in extra140) is 31.95x longer than
# the class docstring (40 chars), because the module-level docstring contains all
# the format-character tables and byte-order prefix documentation. No prior struct
# spec anchors Struct.__doc__.__len__()==40 as a standalone under structcls141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra141.Struct_doc_len_40:
  description: "struct.Struct.__doc__.__len__() == 40 — 'Struct(fmt) --> compiled struct object\\n\\n' (40 chars including trailing newlines); one of the shortest class docstrings in the stdlib series; module-level __doc__ (1278 chars, extra140) is ~32x longer; no prior struct spec anchors this as a standalone; first standalone under structcls141"
  category: doc_lengths
  kind: python_call_eq
  function: Struct.__doc__.__len__
  args: []
  expected: 40

