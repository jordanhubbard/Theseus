spec: hashlib_extra5
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/sha256module.c"
  notes:
    - "This spec extends prior hashlib specs."
    - "Focus: __module__ and __name__ for hashlib functions; digest sizes; available algorithms."
    - "hashlib.algorithms_guaranteed is a set of algorithm names guaranteed to be available."
    - "'sha256' in hashlib.algorithms_guaranteed == True."
    - "'md5' in hashlib.algorithms_guaranteed == True."
    - "'sha1' in hashlib.algorithms_guaranteed == True."
    - "hashlib.sha256(b'').digest_size == 32 (256 bits / 8)."
    - "hashlib.sha256(b'').block_size == 64."
    - "hashlib.md5(b'').digest_size == 16 (128 bits / 8)."
    - "hashlib.sha1(b'').digest_size == 20 (160 bits / 8)."
    - "hashlib.new.__name__ == 'new'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table hashlib_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [new,       new.__name__.__eq__,       ["new"],       true]
    - [sha256,    sha256.__name__.__eq__,    ["openssl_sha256"], true]

invariant hashlib_extra5.algorithms_guaranteed.sha256:
  description: "'sha256' in hashlib.algorithms_guaranteed == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra5.algorithms_guaranteed.md5:
  description: "'md5' in hashlib.algorithms_guaranteed == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

invariant hashlib_extra5.algorithms_guaranteed.sha1:
  description: "'sha1' in hashlib.algorithms_guaranteed == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha1"]
  expected: true

invariant hashlib_extra5.algorithms_guaranteed.sha512:
  description: "'sha512' in hashlib.algorithms_guaranteed == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha512"]
  expected: true

invariant hashlib_extra5.algorithms_guaranteed.is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra5.sha256.digest_size:
  description: "hashlib.sha256(b'').digest_size == 32"
  category: digest_size
  kind: python_call_eq
  function: sha256
  args: [!hex ""]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra5.sha256.block_size:
  description: "hashlib.sha256(b'').block_size == 64"
  category: block_size
  kind: python_call_eq
  function: sha256
  args: [!hex ""]
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra5.md5.digest_size:
  description: "hashlib.md5(b'').digest_size == 16"
  category: digest_size
  kind: python_call_eq
  function: md5
  args: [!hex ""]
  method: digest_size.__eq__
  method_args: [16]
  expected: true

invariant hashlib_extra5.sha1.digest_size:
  description: "hashlib.sha1(b'').digest_size == 20"
  category: digest_size
  kind: python_call_eq
  function: sha1
  args: [!hex ""]
  method: digest_size.__eq__
  method_args: [20]
  expected: true

invariant hashlib_extra5.sha256.name_attr:
  description: "hashlib.sha256(b'').name == 'sha256'"
  category: name_attr
  kind: python_call_eq
  function: sha256
  args: [!hex ""]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra5.algorithms_available.is_set:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true
