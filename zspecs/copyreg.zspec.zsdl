spec: copyreg
version: ">=3.x"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "Python copyreg documentation — https://docs.python.org/3/library/copyreg.html"
    - "Test vectors verified by running Python 3.14.3 copyreg module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
  notes:
    - "copyreg.pickle(type, reduce_func) registers a custom reduce function for pickling objects of a given type."
    - "copyreg.constructor(object) registers a callable as a legitimate constructor for use during unpickling."
    - "copyreg.add_extension(module, name, code) and remove_extension() manage a short-code registry for pickle opcode optimization."
    - "copyreg.clear_extension_cache() clears the runtime cache mapping codes back to (module, name) pairs."
    - "copyreg.dispatch_table is a dict mapping types to their registered reduce functions."
    - "All functions are defined in the copyreg module itself (__module__ == 'copyreg')."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "copyreg raises TypeError when pickle() is called with a non-callable reduce function, and ValueError when add_extension() receives a code <= 0."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Function names — verify the module exports the expected callables
# ---------------------------------------------------------------------------

invariant copyreg.names.pickle:
  description: "copyreg.pickle.__name__ == 'pickle'"
  category: names
  kind: python_call_eq
  function: "pickle.__name__.__eq__"
  args: ["pickle"]
  expected: true

invariant copyreg.names.constructor:
  description: "copyreg.constructor.__name__ == 'constructor'"
  category: names
  kind: python_call_eq
  function: "constructor.__name__.__eq__"
  args: ["constructor"]
  expected: true

invariant copyreg.names.add_extension:
  description: "copyreg.add_extension.__name__ == 'add_extension'"
  category: names
  kind: python_call_eq
  function: "add_extension.__name__.__eq__"
  args: ["add_extension"]
  expected: true

invariant copyreg.names.remove_extension:
  description: "copyreg.remove_extension.__name__ == 'remove_extension'"
  category: names
  kind: python_call_eq
  function: "remove_extension.__name__.__eq__"
  args: ["remove_extension"]
  expected: true

invariant copyreg.names.clear_extension_cache:
  description: "copyreg.clear_extension_cache.__name__ == 'clear_extension_cache'"
  category: names
  kind: python_call_eq
  function: "clear_extension_cache.__name__.__eq__"
  args: ["clear_extension_cache"]
  expected: true

# ---------------------------------------------------------------------------
# Module origin — all public functions belong to copyreg
# ---------------------------------------------------------------------------

invariant copyreg.module.pickle:
  description: "copyreg.pickle.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: "pickle.__module__.__eq__"
  args: ["copyreg"]
  expected: true

invariant copyreg.module.constructor:
  description: "copyreg.constructor.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: "constructor.__module__.__eq__"
  args: ["copyreg"]
  expected: true

invariant copyreg.module.add_extension:
  description: "copyreg.add_extension.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: "add_extension.__module__.__eq__"
  args: ["copyreg"]
  expected: true

# ---------------------------------------------------------------------------
# dispatch_table — must be a plain dict
# ---------------------------------------------------------------------------

invariant copyreg.dispatch_table.is_dict:
  description: "copyreg.dispatch_table.__class__.__name__ == 'dict' — dispatch_table is a plain dict"
  category: dispatch_table
  kind: python_call_eq
  function: "dispatch_table.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true
