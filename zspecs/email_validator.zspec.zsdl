spec: email_validator
version: ">=2.0.0"
backend: node(email-validator)

docs: https://github.com/manishsaraan/email-validator#readme

provenance:
  derived_from:
    - "email-validator README — https://github.com/manishsaraan/email-validator#readme"
    - "RFC 5321/5322 (lite subset)"
    - "Test vectors verified with email-validator via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "email-validator source"
  notes:
    - "Lightweight email-syntax validator using a single tested regex (sub-RFC-5322 but practical)."
    - "Install: npm install email-validator"
    - "Module exports {validate}; validate(s) returns boolean."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure boolean predicate; never throws."
  stderr: "null"
  stickiness: "N/A — pure function."
  codes: {}

table email_validator.validate:
  kind: node_module_call_eq
  category: validate
  function: validate
  id_prefix: validate

  columns: [id, args, expected]
  rows:
    - [simple_valid,       ["a@b.com"],                       true]
    - [longer_valid,       ["jordan.h@example.com"],          true]
    - [plus_tag_valid,     ["plus+tag@example.com"],          true]
    - [subdomain,          ["a@x.example.com"],               true]
    - [hyphen_in_domain,   ["a@my-host.com"],                  true]
    - [missing_at,         ["not an email"],                   false]
    - [empty_local_part,   ["@no-local.com"],                  false]
    - [empty_string,       [""],                                false]
    - [no_tld,             ["a@b"],                            false]
    - [whitespace_only,    ["   "],                             false]
