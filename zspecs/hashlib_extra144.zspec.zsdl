spec: hashlib_extra144
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra143.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __doc__ lengths (63/64/66/66/66/66) and qualname lengths / pbkdf2_hmac/scrypt __doc__ lengths (91/46) / md5/sha1/sha224/sha384/pbkdf2_hmac/scrypt __qualname__ lengths / __module__ equality across constructor groups (table + invariants)."
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b and blake2s class constants (SALT_SIZE, MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE) / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ and __doc__.__len__() / hashlib.__spec__ attribute identity / hashlib.new.__doc__.__len__()==147 / hashlib.file_digest.__doc__.__len__()==417."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__()."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra143."
    - "Wave 290 theme: HASH object type and method __doc__ lengths accessed via hashlib._hashlib.HASH / HASH method __qualname__ lengths / sha256 vs sha512 __doc__ inequality / sha256 vs sha224 __doc__ inequality."
    - "hashlib._hashlib.HASH.__doc__.__len__() == 442. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.update.__doc__.__len__() == 57. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.digest.__doc__.__len__() == 42. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.hexdigest.__doc__.__len__() == 58. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.copy.__doc__.__len__() == 33. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.update.__qualname__ == 'HASH.update' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.digest.__qualname__ == 'HASH.digest' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.hexdigest.__qualname__ == 'HASH.hexdigest' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.copy.__qualname__ == 'HASH.copy' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__ != hashlib.sha512.__doc__ (both 66 chars but different algorithm names). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__ != hashlib.sha224.__doc__ (both 66 chars but different algorithm names). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__.__len__() == 10 ('__hash_new'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib._hashlib is the private _hashlib C extension module exposed as an attribute of the hashlib module. The HASH type is accessed as hashlib._hashlib.HASH — a dotted path without parentheses — making it usable as a ZSDL function path."
    - "Note: type(hashlib.md5()).__name__ == 'HASH' — the C-level hash object type is named HASH. The type's __doc__ (442 chars) lists all four methods (update/digest/hexdigest/copy) and two attributes (name, digest_size). This is the class-level docstring, distinct from any method docstrings."
    - "Note: The four HASH method docstrings are all short: copy (33) is shortest, digest (42) next, update (57) third, hexdigest (58) longest. hexdigest is one char longer than update because 'hexadecimal digits' is longer than 'string'."
    - "Note: sha256.__doc__ and sha512.__doc__ are both 66 chars (same template length) but are NOT equal strings because they embed the algorithm name ('sha256' vs 'sha512'). This illustrates that equal length does not imply equal content."
    - "Note: HASH method qualnames follow the pattern 'HASH.<method>'. update and digest share 11-char qualnames; hexdigest is 14 chars; copy is 9 chars (shortest: 'HASH.' prefix = 5 + 4-char name)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__doc__.__len__()==442
# hashlib._hashlib.HASH.update.__doc__.__len__()==57
# hashlib._hashlib.HASH.digest.__doc__.__len__()==42
# hashlib._hashlib.HASH.hexdigest.__doc__.__len__()==58
# hashlib._hashlib.HASH.copy.__doc__.__len__()==33
#
# Wave 290 theme: HASH object type and method __doc__ lengths.
#
# The HASH type __doc__ (442 chars) enumerates all four methods (update,
# digest, hexdigest, copy) and two attributes (name, digest_size) in a
# structured list format. The method docstrings are short C-level descriptions:
# copy (33) < digest (42) < update (57) < hexdigest (58). The HASH type is
# accessed via hashlib._hashlib.HASH without calling any constructor.
# No prior hashlib spec anchors HASH object __doc__ lengths under hashdoc144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra144.HASH_method_doc_lengths:
  description: "hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH.update/__doc__/__len__()==57 / HASH.digest/__doc__/__len__()==42 / HASH.hexdigest/__doc__/__len__()==58 / HASH.copy/__doc__/__len__()==33 — HASH type __doc__ (442 chars) lists all four methods and two attributes; copy (33) is shortest, hexdigest (58) is longest; all are C-level method_descriptor docstrings from _hashlib; HASH accessed via hashlib._hashlib.HASH; no prior hashlib spec anchors HASH object __doc__ lengths; first hashdoc144 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: hashdoc144

  columns: [id, function, args, expected, description]
  rows:
    - [HASH_type_doc_len,      _hashlib.HASH.__doc__.__len__,      [], 442, "hashlib._hashlib.HASH.__doc__.__len__() is 442 (HASH class docstring lists update/digest/hexdigest/copy methods and name/digest_size attributes)"]
    - [HASH_update_doc_len,    _hashlib.HASH.update.__doc__.__len__,    [], 57,  "hashlib._hashlib.HASH.update.__doc__.__len__() is 57 ('Update this hash object\\'s state with the provided string.')"]
    - [HASH_digest_doc_len,    _hashlib.HASH.digest.__doc__.__len__,    [], 42,  "hashlib._hashlib.HASH.digest.__doc__.__len__() is 42 ('Return the digest value as a bytes object.')"]
    - [HASH_hexdigest_doc_len, _hashlib.HASH.hexdigest.__doc__.__len__, [], 58,  "hashlib._hashlib.HASH.hexdigest.__doc__.__len__() is 58 ('Return the digest value as a string of hexadecimal digits.')"]
    - [HASH_copy_doc_len,      _hashlib.HASH.copy.__doc__.__len__,      [], 33,  "hashlib._hashlib.HASH.copy.__doc__.__len__() is 33 ('Return a copy of the hash object.')"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.update.__qualname__.__len__()==11 ('HASH.update')
# hashlib._hashlib.HASH.digest.__qualname__.__len__()==11 ('HASH.digest')
# hashlib._hashlib.HASH.hexdigest.__qualname__.__len__()==14 ('HASH.hexdigest')
# hashlib._hashlib.HASH.copy.__qualname__.__len__()==9 ('HASH.copy')
#
# Wave 290 theme: HASH method __qualname__ lengths.
#
# All HASH method qualnames follow the pattern 'HASH.<method>'. The 5-char
# prefix 'HASH.' plus the method name length gives: update/digest = 11 each,
# hexdigest = 14, copy = 9 (shortest: 5 + 4). No prior hashlib spec anchors
# HASH method __qualname__ lengths under hashdoc144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra144.HASH_method_qualname_lengths:
  description: "hashlib._hashlib.HASH.update/__qualname__/__len__()==11 / digest/__qualname__/__len__()==11 / hexdigest/__qualname__/__len__()==14 / copy/__qualname__/__len__()==9 — all HASH method qualnames follow 'HASH.<method>' pattern (5-char prefix + method name length); update/digest share 11-char qualnames; hexdigest is longest (14); copy is shortest (9 = 5 + 4 chars); no prior hashlib spec anchors HASH method qualname lengths; first hashdoc144 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashdoc144

  columns: [id, function, args, expected, description]
  rows:
    - [HASH_update_qualname_len,    _hashlib.HASH.update.__qualname__.__len__,    [], 11, "hashlib._hashlib.HASH.update.__qualname__.__len__() is 11 ('HASH.update' = 5 + 6 chars)"]
    - [HASH_digest_qualname_len,    _hashlib.HASH.digest.__qualname__.__len__,    [], 11, "hashlib._hashlib.HASH.digest.__qualname__.__len__() is 11 ('HASH.digest' = 5 + 6 chars, same as update)"]
    - [HASH_hexdigest_qualname_len, _hashlib.HASH.hexdigest.__qualname__.__len__, [], 14, "hashlib._hashlib.HASH.hexdigest.__qualname__.__len__() is 14 ('HASH.hexdigest' = 5 + 9 chars; longest HASH method qualname)"]
    - [HASH_copy_qualname_len,      _hashlib.HASH.copy.__qualname__.__len__,      [], 9,  "hashlib._hashlib.HASH.copy.__qualname__.__len__() is 9 ('HASH.copy' = 5 + 4 chars; shortest HASH method qualname)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__eq__(hashlib.sha512.__doc__)==False
# hashlib.sha256.__doc__.__eq__(hashlib.sha224.__doc__)==False
# hashlib.new.__qualname__.__len__()==10
#
# Wave 290 theme: sha256/sha512/sha224 __doc__ inequality and new.__qualname__.__len__().
#
# sha256, sha512, and sha224 all have 66-char __doc__ strings (the template
# 'Returns a {name} hash object; optionally initialized with a string' where the
# name is 6 chars in each case). Despite equal lengths, the docstrings are NOT
# equal because the embedded algorithm name differs ('sha256' vs 'sha512' vs
# 'sha224'). hashlib.new.__qualname__ is '__hash_new' (10 chars). No prior hashlib
# spec anchors these inequality checks or new.__qualname__.__len__()==10 as a
# table under hashdoc144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra144.sha256_doc_inequality_and_new_qualname:
  description: "hashlib.sha256/__doc__.__eq__(hashlib.sha512/__doc__)==False / sha256/__doc__.__eq__(sha224/__doc__)==False / hashlib.new/__qualname__.__len__()==10 — sha256/sha512/sha224 all have 66-char docs but are not equal (differ in embedded algorithm name); equal length does not imply equal content; new.__qualname__ is '__hash_new' (private backing name, 10 chars); no prior hashlib spec anchors these together; first hashdoc144 anchor"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc144

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_ne_sha512_doc,  sha256.__doc__.__eq__, ["Returns a sha512 hash object; optionally initialized with a string"], false, "hashlib.sha256.__doc__ != hashlib.sha512.__doc__ (both 66 chars; differ only in 'sha256' vs 'sha512' embedded name)"]
    - [sha256_ne_sha224_doc,  sha256.__doc__.__eq__, ["Returns a sha224 hash object; optionally initialized with a string"], false, "hashlib.sha256.__doc__ != hashlib.sha224.__doc__ (both 66 chars; differ only in 'sha256' vs 'sha224' embedded name)"]
    - [new_qualname_len,      new.__qualname__.__len__,  [], 10, "hashlib.new.__qualname__.__len__() is 10 ('__hash_new'; private backing function name, 10 chars)"]
    - [new_qualname_eq,       new.__qualname__.__eq__, ["__hash_new"], true, "hashlib.new.__qualname__ == '__hash_new' (double-underscore prefix marks it as internal; public name 'new' is only 3 chars)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__doc__.__len__()==442 — standalone
#
# hashlib._hashlib.HASH.__doc__.__len__() is 442. The HASH class docstring is a
# structured listing that enumerates all four HASH methods (update, digest,
# hexdigest, copy) under a 'Methods:' section and two attributes (name,
# digest_size) under an 'Attributes:' section. This is the C-level class-level
# docstring for the HASH type from _hashlib; it is the same for all algorithm
# instances (md5, sha1, sha256, etc.) because they all return the same HASH type.
# HASH is accessed via hashlib._hashlib.HASH — no parentheses required.
# No prior hashlib spec anchors HASH type __doc__.__len__() as a standalone
# under hashdoc144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra144.HASH_type_doc_len_442:
  description: "hashlib._hashlib.HASH.__doc__.__len__() == 442 — the HASH class docstring (442 chars) lists update/digest/hexdigest/copy methods under 'Methods:' and name/digest_size attributes under 'Attributes:'; same docstring for all algorithm instances; C-level type from _hashlib; accessed via hashlib._hashlib.HASH; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc144"
  category: doc_lengths
  kind: python_call_eq
  function: _hashlib.HASH.__doc__.__len__
  args: []
  expected: 442

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.hexdigest.__doc__.__len__()==58 — standalone
#
# hashlib._hashlib.HASH.hexdigest.__doc__.__len__() is 58. The hexdigest method
# docstring is the longest of the four HASH method docstrings: 'Return the
# digest value as a string of hexadecimal digits.' (58 chars). It is one char
# longer than update (57) because 'hexadecimal digits' is longer than 'string'
# in the update docstring. No prior hashlib spec anchors
# HASH.hexdigest.__doc__.__len__()==58 as a standalone under hashdoc144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra144.HASH_hexdigest_doc_len_58:
  description: "hashlib._hashlib.HASH.hexdigest.__doc__.__len__() == 58 — longest HASH method docstring (58 chars); 'Return the digest value as a string of hexadecimal digits.'; one char longer than update (57); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc144"
  category: doc_lengths
  kind: python_call_eq
  function: _hashlib.HASH.hexdigest.__doc__.__len__
  args: []
  expected: 58

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.copy.__doc__.__len__()==33 — standalone
#
# hashlib._hashlib.HASH.copy.__doc__.__len__() is 33. The copy method docstring
# is the shortest of the four HASH method docstrings: 'Return a copy of the
# hash object.' (33 chars). copy is simpler than the other methods — it takes
# no arguments and simply duplicates the current hash state. No prior hashlib
# spec anchors HASH.copy.__doc__.__len__()==33 as a standalone under hashdoc144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra144.HASH_copy_doc_len_33:
  description: "hashlib._hashlib.HASH.copy.__doc__.__len__() == 33 — shortest HASH method docstring (33 chars); 'Return a copy of the hash object.'; takes no arguments; copy is the simplest HASH method (no input, no flags); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc144"
  category: doc_lengths
  kind: python_call_eq
  function: _hashlib.HASH.copy.__doc__.__len__
  args: []
  expected: 33

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__len__()==10 — standalone
#
# hashlib.new.__qualname__.__len__() is 10. The qualname '__hash_new' (10 chars)
# reveals the private naming convention: the module exports 'new' as the public
# API but the actual function implementation is named '__hash_new' with a
# double-underscore prefix indicating it is internal. This is distinct from
# the 3-char public name 'new'. No prior hashlib spec anchors
# new.__qualname__.__len__()==10 as a standalone under hashdoc144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra144.new_qualname_len_10:
  description: "hashlib.new.__qualname__.__len__() == 10 — qualname is '__hash_new' (10 chars), revealing the private backing function name; public name 'new' is only 3 chars; double-underscore prefix marks it as internal; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc144"
  category: qualname_lengths
  kind: python_call_eq
  function: new.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.digest.__doc__.__len__()==42 — standalone
#
# hashlib._hashlib.HASH.digest.__doc__.__len__() is 42. The digest method
# docstring 'Return the digest value as a bytes object.' is the second-shortest
# HASH method docstring. It differs from hexdigest (58) in that 'a bytes object'
# (14 chars) replaces 'a string of hexadecimal digits' (31 chars), making
# digest's docstring 16 chars shorter than hexdigest's. No prior hashlib spec
# anchors HASH.digest.__doc__.__len__()==42 as a standalone under hashdoc144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra144.HASH_digest_doc_len_42:
  description: "hashlib._hashlib.HASH.digest.__doc__.__len__() == 42 — second-shortest HASH method docstring (42 chars); 'Return the digest value as a bytes object.'; 16 chars shorter than hexdigest (58) because 'bytes object' replaces 'string of hexadecimal digits'; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc144"
  category: doc_lengths
  kind: python_call_eq
  function: _hashlib.HASH.digest.__doc__.__len__
  args: []
  expected: 42

