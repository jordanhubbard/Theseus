spec: theseus_io_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_io_cr3)
blocks: io

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
  notes:
    - "Clean-room extended I/O utilities. Do NOT import io."
    - "DEFAULT_BUFFER_SIZE: default buffer size (8192)."
    - "RawIOBase: base class for raw I/O (binary, unbuffered)."
    - "BufferedIOBase: base class for buffered I/O."
    - "TextIOBase: base class for text I/O."
    - "IncrementalNewlineDecoder: translates newlines on read."
    - "io3_default_buffer_size(): DEFAULT_BUFFER_SIZE == 8192."
    - "io3_stringio_getvalue(): s=StringIO(); s.write('hello'); s.getvalue() == 'hello'."
    - "io3_bytesio_read(): b=BytesIO(b'abc'); b.read(2) == b'ab'."
    - "StringIO: in-memory text stream using a list of chars or a string buffer."
    - "BytesIO: in-memory binary stream using a bytearray."
    - "Export: DEFAULT_BUFFER_SIZE, StringIO, BytesIO."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_io_cr3.default_buffer_size:
  description: "DEFAULT_BUFFER_SIZE == 8192"
  category: constants
  kind: python_call_eq
  function: io3_default_buffer_size
  args: []
  expected: 8192

invariant theseus_io_cr3.stringio_getvalue:
  description: "StringIO write then getvalue"
  category: stringio
  kind: python_call_eq
  function: io3_stringio_getvalue
  args: []
  expected: "hello"

invariant theseus_io_cr3.bytesio_read:
  description: "BytesIO read partial"
  category: bytesio
  kind: python_call_eq
  function: io3_bytesio_read
  args: []
  expected: true
