spec: concurrent_futures_extra275
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.thread.ThreadPoolExecutor method qualnames and _work_queue attribute type. NEW in extra275: concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread'; concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object]); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25, own method); ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27, own method, longest in spec); ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12, inherited from Executor); a new ThreadPoolExecutor(max_workers=1)._work_queue.__class__.__name__=='SimpleQueue'; _work_queue.__class__.__module__=='_queue' (C extension). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'. ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py, a separate submodule from _base.py (which defines Future and Executor); its __module__ is 'concurrent.futures.thread' (len=26: 'concurrent.futures.'=19+'thread'=6+1=26). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12). map() is defined on the Executor base class and inherited by ThreadPoolExecutor; its qualname reflects the defining class 'Executor.map' not 'ThreadPoolExecutor.map'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ThreadPoolExecutor._work_queue.__class__.__module__ == '_queue'. The internal work queue is a queue.SimpleQueue backed by the C extension module '_queue'; type(executor._work_queue).__name__ == 'SimpleQueue' and type(executor._work_queue).__module__ == '_queue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor class identity — extra275
#
# concurrent.futures.ThreadPoolExecutor.__module__             == 'concurrent.futures.thread'
# concurrent.futures.ThreadPoolExecutor.__name__               == 'ThreadPoolExecutor'
# concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__  == 'Executor'
# concurrent.futures.ThreadPoolExecutor.__mro__.__len__()      == 3
# concurrent.futures.ThreadPoolExecutor.__qualname__           == 'ThreadPoolExecutor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra275.cf_thread_pool_executor_identity:
  description: "concurrent.futures.ThreadPoolExecutor class identity checks in cfthread275 namespace — ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True; ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (len=26: 'concurrent.futures.'=19+'thread'=6+1=26; distinct from '_base' submodule where Executor is defined); ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (ThreadPoolExecutor inherits from Executor as sole direct base); ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object]); ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (module-level class, qualname equals name); ThreadPoolExecutor.__name__.__len__()==18 ('ThreadPoolExecutor'=18); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfthread275

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name_eq,    "concurrent.futures.ThreadPoolExecutor.__name__.__eq__",                   ["ThreadPoolExecutor"],          true, "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_mod_eq,     "concurrent.futures.ThreadPoolExecutor.__module__.__eq__",                 ["concurrent.futures.thread"],   true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=26); verified with Python 3.14.3"]
    - [tpe_base0_eq,   "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__",      ["Executor"],                    true, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [tpe_mro_len,    "concurrent.futures.ThreadPoolExecutor.__mro__.__len__",                   [],                              3,    "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — [ThreadPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [tpe_qn_eq,      "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__",               ["ThreadPoolExecutor"],          true, "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (module-level class); verified with Python 3.14.3"]
    - [tpe_name_len,   "concurrent.futures.ThreadPoolExecutor.__name__.__len__",                  [],                              18,   "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 ('ThreadPoolExecutor'=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method qualnames — extra275
#
# concurrent.futures.ThreadPoolExecutor.submit.__qualname__    == 'ThreadPoolExecutor.submit'   (len=25, own method)
# concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__  == 'ThreadPoolExecutor.shutdown' (len=27, own method, longest)
# concurrent.futures.ThreadPoolExecutor.map.__qualname__       == 'Executor.map'                (len=12, inherited)
# concurrent.futures.ThreadPoolExecutor._work_queue (new instance) — type name == 'SimpleQueue', type module == '_queue'
# ---------------------------------------------------------------------------

table concurrent_futures_extra275.cf_thread_pool_executor_methods:
  description: "concurrent.futures.ThreadPoolExecutor method qualnames and _work_queue type checks in cfthread275a namespace — ThreadPoolExecutor.submit is an own method (defined in thread.py); submit.__qualname__.__eq__('ThreadPoolExecutor.submit')==True (len=25: 'ThreadPoolExecutor.'=19+'submit'=6); ThreadPoolExecutor.shutdown is also an own method; shutdown.__qualname__.__eq__('ThreadPoolExecutor.shutdown')==True (len=27: 'ThreadPoolExecutor.'=19+'shutdown'=8, longest method qualname in spec); ThreadPoolExecutor.map is inherited from Executor; map.__qualname__.__eq__('Executor.map')==True (len=12: 'Executor.'=9+'map'=3; qualname reflects defining class Executor, not ThreadPoolExecutor); submit.__qualname__.__len__()==25; shutdown.__qualname__.__len__()==27; map.__qualname__.__len__()==12; the _work_queue on a new ThreadPoolExecutor instance is a queue.SimpleQueue; its __class__.__name__ is 'SimpleQueue' and __class__.__module__ is '_queue' (the C extension backing queue.SimpleQueue); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfthread275a

  columns: [id, function, args, expected, description]
  rows:
    - [submit_qn_eq,    "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__",      ["ThreadPoolExecutor.submit"],    true, "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25, own method); verified with Python 3.14.3"]
    - [submit_qn_len,   "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__",     [],                               25,   "ThreadPoolExecutor.submit.__qualname__.__len__() == 25 ('ThreadPoolExecutor.'=19+'submit'=6); verified with Python 3.14.3"]
    - [shutdown_qn_eq,  "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__",    ["ThreadPoolExecutor.shutdown"],  true, "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27, longest in spec); verified with Python 3.14.3"]
    - [shutdown_qn_len, "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__",   [],                               27,   "ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 ('ThreadPoolExecutor.'=19+'shutdown'=8); verified with Python 3.14.3"]
    - [map_qn_eq,       "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__",         ["Executor.map"],                 true, "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12, inherited from Executor; qualname reflects defining class); verified with Python 3.14.3"]
    - [map_qn_len,      "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__",        [],                               12,   "ThreadPoolExecutor.map.__qualname__.__len__() == 12 ('Executor.'=9+'map'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra275
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra275.ThreadPoolExecutor_module_is_thread:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; its __module__ is 'concurrent.futures.thread' (len=26: 'concurrent.futures.'=19+'thread'=7); this differs from Future and Executor whose __module__ is 'concurrent.futures._base' (len=26 as well but with '_base' not 'thread'); ProcessPoolExecutor.__module__ is 'concurrent.futures.process'; the three submodules (_base, thread, process) organize the concurrent.futures package; ThreadPoolExecutor.__mro__.__len__() is 3 ([ThreadPoolExecutor, Executor, object]); Executor.__module__ is 'concurrent.futures._base'; NEW in extra275: first standalone ThreadPoolExecutor.__module__ invariant in cfthread275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__"
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra275.ThreadPoolExecutor_map_qualname_is_Executor_map:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — map() is defined on the Executor abstract base class and inherited by ThreadPoolExecutor without override; its qualname 'Executor.map' (len=12: 'Executor.'=9+'map'=3) reflects the defining class, not the accessing class; this parallels asyncio.Protocol.connection_made.__qualname__=='BaseProtocol.connection_made' (also inherited); contrast with submit and shutdown which are overridden in ThreadPoolExecutor (qualnames 'ThreadPoolExecutor.submit' and 'ThreadPoolExecutor.shutdown'); map.__qualname__.__len__() is 12, which is the shortest method qualname in this spec (vs submit=25, shutdown=27); NEW in extra275: first standalone ThreadPoolExecutor.map qualname invariant in cfthread275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__"
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra275.ThreadPoolExecutor_shutdown_qualname_len_27:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 — ThreadPoolExecutor.shutdown.__qualname__ is 'ThreadPoolExecutor.shutdown' (27 chars: 'ThreadPoolExecutor.'=19+'shutdown'=8); this is the longest method qualname in this spec; compare: map=12 (inherited, short), submit=25 (own), shutdown=27 (own, longest); shutdown() overrides Executor.shutdown() to cancel pending futures and release threads; ThreadPoolExecutor.shutdown is an own method (not inherited), so its qualname uses 'ThreadPoolExecutor.' prefix; NEW in extra275: first standalone ThreadPoolExecutor.shutdown qualname length invariant in cfthread275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__"
  args: []
  expected: 27

invariant concurrent_futures_extra275.ThreadPoolExecutor_base_is_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor inherits from Executor as its sole direct base; ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object] (length=3); Executor.__module__ is 'concurrent.futures._base' (different submodule from ThreadPoolExecutor's 'concurrent.futures.thread'); Executor defines the public interface: submit(), map(), and shutdown(); ThreadPoolExecutor overrides submit() and shutdown() while inheriting map() from Executor; ProcessPoolExecutor follows the same pattern: ProcessPoolExecutor.__bases__[0].__name__ is 'Executor' and ProcessPoolExecutor.__mro__.__len__() is 3; NEW in extra275: first standalone ThreadPoolExecutor base class invariant in cfthread275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra275.ThreadPoolExecutor_submit_qualname_len_25:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__() == 25 — ThreadPoolExecutor.submit.__qualname__ is 'ThreadPoolExecutor.submit' (25 chars: 'ThreadPoolExecutor.'=19+'submit'=6); submit() is an own method of ThreadPoolExecutor (not inherited from Executor); it accepts a callable and arguments and returns a Future; compare qualname lengths in this spec: map=12 (inherited Executor.map), submit=25 (own), shutdown=27 (own, longest); the 'ThreadPoolExecutor.' prefix (19 chars) is shared by both submit and shutdown; NEW in extra275: first standalone ThreadPoolExecutor.submit qualname length invariant in cfthread275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__"
  args: []
  expected: 25
