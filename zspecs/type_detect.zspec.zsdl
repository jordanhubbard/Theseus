spec: type_detect
version: ">=4.0.0"
backend: node(type-detect)

docs: https://www.npmjs.com/package/type-detect

provenance:
  derived_from:
    - "type-detect README — https://www.npmjs.com/package/type-detect"
    - "Test vectors verified with type-detect@4.0.8 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "type-detect source"
  notes:
    - "type-detect exports a function directly as module.exports."
    - "typeDetect(value) returns a string describing the type."
    - "More precise than typeof: distinguishes Array, Object, null, etc."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string type name."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table type_detect.type_detect:
  kind: node_module_call_eq
  function: ~
  category: type_detect
  id_prefix: tdet

  columns: [id, args, expected]
  rows:
    - [string,  ["hello"],     "string"]
    - [number,  [42],          "number"]
    - [bool,    [true],        "boolean"]
    - [array,   [[1, 2, 3]],   "Array"]
    - [object,  [{"a": 1}],    "Object"]
    - [null_v,  [null],        "null"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:58:54Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
