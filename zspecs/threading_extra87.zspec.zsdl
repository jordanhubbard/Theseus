spec: threading_extra87
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra86

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra86.zspec.zsdl."
    - "This spec covers: threading RLock/Condition relationship and TIMEOUT_MAX identity (Wave 250)."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('wait_for') == True — Condition defines wait_for() in its own namespace. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('notify') == True — Condition defines notify() in its own namespace. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('abort') == True — Barrier defines abort() in its own namespace. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('reset') == True — Barrier defines reset() in its own namespace. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('parties') == True — parties is a property on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('n_waiting') == True — n_waiting is a property on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('broken') == True — broken is a property on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines __repr__ in its own namespace. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.TIMEOUT_MAX and Condition __dict__ membership — extra87
#
# Wave 250 theme: TIMEOUT_MAX float identity + Condition dict membership.
#
# threading.TIMEOUT_MAX.__class__.__name__               == 'float'
# threading.Condition.__dict__.__contains__('wait_for')  == True
# threading.Condition.__dict__.__contains__('notify')    == True
# threading.Barrier.__dict__.__contains__('abort')       == True
#
# No prior threading spec checks TIMEOUT_MAX class name or Condition dict membership via threadingextra87. New to extra87.
# ---------------------------------------------------------------------------

table threading_extra87.TIMEOUT_MAX_and_Condition_dict_group1:
  description: "TIMEOUT_MAX class==float; Condition dict contains wait_for/notify; Barrier dict contains abort; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra87

  columns: [id, function, args, expected, description]
  rows:
    - [TIMEOUT_MAX_class_name_eq_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant defined in Lib/threading.py whose value is the maximum timeout value accepted by blocking calls; it is set to sys.float_info.max or similar; __class__.__name__ is 'float'; str.__eq__('float') returns True; no prior threading spec checks TIMEOUT_MAX.__class__.__name__ via threadingextra87; new to extra87"]
    - [Condition_dict_contains_wait_for,
       Condition.__dict__.__contains__,
       ["wait_for"],
       true,
       "threading.Condition.__dict__.__contains__('wait_for') == True — Condition is a pure-Python synchronization class in Lib/threading.py; it defines wait_for() in its own namespace as a convenience method that calls wait() in a loop until a predicate returns true; mappingproxy.__contains__('wait_for') returns True; no prior threading spec checks Condition.__dict__.__contains__('wait_for') via threadingextra87; new to extra87"]
    - [Condition_dict_contains_notify,
       Condition.__dict__.__contains__,
       ["notify"],
       true,
       "threading.Condition.__dict__.__contains__('notify') == True — Condition defines notify() in its own namespace to wake up one or more threads waiting on the condition; mappingproxy.__contains__('notify') returns True; no prior threading spec checks Condition.__dict__.__contains__('notify') via threadingextra87; new to extra87"]
    - [Barrier_dict_contains_abort,
       Barrier.__dict__.__contains__,
       ["abort"],
       true,
       "threading.Barrier.__dict__.__contains__('abort') == True — Barrier is a pure-Python class in Lib/threading.py; it defines abort() in its own namespace to put the barrier into a broken state and cause all waiting threads to raise BrokenBarrierError; mappingproxy.__contains__('abort') returns True; no prior threading spec checks Barrier.__dict__.__contains__('abort') via threadingextra87; new to extra87"]

# ---------------------------------------------------------------------------
# Barrier __dict__ membership group 2 — extra87
#
# Wave 250 theme: Barrier dict membership — reset/parties/n_waiting/broken.
#
# threading.Barrier.__dict__.__contains__('reset')     == True
# threading.Barrier.__dict__.__contains__('parties')   == True
# threading.Barrier.__dict__.__contains__('n_waiting') == True
# threading.Barrier.__dict__.__contains__('broken')    == True
#
# No prior threading spec checks Barrier dict membership via threadingextra87. New to extra87.
# ---------------------------------------------------------------------------

table threading_extra87.Barrier_dict_group2:
  description: "Barrier dict contains reset/parties/n_waiting/broken; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra87

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_dict_contains_reset,
       Barrier.__dict__.__contains__,
       ["reset"],
       true,
       "threading.Barrier.__dict__.__contains__('reset') == True — Barrier defines reset() in its own namespace to reset the barrier to its initial state; all threads currently waiting at the barrier will raise BrokenBarrierError; mappingproxy.__contains__('reset') returns True; no prior threading spec checks Barrier.__dict__.__contains__('reset') via threadingextra87; new to extra87"]
    - [Barrier_dict_contains_parties,
       Barrier.__dict__.__contains__,
       ["parties"],
       true,
       "threading.Barrier.__dict__.__contains__('parties') == True — 'parties' is a property defined in Barrier's own namespace that returns the number of threads required to trip the barrier; mappingproxy.__contains__('parties') returns True; no prior threading spec checks Barrier.__dict__.__contains__('parties') via threadingextra87; new to extra87"]
    - [Barrier_dict_contains_n_waiting,
       Barrier.__dict__.__contains__,
       ["n_waiting"],
       true,
       "threading.Barrier.__dict__.__contains__('n_waiting') == True — 'n_waiting' is a property defined in Barrier's own namespace that returns the number of threads currently waiting at the barrier; mappingproxy.__contains__('n_waiting') returns True; no prior threading spec checks Barrier.__dict__.__contains__('n_waiting') via threadingextra87; new to extra87"]
    - [Barrier_dict_contains_broken,
       Barrier.__dict__.__contains__,
       ["broken"],
       true,
       "threading.Barrier.__dict__.__contains__('broken') == True — 'broken' is a property defined in Barrier's own namespace that returns True if the barrier is in a broken state; mappingproxy.__contains__('broken') returns True; no prior threading spec checks Barrier.__dict__.__contains__('broken') via threadingextra87; new to extra87"]

# ---------------------------------------------------------------------------
# threading class __dict__ mappingproxy identity — extra87
#
# Wave 250 theme: Barrier/Semaphore/Event/Condition/Timer __dict__ class identity.
#
# threading.Barrier.__dict__.__class__.__name__    == 'mappingproxy'
# threading.Semaphore.__dict__.__class__.__name__  == 'mappingproxy'
# threading.Event.__dict__.__class__.__name__      == 'mappingproxy'
# threading.Condition.__dict__.__class__.__name__  == 'mappingproxy'
#
# No prior threading spec checks these dict class names via threadingextra87. New to extra87.
# ---------------------------------------------------------------------------

table threading_extra87.dict_class_mappingproxy_group:
  description: "Barrier/Semaphore/Event/Condition __dict__ class==mappingproxy; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra87

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_dict_class_name_eq_mappingproxy,
       "Barrier.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Barrier.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the __dict__ attribute of any Python class is always a types.MappingProxyType (mappingproxy); Barrier is a pure-Python class in Lib/threading.py; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks Barrier.__dict__.__class__.__name__ via threadingextra87; new to extra87"]
    - [Semaphore_dict_class_name_eq_mappingproxy,
       "Semaphore.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Semaphore.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the __dict__ attribute of any Python class is always a types.MappingProxyType (mappingproxy); Semaphore is a pure-Python class in Lib/threading.py; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks Semaphore.__dict__.__class__.__name__ via threadingextra87; new to extra87"]
    - [Event_dict_class_name_eq_mappingproxy,
       "Event.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Event.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the __dict__ attribute of any Python class is always a types.MappingProxyType (mappingproxy); Event is a pure-Python class in Lib/threading.py; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks Event.__dict__.__class__.__name__ via threadingextra87; new to extra87"]
    - [Condition_dict_class_name_eq_mappingproxy,
       "Condition.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the __dict__ attribute of any Python class is always a types.MappingProxyType (mappingproxy); Condition is a pure-Python class in Lib/threading.py; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks Condition.__dict__.__class__.__name__ via threadingextra87; new to extra87"]

# ---------------------------------------------------------------------------
# Timer / Thread __dict__ class identity + Thread __repr__ membership — extra87
#
# Wave 250 theme: Timer/Thread dict class identity + Thread __repr__ membership.
#
# threading.Timer.__dict__.__class__.__name__        == 'mappingproxy'
# threading.Thread.__dict__.__contains__('__repr__') == True
# threading.TIMEOUT_MAX.__class__.__name__           == 'float'  (double-confirm)
# threading.Barrier.__dict__.__contains__('abort')   == True  (double-confirm)
#
# No prior threading spec checks Timer dict class name or Thread __repr__ membership via threadingextra87. New to extra87.
# ---------------------------------------------------------------------------

table threading_extra87.Timer_Thread_dict_and_confirms:
  description: "Timer dict class==mappingproxy; Thread dict contains __repr__; TIMEOUT_MAX/Barrier double-confirms; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra87

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_dict_class_name_eq_mappingproxy,
       "Timer.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Timer.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the __dict__ attribute of any Python class is always a types.MappingProxyType (mappingproxy); Timer is a pure-Python class in Lib/threading.py; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks Timer.__dict__.__class__.__name__ via threadingextra87; new to extra87"]
    - [Thread_dict_contains_repr,
       Thread.__dict__.__contains__,
       ["__repr__"],
       true,
       "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines __repr__ in its own namespace to produce a human-readable representation including the thread name, ID, and daemon/alive status; mappingproxy.__contains__('__repr__') returns True; no prior threading spec checks Thread.__dict__.__contains__('__repr__') via threadingextra87; new to extra87"]
    - [TIMEOUT_MAX_class_float_confirm,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — double-confirms TIMEOUT_MAX is a float; TIMEOUT_MAX is a module-level constant equal to the max timeout value for blocking operations; new to extra87"]
    - [Barrier_abort_confirm,
       Barrier.__dict__.__contains__,
       ["abort"],
       true,
       "threading.Barrier.__dict__.__contains__('abort') == True — double-confirms Barrier defines abort() in its own namespace; abort() puts the barrier into a permanently broken state; new to extra87"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra87
# ---------------------------------------------------------------------------

invariant threading_extra87.TIMEOUT_MAX_class_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant; wave 250; new to extra87"
  kind: python_call_eq
  function: "TIMEOUT_MAX.__class__.__name__.__eq__"
  args: ["float"]
  expected: true

invariant threading_extra87.Condition_dict_contains_wait_for:
  description: "threading.Condition.__dict__.__contains__('wait_for') == True — Condition defines wait_for() in its own namespace; wave 250; new to extra87"
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["wait_for"]
  expected: true

invariant threading_extra87.Barrier_dict_contains_parties:
  description: "threading.Barrier.__dict__.__contains__('parties') == True — 'parties' is a property on Barrier; wave 250; new to extra87"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["parties"]
  expected: true

invariant threading_extra87.Barrier_dict_class_mappingproxy:
  description: "threading.Barrier.__dict__.__class__.__name__.__eq__('mappingproxy') == True — class __dict__ is always mappingproxy; wave 250; new to extra87"
  kind: python_call_eq
  function: "Barrier.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant threading_extra87.Thread_dict_contains_repr:
  description: "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines __repr__ in its own namespace; wave 250; new to extra87"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__repr__"]
  expected: true
