spec: abc_extra2371
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "All expected values verified interactively with Python 3.14.4 on macOS/Darwin 25.4.0."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC is an instance of ABCMeta (its metaclass), not of type."
    - "abc.ABCMeta.__class__.__name__ == 'type' — ABCMeta is itself a class whose metaclass is the built-in type."
    - "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is implemented as a plain Python function in CPython 3.x (verified: isinstance(abc.abstractmethod, type) is False)."
    - "abc.abstractclassmethod, abstractstaticmethod, abstractproperty are deprecated decorator classes — __class__.__name__ == 'type'."
    - "abc.get_cache_token is a C-level builtin implemented in _abc — __class__.__name__ == 'builtin_function_or_method'."
    - "abc.update_abstractmethods is a plain Python function — __class__.__name__ == 'function'."
    - "The pattern function: Name.__class__.__name__.__eq__ with args: ['expected'] and expected: true is the canonical ZSDL idiom for attribute equality checks."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level objects: __class__.__name__ checks
# All in one table per the theme of this spec.
# ---------------------------------------------------------------------------

table abc_extra2371.object_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["ab2371001", "ABC.__class__.__name__.__eq__",                ["ABCMeta"],                  true]
    - ["ab2371002", "ABCMeta.__class__.__name__.__eq__",            ["type"],                     true]
    - ["ab2371003", "abstractmethod.__class__.__name__.__eq__",     ["function"],                 true]
    - ["ab2371004", "get_cache_token.__class__.__name__.__eq__",    ["builtin_function_or_method"], true]
    - ["ab2371005", "abstractclassmethod.__class__.__name__.__eq__", ["type"],                    true]
    - ["ab2371006", "abstractstaticmethod.__class__.__name__.__eq__", ["type"],                   true]
    - ["ab2371007", "abstractproperty.__class__.__name__.__eq__",   ["type"],                     true]
    - ["ab2371008", "update_abstractmethods.__class__.__name__.__eq__", ["function"],             true]

# ---------------------------------------------------------------------------
# Cross-checks: __name__ attribute values for classes
# ---------------------------------------------------------------------------

table abc_extra2371.class_names:
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - ["ab2371009", "ABCMeta.__name__.__eq__",             ["ABCMeta"],             true]
    - ["ab2371010", "abstractclassmethod.__name__.__eq__", ["abstractclassmethod"], true]
    - ["ab2371011", "abstractstaticmethod.__name__.__eq__", ["abstractstaticmethod"], true]
    - ["ab2371012", "abstractproperty.__name__.__eq__",    ["abstractproperty"],    true]

# ---------------------------------------------------------------------------
# Cross-checks: __name__ attribute values for callables
# ---------------------------------------------------------------------------

table abc_extra2371.callable_names:
  kind: python_call_eq
  category: callable_names

  columns: [id, function, args, expected]
  rows:
    - ["ab2371013", "abstractmethod.__name__.__eq__",      ["abstractmethod"],      true]
    - ["ab2371014", "get_cache_token.__name__.__eq__",     ["get_cache_token"],     true]
    - ["ab2371015", "update_abstractmethods.__name__.__eq__", ["update_abstractmethods"], true]

# ---------------------------------------------------------------------------
# ABC metaclass identity: type(ABC) is ABCMeta
# ---------------------------------------------------------------------------

table abc_extra2371.metaclass_checks:
  kind: python_call_eq
  category: metaclass

  columns: [id, function, args, expected]
  rows:
    - ["ab2371016", "ABC.__class__.__name__.__eq__",       ["ABCMeta"], true]
    - ["ab2371017", "ABC.__class__.__class__.__name__.__eq__", ["type"], true]
    - ["ab2371018", "ABCMeta.__class__.__name__.__eq__",   ["type"],    true]

# ---------------------------------------------------------------------------
# Module membership: key names are present in abc.__dict__
# ---------------------------------------------------------------------------

table abc_extra2371.module_members:
  kind: python_call_eq
  category: module_members

  columns: [id, function, args, expected]
  rows:
    - ["ab2371019", "ABC.__module__.__eq__",               ["abc"],     true]
    - ["ab2371020", "ABCMeta.__module__.__eq__",           ["abc"],     true]
    - ["ab2371021", "abstractmethod.__module__.__eq__",    ["abc"],     true]
    - ["ab2371022", "update_abstractmethods.__module__.__eq__", ["abc"], true]
