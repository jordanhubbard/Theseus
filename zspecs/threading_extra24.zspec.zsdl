spec: threading_extra24
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and prior extras through threading_extra23.zspec.zsdl."
    - "threading_extra19 covers: Thread/Event/Condition/Semaphore/Timer/Barrier __qualname__ in a table; Lock/__qualname__=='lock'; RLock/__qualname__=='RLock'."
    - "threading_extra23 covers: class __qualname__ length table; BoundedSemaphore/local/Lock/RLock standalone qualname invariants."
    - "NOT yet covered in any prior spec: Thread instance method __qualname__ table (start/run/join/is_alive) in extra24 namespace."
    - "NOT yet covered: Event instance method __qualname__ table (set/clear/wait/is_set) in extra24 namespace."
    - "NOT yet covered: Thread.daemon property fget/__qualname__ == 'Thread.daemon' as standalone invariant."
    - "Thread.start.__qualname__ == 'Thread.start' — method defined directly on Thread class."
    - "Thread.run.__qualname__ == 'Thread.run' — method defined directly on Thread class."
    - "Thread.join.__qualname__ == 'Thread.join' — method defined directly on Thread class."
    - "Thread.is_alive.__qualname__ == 'Thread.is_alive' — method defined directly on Thread class."
    - "Event.set.__qualname__ == 'Event.set' — method defined directly on Event class."
    - "Event.clear.__qualname__ == 'Event.clear' — method defined directly on Event class."
    - "Event.wait.__qualname__ == 'Event.wait' — method defined directly on Event class."
    - "Event.is_set.__qualname__ == 'Event.is_set' — method defined directly on Event class."
    - "Thread.daemon is a property; its fget.__qualname__ == 'Thread.daemon'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread method __qualname__ table — extra24 namespace
#
# threading_extra19 checks Thread's class-level __qualname__ == 'Thread'.
# No prior spec provides a table of Thread *instance method* __qualname__
# values. Each method __qualname__ follows the pattern 'Thread.<method>'.
# Lengths: Thread.start(12), Thread.run(10), Thread.join(11),
#          Thread.is_alive(15).
# ---------------------------------------------------------------------------

table threading_extra24.thread_method_qualnames:
  description: "threading.Thread method __qualname__ values in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: thmqn24

  columns: [id, function, args, expected]
  rows:
    - [start,    Thread.start.__qualname__.__eq__,    ["Thread.start"],    true]
    - [run,      Thread.run.__qualname__.__eq__,      ["Thread.run"],      true]
    - [join,     Thread.join.__qualname__.__eq__,     ["Thread.join"],     true]
    - [is_alive, Thread.is_alive.__qualname__.__eq__, ["Thread.is_alive"], true]

# ---------------------------------------------------------------------------
# Thread method __qualname__ length table — extra24 namespace
#
# Lengths: Thread.start(12), Thread.run(10), Thread.join(11),
#          Thread.is_alive(15).
# ---------------------------------------------------------------------------

table threading_extra24.thread_method_qualname_lengths:
  description: "threading.Thread method __qualname__ lengths in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: thmqnlen24

  columns: [id, function, args, expected]
  rows:
    - [start,    Thread.start.__qualname__.__len__,    [], 12]
    - [run,      Thread.run.__qualname__.__len__,      [], 10]
    - [join,     Thread.join.__qualname__.__len__,     [], 11]
    - [is_alive, Thread.is_alive.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Event method __qualname__ table — extra24 namespace
#
# No prior spec provides a table of Event *instance method* __qualname__
# values. Each method __qualname__ follows the pattern 'Event.<method>'.
# Lengths: Event.set(9), Event.clear(11), Event.wait(10), Event.is_set(12).
# ---------------------------------------------------------------------------

table threading_extra24.event_method_qualnames:
  description: "threading.Event method __qualname__ values in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: evmqn24

  columns: [id, function, args, expected]
  rows:
    - [set,    Event.set.__qualname__.__eq__,    ["Event.set"],    true]
    - [clear,  Event.clear.__qualname__.__eq__,  ["Event.clear"],  true]
    - [wait,   Event.wait.__qualname__.__eq__,   ["Event.wait"],   true]
    - [is_set, Event.is_set.__qualname__.__eq__, ["Event.is_set"], true]

# ---------------------------------------------------------------------------
# Event method __qualname__ length table — extra24 namespace
#
# Lengths: Event.set(9), Event.clear(11), Event.wait(10), Event.is_set(12).
# ---------------------------------------------------------------------------

table threading_extra24.event_method_qualname_lengths:
  description: "threading.Event method __qualname__ lengths in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: evmqnlen24

  columns: [id, function, args, expected]
  rows:
    - [set,    Event.set.__qualname__.__len__,    [], 9]
    - [clear,  Event.clear.__qualname__.__len__,  [], 11]
    - [wait,   Event.wait.__qualname__.__len__,   [], 10]
    - [is_set, Event.is_set.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Thread.daemon property fget.__qualname__ — standalone extra24 invariant
#
# threading.Thread.daemon is a property. Its getter function's __qualname__
# is 'Thread.daemon', confirming the property belongs to Thread and has the
# expected nesting path. No prior spec checks the daemon fget qualname.
# ---------------------------------------------------------------------------

invariant threading_extra24.Thread.daemon.fget_qualname_eq:
  description: "threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' — property getter qualname"
  category: method_names
  kind: python_call_eq
  function: Thread.daemon.fget.__qualname__.__eq__
  args: ["Thread.daemon"]
  expected: true
