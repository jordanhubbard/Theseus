spec: pathlib_extra245
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra244.zspec.zsdl — covers Path.stat, chmod, exists, glob method identity"
  notes:
    - "This spec covers: pathlib.Path property identity contracts — name, stem, suffix, parent fget function names."
    - "pathlib.Path.name is a property descriptor; __class__.__name__ == 'property'; verified Python 3.14.3 macOS."
    - "pathlib.Path.name.fget.__name__ == 'name' — the fget function name for the 'name' property; length 4; verified Python 3.14.3 macOS."
    - "pathlib.Path.name.fget.__qualname__ == 'PurePath.name' — fget is defined on PurePath; length 13; verified Python 3.14.3 macOS."
    - "pathlib.Path.stem.fget.__name__ == 'stem' — the fget function name for the 'stem' property; length 4; verified Python 3.14.3 macOS."
    - "pathlib.Path.stem.fget.__qualname__ == 'PurePath.stem' — fget is defined on PurePath; length 13; verified Python 3.14.3 macOS."
    - "pathlib.Path.suffix.fget.__name__ == 'suffix' — the fget function name for the 'suffix' property; length 6; verified Python 3.14.3 macOS."
    - "pathlib.Path.suffix.fget.__qualname__ == 'PurePath.suffix' — fget is defined on PurePath; length 15; verified Python 3.14.3 macOS."
    - "pathlib.Path.parent.fget.__name__ == 'parent' — the fget function name for the 'parent' property; length 6; verified Python 3.14.3 macOS."
    - "pathlib.Path.parent.fget.__qualname__ == 'PurePath.parent' — fget is defined on PurePath; length 15; verified Python 3.14.3 macOS."
    - "All four properties are inherited from PurePath; fget qualnames carry the 'PurePath.' prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path property class identity
# Path.name is a descriptor of type 'property'; its __class__.__name__ == 'property'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra245.Path.name_prop.class_eq:
  description: "pathlib.Path.name.__class__.__name__ == 'property' — name is a property descriptor; verified Python 3.14.3 macOS"
  category: property_identity
  kind: python_call_eq
  function: Path.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path.name property fget identity contracts
# Path.name.fget is the getter function inherited from PurePath.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra245.Path.name_prop.fget_name_eq:
  description: "pathlib.Path.name.fget.__name__ == 'name' — fget function name is 'name'; verified Python 3.14.3 macOS"
  category: property_identity
  kind: python_call_eq
  function: Path.name.fget.__name__.__eq__
  args: ["name"]
  expected: true

invariant pathlib_extra245.Path.name_prop.fget_name_len:
  description: "len(pathlib.Path.name.fget.__name__) == 4 — 'name' has 4 characters; verified Python 3.14.3 macOS"
  category: property_identity
  kind: python_call_eq
  function: Path.name.fget.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra245.Path.name_prop.fget_qualname_eq:
  description: "pathlib.Path.name.fget.__qualname__ == 'PurePath.name' — fget qualname shows PurePath origin; verified Python 3.14.3 macOS"
  category: property_identity
  kind: python_call_eq
  function: Path.name.fget.__qualname__.__eq__
  args: ["PurePath.name"]
  expected: true

invariant pathlib_extra245.Path.name_prop.fget_qualname_len:
  description: "len(pathlib.Path.name.fget.__qualname__) == 13 — 'PurePath.name' has 13 characters; verified Python 3.14.3 macOS"
  category: property_identity
  kind: python_call_eq
  function: Path.name.fget.__qualname__.__len__
  args: []
  expected: 13

