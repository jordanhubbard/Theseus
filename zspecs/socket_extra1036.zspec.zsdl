spec: socket_extra1036
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module socket class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket property descriptor class names, method qualnames, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1036.socket_property_class_names:
  description: "socket.socket property descriptor __class__.__name__ identity"
  kind: python_call_eq
  category: property_class_names
  id_prefix: sk1036p
  columns: [id, function, args, expected]
  rows:
    - [sk1036p001, socket.socket.family.__class__.__name__.__eq__,   ["property"], true]
    - [sk1036p002, socket.socket.type.__class__.__name__.__eq__,     ["property"], true]
    - [sk1036p003, socket.socket.proto.__class__.__name__.__eq__,    ["property"], true]
    - [sk1036p004, socket.socket.timeout.__class__.__name__.__eq__,  ["property"], true]
    - [sk1036p005, socket.socket.fileno.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [sk1036p006, socket.socket.getsockname.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [sk1036p007, socket.socket.getsockopt.__class__.__name__.__eq__, ["method_descriptor"], true]

table socket_extra1036.socket_method_reduce_qualnames:
  description: "socket.socket method __reduce__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_qualnames
  id_prefix: sk1036r
  columns: [id, function, args, expected]
  rows:
    - [sk1036r001, socket.socket.__reduce__.__qualname__.__eq__,       ["socket.__reduce__"],       true]
    - [sk1036r002, socket.socket.__init__.__qualname__.__eq__,         ["socket.__init__"],         true]
    - [sk1036r003, socket.socket.__repr__.__qualname__.__eq__,         ["socket.__repr__"],         true]
    - [sk1036r004, socket.socket.__enter__.__qualname__.__eq__,        ["socket.__enter__"],        true]
    - [sk1036r005, socket.socket.__exit__.__qualname__.__eq__,         ["socket.__exit__"],         true]
    - [sk1036r006, socket.socket.bind.__qualname__.__eq__,             ["socket.bind"],             true]
    - [sk1036r007, socket.socket.connect.__qualname__.__eq__,          ["socket.connect"],          true]
    - [sk1036r008, socket.socket.close.__qualname__.__eq__,            ["socket.close"],            true]

table socket_extra1036.module_doc_class_identity:
  description: "socket module __doc__ class identity and module-level attribute checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: sk1036m
  columns: [id, function, args, expected]
  rows:
    - [sk1036m001, socket.__doc__.__class__.__name__.__eq__,           ["str"],    true]
    - [sk1036m002, socket.__name__.__eq__,                             ["socket"], true]
    - [sk1036m003, socket.socket.__class__.__name__.__eq__,            ["type"],   true]
    - [sk1036m004, socket.socket.__module__.__eq__,                    ["socket"], true]
    - [sk1036m005, socket.socket.__doc__.__class__.__name__.__eq__,    ["str"],    true]
