spec: arrow_time_rust
version: ">=3.9"
backend: rust_module(arrow_time_rust)

docs: https://arrow.readthedocs.io/

provenance:
  derived_from:
    - "https://arrow.readthedocs.io/ — Arrow library documentation"
  not_derived_from:
    - "arrow source: arrow/arrow.py"
  notes:
    - "arrow is a Python library for creating, manipulating, formatting, and converting dates and times."
    - "arrow.get('2023-01-15') returns an Arrow object."
    - "Expose arrow_year(s) -> int: arrow.get(s).year."
    - "Expose arrow_month(s) -> int: arrow.get(s).month."
    - "Expose arrow_day(s) -> int: arrow.get(s).day."
    - "Expose arrow_format(s, fmt) -> str: arrow.get(s).format(fmt)."
    - "Expose arrow_weekday(s) -> int: arrow.get(s).weekday() — 0=Monday, 6=Sunday."
    - "arrow.get('2023-01-15').year == 2023, month == 1, day == 15."
    - "arrow.get('2023-01-15').format('YYYY-MM-DD') == '2023-01-15'."
    - "arrow.get('2023-01-15').weekday() == 6 (Sunday)."
    - "All test vectors verified against arrow 1.3.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# arrow_year — extract year from ISO date string
table arrow_time_rust.year.vectors:
  kind: python_call_eq
  category: year
  id_prefix: at_yr
  function: arrow_year

  columns: [id, args, expected]
  rows:
    - [y2023, ["2023-01-15"], 2023]
    - [y2000, ["2000-06-30"], 2000]
    - [y1999, ["1999-12-31"], 1999]

# arrow_month — extract month from ISO date string
table arrow_time_rust.month.vectors:
  kind: python_call_eq
  category: month
  id_prefix: at_mo
  function: arrow_month

  columns: [id, args, expected]
  rows:
    - [jan, ["2023-01-15"], 1]
    - [jun, ["2000-06-30"], 6]
    - [dec, ["1999-12-31"], 12]

# arrow_day — extract day from ISO date string
table arrow_time_rust.day.vectors:
  kind: python_call_eq
  category: day
  id_prefix: at_dy
  function: arrow_day

  columns: [id, args, expected]
  rows:
    - [d15, ["2023-01-15"], 15]
    - [d30, ["2000-06-30"], 30]
    - [d31, ["1999-12-31"], 31]

# arrow_format — format using arrow format strings
table arrow_time_rust.format.vectors:
  kind: python_call_eq
  category: format
  id_prefix: at_fmt
  function: arrow_format

  columns: [id, args, expected]
  rows:
    - [iso_date,  ["2023-01-15", "YYYY-MM-DD"], "2023-01-15"]
    - [us_format, ["2023-01-15", "MM/DD/YYYY"], "01/15/2023"]
    - [year_only, ["2023-01-15", "YYYY"],        "2023"]

# arrow_weekday — day of week (0=Monday, 6=Sunday)
invariant arrow_time_rust.weekday.sunday:
  description: "2023-01-15 is Sunday (weekday==6)"
  category: weekday
  kind: python_call_eq
  function: arrow_weekday
  args: ["2023-01-15"]
  expected: 6

invariant arrow_time_rust.weekday.monday:
  description: "2023-01-16 is Monday (weekday==0)"
  category: weekday
  kind: python_call_eq
  function: arrow_weekday
  args: ["2023-01-16"]
  expected: 0

