spec: io_extra161
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.StringIO and io.BytesIO class identity and base class names; io.FileIO, io.BufferedReader, and io.TextIOWrapper __module__ values."
    - "A critical discovery: io.StringIO.__module__ == '_io' (NOT 'io'). StringIO, BytesIO, FileIO, BufferedReader, and TextIOWrapper are all concrete classes implemented in the _io C extension, so their __module__ is '_io'. This contrasts with the public ABC wrappers (IOBase, RawIOBase, BufferedIOBase, TextIOBase) whose __module__ is 'io'."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO inherits directly from the private C ABC _TextIOBase, NOT from the public Python wrapper io.TextIOBase. This follows the same two-layer pattern established in io_extra159."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits from the private C ABC _BufferedIOBase. io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits from _RawIOBase."
    - "io.StringIO.__name__ == 'StringIO', io.BytesIO.__name__ == 'BytesIO', io.FileIO.__name__ == 'FileIO' — all concrete class names match their public names exactly."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO and io.BytesIO class identity: __name__ and __module__
# StringIO.__name__ == 'StringIO', StringIO.__module__ == '_io'
# BytesIO.__name__ == 'BytesIO', BytesIO.__module__ == '_io'
# Both are concrete C extension classes with __module__ == '_io', NOT 'io'.
# Contrast with public ABC wrappers (IOBase, RawIOBase, etc.) where __module__=='io'.
# ---------------------------------------------------------------------------

table io_extra161.StringIO_BytesIO_identity:
  description: "io.StringIO and io.BytesIO class identity: __name__ and __module__; both are C extension classes with __module__=='_io' (NOT 'io'), contrasting with public ABC wrappers"
  kind: python_call_eq
  category: identity
  id_prefix: ioconcid161

  columns: [id, function, args, expected, description]
  rows:
    - [sio_name_eq,    StringIO.__name__.__eq__,    ["StringIO"], true, "io.StringIO.__name__ == 'StringIO' (the in-memory text stream class; StringIO reads and writes a string buffer; it is the text-mode analog of BytesIO; __name__ equals the bare class name 'StringIO' without any module prefix)"]
    - [sio_module_eq,  StringIO.__module__.__eq__,  ["_io"],      true, "io.StringIO.__module__ == '_io' (StringIO is a C extension class implemented in _io, NOT a public Python ABC; its __module__ is '_io' — the private C extension — unlike the public ABC wrappers (IOBase, RawIOBase, TextIOBase) whose __module__ is 'io'; StringIO is exposed as io.StringIO via Lib/io.py)"]
    - [bio_name_eq,    BytesIO.__name__.__eq__,     ["BytesIO"],  true, "io.BytesIO.__name__ == 'BytesIO' (the in-memory binary stream class; BytesIO reads and writes a bytes buffer; it is the binary analog of StringIO; __name__ is the bare class name 'BytesIO' without module prefix)"]
    - [bio_module_eq,  BytesIO.__module__.__eq__,   ["_io"],      true, "io.BytesIO.__module__ == '_io' (BytesIO is implemented in the _io C extension, so its __module__ is '_io'; this is the same as StringIO, FileIO, BufferedReader, and TextIOWrapper — all concrete io classes have __module__=='_io' while only the public ABC wrappers have __module__=='io')"]
    - [fio_name_eq,    FileIO.__name__.__eq__,      ["FileIO"],   true, "io.FileIO.__name__ == 'FileIO' (the raw binary file stream class; FileIO wraps OS-level file descriptors and provides unbuffered read/write/seek; it is the primary concrete implementation of RawIOBase; __name__ is 'FileIO' matching the class name exactly)"]
    - [fio_module_eq,  FileIO.__module__.__eq__,    ["_io"],      true, "io.FileIO.__module__ == '_io' (FileIO is a C extension class with __module__=='_io'; this consistent pattern — all five concrete io classes (StringIO, BytesIO, FileIO, BufferedReader, TextIOWrapper) have __module__=='_io' while all four public ABC wrappers have __module__=='io' — reveals the two-layer io architecture)"]

# ---------------------------------------------------------------------------
# io concrete class base class names: what do StringIO, BytesIO, FileIO inherit from?
# StringIO.__bases__[0].__name__ == '_TextIOBase' (private C ABC)
# BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (private C ABC)
# FileIO.__bases__[0].__name__ == '_RawIOBase' (private C ABC, confirmed in io_extra159)
# All three inherit from private C ABCs (with underscore prefix), NOT public wrappers.
# ---------------------------------------------------------------------------

table io_extra161.concrete_class_base_names:
  description: "io concrete class __bases__[0].__name__ values: StringIO inherits from '_TextIOBase', BytesIO from '_BufferedIOBase', FileIO from '_RawIOBase'; all private C ABCs with underscore prefix"
  kind: python_call_eq
  category: identity
  id_prefix: ioconcid161

  columns: [id, function, args, expected, description]
  rows:
    - [sio_base_eq,    "StringIO.__bases__[0].__name__.__eq__",         ["_TextIOBase"],      true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (StringIO's direct base class is the private C ABC _TextIOBase, NOT the public Python wrapper io.TextIOBase; the public wrapper io.TextIOBase itself wraps _TextIOBase; this follows the same pattern as FileIO/_RawIOBase and BufferedReader/_BufferedIOBase established in io_extra159)"]
    - [bio_base_eq,    "BytesIO.__bases__[0].__name__.__eq__",          ["_BufferedIOBase"],  true, "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (BytesIO inherits directly from the private C ABC _BufferedIOBase, not the public wrapper io.BufferedIOBase; BytesIO is an in-memory buffer that satisfies the BufferedIOBase interface but is implemented directly in C, bypassing the public Python ABC wrapper layer)"]
    - [fio_base_eq,    "FileIO.__bases__[0].__name__.__eq__",           ["_RawIOBase"],       true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (FileIO inherits from the private C ABC _RawIOBase; this was established in io_extra159; repeated here to complete the picture: all three primary concrete stream classes (StringIO, BytesIO, FileIO) inherit private C ABCs, not the public Python wrapper ABCs)"]
    - [bufrd_module_eq, BufferedReader.__module__.__eq__,                ["_io"],              true, "io.BufferedReader.__module__ == '_io' (BufferedReader is a C extension class; its __module__ is '_io'; it wraps a RawIOBase object and provides buffered reading; along with StringIO, BytesIO, FileIO, and TextIOWrapper, it completes the set of five concrete io classes all having __module__=='_io')"]
    - [twr_module_eq,   TextIOWrapper.__module__.__eq__,                 ["_io"],              true, "io.TextIOWrapper.__module__ == '_io' (TextIOWrapper is a C extension class wrapping a binary stream with text encoding/decoding; its __module__ is '_io'; TextIOWrapper is what you get when you call open() in text mode — it wraps a BufferedReader or BufferedWriter with a codec)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra161.StringIO_module_is_private_io:
  description: "io.StringIO.__module__ == '_io' — StringIO's __module__ is the private C extension '_io', NOT the public module 'io'; this is a critical distinction from the ABC wrappers (IOBase, RawIOBase, BufferedIOBase, TextIOBase) which all have __module__=='io'; StringIO is exposed publicly via io.StringIO through Lib/io.py's import but its actual __module__ attribute records '_io' where it was defined; this means type(io.StringIO()).__module__ == '_io'"
  category: identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra161.BytesIO_base_is_private_BufferedIOBase:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO's direct base class is the private C ABC _BufferedIOBase; this continues the pattern established in io_extra159 where FileIO inherits from _RawIOBase and BufferedReader inherits from _BufferedIOBase; all concrete io classes skip the public Python ABC wrappers and inherit directly from the private C ABCs; the public Python wrappers (io.BufferedIOBase) are parallel to the C ABCs, not in the inheritance chain of concrete classes"
  category: identity
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra161.StringIO_base_is_private_TextIOBase:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO's direct base class is the private C ABC _TextIOBase; StringIO is the in-memory text stream and TextIOWrapper is the file-based text stream — both inherit from _TextIOBase; neither inherits from the public Python wrapper io.TextIOBase; this completes the three-way pattern: StringIO->_TextIOBase, BytesIO->_BufferedIOBase, FileIO->_RawIOBase"
  category: identity
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra161.FileIO_name_eq:
  description: "io.FileIO.__name__ == 'FileIO' — FileIO's __name__ is the bare class name 'FileIO'; combined with __module__ == '_io' and __bases__[0].__name__ == '_RawIOBase' (from io_extra159), FileIO's full identity shows it is a private C extension class that directly implements raw binary file I/O without going through the public Python ABC wrapper layer; 'FileIO' has 6 characters"
  category: identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra161.TextIOWrapper_module_is_private_io:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is the concrete text stream class that wraps a buffered binary stream with a codec for encoding/decoding; its __module__ is '_io' like all other concrete io classes; TextIOWrapper is returned by open() in text mode and is the most commonly used io class in practice; its __module__ == '_io' while the abstract io.TextIOBase wrapper has __module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true
