spec: multiprocessing_extra1516
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ in class __dict__."
    - "multiprocessing is an OS-process concurrency module — not a numeric library. Neither Process nor pool.Pool define any arithmetic operator protocol methods in their own __dict__."
    - "multiprocessing.Process is a class for spawning OS child processes — start(), join(), terminate(), kill() are its interface; arithmetic on a process handle is undefined."
    - "multiprocessing.pool.Pool manages a pool of worker processes — apply(), map(), starmap(), imap() are its interface; arithmetic on a pool object is undefined."
    - "Neither Process nor Pool has __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, or __pow__ in their __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process arithmetic operator __dict__ absence
#
# multiprocessing.Process.__dict__.__contains__('__add__')      == False
# multiprocessing.Process.__dict__.__contains__('__mul__')      == False
# multiprocessing.Process.__dict__.__contains__('__sub__')      == False
# multiprocessing.Process.__dict__.__contains__('__truediv__')  == False
# multiprocessing.Process.__dict__.__contains__('__floordiv__') == False
# multiprocessing.Process.__dict__.__contains__('__mod__')      == False
# multiprocessing.Process.__dict__.__contains__('_start_method') == True  (sync class attr)
# ---------------------------------------------------------------------------

table multiprocessing_extra1516.process_no_arithmetic_ops:
  description: "multiprocessing.Process has no arithmetic operator methods in its own __dict__ — mp1516pr namespace. multiprocessing.Process.__dict__.__contains__('__add__')==False (Process is a class for spawning OS-level child processes; its interface is start(), join(), terminate(), kill(), is_alive(), pid — process lifecycle management; arithmetic operators on a process handle are semantically meaningless and undefined; the OS process object has no concept of addition); multiprocessing.Process.__dict__.__contains__('__mul__')==False (no multiplication on Process — you cannot multiply process objects; to spawn N processes you create N Process instances explicitly); multiprocessing.Process.__dict__.__contains__('__sub__')==False (no subtraction on Process); multiprocessing.Process.__dict__.__contains__('__truediv__')==False (no division on Process); multiprocessing.Process.__dict__.__contains__('__floordiv__')==False (no floor division on Process); multiprocessing.Process.__dict__.__contains__('__mod__')==False (no modulo on Process); multiprocessing.Process.__dict__.__contains__('_start_method')==True (_start_method IS defined directly in the context.Process subclass that multiprocessing.Process points to — it is the platform start method such as 'fork', 'spawn', or 'forkserver'; established in prior specs; verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: mp1516pr

  columns: [id, function, args, expected, description]
  rows:
    - [mp1516pr001, multiprocessing.Process.__dict__.__contains__, ["__add__"],       false, "Process.__dict__.__contains__('__add__')==False — OS process handle, not numeric; no __add__; verified with Python 3.14.4"]
    - [mp1516pr002, multiprocessing.Process.__dict__.__contains__, ["__mul__"],       false, "Process.__dict__.__contains__('__mul__')==False — no multiplication on Process; verified with Python 3.14.4"]
    - [mp1516pr003, multiprocessing.Process.__dict__.__contains__, ["__sub__"],       false, "Process.__dict__.__contains__('__sub__')==False — no subtraction on Process; verified with Python 3.14.4"]
    - [mp1516pr004, multiprocessing.Process.__dict__.__contains__, ["__truediv__"],   false, "Process.__dict__.__contains__('__truediv__')==False — no true division on Process; verified with Python 3.14.4"]
    - [mp1516pr005, multiprocessing.Process.__dict__.__contains__, ["__floordiv__"],  false, "Process.__dict__.__contains__('__floordiv__')==False — no floor division on Process; verified with Python 3.14.4"]
    - [mp1516pr006, multiprocessing.Process.__dict__.__contains__, ["__mod__"],       false, "Process.__dict__.__contains__('__mod__')==False — no modulo on Process; verified with Python 3.14.4"]
    - [mp1516pr007, multiprocessing.Process.__dict__.__contains__, ["_start_method"], true,  "Process.__dict__.__contains__('_start_method')==True — _start_method class attr (e.g. 'fork'/'spawn') defined directly in context.Process.__dict__; established in prior specs; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.pool.Pool arithmetic operator __dict__ absence
#
# multiprocessing.pool.Pool.__dict__.__contains__('__add__')      == False
# multiprocessing.pool.Pool.__dict__.__contains__('__mul__')      == False
# multiprocessing.pool.Pool.__dict__.__contains__('__sub__')      == False
# multiprocessing.pool.Pool.__dict__.__contains__('__truediv__')  == False
# multiprocessing.pool.Pool.__dict__.__contains__('__floordiv__') == False
# multiprocessing.pool.Pool.__dict__.__contains__('__mod__')      == False
# multiprocessing.pool.Pool.__dict__.__contains__('apply')        == True  (sync method)
# multiprocessing.pool.Pool.__dict__.__contains__('map')          == True  (sync method)
# ---------------------------------------------------------------------------

table multiprocessing_extra1516.pool_no_arithmetic_ops:
  description: "multiprocessing.pool.Pool has no arithmetic operator methods in its own __dict__ — mp1516pl namespace. multiprocessing.pool.Pool.__dict__.__contains__('__add__')==False (Pool manages a pool of worker processes for parallel computation; its interface is apply(), map(), starmap(), imap(), apply_async(), map_async() — work distribution methods; arithmetic operators on a pool manager are undefined and nonsensical); multiprocessing.pool.Pool.__dict__.__contains__('__mul__')==False (no multiplication on Pool — Pool.map() distributes computation but this is not the Python multiplication operator protocol); multiprocessing.pool.Pool.__dict__.__contains__('__sub__')==False (no subtraction on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__truediv__')==False (no true division on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__floordiv__')==False (no floor division on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__mod__')==False (no modulo on Pool); multiprocessing.pool.Pool.__dict__.__contains__('apply')==True (Pool.apply() IS defined directly in Pool.__dict__ — it calls a function with the given args in a worker process and blocks until the result is ready); multiprocessing.pool.Pool.__dict__.__contains__('map')==True (Pool.map() IS defined directly in Pool.__dict__ — it distributes the iterable over the pool workers and collects results in order); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: mp1516pl

  columns: [id, function, args, expected, description]
  rows:
    - [mp1516pl001, multiprocessing.pool.Pool.__dict__.__contains__, ["__add__"],      false, "Pool.__dict__.__contains__('__add__')==False — process pool manager, not numeric; no __add__; verified with Python 3.14.4"]
    - [mp1516pl002, multiprocessing.pool.Pool.__dict__.__contains__, ["__mul__"],      false, "Pool.__dict__.__contains__('__mul__')==False — no multiplication on Pool; verified with Python 3.14.4"]
    - [mp1516pl003, multiprocessing.pool.Pool.__dict__.__contains__, ["__sub__"],      false, "Pool.__dict__.__contains__('__sub__')==False — no subtraction on Pool; verified with Python 3.14.4"]
    - [mp1516pl004, multiprocessing.pool.Pool.__dict__.__contains__, ["__truediv__"],  false, "Pool.__dict__.__contains__('__truediv__')==False — no true division on Pool; verified with Python 3.14.4"]
    - [mp1516pl005, multiprocessing.pool.Pool.__dict__.__contains__, ["__floordiv__"], false, "Pool.__dict__.__contains__('__floordiv__')==False — no floor division on Pool; verified with Python 3.14.4"]
    - [mp1516pl006, multiprocessing.pool.Pool.__dict__.__contains__, ["__mod__"],      false, "Pool.__dict__.__contains__('__mod__')==False — no modulo on Pool; verified with Python 3.14.4"]
    - [mp1516pl007, multiprocessing.pool.Pool.__dict__.__contains__, ["apply"],        true,  "Pool.__dict__.__contains__('apply')==True — Pool.apply() defined in Pool.__dict__; synchronous single-task dispatch to a worker; verified with Python 3.14.4"]
    - [mp1516pl008, multiprocessing.pool.Pool.__dict__.__contains__, ["map"],          true,  "Pool.__dict__.__contains__('map')==True — Pool.map() defined in Pool.__dict__; parallel mapping over an iterable using worker processes; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.Process full arithmetic sweep — all 7 operators
#
# Verifies that __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__,
# __pow__ are ALL absent from multiprocessing.Process.__dict__
# Also contrasts pool.Pool.__dict__.__contains__('starmap') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra1516.process_full_arith_sweep:
  description: "multiprocessing.Process full arithmetic operator sweep — all 7 operators absent from own __dict__ — mp1516fs namespace. Comprehensive confirmation that multiprocessing.Process defines none of the standard Python arithmetic operator protocol methods in its own __dict__. multiprocessing.Process represents an OS-level child process; it is a process management abstraction, not a numeric type; the concept of adding, multiplying, or exponentiating process handles is architecturally undefined; Process.__dict__ contains only _start_method, _Popen, _after_fork, and a few dunder attributes — no arithmetic operators; Pool.starmap is also confirmed True as a sync pool method; verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: mp1516fs

  columns: [id, function, args, expected, description]
  rows:
    - [mp1516fs001, multiprocessing.Process.__dict__.__contains__, ["__add__"],       false, "Process.__dict__.__contains__('__add__')==False — OS process, not numeric; verified with Python 3.14.4"]
    - [mp1516fs002, multiprocessing.Process.__dict__.__contains__, ["__mul__"],       false, "Process.__dict__.__contains__('__mul__')==False — no multiplication on Process; verified with Python 3.14.4"]
    - [mp1516fs003, multiprocessing.Process.__dict__.__contains__, ["__sub__"],       false, "Process.__dict__.__contains__('__sub__')==False — no subtraction on Process; verified with Python 3.14.4"]
    - [mp1516fs004, multiprocessing.Process.__dict__.__contains__, ["__truediv__"],   false, "Process.__dict__.__contains__('__truediv__')==False — no true division on Process; verified with Python 3.14.4"]
    - [mp1516fs005, multiprocessing.Process.__dict__.__contains__, ["__floordiv__"],  false, "Process.__dict__.__contains__('__floordiv__')==False — no floor division on Process; verified with Python 3.14.4"]
    - [mp1516fs006, multiprocessing.Process.__dict__.__contains__, ["__mod__"],       false, "Process.__dict__.__contains__('__mod__')==False — no modulo on Process; verified with Python 3.14.4"]
    - [mp1516fs007, multiprocessing.Process.__dict__.__contains__, ["__pow__"],       false, "Process.__dict__.__contains__('__pow__')==False — no exponentiation on Process; full arithmetic sweep confirms no arithmetic protocol; verified with Python 3.14.4"]
    - [mp1516fs008, multiprocessing.pool.Pool.__dict__.__contains__, ["starmap"],     true,  "Pool.__dict__.__contains__('starmap')==True — Pool.starmap() defined in Pool.__dict__; like map() but unpacks arguments from iterables; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1516.process_no_add:
  description: "multiprocessing.Process.__dict__.__contains__('__add__') returns False — multiprocessing.Process does not define __add__ in its own __dict__; Process is an OS-level child process abstraction; its semantic domain is process lifecycle management (start, join, terminate, kill) and inter-process state; arithmetic on an OS process handle is architecturally undefined — you cannot 'add' two child processes; Process.__dict__ contains _start_method, _Popen, _after_fork and class metadata only; wave 548 theme: arithmetic operator __dict__ presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant multiprocessing_extra1516.process_no_pow:
  description: "multiprocessing.Process.__dict__.__contains__('__pow__') returns False — multiprocessing.Process does not define __pow__ in its own __dict__; exponentiation of an OS process handle is undefined and unsupported; Process represents a child OS process identified by a PID and managed via OS signals and IPC; no numeric operator protocol of any kind (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) is defined in Process.__dict__; wave 548 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__pow__"]
  expected: false

invariant multiprocessing_extra1516.pool_no_mul:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('__mul__') returns False — multiprocessing.pool.Pool does not define __mul__ in its own __dict__; Pool manages a pool of worker processes and exposes apply(), map(), starmap(), imap() for parallel work distribution; Pool.map() is named analogously to Python's built-in map() and takes a function and iterable, distributing work across processes — but this is not the Python __mul__ operator protocol; wave 548 theme: arithmetic operator __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant multiprocessing_extra1516.pool_no_floordiv:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('__floordiv__') returns False — multiprocessing.pool.Pool does not define __floordiv__ in its own __dict__; Pool is a process pool manager; floor division (the // operator) is undefined for a pool object; Pool.__dict__ contains process pool management methods (apply, map, starmap, starmap_async, imap, imap_unordered, apply_async, map_async) and pool maintenance internals (_maintain_pool, _repopulate_pool, etc.) — no arithmetic operators; wave 548 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["__floordiv__"]
  expected: false
