spec: theseus_fnmatch_cr
version: ">=3.8"
backend: python_cleanroom(theseus_fnmatch_cr)
blocks: fnmatch

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/fnmatch.html"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py (internal implementation)"
  notes:
    - "Clean-room fnmatch module. Do NOT import fnmatch."
    - "fnmatch(name, pat): test whether name matches shell pattern."
    - "fnmatchcase(name, pat): case-sensitive fnmatch."
    - "filter(names, pat): return list of names matching pat."
    - "translate(pat): convert shell pattern to regex."

error_model: python_exceptions

invariant theseus_fnmatch_cr.fnmatch2_star:
  description: "fnmatch('foo.txt', '*.txt') returns True"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch2_star
  args: []
  expected: true

invariant theseus_fnmatch_cr.fnmatch2_question:
  description: "fnmatch('foo', 'f?o') returns True"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch2_question
  args: []
  expected: true

invariant theseus_fnmatch_cr.fnmatch2_filter:
  description: "filter(['a.py','b.txt','c.py'], '*.py') returns 2 items"
  category: filter
  kind: python_call_eq
  function: fnmatch2_filter
  args: []
  expected: 2
