spec: hashlib_extra2071
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "_hashlib.HASH is a cryptographic digest C type; it is not numeric so __pos__/__neg__ are absent. Pickling and copying are handled by the runtime, not the type itself, so __reduce__/__reduce_ex__/__copy__/__deepcopy__ are absent from its own __dict__. __getattribute__ is likewise not overridden."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2071.unary_sign_protocol:
  description: "_hashlib.HASH __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2071

  columns: [id, function, args, expected]
  rows:
    - ["hl2071001", "_hashlib.HASH.__dict__.__contains__", ["__pos__"], false]
    - ["hl2071002", "_hashlib.HASH.__dict__.__contains__", ["__neg__"], false]

