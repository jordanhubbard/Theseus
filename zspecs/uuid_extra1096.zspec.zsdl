spec: uuid_extra1096
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.uuid1/__doc__/__class__/__name__, uuid.uuid4/__doc__ class name, UUID.__new__/__repr__/__hash__/__int__/__str__ qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1096.generator_doc_class_names:
  description: "uuid.uuid1 and uuid.uuid4 __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: generator_doc_classnames
  id_prefix: uu1096gd
  columns: [id, function, args, expected]
  rows:
    - [uu1096gd001, uuid.uuid1.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1096gd002, uuid.uuid4.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1096gd003, uuid.uuid3.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1096gd004, uuid.uuid5.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1096gd005, uuid.uuid1.__doc__.__class__.__module__.__eq__,            ["builtins"], true]
    - [uu1096gd006, uuid.uuid4.__doc__.__class__.__module__.__eq__,            ["builtins"], true]
    - [uu1096gd007, uuid.uuid1.__doc__.__class__.__qualname__.__eq__,          ["str"],      true]
    - [uu1096gd008, uuid.uuid4.__doc__.__class__.__qualname__.__eq__,          ["str"],      true]

table uuid_extra1096.uuid_new_qualname:
  description: "uuid.UUID.__new__ qualname and class name identity"
  kind: python_call_eq
  category: uuid_new_qualname
  id_prefix: uu1096nq
  columns: [id, function, args, expected]
  rows:
    - [uu1096nq001, uuid.UUID.__new__.__qualname__.__eq__,              ["UUID.__new__"],  true]
    - [uu1096nq002, uuid.UUID.__new__.__qualname__.__class__.__name__.__eq__, ["str"],     true]
    - [uu1096nq003, uuid.UUID.__new__.__class__.__name__.__eq__,        ["function"],      true]
    - [uu1096nq004, uuid.UUID.__new__.__module__.__eq__,                ["uuid"],          true]
    - [uu1096nq005, uuid.UUID.__new__.__module__.__class__.__name__.__eq__, ["str"],       true]
    - [uu1096nq006, uuid.UUID.__repr__.__qualname__.__eq__,             ["UUID.__repr__"], true]
    - [uu1096nq007, uuid.UUID.__repr__.__qualname__.__class__.__name__.__eq__, ["str"],    true]
    - [uu1096nq008, uuid.UUID.__repr__.__module__.__eq__,               ["uuid"],          true]

table uuid_extra1096.uuid_hash_int_str_qualnames:
  description: "uuid.UUID.__hash__, __int__, __str__ qualname identity"
  kind: python_call_eq
  category: uuid_hash_int_str_qualnames
  id_prefix: uu1096hs
  columns: [id, function, args, expected]
  rows:
    - [uu1096hs001, uuid.UUID.__hash__.__qualname__.__eq__,             ["UUID.__hash__"], true]
    - [uu1096hs002, uuid.UUID.__int__.__qualname__.__eq__,              ["UUID.__int__"],  true]
    - [uu1096hs003, uuid.UUID.__str__.__qualname__.__eq__,              ["UUID.__str__"],  true]
    - [uu1096hs004, uuid.UUID.__hash__.__qualname__.__class__.__name__.__eq__, ["str"],    true]
    - [uu1096hs005, uuid.UUID.__int__.__qualname__.__class__.__name__.__eq__,  ["str"],    true]
    - [uu1096hs006, uuid.UUID.__str__.__qualname__.__class__.__name__.__eq__,  ["str"],    true]
    - [uu1096hs007, uuid.UUID.__hash__.__module__.__eq__,               ["uuid"],          true]
    - [uu1096hs008, uuid.UUID.__int__.__module__.__eq__,                ["uuid"],          true]
    - [uu1096hs009, uuid.UUID.__str__.__module__.__eq__,                ["uuid"],          true]
    - [uu1096hs010, uuid.UUID.__hash__.__class__.__name__.__eq__,       ["function"],      true]
