spec: lodash_isempty
version: ">=4.0.0"
backend: node(lodash.isempty)

docs: https://lodash.com/docs/#isEmpty

provenance:
  derived_from:
    - "lodash.isempty README — https://www.npmjs.com/package/lodash.isempty"
    - "Test vectors verified with lodash.isempty@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isempty exports the _.isEmpty function directly as module.exports."
    - "isEmpty checks if value is an empty collection (array, string, object) or falsy."
    - "Numbers and booleans always return true (not iterable)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isempty.isempty:
  kind: node_module_call_eq
  function: ~
  category: isempty
  id_prefix: limt

  columns: [id, args, expected]
  rows:
    - [empty_arr,   [[]],             true]
    - [nonempty,    [[1, 2, 3]],      false]
    - [empty_obj,   [{}],             true]
    - [nonempty_obj, [{"a": 1}],      false]
    - [empty_str,   [""],             true]
    - [nonempty_str, ["hi"],          false]

