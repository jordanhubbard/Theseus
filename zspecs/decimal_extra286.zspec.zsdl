spec: decimal_extra286
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Decimal data operation and arithmetic method qualnames"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c, Lib/_pydecimal.py"
  notes:
    - "All listed Decimal methods have __qualname__ matching 'Decimal.<methodname>' on CPython"
    - "adjusted() and radix() are no-argument instance/class methods with standard qualnames"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra286.decimal_data_method_qualnames:
  description: "Decimal data operation method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: decx286

  columns: [id, function, args, expected, description]
  rows:
    - [decx286_001, decimal.Decimal.as_tuple.__qualname__.__eq__, ["Decimal.as_tuple"], true, "Decimal.as_tuple qualname"]
    - [decx286_002, decimal.Decimal.as_integer_ratio.__qualname__.__eq__, ["Decimal.as_integer_ratio"], true, "Decimal.as_integer_ratio qualname"]
    - [decx286_003, decimal.Decimal.canonical.__qualname__.__eq__, ["Decimal.canonical"], true, "Decimal.canonical qualname"]
    - [decx286_004, decimal.Decimal.conjugate.__qualname__.__eq__, ["Decimal.conjugate"], true, "Decimal.conjugate qualname"]
    - [decx286_005, decimal.Decimal.copy_abs.__qualname__.__eq__, ["Decimal.copy_abs"], true, "Decimal.copy_abs qualname"]
    - [decx286_006, decimal.Decimal.copy_negate.__qualname__.__eq__, ["Decimal.copy_negate"], true, "Decimal.copy_negate qualname"]
    - [decx286_007, decimal.Decimal.copy_sign.__qualname__.__eq__, ["Decimal.copy_sign"], true, "Decimal.copy_sign qualname"]
    - [decx286_008, decimal.Decimal.number_class.__qualname__.__eq__, ["Decimal.number_class"], true, "Decimal.number_class qualname"]

table decimal_extra286.decimal_arithmetic_method_qualnames:
  description: "Decimal arithmetic and utility method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: decx286a

  columns: [id, function, args, expected, description]
  rows:
    - [decx286a_001, decimal.Decimal.quantize.__qualname__.__eq__, ["Decimal.quantize"], true, "Decimal.quantize qualname"]
    - [decx286a_002, decimal.Decimal.remainder_near.__qualname__.__eq__, ["Decimal.remainder_near"], true, "Decimal.remainder_near qualname"]
    - [decx286a_003, decimal.Decimal.rotate.__qualname__.__eq__, ["Decimal.rotate"], true, "Decimal.rotate qualname"]
    - [decx286a_004, decimal.Decimal.same_quantum.__qualname__.__eq__, ["Decimal.same_quantum"], true, "Decimal.same_quantum qualname"]
    - [decx286a_005, decimal.Decimal.scaleb.__qualname__.__eq__, ["Decimal.scaleb"], true, "Decimal.scaleb qualname"]
    - [decx286a_006, decimal.Decimal.shift.__qualname__.__eq__, ["Decimal.shift"], true, "Decimal.shift qualname"]
    - [decx286a_007, decimal.Decimal.adjusted.__qualname__.__eq__, ["Decimal.adjusted"], true, "Decimal.adjusted qualname"]
    - [decx286a_008, decimal.Decimal.radix.__qualname__.__eq__, ["Decimal.radix"], true, "Decimal.radix qualname"]

invariant decimal_extra286.inv_as_tuple_qualname:
  description: "Decimal.as_tuple __qualname__ is 'Decimal.as_tuple'"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.as_tuple.__qualname__.__eq__
  args: ["Decimal.as_tuple"]
  expected: true

invariant decimal_extra286.inv_quantize_qualname:
  description: "Decimal.quantize __qualname__ is 'Decimal.quantize'"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

invariant decimal_extra286.inv_copy_sign_qualname:
  description: "Decimal.copy_sign __qualname__ is 'Decimal.copy_sign'"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.copy_sign.__qualname__.__eq__
  args: ["Decimal.copy_sign"]
  expected: true

invariant decimal_extra286.inv_radix_qualname:
  description: "Decimal.radix __qualname__ is 'Decimal.radix'"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.radix.__qualname__.__eq__
  args: ["Decimal.radix"]
  expected: true
