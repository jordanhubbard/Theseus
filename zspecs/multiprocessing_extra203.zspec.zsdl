spec: multiprocessing_extra203
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: __doc__ string contains checks using NEW words for multiprocessing factory functions and the BaseProcess class. Wave 379 used 'queue','pool','process','pipe' (lower/upper)."
    - "multiprocessing.Queue.__doc__ == 'Returns a queue object' (len=22). Wave 379 used 'queue','pipe'. NEW: 'Returns'==True, 'object'==True. Verified with Python 3.14.3."
    - "multiprocessing.Pool.__doc__ == 'Returns a process pool object' (len=29). Wave 379 used 'pool','process'. NEW: 'Returns'==True, 'object'==True. Verified with Python 3.14.3."
    - "multiprocessing.Pipe.__doc__ == 'Returns two connection object connected by a pipe' (len=49). Wave 379 used 'pipe'. NEW: 'two'==True, 'connection'==True, 'connected'==True. Verified with Python 3.14.3."
    - "multiprocessing.Value.__doc__ == 'Returns a synchronized shared object' (len=36). NEW object: 'synchronized'==True, 'shared'==True. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__doc__ (len=116): 'activity'==True, 'separate'==True, 'analogous'==True, 'Thread'==True. NEW object: not in wave 379. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Queue and Pool __doc__ new-word checks — extra203
#
# Queue.__doc__ == 'Returns a queue object' (len=22)
# Pool.__doc__ == 'Returns a process pool object' (len=29)
# NEW words not in wave 379: 'Returns', 'object'
# ---------------------------------------------------------------------------

table multiprocessing_extra203.mp_queue_pool_doc_new_words:
  description: "multiprocessing Queue/Pool __doc__ contains checks using words NOT in wave 379 — mpe203qp: Queue 'Returns'==True, 'object'==True; Pool 'Returns'==True, 'object'==True; wave 379 used 'queue','pool','process','pipe'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpe203qp

  columns: [id, function, args, expected, description]
  rows:
    - [queue_doc_has_Returns, multiprocessing.Queue.__doc__.__contains__, ["Returns"], true, "multiprocessing.Queue.__doc__.__contains__('Returns') == True; full doc: 'Returns a queue object'; verified with Python 3.14.3"]
    - [queue_doc_has_object,  multiprocessing.Queue.__doc__.__contains__, ["object"],  true, "multiprocessing.Queue.__doc__.__contains__('object') == True; 'Returns a queue object'; verified with Python 3.14.3"]
    - [pool_doc_has_Returns,  multiprocessing.Pool.__doc__.__contains__,  ["Returns"], true, "multiprocessing.Pool.__doc__.__contains__('Returns') == True; full doc: 'Returns a process pool object'; verified with Python 3.14.3"]
    - [pool_doc_has_object,   multiprocessing.Pool.__doc__.__contains__,  ["object"],  true, "multiprocessing.Pool.__doc__.__contains__('object') == True; 'Returns a process pool object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Pipe __doc__ new-word checks — extra203
#
# Pipe.__doc__ == 'Returns two connection object connected by a pipe' (len=49)
# NEW words not in wave 379: 'two', 'connection', 'connected'
# ---------------------------------------------------------------------------

table multiprocessing_extra203.mp_pipe_doc_new_words:
  description: "multiprocessing.Pipe.__doc__ contains checks using words NOT in wave 379 — mpe203pipe: 'two'==True ('Returns two connection object...'); 'connection'==True; 'connected'==True ('connected by a pipe'); wave 379 used 'pipe'; full doc len==49; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpe203pipe

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_doc_has_two,       multiprocessing.Pipe.__doc__.__contains__, ["two"],       true, "multiprocessing.Pipe.__doc__.__contains__('two') == True; 'Returns two connection object'; verified with Python 3.14.3"]
    - [pipe_doc_has_connection, multiprocessing.Pipe.__doc__.__contains__, ["connection"], true, "multiprocessing.Pipe.__doc__.__contains__('connection') == True; 'two connection object connected'; verified with Python 3.14.3"]
    - [pipe_doc_has_connected,  multiprocessing.Pipe.__doc__.__contains__, ["connected"],  true, "multiprocessing.Pipe.__doc__.__contains__('connected') == True; 'connected by a pipe'; verified with Python 3.14.3"]
    - [pipe_doc_no_duplex,      multiprocessing.Pipe.__doc__.__contains__, ["duplex"],     false, "multiprocessing.Pipe.__doc__.__contains__('duplex') == False; 'duplex' not in brief 49-char docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Value __doc__ contains checks — extra203 (new object, not in wave 379)
#
# Value.__doc__ == 'Returns a synchronized shared object' (len=36)
# 'synchronized'==True, 'shared'==True, 'Returns'==True, 'object'==True
# ---------------------------------------------------------------------------

table multiprocessing_extra203.mp_value_doc_contains:
  description: "multiprocessing.Value.__doc__ contains checks — mpe203val: new object not covered in wave 379; 'synchronized'==True; 'shared'==True; 'Returns'==True; 'object'==True; full doc: 'Returns a synchronized shared object' (len=36); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpe203val

  columns: [id, function, args, expected, description]
  rows:
    - [val_doc_has_synchronized, multiprocessing.Value.__doc__.__contains__, ["synchronized"], true, "multiprocessing.Value.__doc__.__contains__('synchronized') == True; 'Returns a synchronized shared object'; verified with Python 3.14.3"]
    - [val_doc_has_shared,       multiprocessing.Value.__doc__.__contains__, ["shared"],       true, "multiprocessing.Value.__doc__.__contains__('shared') == True; 'synchronized shared object'; verified with Python 3.14.3"]
    - [val_doc_has_Returns,      multiprocessing.Value.__doc__.__contains__, ["Returns"],      true, "multiprocessing.Value.__doc__.__contains__('Returns') == True; starts with 'Returns'; verified with Python 3.14.3"]
    - [val_doc_has_object,       multiprocessing.Value.__doc__.__contains__, ["object"],       true, "multiprocessing.Value.__doc__.__contains__('object') == True; 'a synchronized shared object'; verified with Python 3.14.3"]
    - [val_doc_len,              multiprocessing.Value.__doc__.__len__,      [],               36,   "multiprocessing.Value.__doc__.__len__() == 36; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess __doc__ contains checks — extra203 (new, not in wave 379)
#
# BaseProcess.__doc__ (len=116): process objects represent activity in separate process
# 'activity'==True, 'separate'==True, 'analogous'==True, 'Thread'==True
# ---------------------------------------------------------------------------

table multiprocessing_extra203.mp_baseprocess_doc_contains:
  description: "multiprocessing.process.BaseProcess.__doc__ contains checks — mpe203bp: new object not covered in wave 379; 'activity'==True; 'separate'==True ('run in a separate process'); 'analogous'==True ('analogous to threading.Thread'); 'Thread'==True; len==116; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpe203bp

  columns: [id, function, args, expected, description]
  rows:
    - [bp_doc_has_activity,  multiprocessing.process.BaseProcess.__doc__.__contains__, ["activity"],  true, "multiprocessing.process.BaseProcess.__doc__.__contains__('activity') == True; 'activity that is run in a separate process'; verified with Python 3.14.3"]
    - [bp_doc_has_separate,  multiprocessing.process.BaseProcess.__doc__.__contains__, ["separate"],  true, "multiprocessing.process.BaseProcess.__doc__.__contains__('separate') == True; 'run in a separate process'; verified with Python 3.14.3"]
    - [bp_doc_has_analogous, multiprocessing.process.BaseProcess.__doc__.__contains__, ["analogous"], true, "multiprocessing.process.BaseProcess.__doc__.__contains__('analogous') == True; 'analogous to threading.Thread'; verified with Python 3.14.3"]
    - [bp_doc_has_Thread,    multiprocessing.process.BaseProcess.__doc__.__contains__, ["Thread"],    true, "multiprocessing.process.BaseProcess.__doc__.__contains__('Thread') == True; 'analogous to threading.Thread'; verified with Python 3.14.3"]
    - [bp_doc_len,           multiprocessing.process.BaseProcess.__doc__.__len__,      [],            116,  "multiprocessing.process.BaseProcess.__doc__.__len__() == 116; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra203
# ---------------------------------------------------------------------------

invariant multiprocessing_extra203.pipe_doc_has_connection:
  description: "multiprocessing.Pipe.__doc__.__contains__('connection') returns True — Pipe.__doc__ is 'Returns two connection object connected by a pipe' (len=49); 'connection' not used in wave 379 (which used 'pipe'); a Pipe returns two Connection objects, one for each end; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Pipe.__doc__.__contains__
  args: ["connection"]
  expected: true

invariant multiprocessing_extra203.value_doc_has_synchronized:
  description: "multiprocessing.Value.__doc__.__contains__('synchronized') returns True — Value.__doc__ is 'Returns a synchronized shared object' (len=36); new object not in wave 379; multiprocessing.Value creates process-safe ctypes wrappers; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__doc__.__contains__
  args: ["synchronized"]
  expected: true

invariant multiprocessing_extra203.baseprocess_doc_has_analogous:
  description: "multiprocessing.process.BaseProcess.__doc__.__contains__('analogous') returns True — BaseProcess.__doc__ (len=116) states 'The class is analogous to threading.Thread'; new object not in wave 379; BaseProcess is the base for the public Process class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__doc__.__contains__
  args: ["analogous"]
  expected: true

invariant multiprocessing_extra203.queue_doc_has_Returns:
  description: "multiprocessing.Queue.__doc__.__contains__('Returns') returns True — Queue.__doc__ is 'Returns a queue object' (len=22); 'Returns' not used in wave 379 (which used 'queue','pipe'); multiprocessing.Queue is a factory function, not a class — its docstring is brief and imperative; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Queue.__doc__.__contains__
  args: ["Returns"]
  expected: true
