spec: theseus_linecache_cr
version: ">=3.0"
backend: python_cleanroom(theseus_linecache_cr)
blocks: _theseus_linecache_original

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/linecache.html"
  not_derived_from:
    - "CPython source: Lib/linecache.py"
  notes:
    - "Clean-room linecache module. Do NOT import linecache."
    - "Note: blocks uses a sentinel because Python's shutdown cleanup removes"
    - "linecache from sys.modules and then re-imports it; standard blocking"
    - "would intercept Python-internal cleanup, not user code."

error_model: python_exceptions

invariant theseus_linecache_cr.linecache2_getline:
  description: "getline() returns a line from a file"
  category: behavior
  kind: python_call_eq
  function: linecache2_getline
  args: []
  expected: true

invariant theseus_linecache_cr.linecache2_getlines:
  description: "getlines() returns all lines from a file"
  category: behavior
  kind: python_call_eq
  function: linecache2_getlines
  args: []
  expected: true

invariant theseus_linecache_cr.linecache2_clearcache:
  description: "clearcache() clears the cache"
  category: behavior
  kind: python_call_eq
  function: linecache2_clearcache
  args: []
  expected: true
