spec: decimal_extra348
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Most decimal exception classes extend DecimalException directly"
    - "Overflow and Underflow are special: they extend Inexact (which itself extends DecimalException)"
    - "All __module__ values are 'decimal' (not '_decimal' C extension)"
    - "All class identity values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception class identity — class names
# ---------------------------------------------------------------------------

table decimal_extra348.exception_class_names:
  description: "decimal exception class __name__ identity checks — InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decexcname348

  columns: [id, function, args, expected]
  rows:
    - [invalidoperation_name, decimal.InvalidOperation.__name__.__eq__, ["InvalidOperation"], true]
    - [divisionbyzero_name,   decimal.DivisionByZero.__name__.__eq__,   ["DivisionByZero"],   true]
    - [overflow_name,         decimal.Overflow.__name__.__eq__,         ["Overflow"],         true]
    - [underflow_name,        decimal.Underflow.__name__.__eq__,        ["Underflow"],        true]
    - [inexact_name,          decimal.Inexact.__name__.__eq__,          ["Inexact"],          true]
    - [rounded_name,          decimal.Rounded.__name__.__eq__,          ["Rounded"],          true]

# ---------------------------------------------------------------------------
# decimal exception class identity — module attributes
# ---------------------------------------------------------------------------

table decimal_extra348.exception_class_modules:
  description: "decimal exception class __module__ identity checks — all six classes report __module__ as 'decimal'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decexcmod348

  columns: [id, function, args, expected]
  rows:
    - [invalidoperation_module, decimal.InvalidOperation.__module__.__eq__, ["decimal"], true]
    - [divisionbyzero_module,   decimal.DivisionByZero.__module__.__eq__,   ["decimal"], true]
    - [overflow_module,         decimal.Overflow.__module__.__eq__,         ["decimal"], true]
    - [underflow_module,        decimal.Underflow.__module__.__eq__,        ["decimal"], true]
    - [inexact_module,          decimal.Inexact.__module__.__eq__,          ["decimal"], true]
    - [rounded_module,          decimal.Rounded.__module__.__eq__,          ["decimal"], true]

# ---------------------------------------------------------------------------
# decimal exception class identity — base class names
# ---------------------------------------------------------------------------

table decimal_extra348.exception_class_bases:
  description: "decimal exception class __bases__[0].__name__ identity checks — InvalidOperation, DivisionByZero, Inexact, and Rounded extend DecimalException; Overflow and Underflow extend Inexact (giving them a two-level hierarchy: Overflow -> Inexact -> DecimalException); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decexcbase348

  columns: [id, function, args, expected]
  rows:
    - [invalidoperation_base, "decimal.InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [divisionbyzero_base,   "decimal.DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"], true]
    - [overflow_base,         "decimal.Overflow.__bases__[0].__name__.__eq__",         ["Inexact"],          true]
    - [underflow_base,        "decimal.Underflow.__bases__[0].__name__.__eq__",        ["Inexact"],          true]
    - [inexact_base,          "decimal.Inexact.__bases__[0].__name__.__eq__",          ["DecimalException"], true]
    - [rounded_base,          "decimal.Rounded.__bases__[0].__name__.__eq__",          ["DecimalException"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra348.overflow_extends_inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow is a subclass of Inexact (not directly of DecimalException); this models the IEEE 754 rule that an overflow always produces an inexact result; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "decimal.Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra348.underflow_extends_inexact:
  description: "decimal.Underflow.__bases__[0].__name__ == 'Inexact' — Underflow is also a subclass of Inexact (not directly of DecimalException); this models the IEEE 754 rule that underflow implies an inexact (subnormal) result; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "decimal.Underflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true
