spec: uuid_extra104
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra103.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __module__ equality / uuid module __name__/__package__/__spec__ identity / UUID.__new__ qualname 'object.__new__' (table + invariants)."
    - "uuid_extra102.zspec.zsdl — covers UUID.variant property vs UUID.is_safe member_descriptor / UUID.__reduce__/__hash__/__str__ type and qualname / UUID comparison method qualnames (table + invariants)."
    - "uuid_extra101.zspec.zsdl — covers SafeUUID enum class identity (__name__/__module__/__qualname__/__bases__[0]/__mro__/__class__ EnumType) (table + invariants)."
    - "uuid_extra100.zspec.zsdl — covers UUID class-level descriptor types for hex/bytes/bytes_le/int/variant / UUID.int member_descriptor qualname and __objclass__ / UUID.__slots__ (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes / UUID.__str__/__repr__ qualname equality / UUID.__eq__/__hash__/__lt__ qualname equality (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name / UUID.__module__/__class__/__qualname__ equality and length (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra103; it does NOT duplicate invariants present in those files."
    - "Wave 272 theme: UUID class __name__/__module__/__qualname__ equality and lengths; UUID property fget qualname lengths for hex/bytes/version/variant; uuid.getnode function identity; NAMESPACE_DNS string length."
    - "uuid.UUID.__name__ == 'UUID' (4 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid' (4 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__qualname__ == 'UUID' (4 chars; same as __name__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (8 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (10 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (12 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (12 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__qualname__ == 'getnode' (7 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_DNS).__len__() == 36 (standard UUID string representation with hyphens). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__name__=='UUID' (4 chars) and UUID.__module__=='uuid' (4 chars) have the same length. UUID.__qualname__ is also 'UUID' (same as __name__ because UUID is a top-level class, not nested). uuid_extra96 anchors UUID.__module__ equality; this spec anchors UUID.__name__ equality and __len__() for both __name__ and __module__ as a grouped table."
    - "Note: UUID property fget qualnames follow the pattern 'UUID.<attr>': hex=8 chars, bytes=10 chars, version=12 chars, variant=12 chars. uuid_extra97 anchors UUID.hex fget qualname equality; this spec anchors hex/bytes/version/variant fget qualname lengths as a grouped table."
    - "Note: uuid.getnode is a Python function (type 'function') with __qualname__=='getnode' (7 chars) and __module__=='uuid'. uuid_extra86 anchors getnode __qualname__ and co_argcount; this spec anchors getnode __class__.__name__=='function' as a standalone."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__module__.__eq__('uuid')
# uuid.UUID.__qualname__.__eq__('UUID')
# uuid.UUID.__name__.__len__() == 4
# uuid.UUID.__module__.__len__() == 4
#
# Wave 272 theme: UUID class __name__/__module__/__qualname__ equality and lengths.
#
# uuid.UUID.__name__ is 'UUID' (4 chars: U-U-I-D). uuid.UUID.__module__ is 'uuid'
# (4 chars: u-u-i-d). Both have the same length (4) — note that the class name
# is uppercase ('UUID') while the module name is lowercase ('uuid'). uuid.UUID.__qualname__
# is also 'UUID' (same as __name__ because UUID is a top-level class, not nested
# inside another class or function). uuid_extra96 anchors UUID.__module__ equality
# and length; this spec groups __name__/__module__/__qualname__ equality with lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra104.UUID_class_name_module_qualname_equality_and_lengths:
  description: "UUID.__name__.__eq__('UUID')==True / UUID.__module__.__eq__('uuid')==True / UUID.__qualname__.__eq__('UUID')==True / UUID.__name__.__len__()==4 / UUID.__module__.__len__()==4 — class __name__=='UUID' (4 chars uppercase); __module__=='uuid' (4 chars lowercase); __qualname__=='UUID' (same as __name__; top-level class not nested); both name and module have length 4; first uuidcls104 anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidcls104

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,     "UUID.__name__.__eq__",           ["UUID"], true, "uuid.UUID.__name__ is 'UUID' (4 chars uppercase; the class name as declared in Lib/uuid.py)"]
    - [class_module_eq,   "UUID.__module__.__eq__",         ["uuid"], true, "uuid.UUID.__module__ is 'uuid' (4 chars lowercase; the module where UUID class is defined)"]
    - [class_qualname_eq, "UUID.__qualname__.__eq__",       ["UUID"], true, "uuid.UUID.__qualname__ is 'UUID' (same as __name__; top-level class; no outer class or function)"]
    - [class_name_len,    "UUID.__name__.__len__",          [],       4,    "uuid.UUID.__name__.__len__() is 4 ('UUID': U-U-I-D; same length as module name 'uuid')"]
    - [class_module_len,  "UUID.__module__.__len__",        [],       4,    "uuid.UUID.__module__.__len__() is 4 ('uuid': u-u-i-d; same length as class name 'UUID')"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__() == 8
# uuid.UUID.bytes.fget.__qualname__.__len__() == 10
# uuid.UUID.version.fget.__qualname__.__len__() == 12
# uuid.UUID.variant.fget.__qualname__.__len__() == 12
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex')
#
# Wave 272 theme: UUID property fget qualname lengths.
#
# UUID.hex, UUID.bytes, UUID.version, UUID.variant are properties. Their fget
# functions have qualnames following the pattern 'UUID.<attr>'. The lengths are:
# 'UUID.hex'=8 chars ('UUID.'=5 + 'hex'=3), 'UUID.bytes'=10 ('UUID.'=5 + 'bytes'=5),
# 'UUID.version'=12 ('UUID.'=5 + 'version'=7), 'UUID.variant'=12 ('UUID.'=5 + 'variant'=7).
# version and variant have the same qualname length (12). uuid_extra97 anchors
# UUID.hex fget qualname equality; this spec anchors fget qualname lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra104.UUID_property_fget_qualname_lengths:
  description: "UUID.hex.fget.__qualname__.__len__()==8 / UUID.bytes.fget.__qualname__.__len__()==10 / UUID.version.fget.__qualname__.__len__()==12 / UUID.variant.fget.__qualname__.__len__()==12 / UUID.hex.fget.__qualname__.__eq__('UUID.hex')==True — fget qualnames follow 'UUID.<attr>' pattern; hex=8 ('UUID.'=5+'hex'=3); bytes=10 ('UUID.'=5+'bytes'=5); version=12 ('UUID.'=5+'version'=7); variant=12 (same as version); extra97 anchors hex qualname eq; first uuidcls104 anchor"
  kind: python_call_eq
  category: property_identity
  id_prefix: uuidcls104

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_qualname_eq,      "UUID.hex.fget.__qualname__.__eq__",     ["UUID.hex"], true, "UUID.hex.fget.__qualname__ is 'UUID.hex' (8 chars; 'UUID.'=5 + 'hex'=3; property fget qualname)"]
    - [hex_fget_qualname_len,     "UUID.hex.fget.__qualname__.__len__",    [],           8,    "UUID.hex.fget.__qualname__.__len__() is 8 ('UUID.hex': 'UUID.'=5 + 'hex'=3)"]
    - [bytes_fget_qualname_len,   "UUID.bytes.fget.__qualname__.__len__",  [],           10,   "UUID.bytes.fget.__qualname__.__len__() is 10 ('UUID.bytes': 'UUID.'=5 + 'bytes'=5)"]
    - [version_fget_qualname_len, "UUID.version.fget.__qualname__.__len__", [],          12,   "UUID.version.fget.__qualname__.__len__() is 12 ('UUID.version': 'UUID.'=5 + 'version'=7)"]
    - [variant_fget_qualname_len, "UUID.variant.fget.__qualname__.__len__", [],          12,   "UUID.variant.fget.__qualname__.__len__() is 12 ('UUID.variant': 'UUID.'=5 + 'variant'=7; same length as version)"]

# ---------------------------------------------------------------------------
# uuid.getnode.__qualname__.__eq__('getnode')
# uuid.getnode.__module__.__eq__('uuid')
# uuid.getnode.__class__.__name__.__eq__('function')
# str(uuid.NAMESPACE_DNS).__len__() == 36
# str(uuid.NAMESPACE_URL).__len__() == 36
#
# Wave 272 theme: uuid.getnode function identity and NAMESPACE constant string lengths.
#
# uuid.getnode is a Python function (type 'function') with qualname 'getnode'
# (7 chars: g-e-t-n-o-d-e) and __module__=='uuid'. It returns the hardware address
# (MAC address) of a network interface as a 48-bit integer (for use in uuid1).
# NAMESPACE_DNS and NAMESPACE_URL are UUID instances; their str() representation
# is always 36 chars (the standard UUID string format with 4 hyphens: 8-4-4-4-12).
# uuid_extra86 anchors getnode __qualname__ and co_argcount; this spec anchors
# getnode __class__.__name__ and the NAMESPACE string lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra104.getnode_identity_and_namespace_string_lengths:
  description: "getnode.__qualname__.__eq__('getnode')==True / getnode.__module__.__eq__('uuid')==True / getnode.__class__.__name__.__eq__('function')==True / str(NAMESPACE_DNS).__len__()==36 / str(NAMESPACE_URL).__len__()==36 — getnode is 'function' type (not C builtin); qualname is 'getnode' (7 chars); module is 'uuid'; NAMESPACE_DNS/URL str() has 36 chars (UUID with 4 hyphens: 8-4-4-4-12); first uuidcls104 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidcls104

  columns: [id, function, args, expected, description]
  rows:
    - [getnode_qualname_eq,   "getnode.__qualname__.__eq__",              ["getnode"],  true, "uuid.getnode.__qualname__ is 'getnode' (7 chars; g-e-t-n-o-d-e; top-level function in uuid.py)"]
    - [getnode_module_eq,     "getnode.__module__.__eq__",                ["uuid"],     true, "uuid.getnode.__module__ is 'uuid' (defined in Lib/uuid.py; returns hardware MAC address for uuid1)"]
    - [getnode_type_eq,       "getnode.__class__.__name__.__eq__",        ["function"], true, "type(uuid.getnode) is 'function' (Python function; not a C builtin_function_or_method)"]
    - [ns_dns_str_len,        "NAMESPACE_DNS.__str__().__len__",          [],           36,   "str(uuid.NAMESPACE_DNS).__len__() is 36 (standard UUID string: 8-4-4-4-12 hex groups with 4 hyphens)"]
    - [ns_url_str_len,        "NAMESPACE_URL.__str__().__len__",          [],           36,   "str(uuid.NAMESPACE_URL).__len__() is 36 (same format as NAMESPACE_DNS; all UUID strings are 36 chars)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# uuid.UUID.__name__ is 'UUID'. The __name__ attribute of a class is the
# class name as declared in the source code. UUID is declared as 'class UUID:'
# in Lib/uuid.py, so __name__ is 'UUID' (4 chars, all uppercase: U-U-I-D).
# The uppercase name 'UUID' distinguishes the class from the module 'uuid'
# (lowercase). Note that UUID.__name__ ('UUID') differs from uuid.__name__
# ('uuid') — the former is the class name, the latter is the module name.
# uuid_extra96 anchors UUID.__module__ equality; this spec anchors UUID.__name__
# equality as a standalone under uuidcls104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra104.UUID_class_name_eq:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — class __name__ is 'UUID' (4 chars uppercase; U-U-I-D); declared as 'class UUID:' in Lib/uuid.py; uppercase distinguishes class from module 'uuid' (lowercase); UUID.__name__!='uuid' (module name); extra96 anchors UUID.__module__; first standalone under uuidcls104"
  category: class_identity
  kind: python_call_eq
  function: "UUID.__name__.__eq__"
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__qualname__.__eq__('UUID') — standalone
#
# uuid.UUID.__qualname__ is 'UUID'. For a top-level class (not nested inside
# another class or function), __qualname__ equals __name__. UUID is declared
# at the top level of Lib/uuid.py, so __qualname__=='UUID' (4 chars), the same
# as __name__=='UUID'. If UUID were a nested class (e.g., defined inside another
# class Outer), __qualname__ would be 'Outer.UUID'. The equality __qualname__==
# __name__ is a marker of top-level class definitions. uuid_extra99 anchors
# UUID.__qualname__ via length checks; this spec anchors it as __eq__() standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra104.UUID_class_qualname_eq:
  description: "uuid.UUID.__qualname__.__eq__('UUID') == True — __qualname__ is 'UUID' (same as __name__; top-level class not nested in another class or function); if nested, qualname would be 'Outer.UUID'; equality __qualname__==__name__ is a marker of top-level definition; extra99 anchors via length; first standalone for __qualname__ eq under uuidcls104"
  category: class_identity
  kind: python_call_eq
  function: "UUID.__qualname__.__eq__"
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__() == 8 — standalone
#
# uuid.UUID.hex.fget.__qualname__ is 'UUID.hex' (8 chars: 'UUID.'=5 + 'hex'=3).
# UUID.hex is a property that returns the UUID as a 32-character lowercase
# hexadecimal string without hyphens (e.g., '550e8400e29b41d4a716446655440000').
# The property's fget function has a qualname following the 'UUID.<attr>' pattern.
# 'UUID.hex' is the shortest among the UUID property fget qualnames in this spec
# (hex=8, bytes=10, version=12, variant=12). uuid_extra97 anchors UUID.hex fget
# qualname equality; this spec anchors the length as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra104.UUID_hex_fget_qualname_len:
  description: "uuid.UUID.hex.fget.__qualname__.__len__() == 8 — fget qualname 'UUID.hex' is 8 chars ('UUID.'=5 + 'hex'=3); UUID.hex returns 32-char hex string without hyphens; shortest among UUID property fget qualnames (hex=8, bytes=10, version=12, variant=12); extra97 anchors qualname equality; first standalone under uuidcls104"
  category: property_identity
  kind: python_call_eq
  function: "UUID.hex.fget.__qualname__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.getnode.__class__.__name__.__eq__('function') — standalone
#
# uuid.getnode is a Python function (type 'function'). This distinguishes it
# from C-level functions like hashlib.pbkdf2_hmac (type 'builtin_function_or_method').
# getnode is implemented in Lib/uuid.py using Python code with ctypes for
# MAC address retrieval (platform-dependent). The fact that getnode is a
# Python function (not a C builtin) means it has a __code__ attribute with
# co_name, co_argcount, etc. uuid_extra86 anchors getnode __qualname__ and
# co_argcount; this spec anchors the type name as a standalone under uuidcls104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra104.getnode_type_eq:
  description: "uuid.getnode.__class__.__name__.__eq__('function') == True — getnode is a Python function (not C builtin_function_or_method); implemented in Lib/uuid.py using ctypes for MAC address retrieval; has __code__ attribute with co_name and co_argcount; extra86 anchors qualname and co_argcount; first standalone for type identity under uuidcls104"
  category: function_identity
  kind: python_call_eq
  function: "getnode.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# str(uuid.NAMESPACE_DNS).__len__() == 36 — standalone
#
# str(uuid.NAMESPACE_DNS) has length 36. NAMESPACE_DNS is a UUID instance with
# value '6ba7b810-9dad-11d1-80b4-00c04fd430c8'. The standard string representation
# of a UUID is always 36 characters: 8 hex chars + hyphen + 4 hex chars + hyphen +
# 4 hex chars + hyphen + 4 hex chars + hyphen + 12 hex chars = 32 hex chars +
# 4 hyphens = 36 chars total. All UUID instances have a 36-char str() regardless
# of their specific value. uuid_extra98 anchors NAMESPACE_DNS string value equality;
# this spec anchors the str() length as a standalone under uuidcls104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra104.namespace_dns_str_len:
  description: "str(uuid.NAMESPACE_DNS).__len__() == 36 — NAMESPACE_DNS str() is 36 chars (8+1+4+1+4+1+4+1+12=36; 32 hex chars + 4 hyphens); standard UUID string format; all UUID instances have 36-char str(); extra98 anchors NAMESPACE_DNS string value equality; first standalone for str() length under uuidcls104"
  category: namespace_identity
  kind: python_call_eq
  function: "NAMESPACE_DNS.__str__().__len__"
  args: []
  expected: 36
