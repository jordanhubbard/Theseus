spec: re_extra39
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra38.zspec.zsdl — covers compile(IGNORECASE).flags==34/compile(MULTILINE).flags==40/compile(DOTALL).flags==48; split with capturing group; findall two groups returning tuples; search lastgroup; escape dot+star."
    - "re_extra35.zspec.zsdl — covers error.__init__.__qualname__.__len__()==21; error.__str__.__qualname__.__len__()==21; Pattern.__dict__.__len__()==26; Match.__dict__.__len__()==21; error.__dict__.__len__()==6; re.__version__.__len__()==5; RegexFlag.__mro__.__len__()==7."
    - "re_extra12.zspec.zsdl — covers IGNORECASE|MULTILINE==10 (the integer OR of two RegexFlag members, not a compiled pattern's .flags attribute)."
    - "re_extra14.zspec.zsdl — covers match(r'(\\w+)\\s+(\\w+)', ...).groups().__len__()==2 (two groups pattern)."
  notes:
    - "This spec extends re_extra38.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths; all public function __name__/__module__/__qualname__/__qualname__.__len__(); error/__name__/__module__/__qualname__/__bases__; RegexFlag attributes; IGNORECASE/MULTILINE/DOTALL/VERBOSE values; Pattern/Match method __qualname__.__len__() for all main methods; module-level function __qualname__.__len__(); compiled pattern .flags with single explicit flag; split with capturing group delimiter; findall with two capture groups; search lastgroup; escape; re.__version__; Pattern/Match/__dict__.__len__(); error.__dict__.__len__()."
    - "This spec covers: compile(r'\\w+', IGNORECASE|MULTILINE).flags==42 (NOVEL — re_extra38 covers single-flag compiled pattern .flags values: IGNORECASE(34)/MULTILINE(40)/DOTALL(48); no prior re spec checks .flags when two flags are OR-ed together; IGNORECASE(2)+MULTILINE(8)+UNICODE(32)=42); error.__static_attributes__.__len__()==5 (NOVEL — error.__static_attributes__ is a tuple of the five instance slot names: 'colno'/'lineno'/'msg'/'pattern'/'pos'; no prior re spec checks __static_attributes__ or its length); match(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').groups()__len__()==3 (NOVEL — re_extra14 covers .groups().__len__()==2 for a two-group pattern; no prior re spec checks a three-group match); match(...).group(0).__len__()==10 (NOVEL — no prior re spec checks the length of group(0) for a date-format match); fullmatch(r'\\d{4}-\\d{2}-\\d{2}', '2024-03-15').group().__len__()==10 (NOVEL — fullmatch date-string length not previously tested)."
    - "re.compile(r'\\w+', IGNORECASE|MULTILINE).flags == 42 — IGNORECASE(2) + MULTILINE(8) + UNICODE(32) = 42. re_extra38 covers single-flag compiled patterns; no prior re spec uses two OR-ed flags. re_extra12 covers the integer 10 (= IGNORECASE|MULTILINE as standalone flag OR) but not the compiled pattern .flags attribute. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.error.__static_attributes__ == ('colno', 'lineno', 'msg', 'pattern', 'pos') — a tuple of 5 entries. This tuple lists the instance attributes that PatternError sets in __init__. No prior re spec accesses __static_attributes__ at all. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.error.__static_attributes__[0] == 'colno' — the first entry alphabetically is 'colno' (5 chars). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.match(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').groups().__len__() == 3 — three capture groups produce a 3-tuple. re_extra14 covers .groups().__len__()==2 (two-group pattern). This is the first three-group match groups length check. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.match(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').group(0).__len__() == 10 — group(0) is the full match '2024-03-15' (10 chars). No prior re spec checks the length of group(0) on a date-format string. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.fullmatch(r'\\d{4}-\\d{2}-\\d{2}', '2024-03-15').group().__len__() == 10 — fullmatch of a date string; the group() result '2024-03-15' has 10 characters. No prior re spec tests fullmatch with a date string or its group() length. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile with two OR-ed flags: IGNORECASE|MULTILINE -> .flags == 42
#
# re_extra38 covers compile(r'test', IGNORECASE).flags==34 (IGNORECASE=2+UNICODE=32),
# compile(r'^t', MULTILINE).flags==40, and compile(r'.+', DOTALL).flags==48.
# All three use a single explicit flag. No prior re spec checks .flags when
# two explicit flags are combined via |. The combined value is:
#
#   IGNORECASE(2) + MULTILINE(8) + UNICODE(32) = 42
#
# re_extra12 records IGNORECASE|MULTILINE as the integer 10 (the raw enum OR),
# which is different from the compiled pattern's .flags integer that also
# includes the always-present UNICODE(32). Novel.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra39.compile_two_flags_value:
  description: "re.compile(r'\\w+', IGNORECASE|MULTILINE).flags == 42 — IGNORECASE(2)+MULTILINE(8)+UNICODE(32)=42; re_extra38 covers single-flag compiled .flags but not two OR-ed flags together; novel"
  category: pattern_flags
  kind: python_call_eq
  function: "compile.__call__(r'\\w+', IGNORECASE|MULTILINE).flags.__eq__"
  args: [42]
  expected: true

# ---------------------------------------------------------------------------
# re.error.__static_attributes__ — instance slot names tuple
#
# Python 3.12 adds __static_attributes__ to classes that declare instance
# attributes outside of __init__ at the class body level. For re.error
# (PatternError), these are the five instance attributes set in __init__:
#
#   re.error.__static_attributes__ == ('colno', 'lineno', 'msg', 'pattern', 'pos')
#
# No prior re spec accesses __static_attributes__ at all. The tuple has
# 5 entries. The first entry alphabetically is 'colno' (5 chars).
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra39.error_static_attributes_len:
  description: "len(re.error.__static_attributes__) == 5 — tuple of five instance attribute names: colno/lineno/msg/pattern/pos; novel (no prior re spec accesses __static_attributes__); verified Python 3.12 macOS/Darwin 25.4.0"
  category: class_structure
  kind: python_call_eq
  function: "error.__static_attributes__.__len__"
  args: []
  expected: 5

invariant re_extra39.error_static_attributes_first_entry:
  description: "re.error.__static_attributes__[0] == 'colno' — alphabetically first slot name; len 5; novel"
  category: class_structure
  kind: python_call_eq
  function: "error.__static_attributes__.__getitem__"
  args: [0]
  expected: "colno"

# ---------------------------------------------------------------------------
# re.match with three capture groups: .groups().__len__() and group(0).__len__()
#
# re_extra14 covers match(r'(\w+)\s+(\w+)', 'foo bar').groups().__len__()==2
# (two-group pattern). No prior re spec checks a three-group pattern.
# The date pattern r'(\d{4})-(\d{2})-(\d{2})' applied to '2024-03-15' yields:
#
#   groups() == ('2024', '03', '15')   — 3-tuple
#   group(0) == '2024-03-15'           — full match, 10 chars
#
# Novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra39.match_three_groups_len:
  description: "re.match(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').groups().__len__() == 3 — three capture groups produce a 3-tuple; re_extra14 covers 2-group .groups().__len__()==2 but not 3-group; novel"
  category: match_groups
  kind: python_call_eq
  function: "match.__call__(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').groups().__len__"
  args: []
  expected: 3

invariant re_extra39.match_group0_len:
  description: "re.match(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').group(0).__len__() == 10 — group(0) is the full match '2024-03-15' (10 chars); no prior re spec checks group(0).__len__() on a date-format string; novel"
  category: match_groups
  kind: python_call_eq
  function: "match.__call__(r'(\\d{4})-(\\d{2})-(\\d{2})', '2024-03-15').group().__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# re.fullmatch with a date-format pattern: group() length
#
# re_extra12 covers fullmatch(r'\d+', '123') returning a Match and
# fullmatch(r'\d+', '12x') returning None. No prior re spec tests fullmatch
# with a date-format pattern or checks the length of the resulting group().
#
# fullmatch(r'\d{4}-\d{2}-\d{2}', '2024-03-15').group() == '2024-03-15' (len 10)
#
# Novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra39.fullmatch_date_group_len:
  description: "re.fullmatch(r'\\d{4}-\\d{2}-\\d{2}', '2024-03-15').group().__len__() == 10 — '2024-03-15' is 10 chars; fullmatch with date pattern; novel (prior fullmatch tests use digit-only patterns)"
  category: fullmatch
  kind: python_call_eq
  function: "fullmatch.__call__(r'\\d{4}-\\d{2}-\\d{2}', '2024-03-15').group().__len__"
  args: []
  expected: 10
