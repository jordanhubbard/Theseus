spec: fractions_extra24
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra23.zspec.zsdl."
    - "Prior specs covered: Fraction.__module__/__name__/__qualname__ lengths, Fraction.__str__/__abs__/__neg__/__pos__ __qualname__ and lengths, Fraction.limit_denominator/__name__/__qualname__ and lengths, Fraction.from_float/__name__/__qualname__/__qualname__.__len__(), Fraction.from_decimal/__name__."
    - "This spec covers: Fraction.__repr__.__qualname__/__module__ and their lengths; Fraction.__floor__/__ceil__ __qualname__/__module__ and lengths; Fraction.numerator/denominator property getter __name__/__qualname__ and lengths; Fraction.from_decimal.__qualname__ and its length."
    - "Fraction.__repr__.__qualname__ == 'Fraction.__repr__' (17 chars); __floor__/__ceil__ are 18 and 17 chars respectively."
    - "numerator.fget.__qualname__ == 'Fraction.numerator' (18 chars); denominator.fget.__qualname__ == 'Fraction.denominator' (20 chars)."
    - "from_decimal.__qualname__ == 'Fraction.from_decimal' (21 chars)."
    - "All method __module__ values are 'fractions' (len 9)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# fractions.Fraction.__repr__.__qualname__ and __module__
#
# fractions_extra22 records Fraction.__repr__.__name__ == '__repr__'.
# No prior spec records Fraction.__repr__.__qualname__ or __module__.
# __repr__.__qualname__ == 'Fraction.__repr__' (17 chars).
# __repr__.__module__ == 'fractions' (9 chars).
# ---------------------------------------------------------------------------

invariant fractions_extra24.Fraction.repr_qualname:
  description: "fractions.Fraction.__repr__.__qualname__ == 'Fraction.__repr__'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__qualname__.__eq__
  args: ["Fraction.__repr__"]
  expected: true

invariant fractions_extra24.Fraction.repr_qualname_len:
  description: "len(fractions.Fraction.__repr__.__qualname__) == 17 — 'Fraction.__repr__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# fractions.Fraction.__floor__ and __ceil__ __qualname__ and __module__
#
# No prior fractions spec records __floor__ or __ceil__ __qualname__.
# __floor__.__qualname__ == 'Fraction.__floor__' (18 chars).
# __ceil__.__qualname__ == 'Fraction.__ceil__' (17 chars).
# Both have __module__ == 'fractions' (9 chars).
# ---------------------------------------------------------------------------

table fractions_extra24.floor_ceil_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [floor, Fraction.__floor__.__qualname__.__eq__, ["Fraction.__floor__"], true, "fractions.Fraction.__floor__.__qualname__ == 'Fraction.__floor__'"]
    - [ceil,  Fraction.__ceil__.__qualname__.__eq__,  ["Fraction.__ceil__"],  true, "fractions.Fraction.__ceil__.__qualname__ == 'Fraction.__ceil__'"]

invariant fractions_extra24.Fraction.floor_qualname_len:
  description: "len(fractions.Fraction.__floor__.__qualname__) == 18 — 'Fraction.__floor__' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__floor__.__qualname__.__len__
  args: []
  expected: 18

invariant fractions_extra24.Fraction.ceil_qualname_len:
  description: "len(fractions.Fraction.__ceil__.__qualname__) == 17 — 'Fraction.__ceil__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__ceil__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# fractions.Fraction.numerator and denominator property getter qualnames
#
# The numerator and denominator properties are implemented as Python-level
# property objects. Their getter functions have __qualname__ and __name__
# attributes. No prior fractions spec records these values.
# numerator.fget.__qualname__ == 'Fraction.numerator' (18 chars).
# denominator.fget.__qualname__ == 'Fraction.denominator' (20 chars).
# ---------------------------------------------------------------------------

table fractions_extra24.property_getter_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [numerator,   "Fraction.numerator.fget.__qualname__.__eq__",   ["Fraction.numerator"],   true, "fractions.Fraction.numerator.fget.__qualname__ == 'Fraction.numerator'"]
    - [denominator, "Fraction.denominator.fget.__qualname__.__eq__", ["Fraction.denominator"], true, "fractions.Fraction.denominator.fget.__qualname__ == 'Fraction.denominator'"]

invariant fractions_extra24.Fraction.numerator_qualname_len:
  description: "len(fractions.Fraction.numerator.fget.__qualname__) == 18 — 'Fraction.numerator' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.numerator.fget.__qualname__.__len__"
  args: []
  expected: 18

invariant fractions_extra24.Fraction.denominator_qualname_len:
  description: "len(fractions.Fraction.denominator.fget.__qualname__) == 20 — 'Fraction.denominator' is 20 chars"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.denominator.fget.__qualname__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# fractions.Fraction.from_decimal.__qualname__ and its length
#
# fractions_extra23 records from_decimal.__name__ == 'from_decimal' and its
# length (12). No prior spec records from_decimal.__qualname__.
# from_decimal is a classmethod; __qualname__ == 'Fraction.from_decimal' (21 chars).
# ---------------------------------------------------------------------------

invariant fractions_extra24.Fraction.from_decimal_qualname:
  description: "fractions.Fraction.from_decimal.__qualname__ == 'Fraction.from_decimal'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__qualname__.__eq__
  args: ["Fraction.from_decimal"]
  expected: true

invariant fractions_extra24.Fraction.from_decimal_qualname_len:
  description: "len(fractions.Fraction.from_decimal.__qualname__) == 21 — 'Fraction.from_decimal' is 21 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__qualname__.__len__
  args: []
  expected: 21
