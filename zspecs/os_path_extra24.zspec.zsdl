spec: os_path_extra24
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra23.zspec.zsdl — covers __module__.__len__() for posixpath/genericpath functions in tables; __name__.__len__() for join/split/splitext/basename/dirname; normpath.__module__.__len__()==5 standalone."
    - "os_path_extra22.zspec.zsdl — covers __qualname__.__class__.__name__=='str' for all 12 functions; splitext/normpath __qualname__.__len__()."
    - "os_path_extra20.zspec.zsdl — covers isabs.__qualname__.__len__()==5."
    - "os_path_extra17.zspec.zsdl — covers __qualname__.__len__() for join/split/basename/dirname/exists/isfile/isdir/abspath/expanduser."
  notes:
    - "This spec extends os_path_extra23.zspec.zsdl."
    - "Prior specs covered: join/split/splitext/basename/dirname/normpath/abspath/isabs/isfile/isdir/exists/expanduser __qualname__ equality and lengths; __name__/__module__ equality and lengths; __qualname__.__class__.__name__=='str' type checks."
    - "This spec covers: posixpath.__all__.__len__()==42; posixpath.__all__.__class__.__name__=='list'; sep/curdir/pardir/extsep/pathsep __class__.__name__=='str' (table); sep.__len__()==1, pardir.__len__()==2, extsep.__len__()==1, pathsep.__len__()==1 (table); sep/curdir/pardir __class__.__module__=='builtins' (standalone); os.path.__spec__.__class__.__name__=='ModuleSpec' (len 10)."
    - "posixpath.__all__.__len__() == 42 — verified with Python 3.14 on macOS."
    - "os.path.sep == '/' (len 1). os.path.curdir == '.' (len 1). os.path.pardir == '..' (len 2). os.path.extsep == '.' (len 1). os.path.pathsep == ':' (len 1 on macOS)."
    - "sep/curdir/pardir/extsep/pathsep are all str instances: __class__.__name__ == 'str'."
    - "str.__module__ == 'builtins', so all path separator constants have __class__.__module__ == 'builtins'."
    - "os.path.__spec__.__class__.__name__ == 'ModuleSpec' (len 10). Verified."
    - "os.path.__loader__.__class__.__name__ == 'type' (len 4) — posixpath is loaded via FrozenImporter, whose metaclass is 'type'. Distinguished from SourceFileLoader used by tokenize/importlib/glob."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: module-level string constants __class__.__name__ == 'str'
#
# sep/curdir/pardir/extsep/pathsep are POSIX path separator constants.
# All are plain Python str objects. No prior os.path spec groups their
# __class__.__name__ checks into a single table.
# Verified: all five return 'str'.
# ---------------------------------------------------------------------------

table os_path_extra24.separator_class_names:
  description: "__class__.__name__ == 'str' for os.path separator constants sep/curdir/pardir/extsep/pathsep"
  kind: python_call_eq
  category: constant_types
  id_prefix: scn24

  columns: [id, function, args, expected]
  rows:
    - [sep,     "sep.__class__.__name__.__eq__",     ["str"], true]
    - [curdir,  "curdir.__class__.__name__.__eq__",  ["str"], true]
    - [pardir,  "pardir.__class__.__name__.__eq__",  ["str"], true]
    - [extsep,  "extsep.__class__.__name__.__eq__",  ["str"], true]
    - [pathsep, "pathsep.__class__.__name__.__eq__", ["str"], true]

# ---------------------------------------------------------------------------
# Table: module-level string constant lengths
#
# The POSIX path separator constants have well-known lengths:
# sep='/' (1), curdir='.' (1), pardir='..' (2), extsep='.' (1), pathsep=':' (1).
# No prior os.path spec groups their __len__() checks into a single table.
# Verified: sep=1, curdir=1, pardir=2, extsep=1, pathsep=1.
# ---------------------------------------------------------------------------

table os_path_extra24.separator_lengths:
  description: "__len__() for os.path separator constants — sep=1 curdir=1 pardir=2 extsep=1 pathsep=1"
  kind: python_call_eq
  category: constant_lengths
  id_prefix: sl24

  columns: [id, function, args, expected]
  rows:
    - [sep,     "sep.__len__",     [], 1]
    - [curdir,  "curdir.__len__",  [], 1]
    - [pardir,  "pardir.__len__",  [], 2]
    - [extsep,  "extsep.__len__",  [], 1]
    - [pathsep, "pathsep.__len__", [], 1]

# ---------------------------------------------------------------------------
# Table: __all__ membership for key os.path constants
#
# posixpath.__all__ includes the separator constants. No prior os.path spec
# checks __all__.__contains__() for any of these constants.
# Verified: all three return True.
# ---------------------------------------------------------------------------

table os_path_extra24.all_contains:
  description: "__all__.__contains__() confirms sep/curdir/pardir are in posixpath.__all__"
  kind: python_call_eq
  category: all_membership
  id_prefix: allc24

  columns: [id, function, args, expected]
  rows:
    - [sep,    "__all__.__contains__", ["sep"],    true]
    - [curdir, "__all__.__contains__", ["curdir"], true]
    - [pardir, "__all__.__contains__", ["pardir"], true]

# ---------------------------------------------------------------------------
# Standalone: posixpath.__all__.__len__() == 42
#
# posixpath exports 42 public names. No prior os.path spec checks
# __all__.__len__(). Verified: 42 with Python 3.14 on macOS.
# ---------------------------------------------------------------------------

invariant os_path_extra24.all.len:
  description: "posixpath.__all__.__len__() == 42 — 42 public names are exported from posixpath"
  category: all_membership
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 42

# ---------------------------------------------------------------------------
# Standalone: posixpath.__all__.__class__.__name__ == 'list'
#
# __all__ is a plain Python list per convention. No prior os.path spec checks
# __all__.__class__.__name__. Verified: 'list'.
# ---------------------------------------------------------------------------

invariant os_path_extra24.all.class_name:
  description: "posixpath.__all__.__class__.__name__.__eq__('list') == True — __all__ is a list"
  category: all_membership
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.path.sep.__class__.__module__ == 'builtins'
#
# sep is a str, and str.__module__ == 'builtins'. This confirms the separator
# constants come from a builtin type. No prior os.path spec covers
# __class__.__module__ for any path constant.
# Verified: 'builtins'.
# ---------------------------------------------------------------------------

invariant os_path_extra24.sep.class_module:
  description: "os.path.sep.__class__.__module__.__eq__('builtins') == True — str is a builtin type"
  category: constant_types
  kind: python_call_eq
  function: "sep.__class__.__module__.__eq__"
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.path.__spec__.__class__.__name__.__len__() == 10
#
# os.path.__spec__.__class__.__name__ == 'ModuleSpec'. len('ModuleSpec') == 10.
# No prior os.path spec covers __spec__.__class__.__name__.__len__().
# Verified: 10.
# ---------------------------------------------------------------------------

invariant os_path_extra24.spec.class_name_len:
  description: "os.path.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: os.path.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# Confirms by equality that the spec class is exactly 'ModuleSpec'.
# No prior os.path spec checks __spec__.__class__.__name__ via __eq__.
# Verified: True.
# ---------------------------------------------------------------------------

invariant os_path_extra24.spec.class_name_eq:
  description: "os.path.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — spec class is ModuleSpec"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true
