spec: unicodedata_extra
version: ">=3.0"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Unicode Standard — https://www.unicode.org/versions/latest/"
    - "Test vectors verified by running Python 3.14.3 unicodedata module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
    - "unicodedata.zspec.zsdl — covers name, lookup, category, bidirectional, combining, east_asian_width, decomposition, decimal, numeric, normalize, unidata_version"
  notes:
    - "This spec extends unicodedata.zspec.zsdl with function identity checks and additional value vectors."
    - "Function identity invariants (.__name__) confirm the expected symbol is present in the module."
    - "unicodedata.lookup, name, decimal, digit, numeric, category, bidirectional, combining are built-in functions."
    - "unicodedata.east_asian_width, mirrored, decomposition, normalize, is_normalized are also built-in functions."
    - "unicodedata.unidata_version is a module-level string attribute — verified via __class__.__name__."
    - "unicodedata.name('A') == 'LATIN CAPITAL LETTER A' — character name in ALL CAPS."
    - "unicodedata.category('A') == 'Lu' — uppercase letter category code."
    - "is_normalized was added in Python 3.11; version guard is inherited from the spec version field."
    - "All expected values verified by running Python 3.14.3 unicodedata module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function identity checks — confirm all major symbols are present by name
# unicodedata.zspec.zsdl does not check .__name__ on these functions.
# ---------------------------------------------------------------------------

invariant unicodedata_extra.lookup.name:
  description: "unicodedata.lookup.__name__ == 'lookup'"
  category: function_identity
  kind: python_call_eq
  function: lookup.__name__.__eq__
  args: ["lookup"]
  expected: true

invariant unicodedata_extra.name.name:
  description: "unicodedata.name.__name__ == 'name'"
  category: function_identity
  kind: python_call_eq
  function: name.__name__.__eq__
  args: ["name"]
  expected: true

invariant unicodedata_extra.decimal.name:
  description: "unicodedata.decimal.__name__ == 'decimal'"
  category: function_identity
  kind: python_call_eq
  function: decimal.__name__.__eq__
  args: ["decimal"]
  expected: true

invariant unicodedata_extra.digit.name:
  description: "unicodedata.digit.__name__ == 'digit'"
  category: function_identity
  kind: python_call_eq
  function: digit.__name__.__eq__
  args: ["digit"]
  expected: true

invariant unicodedata_extra.numeric.name:
  description: "unicodedata.numeric.__name__ == 'numeric'"
  category: function_identity
  kind: python_call_eq
  function: numeric.__name__.__eq__
  args: ["numeric"]
  expected: true

invariant unicodedata_extra.category.name:
  description: "unicodedata.category.__name__ == 'category'"
  category: function_identity
  kind: python_call_eq
  function: category.__name__.__eq__
  args: ["category"]
  expected: true

invariant unicodedata_extra.bidirectional.name:
  description: "unicodedata.bidirectional.__name__ == 'bidirectional'"
  category: function_identity
  kind: python_call_eq
  function: bidirectional.__name__.__eq__
  args: ["bidirectional"]
  expected: true

invariant unicodedata_extra.combining.name:
  description: "unicodedata.combining.__name__ == 'combining'"
  category: function_identity
  kind: python_call_eq
  function: combining.__name__.__eq__
  args: ["combining"]
  expected: true

invariant unicodedata_extra.east_asian_width.name:
  description: "unicodedata.east_asian_width.__name__ == 'east_asian_width'"
  category: function_identity
  kind: python_call_eq
  function: east_asian_width.__name__.__eq__
  args: ["east_asian_width"]
  expected: true

invariant unicodedata_extra.mirrored.name:
  description: "unicodedata.mirrored.__name__ == 'mirrored'"
  category: function_identity
  kind: python_call_eq
  function: mirrored.__name__.__eq__
  args: ["mirrored"]
  expected: true

invariant unicodedata_extra.decomposition.name:
  description: "unicodedata.decomposition.__name__ == 'decomposition'"
  category: function_identity
  kind: python_call_eq
  function: decomposition.__name__.__eq__
  args: ["decomposition"]
  expected: true

invariant unicodedata_extra.normalize.name:
  description: "unicodedata.normalize.__name__ == 'normalize'"
  category: function_identity
  kind: python_call_eq
  function: normalize.__name__.__eq__
  args: ["normalize"]
  expected: true

invariant unicodedata_extra.is_normalized.name:
  description: "unicodedata.is_normalized.__name__ == 'is_normalized'"
  category: function_identity
  kind: python_call_eq
  function: is_normalized.__name__.__eq__
  args: ["is_normalized"]
  expected: true

# ---------------------------------------------------------------------------
# name() — additional vector (already covered in unicodedata.zspec.zsdl but
# spec rule says derive from public docs; this confirms 'A' -> 'LATIN CAPITAL LETTER A')
# ---------------------------------------------------------------------------

invariant unicodedata_extra.name.capital_a:
  description: "unicodedata.name('A') == 'LATIN CAPITAL LETTER A'"
  category: name
  kind: python_call_eq
  function: name
  args: ["A"]
  expected: "LATIN CAPITAL LETTER A"

# ---------------------------------------------------------------------------
# category() — additional vector
# unicodedata.zspec.zsdl already covers 'A' -> 'Lu' in the table
# We add a standalone invariant for clarity
# ---------------------------------------------------------------------------

invariant unicodedata_extra.category.capital_a:
  description: "unicodedata.category('A') == 'Lu' — uppercase letter"
  category: category
  kind: python_call_eq
  function: category
  args: ["A"]
  expected: "Lu"

# ---------------------------------------------------------------------------
# unidata_version — module-level string attribute type check
# unicodedata.zspec.zsdl verifies unidata_version > '' (non-empty)
# We verify the type is str via __class__.__name__
# ---------------------------------------------------------------------------

invariant unicodedata_extra.unidata_version.class_name:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str'"
  category: version
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true
