spec: hl3166
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (hl3166): __add__, __sub__, __mul__ dict-presence checks for hashlib types."
    - "type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "type(hashlib.blake2s(b'')) is _blake2.blake2s — distinct from HASH and blake2b."
    - "None of the hashlib types define __add__, __sub__, or __mul__ in their own __dict__."
    - "Hash objects are digest machines — they expose an update/digest API only and do not support arithmetic operations."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3166.add:
  description: "hashlib types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3166
  columns: [id, function, args, expected]
  rows:
    - ["hl3166001", operator.contains, [type(hashlib.md5()).__dict__,        "__add__"], false]
    - ["hl3166002", operator.contains, [type(hashlib.sha256()).__dict__,     "__add__"], false]
    - ["hl3166003", operator.contains, [type(hashlib.sha512()).__dict__,     "__add__"], false]
    - ["hl3166004", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__add__"], false]
    - ["hl3166005", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__add__"], false]

