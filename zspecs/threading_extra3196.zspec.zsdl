spec: th3196
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (th3196): __pow__, __lshift__, __rshift__ dict-presence checks for threading types."
    - "None of the threading types define __pow__, __lshift__, or __rshift__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3196.pow:
  description: "threading types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3196
  columns: [id, function, args, expected]
  rows:
    - ["th3196001", operator.contains, [threading.Thread.__dict__,           "__pow__"], false]
    - ["th3196002", operator.contains, [type(threading.Lock()).__dict__,     "__pow__"], false]
    - ["th3196003", operator.contains, [type(threading.RLock()).__dict__,    "__pow__"], false]
    - ["th3196004", operator.contains, [threading.Event.__dict__,            "__pow__"], false]
    - ["th3196005", operator.contains, [threading.Condition.__dict__,        "__pow__"], false]
    - ["th3196006", operator.contains, [threading.Semaphore.__dict__,        "__pow__"], false]
    - ["th3196007", operator.contains, [threading.BoundedSemaphore.__dict__, "__pow__"], false]
    - ["th3196008", operator.contains, [threading.Timer.__dict__,            "__pow__"], false]
    - ["th3196009", operator.contains, [threading.Barrier.__dict__,          "__pow__"], false]
    - ["th3196010", operator.contains, [threading.local.__dict__,            "__pow__"], false]

