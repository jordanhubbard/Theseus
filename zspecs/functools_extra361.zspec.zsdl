spec: functools_extra361
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a pure-Python decorator function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' — cache is a pure-Python function in Lib/functools.py, added in Python 3.9. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' — reduce is a builtin_function_or_method implemented in C (_functools module). Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — the C implementation lives in _functools; functools re-exports it. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' — pure-Python class decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache and functools.cache function identity
#
# functools.lru_cache.__name__ == 'lru_cache'
# functools.lru_cache.__module__ == 'functools'
# functools.lru_cache.__qualname__ == 'lru_cache'
# functools.cache.__name__ == 'cache'
# functools.cache.__module__ == 'functools'
# functools.cache.__qualname__ == 'cache'
#
# Both lru_cache and cache are pure-Python decorator functions defined in
# Lib/functools.py. cache was added in Python 3.9 as a simpler alias
# equivalent to lru_cache(maxsize=None).
# ---------------------------------------------------------------------------

table functools_extra361.lru_cache_and_cache_identity:
  description: "functools.lru_cache and functools.cache decorator function identity: __name__, __module__, __qualname__; both pure-Python functions in Lib/functools.py; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslcc361

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_eq,
       "lru_cache.__name__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a pure-Python decorator function in Lib/functools.py that wraps a function with a least-recently-used cache; its __name__ attribute is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra361"]
    - [lru_cache_module_eq,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra361"]
    - [lru_cache_qualname_eq,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a top-level function in functools; its __qualname__ equals its __name__, 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra361"]
    - [cache_name_eq,
       "cache.__name__.__eq__",
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — cache is a pure-Python function added in Python 3.9 in Lib/functools.py; it is equivalent to lru_cache(maxsize=None); its __name__ is 'cache'; str.__eq__('cache') returns True; new to extra361"]
    - [cache_module_eq,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra361"]
    - [cache_qualname_eq,
       "cache.__qualname__.__eq__",
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — cache is a top-level function in functools; its __qualname__ equals its __name__, 'cache'; str.__eq__('cache') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce and functools.total_ordering identity
#
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__module__ == '_functools'
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__module__ == 'functools'
#
# reduce is a C builtin re-exported from _functools into functools.
# Its __module__ is '_functools', not 'functools'.
# total_ordering is a pure-Python class decorator in Lib/functools.py.
# ---------------------------------------------------------------------------

table functools_extra361.reduce_and_total_ordering_identity:
  description: "functools.reduce (C builtin, __module__=='_functools') and functools.total_ordering (pure-Python decorator) identity: __name__ and __module__; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsrto361

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       "reduce.__name__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is a C builtin_function_or_method implemented in Modules/_functoolsmodule.c and re-exported through functools; its __name__ is 'reduce'; str.__eq__('reduce') returns True; new to extra361"]
    - [reduce_module_eq,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce's C implementation lives in the _functools extension module; even though functools re-exports it, its __module__ remains '_functools'; str.__eq__('_functools') returns True; new to extra361"]
    - [total_ordering_name_eq,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a pure-Python class decorator in Lib/functools.py that fills in missing comparison methods; its __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra361"]
    - [total_ordering_module_eq,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra361
# ---------------------------------------------------------------------------

invariant functools_extra361.lru_cache_name:
  description: "functools.lru_cache.__name__ == 'lru_cache' — pure-Python decorator in Lib/functools.py; new to extra361"
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra361.lru_cache_module:
  description: "functools.lru_cache.__module__ == 'functools' — defined in Lib/functools.py; new to extra361"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra361.lru_cache_qualname:
  description: "functools.lru_cache.__qualname__ == 'lru_cache' — top-level function; qualname equals name; new to extra361"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra361.cache_name:
  description: "functools.cache.__name__ == 'cache' — added in Python 3.9; equivalent to lru_cache(maxsize=None); new to extra361"
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra361.cache_module:
  description: "functools.cache.__module__ == 'functools' — defined in Lib/functools.py; new to extra361"
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra361.cache_qualname:
  description: "functools.cache.__qualname__ == 'cache' — top-level function; qualname equals name; new to extra361"
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra361.reduce_name:
  description: "functools.reduce.__name__ == 'reduce' — C builtin re-exported from _functools; new to extra361"
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra361.reduce_module:
  description: "functools.reduce.__module__ == '_functools' — C implementation in _functools; functools re-exports it but __module__ stays '_functools'; new to extra361"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra361.total_ordering_name:
  description: "functools.total_ordering.__name__ == 'total_ordering' — pure-Python class decorator in Lib/functools.py; new to extra361"
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra361.total_ordering_module:
  description: "functools.total_ordering.__module__ == 'functools' — defined in Lib/functools.py; new to extra361"
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true
