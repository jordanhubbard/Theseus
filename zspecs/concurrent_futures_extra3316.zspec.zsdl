spec: cf3316
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (cf3316): __ipow__, __ilshift__, __irshift__ dict-presence (in-place **=, <<=, >>=) for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__ipow__): all 3 concurrent.futures classes return false for __ipow__. In-place exponentiation (__ipow__, **=) is the augmented assignment variant of __pow__. concurrent.futures types define no __pow__ (confirmed false in wave 660), so __ipow__ is equally absent. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine — not a numeric type; future **= n is not a defined Python expression. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); in-place exponentiation is not defined for executor objects."
    - "Key finding (__ilshift__): all 3 concurrent.futures classes return false for __ilshift__. In-place left shift (__ilshift__, <<=) is the augmented assignment variant of __lshift__. concurrent.futures types define no __lshift__ (confirmed false in wave 660), so __ilshift__ is equally absent. concurrent.futures.Future: a state-machine result handle; future <<= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an entirely method-based API; <<= is not defined for executor objects."
    - "Key finding (__irshift__): all 3 concurrent.futures classes return false for __irshift__. In-place right shift (__irshift__, >>=) is the augmented assignment variant of __rshift__. concurrent.futures types define no __rshift__ (confirmed false in wave 660), so __irshift__ is equally absent. concurrent.futures.Future is a state-machine result handle, not an integer or bit-string type; future >>= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no in-place right-shift semantics."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, bitwise, in-place augmented assignment, or operator overloading of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — operator.contains(Cls.__dict__, '__ipow__')
#
# All 3 concurrent.futures classes return false for __ipow__.
# In-place exponentiation (__ipow__, **=) is the augmented assignment variant
#   of __pow__. concurrent.futures types define no __pow__ (wave 660), so
#   __ipow__ is equally absent.
# concurrent.futures.Future: a result-handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; future **= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an
#   entirely method-based API; in-place exponentiation is not defined for pools.
# ---------------------------------------------------------------------------

table cf3316.ipow:
  description: "concurrent.futures types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3316

  columns: [id, function, args, expected]
  rows:
    - ["cf3316001", operator.contains, [concurrent.futures.Future.__dict__,              "__ipow__"], false]
    - ["cf3316002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ipow__"], false]
    - ["cf3316003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ipow__"], false]

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — operator.contains(Cls.__dict__, '__ilshift__')
#
# All 3 concurrent.futures classes return false for __ilshift__.
# In-place left shift (__ilshift__, <<=) is the augmented assignment variant
#   of __lshift__. concurrent.futures types define no __lshift__ (wave 660),
#   so __ilshift__ is equally absent.
# concurrent.futures.Future: a state-machine result handle; future <<= n is
#   not a valid Python expression. Future manages asynchronous results through
#   callbacks and state transitions, not bitwise operators.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   in-place left shift is entirely absent from their API.
# ---------------------------------------------------------------------------

table cf3316.ilshift:
  description: "concurrent.futures types __ilshift__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3316

  columns: [id, function, args, expected]
  rows:
    - ["cf3316004", operator.contains, [concurrent.futures.Future.__dict__,              "__ilshift__"], false]
    - ["cf3316005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ilshift__"], false]
    - ["cf3316006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ilshift__"], false]

# ---------------------------------------------------------------------------
# __irshift__ dict-presence — operator.contains(Cls.__dict__, '__irshift__')
#
# All 3 concurrent.futures classes return false for __irshift__.
# In-place right shift (__irshift__, >>=) is the augmented assignment variant
#   of __rshift__. concurrent.futures types define no __rshift__ (wave 660),
#   so __irshift__ is equally absent.
# concurrent.futures.Future: a state-machine result handle, not an integer or
#   bit-string type; future >>= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: pool managers; executor >>= n is
#   not a defined Python operation.
# ---------------------------------------------------------------------------

table cf3316.irshift:
  description: "concurrent.futures types __irshift__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3316

  columns: [id, function, args, expected]
  rows:
    - ["cf3316007", operator.contains, [concurrent.futures.Future.__dict__,              "__irshift__"], false]
    - ["cf3316008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__irshift__"], false]
    - ["cf3316009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__irshift__"], false]

# ---------------------------------------------------------------------------
# combined — __ipow__, __ilshift__, __irshift__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __ipow__: false for all 3 — no in-place exponentiation defined.
# __ilshift__: false for all 3 — no in-place left shift defined.
# __irshift__: false for all 3 — no in-place right shift defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown().
#   Neither forward power/shift operators (wave 660) nor their in-place
#   augmented assignment variants appear anywhere in the concurrent.futures
#   type hierarchy.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric or bitwise type. __ipow__, __ilshift__,
#   and __irshift__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate
#   a pool of worker threads or processes; they expose only lifecycle and
#   dispatch methods. No in-place augmented assignment operator overloads
#   are defined.
# ---------------------------------------------------------------------------

table cf3316.combined:
  description: "concurrent.futures types combined __ipow__/__ilshift__/__irshift__; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3316

  columns: [id, function, args, expected]
