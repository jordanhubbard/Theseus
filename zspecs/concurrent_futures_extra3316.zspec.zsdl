    - ["cf3316011", operator.contains, [concurrent.futures.Future.__dict__,              "__ilshift__"], false]
    - ["cf3316012", operator.contains, [concurrent.futures.Future.__dict__,              "__irshift__"], false]
    - ["cf3316013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ipow__"], false]
    - ["cf3316014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ilshift__"], false]
    - ["cf3316015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__irshift__"], false]
    - ["cf3316016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ipow__"], false]
    - ["cf3316017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ilshift__"], false]
    - ["cf3316018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__irshift__"], false]
