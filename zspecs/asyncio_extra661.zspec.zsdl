spec: asyncio_extra661
backend: python_module(asyncio)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio.Task method qualnames"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queue class identities"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers additional Task method qualnames and PriorityQueue/LifoQueue/QueueEmpty/QueueFull module identity"]
  created_at: "2026-04-12T00:00:00Z"

table asyncio_extra661.task_method_qualnames:
  description: "asyncio.Task additional method __qualname__ equality checks"
  kind: python_call_eq
  category: task_method_identity
  id_prefix: as661tm
  columns: [id, function, args, expected]
  rows:
    - [as661tm001, asyncio.Task.cancel.__qualname__.__eq__, ["Task.cancel"], true]
    - [as661tm002, asyncio.Task.done.__qualname__.__eq__, ["Task.done"], true]
    - [as661tm003, asyncio.Task.result.__qualname__.__eq__, ["Task.result"], true]
    - [as661tm004, asyncio.Task.exception.__qualname__.__eq__, ["Task.exception"], true]
    - [as661tm005, asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true]
    - [as661tm006, asyncio.Task.get_name.__qualname__.__eq__, ["Task.get_name"], true]
    - [as661tm007, asyncio.Task.set_name.__qualname__.__eq__, ["Task.set_name"], true]

table asyncio_extra661.queue_class_identity:
  description: "asyncio PriorityQueue, LifoQueue, QueueEmpty, QueueFull module and qualname identity"
  kind: python_call_eq
  category: queue_class_identity
  id_prefix: as661qi
  columns: [id, function, args, expected]
  rows:
    - [as661qi001, asyncio.PriorityQueue.__qualname__.__eq__, ["PriorityQueue"], true]
    - [as661qi002, asyncio.PriorityQueue.__module__.__eq__, ["asyncio.queues"], true]
    - [as661qi003, asyncio.LifoQueue.__qualname__.__eq__, ["LifoQueue"], true]
    - [as661qi004, asyncio.LifoQueue.__module__.__eq__, ["asyncio.queues"], true]
    - [as661qi005, asyncio.QueueEmpty.__module__.__eq__, ["asyncio.queues"], true]
    - [as661qi006, asyncio.QueueFull.__module__.__eq__, ["asyncio.queues"], true]
