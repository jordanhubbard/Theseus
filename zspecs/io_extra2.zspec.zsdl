spec: io_extra2
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io.zspec.zsdl, io_extra.zspec.zsdl, and io_streams.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "io.zspec.zsdl covers: StringIO.__name__, BytesIO.__name__, SEEK_*/DEFAULT_BUFFER_SIZE values, stream read/getvalue/readline/tell/readable/writable/seekable/closed."
    - "io_extra.zspec.zsdl covers: TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata; SEEK_*/DEFAULT_BUFFER_SIZE type checks."
    - "io_streams.zspec.zsdl covers: StringIO/BytesIO __module__, read/getvalue with bytes, empty stream readable/writable."
    - "io.IOBase is the abstract base class for all I/O classes. CPython implements it in the _io C extension."
    - "io.IOBase.__name__ == 'IOBase' and io.IOBase.__module__ == '_io' (C extension)."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes for raw, buffered, and text I/O respectively."
    - "io.FileIO is the raw binary I/O implementation for file descriptors."
    - "io.BufferedReader, io.BufferedWriter are concrete buffered I/O classes for reading and writing."
    - "io.BufferedRWPair wraps a pair of raw streams for both reading and writing."
    - "io.IncrementalNewlineDecoder is a codec helper used internally by TextIOWrapper."
    - "io.IOBase.__bases__[0].__name__ == 'object' — IOBase inherits directly from the built-in object type."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase — class name and module
# ---------------------------------------------------------------------------

invariant io_extra2.IOBase.class_name:
  description: "io.IOBase.__name__ == 'IOBase'"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra2.IOBase.module:
  description: "io.IOBase.__module__ == '_io' — CPython implements IOBase in the _io C extension"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra2.IOBase.base_is_object:
  description: "io.IOBase.__bases__[0].__name__ == 'object' — IOBase inherits directly from object"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# RawIOBase — class name
# ---------------------------------------------------------------------------

invariant io_extra2.RawIOBase.class_name:
  description: "io.RawIOBase.__name__ == 'RawIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

