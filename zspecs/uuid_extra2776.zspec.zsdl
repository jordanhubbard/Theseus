spec: uuid_extra2776
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for UUID, SafeUUID."
    - "uuid_extra2746.zspec.zsdl — covers __imatmul__, __ifloordiv__, __imod__ absence for UUID, SafeUUID."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "uuid.UUID.__dict__.__contains__('__isub__') == False — UUID is an immutable identifier type; it does not define in-place subtraction; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__imul__') == False — UUID does not define in-place multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__itruediv__') == False — UUID does not define in-place true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__isub__') == False — SafeUUID (an IntEnum subclass) does not add in-place subtraction to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__imul__') == False — SafeUUID does not add in-place multiplication to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__itruediv__') == False — SafeUUID does not add in-place true division to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__dict__ — __isub__, __imul__, __itruediv__ absence
# UUID is a pure-Python class representing a universally unique identifier.
# It supports comparison operators (__eq__, __lt__, etc.) and __hash__, but
# not in-place arithmetic operators (-=, *=, /=).
# ---------------------------------------------------------------------------

table uuid_extra2776.uuid_dict_isub_imul_itruediv:
  description: "uuid.UUID.__dict__ does not contain __isub__, __imul__, or __itruediv__ — UUID defines no in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2776

  columns: [id, function, args, expected]
  rows:
    - ["uu2776-uuid-isub",     uuid.UUID.__dict__.__contains__,  ["__isub__"],     false]
    - ["uu2776-uuid-imul",     uuid.UUID.__dict__.__contains__,  ["__imul__"],     false]
    - ["uu2776-uuid-itruediv", uuid.UUID.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: uuid.SafeUUID.__dict__ — __isub__, __imul__, __itruediv__ absence
# SafeUUID is an IntEnum subclass with values -1 (unsafe) and 0 (safe).
# It does not add new in-place arithmetic operators beyond those inherited
# from IntEnum; the __dict__ check is against SafeUUID's own namespace only.
# ---------------------------------------------------------------------------

table uuid_extra2776.safeuuid_dict_isub_imul_itruediv:
  description: "uuid.SafeUUID.__dict__ does not contain __isub__, __imul__, or __itruediv__ — SafeUUID (IntEnum subclass) defines no additional in-place arithmetic operators in its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2776

  columns: [id, function, args, expected]
  rows:
    - ["uu2776-safe-isub",     uuid.SafeUUID.__dict__.__contains__,  ["__isub__"],     false]
    - ["uu2776-safe-imul",     uuid.SafeUUID.__dict__.__contains__,  ["__imul__"],     false]
    - ["uu2776-safe-itruediv", uuid.SafeUUID.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID.__dict__ — per-dunder detail with descriptions
# Explicit per-dunder rows documenting why each operator is absent.
# ---------------------------------------------------------------------------

table uuid_extra2776.uuid_dict_detail:
  description: "uuid.UUID.__dict__ in-place operator absence detail — __isub__, __imul__, and __itruediv__ are not defined because UUID is an immutable identifier type, not a numeric operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2776

  columns: [id, function, args, expected, description]
  rows:
    - ["uu2776-d-isub",     uuid.UUID.__dict__.__contains__, ["__isub__"],     false, "uuid.UUID does not support -= — UUIDs are immutable identifiers; in-place subtraction is undefined"]
    - ["uu2776-d-imul",     uuid.UUID.__dict__.__contains__, ["__imul__"],     false, "uuid.UUID does not support *= — multiplication has no meaning for a universally unique identifier"]
    - ["uu2776-d-itruediv", uuid.UUID.__dict__.__contains__, ["__itruediv__"], false, "uuid.UUID does not support /= — in-place true division is undefined for UUID objects"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — UUID and SafeUUID both lack all three dunders
# ---------------------------------------------------------------------------

table uuid_extra2776.all_types_all_dunders_absent:
  description: "uuid.UUID and uuid.SafeUUID both lack __isub__, __imul__, and __itruediv__ in __dict__ — neither uuid type defines in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2776

  columns: [id, function, args, expected]
  rows:
    - ["uu2776-x-uuid-isub",     uuid.UUID.__dict__.__contains__,     ["__isub__"],     false]
    - ["uu2776-x-uuid-imul",     uuid.UUID.__dict__.__contains__,     ["__imul__"],     false]
    - ["uu2776-x-uuid-itruediv", uuid.UUID.__dict__.__contains__,     ["__itruediv__"], false]
    - ["uu2776-x-safe-isub",     uuid.SafeUUID.__dict__.__contains__,  ["__isub__"],     false]
    - ["uu2776-x-safe-imul",     uuid.SafeUUID.__dict__.__contains__,  ["__imul__"],     false]
    - ["uu2776-x-safe-itruediv", uuid.SafeUUID.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra2776.uuid_no_isub:
  description: "uuid.UUID.__dict__.__contains__('__isub__') == False — UUID does not define the -= operator; UUID objects are immutable (the int field is fixed at construction); confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant uuid_extra2776.uuid_no_imul:
  description: "uuid.UUID.__dict__.__contains__('__imul__') == False — UUID does not define the *= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant uuid_extra2776.uuid_no_itruediv:
  description: "uuid.UUID.__dict__.__contains__('__itruediv__') == False — UUID does not define the /= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

invariant uuid_extra2776.safeuuid_no_isub:
  description: "uuid.SafeUUID.__dict__.__contains__('__isub__') == False — SafeUUID is an IntEnum subclass and does not add __isub__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant uuid_extra2776.safeuuid_no_imul:
  description: "uuid.SafeUUID.__dict__.__contains__('__imul__') == False — SafeUUID does not add __imul__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant uuid_extra2776.safeuuid_no_itruediv:
  description: "uuid.SafeUUID.__dict__.__contains__('__itruediv__') == False — SafeUUID does not add __itruediv__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false
