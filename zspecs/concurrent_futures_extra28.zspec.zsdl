spec: concurrent_futures_extra28
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra27.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, thread/process submodule __name__, class __module__/__name__/__len__() tables, ThreadPoolExecutor submit/shutdown qualname lens, ProcessPoolExecutor submit/shutdown qualname lens, Executor.map qualname len, Future method qualname lens for result/add_done_callback/cancel/done/exception, CancelledError/TimeoutError/BrokenExecutor __bases__[0].__name__ and __mro__.__len__()."
    - "This spec covers: concurrent.futures.__all__.__len__() and __class__.__name__.__len__(); class __dict__.__class__.__name__.__len__() for Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor/BrokenExecutor/CancelledError; Future method __qualname__.__len__() for set_result/set_exception/running/set_running_or_notify_cancel; as_completed/__module__.__len__() and wait/__module__.__len__()."
    - "concurrent.futures.__all__ is a list — __class__.__name__ == 'list', __len__() == 4."
    - "concurrent.futures.__all__.__len__() == 14 — the module exports 14 public names."
    - "Class __dict__ is a mappingproxy — __class__.__name__ == 'mappingproxy', __len__() == 12."
    - "Future.set_result.__qualname__ == 'Future.set_result' — length 17."
    - "Future.set_exception.__qualname__ == 'Future.set_exception' — length 20."
    - "Future.running.__qualname__ == 'Future.running' — length 14."
    - "Future.set_running_or_notify_cancel.__qualname__ == 'Future.set_running_or_notify_cancel' — length 35."
    - "as_completed.__module__ == 'concurrent.futures._base' — length 24."
    - "wait.__module__ == 'concurrent.futures._base' — length 24."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ metadata — extra28 namespace
#
# concurrent.futures.__all__ is a list (not a tuple).
# __class__.__name__ == 'list' (4 chars); __len__() == 14.
# This is a novel angle: prior specs have not measured __all__ metadata
# for this module.
# ---------------------------------------------------------------------------

table concurrent_futures_extra28.all_metadata:
  description: "concurrent.futures.__all__ metadata: list type name length and export count in extra28 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: allmetadata28

  columns: [id, function, args, expected]
  rows:
    - [all_class_name_len, concurrent.futures.__all__.__class__.__name__.__len__, [], 4]
    - [all_len,            concurrent.futures.__all__.__len__,                    [], 14]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() table — extra28 namespace
#
# All pure-Python classes in concurrent.futures have __dict__ of type
# mappingproxy — 'mappingproxy' has 12 characters. This holds for:
# Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor, BrokenExecutor,
# CancelledError. The uniform length of 12 reflects standard Python
# class mechanics; no prior spec has measured this for concurrent.futures.
# ---------------------------------------------------------------------------

table concurrent_futures_extra28.class_dict_class_name_lengths:
  description: "concurrent.futures class __dict__.__class__.__name__.__len__() for key classes in extra28 namespace — all equal 12 (mappingproxy)"
  kind: python_call_eq
  category: class_structure
  id_prefix: classdictnamelen28

  columns: [id, function, args, expected]
  rows:
    - [Future,              Future.__dict__.__class__.__name__.__len__,              [], 12]
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__dict__.__class__.__name__.__len__,  [], 12]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__dict__.__class__.__name__.__len__, [], 12]
    - [Executor,            Executor.__dict__.__class__.__name__.__len__,            [], 12]
    - [BrokenExecutor,      BrokenExecutor.__dict__.__class__.__name__.__len__,      [], 12]
    - [CancelledError,      CancelledError.__dict__.__class__.__name__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# Future internal/lifecycle method __qualname__ length table — extra28 namespace
#
# Prior specs covered public consumer methods (result, add_done_callback,
# cancel, done, exception). This table adds the internal/lifecycle methods:
#   Future.set_result.__qualname__                  == 'Future.set_result'                  (17)
#   Future.set_exception.__qualname__               == 'Future.set_exception'               (20)
#   Future.running.__qualname__                     == 'Future.running'                     (14)
#   Future.set_running_or_notify_cancel.__qualname__ == 'Future.set_running_or_notify_cancel' (35)
# The set_running_or_notify_cancel method has the longest __qualname__ of any
# Future method, reflecting its internal state-transition semantics.
# ---------------------------------------------------------------------------

table concurrent_futures_extra28.future_internal_method_qualname_lengths:
  description: "concurrent.futures.Future internal/lifecycle method __qualname__ lengths in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futintmqualnamelen28

  columns: [id, function, args, expected]
  rows:
    - [set_result,                  Future.set_result.__qualname__.__len__,                  [], 17]
    - [set_exception,               Future.set_exception.__qualname__.__len__,               [], 20]
    - [running,                     Future.running.__qualname__.__len__,                     [], 14]
    - [set_running_or_notify_cancel, Future.set_running_or_notify_cancel.__qualname__.__len__, [], 35]

# ---------------------------------------------------------------------------
# Function __module__ length table — extra28 namespace
#
# as_completed and wait are both defined in concurrent.futures._base.
# Their __module__ is 'concurrent.futures._base' — 24 characters.
# This length reflects the private _base submodule path. Prior specs have
# not measured __module__.__len__() for these two utility functions.
# ---------------------------------------------------------------------------

table concurrent_futures_extra28.function_module_lengths:
  description: "concurrent.futures utility function __module__.__len__() for as_completed/wait in extra28 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: fnmodulelen28

  columns: [id, function, args, expected]
  rows:
    - [as_completed, as_completed.__module__.__len__, [], 24]
    - [wait,         wait.__module__.__len__,         [], 24]

# ---------------------------------------------------------------------------
# Future.set_result qualname string equality — extra28 standalone invariant
#
# Confirms the full __qualname__ string 'Future.set_result' for the
# set_result method, complementing the length check in the table above.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra28.Future.set_result_qualname_eq:
  description: "concurrent.futures.Future.set_result.__qualname__ == 'Future.set_result' — method defined on Future"
  category: method_names
  kind: python_call_eq
  function: Future.set_result.__qualname__.__eq__
  args: ["Future.set_result"]
  expected: true

# ---------------------------------------------------------------------------
# Future.set_running_or_notify_cancel qualname length — extra28 standalone
#
# set_running_or_notify_cancel is Future's longest method name (35 chars).
# It is an internal lifecycle method for executors to update state.
# This invariant confirms the __qualname__.__len__() == 35 explicitly.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra28.Future.set_running_or_notify_cancel_qualname_len:
  description: "concurrent.futures.Future.set_running_or_notify_cancel.__qualname__.__len__() == 35 — longest Future method qualname"
  category: method_names
  kind: python_call_eq
  function: Future.set_running_or_notify_cancel.__qualname__.__len__
  args: []
  expected: 35

invariant concurrent_futures_extra28.all_len:
  description: "concurrent.futures.__all__.__len__() == 14 — the module exports 14 public names"
  category: module_structure
  kind: python_call_eq
  function: concurrent.futures.__all__.__len__
  args: []
  expected: 14
