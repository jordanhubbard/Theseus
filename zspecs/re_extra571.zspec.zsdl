spec: re_extra571
version: ">=3.9"
backend: python_module(re)
docs: "Cover re module exception and class identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module class, exception, and flag documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that re module types, exceptions, and flags have expected class names, qualnames, modules, and doc types"
  created_at: "2026-04-12T00:00:00Z"

table re_extra571.class_name_identity:
  description: "Verify that re module classes and exceptions have expected __class__.__name__ values"
  kind: python_call_eq
  category: class_identity
  id_prefix: REEX571CN
  columns: [id, function, args, expected]
  rows:
    - [REEX571CN001, re.error.__class__.__name__.__eq__, ["type"], true]
    - [REEX571CN002, re.Pattern.__class__.__name__.__eq__, ["type"], true]
    - [REEX571CN003, re.Match.__class__.__name__.__eq__, ["type"], true]
    - [REEX571CN004, re.RegexFlag.__class__.__name__.__eq__, ["EnumType"], true]
table re_extra571.qualname_identity:
  description: "Verify that re module classes have correct __qualname__ values"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: REEX571QN
  columns: [id, function, args, expected]
  rows:
    - [REEX571QN001, re.error.__qualname__.__eq__, ["error"], true]
    - [REEX571QN002, re.Pattern.__qualname__.__eq__, ["Pattern"], true]
    - [REEX571QN003, re.Match.__qualname__.__eq__, ["Match"], true]
    - [REEX571QN004, re.RegexFlag.__qualname__.__eq__, ["RegexFlag"], true]
table re_extra571.module_identity:
  description: "Verify that re module classes report correct __module__ values"
  kind: python_call_eq
  category: module_identity
  id_prefix: REEX571MI
  columns: [id, function, args, expected]
  rows:
    - [REEX571MI001, re.error.__module__.__eq__, ["re"], true]
    - [REEX571MI002, re.RegexFlag.__module__.__eq__, ["re"], true]
table re_extra571.doc_type_identity:
  description: "Verify that re.error has a str __doc__"
  kind: python_call_eq
  category: doc_identity
  id_prefix: REEX571DI
  columns: [id, function, args, expected]
  rows:
    - [REEX571DI001, re.error.__doc__.__class__.__name__.__eq__, ["str"], true]