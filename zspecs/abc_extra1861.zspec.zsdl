spec: abc_extra1861
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__) and in-place operators (__iadd__/__imul__/__ior__)."
    - "abc.ABC is a simple helper class with ABCMeta as its metaclass; no bitwise or in-place operator dunders in own __dict__."
    - "abc.ABCMeta is the metaclass for ABCs; no bitwise or in-place operator dunders in own __dict__."
    - "abc.abstractmethod is a decorator function (type 'function'); no bitwise or in-place operator dunders in own __dict__."
    - "abc.abstractclassmethod and abc.abstractstaticmethod were removed in Python 3.11."
    - "abc.abstractproperty is deprecated but still present in Python 3.14 as of 2026-04-12."
    - "abc.abstractmethod.__call__ is present (it is callable); abc.abstractmethod.__get__ is present (descriptor protocol)."
    - "abc.abstractmethod.__init__ is present (function objects have __init__); abc.abstractmethod.__wrapped__ is absent."
    - "abc.abstractmethod.__doc__ and __module__ are present as standard function attributes."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators absent from abc class own __dict__
# ---------------------------------------------------------------------------

table abc_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from abc class own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: ab1861

  columns: [id, function, args, expected]
  rows:
    - ["ab1861001", abc.ABC.__dict__.__contains__,            ["__or__"],   false]
    - ["ab1861002", abc.ABC.__dict__.__contains__,            ["__and__"],  false]
    - ["ab1861003", abc.ABC.__dict__.__contains__,            ["__xor__"],  false]
    - ["ab1861004", abc.ABCMeta.__dict__.__contains__,        ["__or__"],   false]
    - ["ab1861005", abc.ABCMeta.__dict__.__contains__,        ["__and__"],  false]
    - ["ab1861006", abc.abstractmethod.__dict__.__contains__, ["__or__"],   false]
    - ["ab1861007", abc.abstractmethod.__dict__.__contains__, ["__and__"],  false]
    - ["ab1861008", abc.abstractmethod.__dict__.__contains__, ["__xor__"],  false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators absent from abc class own __dict__
# ---------------------------------------------------------------------------

table abc_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from abc class own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: ab1861

  columns: [id, function, args, expected]
  rows:
    - ["ab1861009", abc.ABC.__dict__.__contains__,            ["__iadd__"], false]
    - ["ab1861010", abc.ABC.__dict__.__contains__,            ["__ior__"],  false]
    - ["ab1861011", abc.ABCMeta.__dict__.__contains__,        ["__iadd__"], false]
    - ["ab1861012", abc.ABCMeta.__dict__.__contains__,        ["__ior__"],  false]
    - ["ab1861013", abc.abstractmethod.__dict__.__contains__, ["__iadd__"], false]
    - ["ab1861014", abc.abstractmethod.__dict__.__contains__, ["__ior__"],  false]
    - ["ab1861015", abc.abstractmethod.__dict__.__contains__, ["__imul__"], false]
    - ["ab1861016", abc.ABC.__dict__.__contains__,            ["__imul__"], false]

# ---------------------------------------------------------------------------
# Table 3: abstractmethod decorator attributes and abc module contents
# ---------------------------------------------------------------------------

table abc_extra1861.abstractmethod_decorator_attrs:
  description: "abc module contents and abc.abstractmethod function attributes"
  kind: python_call_eq
  category: module_contents
  id_prefix: ab1861

  columns: [id, function, args, expected]
  rows:
    - ["ab1861017", abc.__dict__.__contains__,            ["abstractmethod"],       true]
    - ["ab1861018", abc.__dict__.__contains__,            ["abstractclassmethod"],  false]
    - ["ab1861019", abc.__dict__.__contains__,            ["abstractstaticmethod"], false]
    - ["ab1861020", abc.__dict__.__contains__,            ["abstractproperty"],     true]
    - ["ab1861021", abc.abstractmethod.__dict__.__contains__, ["__call__"],         true]
    - ["ab1861022", abc.abstractmethod.__dict__.__contains__, ["__get__"],          true]
    - ["ab1861023", abc.abstractmethod.__dict__.__contains__, ["__init__"],         true]
    - ["ab1861024", abc.abstractmethod.__dict__.__contains__, ["__wrapped__"],      false]
    - ["ab1861025", abc.abstractmethod.__dict__.__contains__, ["__doc__"],          true]
    - ["ab1861026", abc.abstractmethod.__dict__.__contains__, ["__module__"],       true]
