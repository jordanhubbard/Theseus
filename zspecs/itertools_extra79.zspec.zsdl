spec: itertools_extra79
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra78.zspec.zsdl."
    - "This spec covers: itertools C type __doc__.__class__.__name__ and __new__ presence for combinations/combinations_with_replacement/islice/pairwise/accumulate/product/chain/cycle (Wave 244)."
    - "extra78 covered: repeat/starmap/compress/dropwhile/takewhile/zip_longest/filterfalse/count/groupby/permutations."
    - "combinations.__dict__.__contains__('__new__') == True — C types define __new__ in their class dict. Verified with Python 3.14.3."
    - "combinations_with_replacement.__dict__.__contains__('__new__') == True — verified with Python 3.14.3."
    - "islice.__dict__.__contains__('__new__') == True — verified with Python 3.14.3."
    - "pairwise.__dict__.__contains__('__new__') == True — pairwise added in Python 3.10; verified with Python 3.14.3."
    - "accumulate.__dict__.__contains__('__new__') == True — verified with Python 3.14.3."
    - "product.__dict__.__contains__('__new__') == True — verified with Python 3.14.3."
    - "chain.__dict__.__contains__('__new__') == True — verified with Python 3.14.3."
    - "cycle.__dict__.__contains__('__new__') == True — verified with Python 3.14.3."
    - "combinations.__doc__.__class__.__name__ == 'str' — all itertools C type __doc__ strings are plain str objects. Verified with Python 3.14.3."
    - "combinations_with_replacement.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "islice.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "pairwise.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "accumulate.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "product.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "chain.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "cycle.__doc__.__class__.__name__ == 'str' — verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# combinations and combinations_with_replacement __new__ presence + __doc__ class — extra79
#
# Wave 244 theme: remaining itertools C types __dict__ __new__ presence.
#
# itertools.combinations.__dict__.__contains__('__new__')                   == True
# itertools.combinations.__doc__.__class__.__name__                         == 'str'
# itertools.combinations_with_replacement.__dict__.__contains__('__new__')  == True
# itertools.combinations_with_replacement.__doc__.__class__.__name__         == 'str'
#
# No prior itertools spec checks combinations/combinations_with_replacement via itrtoolsextra79. New to extra79.
# ---------------------------------------------------------------------------

table itertools_extra79.combinations_cwr_dict:
  description: "combinations/__dict__.__contains__('__new__')==True, __doc__.__class__.__name__=='str'; combinations_with_replacement same; wave 244 remaining itertools C type __dict__ content; new to extra79"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra79

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_dict_contains_new,
       combinations.__dict__.__contains__,
       ["__new__"],
       true,
       "itertools.combinations.__dict__.__contains__('__new__') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c; C types define __new__ in their class dict to handle instance creation; mappingproxy.__contains__('__new__') returns True; no prior itertools spec checks combinations.__dict__.__contains__('__new__') via itrtoolsextra79; new to extra79"]
    - [combinations_doc_class_name_eq_str,
       combinations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__name__.__eq__('str') == True — combinations is a C extension type whose docstring is a plain Python str object; __doc__.__class__.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks combinations.__doc__.__class__.__name__ via itrtoolsextra79; new to extra79"]
    - [combinations_with_replacement_dict_contains_new,
       combinations_with_replacement.__dict__.__contains__,
       ["__new__"],
       true,
       "itertools.combinations_with_replacement.__dict__.__contains__('__new__') == True — combinations_with_replacement is a C extension type defined in Modules/itertoolsmodule.c; C types define __new__ in their class dict to handle instance creation; mappingproxy.__contains__('__new__') returns True; no prior itertools spec checks combinations_with_replacement.__dict__.__contains__('__new__') via itrtoolsextra79; new to extra79"]
    - [combinations_with_replacement_doc_class_name_eq_str,
       combinations_with_replacement.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations_with_replacement.__doc__.__class__.__name__.__eq__('str') == True — combinations_with_replacement is a C extension type whose docstring is a plain Python str object; __doc__.__class__.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks combinations_with_replacement.__doc__.__class__.__name__ via itrtoolsextra79; new to extra79"]

