invariant itertools_extra79.combinations_dict_contains_new:
  description: "itertools.combinations.__dict__.__contains__('__new__') == True — combinations C type class dict contains __new__; wave 244 combinations __dict__ content; new to extra79"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__new__"]
  expected: true

