spec: threading_extra452
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module function-level identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers current_thread, main_thread, active_count, enumerate, settrace, setprofile, and local identity"
    - "threading.local.__module__ is '_thread' (C-level implementation)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra452.function_name_identity:
  description: "threading module function __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: tname

  columns: [id, function, args, expected]
  rows:
    - [tname001, threading.current_thread.__name__.__eq__, ["current_thread"], true]
    - [tname002, threading.main_thread.__name__.__eq__, ["main_thread"], true]
    - [tname003, threading.active_count.__name__.__eq__, ["active_count"], true]
    - [tname004, threading.enumerate.__name__.__eq__, ["enumerate"], true]
    - [tname005, threading.settrace.__name__.__eq__, ["settrace"], true]
    - [tname006, threading.setprofile.__name__.__eq__, ["setprofile"], true]
    - [tname007, threading.local.__name__.__eq__, ["local"], true]

table threading_extra452.function_module_identity:
  description: "threading module function __module__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: tmod

  columns: [id, function, args, expected]
  rows:
    - [tmod001, threading.current_thread.__module__.__eq__, ["threading"], true]
    - [tmod002, threading.main_thread.__module__.__eq__, ["threading"], true]
    - [tmod003, threading.active_count.__module__.__eq__, ["threading"], true]
    - [tmod004, threading.enumerate.__module__.__eq__, ["threading"], true]
    - [tmod005, threading.settrace.__module__.__eq__, ["threading"], true]
    - [tmod006, threading.local.__module__.__eq__, ["_thread"], true]

table threading_extra452.local_bases_identity:
  description: "threading.local class __bases__ identity check"
  kind: python_call_eq
  category: identity
  id_prefix: tbas

  columns: [id, function, args, expected]
  rows:
    - [tbas001, "threading.local.__bases__[0].__name__.__eq__", ["object"], true]
