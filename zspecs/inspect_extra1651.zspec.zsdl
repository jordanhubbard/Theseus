spec: inspect_extra1651
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__ class creation hook"
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are pure Python classes"
    - "none of them define __init_subclass__ in their own __dict__"
    - "none define __set_name__ (they are not descriptors)"
    - "none define __class_getitem__ (they do not support generic alias syntax)"
    - "the inspect module dict contains a rich set of predicate and utility functions"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: inspect classes do not define __init_subclass__ in their own
# __dict__. Parameter, Signature, and BoundArguments are plain Python classes
# used for introspection; they carry no class creation hooks.
# ---------------------------------------------------------------------------

table inspect_extra1651.classes_no_init_subclass:
  description: "inspect classes do not define __init_subclass__, __set_name__, or __subclasshook__ in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1651ni

  columns: [id, function, args, expected]
  rows:
    - ["in1651ni001", "inspect.Parameter.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["in1651ni002", "inspect.Signature.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["in1651ni003", "inspect.BoundArguments.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in1651ni004", "object.__dict__.__contains__",                 ["__init_subclass__"], true]
    - ["in1651ni005", "inspect.Parameter.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["in1651ni006", "inspect.Signature.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["in1651ni007", "inspect.BoundArguments.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["in1651ni008", "inspect.Parameter.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["in1651ni009", "inspect.Signature.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["in1651ni010", "inspect.BoundArguments.__dict__.__contains__", ["__instancecheck__"], false]
    - ["in1651ni011", "inspect.Parameter.__dict__.__contains__",     ["__subclasscheck__"], false]
    - ["in1651ni012", "inspect.Signature.__dict__.__contains__",     ["__subclasscheck__"], false]
    - ["in1651ni013", "inspect.BoundArguments.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["in1651ni014", "inspect.Parameter.__dict__.__contains__",     ["__init__"],          true]
    - ["in1651ni015", "inspect.Signature.__dict__.__contains__",     ["__init__"],          true]
    - ["in1651ni016", "inspect.BoundArguments.__dict__.__contains__", ["__init__"],          true]
    - ["in1651ni017", "inspect.Parameter.__dict__.__contains__",     ["__repr__"],          true]
    - ["in1651ni018", "inspect.Signature.__dict__.__contains__",     ["__repr__"],          true]
    - ["in1651ni019", "inspect.BoundArguments.__dict__.__contains__", ["__repr__"],          true]
    - ["in1651ni020", "inspect.Parameter.__dict__.__contains__",     ["__eq__"],            true]
    - ["in1651ni021", "inspect.Signature.__dict__.__contains__",     ["__eq__"],            true]
    - ["in1651ni022", "inspect.BoundArguments.__dict__.__contains__", ["__eq__"],            true]
    - ["in1651ni023", "inspect.Parameter.__dict__.__contains__",     ["__hash__"],          true]
    - ["in1651ni024", "inspect.Signature.__dict__.__contains__",     ["__hash__"],          true]
    - ["in1651ni025", "inspect.BoundArguments.__dict__.__contains__", ["__hash__"],          true]

# ---------------------------------------------------------------------------
# Table 2: __class_getitem__ and __set_name__ absence for inspect classes.
# These are not generic types and not descriptors; they do not define either
# of these dunder methods in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra1651.class_getitem_and_set_name:
  description: "inspect classes do not define __class_getitem__ or __set_name__ in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1651cg

  columns: [id, function, args, expected]
  rows:
    - ["in1651cg001", "inspect.Parameter.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["in1651cg002", "inspect.Signature.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["in1651cg003", "inspect.BoundArguments.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in1651cg004", "inspect.Parameter.__dict__.__contains__",      ["__set_name__"],      false]
    - ["in1651cg005", "inspect.Signature.__dict__.__contains__",      ["__set_name__"],      false]
    - ["in1651cg006", "inspect.BoundArguments.__dict__.__contains__", ["__set_name__"],      false]
    - ["in1651cg007", "inspect.Parameter.__dict__.__contains__",      ["__get__"],           false]
    - ["in1651cg008", "inspect.Signature.__dict__.__contains__",      ["__get__"],           false]
    - ["in1651cg009", "inspect.BoundArguments.__dict__.__contains__", ["__get__"],           false]
    - ["in1651cg010", "inspect.Parameter.__dict__.__contains__",      ["__set__"],           false]
    - ["in1651cg011", "inspect.Signature.__dict__.__contains__",      ["__set__"],           false]
    - ["in1651cg012", "inspect.BoundArguments.__dict__.__contains__", ["__set__"],           false]
    - ["in1651cg013", "inspect.Parameter.__dict__.__contains__",      ["kind"],              true]
    - ["in1651cg014", "inspect.Parameter.__dict__.__contains__",      ["annotation"],        true]
    - ["in1651cg015", "inspect.Parameter.__dict__.__contains__",      ["default"],           true]
    - ["in1651cg016", "inspect.Parameter.__dict__.__contains__",      ["replace"],           true]
    - ["in1651cg017", "inspect.Signature.__dict__.__contains__",      ["parameters"],        true]
    - ["in1651cg018", "inspect.Signature.__dict__.__contains__",      ["replace"],           true]
    - ["in1651cg019", "inspect.Signature.__dict__.__contains__",      ["bind"],              true]
    - ["in1651cg020", "inspect.Signature.__dict__.__contains__",      ["bind_partial"],      true]
    - ["in1651cg021", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"],    true]
    - ["in1651cg022", "inspect.BoundArguments.__dict__.__contains__", ["args"],              true]
    - ["in1651cg023", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"],            true]
    - ["in1651cg024", "inspect.Parameter.__dict__.__contains__",      ["POSITIONAL_ONLY"],   true]
    - ["in1651cg025", "inspect.Parameter.__dict__.__contains__",      ["KEYWORD_ONLY"],      true]

# ---------------------------------------------------------------------------
# Table 3: inspect module-level function presence.
# The inspect module provides a comprehensive set of introspection utilities.
# All of these live in inspect.__dict__ as module-level names.
# ---------------------------------------------------------------------------

table inspect_extra1651.module_function_presence:
  description: "inspect module-level function and attribute presence in inspect.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1651mp

  columns: [id, function, args, expected]
  rows:
    - ["in1651mp001", "inspect.__dict__.__contains__", ["signature"],             true]
    - ["in1651mp002", "inspect.__dict__.__contains__", ["getmembers"],            true]
    - ["in1651mp003", "inspect.__dict__.__contains__", ["isclass"],               true]
    - ["in1651mp004", "inspect.__dict__.__contains__", ["isfunction"],            true]
    - ["in1651mp005", "inspect.__dict__.__contains__", ["ismethod"],              true]
    - ["in1651mp006", "inspect.__dict__.__contains__", ["ismodule"],              true]
    - ["in1651mp007", "inspect.__dict__.__contains__", ["isgenerator"],           true]
    - ["in1651mp008", "inspect.__dict__.__contains__", ["isgeneratorfunction"],   true]
    - ["in1651mp009", "inspect.__dict__.__contains__", ["iscoroutinefunction"],   true]
    - ["in1651mp010", "inspect.__dict__.__contains__", ["isasyncgenfunction"],    true]
    - ["in1651mp011", "inspect.__dict__.__contains__", ["isbuiltin"],             true]
    - ["in1651mp012", "inspect.__dict__.__contains__", ["isframe"],               true]
    - ["in1651mp013", "inspect.__dict__.__contains__", ["iscode"],                true]
    - ["in1651mp014", "inspect.__dict__.__contains__", ["isroutine"],             true]
    - ["in1651mp015", "inspect.__dict__.__contains__", ["stack"],                 true]
    - ["in1651mp016", "inspect.__dict__.__contains__", ["getfile"],               true]
    - ["in1651mp017", "inspect.__dict__.__contains__", ["getsource"],             true]
    - ["in1651mp018", "inspect.__dict__.__contains__", ["getmro"],                true]
    - ["in1651mp019", "inspect.__dict__.__contains__", ["getfullargspec"],        true]
    - ["in1651mp020", "inspect.__dict__.__contains__", ["getdoc"],                true]
    - ["in1651mp021", "inspect.__dict__.__contains__", ["getcomments"],           true]
    - ["in1651mp022", "inspect.__dict__.__contains__", ["getlineno"],             true]
    - ["in1651mp023", "inspect.__dict__.__contains__", ["ismethoddescriptor"],    true]
    - ["in1651mp024", "inspect.__dict__.__contains__", ["isdatadescriptor"],      true]
    - ["in1651mp025", "inspect.__dict__.__contains__", ["isabstract"],            true]
    - ["in1651mp026", "inspect.__dict__.__contains__", ["isawaitable"],           true]
    - ["in1651mp027", "inspect.__dict__.__contains__", ["iscoroutine"],           true]
    - ["in1651mp028", "inspect.__dict__.__contains__", ["isasyncgen"],            true]
    - ["in1651mp029", "inspect.__dict__.__contains__", ["ismethodwrapper"],       true]
    - ["in1651mp030", "inspect.__dict__.__contains__", ["getmodule"],             true]
