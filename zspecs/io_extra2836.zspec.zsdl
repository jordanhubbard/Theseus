spec: io_extra2836
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2821.zspec.zsdl — wave 635 predecessor (covered __radd__, __rsub__, __rmul__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "io classes are I/O stream objects, not numeric types — none define reflected division or modulo operators."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase do NOT define __rtruediv__, __rfloordiv__, or __rmod__."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these reflected operators."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper also absent for all three."
    - "Absence is consistent across all 11 io classes tested — io streams have no arithmetic semantics."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rtruediv__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io_extra2836.rtruediv_protocol:
  description: "__rtruediv__ is absent from all io class __dict__s — io streams are not numeric types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2836

  columns: [id, function, args, expected]
  rows:
    - ["io2836001", "io.IOBase.__dict__.__contains__",         ["__rtruediv__"], false]
    - ["io2836002", "io.RawIOBase.__dict__.__contains__",      ["__rtruediv__"], false]
    - ["io2836003", "io.BufferedIOBase.__dict__.__contains__", ["__rtruediv__"], false]
    - ["io2836004", "io.TextIOBase.__dict__.__contains__",     ["__rtruediv__"], false]
    - ["io2836005", "io.BytesIO.__dict__.__contains__",        ["__rtruediv__"], false]
    - ["io2836006", "io.StringIO.__dict__.__contains__",       ["__rtruediv__"], false]
    - ["io2836007", "io.FileIO.__dict__.__contains__",         ["__rtruediv__"], false]
    - ["io2836008", "io.BufferedReader.__dict__.__contains__", ["__rtruediv__"], false]
    - ["io2836009", "io.BufferedWriter.__dict__.__contains__", ["__rtruediv__"], false]
    - ["io2836010", "io.BufferedRandom.__dict__.__contains__", ["__rtruediv__"], false]
    - ["io2836011", "io.TextIOWrapper.__dict__.__contains__",  ["__rtruediv__"], false]

