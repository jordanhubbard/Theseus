spec: concurrent_futures_extra284
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Future and Executor class method identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "All Future method qualnames verified as 'Future.<method>' (not 'object.<method>')"
    - "Executor.submit raises NotImplementedError when called on base class"
    - "All qualnames verified on Python 3.14.4"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra284.future_method_qualnames:
  description: "__qualname__ attribute of concurrent.futures.Future instance methods"
  kind: python_call_eq
  category: identity
  id_prefix: cfqual

  columns: [id, function, args, expected, description]
  rows:
    - [cfqual001, concurrent.futures.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true, "Future.cancel qualname"]
    - [cfqual002, concurrent.futures.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true, "Future.cancelled qualname"]
    - [cfqual003, concurrent.futures.Future.running.__qualname__.__eq__, ["Future.running"], true, "Future.running qualname"]
    - [cfqual004, concurrent.futures.Future.done.__qualname__.__eq__, ["Future.done"], true, "Future.done qualname"]
    - [cfqual005, concurrent.futures.Future.result.__qualname__.__eq__, ["Future.result"], true, "Future.result qualname"]
    - [cfqual006, concurrent.futures.Future.exception.__qualname__.__eq__, ["Future.exception"], true, "Future.exception qualname"]
    - [cfqual007, concurrent.futures.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true, "Future.add_done_callback qualname"]

table concurrent_futures_extra284.future_set_and_executor_qualnames:
  description: "__qualname__ of Future set methods and Executor base class methods"
  kind: python_call_eq
  category: identity
  id_prefix: cfexec

  columns: [id, function, args, expected, description]
  rows:
    - [cfexec001, concurrent.futures.Future.set_result.__qualname__.__eq__, ["Future.set_result"], true, "Future.set_result qualname"]
    - [cfexec002, concurrent.futures.Future.set_exception.__qualname__.__eq__, ["Future.set_exception"], true, "Future.set_exception qualname"]
    - [cfexec003, concurrent.futures.Executor.submit.__qualname__.__eq__, ["Executor.submit"], true, "Executor.submit qualname"]
    - [cfexec004, concurrent.futures.Executor.map.__qualname__.__eq__, ["Executor.map"], true, "Executor.map qualname"]
    - [cfexec005, concurrent.futures.Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true, "Executor.shutdown qualname"]

invariant concurrent_futures_extra284.future_cancel_qualname:
  description: "Future.cancel qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra284.future_result_qualname:
  description: "Future.result qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra284.executor_submit_qualname:
  description: "Executor.submit qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true
