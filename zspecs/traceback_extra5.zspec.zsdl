spec: traceback_extra5
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl, traceback_extra.zspec.zsdl, traceback_extra2.zspec.zsdl, traceback_extra3.zspec.zsdl, and traceback_extra4.zspec.zsdl."
    - "Prior specs cover: __name__ (traceback.zspec + traceback_extra4), __module__ (traceback_extra2 + traceback_extra3), __bases__ hierarchy (traceback_extra2 + traceback_extra3)."
    - "This spec adds __qualname__ checks for traceback classes and functions."
    - "For module-level functions, __qualname__ == __name__ (no enclosing class or function)."
    - "traceback.TracebackException.__qualname__ == 'TracebackException'."
    - "traceback.StackSummary.__qualname__ == 'StackSummary'."
    - "traceback.FrameSummary.__qualname__ == 'FrameSummary'."
    - "traceback.print_exc.__qualname__ == 'print_exc'."
    - "traceback.format_exc.__qualname__ == 'format_exc'."
    - "traceback.format_tb.__qualname__ == 'format_tb'."
    - "traceback.print_tb.__qualname__ == 'print_tb'."
    - "traceback.extract_tb.__qualname__ == 'extract_tb'."
    - "traceback.extract_stack.__qualname__ == 'extract_stack'."
    - "traceback.format_stack.__qualname__ == 'format_stack'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ checks
# Prior specs cover __name__ and __module__ for these classes.
# __qualname__ == __name__ for top-level class definitions.
# ---------------------------------------------------------------------------

table traceback_extra5.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__qualname__.__eq__, ["TracebackException"], true]
    - [StackSummary,       StackSummary.__qualname__.__eq__,       ["StackSummary"],       true]
    - [FrameSummary,       FrameSummary.__qualname__.__eq__,       ["FrameSummary"],       true]

# ---------------------------------------------------------------------------
# Function __qualname__ checks
# Module-level functions: __qualname__ == __name__ (no enclosing scope).
# Prior specs cover __name__ and __module__ for these functions.
# ---------------------------------------------------------------------------

table traceback_extra5.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [print_exc,    print_exc.__qualname__.__eq__,    ["print_exc"],    true]
    - [format_exc,   format_exc.__qualname__.__eq__,   ["format_exc"],   true]
    - [format_tb,    format_tb.__qualname__.__eq__,    ["format_tb"],    true]
    - [print_tb,     print_tb.__qualname__.__eq__,     ["print_tb"],     true]
    - [extract_tb,   extract_tb.__qualname__.__eq__,   ["extract_tb"],   true]
    - [extract_stack, extract_stack.__qualname__.__eq__, ["extract_stack"], true]
    - [format_stack, format_stack.__qualname__.__eq__, ["format_stack"], true]
