spec: io_extra154
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.__spec__ loader and class identity — io.__loader__.__class__.__name__ == 'type' (FrozenImporter is its own class, not an instance), io.__spec__.__class__.__name__ == 'ModuleSpec', io.__spec__.parent == '' (empty string, not 'io'). Also covers io.IOBase/__dict__ mappingproxy identity and lengths, io.TextIOWrapper/__dict__/__mro__ identity."
    - "io.__loader__ is the FrozenImporter class itself (not an instance); therefore io.__loader__.__class__.__name__ == 'type' (the metaclass of all classes). This contrasts with pathlib and re whose __loader__ is a SourceFileLoader *instance* with __class__.__name__ == 'SourceFileLoader'."
    - "io.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); io.__spec__.parent == '' (empty string, not 'io'); io.__spec__.has_location == False (frozen module)."
    - "io.IOBase.__dict__.__class__.__name__ == 'mappingproxy' (len=12); io.IOBase.__dict__.__len__() == 6 (the ABCMeta-based IOBase class has 6 entries: __module__, __firstlineno__, __doc__, __static_attributes__, __abstractmethods__, _abc_impl)."
    - "io.TextIOWrapper.__dict__.__len__() == 31 (the most populated dict among io concrete classes: TextIOWrapper has the most methods because it adds encoding/decoding, reconfigure, detach on top of buffered I/O)."
    - "io.TextIOWrapper.__mro__.__len__() == 4 (MRO: [TextIOWrapper, _TextIOBase, _IOBase, object]; the same 4-entry depth as BytesIO and StringIO)."
    - "io.IOBase.__mro__.__len__() == 3 (MRO: [IOBase, _IOBase, object]; shorter than BytesIO/StringIO/TextIOWrapper (4) because IOBase is the public ABC wrapper over the private _IOBase C type)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__spec__ class and loader identity
# io.__spec__.__class__.__name__ == 'ModuleSpec' (len=10).
# io.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, not an instance).
# io.__spec__.parent == '' (empty string).
# io.__spec__.has_location == False (io is a frozen module).
# ---------------------------------------------------------------------------

table io_extra154.spec_and_loader_identity:
  description: "io.__spec__ class identity: __class__.__name__=='ModuleSpec' (10); io.__loader__.__class__.__name__=='type' (FrozenImporter is a class); io.__spec__.parent=='' (empty); io.__spec__.has_location==False"
  kind: python_call_eq
  category: identity
  id_prefix: iospec154

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,     __spec__.__class__.__name__.__eq__,    ["ModuleSpec"], true, "io.__spec__.__class__.__name__ == 'ModuleSpec' (the import system stores module metadata in a ModuleSpec object from importlib.machinery)"]
    - [spec_cls_len,    __spec__.__class__.__name__.__len__,   [],             10,   "io.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' has 10 characters)"]
    - [loader_cls_eq,   __loader__.__class__.__name__.__eq__,  ["type"],       true, "io.__loader__.__class__.__name__ == 'type' — io.__loader__ is the FrozenImporter class itself (not an instance); FrozenImporter's metaclass is 'type', the default metaclass for all Python classes"]
    - [spec_parent_eq,  __spec__.parent.__eq__,                [""],           true, "io.__spec__.parent == '' (empty string; io is a top-level module with no parent package, unlike re whose __spec__.parent == 're')"]
    - [spec_parent_len, __spec__.parent.__len__,               [],             0,    "io.__spec__.parent.__len__() == 0 (the parent string is empty; 0 characters)"]
    - [spec_name_eq,    __spec__.name.__eq__,                  ["io"],         true, "io.__spec__.name == 'io' (the module spec name; len=2)"]

# ---------------------------------------------------------------------------
# io.IOBase __dict__ mappingproxy identity
# io.IOBase.__dict__.__class__.__name__ == 'mappingproxy' (len=12).
# io.IOBase.__dict__.__len__() == 6.
# io.IOBase.__mro__.__len__() == 3 (IOBase, _IOBase, object).
# ---------------------------------------------------------------------------

table io_extra154.IOBase_dict_identity:
  description: "io.IOBase.__dict__ identity: __class__.__name__=='mappingproxy' (12), __len__()==6; io.IOBase.__mro__.__len__()==3"
  kind: python_call_eq
  category: identity
  id_prefix: iospec154

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_dict_cls_eq,  IOBase.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "io.IOBase.__dict__.__class__.__name__ == 'mappingproxy' (all type __dict__ attributes are mappingproxy objects, providing a read-only view of the class namespace)"]
    - [iobase_dict_cls_len, IOBase.__dict__.__class__.__name__.__len__,[],               12,   "io.IOBase.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy' has 12 characters)"]
    - [iobase_dict_len,     IOBase.__dict__.__len__,                    [],               6,    "io.IOBase.__dict__.__len__() == 6 (IOBase has 6 entries: __module__, __firstlineno__, __doc__, __static_attributes__, __abstractmethods__, _abc_impl; these are the ABCMeta bookkeeping attributes, not IO methods)"]
    - [rawiobase_dict_len,  RawIOBase.__dict__.__len__,                 [],               6,    "io.RawIOBase.__dict__.__len__() == 6 (same 6-entry structure as IOBase: __module__, __firstlineno__, __doc__, __static_attributes__, __abstractmethods__, _abc_impl; RawIOBase is a thin ABC wrapper)"]
    - [bufiobase_dict_len,  BufferedIOBase.__dict__.__len__,            [],               6,    "io.BufferedIOBase.__dict__.__len__() == 6 (same 6-entry ABCMeta structure as IOBase and RawIOBase; BufferedIOBase defines no new Python-visible methods in its dict)"]
    - [textiobase_dict_len, TextIOBase.__dict__.__len__,                [],               6,    "io.TextIOBase.__dict__.__len__() == 6 (same 6-entry structure as IOBase, RawIOBase, BufferedIOBase; all four public IO ABCs share this exact dict size)"]
    - [iobase_mro_len,      "IOBase.__mro__.__len__",                   [],               3,    "io.IOBase.__mro__.__len__() == 3 (MRO: [IOBase, _IOBase, object]; IOBase is shorter than BytesIO/StringIO/TextIOWrapper which have MRO length 4 because IOBase directly wraps the private C type)"]
    - [iobase_base0_eq,     "IOBase.__bases__[0].__name__.__eq__",      ["_IOBase"],      true, "io.IOBase.__bases__[0].__name__ == '_IOBase' (the private C extension ABC is the direct base of the public Python IOBase wrapper)"]

# ---------------------------------------------------------------------------
# io.BytesIO and io.StringIO __dict__ lengths
# io.BytesIO.__dict__.__len__() == 28.
# io.StringIO.__dict__.__len__() == 21.
# Both have __dict__.__class__.__name__ == 'mappingproxy'.
# ---------------------------------------------------------------------------

table io_extra154.BytesIO_StringIO_dict_identity:
  description: "io.BytesIO.__dict__ identity: __class__.__name__=='mappingproxy', __len__()==28; io.StringIO.__dict__.__len__()==21"
  kind: python_call_eq
  category: identity
  id_prefix: iospec154

  columns: [id, function, args, expected, description]
  rows:
    - [bio_dict_cls_eq,   BytesIO.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "io.BytesIO.__dict__.__class__.__name__ == 'mappingproxy' (BytesIO.__dict__ is a read-only mappingproxy like all class __dict__ attributes)"]
    - [bio_dict_len,      BytesIO.__dict__.__len__,                     [],               28,   "io.BytesIO.__dict__.__len__() == 28 (BytesIO has 28 entries including __new__, __init__, read, write, seek, tell, readline, readlines, writelines, read1, readinto, getvalue, getbuffer, truncate, flush, close, isatty, seekable, readable, writable, __iter__, __next__, __getstate__, __setstate__, __sizeof__, closed, __doc__, __module__)"]
    - [sio_dict_cls_eq,   StringIO.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "io.StringIO.__dict__.__class__.__name__ == 'mappingproxy' (StringIO.__dict__ is also a mappingproxy)"]
    - [sio_dict_len,      StringIO.__dict__.__len__,                     [],               21,   "io.StringIO.__dict__.__len__() == 21 (StringIO has 21 entries; fewer than BytesIO (28) because StringIO omits binary-only methods like readinto, read1, getbuffer; it adds newlines and line_buffering properties)"]
    - [fileio_dict_len,   FileIO.__dict__.__len__,                       [],               26,   "io.FileIO.__dict__.__len__() == 26 (FileIO has 26 entries; the raw file IO class; close to BytesIO but differs in that it has readall, mode, and name properties instead of getvalue/getbuffer)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper __dict__ and MRO identity
# io.TextIOWrapper.__dict__.__len__() == 31 (the most entries among io concrete classes).
# io.TextIOWrapper.__mro__.__len__() == 4 ([TextIOWrapper, _TextIOBase, _IOBase, object]).
# ---------------------------------------------------------------------------

table io_extra154.TextIOWrapper_dict_mro_identity:
  description: "io.TextIOWrapper.__dict__ identity: __len__()==31 (most entries among concrete io classes); __mro__.__len__()==4"
  kind: python_call_eq
  category: identity
  id_prefix: iospec154

  columns: [id, function, args, expected, description]
  rows:
    - [textiow_dict_len,   TextIOWrapper.__dict__.__len__,                   [],               31,   "io.TextIOWrapper.__dict__.__len__() == 31 (the largest __dict__ among io concrete classes; TextIOWrapper adds encoding/decoding, newlines, line_buffering, write_through, reconfigure, detach on top of buffered binary I/O)"]
    - [textiow_mro_len,    "TextIOWrapper.__mro__.__len__",                  [],               4,    "io.TextIOWrapper.__mro__.__len__() == 4 (MRO: [TextIOWrapper, _TextIOBase, _IOBase, object]; the same 4-entry depth as BytesIO ([BytesIO, _BufferedIOBase, _IOBase, object]) and StringIO ([StringIO, _TextIOBase, _IOBase, object])"]
    - [textiow_name_eq,    TextIOWrapper.__name__.__eq__,                    ["TextIOWrapper"], true, "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=14)"]
    - [textiow_name_len,   TextIOWrapper.__name__.__len__,                   [],               14,   "io.TextIOWrapper.__name__.__len__() == 14 ('TextIOWrapper' has 14 characters)"]
    - [textiow_module_eq,  TextIOWrapper.__module__.__eq__,                  ["_io"],          true, "io.TextIOWrapper.__module__ == '_io' (implemented in the C extension _io module, like all concrete io classes; the public 'io' module re-exports them)"]
    - [textiow_base0_eq,   "TextIOWrapper.__bases__[0].__name__.__eq__",     ["_TextIOBase"],  true, "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (the private C-extension TextIOBase ABC is the direct base of TextIOWrapper)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra154.loader.class_is_type:
  description: "io.__loader__.__class__.__name__ == 'type' — io.__loader__ is the FrozenImporter class itself (not an instance of FrozenImporter); since FrozenImporter is a class and the metaclass of all classes is 'type', its __class__.__name__ is 'type'. This contrasts with pathlib, re, and decimal where __loader__ is a SourceFileLoader *instance* (so __class__.__name__ == 'SourceFileLoader')."
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra154.spec.class_is_ModuleSpec:
  description: "io.__spec__.__class__.__name__ == 'ModuleSpec' (len=10) — every module loaded by the Python import system has a __spec__ attribute which is an instance of importlib.machinery.ModuleSpec; the ModuleSpec stores the name, loader, origin, and other import metadata for the module"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant io_extra154.spec.parent_empty:
  description: "io.__spec__.parent == '' (empty string, len=0) — io is a top-level module with no parent package, so __spec__.parent is the empty string; by contrast, re.__spec__.parent == 're' (re is also a package, its parent is itself); io.__package__ is also '' for the same reason"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant io_extra154.IOBase.dict_len_6:
  description: "io.IOBase.__dict__.__len__() == 6 (the public IOBase wrapper class has 6 entries: __module__, __firstlineno__, __doc__, __static_attributes__, __abstractmethods__, _abc_impl; these are ABCMeta bookkeeping attributes, not IO methods; the actual IO methods like read/write/seek/close are defined on the private _IOBase C type)"
  category: identity
  kind: python_call_eq
  function: IOBase.__dict__.__len__
  args: []
  expected: 6

invariant io_extra154.IOBase.mro_len_3:
  description: "io.IOBase.__mro__.__len__() == 3 (MRO: [IOBase, _IOBase, object]; the public IOBase ABC has a 3-entry MRO, shorter than BytesIO (4), StringIO (4), and TextIOWrapper (4); IOBase directly wraps the C type _IOBase without any intermediate buffering layers)"
  category: identity
  kind: python_call_eq
  function: "IOBase.__mro__.__len__"
  args: []
  expected: 3

invariant io_extra154.TextIOWrapper.dict_len_31:
  description: "io.TextIOWrapper.__dict__.__len__() == 31 — TextIOWrapper has the most entries (31) among io concrete classes; more than BytesIO (28), FileIO (26), and StringIO (21); the extra entries cover text-mode features: encoding, errors, newlines, line_buffering, write_through, reconfigure(), detach(), and __repr__"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__len__
  args: []
  expected: 31

invariant io_extra154.BytesIO.dict_len_28:
  description: "io.BytesIO.__dict__.__len__() == 28 — BytesIO has 28 entries in its class __dict__; more than StringIO (21) because BytesIO includes binary-only methods (read1, readinto, getbuffer) and more dunder methods (__iter__, __next__, __getstate__, __setstate__, __sizeof__)"
  category: identity
  kind: python_call_eq
  function: BytesIO.__dict__.__len__
  args: []
  expected: 28

invariant io_extra154.IOBase.dict_class_is_mappingproxy:
  description: "io.IOBase.__dict__.__class__.__name__ == 'mappingproxy' — all Python class __dict__ attributes are mappingproxy objects, which are read-only views of the underlying dict; this is the same for all io classes (IOBase, BytesIO, StringIO, TextIOWrapper) and all Python types in general"
  category: identity
  kind: python_call_eq
  function: IOBase.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
