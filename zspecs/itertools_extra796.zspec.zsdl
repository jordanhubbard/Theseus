  notes:
    - "Covers itertools count, cycle, repeat, zip_longest, tee identity attributes"
    - "Doc class name checks confirm __doc__ is always a str, not None"
  created_at: "2026-04-12"

table itertools_extra796.name:
  description: "itertools type identity — qualname, module, and doc class checks"
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: it796xx
  columns: [id, function, args, expected]
  rows:
    - [it796xx001, itertools.count.__qualname__.__eq__, ["count"], true]
    - [it796xx002, itertools.count.__module__.__eq__, ["itertools"], true]
    - [it796xx003, itertools.count.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it796xx004, itertools.cycle.__qualname__.__eq__, ["cycle"], true]
    - [it796xx005, itertools.cycle.__module__.__eq__, ["itertools"], true]
    - [it796xx006, itertools.cycle.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it796xx007, itertools.repeat.__qualname__.__eq__, ["repeat"], true]
    - [it796xx008, itertools.repeat.__module__.__eq__, ["itertools"], true]
    - [it796xx009, itertools.repeat.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it796xx010, itertools.zip_longest.__qualname__.__eq__, ["zip_longest"], true]
    - [it796xx011, itertools.zip_longest.__module__.__eq__, ["itertools"], true]
    - [it796xx012, itertools.tee.__qualname__.__eq__, ["tee"], true]
