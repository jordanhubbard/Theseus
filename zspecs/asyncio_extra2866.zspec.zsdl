spec: as2866
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [asyncio source, Python docs, https://docs.python.org/3/library/asyncio-sync.html, https://docs.python.org/3/library/asyncio-task.html]
  not_derived_from: [asyncio_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence, asyncio_extra2836.zspec.zsdl — covers __rtruediv__/__rfloordiv__/__rmod__ dict-presence, asyncio_extra2821.zspec.zsdl — covers __radd__/__rsub__/__rmul__ dict-presence]
  notes: [Wave 638 theme — __rand__/__ror__/__rxor__ dict-presence checks for asyncio types. Reflected bitwise AND, OR, and XOR operators. Task/Future/Queue/Event/Semaphore/BoundedSemaphore/Lock/Condition/Handle/TimerHandle/Timeout/TaskGroup are async coordination primitives not bitwise/set-like types — none define these dunders. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table as2866.rand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["as2866001", operator.contains, [asyncio.Task.__dict__, "__rand__"], false]
    - ["as2866002", operator.contains, [asyncio.Future.__dict__, "__rand__"], false]
