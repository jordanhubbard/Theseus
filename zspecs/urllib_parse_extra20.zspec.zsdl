spec: urllib_parse_extra20
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra19.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __qualname__ standalones, DefragResult __bases__[0].__name__, urldefrag __name__/__module__, parse_qs/parse_qsl __name__, urlencode __module__ standalone."
    - "urllib_parse_extra18.zspec.zsdl — covers __module__.__eq__ for urlparse/urlsplit/urlunsplit/urlunparse/urlencode/urljoin/quote/unquote/quote_plus/unquote_plus."
    - "urllib_parse_extra14.zspec.zsdl — covers __qualname__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote."
  notes:
    - "This spec extends urllib_parse_extra19.zspec.zsdl."
    - "Prior specs covered: urlparse/urlunparse/urljoin/urlencode/quote/unquote/quote_plus/unquote_plus/urlsplit/urlunsplit __name__/__module__, ParseResult/SplitResult/DefragResult __name__/__module__/__qualname__/__bases__, urldefrag/__name__/__module__, parse_qs/parse_qsl/__name__, urlencode/__module__."
    - "This spec covers: __qualname__ for urlparse/urlunparse/urljoin/urlencode/quote/unquote/urlsplit/urlunsplit; __module__.__len__() for urlparse/urljoin/quote; parse_qs.__qualname__."
    - "urllib.parse.urlparse.__qualname__ == 'urlparse' — extra4/14 cover via __eq__ table and __len__(); standalone eq here as cross-namespace anchor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlunparse.__qualname__ == 'urlunparse' — extra15 covers __qualname__.__eq__ and __len__(); standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urljoin.__qualname__ == 'urljoin' — extra4/14 cover in tables; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlencode.__qualname__ == 'urlencode' — extra4/14 cover in tables; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.quote.__qualname__ == 'quote' — extra4/14 cover in tables; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.unquote.__qualname__ == 'unquote' — extra4/14 cover in tables; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlsplit.__qualname__ == 'urlsplit' — extra4/14 cover in tables; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlunsplit.__qualname__ == 'urlunsplit' — extra15 covers; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlparse.__module__ == 'urllib.parse' — len 12. extra18 covers via table; __len__() as standalone here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urljoin.__module__ == 'urllib.parse' — len 12. extra18 covers via table; __len__() as standalone here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.quote.__module__ == 'urllib.parse' — len 12. extra18 covers via table; __len__() as standalone here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.parse_qs.__qualname__ == 'parse_qs' — extra5 covers __qualname__.__eq__; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for urlparse, urlunparse, urljoin, urlencode, quote, unquote,
# urlsplit, urlunsplit — standalone cross-namespace anchors
#
# Prior specs cover these in tables (extra4, extra14, extra15). These standalone
# invariants provide cross-namespace anchors from the extra20 namespace.
# For module-level functions __qualname__ == __name__ == the function name.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra20.urlparse.qualname_eq:
  description: "urllib.parse.urlparse.__qualname__ == 'urlparse' — cross-namespace anchor from extra20; extra4/14 cover in tables"
  category: function_qualnames
  kind: python_call_eq
  function: urlparse.__qualname__.__eq__
  args: ["urlparse"]
  expected: true

invariant urllib_parse_extra20.urlunparse.qualname_eq:
  description: "urllib.parse.urlunparse.__qualname__ == 'urlunparse' — cross-namespace anchor from extra20; extra15 covers originally"
  category: function_qualnames
  kind: python_call_eq
  function: urlunparse.__qualname__.__eq__
  args: ["urlunparse"]
  expected: true

invariant urllib_parse_extra20.urljoin.qualname_eq:
  description: "urllib.parse.urljoin.__qualname__ == 'urljoin' — cross-namespace anchor from extra20; extra4/14 cover in tables"
  category: function_qualnames
  kind: python_call_eq
  function: urljoin.__qualname__.__eq__
  args: ["urljoin"]
  expected: true

invariant urllib_parse_extra20.urlencode.qualname_eq:
  description: "urllib.parse.urlencode.__qualname__ == 'urlencode' — cross-namespace anchor from extra20; extra4/14 cover in tables"
  category: function_qualnames
  kind: python_call_eq
  function: urlencode.__qualname__.__eq__
  args: ["urlencode"]
  expected: true

invariant urllib_parse_extra20.parse_qs.qualname_eq:
  description: "urllib.parse.parse_qs.__qualname__ == 'parse_qs' — cross-namespace anchor from extra20; extra5 covers in table"
  category: function_qualnames
  kind: python_call_eq
  function: parse_qs.__qualname__.__eq__
  args: ["parse_qs"]
  expected: true

table urllib_parse_extra20.function_qualnames:
  description: "__qualname__.__eq__ for quote/unquote/urlsplit/urlunsplit — cross-namespace anchors from extra20"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fq20

  columns: [id, function, args, expected]
  rows:
    - [quote,      quote.__qualname__.__eq__,      ["quote"],      true]
    - [unquote,    unquote.__qualname__.__eq__,     ["unquote"],    true]
    - [urlsplit,   urlsplit.__qualname__.__eq__,    ["urlsplit"],   true]
    - [urlunsplit, urlunsplit.__qualname__.__eq__,  ["urlunsplit"], true]

# ---------------------------------------------------------------------------
# __module__.__len__() for urlparse, urljoin, quote
#
# urllib_parse_extra18 covers __module__.__eq__ for these three in a table.
# No prior spec checks __module__.__len__() as a standalone for any of them.
# All three have __module__ == 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra20.urlparse.module_len:
  description: "len(urllib.parse.urlparse.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: urlparse.__module__.__len__
  args: []
  expected: 12

invariant urllib_parse_extra20.urljoin.module_len:
  description: "len(urllib.parse.urljoin.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: urljoin.__module__.__len__
  args: []
  expected: 12

invariant urllib_parse_extra20.quote.module_len:
  description: "len(urllib.parse.quote.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: quote.__module__.__len__
  args: []
  expected: 12
