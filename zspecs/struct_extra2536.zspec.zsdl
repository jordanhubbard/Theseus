spec: struct_extra2536
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec focuses on __format__, __bytes__, and __fspath__ dict-presence for struct.Struct."
    - "struct_extra.zspec.zsdl covers: Struct.format/size attrs; calcsize extra formats; pack_into/unpack_from/iter_unpack; struct.error class name and base class."
    - "struct.Struct does NOT define __format__ in its __dict__ — format() falls back to object.__format__."
    - "struct.Struct does NOT define __bytes__ in its __dict__ — Struct objects are not byte-convertible via the bytes() protocol."
    - "struct.Struct does NOT define __fspath__ in its __dict__ — Struct objects are not filesystem paths."
    - "struct.Struct.__dict__ DOES contain: __new__, __repr__, __getattribute__, __setattr__, __delattr__, __init__, iter_unpack, pack, pack_into, unpack, unpack_from, __sizeof__, format, size, __doc__, __module__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class __dict__ presence: __format__ absent
# ---------------------------------------------------------------------------

table struct_extra2536.Struct.format_absent:
  description: "struct.Struct.__dict__ does NOT contain __format__ — no custom formatting protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2536

  columns: [id, function, args, expected]
  rows:
    - ["st2536-fmt-absent", Struct.__dict__.__contains__, ["__format__"], false]

# ---------------------------------------------------------------------------
# struct.Struct class __dict__ presence: __bytes__ absent
# ---------------------------------------------------------------------------

table struct_extra2536.Struct.bytes_absent:
  description: "struct.Struct.__dict__ does NOT contain __bytes__ — no bytes-conversion protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2536

  columns: [id, function, args, expected]
  rows:
    - ["st2536-bytes-absent", Struct.__dict__.__contains__, ["__bytes__"], false]

# ---------------------------------------------------------------------------
# struct.Struct class __dict__ presence: __fspath__ absent
# ---------------------------------------------------------------------------

table struct_extra2536.Struct.fspath_absent:
  description: "struct.Struct.__dict__ does NOT contain __fspath__ — no filesystem-path protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2536

  columns: [id, function, args, expected]
  rows:
    - ["st2536-fspath-absent", Struct.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# struct.Struct class __dict__ presence: members that ARE present (positive control)
# These confirm __dict__.__contains__ works correctly for struct.Struct.
# ---------------------------------------------------------------------------

table struct_extra2536.Struct.dict_present:
  description: "struct.Struct.__dict__ DOES contain these members (positive-control checks)"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2536

  columns: [id, function, args, expected]
  rows:
    - ["st2536-repr-present",       Struct.__dict__.__contains__, ["__repr__"],      true]
    - ["st2536-init-present",       Struct.__dict__.__contains__, ["__init__"],      true]
    - ["st2536-new-present",        Struct.__dict__.__contains__, ["__new__"],       true]
    - ["st2536-pack-present",       Struct.__dict__.__contains__, ["pack"],          true]
    - ["st2536-unpack-present",     Struct.__dict__.__contains__, ["unpack"],        true]
    - ["st2536-pack-into-present",  Struct.__dict__.__contains__, ["pack_into"],     true]
    - ["st2536-format-attr-present", Struct.__dict__.__contains__, ["format"],       true]
    - ["st2536-size-attr-present",  Struct.__dict__.__contains__, ["size"],          true]

# ---------------------------------------------------------------------------
# struct.Struct class __dict__ presence: all three protocols absent in one table
# Consolidates the three absent checks for compact cross-reference.
# ---------------------------------------------------------------------------

table struct_extra2536.Struct.protocol_dunders_absent:
  description: "struct.Struct.__dict__ contains none of __format__, __bytes__, __fspath__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2536

  columns: [id, function, args, expected]
  rows:
    - ["st2536-p1-fmt",    Struct.__dict__.__contains__, ["__format__"], false]
    - ["st2536-p1-bytes",  Struct.__dict__.__contains__, ["__bytes__"],  false]
    - ["st2536-p1-fspath", Struct.__dict__.__contains__, ["__fspath__"], false]
