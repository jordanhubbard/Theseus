spec: relative_luminance
version: ">=2.0.1"
backend: node(relative-luminance)

docs: https://www.npmjs.com/package/relative-luminance

provenance:
  derived_from:
    - "relative-luminance README — https://www.npmjs.com/package/relative-luminance"
    - "Test vectors verified with relative-luminance via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "relative-luminance source"
  notes:
    - "relative-luminance is an npm package. Install: npm install relative-luminance"
    - "Calculates the relative luminance of an RGB color per WCAG 2.0. Range: 0 (black) to 1 (white)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number between 0 and 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table relative_luminance.luminance:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: rlum

  columns: [id, args, expected]
  rows:
    - [red,    [[255, 0, 0]],       0.2126]
    - [black,  [[0, 0, 0]],         0]
    - [white,  [[255, 255, 255]],   1]
