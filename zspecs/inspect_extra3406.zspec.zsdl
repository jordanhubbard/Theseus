spec: in3406
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (in3406): __bool__, __str__, __repr__ dict-presence checks for inspect types."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "All values False — inspect introspection types have no custom bool/str/repr conversion in their own __dict__."
    - "None of the inspect types define __bool__, __str__, or __repr__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement bool, str, or repr conversion protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3406.bool:
  description: "inspect types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3406
  columns: [id, function, args, expected]
  rows:
    - ["in3406001", operator.contains, [inspect.Parameter.__dict__,           "__bool__"], false]
    - ["in3406002", operator.contains, [inspect.Signature.__dict__,           "__bool__"], false]
    - ["in3406003", operator.contains, [inspect.BoundArguments.__dict__,      "__bool__"], false]
    - ["in3406004", operator.contains, [inspect.FrameInfo.__dict__,           "__bool__"], false]
    - ["in3406005", operator.contains, [inspect.ArgInfo.__dict__,             "__bool__"], false]
    - ["in3406006", operator.contains, [inspect.FullArgSpec.__dict__,         "__bool__"], false]
    - ["in3406007", operator.contains, [inspect.Attribute.__dict__,           "__bool__"], false]
    - ["in3406008", operator.contains, [inspect.ClassFoundException.__dict__, "__bool__"], false]
    - ["in3406009", operator.contains, [inspect.EndOfBlock.__dict__,          "__bool__"], false]

