spec: pathlib_extra35
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra31.zspec.zsdl — covers PurePosixPath/__qualname__/__module__; PureWindowsPath/__qualname__/__module__; PosixPath/__qualname__/__module__; PurePath/__bases__[0].__name__; PurePath properties fget.__qualname__"
    - "pathlib_extra32.zspec.zsdl — covers PurePath.parent/parents/suffixes/drive/root/anchor fget.__qualname__/__module__"
    - "pathlib_extra33.zspec.zsdl — covers PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__; PosixPath/WindowsPath __bases__[0].__name__; Path/__init__/__qualname__; PurePath/__init__/__name__/__qualname__; Path/__truediv__/__name__/__qualname__"
    - "pathlib_extra34.zspec.zsdl — covers __module__.__len__() for Path/PurePath/PurePosixPath/PureWindowsPath; __name__.__len__() for all six classes; __qualname__.__len__() for Path/PurePath"
  notes:
    - "This spec extends pathlib_extra34.zspec.zsdl."
    - "Prior specs covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__, bases, Path/__init__/__truediv__ __name__/__qualname__, __module__.__len__() for four classes, __name__.__len__() for all six classes, __qualname__.__len__() for Path/PurePath."
    - "This spec covers: __qualname__.__len__() for PosixPath, PurePosixPath, PureWindowsPath, WindowsPath; __qualname__.__len__() for Path.open/read_text/write_text/mkdir/exists/stat methods; __module__.__len__() for PosixPath/WindowsPath."
    - "No prior pathlib spec checks pathlib.PosixPath.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePosixPath.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.PureWindowsPath.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.WindowsPath.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.open.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.read_text.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.write_text.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.mkdir.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.exists.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.stat.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.PosixPath.__module__.__len__()."
    - "No prior pathlib spec checks pathlib.WindowsPath.__module__.__len__()."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath' — len 9 (flat, same as __name__)."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' — len 13 (flat, same as __name__)."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath' — len 15 (flat, same as __name__)."
    - "pathlib.WindowsPath.__qualname__ == 'WindowsPath' — len 11 (flat, same as __name__)."
    - "pathlib.Path.open.__qualname__ == 'Path.open' — len 9."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' — len 14."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text' — len 15."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' — len 10."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists' — len 11."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' — len 9."
    - "pathlib.PosixPath.__module__ == 'pathlib' — len 7."
    - "pathlib.WindowsPath.__module__ == 'pathlib' — len 7."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for PosixPath, PurePosixPath, PureWindowsPath,
# WindowsPath
#
# These four classes all have flat __qualname__ values equal to their
# __name__ strings. Prior spec pathlib_extra34 checked Path and PurePath;
# this spec extends coverage to the remaining four concrete and pure
# path classes.
#   PosixPath       -> 'PosixPath'       -> 9
#   PurePosixPath   -> 'PurePosixPath'   -> 13
#   PureWindowsPath -> 'PureWindowsPath' -> 15
#   WindowsPath     -> 'WindowsPath'     -> 11
# ---------------------------------------------------------------------------

invariant pathlib_extra35.PosixPath.qualname_len:
  description: "pathlib.PosixPath.__qualname__.__len__() == 9 — 'PosixPath' has 9 characters (flat qualname)"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra35.PurePosixPath.qualname_len:
  description: "pathlib.PurePosixPath.__qualname__.__len__() == 13 — 'PurePosixPath' has 13 characters (flat qualname)"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__qualname__.__len__
  args: []
  expected: 13

invariant pathlib_extra35.PureWindowsPath.qualname_len:
  description: "pathlib.PureWindowsPath.__qualname__.__len__() == 15 — 'PureWindowsPath' has 15 characters (flat qualname)"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra35.WindowsPath.qualname_len:
  description: "pathlib.WindowsPath.__qualname__.__len__() == 11 — 'WindowsPath' has 11 characters (flat qualname)"
  category: class_identity
  kind: python_call_eq
  function: WindowsPath.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Path instance methods
#
# Path method qualnames are dotted (class.method), so they are longer than
# the bare method name. Lengths verified with Python 3.12:
#   Path.open        -> 'Path.open'        -> 9
#   Path.read_text   -> 'Path.read_text'   -> 14
#   Path.write_text  -> 'Path.write_text'  -> 15
#   Path.mkdir       -> 'Path.mkdir'       -> 10
#   Path.exists      -> 'Path.exists'      -> 11
#   Path.stat        -> 'Path.stat'        -> 9
# No prior pathlib spec checks the __qualname__ length of any Path method.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# __module__.__len__() for PosixPath and WindowsPath
#
# Both classes are defined in the pure-Python Lib/pathlib module, so their
# __module__ is 'pathlib' (len 7). Prior spec pathlib_extra34 checked
# Path/PurePath/PurePosixPath/PureWindowsPath; these two extend coverage.
# ---------------------------------------------------------------------------

table pathlib_extra35.remaining_class_module_lengths:
  description: "__module__.__len__() for PosixPath and WindowsPath — both 7 (module name 'pathlib')"
  kind: python_call_eq
  category: class_identity
  id_prefix: rcml35

  columns: [id, function, args, expected]
  rows:
    - [PosixPath,   PosixPath.__module__.__len__,   [], 7]
    - [WindowsPath, WindowsPath.__module__.__len__, [], 7]

table pathlib_extra35.class_qualname_lengths:
  description: "__qualname__.__len__() for PosixPath, PurePosixPath, PureWindowsPath, WindowsPath — flat qualnames matching __name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: cql35

  columns: [id, function, args, expected]
  rows:
    - [PosixPath,       PosixPath.__qualname__.__len__,       [], 9]
    - [PurePosixPath,   PurePosixPath.__qualname__.__len__,   [], 13]
    - [PureWindowsPath, PureWindowsPath.__qualname__.__len__, [], 15]
    - [WindowsPath,     WindowsPath.__qualname__.__len__,     [], 11]

table pathlib_extra35.path_method_qualname_lengths:
  description: "__qualname__.__len__() for Path.open/read_text/write_text/mkdir/exists/stat — dotted class.method qualnames"
  kind: python_call_eq
  category: class_identity
  id_prefix: pmql35

  columns: [id, function, args, expected]
  rows:
    - [Path_open_qualname_len,       "Path.open.__qualname__.__len__",       [],  9]
    - [Path_read_text_qualname_len,  "Path.read_text.__qualname__.__len__",  [], 14]
    - [Path_write_text_qualname_len, "Path.write_text.__qualname__.__len__", [], 15]
    - [Path_mkdir_qualname_len,      "Path.mkdir.__qualname__.__len__",      [], 10]
    - [Path_exists_qualname_len,     "Path.exists.__qualname__.__len__",     [], 11]
    - [Path_stat_qualname_len,       "Path.stat.__qualname__.__len__",       [],  9]
