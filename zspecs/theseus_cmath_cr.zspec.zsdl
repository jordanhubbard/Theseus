spec: theseus_cmath_cr
version: ">=3.8"
backend: python_cleanroom(theseus_cmath_cr)
blocks: cmath

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/cmath.html"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "Clean-room cmath module. Do NOT import cmath."
    - "Complex math functions: phase, polar, rect, exp, log, sqrt, sin, cos."

error_model: python_exceptions

invariant theseus_cmath_cr.cmath2_polar:
  description: "polar(1+0j) returns (1.0, 0.0)"
  category: polar
  kind: python_call_eq
  function: cmath2_polar
  args: []
  expected: true

invariant theseus_cmath_cr.cmath2_rect:
  description: "rect(1.0, 0.0) returns 1+0j"
  category: rect
  kind: python_call_eq
  function: cmath2_rect
  args: []
  expected: true

invariant theseus_cmath_cr.cmath2_phase:
  description: "phase(-1+0j) is approximately pi"
  category: phase
  kind: python_call_eq
  function: cmath2_phase
  args: []
  expected: true
