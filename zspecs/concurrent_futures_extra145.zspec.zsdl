table concurrent_futures_extra145.cf_all_exception_and_constant_members:
  description: "concurrent.futures.__all__ membership checks for exception and constant names in cf_all145 namespace — concurrent.futures.__all__.__contains__('CancelledError')==True ('CancelledError' is raised when a future is cancelled before completing); concurrent.futures.__all__.__contains__('TimeoutError')==True ('TimeoutError' is raised when a wait/result call exceeds its timeout); concurrent.futures.__all__.__contains__('InvalidStateError')==True ('InvalidStateError' is raised when an operation is not valid in the current state, added recently); concurrent.futures.__all__.__contains__('BrokenExecutor')==True ('BrokenExecutor' is raised when an executor becomes unusable after a failed shutdown); concurrent.futures.__all__.__contains__('FIRST_COMPLETED')==True ('FIRST_COMPLETED' constant for wait() return_when parameter); concurrent.futures.__all__.__contains__('ALL_COMPLETED')==True ('ALL_COMPLETED' constant for wait() return_when parameter); all six names confirmed in the 14-item list; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: cf_all145b

  columns: [id, function, args, expected, description]
  rows:
    - [has_cancelled, "concurrent.futures.__all__.__contains__",  ["CancelledError"],   true,  "concurrent.futures.__all__.__contains__('CancelledError') == True; verified with Python 3.14.3"]
    - [has_timeout,   "concurrent.futures.__all__.__contains__",  ["TimeoutError"],     true,  "concurrent.futures.__all__.__contains__('TimeoutError') == True; verified with Python 3.14.3"]
    - [has_invalid,   "concurrent.futures.__all__.__contains__",  ["InvalidStateError"], true,  "concurrent.futures.__all__.__contains__('InvalidStateError') == True; verified with Python 3.14.3"]
    - [has_broken,    "concurrent.futures.__all__.__contains__",  ["BrokenExecutor"],   true,  "concurrent.futures.__all__.__contains__('BrokenExecutor') == True; verified with Python 3.14.3"]
    - [has_first_c,   "concurrent.futures.__all__.__contains__",  ["FIRST_COMPLETED"],  true,  "concurrent.futures.__all__.__contains__('FIRST_COMPLETED') == True; verified with Python 3.14.3"]
    - [has_all_c,     "concurrent.futures.__all__.__contains__",  ["ALL_COMPLETED"],    true,  "concurrent.futures.__all__.__contains__('ALL_COMPLETED') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra145
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra145.cf_all_is_list:
  description: "concurrent.futures.__all__.__class__.__name__.__eq__('list') returns True — concurrent.futures.__all__ is a list (unlike asyncio.__all__ which is a tuple); concurrent.futures.__all__.__class__.__name__=='list'; concurrent.futures.__all__.__len__()==14; this is NEW in extra145: the first spec to verify concurrent.futures.__all__.__class__.__name__; the list contains 14 names: 3 wait constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED), 4 exceptions (CancelledError, TimeoutError, InvalidStateError, BrokenExecutor), 2 core classes (Future, Executor), 2 utility functions (wait, as_completed), and 3 executor classes (ProcessPoolExecutor, ThreadPoolExecutor, InterpreterPoolExecutor); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

invariant concurrent_futures_extra145.cf_all_len_14:
  description: "concurrent.futures.__all__.__len__() == 14 — concurrent.futures exports 14 public names through its __all__ list; this is a compact API compared to asyncio (95 items, tuple) and multiprocessing (37 items, list); the 14 names span 4 categories: constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED — 3 items), exceptions (CancelledError, TimeoutError, InvalidStateError, BrokenExecutor — 4 items), core types (Future, Executor — 2 items), utilities (wait, as_completed — 2 items), and executors (ProcessPoolExecutor, ThreadPoolExecutor, InterpreterPoolExecutor — 3 items); concurrent.futures.__all__.__class__.__name__=='list'; NEW in extra145: first standalone concurrent.futures.__all__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__all__.__len__"
  args: []
  expected: 14

invariant concurrent_futures_extra145.cf_spec_name_len_18:
  description: "concurrent.futures.__spec__.name.__len__() == 18 — concurrent.futures.__spec__.name is 'concurrent.futures' (18 chars: 'concurrent'=10 + '.'=1 + 'futures'=7=18); this is the longest module name among the four modules in this batch: asyncio.__spec__.name.__len__()==7, multiprocessing.__spec__.name.__len__()==15, abc.__spec__.name.__len__()==3, concurrent.futures.__spec__.name.__len__()==18; concurrent.futures.__name__.__len__()==18 and concurrent.futures.__package__.__len__()==18 match; concurrent.futures.__all__.__len__()==14 (list); NEW in extra145: first standalone concurrent.futures.__spec__.name length invariant in cf_all145 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.name.__len__"
  args: []
  expected: 18

invariant concurrent_futures_extra145.cf_all_contains_future:
  description: "concurrent.futures.__all__.__contains__('Future') returns True — 'Future' is one of the 14 names in concurrent.futures.__all__ (a list); concurrent.futures.Future represents a computation that hasn't necessarily completed yet; it is the central class in the concurrent.futures API, returned by Executor.submit(); concurrent.futures.__all__.__class__.__name__=='list'; concurrent.futures.__all__.__len__()==14; other executor types in the list include ThreadPoolExecutor, ProcessPoolExecutor, and InterpreterPoolExecutor; NEW in extra145: first standalone concurrent.futures.__all__ 'Future' membership invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__all__.__contains__"
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra145.cf_all_contains_as_completed:
  description: "concurrent.futures.__all__.__contains__('as_completed') returns True — 'as_completed' is one of the 14 names in concurrent.futures.__all__ (a list); as_completed() is a generator function that yields futures as they finish (in completion order, not submission order), useful for processing results as they arrive rather than waiting for all to finish; concurrent.futures.__all__.__contains__('wait')==True for the blocking variant; concurrent.futures.__all__.__class__.__name__=='list'; concurrent.futures.__all__.__len__()==14; NEW in extra145: first standalone concurrent.futures.__all__ 'as_completed' membership invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__all__.__contains__"
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra145.cf_spec_name_eq:
  description: "concurrent.futures.__spec__.name.__eq__('concurrent.futures') returns True — concurrent.futures.__spec__.name is 'concurrent.futures' (18 chars); the ModuleSpec name is the fully-qualified name used by the Python import system; concurrent.futures.__name__=='concurrent.futures' and concurrent.futures.__package__=='concurrent.futures' also hold; all three attributes share the same 18-character value; concurrent.futures is a sub-package of the 'concurrent' namespace package (concurrent itself has no __init__.py); concurrent.futures.__all__.__len__()==14 (list); NEW in extra145: first standalone concurrent.futures.__spec__.name equality invariant in cf_all145 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.name.__eq__"
  args: ["concurrent.futures"]
  expected: true
