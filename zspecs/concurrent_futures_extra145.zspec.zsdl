# 'CancelledError' in concurrent.futures.__all__   == True
# 'TimeoutError' in concurrent.futures.__all__     == True
# 'InvalidStateError' in concurrent.futures.__all__ == True
# 'BrokenExecutor' in concurrent.futures.__all__   == True
# 'FIRST_COMPLETED' in concurrent.futures.__all__  == True
# 'ALL_COMPLETED' in concurrent.futures.__all__    == True
