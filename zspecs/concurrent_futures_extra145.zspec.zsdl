spec: concurrent_futures_extra145
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec covers concurrent.futures.__all__ — a list of length 14. concurrent.futures.__all__.__class__.__name__=='list'. concurrent.futures.__all__.__len__()==14. Items: ['FIRST_COMPLETED', 'FIRST_EXCEPTION', 'ALL_COMPLETED', 'CancelledError', 'TimeoutError', 'InvalidStateError', 'BrokenExecutor', 'Future', 'Executor', 'wait', 'as_completed', 'ProcessPoolExecutor', 'ThreadPoolExecutor', 'InterpreterPoolExecutor']. concurrent.futures.__spec__.name=='concurrent.futures' (len=18). concurrent.futures.__package__=='concurrent.futures' (len=18). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__all__ has 14 items (a list). Includes 'InterpreterPoolExecutor' (added in Python 3.14 for running subinterpreters). The 14 names cover: 3 wait constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED), 4 exceptions (CancelledError, TimeoutError, InvalidStateError, BrokenExecutor), 2 core classes (Future, Executor), 2 utility functions (wait, as_completed), 3 executors (ProcessPoolExecutor, ThreadPoolExecutor, InterpreterPoolExecutor). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ type and size — extra145
#
# concurrent.futures.__all__.__class__.__name__ == 'list'
# concurrent.futures.__all__.__len__()          == 14
# concurrent.futures.__spec__.name.__eq__('concurrent.futures') == True (len=18)
# concurrent.futures.__package__.__eq__('concurrent.futures')  == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra145.cf_all_type_and_size:
  description: "concurrent.futures.__all__ type and size checks in cf_all145 namespace — concurrent.futures.__all__.__class__.__name__=='list' (a mutable list, unlike asyncio.__all__ which is a tuple); concurrent.futures.__all__.__len__()==14 (14 public names: 3 wait constants, 4 exceptions, 2 core classes, 2 utility functions, 3 executors); concurrent.futures.__spec__.name.__eq__('concurrent.futures')==True (len=18: 'concurrent'=10 + '.'=1 + 'futures'=7=18); concurrent.futures.__spec__.name.__len__()==18; concurrent.futures.__name__.__eq__('concurrent.futures')==True (same as __spec__.name); concurrent.futures.__package__.__eq__('concurrent.futures')==True (package is itself, since concurrent.futures is a sub-package); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf_all145

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls_eq,    "concurrent.futures.__all__.__class__.__name__.__eq__",  ["list"],               true,  "concurrent.futures.__all__.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [all_len,       "concurrent.futures.__all__.__len__",                     [],                     14,    "concurrent.futures.__all__.__len__() == 14; verified with Python 3.14.3"]
    - [spec_name_eq,  "concurrent.futures.__spec__.name.__eq__",               ["concurrent.futures"],  true,  "concurrent.futures.__spec__.name == 'concurrent.futures' (len=18); verified with Python 3.14.3"]
    - [spec_name_len, "concurrent.futures.__spec__.name.__len__",               [],                     18,    "concurrent.futures.__spec__.name.__len__() == 18; verified with Python 3.14.3"]
    - [name_eq,       "concurrent.futures.__name__.__eq__",                    ["concurrent.futures"],  true,  "concurrent.futures.__name__ == 'concurrent.futures' (len=18); verified with Python 3.14.3"]
    - [pkg_eq,        "concurrent.futures.__package__.__eq__",                 ["concurrent.futures"],  true,  "concurrent.futures.__package__ == 'concurrent.futures' (package is itself); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ membership — executor and utility names — extra145
#
# 'Future' in concurrent.futures.__all__              == True
# 'Executor' in concurrent.futures.__all__            == True
# 'ThreadPoolExecutor' in concurrent.futures.__all__  == True
# 'ProcessPoolExecutor' in concurrent.futures.__all__ == True
# 'wait' in concurrent.futures.__all__                == True
# 'as_completed' in concurrent.futures.__all__        == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra145.cf_all_executor_members:
  description: "concurrent.futures.__all__ membership checks for executor and utility names in cf_all145 namespace — concurrent.futures.__all__.__contains__('Future')==True ('Future' represents the result of an async computation scheduled to an executor); concurrent.futures.__all__.__contains__('Executor')==True ('Executor' is the abstract base class for ThreadPoolExecutor and ProcessPoolExecutor); concurrent.futures.__all__.__contains__('ThreadPoolExecutor')==True ('ThreadPoolExecutor' submits callables to a pool of threads); concurrent.futures.__all__.__contains__('ProcessPoolExecutor')==True ('ProcessPoolExecutor' submits callables to a pool of processes for true parallelism); concurrent.futures.__all__.__contains__('wait')==True ('wait' blocks until all futures complete); concurrent.futures.__all__.__contains__('as_completed')==True ('as_completed' is a generator yielding futures as they complete); all six names confirmed in the 14-item list; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: cf_all145a

  columns: [id, function, args, expected, description]
  rows:
    - [has_future,  "concurrent.futures.__all__.__contains__",  ["Future"],              true,  "concurrent.futures.__all__.__contains__('Future') == True; verified with Python 3.14.3"]
    - [has_exec,    "concurrent.futures.__all__.__contains__",  ["Executor"],            true,  "concurrent.futures.__all__.__contains__('Executor') == True; verified with Python 3.14.3"]
    - [has_tpe,     "concurrent.futures.__all__.__contains__",  ["ThreadPoolExecutor"],  true,  "concurrent.futures.__all__.__contains__('ThreadPoolExecutor') == True; verified with Python 3.14.3"]
    - [has_ppe,     "concurrent.futures.__all__.__contains__",  ["ProcessPoolExecutor"], true,  "concurrent.futures.__all__.__contains__('ProcessPoolExecutor') == True; verified with Python 3.14.3"]
    - [has_wait,    "concurrent.futures.__all__.__contains__",  ["wait"],                true,  "concurrent.futures.__all__.__contains__('wait') == True; verified with Python 3.14.3"]
    - [has_asc,     "concurrent.futures.__all__.__contains__",  ["as_completed"],        true,  "concurrent.futures.__all__.__contains__('as_completed') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
