spec: functools_extra79
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra78.zspec.zsdl."
    - "Wave 240 theme: functools reduce, cmp_to_key (C builtins), and total_ordering (pure Python)."
    - "reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin in _functoolsmodule.c. Verified with Python 3.14.3."
    - "reduce.__module__ == '_functools' — reduce lives in the _functools C extension. Verified with Python 3.14.3."
    - "reduce.__qualname__ == 'reduce' — reduce is a top-level C builtin; its __qualname__ equals its simple name. Verified with Python 3.14.3."
    - "cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin in _functoolsmodule.c. Verified with Python 3.14.3."
    - "cmp_to_key.__module__ == '_functools' — cmp_to_key lives in the _functools C extension. Verified with Python 3.14.3."
    - "cmp_to_key.__qualname__ == 'cmp_to_key' — cmp_to_key is a top-level C builtin; its __qualname__ equals its simple name. Verified with Python 3.14.3."
    - "total_ordering.__class__.__name__ == 'function' — total_ordering is a pure-Python decorator defined in Lib/functools.py. Verified with Python 3.14.3."
    - "total_ordering.__module__ == 'functools' — total_ordering is defined in the functools module. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_name == 'total_ordering' — the code object's co_name matches the def statement name. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_argcount == 1 — total_ordering(cls) takes one positional argument. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reduce C builtin class identity — extra79
#
# Wave 240 theme: reduce is a C builtin in _functoolsmodule.c.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__         == '_functools'
# functools.reduce.__qualname__       == 'reduce'
#
# No prior functools spec checks reduce C builtin identity via functoolsmore79. New to extra79.
# ---------------------------------------------------------------------------

table functools_extra79.reduce_class_identity:
  description: "reduce.__class__.__name__=='builtin_function_or_method', __module__=='_functools', __qualname__=='reduce'; wave 240 reduce C builtin identity; new to extra79"
  kind: python_call_eq
  category: function_identity
  id_prefix: functoolsmore79

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin function defined in Modules/_functoolsmodule.c; its __class__ is the built-in function type and __class__.__name__ is 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks reduce.__class__.__name__ via functoolsmore79; new to extra79"]
    - [reduce_module_eq_functools_c,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C builtin defined in Modules/_functoolsmodule.c and exposed as _functools.reduce; the functools module re-exports it; its __module__ attribute records the C extension module name '_functools' (10 chars); str.__eq__('_functools') returns True; no prior functools spec checks reduce.__module__ via functoolsmore79; new to extra79"]
    - [reduce_qualname_eq_reduce,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a top-level C builtin function (not nested inside a class or another function); __qualname__ for a top-level C builtin equals its simple name 'reduce' (6 chars); str.__eq__('reduce') returns True; no prior functools spec checks reduce.__qualname__ via functoolsmore79; new to extra79"]

