  id_prefix: functoolsmore79

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_class_name_eq_builtin,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C builtin function defined in Modules/_functoolsmodule.c that converts a comparison function to a key function; its __class__ is the built-in function type and __class__.__name__ is 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks cmp_to_key.__class__.__name__ via functoolsmore79; new to extra79"]
    - [cmp_to_key_module_eq_functools_c,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is a C builtin defined in Modules/_functoolsmodule.c; the functools module re-exports it from _functools; its __module__ attribute records the C extension module name '_functools' (10 chars); str.__eq__('_functools') returns True; no prior functools spec checks cmp_to_key.__module__ via functoolsmore79; new to extra79"]
    - [cmp_to_key_qualname_eq_cmp_to_key,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a top-level C builtin function; __qualname__ for a top-level C builtin equals its simple name 'cmp_to_key' (10 chars); str.__eq__('cmp_to_key') returns True; no prior functools spec checks cmp_to_key.__qualname__ via functoolsmore79; new to extra79"]

# ---------------------------------------------------------------------------
# total_ordering pure-Python function identity — extra79
#
# Wave 240 theme: total_ordering is a pure-Python decorator in Lib/functools.py.
#
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__module__         == 'functools'
#
# No prior functools spec checks total_ordering class identity via functoolsmore79. New to extra79.
# ---------------------------------------------------------------------------

table functools_extra79.total_ordering_identity:
  description: "total_ordering.__class__.__name__=='function', __module__=='functools'; wave 240 total_ordering function identity; new to extra79"
  kind: python_call_eq
  category: function_identity
  id_prefix: functoolsmore79

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_class_name_eq_function,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a pure-Python class decorator defined in Lib/functools.py; its __class__ is the built-in function type and __class__.__name__ is 'function' (8 chars); str.__eq__('function') returns True; no prior functools spec checks total_ordering.__class__.__name__ via functoolsmore79; new to extra79"]
    - [total_ordering_module_eq_functools,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is a pure-Python decorator defined in Lib/functools.py; its __module__ attribute records the module name as the str 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks total_ordering.__module__ via functoolsmore79; new to extra79"]

# ---------------------------------------------------------------------------
# total_ordering code attributes — extra79
#
# Wave 240 theme: total_ordering code object name and argcount.
#
# total_ordering.__code__.co_name     == 'total_ordering'
# total_ordering.__code__.co_argcount == 1 (cls)
#
# No prior functools spec checks total_ordering __code__ attrs via functoolsmore79. New to extra79.
# ---------------------------------------------------------------------------

table functools_extra79.total_ordering_code:
  description: "total_ordering.__code__.co_name=='total_ordering', co_argcount==1; wave 240 total_ordering code attrs; new to extra79"
  kind: python_call_eq
  category: code_attributes
  id_prefix: functoolsmore79

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_co_name_eq_total_ordering,
       total_ordering.__code__.co_name.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a pure-Python decorator in Lib/functools.py; its code object's co_name stores the name from the def statement which is 'total_ordering' (14 chars); str.__eq__('total_ordering') returns True; no prior functools spec checks total_ordering.__code__.co_name via functoolsmore79; new to extra79"]
    - [total_ordering_co_argcount_eq_1,
       total_ordering.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering is defined as 'def total_ordering(cls):' taking one positional argument (cls); co_argcount counts only positional parameters and equals 1; int.__eq__(1) returns True; no prior functools spec checks total_ordering.__code__.co_argcount via functoolsmore79; new to extra79"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra79
# ---------------------------------------------------------------------------

invariant functools_extra79.reduce_class_builtin:
  description: "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin; wave 240 reduce identity; new to extra79"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra79.reduce_module_functools_c:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce.__module__ is '_functools'; wave 240 reduce identity; new to extra79"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra79.cmp_to_key_module_functools_c:
  description: "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key.__module__ is '_functools'; wave 240 cmp_to_key identity; new to extra79"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra79.total_ordering_co_name:
  description: "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering co_name is 'total_ordering'; wave 240 total_ordering code attrs; new to extra79"
  kind: python_call_eq
  function: total_ordering.__code__.co_name.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra79.total_ordering_co_argcount:
  description: "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering takes 1 positional arg (cls); wave 240 total_ordering code attrs; new to extra79"
  kind: python_call_eq
  function: total_ordering.__code__.co_argcount.__eq__
  args: [1]
  expected: true
