table multiprocessing_extra248.sync_manager_identity:
  description: "multiprocessing.managers.SyncManager(len=11) class identity — inherits from BaseManager(len=11); defined in multiprocessing.managers(len=24); SyncManager and BaseManager share identical name length 11; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp248sm

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,          "multiprocessing.managers.SyncManager.__name__.__eq__",               ["SyncManager"],                   true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'; verified with Python 3.14.3"]
    - [sm_name_len,         "multiprocessing.managers.SyncManager.__name__.__len__",              [],                                11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11 — same as BaseManager name length; verified with Python 3.14.3"]
    - [sm_mod_eq,           "multiprocessing.managers.SyncManager.__module__.__eq__",             ["multiprocessing.managers"],       true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [sm_mod_len,          "multiprocessing.managers.SyncManager.__module__.__len__",            [],                                24,   "multiprocessing.managers.SyncManager.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [sm_base_eq,          "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__",  ["BaseManager"],                   true, "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager' — SyncManager inherits from BaseManager; verified with Python 3.14.3"]
    - [sm_base_len,         "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__", [],                                11,   "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__() == 11 — same length as SyncManager.__name__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra248
# ---------------------------------------------------------------------------

invariant multiprocessing_extra248.value_is_method:
  description: "multiprocessing.Value.__class__.__name__.__eq__('method') returns True — Value (and Array and Manager) are bound methods of a multiprocessing context object defined in Lib/multiprocessing/context.py; they are not standalone functions or classes; this explains why __module__ is 'multiprocessing.context' rather than 'multiprocessing'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra248.sync_manager_and_base_share_name_length:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__() == 11 — 'BaseManager' (len=11) equals SyncManager.__name__.__len__() (also 11); both SyncManager and BaseManager have name length 11; SyncManager.__module__ is 'multiprocessing.managers' (len=24, one more than Value/Array/Manager module len=23); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__"
  args: []
  expected: 11

invariant multiprocessing_extra248.value_array_manager_same_module:
  description: "multiprocessing.Value.__module__.__eq__('multiprocessing.context') returns True — Value, Array, and Manager all share __module__ == 'multiprocessing.context' (len=23); they are bound methods of a DefaultContext instance; SyncManager.__module__ is 'multiprocessing.managers' (len=24, one character longer); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
