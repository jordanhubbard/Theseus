spec: multiprocessing_extra248
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.Value.__name__ == 'Value' (len=5); __class__.__name__ == 'method'; __module__ == 'multiprocessing.context' (len=23)."
    - "multiprocessing.Array.__name__ == 'Array' (len=5); __class__.__name__ == 'method'; __module__ == 'multiprocessing.context' (len=23)."
    - "multiprocessing.Manager.__name__ == 'Manager' (len=7); __class__.__name__ == 'method'; __module__ == 'multiprocessing.context' (len=23)."
    - "Value, Array, and Manager are all 'method' objects (bound methods of a context object), not standalone functions or classes."
    - "Value.__module__ == Array.__module__ == Manager.__module__ == 'multiprocessing.context' (len=23) — all three live in the same context module."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11); __module__ == 'multiprocessing.managers' (len=24); __bases__[0].__name__ == 'BaseManager' (len=11)."
    - "SyncManager.__name__ and SyncManager.__bases__[0].__name__ both have length 11 — SyncManager and BaseManager share the same name length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value identity
#
# multiprocessing.Value.__name__ == 'Value' (len=5)
# multiprocessing.Value.__class__.__name__ == 'method'
# multiprocessing.Value.__module__ == 'multiprocessing.context' (len=23)
# ---------------------------------------------------------------------------

table multiprocessing_extra248.value_array_manager_identity:
  description: "multiprocessing.Value(len=5), Array(len=5), Manager(len=7) identity — all are 'method' objects (bound context methods); all share __module__ == 'multiprocessing.context'(len=23); Value and Array have identical name lengths (5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp248vam

  columns: [id, function, args, expected, description]
  rows:
    - [v_name_eq,           multiprocessing.Value.__name__.__eq__,                 ["Value"],                          true, "multiprocessing.Value.__name__ == 'Value'; verified with Python 3.14.3"]
    - [v_name_len,          multiprocessing.Value.__name__.__len__,                [],                                 5,    "multiprocessing.Value.__name__.__len__() == 5 — same as Array.__name__ length; verified with Python 3.14.3"]
    - [v_cls_eq,            multiprocessing.Value.__class__.__name__.__eq__,       ["method"],                         true, "multiprocessing.Value.__class__.__name__ == 'method' — Value is a bound context method; verified with Python 3.14.3"]
    - [v_mod_eq,            multiprocessing.Value.__module__.__eq__,               ["multiprocessing.context"],        true, "multiprocessing.Value.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [v_mod_len,           multiprocessing.Value.__module__.__len__,              [],                                 23,   "multiprocessing.Value.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [a_name_eq,           multiprocessing.Array.__name__.__eq__,                 ["Array"],                          true, "multiprocessing.Array.__name__ == 'Array'; verified with Python 3.14.3"]
    - [a_name_len,          multiprocessing.Array.__name__.__len__,                [],                                 5,    "multiprocessing.Array.__name__.__len__() == 5 — same as Value.__name__ length; verified with Python 3.14.3"]
    - [a_cls_eq,            multiprocessing.Array.__class__.__name__.__eq__,       ["method"],                         true, "multiprocessing.Array.__class__.__name__ == 'method' — Array is a bound context method; verified with Python 3.14.3"]
    - [a_mod_eq,            multiprocessing.Array.__module__.__eq__,               ["multiprocessing.context"],        true, "multiprocessing.Array.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [a_mod_len,           multiprocessing.Array.__module__.__len__,              [],                                 23,   "multiprocessing.Array.__module__.__len__() == 23 — same as Value module length; verified with Python 3.14.3"]
    - [m_name_eq,           multiprocessing.Manager.__name__.__eq__,               ["Manager"],                        true, "multiprocessing.Manager.__name__ == 'Manager'; verified with Python 3.14.3"]
    - [m_name_len,          multiprocessing.Manager.__name__.__len__,              [],                                 7,    "multiprocessing.Manager.__name__.__len__() == 7 — longer than Value/Array (5); verified with Python 3.14.3"]
    - [m_cls_eq,            multiprocessing.Manager.__class__.__name__.__eq__,     ["method"],                         true, "multiprocessing.Manager.__class__.__name__ == 'method' — Manager is a bound context method; verified with Python 3.14.3"]
    - [m_mod_eq,            multiprocessing.Manager.__module__.__eq__,             ["multiprocessing.context"],        true, "multiprocessing.Manager.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [m_mod_len,           multiprocessing.Manager.__module__.__len__,            [],                                 23,   "multiprocessing.Manager.__module__.__len__() == 23 — all three share same module length; verified with Python 3.14.3"]

