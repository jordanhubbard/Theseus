spec: ft3451
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (ft3451): __getitem__, __setitem__, __delitem__ dict-presence checks for functools types."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (obj[key], obj[key]=val, del obj[key])."
    - "All values False — functools types are callable/descriptor helpers with no container/mapping protocol support."
    - "All other functools types (partialmethod, cached_property, lru_cache wrapper) do not define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3451.getitem:
  description: "functools types __getitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3451
  columns: [id, function, args, expected]
  rows:
    - ["ft3451001", operator.contains, [functools.partial.__dict__,                          "__getitem__"], false]
    - ["ft3451002", operator.contains, [functools.partialmethod.__dict__,                    "__getitem__"], false]
    - ["ft3451003", operator.contains, [functools.cached_property.__dict__,                  "__getitem__"], false]
    - ["ft3451004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__getitem__"], false]

