spec: warnings_extra8
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra7.zspec.zsdl."
    - "warnings_extra7 covers warn.__class__.__name__, warn_explicit.__class__.__name__, _formatwarnmsg_impl.__module__/__qualname__, _filters_mutated.__module__, warnings.__spec__.name, warnings.__file__.__class__.__name__, onceregistry.__len__.__ge__(0)."
    - "warnings_extra6 covers filterwarnings/simplefilter/resetwarnings/showwarning/formatwarning __module__; showwarning/formatwarning __qualname__; built-in warning category __qualname__."
    - "warnings_extra5 covers __qualname__ for warn/warn_explicit/filterwarnings/simplefilter/resetwarnings/catch_warnings/WarningMessage; warning category __class__.__name__."
    - "NOT yet covered: WarningMessage.__module__ == '_py_warnings' as a standalone invariant."
    - "NOT yet covered: catch_warnings.__module__ == '_py_warnings' as a standalone invariant."
    - "NOT yet covered: SyntaxWarning/__name__ and SyntaxWarning/__qualname__ as standalone invariants."
    - "NOT yet covered: ResourceWarning/__name__ and ResourceWarning/__qualname__ as standalone invariants."
    - "NOT yet covered: UnicodeWarning/__name__ and UnicodeWarning/__qualname__ as standalone invariants."
    - "NOT yet covered: BytesWarning/__name__ and BytesWarning/__qualname__ as standalone invariants."
    - "NOT yet covered: DeprecationWarning/__module__ == 'builtins' as a standalone invariant."
    - "NOT yet covered: UserWarning/__module__ == 'builtins' as a standalone invariant."
    - "WarningMessage and catch_warnings are both defined in the Python-layer of warnings; their __module__ is '_py_warnings'."
    - "SyntaxWarning, ResourceWarning, UnicodeWarning, BytesWarning are built-in exception subclasses defined in builtins."
    - "All built-in warning category classes have __module__ == 'builtins'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WarningMessage and catch_warnings — __module__
#
# Prior specs check __name__ and __qualname__ for both; none check __module__.
# Both are defined in the Python-layer of warnings, reported internally as
# '_py_warnings'.
# ---------------------------------------------------------------------------

invariant warnings_extra8.WarningMessage.module:
  description: "warnings.WarningMessage.__module__ == '_py_warnings'"
  category: class_modules
  kind: python_call_eq
  function: WarningMessage.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra8.catch_warnings.module:
  description: "warnings.catch_warnings.__module__ == '_py_warnings'"
  category: class_modules
  kind: python_call_eq
  function: catch_warnings.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# Additional warning category classes — __name__ and __qualname__
#
# warnings_extra6 covers __qualname__ for DeprecationWarning, UserWarning,
# RuntimeWarning, FutureWarning, PendingDeprecationWarning. This spec adds
# __name__ and __qualname__ for SyntaxWarning, ResourceWarning, UnicodeWarning,
# and BytesWarning — the remaining standard warning categories.
# ---------------------------------------------------------------------------

table warnings_extra8.extra_category_names:
  description: "Additional built-in warning categories: __name__ identity checks"
  kind: python_call_eq
  category: warning_category_names
  id_prefix: catname

  columns: [id, function, args, expected]
  rows:
    - [SyntaxWarning,   SyntaxWarning.__name__.__eq__,   ["SyntaxWarning"],   true]
    - [ResourceWarning, ResourceWarning.__name__.__eq__,  ["ResourceWarning"],  true]
    - [UnicodeWarning,  UnicodeWarning.__name__.__eq__,  ["UnicodeWarning"],  true]
    - [BytesWarning,    BytesWarning.__name__.__eq__,    ["BytesWarning"],    true]

table warnings_extra8.extra_category_qualnames:
  description: "Additional built-in warning categories: __qualname__ identity checks"
  kind: python_call_eq
  category: warning_category_qualnames
  id_prefix: catqualname

  columns: [id, function, args, expected]
  rows:
    - [SyntaxWarning,   SyntaxWarning.__qualname__.__eq__,   ["SyntaxWarning"],   true]
    - [ResourceWarning, ResourceWarning.__qualname__.__eq__,  ["ResourceWarning"],  true]
    - [UnicodeWarning,  UnicodeWarning.__qualname__.__eq__,  ["UnicodeWarning"],  true]
    - [BytesWarning,    BytesWarning.__qualname__.__eq__,    ["BytesWarning"],    true]

# ---------------------------------------------------------------------------
# Built-in warning category __module__ == 'builtins'
#
# No prior warnings spec records __module__ for any warning category class.
# All built-in warning categories (DeprecationWarning, UserWarning, etc.) are
# defined in the builtins module, so their __module__ is 'builtins'.
# ---------------------------------------------------------------------------

table warnings_extra8.category_modules:
  description: "Built-in warning categories are defined in the 'builtins' module"
  kind: python_call_eq
  category: warning_category_modules
  id_prefix: catmod

  columns: [id, function, args, expected]
  rows:
    - [DeprecationWarning, DeprecationWarning.__module__.__eq__, ["builtins"], true]
    - [UserWarning,        UserWarning.__module__.__eq__,        ["builtins"], true]
    - [RuntimeWarning,     RuntimeWarning.__module__.__eq__,     ["builtins"], true]
    - [SyntaxWarning,      SyntaxWarning.__module__.__eq__,      ["builtins"], true]
    - [ResourceWarning,    ResourceWarning.__module__.__eq__,    ["builtins"], true]
