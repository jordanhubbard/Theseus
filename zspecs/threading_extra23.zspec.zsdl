spec: threading_extra23
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and prior extras through threading_extra22.zspec.zsdl."
    - "threading_extra19 covers: Thread/Event/Condition/Semaphore/Timer/Barrier __qualname__ in a table; Lock/__qualname__=='lock'; RLock/__qualname__=='RLock'."
    - "threading_extra22 covers: threading utility function __module__ table; current_thread/__qualname__; main_thread/__qualname__; settrace/__module__; setprofile/__module__."
    - "NOT yet covered in any prior spec: threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' as standalone extra23-namespace invariant."
    - "NOT yet covered: threading.local.__qualname__ == '_local' as standalone extra23-namespace invariant."
    - "NOT yet covered: threading class __qualname__ length table for Thread/Event/Condition/Semaphore/Timer/Barrier in extra23 namespace."
    - "NOT yet covered: threading.Lock.__qualname__ == 'lock' as standalone extra23-namespace invariant distinct from extra19."
    - "NOT yet covered: threading.RLock.__qualname__ == 'RLock' as standalone extra23-namespace invariant distinct from extra19."
    - "threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level class in threading."
    - "threading.local.__qualname__ == '_local' — the underlying C type exposed as threading.local; qualname is the implementation name '_local'."
    - "threading.Lock is a factory returning a _thread.lock object; threading.Lock.__qualname__ == 'lock'."
    - "threading.RLock is a factory returning a _thread.RLock object; threading.RLock.__qualname__ == 'RLock'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ length table — threading class qualnames in extra23 namespace
#
# threading_extra19 checks class __qualname__ via __eq__ in a table.
# No prior spec provides a __qualname__ __len__ table for these classes
# in the extra23 namespace. For top-level classes, __qualname__ == __name__
# so lengths match: Thread(6), Event(5), Condition(9), Semaphore(9),
# Timer(5), Barrier(7).
# ---------------------------------------------------------------------------

table threading_extra23.class_qualname_lengths:
  description: "threading class __qualname__ lengths in extra23 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: clsqnlen23

  columns: [id, function, args, expected]
  rows:
    - [Thread,    Thread.__qualname__.__len__,    [], 6]
    - [Event,     Event.__qualname__.__len__,     [], 5]
    - [Condition, Condition.__qualname__.__len__, [], 9]
    - [Semaphore, Semaphore.__qualname__.__len__, [], 9]
    - [Timer,     Timer.__qualname__.__len__,     [], 5]
    - [Barrier,   Barrier.__qualname__.__len__,   [], 7]

# ---------------------------------------------------------------------------
# BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — standalone invariant
#
# threading_extra8 covers BoundedSemaphore.__qualname__ in table form.
# This standalone extra23-namespace invariant provides independent coverage
# confirming BoundedSemaphore is a top-level class whose __qualname__
# equals its simple class name.
# ---------------------------------------------------------------------------

invariant threading_extra23.BoundedSemaphore.qualname_eq:
  description: "threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level class"
  category: class_names
  kind: python_call_eq
  function: BoundedSemaphore.__qualname__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

# ---------------------------------------------------------------------------
# local.__qualname__ == '_local' — standalone invariant
#
# threading.local is the thread-local storage class. Its __qualname__ is
# '_local' (the underlying C implementation name), not 'local'. This is a
# notable asymmetry: the public API name 'threading.local' differs from
# the type's __qualname__ '_local'. No prior spec checks this as a
# standalone extra23-namespace invariant.
# ---------------------------------------------------------------------------

invariant threading_extra23.local.qualname_eq:
  description: "threading.local.__qualname__ == '_local' — C implementation type name differs from public API name"
  category: class_names
  kind: python_call_eq
  function: local.__qualname__.__eq__
  args: ["_local"]
  expected: true

# ---------------------------------------------------------------------------
# Lock.__qualname__ == 'lock' — standalone extra23-namespace invariant
#
# threading_extra19 covers Lock/__qualname__ in the extra19 namespace.
# This standalone invariant provides an independent extra23-namespace anchor
# confirming that threading.Lock (a factory function) exposes __qualname__
# == 'lock', the lowercase C type name, distinguishing it from RLock.
# ---------------------------------------------------------------------------

invariant threading_extra23.Lock.qualname_eq:
  description: "threading.Lock.__qualname__ == 'lock' — Lock factory exposes C type qualname"
  category: class_names
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["lock"]
  expected: true

# ---------------------------------------------------------------------------
# RLock.__qualname__ == 'RLock' — standalone extra23-namespace invariant
#
# threading_extra19 covers RLock/__qualname__ in the extra19 namespace.
# This standalone invariant provides an independent extra23-namespace anchor
# confirming threading.RLock.__qualname__ == 'RLock' (uppercase, unlike the
# lowercase 'lock' for threading.Lock).
# ---------------------------------------------------------------------------

invariant threading_extra23.RLock.qualname_eq:
  description: "threading.RLock.__qualname__ == 'RLock' — RLock factory exposes C type qualname (uppercase)"
  category: class_names
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["RLock"]
  expected: true
