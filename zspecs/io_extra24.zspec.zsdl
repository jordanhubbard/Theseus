spec: io_extra24
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE type/value; StringIO/BytesIO basic class checks"
    - "io_extra22.zspec.zsdl — covers DEFAULT_BUFFER_SIZE.__class__.__name__/ge_4096; UnsupportedOperation qualname/module/base0; BlockingIOError qualname; StringIO/BytesIO/BufferedReader qualname; class __module__ table"
    - "io_extra23.zspec.zsdl — covers StringIO/BytesIO getvalue/read/writable instance method calls"
  notes:
    - "This spec extends io.zspec.zsdl and prior extras through io_extra23.zspec.zsdl."
    - "io.BytesIO.__name__ == 'BytesIO' — class-level __name__ for BytesIO; covered in prior specs, re-anchored as standalone in extra24 namespace."
    - "io.StringIO.__name__ == 'StringIO' — class-level __name__ for StringIO; covered in prior specs, re-anchored here."
    - "io.BufferedReader.__name__ == 'BufferedReader' — covered in prior specs; re-anchored in extra24 namespace."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' — covered in prior specs; re-anchored in extra24 namespace."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — covered in prior specs; re-anchored in extra24 namespace."
    - "io.RawIOBase.__name__ == 'RawIOBase' — covered in prior specs; re-anchored in extra24 namespace."
    - "io.BytesIO.__qualname__ == 'BytesIO' — __qualname__ for BytesIO; no prior spec covers this as a standalone invariant."
    - "io.StringIO.__qualname__ == 'StringIO' — __qualname__ for StringIO; no prior spec covers this as a standalone invariant."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — no prior spec covers this as a standalone invariant."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — no prior spec covers this as a standalone invariant."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — no prior spec covers this as a standalone invariant."
    - "io.RawIOBase.__qualname__ == 'RawIOBase' — no prior spec covers this as a standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — BytesIO, StringIO, BufferedReader, BufferedWriter,
#                  TextIOWrapper, RawIOBase
#
# Prior specs cover these __name__ values in various standalone invariants and
# table rows across different namespace prefixes. This table re-anchors all six
# in the extra24 namespace as a single grouped cross-check.
# ---------------------------------------------------------------------------

table io_extra24.class_names:
  description: "__name__ for BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper/RawIOBase"
  kind: python_call_eq
  category: class_identity
  id_prefix: cname24

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,        BytesIO.__name__.__eq__,        ["BytesIO"],        true]
    - [StringIO,       StringIO.__name__.__eq__,       ["StringIO"],       true]
    - [BufferedReader, BufferedReader.__name__.__eq__, ["BufferedReader"], true]
    - [BufferedWriter, BufferedWriter.__name__.__eq__, ["BufferedWriter"], true]
    - [TextIOWrapper,  TextIOWrapper.__name__.__eq__,  ["TextIOWrapper"],  true]
    - [RawIOBase,      RawIOBase.__name__.__eq__,      ["RawIOBase"],      true]

# ---------------------------------------------------------------------------
# __qualname__ standalone invariants — BytesIO, StringIO, BufferedReader,
#                                      BufferedWriter, TextIOWrapper, RawIOBase
#
# No prior io spec covers __qualname__ for these six classes as standalone
# invariants. For top-level classes, __qualname__ equals __name__. This is a
# distinct property from __name__ and merits independent coverage.
# ---------------------------------------------------------------------------

invariant io_extra24.BytesIO.qualname:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — top-level class qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra24.StringIO.qualname:
  description: "io.StringIO.__qualname__ == 'StringIO' — top-level class qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra24.BufferedReader.qualname:
  description: "io.BufferedReader.__qualname__ == 'BufferedReader' — top-level class qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra24.BufferedWriter.qualname:
  description: "io.BufferedWriter.__qualname__ == 'BufferedWriter' — top-level class qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__qualname__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra24.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — top-level class qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra24.RawIOBase.qualname:
  description: "io.RawIOBase.__qualname__ == 'RawIOBase' — top-level abstract base qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__qualname__.__eq__
  args: ["RawIOBase"]
  expected: true
