spec: gc_extra10
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra9.zspec.zsdl."
    - "gc_extra9 covers __class__.__name__ for remaining gc functions (disable/isenabled/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents/is_tracked/freeze/unfreeze), is_tracked(0)/is_tracked(-1), collect(1)/collect(2) return type and nonneg, get_threshold()[2] default."
    - "gc_extra7 covers collect/enable/is_finalized/get_freeze_count __class__.__name__."
    - "gc_extra4 covers __name__/__qualname__ for all major gc functions."
    - "NOT yet covered: gc.collect.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.disable.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.enable.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.isenabled.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.get_count.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.get_threshold.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.set_threshold.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.get_objects.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.get_referrers.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.get_referents.__module__.__eq__('gc') via standalone invariant."
    - "NOT yet covered: gc.get_threshold().__class__.__name__ == 'tuple' as standalone invariant."
    - "NOT yet covered: gc.get_threshold().__len__() == 3 as standalone invariant."
    - "NOT yet covered: gc.get_count().__class__.__name__ == 'tuple' as standalone invariant."
    - "All gc module-level functions are C builtins and report __module__ == 'gc'."
    - "gc.get_threshold() returns a 3-tuple: (threshold0, threshold1, threshold2)."
    - "gc.get_count() returns a 3-tuple: (count0, count1, count2) — one entry per generation."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — all major gc functions via __eq__ chain
#
# gc_extra4 covers __module__ for several gc functions via a table. This spec
# provides standalone invariants for each function using the __module__.__eq__
# method chain pattern, forming explicit boolean contracts.
# ---------------------------------------------------------------------------

invariant gc_extra10.collect.module:
  description: "gc.collect.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: collect.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.disable.module:
  description: "gc.disable.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: disable.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.enable.module:
  description: "gc.enable.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: enable.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.isenabled.module:
  description: "gc.isenabled.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: isenabled.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.get_count.module:
  description: "gc.get_count.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: get_count.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.get_threshold.module:
  description: "gc.get_threshold.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: get_threshold.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.set_threshold.module:
  description: "gc.set_threshold.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: set_threshold.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.get_objects.module:
  description: "gc.get_objects.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: get_objects.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.get_referrers.module:
  description: "gc.get_referrers.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: get_referrers.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra10.get_referents.module:
  description: "gc.get_referents.__module__.__eq__('gc') == True"
  category: function_modules
  kind: python_call_eq
  function: get_referents.__module__.__eq__
  args: ["gc"]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold() return type and length
#
# gc.zspec.zsdl and gc_extra verify get_threshold() returns a tuple and its
# length via separate angle. This spec asserts both as standalone boolean
# invariants using the __eq__ method chain.
# gc.get_threshold() always returns exactly 3 values: gen-0, gen-1, gen-2 thresholds.
# ---------------------------------------------------------------------------

invariant gc_extra10.get_threshold.class_is_tuple:
  description: "gc.get_threshold().__class__.__name__.__eq__('tuple') == True — return type is tuple"
  category: threshold
  kind: python_call_eq
  function: get_threshold().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant gc_extra10.get_threshold.len_is_3:
  description: "gc.get_threshold().__len__() == 3 — threshold tuple has exactly 3 elements"
  category: threshold
  kind: python_call_eq
  function: get_threshold().__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# get_count() return class name
#
# gc_extra2 checks get_count().__len__() == 3 (the tuple has 3 entries).
# No prior spec checks get_count().__class__.__name__ == 'tuple' as a
# standalone boolean invariant using the __eq__ method chain.
# ---------------------------------------------------------------------------

invariant gc_extra10.get_count.class_is_tuple:
  description: "gc.get_count().__class__.__name__.__eq__('tuple') == True — return type is tuple"
  category: get_count
  kind: python_call_eq
  function: get_count().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
