spec: socket_extra254
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 254 theme: socket.socket additional send/recv variant and name/address method identity."
    - "socket.socket.sendall.__name__ == 'sendall'. sendall is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__name__ == 'sendto'. sendto is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__name__ == 'recvfrom'. recvfrom is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvmsg.__name__ == 'recvmsg'. recvmsg is present on macOS (POSIX). recvmsg is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__name__ == 'getpeername'. getpeername is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__name__ == 'getsockname'. getsockname is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__name__ == 'setblocking'. setblocking is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getblocking.__name__ == 'getblocking'. getblocking is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__name__ == 'shutdown'. shutdown is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All tested socket.socket methods are method_descriptor objects (C-level descriptors from Modules/socketmodule.c), not Python functions or slot wrappers."
    - "Note: recvmsg is available on POSIX platforms (macOS, Linux) but not on Windows. This spec targets macOS/Darwin where it is present."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.sendall.__name__.__eq__('sendall')
# socket.socket.sendto.__name__.__eq__('sendto')
# socket.socket.recvfrom.__name__.__eq__('recvfrom')
# socket.socket.recvmsg.__name__.__eq__('recvmsg')
#
# Wave 254 theme: socket.socket send/recv variant method __name__ identity.
#
# sendall, sendto, recvfrom, and recvmsg are C-level method_descriptor objects
# on socket.socket from Modules/socketmodule.c. sendall sends all data by
# looping until complete. sendto sends to a specific address (UDP). recvfrom
# receives and returns (data, address) pair. recvmsg is POSIX-only (present on
# macOS/Darwin). All have __name__ equal to their method name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra254.send_recv_variant_name_identity:
  description: "socket.socket send/recv variant method __name__ identity — sendall/sendto/recvfrom/recvmsg all have __name__ equal to their method name — all are C-level method_descriptor objects; sendall loops until complete; sendto sends to address (UDP); recvfrom returns (data, address); recvmsg is POSIX-only; wave 254 theme; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: identity
  id_prefix: sockmethod254a

  columns: [id, function, args, expected, description]
  rows:
    - [sendall_name,  socket.sendall.__name__.__eq__,   ["sendall"],  true, "socket.socket.sendall.__name__ == 'sendall'; loops until all data sent; C method_descriptor"]
    - [sendto_name,   socket.sendto.__name__.__eq__,    ["sendto"],   true, "socket.socket.sendto.__name__ == 'sendto'; sends to specific address (UDP); C method_descriptor"]
    - [recvfrom_name, socket.recvfrom.__name__.__eq__,  ["recvfrom"], true, "socket.socket.recvfrom.__name__ == 'recvfrom'; returns (data, address) pair; C method_descriptor"]
    - [recvmsg_name,  socket.recvmsg.__name__.__eq__,   ["recvmsg"],  true, "socket.socket.recvmsg.__name__ == 'recvmsg'; POSIX-only (macOS/Linux); C method_descriptor"]

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__name__.__eq__('getpeername')
# socket.socket.getsockname.__name__.__eq__('getsockname')
# socket.socket.setblocking.__name__.__eq__('setblocking')
# socket.socket.getblocking.__name__.__eq__('getblocking')
# socket.socket.shutdown.__name__.__eq__('shutdown')
#
# Wave 254 theme: socket.socket name/address and blocking/shutdown method identity.
#
# getpeername returns the address of the remote end of a connected socket.
# getsockname returns the socket's own bound address. setblocking(True/False)
# toggles blocking mode. getblocking() returns the current blocking state (bool).
# shutdown(how) shuts down sending/receiving (SHUT_RD, SHUT_WR, SHUT_RDWR).
# All are C-level method_descriptor objects from Modules/socketmodule.c.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra254.name_address_blocking_shutdown_identity:
  description: "socket.socket name/address/blocking/shutdown method __name__ identity — getpeername/getsockname/setblocking/getblocking/shutdown all have __name__ equal to their method name — all are C-level method_descriptor objects; getpeername returns remote address; getsockname returns local address; setblocking/getblocking toggle/query blocking mode; shutdown(how) partially or fully closes socket; wave 254 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockmethod254b

  columns: [id, function, args, expected, description]
  rows:
    - [getpeername_name, socket.getpeername.__name__.__eq__,  ["getpeername"], true, "socket.socket.getpeername.__name__ == 'getpeername'; returns remote address of connected socket"]
    - [getsockname_name, socket.getsockname.__name__.__eq__,  ["getsockname"], true, "socket.socket.getsockname.__name__ == 'getsockname'; returns socket's own bound address"]
    - [setblocking_name, socket.setblocking.__name__.__eq__,  ["setblocking"], true, "socket.socket.setblocking.__name__ == 'setblocking'; toggles blocking/non-blocking mode"]
    - [getblocking_name, socket.getblocking.__name__.__eq__,  ["getblocking"], true, "socket.socket.getblocking.__name__ == 'getblocking'; returns current blocking state as bool"]
    - [shutdown_name,    socket.shutdown.__name__.__eq__,     ["shutdown"],    true, "socket.socket.shutdown.__name__ == 'shutdown'; shuts down send/recv via SHUT_RD/WR/RDWR"]

# ---------------------------------------------------------------------------
# socket.socket.sendall.__class__.__name__.__eq__('method_descriptor')
# socket.socket.recvfrom.__class__.__name__.__eq__('method_descriptor')
# socket.socket.shutdown.__class__.__name__.__eq__('method_descriptor')
#
# Wave 254 theme: socket.socket method class type identity (method_descriptor).
#
# All socket.socket methods are C-level method_descriptor objects, not Python
# functions or slot_wrapper objects. method_descriptor is the type of C-level
# methods defined via PyMethodDef in extension types. This is distinct from
# wrapper_descriptor (used for slots like __init__) and from Python functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra254.method_class_identity:
  description: "socket.socket methods are method_descriptor objects — sendall/recvfrom/shutdown all have __class__.__name__ == 'method_descriptor' — method_descriptor is the type of C-level methods defined via PyMethodDef in extension types; distinct from wrapper_descriptor (slots) and Python function; wave 254 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass254

  columns: [id, function, args, expected, description]
  rows:
    - [sendall_class,  socket.sendall.__class__.__name__.__eq__,   ["method_descriptor"], true, "socket.socket.sendall.__class__.__name__ == 'method_descriptor'; C PyMethodDef method"]
    - [recvfrom_class, socket.recvfrom.__class__.__name__.__eq__,  ["method_descriptor"], true, "socket.socket.recvfrom.__class__.__name__ == 'method_descriptor'; C PyMethodDef method"]
    - [shutdown_class, socket.shutdown.__class__.__name__.__eq__,  ["method_descriptor"], true, "socket.socket.shutdown.__class__.__name__ == 'method_descriptor'; C PyMethodDef method"]

# ---------------------------------------------------------------------------
# socket.socket.sendall.__name__.__eq__('sendall') — standalone
#
# socket.socket.sendall.__name__ is 'sendall'. sendall is the "send everything"
# method on socket objects. Unlike socket.send() which may send only part of
# the data (returning the number of bytes actually sent), sendall() loops
# internally until all data has been sent or an error occurs. It returns None
# on success and raises OSError on failure. For non-blocking sockets, sendall
# raises BlockingIOError if the send buffer is full. sendall is implemented
# as a C method_descriptor in Modules/socketmodule.c. Its __name__ is
# 'sendall' confirming the identity. This is the first standalone anchor for
# sendall.__name__ under sockmethod254a. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra254.sendall_name:
  description: "socket.socket.sendall.__name__.__eq__('sendall') == True — sendall loops until all data sent (unlike send which may be partial); returns None on success; raises OSError on error; raises BlockingIOError on non-blocking socket with full buffer; C method_descriptor in Modules/socketmodule.c; first standalone for sendall.__name__ under sockmethod254a; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: socket.sendall.__name__.__eq__
  args: ["sendall"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__name__.__eq__('getpeername') — standalone
#
# socket.socket.getpeername.__name__ is 'getpeername'. getpeername() returns
# the address of the remote end of a connected socket as a (host, port) tuple
# for AF_INET sockets or a string for AF_UNIX sockets. It raises OSError if
# the socket is not connected (e.g., ENOTCONN). getpeername is the BSD socket
# API function corresponding to the POSIX getpeername(2) system call. It is
# implemented as a C method_descriptor in Modules/socketmodule.c. Its __name__
# is 'getpeername'. This is the first standalone anchor for getpeername.__name__
# under sockmethod254b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra254.getpeername_name:
  description: "socket.socket.getpeername.__name__.__eq__('getpeername') == True — getpeername returns remote address of connected socket as (host, port) for AF_INET or string for AF_UNIX; raises OSError (ENOTCONN) if not connected; corresponds to POSIX getpeername(2) syscall; C method_descriptor in Modules/socketmodule.c; first standalone for getpeername.__name__ under sockmethod254b; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: socket.getpeername.__name__.__eq__
  args: ["getpeername"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setblocking.__name__.__eq__('setblocking') — standalone
#
# socket.socket.setblocking.__name__ is 'setblocking'. setblocking(flag) sets
# the socket to blocking mode (flag=True) or non-blocking mode (flag=False).
# Internally it calls settimeout(None) for blocking mode and settimeout(0.0)
# for non-blocking mode. In non-blocking mode, socket operations that would
# block raise BlockingIOError instead of waiting. setblocking is implemented
# as a C method_descriptor in Modules/socketmodule.c. Its __name__ is
# 'setblocking'. This is the first standalone anchor for setblocking.__name__
# under sockmethod254b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra254.setblocking_name:
  description: "socket.socket.setblocking.__name__.__eq__('setblocking') == True — setblocking(flag) sets blocking (True) or non-blocking (False) mode; internally calls settimeout(None) for blocking or settimeout(0.0) for non-blocking; non-blocking operations raise BlockingIOError instead of waiting; C method_descriptor in Modules/socketmodule.c; first standalone for setblocking.__name__ under sockmethod254b; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: socket.setblocking.__name__.__eq__
  args: ["setblocking"]
  expected: true
