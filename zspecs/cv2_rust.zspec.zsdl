spec: cv2_rust
version: ">=3.9"
backend: rust_module(cv2_rust)

docs: https://docs.opencv.org/4.x/d6/d00/tutorial_py_root.html

provenance:
  derived_from:
    - "https://docs.opencv.org/4.x/ — OpenCV Python documentation"
  not_derived_from:
    - "opencv source: modules/python/src2/cv2.cpp"
  notes:
    - "OpenCV (cv2) provides computer vision functions."
    - "cv2.getTickFrequency() > 0 — always positive."
    - "np.zeros((100, 100, 3), dtype=np.uint8).shape == (100, 100, 3)."
    - "cv2.resize(img, (50, 50)).shape == (50, 50, 3)."
    - "img = np.zeros((100,100,3), dtype=np.uint8); cv2.resize(img, (50,50)).shape[0] == 50."
    - "Expose cv2_zeros_shape(h, w) -> list: list(np.zeros((h,w,3), dtype=np.uint8).shape)."
    - "Expose cv2_resize_shape(h, w, new_h, new_w) -> list: list(cv2.resize(np.zeros((h,w,3),dtype=np.uint8),(new_w,new_h)).shape)."
    - "Expose cv2_version_major() -> int: int(cv2.__version__.split('.')[0])."
    - "All test vectors verified against opencv-python 4.11.0.86."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# cv2_zeros_shape — zeros image shape
table cv2_rust.image.zeros_shape:
  kind: python_call_eq
  category: zeros_shape
  id_prefix: cv2_zs
  function: cv2_zeros_shape

  columns: [id, args, expected]
  rows:
    - [hundred,  [100, 100], [100, 100, 3]]
    - [rect,     [50, 200],  [50, 200, 3]]

# cv2_resize_shape — resized image shape
table cv2_rust.image.resize_shape:
  kind: python_call_eq
  category: resize_shape
  id_prefix: cv2_rs
  function: cv2_resize_shape

  columns: [id, args, expected]
  rows:
    - [half,    [100, 100, 50, 50],  [50, 50, 3]]
    - [double,  [50, 50, 100, 100],  [100, 100, 3]]

# cv2_version_major — major version >= 4
invariant cv2_rust.version.major_ge_4:
  description: "cv2 major version >= 4"
  category: version
  kind: python_call_eq
  function: cv2_version_major
  args: []
  expected: 4

