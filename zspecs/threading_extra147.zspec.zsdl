spec: threading_extra147
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Condition class identity — __name__ 'Condition' len 9, __module__ 'threading', __doc__ len 338, MRO len 2, __bases__[0].__name__ 'object'; threading.Condition method qualnames — notify __qualname__ 'Condition.notify' len 16, notify_all 'Condition.notify_all' len 20, wait 'Condition.wait' len 14, wait_for 'Condition.wait_for' len 18, notifyAll 'Condition.notifyAll' len 19; threading.Condition method co_argcount — notify 2, notify_all 1, wait 2, wait_for 3; threading.Event class identity — __name__ 'Event' len 5, __module__ 'threading', __doc__ len 226, MRO len 2; threading.Event method qualnames — set 'Event.set' len 9, clear 'Event.clear' len 11, wait 'Event.wait' len 10, is_set 'Event.is_set' len 12 (Wave 274)."
    - "threading.Condition is a Python class in Lib/threading.py; __name__ == 'Condition' (len 9); __module__ == 'threading'; __doc__ len == 338; MRO len == 2; __bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' (len 16); co_argcount == 2 (self, n). Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len 20); co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' (len 14); co_argcount == 2 (self, timeout). Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len 18); co_argcount == 3 (self, predicate, timeout). Verified with Python 3.14.3."
    - "threading.Condition.notifyAll.__qualname__ == 'Condition.notifyAll' (len 19); co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' (len 5); __doc__ len == 226; MRO len == 2. Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' (len 9); Event.clear.__qualname__ == 'Event.clear' (len 11); Event.wait.__qualname__ == 'Event.wait' (len 10); Event.is_set.__qualname__ == 'Event.is_set' (len 12). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition class identity
#
# Wave 274 theme: threading.Condition — a synchronization primitive that allows
# threads to wait for some condition to become true.
#
# threading.Condition.__class__.__name__ == 'type'
# threading.Condition.__name__ == 'Condition' (len 9)
# threading.Condition.__qualname__ == 'Condition' (len 9)
# threading.Condition.__module__ == 'threading' (len 9)
# len(threading.Condition.__doc__) == 338
# len(threading.Condition.__mro__) == 2
# threading.Condition.__bases__[0].__name__ == 'object'
#
# Condition is defined in Lib/threading.py; it does not inherit from any
# threading-specific base. New to extra147.
# ---------------------------------------------------------------------------

table threading_extra147.condition_class_identity:
  description: "threading.Condition: Python class, __name__ 'Condition' len 9, __module__ 'threading', __doc__ len 338, MRO len 2, __bases__[0]=='object'; wave 274; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcond147

  columns: [id, function, args, expected, description]
  rows:
    - [condition_class_name_eq_type,
       "Condition.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Condition.__class__.__name__.__eq__('type') == True — Condition is a Python class defined in Lib/threading.py; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra147"]
    - [condition_name_eq,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — the class __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra147"]
    - [condition_name_len_eq_9,
       "Condition.__name__.__len__",
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — __name__ is 'Condition' which has 9 characters; len('Condition') == 9; new to extra147"]
    - [condition_module_eq_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra147"]
    - [condition_doc_len_eq_338,
       "Condition.__doc__.__len__",
       [],
       338,
       "threading.Condition.__doc__.__len__() == 338 — the Condition class docstring has 338 characters; Condition implements a condition variable for thread synchronization; len(__doc__) == 338; verified with Python 3.14.3; new to extra147"]
    - [condition_mro_len_eq_2,
       "Condition.__mro__.__len__",
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — Condition inherits directly from object; MRO is [Condition, object]; len(__mro__) is 2; new to extra147"]
    - [condition_bases_first_eq_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition inherits directly from object with no intermediate threading base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition method qualnames and co_argcount
#
# Wave 274 theme: threading.Condition methods — notify, notify_all, wait, wait_for,
# notifyAll — all follow the 'Condition.<method>' qualname pattern.
#
# threading.Condition.notify.__qualname__ == 'Condition.notify' (len 16)
# threading.Condition.notify.__code__.co_argcount == 2
# threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len 20)
# threading.Condition.notify_all.__code__.co_argcount == 1
# threading.Condition.wait.__qualname__ == 'Condition.wait' (len 14)
# threading.Condition.wait.__code__.co_argcount == 2
# threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len 18)
# threading.Condition.wait_for.__code__.co_argcount == 3
# threading.Condition.notifyAll.__qualname__ == 'Condition.notifyAll' (len 19)
# threading.Condition.notifyAll.__code__.co_argcount == 1
#
# All Condition methods are Python functions with 'Condition.<method>' qualnames.
# New to extra147.
# ---------------------------------------------------------------------------

table threading_extra147.condition_method_qualnames:
  description: "threading.Condition methods: notify (qualname len 16, co_argcount 2), notify_all (len 20, co_argcount 1), wait (len 14, co_argcount 2), wait_for (len 18, co_argcount 3), notifyAll (len 19, co_argcount 1); wave 274; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcondmethods147

  columns: [id, function, args, expected, description]
  rows:
    - [notify_qualname_eq,
       "Condition.notify.__qualname__.__eq__",
       ["Condition.notify"],
       true,
