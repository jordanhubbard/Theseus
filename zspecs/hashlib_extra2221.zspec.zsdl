spec: hashlib_extra2221
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib.zspec.zsdl"
    - "_hashlib.zspec.zsdl"
  notes:
    - "Wave _extra2221: identity/display protocol dict-presence checks for hashlib classes."
    - "Covers __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ presence in blake2b and blake2s class dicts."
    - "hashlib.blake2b and hashlib.blake2s are C extension types implemented in _blake2."
    - "C extension types typically do not store __hash__, __repr__, __str__, __qualname__, or __name__ in their own __dict__."
    - "blake2b.__module__ == '_blake2' — the C extension module, not 'hashlib'."
    - "blake2s.__module__ == '_blake2' — the C extension module, not 'hashlib'."
    - "__doc__ is present in both blake2b.__dict__ and blake2s.__dict__ (set by the C extension)."
    - "__new__ is present in blake2b.__dict__ and blake2s.__dict__ (C extension constructor slot)."
    - "__init__ is NOT present in blake2b.__dict__ or blake2s.__dict__ (C extension uses __new__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2221.blake2b_identity_protocol:
  description: "hashlib.blake2b identity/display protocol dict-presence: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2221

  columns: [id, function, args, expected]
  rows:
    - ["hl2221001", "hashlib.blake2b.__dict__.__contains__", ["__hash__"],     false]
    - ["hl2221002", "hashlib.blake2b.__dict__.__contains__", ["__repr__"],     false]
    - ["hl2221003", "hashlib.blake2b.__dict__.__contains__", ["__str__"],      false]
    - ["hl2221004", "hashlib.blake2b.__dict__.__contains__", ["__doc__"],      true]
    - ["hl2221005", "hashlib.blake2b.__dict__.__contains__", ["__module__"],   true]
    - ["hl2221006", "hashlib.blake2b.__dict__.__contains__", ["__qualname__"], false]
    - ["hl2221007", "hashlib.blake2b.__dict__.__contains__", ["__name__"],     false]

table hashlib_extra2221.blake2s_identity_protocol:
  description: "hashlib.blake2s identity/display protocol dict-presence: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2221

  columns: [id, function, args, expected]
  rows:
    - ["hl2221008", "hashlib.blake2s.__dict__.__contains__", ["__hash__"],     false]
    - ["hl2221009", "hashlib.blake2s.__dict__.__contains__", ["__repr__"],     false]
    - ["hl2221010", "hashlib.blake2s.__dict__.__contains__", ["__str__"],      false]
    - ["hl2221011", "hashlib.blake2s.__dict__.__contains__", ["__doc__"],      true]
    - ["hl2221012", "hashlib.blake2s.__dict__.__contains__", ["__module__"],   true]
    - ["hl2221013", "hashlib.blake2s.__dict__.__contains__", ["__qualname__"], false]
    - ["hl2221014", "hashlib.blake2s.__dict__.__contains__", ["__name__"],     false]

table hashlib_extra2221.blake2b_constructor_protocol:
  description: "hashlib.blake2b constructor/lifecycle dict-presence: __new__, __init__, __format__, __bytes__, __reduce__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2221

  columns: [id, function, args, expected]
  rows:
    - ["hl2221015", "hashlib.blake2b.__dict__.__contains__", ["__new__"],    true]
    - ["hl2221016", "hashlib.blake2b.__dict__.__contains__", ["__init__"],   false]
    - ["hl2221017", "hashlib.blake2b.__dict__.__contains__", ["__format__"], false]
    - ["hl2221018", "hashlib.blake2b.__dict__.__contains__", ["__bytes__"],  false]
    - ["hl2221019", "hashlib.blake2b.__dict__.__contains__", ["__reduce__"], false]

table hashlib_extra2221.blake2s_constructor_protocol:
  description: "hashlib.blake2s constructor/lifecycle dict-presence: __new__, __init__, __format__, __bytes__, __reduce__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2221

  columns: [id, function, args, expected]
  rows:
    - ["hl2221020", "hashlib.blake2s.__dict__.__contains__", ["__new__"],    true]
    - ["hl2221021", "hashlib.blake2s.__dict__.__contains__", ["__init__"],   false]
    - ["hl2221022", "hashlib.blake2s.__dict__.__contains__", ["__format__"], false]
    - ["hl2221023", "hashlib.blake2s.__dict__.__contains__", ["__bytes__"],  false]
    - ["hl2221024", "hashlib.blake2s.__dict__.__contains__", ["__reduce__"], false]

table hashlib_extra2221.cross_checks:
  description: "hashlib cross-checks: blake2b vs blake2s symmetry and C-extension dict-absence patterns"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2221

  columns: [id, function, args, expected]
  rows:
    - ["hl2221025", "hashlib.blake2b.__dict__.__contains__", ["__hash__"],   false]
    - ["hl2221026", "hashlib.blake2s.__dict__.__contains__", ["__hash__"],   false]
    - ["hl2221027", "hashlib.blake2b.__dict__.__contains__", ["__doc__"],    true]
    - ["hl2221028", "hashlib.blake2s.__dict__.__contains__", ["__doc__"],    true]
    - ["hl2221029", "hashlib.blake2b.__dict__.__contains__", ["__module__"], true]
    - ["hl2221030", "hashlib.blake2s.__dict__.__contains__", ["__module__"], true]
