spec: socket_extra44
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra43.zspec.zsdl — covers socket.socket settimeout/gettimeout/shutdown/sendall __name__.__eq__ string values."
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra41.zspec.zsdl — covers socket.socket setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__; socket.gethostname __name__/__module__.__eq__."
    - "socket_extra40.zspec.zsdl — covers socket.socket setsockopt/getsockopt __name__.__eq__; getdefaulttimeout/__qualname__.__eq__."
    - "socket_extra39.zspec.zsdl — covers socket.socket connect/bind/accept/listen/send/recv __name__.__eq__ string values."
    - "socket_extra37.zspec.zsdl — covers socket.socket recvfrom/sendto/makefile/connect_ex/recv_into/recvfrom_into __name__.__len__(); dup/get_inheritable/set_inheritable __name__.__len__() (length checks only, NOT string eq values)."
  notes:
    - "This spec extends socket through socket_extra43; it does NOT duplicate invariants present in those files."
    - "Coverage gap: socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__. socket_extra40 covers setsockopt/getsockopt __name__.__eq__. socket_extra41 covers setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__. socket_extra43 covers settimeout/gettimeout/shutdown/sendall __name__.__eq__. socket_extra37 covers recvfrom/sendto/connect_ex/recv_into/recvfrom_into __name__.__len__() (length checks only, NOT string eq values). But NO prior spec checks socket.socket.recvfrom/__name__.__eq__('recvfrom'), sendto/__name__.__eq__('sendto'), connect_ex/__name__.__eq__('connect_ex'), recv_into/__name__.__eq__('recv_into'), or recvfrom_into/__name__.__eq__('recvfrom_into') as string eq values. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__name__ == 'recvfrom'. extra37 covers __name__.__len__()==8 (length only). extra42 covers __qualname__.__eq__('socket.recvfrom') (__qualname__ axis). No prior spec checks recvfrom/__name__.__eq__('recvfrom') (__name__ axis, string eq value). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__name__ == 'sendto'. extra37 covers __name__.__len__()==6 (length only). extra42 covers __qualname__.__eq__('socket.sendto') (__qualname__ axis). No prior spec checks sendto/__name__.__eq__('sendto') (__name__ axis, string eq value). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.connect_ex.__name__ == 'connect_ex'. extra37 covers __name__.__len__()==10 (length only). extra42 covers __qualname__.__eq__('socket.connect_ex') (__qualname__ axis). No prior spec checks connect_ex/__name__.__eq__('connect_ex') (__name__ axis, string eq value). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recv_into.__name__ == 'recv_into'. extra37 covers __name__.__len__()==8 (length only). No prior spec checks recv_into/__name__.__eq__('recv_into') (__name__ axis, string eq value) — extra42 does not cover recv_into __qualname__.__eq__ either. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom_into.__name__ == 'recvfrom_into'. extra37 covers __name__.__len__()==13 (length only). No prior spec checks recvfrom_into/__name__.__eq__('recvfrom_into') (__name__ axis, string eq value). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __name__.__eq__ string values:
# recvfrom, sendto, connect_ex, recv_into, recvfrom_into
#
# socket_extra37 covers all five via __name__.__len__() (length checks only):
#   recvfrom.__name__.__len__()==8; sendto.__name__.__len__()==6;
#   connect_ex.__name__.__len__()==10; recv_into.__name__.__len__()==8;
#   recvfrom_into.__name__.__len__()==13.
# socket_extra42 covers recvfrom/sendto/connect_ex __qualname__.__eq__
#   (qualname axis, NOT __name__ axis).
# No prior spec checks __name__.__eq__ string values for any of these five methods.
# ---------------------------------------------------------------------------

table socket_extra44.socket_method_name_eqs:
  description: "socket.socket recvfrom/sendto/connect_ex/recv_into/recvfrom_into __name__.__eq__ string values — novel: extra37 covers __name__.__len__ only for all five; extra42 covers recvfrom/sendto/connect_ex __qualname__.__eq__ (different axis); no prior spec checks __name__.__eq__ string values for any of these five methods"
  kind: python_call_eq
  category: function_names
  id_prefix: ssmne44

  columns: [id, function, args, expected]
  rows:
    - [recvfrom_name_eq,      "socket.recvfrom.__name__.__eq__",      ["recvfrom"],      true]
    - [sendto_name_eq,        "socket.sendto.__name__.__eq__",        ["sendto"],        true]
    - [connect_ex_name_eq,    "socket.connect_ex.__name__.__eq__",    ["connect_ex"],    true]
    - [recv_into_name_eq,     "socket.recv_into.__name__.__eq__",     ["recv_into"],     true]
    - [recvfrom_into_name_eq, "socket.recvfrom_into.__name__.__eq__", ["recvfrom_into"], true]
