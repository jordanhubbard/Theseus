spec: inspect_extra2806
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "any proprietary source"
  notes:
    - "Wave 634 (_extra2806): __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place left-shift <<=, right-shift >>=, power **=)."
    - "inspect.Parameter is a pure-Python class modeling a callable parameter — no in-place shift or power operators."
    - "inspect.BoundArguments is a pure-Python class holding bound argument mappings — no in-place shift or power operators."
    - "inspect.Signature is a pure-Python class representing a callable's signature — no in-place shift or power operators."
    - "inspect.FullArgSpec is a named-tuple subclass holding argument specification data — no in-place shift or power operators."
    - "Introspection data containers have no numeric shift or power in-place mutation semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __ilshift__ dict-presence (in-place left-shift <<=)
#
# inspect.Parameter, BoundArguments, Signature, FullArgSpec are introspection
# data containers — none define __ilshift__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2806.ilshift_protocol:
  description: "inspect types __ilshift__ dict-presence checks — all False (no in-place left-shift protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2806
  columns: [id, function, args, expected]
  rows:
    - ["in2806001", "inspect.Parameter.__dict__.__contains__",      ["__ilshift__"], false]
    - ["in2806002", "inspect.BoundArguments.__dict__.__contains__", ["__ilshift__"], false]
    - ["in2806003", "inspect.Signature.__dict__.__contains__",      ["__ilshift__"], false]
    - ["in2806004", "inspect.FullArgSpec.__dict__.__contains__",    ["__ilshift__"], false]

# ---------------------------------------------------------------------------
# Table 2: __irshift__ dict-presence (in-place right-shift >>=)
#
# None of the inspect introspection types define __irshift__ — they model
# callable metadata and have no numeric shift semantics.
# ---------------------------------------------------------------------------

table inspect_extra2806.irshift_protocol:
  description: "inspect types __irshift__ dict-presence checks — all False (no in-place right-shift protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2806
  columns: [id, function, args, expected]
  rows:
    - ["in2806005", "inspect.Parameter.__dict__.__contains__",      ["__irshift__"], false]
    - ["in2806006", "inspect.BoundArguments.__dict__.__contains__", ["__irshift__"], false]
    - ["in2806007", "inspect.Signature.__dict__.__contains__",      ["__irshift__"], false]
    - ["in2806008", "inspect.FullArgSpec.__dict__.__contains__",    ["__irshift__"], false]

# ---------------------------------------------------------------------------
# Table 3: __ipow__ dict-presence (in-place power **=)
#
# None of the inspect types define __ipow__ — signature and argument
# introspection objects have no exponentiation or numeric power semantics.
# ---------------------------------------------------------------------------

table inspect_extra2806.ipow_protocol:
  description: "inspect types __ipow__ dict-presence checks — all False (no in-place power protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2806
  columns: [id, function, args, expected]
  rows:
    - ["in2806009", "inspect.Parameter.__dict__.__contains__",      ["__ipow__"], false]
    - ["in2806010", "inspect.BoundArguments.__dict__.__contains__", ["__ipow__"], false]
    - ["in2806011", "inspect.Signature.__dict__.__contains__",      ["__ipow__"], false]
    - ["in2806012", "inspect.FullArgSpec.__dict__.__contains__",    ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined in-place shift/power operator absence — all types, all ops
#
# Cross-check: each inspect type lacks all three in-place shift/power operators.
# Confirms that the inspect API is strictly an introspection surface with
# no numeric shift or power in-place mutation semantics.
# ---------------------------------------------------------------------------

table inspect_extra2806.inplace_shift_pow_absent:
  description: "inspect types full __ilshift__/__irshift__/__ipow__ absence cross-check — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2806
  columns: [id, function, args, expected]
  rows:
    - ["in2806013", "inspect.Parameter.__dict__.__contains__",      ["__ilshift__"], false]
    - ["in2806014", "inspect.Parameter.__dict__.__contains__",      ["__irshift__"], false]
    - ["in2806015", "inspect.Parameter.__dict__.__contains__",      ["__ipow__"],    false]
    - ["in2806016", "inspect.BoundArguments.__dict__.__contains__", ["__ilshift__"], false]
    - ["in2806017", "inspect.BoundArguments.__dict__.__contains__", ["__irshift__"], false]
    - ["in2806018", "inspect.BoundArguments.__dict__.__contains__", ["__ipow__"],    false]
    - ["in2806019", "inspect.Signature.__dict__.__contains__",      ["__ilshift__"], false]
    - ["in2806020", "inspect.Signature.__dict__.__contains__",      ["__irshift__"], false]
    - ["in2806021", "inspect.Signature.__dict__.__contains__",      ["__ipow__"],    false]
    - ["in2806022", "inspect.FullArgSpec.__dict__.__contains__",    ["__ilshift__"], false]
    - ["in2806023", "inspect.FullArgSpec.__dict__.__contains__",    ["__irshift__"], false]
    - ["in2806024", "inspect.FullArgSpec.__dict__.__contains__",    ["__ipow__"],    false]
