spec: inspect_extra100
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra99

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra99.zspec.zsdl."
    - "This spec covers: inspect.Parameter class constants (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD) — their __class__.__name__ is '_ParameterKind' (an IntEnum subclass) and their integer .value attributes (0–4); inspect.Parameter.empty and inspect.Signature.empty class name 'type'; inspect._ParameterKind MRO length; wave 257."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — _ParameterKind is an IntEnum subclass. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.value == 0. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.value == 2. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.value == 3. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.value == 4. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the sentinel class inspect._empty; its metaclass is type. Verified with Python 3.14.3."
    - "inspect.Signature.empty.__class__.__name__ == 'type' — Signature.empty is the same sentinel; both point to inspect._empty. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__ len == 6 — MRO: [_ParameterKind, IntEnum, int, ReprEnum, Enum, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind constants — __class__.__name__ == '_ParameterKind'
#
# Wave 257 theme: inspect.Parameter kind constants class name identity.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'
#
# _ParameterKind is an IntEnum subclass defined in Lib/inspect.py.
# All five parameter kind constants are instances of _ParameterKind.
# New to extra100.
# ---------------------------------------------------------------------------

table inspect_extra100.parameter_kind_class_names:
  description: "inspect.Parameter kind constants all have __class__.__name__ == '_ParameterKind' (an IntEnum subclass); POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD/VAR_POSITIONAL/KEYWORD_ONLY/VAR_KEYWORD; wave 257; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam100

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_name_eq_ParameterKind,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a constant of the _ParameterKind enum, which is an IntEnum subclass defined in Lib/inspect.py; it represents a parameter that can only be positional (before '/'); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra100"]
    - [positional_or_keyword_class_name_eq_ParameterKind,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is the default parameter kind; it can be passed either positionally or as a keyword; it is an instance of _ParameterKind (IntEnum); str.__eq__('_ParameterKind') returns True; new to extra100"]
    - [var_positional_class_name_eq_ParameterKind,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL corresponds to *args in function signatures; it captures extra positional arguments as a tuple; it is an instance of _ParameterKind (IntEnum); str.__eq__('_ParameterKind') returns True; new to extra100"]
    - [keyword_only_class_name_eq_ParameterKind,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY represents parameters that follow *args or a bare *; they must be passed as keyword arguments; it is an instance of _ParameterKind (IntEnum); str.__eq__('_ParameterKind') returns True; new to extra100"]
    - [var_keyword_class_name_eq_ParameterKind,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD corresponds to **kwargs in function signatures; it captures extra keyword arguments as a dict; it is an instance of _ParameterKind (IntEnum); str.__eq__('_ParameterKind') returns True; new to extra100"]
    - [positional_only_class_module_eq_inspect,
       "Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__('inspect') == True — _ParameterKind is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constant integer values (0–4)
#
# Wave 257 theme: inspect.Parameter kind constants IntEnum values.
#
# inspect.Parameter.POSITIONAL_ONLY.value == 0
# inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1
# inspect.Parameter.VAR_POSITIONAL.value == 2
# inspect.Parameter.KEYWORD_ONLY.value == 3
# inspect.Parameter.VAR_KEYWORD.value == 4
#
# _ParameterKind inherits from IntEnum, so each constant has an integer .value.
# The values are 0-4 in definition order. New to extra100.
# ---------------------------------------------------------------------------

table inspect_extra100.parameter_kind_values:
  description: "inspect.Parameter kind constants IntEnum values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4; wave 257; new to extra100"
  kind: python_call_eq
  category: integer_values
  id_prefix: inspectparam100

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_value_eq_0,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY is the first _ParameterKind enum member; as an IntEnum its .value is the integer 0; int.__eq__(0) returns True; new to extra100"]
    - [positional_or_keyword_value_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD is the second _ParameterKind enum member with integer value 1; this is the default parameter kind for ordinary def parameters; int.__eq__(1) returns True; new to extra100"]
    - [var_positional_value_eq_2,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL is the third _ParameterKind enum member with integer value 2; it maps to *args in function signatures; int.__eq__(2) returns True; new to extra100"]
    - [keyword_only_value_eq_3,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY is the fourth _ParameterKind enum member with integer value 3; it maps to keyword-only params after *args; int.__eq__(3) returns True; new to extra100"]
    - [var_keyword_value_eq_4,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD is the fifth _ParameterKind enum member with integer value 4; it maps to **kwargs in function signatures; int.__eq__(4) returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.empty and Signature.empty class names; _ParameterKind MRO length
#
# Wave 257 theme: inspect sentinel class identity and _ParameterKind MRO.
#
# inspect.Parameter.empty.__class__.__name__ == 'type'
# inspect.Signature.empty.__class__.__name__ == 'type'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6
#
# Parameter.empty and Signature.empty both point to inspect._empty, a sentinel
# class; its metaclass is the built-in 'type'. The _ParameterKind MRO has 6
# entries: [_ParameterKind, IntEnum, int, ReprEnum, Enum, object]. New to extra100.
# ---------------------------------------------------------------------------

table inspect_extra100.empty_sentinel_and_mro:
  description: "inspect.Parameter.empty.__class__.__name__=='type'; Signature.empty same; _ParameterKind MRO len==6; wave 257; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam100

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_empty_class_name_eq_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is the sentinel class inspect._empty used to indicate that a parameter has no default value; _empty is a plain class with object as base; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra100"]
    - [signature_empty_class_name_eq_type,
       "Signature.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.empty.__class__.__name__.__eq__('type') == True — Signature.empty is the same sentinel class inspect._empty (Parameter.empty is Signature.empty); it is used to indicate absence of a return annotation; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra100"]
    - [parameter_kind_mro_len_eq_6,
       "Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__",
       [],
       6,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6 — _ParameterKind inherits from IntEnum, which inherits from int, ReprEnum, Enum, and ultimately object; the full MRO is [_ParameterKind, IntEnum, int, ReprEnum, Enum, object] — 6 entries; len(__mro__) == 6; new to extra100"]
    - [parameter_empty_name_eq_empty,
       "Parameter.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is the class inspect._empty; its __name__ attribute is '_empty'; str.__eq__('_empty') returns True; new to extra100"]
    - [parameter_kind_bases_first_eq_IntEnum,
       "Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__",
       ["IntEnum"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__('IntEnum') == True — _ParameterKind is defined as 'class _ParameterKind(enum.IntEnum):' in Lib/inspect.py; its direct base class is enum.IntEnum; __bases__[0].__name__ is 'IntEnum'; str.__eq__('IntEnum') returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra100
# ---------------------------------------------------------------------------

invariant inspect_extra100.positional_only_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — _ParameterKind is an IntEnum; wave 257; new to extra100"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra100.var_keyword_value:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4 — fifth IntEnum member, maps to **kwargs; wave 257; new to extra100"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

invariant inspect_extra100.positional_only_value:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0 — first IntEnum member; wave 257; new to extra100"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra100.parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — empty is the _empty sentinel class; wave 257; new to extra100"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra100.parameter_kind_mro_len:
  description: "len(inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__) == 6 — MRO: [_ParameterKind, IntEnum, int, ReprEnum, Enum, object]; wave 257; new to extra100"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__
  args: []
  expected: 6

invariant inspect_extra100.keyword_only_value:
  description: "inspect.Parameter.KEYWORD_ONLY.value == 3 — fourth IntEnum member; wave 257; new to extra100"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.value.__eq__
  args: [3]
  expected: true
