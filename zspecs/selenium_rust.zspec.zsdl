spec: selenium_rust
version: ">=3.9"
backend: rust_module(selenium_rust)

docs: https://selenium-python.readthedocs.io/api.html

provenance:
  derived_from:
    - "https://selenium-python.readthedocs.io/api.html — Selenium Python docs"
  not_derived_from:
    - "selenium source: selenium/webdriver/__init__.py"
  notes:
    - "Selenium provides web browser automation."
    - "selenium.webdriver.Chrome is available."
    - "selenium.webdriver.Firefox is available."
    - "selenium.webdriver.common.by.By.ID == 'id'."
    - "selenium.webdriver.common.by.By.CSS_SELECTOR == 'css selector'."
    - "selenium.webdriver.common.by.By.XPATH == 'xpath'."
    - "Expose selenium_by_id() -> str: By.ID."
    - "Expose selenium_by_css() -> str: By.CSS_SELECTOR."
    - "Expose selenium_by_xpath() -> str: By.XPATH."
    - "All test vectors verified against selenium 4.29.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# selenium_by_id — By.ID locator value
invariant selenium_rust.by.id_value:
  description: "By.ID == 'id'"
  category: by
  kind: python_call_eq
  function: selenium_by_id
  args: []
  expected: "id"

# selenium_by_css — By.CSS_SELECTOR value
invariant selenium_rust.by.css_value:
  description: "By.CSS_SELECTOR == 'css selector'"
  category: by
  kind: python_call_eq
  function: selenium_by_css
  args: []
  expected: "css selector"

# selenium_by_xpath — By.XPATH value
invariant selenium_rust.by.xpath_value:
  description: "By.XPATH == 'xpath'"
  category: by
  kind: python_call_eq
  function: selenium_by_xpath
  args: []
  expected: "xpath"

