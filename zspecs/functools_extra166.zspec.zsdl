spec: functools_extra166
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.singledispatch.__name__ 'singledispatch'; functools.singledispatch.__module__ 'functools'; functools.singledispatch.__class__.__name__ 'function'; functools.singledispatch.__code__.co_argcount 1; functools.singledispatch.__code__.co_name 'singledispatch'; functools.singledispatchmethod.__name__ 'singledispatchmethod'; functools.singledispatchmethod.__module__ 'functools'; functools.singledispatchmethod.__bases__[0].__name__ 'object' (Wave 290)."
    - "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a Python function (decorator factory) defined in Lib/functools.py; its simple __name__ is 'singledispatch'. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in Lib/functools.py and its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a Python function object (not a class); its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 — singledispatch(func) takes 1 positional-or-keyword argument (the function being decorated); co_argcount is 1. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_name == 'singledispatch' — the code object co_name for singledispatch is 'singledispatch'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — singledispatchmethod is a Python class defined in Lib/functools.py; its class name is 'singledispatchmethod'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' — singledispatchmethod is defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object; its single base class has __name__ 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch function identity
#
# Wave 290 theme: functools.singledispatch function identity — name, module,
# class, and code attributes.
#
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__module__ == 'functools'
# functools.singledispatch.__class__.__name__ == 'function'
# functools.singledispatch.__code__.co_argcount == 1
#
# functools.singledispatch is a decorator factory implemented as a Python
# function in Lib/functools.py. It transforms a function into a single-dispatch
# generic function. Unlike singledispatchmethod (which is a class),
# singledispatch is a plain Python function object — its __class__.__name__ is
# 'function'. It takes exactly 1 positional-or-keyword argument (the function
# being decorated), so co_argcount is 1. New to extra166.
# ---------------------------------------------------------------------------

table functools_extra166.singledispatch_function_identity:
  description: "functools.singledispatch: __name__ 'singledispatch', __module__ 'functools', __class__.__name__ 'function', co_argcount 1; wave 290; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: functoolssdi166

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_eq,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a Python function (decorator factory) in Lib/functools.py that transforms a function into a single-dispatch generic function; its simple __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra166"]
    - [sd_module_eq_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra166"]
    - [sd_class_name_eq_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a plain Python function object (not a class like singledispatchmethod); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra166"]
    - [sd_co_argcount_eq_1,
       "singledispatch.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch(func) takes 1 positional-or-keyword argument (the function being decorated into a single-dispatch generic); co_argcount is 1; int.__eq__(1) returns True; new to extra166"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatchmethod class identity
#
# Wave 290 theme: functools.singledispatchmethod class identity — name, module,
# code name, and base class.
#
# functools.singledispatch.__code__.co_name == 'singledispatch'
# functools.singledispatchmethod.__name__ == 'singledispatchmethod'
# functools.singledispatchmethod.__module__ == 'functools'
# functools.singledispatchmethod.__bases__[0].__name__ == 'object'
#
# functools.singledispatchmethod is a Python class defined in Lib/functools.py.
# It is a descriptor that allows singledispatch to work on methods within a
# class body. Unlike singledispatch (which is a function), singledispatchmethod
# is a class object — its __class__.__name__ is 'type'. It inherits directly
# from object (its single base class is object). New to extra166.
# ---------------------------------------------------------------------------

table functools_extra166.singledispatchmethod_class_identity:
  description: "functools: singledispatch co_name 'singledispatch'; singledispatchmethod __name__ 'singledispatchmethod', __module__ 'functools', __bases__[0].__name__ 'object'; wave 290; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: functoolssdmci166

  columns: [id, function, args, expected, description]
  rows:
    - [sd_co_name_eq,
       "singledispatch.__code__.co_name.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — singledispatch is a Python function in Lib/functools.py; its code object co_name attribute is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra166"]
    - [sdm_name_eq,
       "singledispatchmethod.__name__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod is a Python class in Lib/functools.py that is a descriptor for using singledispatch within a class body; its simple class name is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra166"]
    - [sdm_module_eq_functools,
       "singledispatchmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra166"]
    - ["sdm_bases_0_name_eq_object",
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — singledispatchmethod inherits directly from object; its __bases__ tuple has a single element (object); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra166"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra166
# ---------------------------------------------------------------------------

invariant functools_extra166.singledispatch_name:
  description: "functools.singledispatch.__name__ == 'singledispatch' — decorator factory that makes single-dispatch generic functions; wave 290; new to extra166"
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra166.singledispatch_module_functools:
  description: "functools.singledispatch.__module__ == 'functools' — defined in Lib/functools.py; wave 290; new to extra166"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra166.singledispatch_class_function:
  description: "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a plain Python function object, not a class; wave 290; new to extra166"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra166.singledispatch_co_argcount_1:
  description: "functools.singledispatch.__code__.co_argcount == 1 — singledispatch(func) takes 1 argument (the function to decorate); wave 290; new to extra166"
  kind: python_call_eq
  function: singledispatch.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra166.singledispatchmethod_name:
  description: "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — descriptor class for singledispatch on methods; wave 290; new to extra166"
  kind: python_call_eq
  function: singledispatchmethod.__name__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra166.singledispatchmethod_module_functools:
  description: "functools.singledispatchmethod.__module__ == 'functools' — defined in Lib/functools.py; wave 290; new to extra166"
  kind: python_call_eq
  function: singledispatchmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra166.singledispatchmethod_bases_0_object:
  description: "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object; wave 290; new to extra166"
  kind: python_call_eq
  function: "singledispatchmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
