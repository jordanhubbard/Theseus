spec: array_extra17
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra.zspec.zsdl — covers array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2.zspec.zsdl — covers typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3.zspec.zsdl — covers ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4.zspec.zsdl — covers typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5.zspec.zsdl — covers ArrayType.__qualname__, typecodes contains 'I', tobytes for 'b', itemsize lower-bound guard."
    - "array_extra6.zspec.zsdl — covers array metaclass, MRO length 2, typecodes contains 'u'/'w', class identity, float array tolist/length/typecode for 'f'."
    - "array_extra7.zspec.zsdl — covers double array tolist/typecode/itemsize; count/index on 'b'; 'B' tolist; 'h' tolist; tobytes length for 'd'."
    - "array_extra8.zspec.zsdl — covers typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain."
    - "array_extra9.zspec.zsdl — covers class_names table; typecodes via class path; 'i'/'l'/'q' tolist; 'f' itemsize."
    - "array_extra10.zspec.zsdl — covers 'B'/'h'/'H' boundary tolist; empty 'i' tolist; single 'b' max tolist; 'L' itemsize >= 4."
    - "array_extra14.zspec.zsdl — covers typecodes.__contains__ for all 12 typecodes."
    - "array_extra15.zspec.zsdl — covers tolist/len for 'b'[1,2,3]; itemsize exact table b/B/h/H/i/I/d."
    - "array_extra16.zspec.zsdl — covers array.__name__/__module__ via __eq__; typecode 'i' and 'd' on [1,2,3]/[1.0,2.0] fixtures; itemsize 'i' on [1,2,3]; __len__ 'b'[1,2,3]; typecodes class name."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra16.zspec.zsdl."
    - "array.array('i').__len__() == 0 — empty array has length 0. Verified Python 3.12 macOS."
    - "array.array('i', [1,2,3])[0] == 1 — first element of signed-int array. Verified."
    - "array.array('i', [1,2,3])[-1] == 3 — last element via negative index. Verified."
    - "array.array('f', [1.0, 2.0]).typecode == 'f' — float typecode attribute. Verified."
    - "array.array('b').itemsize == 1 — signed byte item size. Verified (attribute is itemsize, not __itemsize)."
    - "array.array('h').itemsize == 2 — signed short item size. Verified."
    - "array.ArrayType.__name__ == 'array' — ArrayType is an alias for array.array. Verified (ArrayType exists in Python 3.12)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array.array('i').__len__() == 0
#
# An empty array constructed with just a typecode has length 0.
# array_extra16 covers __len__ on a 3-element 'b' array; this invariant
# anchors the empty 'i' case from the extra17 namespace.
# ---------------------------------------------------------------------------

invariant array_extra17.len.empty_signed_int:
  description: "array.array('i').__len__() == 0 — empty signed-int array has length 0"
  category: length
  kind: python_call_eq
  function: array
  args: ["i"]
  method: __len__
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# array.array('i', [1,2,3])[0] == 1  and  [-1] == 3
#
# getitem access at first and last index. array_extra4 covers getitem for 'B'
# at index 1; array_extra covers getitem for 'b' at index 0. This spec
# anchors 'i' getitem for indices 0 and -1 from extra17.
# ---------------------------------------------------------------------------

invariant array_extra17.getitem.signed_int_first:
  description: "array.array('i', [1,2,3])[0] == 1 — first element of signed-int array"
  category: getitem
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: __getitem__
  method_args: [0]
  expected: 1

invariant array_extra17.getitem.signed_int_last:
  description: "array.array('i', [1,2,3])[-1] == 3 — last element via negative index"
  category: getitem
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: __getitem__
  method_args: [-1]
  expected: 3

# ---------------------------------------------------------------------------
# array.array('f', [1.0, 2.0]).typecode == 'f'
#
# array_extra6 covers float array typecode for 'f' via a different fixture.
# This invariant anchors the [1.0, 2.0] fixture from the extra17 namespace.
# ---------------------------------------------------------------------------

invariant array_extra17.typecode.float_1_2:
  description: "array.array('f', [1.0, 2.0]).typecode == 'f' — float typecode attribute"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["f", [1.0, 2.0]]
  method: typecode.__eq__
  method_args: ["f"]
  expected: true

# ---------------------------------------------------------------------------
# itemsize for 'b' and 'h'
#
# array_extra covers itemsize for 'b' and 'h' in a table; array_extra15
# covers itemsize exact table including 'b' and 'h'. These standalone
# invariants anchor the checks from the extra17 namespace.
# ---------------------------------------------------------------------------

invariant array_extra17.itemsize.signed_byte:
  description: "array.array('b').itemsize == 1 — signed byte is 1 byte per element"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["b"]
  method: itemsize.__eq__
  method_args: [1]
  expected: true

invariant array_extra17.itemsize.signed_short:
  description: "array.array('h').itemsize == 2 — signed short is 2 bytes per element"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["h"]
  method: itemsize.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# array.ArrayType.__name__ == 'array'
#
# array.ArrayType is an alias for array.array in CPython. array_extra covers
# ArrayType.__name__ as a standalone invariant. This spec anchors it from
# extra17 via a table row alongside array.__name__ for cross-reference.
# ---------------------------------------------------------------------------

table array_extra17.array_type_alias:
  description: "ArrayType is an alias for array.array — both have __name__ == 'array'"
  kind: python_call_eq
  category: class_names
  id_prefix: at17

  columns: [id, function, args, expected]
  rows:
    - [array_class,     array.__name__.__eq__,     ["array"], true]
    - [array_type_alias, ArrayType.__name__.__eq__, ["array"], true]
