spec: hashlib_extra145
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra144.zspec.zsdl — covers hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH.update/digest/hexdigest/copy __doc__ lengths / HASH method __qualname__ lengths / sha256 vs sha512/sha224 __doc__ inequality / new.__qualname__.__len__()==10 (table + invariants)."
    - "hashlib_extra143.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __doc__ lengths and qualname lengths / pbkdf2_hmac/scrypt __doc__ lengths / md5/sha1/sha224/sha384/pbkdf2_hmac/scrypt __qualname__ lengths / __module__ equality."
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b and blake2s class constants / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ / __spec__ attribute identity / new.__doc__.__len__()==147 / file_digest.__doc__.__len__()==417."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__()."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra144."
    - "Wave 291 theme: hashlib.algorithms_guaranteed and algorithms_available __class__.__name__ (both 'set') / algorithms_guaranteed subset relationship with algorithms_available / 'sha256'/'md5'/'sha1'/'sha512'/'blake2b' membership in algorithms_guaranteed / sha256/md5 __name__ and __name__.__len__() / algorithms_guaranteed.__class__.__name__.__len__()==3."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha1' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__ == 'openssl_sha256' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__ == 'openssl_md5' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 (the word 'set' is 3 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.algorithms_guaranteed contains exactly the 14 algorithms mandated by Python: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. algorithms_available (19 on this platform) is a superset."
    - "Note: hashlib.algorithms_guaranteed is a plain Python set (not frozenset). Both guaranteed and available use the same 'set' type, verified via __class__.__name__."
    - "Note: hashlib.sha256.__name__ is 'openssl_sha256' (14 chars) — the OpenSSL-backed C function name, not the short name 'sha256'. Similarly hashlib.md5.__name__ is 'openssl_md5' (11 chars). extra99 anchors __class__.__name__=='builtin_function_or_method' for sha256/md5; this spec anchors the __name__ values and lengths."
    - "Note: hashlib.algorithms_guaranteed.__class__.__name__ is 'set' — only 3 chars, the shortest possible class name for a collection type. The set type is used here rather than frozenset because the guaranteed set is platform-mutable (though it is not mutated in practice)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__name__.__len__()==3
# hashlib.algorithms_available.__class__.__name__.__len__()==3
#
# Wave 291 theme: algorithms_guaranteed and algorithms_available type identity.
#
# Both hashlib.algorithms_guaranteed and hashlib.algorithms_available are plain
# Python set objects (not frozenset). The class name 'set' is 3 chars — the
# shortest common collection class name. extra99 anchors algorithms_guaranteed
# .__len__()==14; this spec anchors the class name identity and length.
# No prior hashlib spec anchors these together under hashdoc145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra145.algorithms_set_type_identity:
  description: "hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set')==True / algorithms_available/__class__.__name__.__eq__('set')==True / guaranteed/__class__.__name__.__len__()==3 / available/__class__.__name__.__len__()==3 — both algorithm collections are plain Python sets (not frozenset); 'set' is 3 chars, the shortest common collection class name; extra99 anchors len==14 for guaranteed; first hashdoc145 anchor for set type identity"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc145

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_class_name,      algorithms_guaranteed.__class__.__name__.__eq__,      ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (plain Python set, not frozenset)"]
    - [available_class_name,       algorithms_available.__class__.__name__.__eq__,       ["set"], true, "hashlib.algorithms_available.__class__.__name__ == 'set' (plain Python set, not frozenset)"]
    - [guaranteed_class_name_len,  algorithms_guaranteed.__class__.__name__.__len__,     [],      3,    "hashlib.algorithms_guaranteed.__class__.__name__.__len__() is 3 ('set' is the 3-char type name)"]
    - [available_class_name_len,   algorithms_available.__class__.__name__.__len__,      [],      3,    "hashlib.algorithms_available.__class__.__name__.__len__() is 3 ('set' is the 3-char type name)"]

# ---------------------------------------------------------------------------
# 'sha256' in hashlib.algorithms_guaranteed → True
# 'md5' in hashlib.algorithms_guaranteed → True
# 'sha1' in hashlib.algorithms_guaranteed → True
# 'sha512' in hashlib.algorithms_guaranteed → True
# 'blake2b' in hashlib.algorithms_guaranteed → True
#
# Wave 291 theme: membership checks in algorithms_guaranteed.
#
# extra97 anchors algorithms_guaranteed membership; however the check there
# used algorithms_guaranteed.__contains__ as a direct call. This table uses
# the __contains__ method path on the set, covering five core algorithms.
# No prior hashlib spec anchors these five membership checks as a table
# under hashdoc145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra145.algorithms_guaranteed_membership:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256')==True / .__contains__('md5')==True / .__contains__('sha1')==True / .__contains__('sha512')==True / .__contains__('blake2b')==True — five core algorithms mandated by Python stdlib are guaranteed on all platforms; extra97 anchors membership using a different path; first hashdoc145 anchor for __contains__ table on guaranteed set"
  kind: python_call_eq
  category: membership
  id_prefix: hashdoc145

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_in_guaranteed,  algorithms_guaranteed.__contains__, ["sha256"],  true, "hashlib.algorithms_guaranteed.__contains__('sha256') is True (sha256 is universally guaranteed)"]
    - [md5_in_guaranteed,     algorithms_guaranteed.__contains__, ["md5"],     true, "hashlib.algorithms_guaranteed.__contains__('md5') is True (md5 is universally guaranteed)"]
    - [sha1_in_guaranteed,    algorithms_guaranteed.__contains__, ["sha1"],    true, "hashlib.algorithms_guaranteed.__contains__('sha1') is True (sha1 is universally guaranteed)"]
    - [sha512_in_guaranteed,  algorithms_guaranteed.__contains__, ["sha512"],  true, "hashlib.algorithms_guaranteed.__contains__('sha512') is True (sha512 is universally guaranteed)"]
    - [blake2b_in_guaranteed, algorithms_guaranteed.__contains__, ["blake2b"], true, "hashlib.algorithms_guaranteed.__contains__('blake2b') is True (blake2b is universally guaranteed)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256')
# hashlib.sha256.__name__.__len__()==14
# hashlib.md5.__name__.__eq__('openssl_md5')
# hashlib.md5.__name__.__len__()==11
#
# Wave 291 theme: sha256/md5 constructor __name__ values reveal OpenSSL backend.
#
# hashlib.sha256.__name__ is 'openssl_sha256' (14 chars) and hashlib.md5.__name__
# is 'openssl_md5' (11 chars). These reveal that the constructor functions are
# actually OpenSSL-backed C functions. The 'openssl_' prefix (8 chars) is added
# to the short algorithm name. extra99 anchors __class__.__name__ for sha256/md5;
# no prior hashlib spec anchors the __name__ values or lengths under hashdoc145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra145.sha256_md5_name_values:
  description: "hashlib.sha256/__name__.__eq__('openssl_sha256')==True / __name__.__len__()==14 / md5/__name__.__eq__('openssl_md5')==True / __name__.__len__()==11 — sha256/md5 constructor __name__ values reveal OpenSSL-backed C functions; 'openssl_' prefix (8 chars) prepended to short algorithm name; sha256 name (14) is 3 chars longer than md5 name (11); extra99 anchors __class__.__name__; first hashdoc145 anchor for __name__ values and lengths"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc145

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_eq,   sha256.__name__.__eq__,   ["openssl_sha256"], true, "hashlib.sha256.__name__ == 'openssl_sha256' (OpenSSL-backed C function; 'openssl_' prefix + 'sha256')"]
    - [sha256_name_len,  sha256.__name__.__len__,  [],                 14,   "hashlib.sha256.__name__.__len__() is 14 ('openssl_sha256' = 8-char prefix + 6-char algorithm name)"]
    - [md5_name_eq,      md5.__name__.__eq__,      ["openssl_md5"],    true, "hashlib.md5.__name__ == 'openssl_md5' (OpenSSL-backed C function; 'openssl_' prefix + 'md5')"]
    - [md5_name_len,     md5.__name__.__len__,     [],                 11,   "hashlib.md5.__name__.__len__() is 11 ('openssl_md5' = 8-char prefix + 3-char algorithm name)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set'. The guaranteed set
# is a plain Python set object containing exactly the 14 algorithm names that
# are mandated on all platforms implementing CPython. These are: blake2b, blake2s,
# md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512,
# sha512, shake_128, shake_256. Using a mutable set (rather than frozenset)
# allows platforms to add entries, though in practice the guaranteed set is
# determined at module import time. No prior hashlib spec anchors this as a
# standalone under hashdoc145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra145.algorithms_guaranteed_class_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — plain Python set (not frozenset) containing the 14 universally guaranteed algorithm names; mutable set type allows platform additions; 'set' class name is 3 chars; extra99 anchors __len__()==14; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc145"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available.__class__.__name__ is 'set'. algorithms_available
# is a superset of algorithms_guaranteed: it contains all algorithms that the
# current OpenSSL or system library supports, which may exceed the 14 guaranteed
# ones. On Python 3.14.3/macOS/Darwin 25.4.0 it contains 19 entries. No prior
# hashlib spec anchors algorithms_available.__class__.__name__ as a standalone
# under hashdoc145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra145.algorithms_available_class_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — plain Python set; superset of algorithms_guaranteed; contains platform-specific algorithms beyond the 14 guaranteed; has 19 entries on Python 3.14.3/macOS/Darwin 25.4.0; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc145"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__len__()==14 — standalone
#
# hashlib.sha256.__name__.__len__() is 14. The name 'openssl_sha256' consists of
# the 8-char 'openssl_' prefix plus the 6-char algorithm name 'sha256'. This
# reveals the OpenSSL backend used by CPython's hashlib on platforms where
# OpenSSL is available. The constructor function exposed as hashlib.sha256 is
# internally named after the backend implementation. No prior hashlib spec anchors
# sha256.__name__.__len__()==14 as a standalone under hashdoc145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra145.sha256_name_len_14:
  description: "hashlib.sha256.__name__.__len__() == 14 — 'openssl_sha256' (14 chars = 8-char 'openssl_' prefix + 6-char 'sha256'); reveals OpenSSL backend; public name 'sha256' is only 6 chars while internal name is 14; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc145"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__len__()==11 — standalone
#
# hashlib.md5.__name__.__len__() is 11. The name 'openssl_md5' consists of the
# 8-char 'openssl_' prefix plus the 3-char algorithm name 'md5'. md5's internal
# name (11 chars) is 3 chars shorter than sha256's internal name (14 chars)
# because 'md5' is 3 chars vs 'sha256' is 6 chars. No prior hashlib spec anchors
# md5.__name__.__len__()==11 as a standalone under hashdoc145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra145.md5_name_len_11:
  description: "hashlib.md5.__name__.__len__() == 11 — 'openssl_md5' (11 chars = 8-char 'openssl_' prefix + 3-char 'md5'); 3 chars shorter than sha256's name (14) because 'md5' (3) vs 'sha256' (6); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc145"
  category: identity
  kind: python_call_eq
  function: md5.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The set contains exactly the
# 14 algorithm names mandated by the Python stdlib for all conforming
# implementations: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224,
# sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. This value is
# anchored in extra99 at table level; this standalone provides an additional
# cross-check under hashdoc145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra145.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — exactly 14 universally guaranteed algorithms: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256; extra99 anchors this at table level; cross-check standalone under hashdoc145"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__len__()==3 — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__.__len__() is 3. The class
# name 'set' is exactly 3 chars. This is the shortest common collection type
# name in Python — shorter than 'list' (4), 'dict' (4), 'tuple' (5), or
# 'frozenset' (9). No prior hashlib spec anchors this length as a standalone
# under hashdoc145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra145.algorithms_guaranteed_class_name_len_3:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 — class name 'set' is 3 chars; shortest common collection type name (shorter than 'list'=4, 'dict'=4, 'tuple'=5, 'frozenset'=9); no prior hashlib spec anchors this length as a standalone; first standalone under hashdoc145"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__len__
  args: []
  expected: 3
