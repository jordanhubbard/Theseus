spec: hashlib_extra42
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra41.zspec.zsdl — covers algorithms_guaranteed.__contains__ for sha256/md5/sha1/sha512; algorithms_guaranteed.__class__.__name__.__eq__('set'); new.__name__.__eq__('__hash_new'); new.__module__.__eq__('hashlib'); md5.__name__.__eq__('openssl_md5')."
    - "hashlib_extra40.zspec.zsdl — covers sha3_512.__module__.__len__()==8; scrypt.__qualname__/__module__.__len__(); md5/__doc__/__class__/__name__.__len__()==3; sha256/sha512/md5/sha1 digest_size."
    - "hashlib_extra32.zspec.zsdl — covers sha224/__module__.__len__()==8; sha384/__module__.__len__()==8; sha3_256/__module__.__len__()==8 (length only, NOT the string eq value)."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512 __module__.__eq__('_hashlib') (eq values); sha224/sha384 __module__ NOT covered as eq values there."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__.__eq__."
    - "hashlib_extra29.zspec.zsdl — covers sha3_256/__name__.__eq__('openssl_sha3_256')."
    - "hashlib_extra38.zspec.zsdl — covers pbkdf2_hmac.__name__.__len__()==11 (length only, NOT __module__)."
  notes:
    - "This spec extends hashlib through hashlib_extra41; it does NOT duplicate invariants present in those files."
    - "Coverage gap: hashlib_extra31 covers md5/sha1/sha256/sha512 __module__.__eq__('_hashlib') as eq string values. But sha224 and sha384 __module__ eq are NOT covered in extra31 (extra32 covers __len__()==8 for sha224/sha384 only). sha3_256.__module__.__eq__ is also not covered as a string eq value (extra32 covers __len__()==8 only). pbkdf2_hmac.__module__ has never been checked as a string eq value in any prior spec."
    - "hashlib.sha224.__module__ == '_hashlib'. SHA-224 is OpenSSL-backed; its __module__ is '_hashlib'. extra31 covers sha224.__module__.__len__()==8 (via extra32) but NOT the string eq value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__module__ == '_hashlib'. SHA-384 is OpenSSL-backed; its __module__ is '_hashlib'. Same gap as sha224. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. SHA3-256 is OpenSSL-backed; its __module__ is '_hashlib'. extra32 covers __module__.__len__()==8 but NOT the string eq value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. pbkdf2_hmac is a C-level function in the _hashlib extension. No prior spec checks pbkdf2_hmac.__module__ as a string eq value (extra38 covers __name__.__len__()==11; extra20 covers __name__.__eq__('pbkdf2_hmac'); neither checks __module__). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha224 and sha384 __module__ string eq checks
#
# hashlib_extra31 covers md5/sha1/sha256/sha512 __module__.__eq__('_hashlib').
# hashlib_extra32 covers sha224/sha384 __module__.__len__()==8 (length only).
# No prior spec checks sha224.__module__ or sha384.__module__ as string eq values.
# Both are OpenSSL-backed constructors defined in the _hashlib C extension.
# ---------------------------------------------------------------------------

table hashlib_extra42.sha224_sha384_module_eq:
  description: "hashlib.sha224.__module__=='_hashlib' and hashlib.sha384.__module__=='_hashlib' — novel string eq checks; extra31 covers sha256/sha512/sha1/md5 module eq; extra32 covers sha224/sha384 module __len__() only"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hsme42

  columns: [id, function, args, expected]
  rows:
    - [sha224_module_eq, sha224.__module__.__eq__, ["_hashlib"], true]
    - [sha384_module_eq, sha384.__module__.__eq__, ["_hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__ string eq check
#
# hashlib_extra29 covers sha3_256.__name__.__eq__('openssl_sha3_256').
# hashlib_extra32 covers sha3_256.__module__.__len__()==8 (length only).
# No prior spec checks sha3_256.__module__ as a string eq value.
# sha3_256 uses the OpenSSL backend, so its __module__ is '_hashlib'.
# ---------------------------------------------------------------------------

invariant hashlib_extra42.sha3_256.module_eq:
  description: "hashlib.sha3_256.__module__ == '_hashlib' — SHA3-256 is OpenSSL-backed; novel: extra32 covers sha3_256.__module__.__len__()==8 but NOT the string eq value"
  category: module_metadata
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__ string eq check
#
# hashlib_extra20 covers pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac').
# hashlib_extra38 covers pbkdf2_hmac.__name__.__len__()==11.
# hashlib_extra24 covers pbkdf2_hmac.__qualname__.__len__()==11.
# No prior spec checks pbkdf2_hmac.__module__ in any capacity.
# pbkdf2_hmac is a C-level function in the _hashlib extension; __module__='_hashlib'.
# ---------------------------------------------------------------------------

invariant hashlib_extra42.pbkdf2_hmac.module_eq:
  description: "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — pbkdf2_hmac is a C-level function in _hashlib; novel: no prior spec checks pbkdf2_hmac.__module__ in any form"
  category: module_metadata
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true
