spec: smtplib_extra3
version: ">=3.9"
backend: python_module(smtplib)

docs: https://docs.python.org/3/library/smtplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/smtplib.html — Python smtplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/smtplib.py internal socket/TLS implementation details"
  notes:
    - "This spec extends smtplib.zspec.zsdl, smtplib_extra.zspec.zsdl, and smtplib_extra2.zspec.zsdl."
    - "smtplib.zspec covers __name__ table (SMTP/SMTP_SSL/SMTPException/SMTPAuthenticationError/SMTPConnectError/SMTPRecipientsRefused/SMTPSenderRefused/SMTPDataError/SMTPNotSupportedError/SMTPHeloError), SMTP.__module__, port constants values."
    - "smtplib_extra covers standalone __name__ invariants for SMTP/SMTP_SSL/SMTPException/SMTPConnectError/SMTPAuthenticationError, SMTPException hierarchy, SMTP_PORT type and value."
    - "smtplib_extra2 covers SMTPServerDisconnected/__name__, SMTPResponseException/__name__, SMTP_SSL bases, SMTPServerDisconnected base, SMTPResponseException base, SMTPSenderRefused base, SMTP.default_port type and value."
    - "This spec adds __qualname__ vectors for all major SMTP classes — not covered in any prior spec."
    - "smtplib.SMTP.__qualname__ == 'SMTP' — top-level class, qualname equals name."
    - "smtplib.SMTP_SSL.__qualname__ == 'SMTP_SSL' — top-level class."
    - "smtplib.SMTPException.__qualname__ == 'SMTPException' — top-level exception class."
    - "smtplib.SMTPServerDisconnected.__qualname__ == 'SMTPServerDisconnected' — top-level exception."
    - "smtplib.SMTPResponseException.__qualname__ == 'SMTPResponseException' — top-level exception."
    - "smtplib.SMTPConnectError.__qualname__ == 'SMTPConnectError' — top-level exception."
    - "smtplib.SMTPAuthenticationError.__qualname__ == 'SMTPAuthenticationError' — top-level exception."
    - "smtplib.SMTPRecipientsRefused.__qualname__ == 'SMTPRecipientsRefused' — top-level exception."
    - "smtplib.SMTP.__module__ == 'smtplib' — already in smtplib.zspec; repeated here via __qualname__ table context only (module row is new: SMTPException.__module__ not covered as standalone)."
    - "smtplib.SMTPException.__module__ == 'smtplib' — not covered as a standalone invariant in any prior spec."
    - "smtplib.SMTP_SSL_PORT.__class__.__name__ == 'int' — smtplib_extra only checks SMTP_PORT type; SMTP_SSL_PORT type is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — SMTP client classes and exception classes
# None of these are covered in any prior smtplib spec.
# ---------------------------------------------------------------------------

table smtplib_extra3.qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [SMTP,                    SMTP.__qualname__.__eq__,                    ["SMTP"],                    true]
    - [SMTP_SSL,                SMTP_SSL.__qualname__.__eq__,                ["SMTP_SSL"],                true]
    - [SMTPException,           SMTPException.__qualname__.__eq__,           ["SMTPException"],           true]
    - [SMTPServerDisconnected,  SMTPServerDisconnected.__qualname__.__eq__,  ["SMTPServerDisconnected"],  true]
    - [SMTPResponseException,   SMTPResponseException.__qualname__.__eq__,   ["SMTPResponseException"],   true]
    - [SMTPConnectError,        SMTPConnectError.__qualname__.__eq__,        ["SMTPConnectError"],        true]
    - [SMTPAuthenticationError, SMTPAuthenticationError.__qualname__.__eq__, ["SMTPAuthenticationError"], true]
    - [SMTPRecipientsRefused,   SMTPRecipientsRefused.__qualname__.__eq__,   ["SMTPRecipientsRefused"],   true]

# ---------------------------------------------------------------------------
# Module checks
# SMTP.__module__ is covered in smtplib.zspec, but SMTPException.__module__
# has never been checked as a standalone invariant.
# ---------------------------------------------------------------------------

invariant smtplib_extra3.module.SMTPException:
  description: "smtplib.SMTPException.__module__ == 'smtplib'"
  category: class_modules
  kind: python_call_eq
  function: SMTPException.__module__.__eq__
  args: ["smtplib"]
  expected: true

# ---------------------------------------------------------------------------
# SMTP_SSL_PORT type check
# smtplib_extra covers SMTP_PORT.__class__.__name__ == 'int' but not
# SMTP_SSL_PORT.__class__.__name__.  This adds the missing type check.
# ---------------------------------------------------------------------------

invariant smtplib_extra3.constants.SMTP_SSL_PORT_type:
  description: "smtplib.SMTP_SSL_PORT.__class__.__name__ == 'int' — SMTPS port constant is an int"
  category: constants
  kind: python_call_eq
  function: SMTP_SSL_PORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true
