spec: concurrent_futures_extra19
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra18.zspec.zsdl."
    - "extra6 covers: CancelledError/BrokenExecutor/wait/as_completed __qualname__ in a table."
    - "extra9 covers: InvalidStateError.__qualname__/__module__."
    - "extra16 covers: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __qualname__ in a table."
    - "extra18 covers: Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor/CancelledError/BrokenExecutor __bases__[0] names; InvalidStateError/__module__; TimeoutError base."
    - "NOT yet covered in any prior spec: concurrent.futures class __qualname__ __len__ table for the four executor/future classes in extra19 namespace."
    - "NOT yet covered: concurrent.futures exception class __qualname__ __len__ table for CancelledError/BrokenExecutor/InvalidStateError in extra19 namespace."
    - "NOT yet covered: concurrent.futures.as_completed.__qualname__ length == 12 as standalone invariant."
    - "NOT yet covered: concurrent.futures.wait.__qualname__ length == 4 as standalone invariant."
    - "NOT yet covered: concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' as standalone extra19-namespace invariant."
    - "NOT yet covered: concurrent.futures.wait.__module__ == 'concurrent.futures._base' as standalone extra19-namespace invariant."
    - "Future.__qualname__ == 'Future' (len 6); Executor.__qualname__ == 'Executor' (len 8)."
    - "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len 18); ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len 19)."
    - "CancelledError.__qualname__ == 'CancelledError' (len 14); BrokenExecutor.__qualname__ == 'BrokenExecutor' (len 14)."
    - "InvalidStateError.__qualname__ == 'InvalidStateError' (len 17)."
    - "as_completed.__module__ == 'concurrent.futures._base' — defined in the _base module."
    - "wait.__module__ == 'concurrent.futures._base' — defined alongside as_completed in _base."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Executor/Future class __qualname__ __len__ table — extra19 namespace
#
# No prior spec provides a __qualname__ __len__ table for concurrent.futures
# executor and future classes. Lengths: Future(6), Executor(8),
# ThreadPoolExecutor(18), ProcessPoolExecutor(19).
# ---------------------------------------------------------------------------

table concurrent_futures_extra19.executor_qualname_lengths:
  description: "concurrent.futures executor and future class __qualname__ lengths"
  kind: python_call_eq
  category: class_names
  id_prefix: exqnlen19

  columns: [id, function, args, expected]
  rows:
    - [Future,              Future.__qualname__.__len__,              [], 6]
    - [Executor,            Executor.__qualname__.__len__,            [], 8]
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__len__,  [], 18]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__len__, [], 19]

# ---------------------------------------------------------------------------
# Exception class __qualname__ __len__ table — extra19 namespace
#
# No prior spec provides a __qualname__ __len__ table for concurrent.futures
# exception classes. Lengths: CancelledError(14), BrokenExecutor(14),
# InvalidStateError(17).
# ---------------------------------------------------------------------------

table concurrent_futures_extra19.exception_qualname_lengths:
  description: "concurrent.futures exception class __qualname__ lengths"
  kind: python_call_eq
  category: class_names
  id_prefix: excqnlen19

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,   CancelledError.__qualname__.__len__,   [], 14]
    - [BrokenExecutor,   BrokenExecutor.__qualname__.__len__,   [], 14]
    - [InvalidStateError, InvalidStateError.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# as_completed.__module__ — standalone extra19-namespace invariant
#
# extra13 covers as_completed/__module__ in a table. This standalone
# extra19-namespace invariant provides an independent anchor confirming
# as_completed is defined in concurrent.futures._base (the shared base
# module) rather than in the thread or process submodules.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra19.as_completed.module_eq:
  description: "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'"
  category: function_modules
  kind: python_call_eq
  function: as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# wait.__module__ — standalone extra19-namespace invariant
#
# extra13 covers wait/__module__ in a table. This standalone extra19-namespace
# invariant provides an independent anchor confirming concurrent.futures.wait
# is defined in concurrent.futures._base alongside as_completed.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra19.wait.module_eq:
  description: "concurrent.futures.wait.__module__ == 'concurrent.futures._base'"
  category: function_modules
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# as_completed.__qualname__ length == 12 — standalone extra19 invariant
#
# No prior spec checks the length of as_completed's __qualname__. The value
# 'as_completed' has 12 characters. This provides a metric orthogonal to the
# __eq__ checks in extra6.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra19.as_completed.qualname_len:
  description: "concurrent.futures.as_completed.__qualname__ has length 12"
  category: function_names
  kind: python_call_eq
  function: as_completed.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# wait.__qualname__ length == 4 — standalone extra19 invariant
#
# No prior spec checks the length of wait's __qualname__. The value 'wait'
# has 4 characters, the shortest __qualname__ among the concurrent.futures
# public functions.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra19.wait.qualname_len:
  description: "concurrent.futures.wait.__qualname__ has length 4"
  category: function_names
  kind: python_call_eq
  function: wait.__qualname__.__len__
  args: []
  expected: 4
