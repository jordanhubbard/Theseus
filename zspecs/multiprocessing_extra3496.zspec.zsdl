spec: mp3496
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (mp3496): __aenter__, __aexit__, __await__ dict-presence checks for multiprocessing types."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async protocols)."
    - "All values False — multiprocessing types are synchronous primitives with no async protocol support."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__aenter__): all 8 multiprocessing classes return false for __aenter__. multiprocessing is a synchronous process-based concurrency API. pool.Pool defines synchronous __enter__/__exit__ (confirmed wave 679), but does NOT define __aenter__ in its own __dict__. No multiprocessing type implements the async context manager protocol. 'async with Pool()' would raise AttributeError at runtime."
    - "Key finding (__aexit__): all 8 multiprocessing classes return false for __aexit__. The async context manager exit protocol is not part of the multiprocessing API surface. pool.Pool's context manager support is entirely synchronous. No type in this set defines __aexit__ in its own __dict__."
    - "Key finding (__await__): all 8 multiprocessing classes return false for __await__. multiprocessing types are not awaitable. pool.AsyncResult (despite its name) is a synchronous result handle — results are retrieved via get()/wait() methods, not via await. No type in this set defines __await__ in its own __dict__."
    - "Note on pool.AsyncResult naming: the 'Async' in AsyncResult refers to non-blocking dispatch (apply_async, map_async), not Python async/await. pool.AsyncResult is not awaitable and does not define __await__ in its own __dict__."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
    - "  Wave 669 (mp3331): __iand__/__ior__/__ixor__ — all false for all 8."
    - "  Wave 670 (mp3346): __neg__/__pos__/__abs__ — all false for all 8."
    - "  Wave 671 (mp3361): __invert__/__floor__/__ceil__ — all false for all 8."
    - "  Wave 672 (mp3376): __trunc__/__round__/__index__ — all false for all 8."
    - "  Wave 673 (mp3391): __int__/__float__/__complex__ — all false for all 8."
    - "  Wave 674 (mp3406): __bool__/__str__/__repr__ — all false for all 8."
    - "  Wave 675 (mp3421): __hash__/__eq__/__lt__ — all false for all 8."
    - "  Wave 676 (mp3436): __le__/__gt__/__ge__ — all false for all 8."
    - "  Wave 677 (mp3451): __getitem__/__setitem__/__delitem__ — all false for all 8."
    - "  Wave 678 (mp3466): __iter__/__next__/__len__ — all false for all 8."
    - "  Wave 679 (mp3481): __enter__/__exit__/__call__ — pool.Pool __enter__=true, __exit__=true; all others false."
    - "  Wave 680 (mp3496): __aenter__/__aexit__/__await__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# All 8 multiprocessing classes return false for __aenter__.
# multiprocessing is a synchronous process-based concurrency API. None of the
#   8 types implement the async context manager protocol.
# pool.Pool: defines synchronous __enter__/__exit__ (wave 679 confirmed), but
#   does NOT define __aenter__ in its own __dict__. 'async with Pool() as p:'
#   would raise AttributeError at runtime.
# multiprocessing.Process: synchronous subprocess lifecycle manager with no
#   __aenter__ in its own __dict__.
# pool.AsyncResult/pool.MapResult: synchronous result handles; the 'Async' in
#   AsyncResult refers to non-blocking dispatch, not Python async/await.
#   No __aenter__ in their own __dict__.
# managers.SyncManager: synchronous server process manager. No __aenter__.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types.
#   No __aenter__ in their own __dict__.
# ---------------------------------------------------------------------------

table mp3496.aenter:
  description: "multiprocessing types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3496

  columns: [id, function, args, expected]
  rows:
    - ["mp3496001", operator.contains, [multiprocessing.Process.__dict__,                 "__aenter__"], false]
    - ["mp3496002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__aenter__"], false]
    - ["mp3496003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__aenter__"], false]
    - ["mp3496004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__aenter__"], false]
    - ["mp3496005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__aenter__"], false]
    - ["mp3496006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__aenter__"], false]
    - ["mp3496007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__aenter__"], false]
    - ["mp3496008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__aenter__"], false]

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# All 8 multiprocessing classes return false for __aexit__.
# The async context manager exit protocol is absent from all multiprocessing types.
# pool.Pool: context manager support is synchronous (__exit__ defined, wave 679).
#   No __aexit__ in pool.Pool.__dict__.
# multiprocessing.Process: no __aexit__ in Process.__dict__.
# pool.AsyncResult/pool.MapResult: synchronous result handles; no __aexit__.
# managers.SyncManager: synchronous manager; no __aexit__ in its __dict__.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types with
#   no __aexit__ in their own __dict__.
# ---------------------------------------------------------------------------

table mp3496.aexit:
  description: "multiprocessing types __aexit__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3496

  columns: [id, function, args, expected]
  rows:
    - ["mp3496009",  operator.contains, [multiprocessing.Process.__dict__,                 "__aexit__"], false]
    - ["mp3496010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__aexit__"], false]
    - ["mp3496011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__aexit__"], false]
    - ["mp3496012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__aexit__"], false]
    - ["mp3496013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__aexit__"], false]
