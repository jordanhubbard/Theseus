    - ["mp3496016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# All 8 multiprocessing classes return false for __await__.
# multiprocessing types are not awaitable. The module predates Python's
#   async/await syntax and provides no native async integration.
# pool.AsyncResult: despite the 'Async' in its name, pool.AsyncResult is a
#   synchronous result handle. Results are retrieved via get(timeout)/wait(timeout)
#   blocking calls. pool.AsyncResult does not define __await__ in its own __dict__.
# pool.Pool: work is dispatched via apply(), map(), apply_async(), map_async().
#   Pool is not awaitable and does not define __await__.
# multiprocessing.Process: subprocess lifecycle manager; not awaitable.
# managers.SyncManager/BaseListProxy/_BaseDictProxy/_BaseSetProxy: all
#   synchronous IPC types; none define __await__ in their own __dict__.
# ---------------------------------------------------------------------------

table mp3496.await:
  description: "multiprocessing types __await__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3496

  columns: [id, function, args, expected]
  rows:
    - ["mp3496017",  operator.contains, [multiprocessing.Process.__dict__,                 "__await__"], false]
    - ["mp3496018",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__await__"], false]
    - ["mp3496019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__await__"], false]
    - ["mp3496020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__await__"], false]
    - ["mp3496021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__await__"], false]
    - ["mp3496022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__await__"], false]
    - ["mp3496023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__await__"], false]
    - ["mp3496024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__await__"], false]

# ---------------------------------------------------------------------------
# combined — __aenter__, __aexit__, __await__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __aenter__: false for all 8.
# __aexit__:  false for all 8.
# __await__:  false for all 8.
# All 24 values are false.
# multiprocessing is a purely synchronous process-based concurrency API.
#   None of its types implement async protocols at the class __dict__ level.
# This wave complements wave 679's finding: pool.Pool defines the synchronous
#   context manager protocol (__enter__=true, __exit__=true in wave 679) but
#   the async protocol counterparts (__aenter__, __aexit__) are absent from
#   pool.Pool.__dict__.
# pool.AsyncResult naming clarification: the 'Async' in AsyncResult is a
#   legacy naming convention for non-blocking dispatch, predating Python's
#   async/await keywords. AsyncResult is in no way related to asyncio or
#   coroutine-based awaitable protocols.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types relay
#   operations to a managed server process via synchronous IPC dispatch.
#   No async protocol dunders are defined in their Python-level __dict__.
# ---------------------------------------------------------------------------

