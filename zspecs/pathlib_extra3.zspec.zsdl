spec: pathlib_extra3
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/suffixes/parts/parent/joinpath/str/as_posix/relative_to/is_absolute"
    - "pathlib_pure.zspec.zsdl — covers PurePosixPath/__name__, PureWindowsPath/__name__, PurePath/__name__, module attrs, class hierarchy, Windows components, match, drive, anchor"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, Path.__module__, PurePosixPath.__module__, component access, parent, truediv, parts"
    - "pathlib_extra2.zspec.zsdl — covers suffixes, with_name, with_suffix, joinpath multi-arg, is_absolute, parents"
  notes:
    - "This spec adds class identity coverage for PosixPath and WindowsPath (concrete platform classes)."
    - "PosixPath and WindowsPath can be constructed on macOS/Linux; WindowsPath cannot be instantiated on non-Windows, but its class metadata is accessible."
    - "PosixPath.__name__ == 'PosixPath'; WindowsPath.__name__ == 'WindowsPath'."
    - "PosixPath.__module__ == 'pathlib'; WindowsPath.__module__ == 'pathlib'."
    - "Path.__bases__[0].__name__ == 'PurePath' — Path inherits directly from PurePath."
    - "PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits from Path."
    - "PurePath.__module__ == 'pathlib'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class names — PosixPath and WindowsPath (not covered by any prior spec)
# ---------------------------------------------------------------------------

invariant pathlib_extra3.PosixPath.name:
  description: "pathlib.PosixPath.__name__ == 'PosixPath'"
  category: class_names
  kind: python_call_eq
  function: PosixPath.__name__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra3.WindowsPath.name:
  description: "pathlib.WindowsPath.__name__ == 'WindowsPath'"
  category: class_names
  kind: python_call_eq
  function: WindowsPath.__name__.__eq__
  args: ["WindowsPath"]
  expected: true

# ---------------------------------------------------------------------------
# Module attributes — PosixPath, WindowsPath, PurePath
# pathlib_pure covers PurePosixPath and PureWindowsPath modules
# pathlib_extra covers Path.__module__ and PurePosixPath.__module__
# We add PosixPath, WindowsPath, and PurePath __module__
# ---------------------------------------------------------------------------

invariant pathlib_extra3.PosixPath.module:
  description: "pathlib.PosixPath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra3.WindowsPath.module:
  description: "pathlib.WindowsPath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra3.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — Path and PosixPath base classes
#
# pathlib_pure covers PurePosixPath.__bases__[0].__name__ == 'PurePath' and
# PureWindowsPath.__bases__[0].__name__ == 'PurePath'.
# We add:
#   Path.__bases__[0].__name__ == 'PurePath'
#   PosixPath.__bases__[0].__name__ == 'Path'
# ---------------------------------------------------------------------------

invariant pathlib_extra3.Path.base:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits from PurePath"
  category: class_hierarchy
  kind: python_call_eq
  function: Path.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "PurePath"

invariant pathlib_extra3.PosixPath.base:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits from Path"
  category: class_hierarchy
  kind: python_call_eq
  function: PosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Path"
