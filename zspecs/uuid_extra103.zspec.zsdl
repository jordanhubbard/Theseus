spec: uuid_extra103
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra102.zspec.zsdl — covers UUID.variant (property) vs UUID.is_safe (member_descriptor) type distinction / UUID.__reduce__ qualname 'object.__reduce__' / UUID.__hash__/__str__ Python function types / UUID.__lt__/__le__/__gt__/__ge__ qualname equality and co_argcount (table + invariants)."
    - "uuid_extra101.zspec.zsdl — covers SafeUUID enum class identity (__name__/__module__/__qualname__/__bases__[0]/__mro__/__class__ EnumType/member class/member count) (table + invariants)."
    - "uuid_extra100.zspec.zsdl — covers UUID class-level descriptor types for hex/bytes/bytes_le/int/variant / UUID.int member_descriptor qualname and __objclass__ / UUID.__slots__ element names and UUID.__setattr__ qualname (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes (co_name, co_argcount) / UUID.__str__/__repr__ qualname equality and length / UUID.__eq__/__hash__/__lt__ qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants class names and hex/str values (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / RFC field property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__/__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__/__bases__[0].__name__/'Enum' (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra102; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: uuid module-level function __module__ attributes (uuid1/uuid3/uuid4/uuid5 all have __module__=='uuid') and uuid module __name__/__package__/__spec__ identity; UUID.__new__ is builtin_function_or_method with qualname 'object.__new__'."
    - "uuid.uuid1.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__module__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__name__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.__name__).__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.__name__) == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.__package__) == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.has_location == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.__new__).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__qualname__ == 'object.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('object.__new__') == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.uuid1, uuid.uuid3, uuid.uuid4, uuid.uuid5 are Python functions (type 'function') with __module__=='uuid'. The __module__ attribute records the module where a function was defined. All four are defined in Lib/uuid.py, so __module__=='uuid'. The __module__ string has length 4 (same as uuid.__name__). uuid_extra86 and uuid_extra96 anchor function qualnames and co_argcount; this spec anchors __module__ equality for all four UUID generation functions for the first time."
    - "Note: uuid.__package__ is '' (empty string, len 0) because uuid is a top-level module. uuid.__name__ is 'uuid' (4 chars). uuid.__spec__.name is 'uuid' (4 chars; same as __name__). uuid.__spec__.has_location is True (loaded from uuid.py source file). UUID.__new__ is inherited from object — type 'builtin_function_or_method', qualname 'object.__new__' (14 chars). uuid_extra102 anchors UUID.__reduce__ qualname 'object.__reduce__'; this spec anchors UUID.__new__ qualname 'object.__new__' from object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid')
# uuid.uuid3.__module__.__eq__('uuid')
# uuid.uuid4.__module__.__eq__('uuid')
# uuid.uuid5.__module__.__eq__('uuid')
# uuid.uuid4.__module__.__len__()==4
#
# Wave 271 theme: uuid1/uuid3/uuid4/uuid5 all have __module__=='uuid'.
#
# All four UUID generation functions (uuid1, uuid3, uuid4, uuid5) are defined
# in Lib/uuid.py and have __module__=='uuid'. The __module__ attribute of a
# function records the name of the module where it was defined. Since all four
# are top-level functions in uuid.py, __module__=='uuid' (4 chars: u-u-i-d).
# uuid_extra86 anchors uuid1/uuid4/uuid3/uuid5 __qualname__ and co_argcount;
# this spec anchors the __module__ equality for all four for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra103.uuid1_uuid3_uuid4_uuid5_module_equality:
  description: "uuid1.__module__.__eq__('uuid')==True / uuid3.__module__.__eq__('uuid')==True / uuid4.__module__.__eq__('uuid')==True / uuid5.__module__.__eq__('uuid')==True / uuid4.__module__.__len__()==4 — all four UUID generation functions have __module__=='uuid' (4 chars; defined in Lib/uuid.py); __module__ records where function was defined; len is 4 (u-u-i-d); extra86 anchors qualnames; first uuidmod103 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmod103

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_module_eq,  "uuid1.__module__.__eq__",   ["uuid"], true, "uuid.uuid1.__module__ is 'uuid' (defined in Lib/uuid.py; generates RFC 4122 UUID from host MAC and current time)"]
    - [uuid3_module_eq,  "uuid3.__module__.__eq__",   ["uuid"], true, "uuid.uuid3.__module__ is 'uuid' (defined in Lib/uuid.py; generates UUID from MD5 hash of namespace and name)"]
    - [uuid4_module_eq,  "uuid4.__module__.__eq__",   ["uuid"], true, "uuid.uuid4.__module__ is 'uuid' (defined in Lib/uuid.py; generates UUID from random bytes)"]
    - [uuid5_module_eq,  "uuid5.__module__.__eq__",   ["uuid"], true, "uuid.uuid5.__module__ is 'uuid' (defined in Lib/uuid.py; generates UUID from SHA-1 hash of namespace and name)"]
    - [uuid4_module_len, "uuid4.__module__.__len__",  [],       4,    "uuid.uuid4.__module__.__len__() is 4 ('uuid': u-u-i-d; same length as uuid.__name__)"]

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid')
# uuid.__package__.__eq__('')
# type(uuid.__name__).__name__.__eq__('str')
# len(uuid.__name__) == 4
# len(uuid.__package__) == 0
#
# Wave 271 theme: uuid module __name__ and __package__ equality and lengths.
#
# uuid.__name__ is 'uuid' (4 chars: u-u-i-d). uuid.__package__ is '' (empty
# string, length 0) because uuid is a top-level module, not a subpackage.
# type(uuid.__name__).__name__ is 'str'. The 'uuid' module name has length 4
# — shorter than 'hashlib' (7 chars) and 'socket' (6 chars). The __package__
# being '' (empty string) distinguishes top-level modules from subpackages
# (like 'email.mime' which would have __package__=='email'). No prior uuid
# spec anchors __name__ or __package__ equality as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra103.uuid_module_name_and_package_equality_and_lengths:
  description: "uuid.__name__.__eq__('uuid')==True / uuid.__package__.__eq__('')==True / type(uuid.__name__).__name__.__eq__('str')==True / uuid.__name__.__len__()==4 / uuid.__package__.__len__()==0 — __name__=='uuid' (4 chars; shortest among hashlib=7, socket=6); __package__=='' (empty string, len 0; top-level module not a subpackage); type of __name__ is str; no prior uuid spec anchors these module-level attrs; first uuidmod103 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmod103

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       "uuid.__name__.__eq__",                     ["uuid"], true, "uuid.__name__ is 'uuid' (4 chars; the module name as registered in sys.modules; u-u-i-d)"]
    - [package_eq,    "uuid.__package__.__eq__",                  [""],     true, "uuid.__package__ is '' (empty string; top-level module; not a subpackage of any package)"]
    - [name_type_str, "uuid.__name__.__class__.__name__.__eq__",  ["str"],  true, "type(uuid.__name__) is 'str' (module __name__ is always a string; the registered module name)"]
    - [name_len,      "uuid.__name__.__len__",                    [],       4,    "uuid.__name__.__len__() is 4 ('uuid': 4 chars; u-u-i-d; shorter than hashlib=7, socket=6)"]
    - [package_len,   "uuid.__package__.__len__",                 [],       0,    "uuid.__package__.__len__() is 0 (empty string; top-level modules have __package__=='' not None)"]

# ---------------------------------------------------------------------------
# uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')
# uuid.__spec__.name.__eq__('uuid')
# uuid.__spec__.has_location == True
# UUID.__new__.__qualname__.__eq__('object.__new__')
# type(UUID.__new__).__name__.__eq__('builtin_function_or_method')
#
# Wave 271 theme: uuid.__spec__ attributes and UUID.__new__ identity.
#
# uuid.__spec__ is a ModuleSpec with name 'uuid' and has_location True.
# UUID.__new__ is inherited from object: type is 'builtin_function_or_method'
# and qualname is 'object.__new__' (14 chars: 'object.'=7 + '__new__'=7).
# This parallels UUID.__reduce__ whose qualname is 'object.__reduce__'
# (17 chars) — both are inherited from object. uuid_extra102 anchors
# UUID.__reduce__; this spec anchors UUID.__new__ qualname for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra103.uuid_spec_and_UUID_new_identity:
  description: "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / uuid.__spec__.name.__eq__('uuid')==True / uuid.__spec__.has_location==True / UUID.__new__.__qualname__.__eq__('object.__new__')==True / type(UUID.__new__).__name__.__eq__('builtin_function_or_method')==True — __spec__ is ModuleSpec; spec.name is 'uuid'; has_location==True (loaded from uuid.py); UUID.__new__ is inherited from object (builtin_function_or_method; qualname 'object.__new__' 14 chars); extra102 anchors UUID.__reduce__; first uuidmod103 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmod103

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq,   "uuid.__spec__.__class__.__name__.__eq__",    ["ModuleSpec"],               true, "uuid.__spec__.__class__.__name__ is 'ModuleSpec' (importlib.machinery.ModuleSpec; holds module metadata)"]
    - [spec_name_eq,    "uuid.__spec__.name.__eq__",                  ["uuid"],                     true, "uuid.__spec__.name is 'uuid' (the fully qualified module name stored in the ModuleSpec)"]
    - [spec_has_loc,    "uuid.__spec__.has_location",                 [],                           true, "uuid.__spec__.has_location is True (module is loaded from uuid.py on disk; not frozen or built-in)"]
    - [new_qualname_eq, "UUID.__new__.__qualname__.__eq__",           ["object.__new__"],           true, "UUID.__new__.__qualname__ is 'object.__new__' (14 chars; 'object.'=7 + '__new__'=7; UUID inherits __new__ from object)"]
    - [new_type_eq,     "UUID.__new__.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "type(UUID.__new__) is 'builtin_function_or_method' (inherited from object; C-level __new__ for object allocation)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid') — standalone
#
# uuid.uuid1.__module__ is 'uuid'. uuid1 is a Python function defined in
# Lib/uuid.py that generates a UUID using the host's MAC address and the
# current time (RFC 4122 version 1). The __module__ attribute records the
# module where the function was defined. Since uuid1 is defined at the top
# level of uuid.py, __module__ is 'uuid' (4 chars). The module name matches
# uuid.__name__ and uuid.__spec__.name. uuid_extra86 anchors uuid1 qualname
# and co_argcount; uuid_extra96 anchors uuid1 co_name; this spec anchors
# uuid1.__module__ equality as a standalone under uuidmod103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra103.uuid1_module_eq:
  description: "uuid.uuid1.__module__.__eq__('uuid') == True — uuid1.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py; generates RFC 4122 v1 UUID from MAC address and current time); __module__ records where function was defined; matches uuid.__name__ and uuid.__spec__.name; extra86 anchors qualname/co_argcount; first standalone under uuidmod103"
  category: module_identity
  kind: python_call_eq
  function: "uuid1.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__module__.__eq__('uuid') — standalone
#
# uuid.uuid4.__module__ is 'uuid'. uuid4 is a Python function defined in
# Lib/uuid.py that generates a UUID from random bytes (RFC 4122 version 4).
# All 128 bits are randomly generated (with the version and variant bits set
# appropriately). uuid4 is the most commonly used UUID generator when uniqueness
# is required without coordination. Its __module__ is 'uuid' (4 chars), same
# as uuid1/uuid3/uuid5. The __module__ string length (4) equals the __module__
# string length of all four UUID generation functions. No prior uuid spec
# anchors uuid4.__module__ equality as a standalone under uuidmod103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra103.uuid4_module_eq:
  description: "uuid.uuid4.__module__.__eq__('uuid') == True — uuid4.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py; generates RFC 4122 v4 UUID from random bytes); most commonly used UUID generator; all four uuid functions share the same __module__ 'uuid'; module string len 4 matches uuid.__name__ len; no prior spec anchors as standalone; first standalone under uuidmod103"
  category: module_identity
  kind: python_call_eq
  function: "uuid4.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid') — standalone
#
# uuid.__name__ is 'uuid'. The uuid module __name__ is 'uuid' (4 chars).
# This is the shortest module __name__ among the Python standard library
# modules covered in these zspecs (uuid=4, socket=6, hashlib=7). The 4-char
# module name 'uuid' matches uuid.__spec__.name ('uuid') and the __module__
# attribute of all functions defined in uuid.py. No prior uuid spec anchors
# uuid.__name__ equality as a module-level attribute standalone (uuid_extra96
# anchors UUID class __module__/__qualname__, which is the UUID class's module,
# not the uuid module's __name__ attribute). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra103.uuid_module_name_eq:
  description: "uuid.__name__.__eq__('uuid') == True — module __name__ is 'uuid' (4 chars; shortest among uuid=4, socket=6, hashlib=7); matches uuid.__spec__.name and function __module__ attrs; distinct from uuid.UUID.__module__ (which is also 'uuid' but is the class module); extra96 anchors UUID class __module__; first standalone for module __name__ under uuidmod103"
  category: module_identity
  kind: python_call_eq
  function: "uuid.__name__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__spec__.has_location == True — standalone
#
# uuid.__spec__.has_location is True. The uuid module is implemented as a
# Python source file (Lib/uuid.py). has_location True means the module has
# a concrete origin path on disk. uuid.py loads several platform-dependent
# implementations for uuid1 (using ctypes to access the MAC address) and
# imports os, platform, and other modules. The SourceFileLoader is used to
# load uuid.py. has_location True distinguishes uuid from built-in modules
# (like 'sys') which are compiled into the interpreter. No prior uuid spec
# anchors __spec__.has_location as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra103.uuid_spec_has_location:
  description: "uuid.__spec__.has_location == True — has_location is True; uuid module is implemented as Lib/uuid.py (Python source); has concrete origin path on disk; uuid.py uses ctypes for MAC address access; loaded by SourceFileLoader; True distinguishes from built-in modules like 'sys'; no prior spec anchors as standalone; first standalone under uuidmod103"
  category: module_identity
  kind: python_call_eq
  function: "uuid.__spec__.has_location"
  args: []
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__new__.__qualname__.__eq__('object.__new__') — standalone
#
# uuid.UUID.__new__.__qualname__ is 'object.__new__' (14 chars: 'object.'=7 +
# '__new__'=7). UUID does not define its own __new__ — it inherits __new__
# from object. object.__new__ is a C-level built-in function responsible for
# allocating memory for new instances. Its type is 'builtin_function_or_method'.
# The qualname 'object.__new__' (14 chars) is shorter than 'object.__reduce__'
# (17 chars: 'object.'=7 + '__reduce__'=10). Both are inherited from object,
# confirmed by the 'object.' qualname prefix. uuid_extra102 anchors
# UUID.__reduce__ qualname; this spec anchors UUID.__new__ qualname as a
# standalone under uuidmod103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra103.UUID_new_qualname_eq:
  description: "uuid.UUID.__new__.__qualname__.__eq__('object.__new__') == True — qualname is 'object.__new__' (14 chars; 'object.'=7 + '__new__'=7); UUID inherits __new__ from object (no custom allocator); type is builtin_function_or_method; shorter than 'object.__reduce__' (17 chars); 'object.' prefix confirms inheritance from object; extra102 anchors UUID.__reduce__; first standalone for UUID.__new__ under uuidmod103"
  category: module_identity
  kind: python_call_eq
  function: "UUID.__new__.__qualname__.__eq__"
  args: ["object.__new__"]
  expected: true
