spec: threading_extra25
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends prior threading specs through threading_extra24.zspec.zsdl."
    - "threading_extra19 covers: Lock.__qualname__=='lock'; RLock.__qualname__=='RLock'; Condition/Semaphore/Timer class __qualname__ table."
    - "threading_extra24 covers: Thread/Event method __qualname__ tables."
    - "NOT yet covered in any prior spec: Lock method __qualname__ table (acquire/release) in extra25 namespace."
    - "NOT yet covered: Condition method __qualname__ table (wait/notify/notify_all) in extra25 namespace."
    - "NOT yet covered: Semaphore method __qualname__ table (acquire/release) in extra25 namespace."
    - "NOT yet covered: Timer.__qualname__ length as a standalone extra25 invariant."
    - "threading.Lock IS a type (class 'lock'); Lock.acquire.__qualname__ == 'lock.acquire' is accessible."
    - "threading.RLock is a factory function, not a class — RLock.acquire is NOT accessible from the module namespace."
    - "Condition.wait.__qualname__ == 'Condition.wait' — method defined directly on Condition."
    - "Condition.notify.__qualname__ == 'Condition.notify' — method defined directly on Condition."
    - "Condition.notify_all.__qualname__ == 'Condition.notify_all' — method defined directly on Condition."
    - "Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — method defined directly on Semaphore."
    - "Semaphore.release.__qualname__ == 'Semaphore.release' — method defined directly on Semaphore."
    - "Timer.__qualname__ == 'Timer' — length 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Lock method __qualname__ table — extra25 namespace
#
# threading.Lock is a C-level type (_thread.lock). Its acquire and release
# methods have __qualname__ 'lock.acquire' and 'lock.release' (lowercase
# 'lock', matching the C type name). threading_extra19 checks Lock.__qualname__
# == 'lock' (the type qualname). No prior spec covers the method __qualname__
# values. Lock.acquire and Lock.release are accessible directly via the type.
# Lengths: lock.acquire(12), lock.release(12).
# ---------------------------------------------------------------------------

table threading_extra25.lock_method_qualnames:
  description: "threading.Lock method __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: lkmqn25

  columns: [id, function, args, expected]
  rows:
    - [acquire, Lock.acquire.__qualname__.__eq__, ["lock.acquire"], true]
    - [release, Lock.release.__qualname__.__eq__, ["lock.release"], true]

# ---------------------------------------------------------------------------
# Lock method __qualname__ length table — extra25 namespace
#
# Lengths: lock.acquire(12), lock.release(12).
# ---------------------------------------------------------------------------

table threading_extra25.lock_method_qualname_lengths:
  description: "threading.Lock method __qualname__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: lkmqnlen25

  columns: [id, function, args, expected]
  rows:
    - [acquire, Lock.acquire.__qualname__.__len__, [], 12]
    - [release, Lock.release.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Condition method __qualname__ table — extra25 namespace
#
# threading_extra19 checks Condition.__qualname__ == 'Condition' (the class).
# No prior spec covers Condition *method* __qualname__ values.
# Lengths: Condition.wait(14), Condition.notify(16), Condition.notify_all(20).
# ---------------------------------------------------------------------------

table threading_extra25.condition_method_qualnames:
  description: "threading.Condition method __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: condmqn25

  columns: [id, function, args, expected]
  rows:
    - [wait,       Condition.wait.__qualname__.__eq__,       ["Condition.wait"],       true]
    - [notify,     Condition.notify.__qualname__.__eq__,     ["Condition.notify"],     true]
    - [notify_all, Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true]

# ---------------------------------------------------------------------------
# Condition method __qualname__ length table — extra25 namespace
#
# Lengths: Condition.wait(14), Condition.notify(16), Condition.notify_all(20).
# ---------------------------------------------------------------------------

table threading_extra25.condition_method_qualname_lengths:
  description: "threading.Condition method __qualname__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: condmqnlen25

  columns: [id, function, args, expected]
  rows:
    - [wait,       Condition.wait.__qualname__.__len__,       [], 14]
    - [notify,     Condition.notify.__qualname__.__len__,     [], 16]
    - [notify_all, Condition.notify_all.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ table — extra25 namespace
#
# threading_extra19 checks Semaphore.__qualname__ == 'Semaphore' (the class).
# No prior spec covers Semaphore *method* __qualname__ values.
# Lengths: Semaphore.acquire(17), Semaphore.release(17).
# ---------------------------------------------------------------------------

table threading_extra25.semaphore_method_qualnames:
  description: "threading.Semaphore method __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: semmqn25

  columns: [id, function, args, expected]
  rows:
    - [acquire, Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true]
    - [release, Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ length table — extra25 namespace
#
# Lengths: Semaphore.acquire(17), Semaphore.release(17).
# ---------------------------------------------------------------------------

table threading_extra25.semaphore_method_qualname_lengths:
  description: "threading.Semaphore method __qualname__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: semmqnlen25

  columns: [id, function, args, expected]
  rows:
    - [acquire, Semaphore.acquire.__qualname__.__len__, [], 17]
    - [release, Semaphore.release.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# Timer.__qualname__ length — standalone extra25 invariant
#
# threading_extra19 checks Timer.__qualname__ == 'Timer' in a table row.
# No prior spec checks the length of 'Timer' (5) as a standalone invariant.
# ---------------------------------------------------------------------------

invariant threading_extra25.Timer.qualname_len:
  description: "threading.Timer.__qualname__ length == 5 — 'Timer' has 5 characters"
  category: method_names
  kind: python_call_eq
  function: Timer.__qualname__.__len__
  args: []
  expected: 5
