spec: asyncio_extra137
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task functions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.create_task and asyncio.ensure_future — module-level coroutine scheduling functions. asyncio.create_task.__qualname__=='create_task' (len=11); asyncio.create_task.__module__=='asyncio.tasks' (len=13); asyncio.create_task.__code__.co_argcount==1 (coro only, loop is keyword-only via **kwargs); asyncio.ensure_future.__qualname__=='ensure_future' (len=13); asyncio.ensure_future.__module__=='asyncio.tasks' (len=13); asyncio.ensure_future.__code__.co_argcount==1 (coro_or_future only, loop is keyword-only); asyncio.create_task.__code__.co_varnames has len 3 ('coro', 'kwargs', 'loop'); asyncio.ensure_future.__code__.co_varnames has len 4 ('coro_or_future', 'loop', 'should_close', '_wrap_awaitable'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.create_task.__code__.co_kwonlyargcount==0 (the 'name' and 'context' parameters are handled via **kwargs in the C wrapper, not as explicit keyword-only args in the pure Python signature); asyncio.ensure_future.__code__.co_kwonlyargcount==1 (the 'loop' parameter is keyword-only). Both functions live in asyncio.tasks (len=13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.create_task qualname and module — extra137
#
# asyncio.create_task.__qualname__  == 'create_task'   (len=11)
# asyncio.create_task.__module__    == 'asyncio.tasks' (len=13)
# ---------------------------------------------------------------------------

table asyncio_extra137.create_task_identity:
  description: "asyncio.create_task qualname, module identity checks — create_task.__qualname__.__eq__('create_task')==True (len=11: 'create_task' is 11 chars); create_task.__module__.__eq__('asyncio.tasks')==True (len=13: 'asyncio.tasks' is 7+1+5=13 chars); both create_task and ensure_future live in asyncio.tasks submodule; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioct137

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,     asyncio.create_task.__qualname__.__eq__,  ["create_task"],   true, "asyncio.create_task.__qualname__ == 'create_task' (len=11); verified with Python 3.14.3"]
    - [qn_len,    asyncio.create_task.__qualname__.__len__,  [],               11,   "asyncio.create_task.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [mod_eq,    asyncio.create_task.__module__.__eq__,    ["asyncio.tasks"], true, "asyncio.create_task.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [mod_len,   asyncio.create_task.__module__.__len__,    [],               13,   "asyncio.create_task.__module__.__len__() == 13; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.create_task code object attributes — extra137
#
# asyncio.create_task.__code__.co_argcount   == 1
# asyncio.create_task.__code__.co_varnames   has len 3
# 'coro' in asyncio.create_task.__code__.co_varnames
# 'loop' in asyncio.create_task.__code__.co_varnames
# ---------------------------------------------------------------------------

table asyncio_extra137.create_task_code:
  description: "asyncio.create_task code object checks — co_argcount==1 (only 'coro' is a positional arg; name/context are handled via **kwargs); co_varnames len==3 ('coro', 'kwargs', 'loop'); 'coro' and 'loop' are both in co_varnames; co_kwonlyargcount==0; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioctcode137

  columns: [id, function, args, expected, description]
  rows:
    - [argc,           asyncio.create_task.__code__.co_argcount.__eq__,              [1],     true, "asyncio.create_task.__code__.co_argcount == 1 (coro is the only positional arg); verified with Python 3.14.3"]
    - [varnames_len,   asyncio.create_task.__code__.co_varnames.__len__,              [],      3,    "asyncio.create_task.__code__.co_varnames.__len__() == 3; verified with Python 3.14.3"]
    - [coro_in,        asyncio.create_task.__code__.co_varnames.__contains__,        ["coro"], true, "asyncio.create_task.__code__.co_varnames contains 'coro'; verified with Python 3.14.3"]
    - [loop_in,        asyncio.create_task.__code__.co_varnames.__contains__,        ["loop"], true, "asyncio.create_task.__code__.co_varnames contains 'loop'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
