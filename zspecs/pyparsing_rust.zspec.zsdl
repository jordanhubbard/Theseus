spec: pyparsing_rust
version: ">=3.9"
backend: rust_module(pyparsing_rust)

docs: https://pyparsing-docs.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://pyparsing-docs.readthedocs.io/ — pyparsing documentation"
  not_derived_from:
    - "pyparsing source: pyparsing/core.py"
  notes:
    - "pyparsing: text parsing library. Expose pre-wired parse functions returning lists."
    - "parse_word_alpha(text) -> list: Word(alphas).parseString(text).asList() == first word."
    - "parse_word_alpha('hello world') == ['hello']."
    - "parse_integer(text) -> list: pyparsing_common.integer.parseString(text).asList()."
    - "parse_integer('42') == [42], parse_integer('123abc') == [123]."
    - "parse_regex_digits(text) -> list: Regex(r'\\d+').parseString(text).asList()."
    - "parse_regex_digits('123abc') == ['123']."
    - "pyparsing_common.number parses both int and float strings."
    - "parse_number('3.14') == [3.14], parse_number('42') == [42]."
    - "All test vectors verified against pyparsing 3.2.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# parse_word_alpha — parse first alphabetic word
table pyparsing_rust.word_alpha.vectors:
  kind: python_call_eq
  category: word_alpha
  id_prefix: pp_wa
  function: parse_word_alpha

  columns: [id, args, expected]
  rows:
    - [single,    ["hello"],        ["hello"]]
    - [first,     ["hello world"],  ["hello"]]
    - [alpha_num, ["abc123"],       ["abc"]]

# parse_integer — parse integer from string
table pyparsing_rust.integer.vectors:
  kind: python_call_eq
  category: integer
  id_prefix: pp_int
  function: parse_integer

  columns: [id, args, expected]
  rows:
    - [plain,    ["42"],        [42]]
    - [prefix,   ["123abc"],   [123]]
    - [zero,     ["0"],         [0]]
    - [negative, ["-7"],        [-7]]

# parse_regex_digits — parse digit sequence using Regex
table pyparsing_rust.regex_digits.vectors:
  kind: python_call_eq
  category: regex
  id_prefix: pp_rd
  function: parse_regex_digits

  columns: [id, args, expected]
  rows:
    - [plain,     ["123"],      ["123"]]
    - [with_text, ["123abc"],   ["123"]]
    - [multi,     ["456"],      ["456"]]

# parse_number — parse integer or float
table pyparsing_rust.number.vectors:
  kind: python_call_eq
  category: number
  id_prefix: pp_num
  function: parse_number

  columns: [id, args, expected]
  rows:
    - [integer,   ["42"],     [42]]
    - [float_val, ["3.14"],   [3.14]]
    - [zero,      ["0"],      [0]]
    - [neg_int,   ["-5"],     [-5]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T23:25:11Z
  iterations: 1
  pass_count: 14
  fail_count: 0
  total_invariants: 14
  notes: Synthesis succeeded in 1 iteration(s). 14 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
