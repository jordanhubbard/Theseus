spec: decimal_extra154
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal comparison and identity dunder method __qualname__ values."
    - "All Decimal dunder method qualnames follow the 'Decimal.<method>' pattern. The 'Decimal.' prefix is 8 characters."
    - "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (len=14; 'Decimal.' (8) + '__lt__' (6) = 14)."
    - "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (len=14; tied with __lt__, __gt__, __ge__, __eq__ at 14 — all six-character __xx__ dunder names)."
    - "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' (len=14; tied with __lt__, __le__, __ge__, __eq__)."
    - "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' (len=14; tied with __lt__, __le__, __gt__, __eq__)."
    - "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (len=14; tied with __lt__, __le__, __gt__, __ge__ — a five-way tie at 14)."
    - "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' (len=16; 'Decimal.' (8) + '__hash__' (8) = 16; tied with __str__ at... no: __str__ is 15)."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (len=15; 'Decimal.' (8) + '__str__' (7) = 15)."
    - "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (len=16; 'Decimal.' (8) + '__repr__' (8) = 16; tied with __hash__ at 16)."
    - "Five-way tie at length 14: __lt__, __le__, __gt__, __ge__, __eq__ — all six-character comparison dunder names."
    - "Two-way tie at length 16: __hash__ and __repr__ — both eight-character dunder names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal comparison dunder method __qualname__ values
# __lt__, __le__, __gt__, __ge__, __eq__ — all tied at length 14.
# Five-way tie: all are 6-character dunder names ('__xx__' format).
# 'Decimal.' (8) + '__xx__' (6) = 14 for all five comparison operators.
# ---------------------------------------------------------------------------

table decimal_extra154.Decimal_comparison_dunder_qualnames:
  description: "decimal.Decimal comparison dunder __qualname__ values: __lt__=__le__=__gt__=__ge__=__eq__='Decimal.__xx__' (all len=14); five-way tie at 14 for all 6-char comparison dunders; all use 'Decimal.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: deccmpq154

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qeq,  "Decimal.__lt__.__qualname__.__eq__",  ["Decimal.__lt__"],  true, "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (Decimal.__lt__() implements the less-than comparison operator for Decimal objects; in the decimal module, comparison between Decimal and NaN raises InvalidOperation (unlike Python floats which return False for NaN comparisons); 'Decimal.__lt__' has 14 characters: 'Decimal.' (8) + '__lt__' (6) = 14; part of the five-way tie at length 14 with __le__, __gt__, __ge__, __eq__)"]
    - [le_qeq,  "Decimal.__le__.__qualname__.__eq__",  ["Decimal.__le__"],  true, "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (Decimal.__le__() implements the less-than-or-equal comparison; 'Decimal.__le__' has 14 characters: 'Decimal.' (8) + '__le__' (6) = 14; tied with __lt__, __gt__, __ge__, __eq__ at length 14; the '__le__', '__lt__', '__ge__', '__gt__', '__eq__' dunders all have exactly 6 characters ('__' + 2-char operator name + '__'), producing the same qualname length 14 for all five comparison operators)"]
    - [gt_qeq,  "Decimal.__gt__.__qualname__.__eq__",  ["Decimal.__gt__"],  true, "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' (Decimal.__gt__() implements the greater-than comparison operator; 'Decimal.__gt__' has 14 characters: 'Decimal.' (8) + '__gt__' (6) = 14; the five comparison dunders __lt__, __le__, __gt__, __ge__, __eq__ form a complete five-way tie at qualname length 14 for decimal.Decimal; this five-way tie is a natural consequence of all five comparison dunder names having exactly 6 characters)"]
    - [ge_qeq,  "Decimal.__ge__.__qualname__.__eq__",  ["Decimal.__ge__"],  true, "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' (Decimal.__ge__() implements the greater-than-or-equal comparison operator; 'Decimal.__ge__' has 14 characters: 'Decimal.' (8) + '__ge__' (6) = 14; tied with the other four comparison dunders at 14; Decimal comparison semantics are defined by the General Decimal Arithmetic specification and differ from float in their treatment of NaN — comparisons with NaN raise InvalidOperation rather than returning False)"]

# ---------------------------------------------------------------------------
# decimal.Decimal identity dunder method __qualname__ values
# __eq__, __str__, __hash__, __repr__ — identity/representation dunders.
# __eq__=14, __str__=15, __hash__=16, __repr__=16
# __hash__ and __repr__ are tied at 16.
# ---------------------------------------------------------------------------

table decimal_extra154.Decimal_identity_dunder_qualnames:
  description: "decimal.Decimal identity/representation dunder __qualname__ values: __eq__='Decimal.__eq__' (len=14), __str__='Decimal.__str__' (len=15), __hash__=__repr__='Decimal.__hash__'/'Decimal.__repr__' (len=16); __hash__ and __repr__ tied at 16"
  kind: python_call_eq
  category: qualname
  id_prefix: deccmpq154

  columns: [id, function, args, expected, description]
  rows:
    - [eq_qeq,    "Decimal.__eq__.__qualname__.__eq__",    ["Decimal.__eq__"],    true, "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (Decimal.__eq__() tests equality between Decimal objects; Decimal('1.0') != Decimal('1.00') because they differ in representation (different exponents); 'Decimal.__eq__' has 14 characters: 'Decimal.' (8) + '__eq__' (6) = 14; part of the five-way tie with __lt__, __le__, __gt__, __ge__ at 14; Decimal equality is exact-match including trailing zeros — unlike math equality where 1.0 == 1.00)"]
    - [str_qeq,   "Decimal.__str__.__qualname__.__eq__",   ["Decimal.__str__"],   true, "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (Decimal.__str__() returns the string representation of the Decimal — e.g., '1.23', 'Infinity', 'NaN'; 'Decimal.__str__' has 15 characters: 'Decimal.' (8) + '__str__' (7) = 15; one character longer than the comparison dunders (14) because '__str__' (7 chars) is one character longer than 6-char dunders like '__eq__'; str(Decimal('1.50')) returns '1.50' preserving significant trailing zeros)"]
    - [hash_qeq,  "Decimal.__hash__.__qualname__.__eq__",  ["Decimal.__hash__"],  true, "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' (Decimal.__hash__() returns the hash of the Decimal; the hash of a Decimal is consistent with int and float hashing: hash(Decimal('1')) == hash(1) == hash(1.0); 'Decimal.__hash__' has 16 characters: 'Decimal.' (8) + '__hash__' (8) = 16; tied with 'Decimal.__repr__' (also 16); both '__hash__' (8 chars) and '__repr__' (8 chars) are 8-character dunders producing qualname length 16)"]
    - [repr_qeq,  "Decimal.__repr__.__qualname__.__eq__",  ["Decimal.__repr__"],  true, "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (Decimal.__repr__() returns the developer representation like Decimal('1.23'); 'Decimal.__repr__' has 16 characters: 'Decimal.' (8) + '__repr__' (8) = 16; tied with 'Decimal.__hash__' (also 16) — both have 8-character dunder names; repr(Decimal('1.23')) returns \"Decimal('1.23')\" which is a valid Python expression to recreate the value; tied with __hash__ at 16 is the longest Decimal dunder qualname in this spec)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra154.Decimal_comparison_dunders_five_way_tie_at_14:
  description: "decimal.Decimal.__lt__.__qualname__.__len__() == 14 — 'Decimal.__lt__' has 14 characters: 'Decimal.' (8) + '__lt__' (6) = 14; __lt__ is part of a five-way tie at qualname length 14 with __le__, __gt__, __ge__, and __eq__ — all five have 6-character comparison dunder names of the form '__xx__' (2 underscores + 2-char operator + 2 underscores = 6); this five-way tie is the dominant pattern in decimal.Decimal comparison dunder qualnames; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__lt__.__qualname__.__len__"
  args: []
  expected: 14

invariant decimal_extra154.Decimal_str_qualname_len_15:
  description: "decimal.Decimal.__str__.__qualname__.__len__() == 15 — 'Decimal.__str__' has 15 characters: 'Decimal.' (8) + '__str__' (7) = 15; falls between the five-way tie at 14 (comparison dunders) and the two-way tie at 16 (__hash__ and __repr__); '__str__' (7 chars) is one character longer than 6-char comparison dunders and one character shorter than 8-char __hash__ and __repr__; Decimal.__str__() preserves significant trailing zeros, a key difference from float str representations; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__str__.__qualname__.__len__"
  args: []
  expected: 15

invariant decimal_extra154.Decimal_hash_repr_tied_at_16:
  description: "decimal.Decimal.__hash__.__qualname__.__len__() == 16 — 'Decimal.__hash__' has 16 characters: 'Decimal.' (8) + '__hash__' (8) = 16; tied with 'Decimal.__repr__' (also 16: 'Decimal.' (8) + '__repr__' (8) = 16); the two-way tie at 16 is the highest qualname length in this spec; both '__hash__' and '__repr__' are 8-character dunder names; the complete length ranking: __lt__=__le__=__gt__=__ge__=__eq__=14, __str__=15, __hash__=__repr__=16; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__hash__.__qualname__.__len__"
  args: []
  expected: 16

