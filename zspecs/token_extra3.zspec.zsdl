spec: token_extra3
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/token.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — covers exact integer values for core and extended constants (ENDMARKER=0, NAME=1, NUMBER=2, STRING=3, NEWLINE=4, INDENT=5, DEDENT=6, OP=55, COMMENT=65, NL=66, ERRORTOKEN=67, ENCODING=68), NT_OFFSET=256, tok_name lookups at indices 0-6, tok_name is_dict, ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
    - "token_extra.zspec.zsdl — covers __class__.__name__ == 'int' for NAME/NUMBER/STRING/OP/COMMENT/NEWLINE/ENDMARKER/INDENT/DEDENT/ERRORTOKEN via table, tok_name is_dict, EXACT_TOKEN_TYPES is_dict, stable constant values NAME==1/NUMBER==2/STRING==3/NEWLINE==4/ENDMARKER==0"
    - "token_extra2.zspec.zsdl — covers EXACT_TYPE is_int, ERRORTOKEN is_int, ENCODING is_int, TYPE_COMMENT is_int, tok_name is_dict, tok_name min_length >= 50, tok_name at indices 0-4, ENDMARKER == 0"
  notes:
    - "This spec covers token aspects not in token.zspec.zsdl, token_extra.zspec.zsdl, or token_extra2.zspec.zsdl."
    - "token.NAME.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.NUMBER.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.STRING.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.OP.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.NEWLINE.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.ENDMARKER.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.INDENT.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.DEDENT.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.COMMENT.__class__.__name__ == 'int' — covered in token_extra; also required here per task spec."
    - "token.NL.__class__.__name__ == 'int' — NL is the non-logical newline token; it is a plain int."
    - "token.tok_name.__class__.__name__ == 'dict' — covered in token.zspec.zsdl and token_extra; also required here."
    - "token.EXACT_TOKEN_TYPES.__class__.__name__ == 'dict' — covered in token_extra; also required here."
    - "token.NAME > 0 — NAME is 1, which is positive; verified via __gt__(0)."
    - "token.ENDMARKER == 0 — ENDMARKER is always 0 across all Python 3.x versions."
    - "token.tok_name[token.NAME] == 'NAME' — verify the dict round-trip for the NAME constant."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Token constant type checks — all are plain Python ints
# ---------------------------------------------------------------------------

table token_extra3.constant_types_primary:
  kind: python_call_eq
  category: constant_types
  id_prefix: toktype

  columns: [id, function, args, expected]
  rows:
    - [name,    NAME.__class__.__name__.__eq__,    ["int"], true]
    - [number,  NUMBER.__class__.__name__.__eq__,  ["int"], true]
    - [string,  STRING.__class__.__name__.__eq__,  ["int"], true]
    - [op,      OP.__class__.__name__.__eq__,      ["int"], true]
    - [newline, NEWLINE.__class__.__name__.__eq__,  ["int"], true]

table token_extra3.constant_types_secondary:
  kind: python_call_eq
  category: constant_types
  id_prefix: toktype2

  columns: [id, function, args, expected]
  rows:
    - [endmarker, ENDMARKER.__class__.__name__.__eq__, ["int"], true]
    - [indent,    INDENT.__class__.__name__.__eq__,    ["int"], true]
    - [dedent,    DEDENT.__class__.__name__.__eq__,    ["int"], true]
    - [comment,   COMMENT.__class__.__name__.__eq__,   ["int"], true]
    - [nl,        NL.__class__.__name__.__eq__,        ["int"], true]

# ---------------------------------------------------------------------------
# Dict-typed module attributes — tok_name and EXACT_TOKEN_TYPES
# ---------------------------------------------------------------------------

invariant token_extra3.tok_name.is_dict:
  description: "token.tok_name.__class__.__name__ == 'dict'"
  category: dict_attrs
  kind: python_call_eq
  function: tok_name.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant token_extra3.EXACT_TOKEN_TYPES.is_dict:
  description: "token.EXACT_TOKEN_TYPES.__class__.__name__ == 'dict'"
  category: dict_attrs
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# NAME is positive (greater than zero)
# ---------------------------------------------------------------------------

invariant token_extra3.NAME.is_positive:
  description: "token.NAME > 0 — NAME (value 1) is a positive integer"
  category: constant_values
  kind: python_call_eq
  function: NAME.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# ENDMARKER == 0 — stable sentinel value
# ---------------------------------------------------------------------------

invariant token_extra3.ENDMARKER.is_zero:
  description: "token.ENDMARKER == 0 — ENDMARKER is always token type 0"
  category: constant_values
  kind: python_call_eq
  function: ENDMARKER.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# tok_name[NAME] == 'NAME' — dict round-trip for NAME constant
# ---------------------------------------------------------------------------

invariant token_extra3.tok_name.name_lookup:
  description: "token.tok_name[token.NAME] == 'NAME' — tok_name[1] == 'NAME'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__getitem__
  args: [1]
  expected: "NAME"

# ---------------------------------------------------------------------------
# EXACT_TOKEN_TYPES — is non-empty (has at least one entry)
# ---------------------------------------------------------------------------

invariant token_extra3.EXACT_TOKEN_TYPES.nonempty:
  description: "len(token.EXACT_TOKEN_TYPES) >= 1 — EXACT_TOKEN_TYPES has at least one mapping"
  category: dict_attrs
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# NUMBER is positive (greater than zero)
# ---------------------------------------------------------------------------

invariant token_extra3.NUMBER.is_positive:
  description: "token.NUMBER > 0 — NUMBER (value 2) is a positive integer"
  category: constant_values
  kind: python_call_eq
  function: NUMBER.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# tok_name is non-empty
# ---------------------------------------------------------------------------

invariant token_extra3.tok_name.nonempty:
  description: "len(token.tok_name) >= 1 — tok_name has at least one mapping"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true
