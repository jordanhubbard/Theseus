  id_prefix: threadingexha153

  columns: [id, function, args, expected, description]
  rows:
    - [excepthookargs_name_eq__ExceptHookArgs,
       "ExceptHookArgs.__name__.__eq__",
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__name__.__eq__('_ExceptHookArgs') == True — ExceptHookArgs is a namedtuple-like type whose internal __name__ is '_ExceptHookArgs' (with leading underscore); it is exposed publicly as threading.ExceptHookArgs; str.__eq__('_ExceptHookArgs') returns True; new to extra153"]
    - [excepthookargs_module_eq__thread,
       "ExceptHookArgs.__module__.__eq__",
       ["_thread"],
       true,
       "threading.ExceptHookArgs.__module__.__eq__('_thread') == True — ExceptHookArgs is defined in Modules/_threadmodule.c; its __module__ is '_thread' (the C extension module), not 'threading'; str.__eq__('_thread') returns True; new to extra153"]
    - [excepthookargs_qualname_eq__ExceptHookArgs,
       "ExceptHookArgs.__qualname__.__eq__",
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__qualname__.__eq__('_ExceptHookArgs') == True — ExceptHookArgs.__qualname__ equals __name__ ('_ExceptHookArgs') since it is a top-level C type; str.__eq__('_ExceptHookArgs') returns True; new to extra153"]
    - [spec_class_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — threading.__spec__ is an importlib.machinery.ModuleSpec object; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra153"]
    - [spec_name_eq_threading,
       "__spec__.name.__eq__",
       ["threading"],
       true,
       "threading.__spec__.name.__eq__('threading') == True — the ModuleSpec .name attribute (not __name__) of the threading module spec is 'threading'; str.__eq__('threading') returns True; new to extra153"]

