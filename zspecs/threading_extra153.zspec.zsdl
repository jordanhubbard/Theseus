    - "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — threading.excepthook is actually a C builtin from _thread (not a Python function); its __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — the internal name of ExceptHookArgs is '_ExceptHookArgs'; __module__ is '_thread'. Added in Python 3.8. Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' — threading.__spec__ is a ModuleSpec object; its .name attribute (not __name__) is 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX — type identity and positivity
#
# Wave 281 theme: threading.TIMEOUT_MAX type and value checks.
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(0) == True
#
# TIMEOUT_MAX is the maximum value usable for a timeout argument in the
# threading module. It is imported from _thread as a float.
# On 64-bit systems it is 9223372036.0. New to extra153.
# ---------------------------------------------------------------------------

table threading_extra153.timeout_max_identity:
  description: "threading.TIMEOUT_MAX: class 'float', __gt__(0) True, positive float imported from _thread; wave 281; new to extra153"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtmax153

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_eq_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant imported from _thread into threading; its __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra153"]
    - [timeout_max_gt_0,
       "TIMEOUT_MAX.__gt__",
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (approximately 9223372036.0 on 64-bit systems); float.__gt__(0) returns True; new to extra153"]
    - [timeout_max_gt_1000,
       "TIMEOUT_MAX.__gt__",
       [1000],
       true,
       "threading.TIMEOUT_MAX.__gt__(1000) == True — TIMEOUT_MAX is far larger than 1000; it is approximately 9 billion seconds on 64-bit systems; float.__gt__(1000) returns True; new to extra153"]
    - [timeout_max_class_class_eq_type,
       "TIMEOUT_MAX.__class__.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.TIMEOUT_MAX.__class__.__class__.__name__.__eq__('type') == True — __class__ of TIMEOUT_MAX is float; the metaclass of float is type; __class__.__class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra153"]

# ---------------------------------------------------------------------------
# Table 2: threading._main_thread and threading.excepthook identity
#
# Wave 281 theme: internal threading object type identity.
#
# type(threading._main_thread).__name__ == '_MainThread'
# type(threading._main_thread).__module__ == 'threading'
# threading.excepthook.__class__.__name__ == 'builtin_function_or_method'
# threading.excepthook.__module__ == '_thread'
#
# _main_thread is an instance of _MainThread which is a Thread subclass.
# excepthook is actually a C builtin from _thread (not a Python function).
# New to extra153.
# ---------------------------------------------------------------------------

table threading_extra153.main_thread_and_excepthook_identity:
