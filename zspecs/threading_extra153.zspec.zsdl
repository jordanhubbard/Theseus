       ["_MainThread"],
       true,
       "threading._main_thread.__class__.__name__.__eq__('_MainThread') == True — _main_thread is the singleton _MainThread instance representing the main thread of execution; __class__.__name__ is '_MainThread'; str.__eq__('_MainThread') returns True; new to extra153"]
    - [main_thread_class_module_eq_threading,
       "_main_thread.__class__.__module__.__eq__",
