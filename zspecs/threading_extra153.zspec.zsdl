    - [excepthook_class_eq_builtin,
       "excepthook.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.excepthook.__class__.__name__.__eq__('builtin_function_or_method') == True — despite being accessible as threading.excepthook, it is actually a C builtin from _thread; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra153"]
    - [excepthook_module_eq__thread,
       "excepthook.__module__.__eq__",
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — threading.excepthook is a C builtin defined in Modules/_threadmodule.c; its __module__ is '_thread' not 'threading'; str.__eq__('_thread') returns True; new to extra153"]

# ---------------------------------------------------------------------------
# Table 3: threading.ExceptHookArgs and threading.__spec__
#
# Wave 281 theme: threading ExceptHookArgs internal name and module spec.
#
# threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'
# threading.ExceptHookArgs.__module__ == '_thread'
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# threading.__spec__.name == 'threading'
#
# ExceptHookArgs (added in Python 3.8) has internal name '_ExceptHookArgs'
# and lives in the _thread C module. threading.__spec__ is a ModuleSpec;
# its .name attribute (not __name__) is 'threading'. New to extra153.
# ---------------------------------------------------------------------------

table threading_extra153.excepthookargs_and_spec:
  description: "threading.ExceptHookArgs: __name__ '_ExceptHookArgs', __module__ '_thread'; threading.__spec__: class 'ModuleSpec', .name 'threading'; wave 281; new to extra153"
  kind: python_call_eq
