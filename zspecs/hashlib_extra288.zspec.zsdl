spec: hashlib_extra288
version: ">=3.11"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — HMAC, pbkdf2_hmac, scrypt, file_digest function identities"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c, Lib/hashlib.py"
  notes:
    - "pbkdf2_hmac and scrypt are C extension functions; __module__ is '_hashlib'"
    - "file_digest is a pure Python function added in 3.11; __module__ is 'hashlib'"
    - "hashlib.new is wrapped internally; __name__ is '__hash_new', __module__ is 'hashlib'"
    - "algorithms_guaranteed contains at least sha256, sha512, md5 on CPython"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra288.func_names:
  description: "hashlib function __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: hlname

  columns: [id, function, args, expected, description]
  rows:
    - [hlname001, hashlib.pbkdf2_hmac.__name__.__class__.__name__, [], str, "pbkdf2_hmac __name__ is a str"]
    - [hlname002, hashlib.pbkdf2_hmac.__name__, [], pbkdf2_hmac, "pbkdf2_hmac __name__ value"]
    - [hlname003, hashlib.scrypt.__name__, [], scrypt, "scrypt __name__ value"]
    - [hlname004, hashlib.file_digest.__name__, [], file_digest, "file_digest __name__ value"]
    - [hlname005, hashlib.new.__name__, [], __hash_new, "hashlib.new internal __name__ is __hash_new"]

table hashlib_extra288.func_modules:
  description: "hashlib function __module__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: hlmod

  columns: [id, function, args, expected, description]
  rows:
    - [hlmod001, hashlib.pbkdf2_hmac.__module__, [], _hashlib, "pbkdf2_hmac is in C extension _hashlib"]
    - [hlmod002, hashlib.scrypt.__module__, [], _hashlib, "scrypt is in C extension _hashlib"]
    - [hlmod003, hashlib.file_digest.__module__, [], hashlib, "file_digest is pure Python in hashlib"]
    - [hlmod004, hashlib.new.__module__, [], hashlib, "hashlib.new wrapper lives in hashlib"]

invariant hashlib_extra288.new_bad_algo_raises:
  description: "hashlib.new with unknown algorithm name raises ValueError"
  category: errors
  kind: python_call_raises
  function: hashlib.new
  args: ["not_a_real_algo_xyz"]
  raises: ValueError

invariant hashlib_extra288.algorithms_guaranteed_nonempty:
  description: "algorithms_guaranteed set contains at least one element"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__len__
  args: []
  expected: 14

invariant hashlib_extra288.pbkdf2_hmac_qualname:
  description: "pbkdf2_hmac __qualname__ equals its __name__"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__qualname__
  args: []
  expected: pbkdf2_hmac
