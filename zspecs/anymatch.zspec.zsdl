spec: anymatch
version: ">=3.0.0"
backend: node(anymatch)

docs: https://github.com/micromatch/anymatch#readme

provenance:
  derived_from:
    - "anymatch README — https://github.com/micromatch/anymatch#readme"
    - "Test vectors verified with anymatch via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "anymatch source"
  notes:
    - "Match strings against multiple glob patterns / regexes / functions — used by chokidar."
    - "Install: npm install anymatch"
    - "v3 CJS; module export IS the function. anymatch(matchers) returns a matcher; anymatch(matchers, value) returns the boolean directly."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string/array input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant anymatch.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant anymatch.inline_match_true:
  description: "anymatch('*.js', 'app.js') returns true"
  category: match
  kind: node_chain_eq
  entry: module
  entry_args: ["*.js", "app.js"]
  chain: []
  expected: true

invariant anymatch.inline_match_false:
  description: "anymatch('*.js', 'app.css') returns false"
  category: match
  kind: node_chain_eq
  entry: module
  entry_args: ["*.js", "app.css"]
  chain: []
  expected: false

invariant anymatch.array_of_patterns_true:
  description: "Array of matchers — first match wins"
  category: match
  kind: node_chain_eq
  entry: module
  entry_args: [["*.js", "*.ts"], "foo.ts"]
  chain: []
  expected: true

invariant anymatch.array_of_patterns_false:
  description: "Array of matchers — none match"
  category: match
  kind: node_chain_eq
  entry: module
  entry_args: [["*.js", "*.ts"], "foo.txt"]
  chain: []
  expected: false

invariant anymatch.partial_application_returns_function:
  description: "anymatch(matchers) without value returns a Function"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: [["*.js"]]
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant anymatch.empty_pattern_array_no_match:
  description: "Empty matcher array returns false for any value"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [[], "foo.js"]
  chain: []
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:33:12Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
