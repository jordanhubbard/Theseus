spec: curses_extra3
version: ">=3.9"
backend: python_module(curses)

docs: https://docs.python.org/3/library/curses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/curses.html — Python curses documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/curses/__init__.py"
  notes:
    - "This spec extends curses.zspec.zsdl, curses_extra.zspec.zsdl, curses_ascii.zspec.zsdl, and curses_extra2.zspec.zsdl."
    - "curses_extra covers: error.__name__/__module__/__bases__, ascii.__name__, ERR/OK, COLOR_BLACK/RED class, A_BOLD/NORMAL/UNDERLINE class."
    - "curses_extra2 covers: newwin.__name__/__qualname__, COLOR_GREEN/YELLOW/BLUE/MAGENTA/CYAN/WHITE class+value, COLOR_BLACK-WHITE values, A_BLINK/DIM class+non-negative."
    - "This spec adds: error.__qualname__, A_STANDOUT/__class__ check (new), A_BOLD/A_NORMAL/A_REVERSE/A_UNDERLINE/A_STANDOUT non-negative checks, module __name__."
    - "curses.zspec.zsdl covers A_BOLD/A_UNDERLINE/A_REVERSE class checks; this spec adds only non-negative value bounds for those."
    - "All COLOR_* and A_* constants are available at import time without calling initscr()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# error.__qualname__ — top-level exception, qualname matches name
# curses_extra covers __name__ and __module__; __qualname__ not yet covered
# ---------------------------------------------------------------------------

invariant curses_extra3.error.qualname:
  description: "curses.error.__qualname__ == 'error'"
  category: classnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# A_REVERSE — non-negative value bound
# curses.zspec.zsdl covers A_REVERSE.__class__ check; value bound is new here.
# ---------------------------------------------------------------------------

invariant curses_extra3.A_REVERSE.is_non_negative:
  description: "curses.A_REVERSE >= 0 — A_REVERSE is a non-negative integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_REVERSE.__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# A_STANDOUT — class check (not covered in any prior spec)
# ---------------------------------------------------------------------------

invariant curses_extra3.A_STANDOUT.class_is_int:
  description: "curses.A_STANDOUT.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: A_STANDOUT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses_extra3.A_STANDOUT.is_non_negative:
  description: "curses.A_STANDOUT >= 0 — A_STANDOUT is a non-negative integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_STANDOUT.__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# A_BOLD — non-negative check (class covered in curses_extra; value bound new)
# ---------------------------------------------------------------------------

invariant curses_extra3.A_BOLD.is_non_negative:
  description: "curses.A_BOLD >= 0 — A_BOLD is a non-negative integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_BOLD.__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# A_NORMAL — non-negative check (class covered in curses_extra; value bound new)
# ---------------------------------------------------------------------------

invariant curses_extra3.A_NORMAL.is_non_negative:
  description: "curses.A_NORMAL >= 0 — A_NORMAL is a non-negative integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_NORMAL.__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Module __name__ — curses module identity
# (not covered in any prior curses spec)
# ---------------------------------------------------------------------------

invariant curses_extra3.module.name:
  description: "curses.__name__ == 'curses' — the module's own __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["curses"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch non-negative checks for A_UNDERLINE, A_REVERSE, A_STANDOUT
# (complements curses_extra2 which batch-checks A_BLINK and A_DIM)
# ---------------------------------------------------------------------------

table curses_extra3.attr_constants.non_negative:
  kind: python_call_eq
  category: constants
  id_prefix: attr_nonneg

  columns: [id, function, args, expected]
  rows:
    - [A_UNDERLINE, A_UNDERLINE.__ge__, [0], true]
    - [A_REVERSE,   A_REVERSE.__ge__,   [0], true]
    - [A_STANDOUT,  A_STANDOUT.__ge__,  [0], true]
