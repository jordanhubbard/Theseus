spec: http_server_extra
version: ">=3.9"
backend: python_module(http.server)

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.server.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
    - "http_server.zspec.zsdl — covers class names (HTTPServer/ThreadingHTTPServer/BaseHTTPRequestHandler/SimpleHTTPRequestHandler/CGIHTTPRequestHandler), server_version, protocol_version, default_request_version, error_content_type, extensions_map type"
    - "http_server_handlers.zspec.zsdl — covers module checks for all 4 classes, SimpleHTTPRequestHandler/CGIHTTPRequestHandler/HTTPServer bases, error_message_format type/nonempty, SimpleHTTP server_version prefix, cgi_directories type/contents"
  notes:
    - "This spec extends the http.server chain; it does NOT duplicate invariants present in any prior spec."
    - "BaseHTTPRequestHandler.__bases__[0].__name__ == 'StreamRequestHandler' — not tested in any prior spec."
    - "ThreadingHTTPServer.__module__ == 'http.server' — http_server_handlers only checked HTTPServer/Base/Simple/CGI modules."
    - "ThreadingHTTPServer.__bases__ is a 2-element tuple: (ThreadingMixIn, HTTPServer)."
    - "ThreadingHTTPServer.__bases__[0].__name__ == 'ThreadingMixIn' — multiple inheritance, MixIn first."
    - "ThreadingHTTPServer.__bases__[1].__name__ == 'HTTPServer' — second base is HTTPServer."
    - "HTTPServer.__qualname__ == 'HTTPServer' — top-level class in http.server module."
    - "BaseHTTPRequestHandler.http_version attribute: BaseHTTP/0.6 era; 'http_version' is not exposed as a plain attribute — the handler uses protocol_version. This spec uses error_content_type and protocol_version string class checks."
    - "BaseHTTPRequestHandler.server_version.__class__.__name__ == 'str' — string attribute type check."
    - "BaseHTTPRequestHandler.error_content_type.__class__.__name__ == 'str' — string attribute type check."
    - "SimpleHTTPRequestHandler.index_pages is a tuple or list of default index filenames (Python 3.9+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler base class
# http_server_handlers checks SimpleHTTP/CGI/HTTPServer bases;
# this spec adds the BaseHTTPRequestHandler base (StreamRequestHandler).
# ---------------------------------------------------------------------------

invariant http_server_extra.BaseHTTPRequestHandler.base:
  description: "BaseHTTPRequestHandler.__bases__[0].__name__ == 'StreamRequestHandler'"
  category: hierarchy
  kind: python_call_eq
  function: BaseHTTPRequestHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "StreamRequestHandler"

# ---------------------------------------------------------------------------
# ThreadingHTTPServer module check
# http_server_handlers only checked HTTPServer/Base/Simple/CGI modules;
# ThreadingHTTPServer was not included.
# ---------------------------------------------------------------------------

invariant http_server_extra.ThreadingHTTPServer.module:
  description: "ThreadingHTTPServer.__module__ == 'http.server'"
  category: modules
  kind: python_call_eq
  function: ThreadingHTTPServer.__module__.__eq__
  args: ["http.server"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadingHTTPServer base classes
# ThreadingHTTPServer uses multiple inheritance: (ThreadingMixIn, HTTPServer).
# The class name is in http_server.zspec; the bases are new here.
# ---------------------------------------------------------------------------

invariant http_server_extra.ThreadingHTTPServer.base0:
  description: "ThreadingHTTPServer.__bases__[0].__name__ == 'ThreadingMixIn' — MixIn is first"
  category: hierarchy
  kind: python_call_eq
  function: ThreadingHTTPServer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ThreadingMixIn"

invariant http_server_extra.ThreadingHTTPServer.base1:
  description: "ThreadingHTTPServer.__bases__[1].__name__ == 'HTTPServer' — HTTPServer is second"
  category: hierarchy
  kind: python_call_eq
  function: ThreadingHTTPServer.__bases__.__getitem__
  args: [1]
  method: __name__
  expected: "HTTPServer"

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler string attribute type checks
# http_server.zspec verifies the values of server_version, protocol_version,
# default_request_version, error_content_type; this spec adds __class__.__name__
# checks to confirm each is a plain str.
# ---------------------------------------------------------------------------

table http_server_extra.handler_string_attr_types:
  kind: python_call_eq
  category: constants
  id_prefix: strtype

  columns: [id, function, args, expected]
  rows:
    - [server_version_type,    BaseHTTPRequestHandler.server_version.__class__.__name__.__eq__,    ["str"], true]
    - [protocol_version_type,  BaseHTTPRequestHandler.protocol_version.__class__.__name__.__eq__,  ["str"], true]
    - [error_content_type_str, BaseHTTPRequestHandler.error_content_type.__class__.__name__.__eq__, ["str"], true]
    - [default_request_version_type, BaseHTTPRequestHandler.default_request_version.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# HTTPServer qualname — not checked in any prior spec
# ---------------------------------------------------------------------------

invariant http_server_extra.HTTPServer.qualname:
  description: "HTTPServer.__qualname__ == 'HTTPServer' — top-level class, no enclosing scope"
  category: class_metadata
  kind: python_call_eq
  function: HTTPServer.__qualname__.__eq__
  args: ["HTTPServer"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler.index_pages — tuple of default filenames (Python 3.9+)
# index_pages = ('index.html', 'index.htm') by default.
# ---------------------------------------------------------------------------

invariant http_server_extra.SimpleHTTPRequestHandler.index_pages_type:
  description: "SimpleHTTPRequestHandler.index_pages.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.index_pages.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant http_server_extra.SimpleHTTPRequestHandler.index_pages_contains_index_html:
  description: "'index.html' in SimpleHTTPRequestHandler.index_pages"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.index_pages.__contains__
  args: ["index.html"]
  expected: true

# ---------------------------------------------------------------------------
# CGIHTTPRequestHandler qualname — not checked in any prior spec
# ---------------------------------------------------------------------------

invariant http_server_extra.CGIHTTPRequestHandler.qualname:
  description: "CGIHTTPRequestHandler.__qualname__ == 'CGIHTTPRequestHandler'"
  category: class_metadata
  kind: python_call_eq
  function: CGIHTTPRequestHandler.__qualname__.__eq__
  args: ["CGIHTTPRequestHandler"]
  expected: true

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler.responses — dict mapping HTTP status codes to
# (short_msg, long_msg) tuples.  Present on all Python 3 builds.
# http_server.zspec and http_server_handlers.zspec do not test this attribute.
# ---------------------------------------------------------------------------

invariant http_server_extra.BaseHTTPRequestHandler.responses_type:
  description: "BaseHTTPRequestHandler.responses.__class__.__name__ == 'dict'"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.responses.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant http_server_extra.BaseHTTPRequestHandler.responses_contains_200:
  description: "200 in BaseHTTPRequestHandler.responses — 200 OK must be present"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.responses.__contains__
  args: [200]
  expected: true
