spec: itertools_extra29
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra28.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__, bases, pairwise/product/permutations/combinations bases, __module__.__len__() for chain/cycle/count/repeat (all 9), __name__.__len__() for chain/cycle/count/repeat/zip_longest/starmap/takewhile/dropwhile."
    - "This spec covers: __name__.__len__() for islice/pairwise/product/groupby/filterfalse/accumulate/permutations/combinations; __module__.__len__() for islice/pairwise/product/groupby/filterfalse/accumulate; __qualname__.__len__() for islice/pairwise/product."
    - "Key findings: islice=6, pairwise=8, product=7, groupby=7, filterfalse=11, accumulate=10, permutations=12, combinations=12. All __module__ strings remain 'itertools' (len 9)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "spec version >=3.10 required for pairwise."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — combinatoric iterator name string lengths
#
# itertools.permutations and itertools.combinations both have 12-character names,
# the longest among the combinatoric iterators. islice has a 6-character name;
# pairwise has 8; product and groupby both have 7; accumulate has 10; filterfalse
# has 11. No prior itertools spec records these eight __name__.__len__() values
# together in a combined table in the extra29 namespace.
# ---------------------------------------------------------------------------

table itertools_extra29.combinatoric_name_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra29.combinatoric_name_str_lengths.islice,
       islice.__name__.__len__,
       [],
       6,
       "len(itertools.islice.__name__) == 6"]
    - [itertools_extra29.combinatoric_name_str_lengths.pairwise,
       pairwise.__name__.__len__,
       [],
       8,
       "len(itertools.pairwise.__name__) == 8"]
    - [itertools_extra29.combinatoric_name_str_lengths.product,
       product.__name__.__len__,
       [],
       7,
       "len(itertools.product.__name__) == 7"]
    - [itertools_extra29.combinatoric_name_str_lengths.groupby,
       groupby.__name__.__len__,
       [],
       7,
       "len(itertools.groupby.__name__) == 7"]
    - [itertools_extra29.combinatoric_name_str_lengths.accumulate,
       accumulate.__name__.__len__,
       [],
       10,
       "len(itertools.accumulate.__name__) == 10"]
    - [itertools_extra29.combinatoric_name_str_lengths.filterfalse,
       filterfalse.__name__.__len__,
       [],
       11,
       "len(itertools.filterfalse.__name__) == 11"]
    - [itertools_extra29.combinatoric_name_str_lengths.permutations,
       permutations.__name__.__len__,
       [],
       12,
       "len(itertools.permutations.__name__) == 12"]
    - [itertools_extra29.combinatoric_name_str_lengths.combinations,
       combinations.__name__.__len__,
       [],
       12,
       "len(itertools.combinations.__name__) == 12"]

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string lengths for remaining itertools types
#
# islice, pairwise, product, groupby, filterfalse, and accumulate all have
# __module__ == 'itertools' (len 9), consistent with every other itertools type.
# The previous spec (extra28) recorded this length for chain, cycle, count, and
# repeat. This table extends the coverage to the remaining filtering and
# combinatoric types. No prior itertools spec records these six __module__.__len__()
# values together in a combined table in the extra29 namespace.
# ---------------------------------------------------------------------------

table itertools_extra29.module_str_lengths_extended:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra29.module_str_lengths_extended.islice,
       islice.__module__.__len__,
       [],
       9,
       "len(itertools.islice.__module__) == 9"]
    - [itertools_extra29.module_str_lengths_extended.pairwise,
       pairwise.__module__.__len__,
       [],
       9,
       "len(itertools.pairwise.__module__) == 9"]
    - [itertools_extra29.module_str_lengths_extended.product,
       product.__module__.__len__,
       [],
       9,
       "len(itertools.product.__module__) == 9"]
    - [itertools_extra29.module_str_lengths_extended.groupby,
       groupby.__module__.__len__,
       [],
       9,
       "len(itertools.groupby.__module__) == 9"]
    - [itertools_extra29.module_str_lengths_extended.filterfalse,
       filterfalse.__module__.__len__,
       [],
       9,
       "len(itertools.filterfalse.__module__) == 9"]
    - [itertools_extra29.module_str_lengths_extended.accumulate,
       accumulate.__module__.__len__,
       [],
       9,
       "len(itertools.accumulate.__module__) == 9"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — qualname lengths for slicing and combinatoric types
#
# For all C-level itertools types, __qualname__ equals __name__ (they are
# module-level type objects). islice.__qualname__ is 'islice' (len 6),
# pairwise.__qualname__ is 'pairwise' (len 8), product.__qualname__ is
# 'product' (len 7). This table confirms the __qualname__.__len__() values for
# three representative types spanning the slicing and combinatoric subcategories.
# No prior itertools spec records these three __qualname__.__len__() values
# together in a combined table in the extra29 namespace.
# ---------------------------------------------------------------------------

table itertools_extra29.qualname_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra29.qualname_str_lengths.islice,
       islice.__qualname__.__len__,
       [],
       6,
       "len(itertools.islice.__qualname__) == 6"]
    - [itertools_extra29.qualname_str_lengths.pairwise,
       pairwise.__qualname__.__len__,
       [],
       8,
       "len(itertools.pairwise.__qualname__) == 8"]
    - [itertools_extra29.qualname_str_lengths.product,
       product.__qualname__.__len__,
       [],
       7,
       "len(itertools.product.__qualname__) == 7"]

# ---------------------------------------------------------------------------
# permutations.__name__.__len__() — standalone name string length
#
# itertools.permutations.__name__ is 'permutations', a 12-character string
# shared with combinations. permutations generates all ordered arrangements
# of a given length from an input iterable. Its 12-character name (tied with
# combinations) is the longest among the non-compound itertools type names.
# No prior itertools spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra29.permutations.name_len:
  description: "len(itertools.permutations.__name__) == 12"
  category: string_properties
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# accumulate.__module__.__len__() — standalone module string length
#
# itertools.accumulate.__module__ is 'itertools', a 9-character string.
# accumulate applies a binary function cumulatively to a sequence, producing
# running totals or other cumulative aggregations. It is a C-level type in the
# itertoolsmodule.c extension; all such types share the 'itertools' module
# string. No prior itertools spec records this standalone in the extra29
# namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra29.accumulate.module_len:
  description: "len(itertools.accumulate.__module__) == 9"
  category: string_properties
  kind: python_call_eq
  function: accumulate.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# combinations.__name__.__len__() — standalone name string length
#
# itertools.combinations.__name__ is 'combinations', a 12-character string.
# combinations generates all unordered selections of a given length from an
# input iterable without repetition. At 12 characters its name is tied with
# permutations as the longest among the standard itertools type names
# (excluding combinations_with_replacement at 29 chars). No prior itertools
# spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra29.combinations.name_len:
  description: "len(itertools.combinations.__name__) == 12"
  category: string_properties
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12
