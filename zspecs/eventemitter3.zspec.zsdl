spec: eventemitter3
version: ">=5.0.0"
backend: node(eventemitter3)

docs: https://github.com/primus/eventemitter3#readme

provenance:
  derived_from:
    - "EventEmitter3 README — https://github.com/primus/eventemitter3#readme"
    - "Test vectors verified with eventemitter3 via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "eventemitter3 source"
  notes:
    - "Fast, browser-friendly drop-in for Node's EventEmitter — used by socket.io, primus, etc."
    - "Install: npm install eventemitter3"
    - "Module export IS the constructor (CJS); .on/.off/.emit/.listenerCount."
    - "Listener-callback tests can't be chained (chain doesn't pass functions); we exercise listenerCount and eventNames as pure observables."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure operations; never throw on standard usage."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh emitter."
  codes: {}

# Fresh emitter — no listeners
invariant eventemitter3.fresh_listenerCount_zero:
  description: "Fresh emitter has listenerCount('x') == 0"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: listenerCount, args: ["x"]}
  expected: 0

invariant eventemitter3.fresh_eventNames_empty:
  description: "Fresh emitter has empty eventNames() array"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: eventNames, args: []}
    - {get: length}
  expected: 0

# After removeAllListeners on a fresh emitter — still 0
invariant eventemitter3.removeAllListeners_returns_this:
  description: "removeAllListeners returns the emitter (chainable)"
  category: api
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: removeAllListeners, args: []}
    - {method: listenerCount, args: ["any"]}
  expected: 0

# listeners() on unset event returns empty array
invariant eventemitter3.listeners_empty_array:
  description: "listeners('event') for unregistered event returns []"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: listeners, args: ["never"]}
    - {get: length}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:46:18Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
