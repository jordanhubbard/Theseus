spec: abc_extra262
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "All ABC methods verified here have __module__ == 'collections.abc'."
    - "Mapping provides concrete mixin methods: get, keys, values, items, __contains__, __eq__, __ne__."
    - "Sequence provides concrete mixin methods: index and count."
    - "MutableMapping provides concrete mixin methods: pop, popitem, clear, update, setdefault."
    - "MutableSequence provides concrete mixin methods: append, clear, reverse, extend, pop, remove, __iadd__."
    - "All __qualname__ values carry the defining ABC class prefix (e.g. 'Mapping.get', 'Sequence.index')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Mapping mixin method __name__ — table
#
# Six concrete mixin methods provided by collections.abc.Mapping:
# get, __contains__, keys, values, items, __eq__.
# ---------------------------------------------------------------------------

table abc_extra262.mapping_method_names:
  description: "collections.abc.Mapping concrete mixin methods report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mapname

  columns: [id, function, args, expected, description]
  rows:
    - [get,           Mapping.get.__name__.__eq__,           ["get"],           true, "Mapping.get.__name__ == 'get'"]
    - [__contains__,  Mapping.__contains__.__name__.__eq__,  ["__contains__"],  true, "Mapping.__contains__.__name__ == '__contains__'"]
    - [keys,          Mapping.keys.__name__.__eq__,          ["keys"],          true, "Mapping.keys.__name__ == 'keys'"]
    - [values,        Mapping.values.__name__.__eq__,        ["values"],        true, "Mapping.values.__name__ == 'values'"]
    - [items,         Mapping.items.__name__.__eq__,         ["items"],         true, "Mapping.items.__name__ == 'items'"]

# ---------------------------------------------------------------------------
# Mapping mixin method __qualname__ — table
# ---------------------------------------------------------------------------

table abc_extra262.mapping_method_qualnames:
  description: "collections.abc.Mapping concrete mixin methods report 'Mapping.'-prefixed __qualname__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mapqualname

  columns: [id, function, args, expected, description]
  rows:
    - [get,           Mapping.get.__qualname__.__eq__,           ["Mapping.get"],           true, "Mapping.get.__qualname__ == 'Mapping.get'"]
    - [__contains__,  Mapping.__contains__.__qualname__.__eq__,  ["Mapping.__contains__"],  true, "Mapping.__contains__.__qualname__ == 'Mapping.__contains__'"]
    - [keys,          Mapping.keys.__qualname__.__eq__,          ["Mapping.keys"],          true, "Mapping.keys.__qualname__ == 'Mapping.keys'"]
    - [values,        Mapping.values.__qualname__.__eq__,        ["Mapping.values"],        true, "Mapping.values.__qualname__ == 'Mapping.values'"]
    - [items,         Mapping.items.__qualname__.__eq__,         ["Mapping.items"],         true, "Mapping.items.__qualname__ == 'Mapping.items'"]

# ---------------------------------------------------------------------------
# Sequence mixin method __name__ and __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra262.Sequence.index.name:
  description: "collections.abc.Sequence.index.__name__ == 'index'"
  category: identity
  kind: python_call_eq
  function: Sequence.index.__name__.__eq__
  args: ["index"]
  expected: true

invariant abc_extra262.Sequence.index.qualname:
  description: "collections.abc.Sequence.index.__qualname__ == 'Sequence.index'"
  category: identity
  kind: python_call_eq
  function: Sequence.index.__qualname__.__eq__
  args: ["Sequence.index"]
  expected: true

invariant abc_extra262.Sequence.count.name:
  description: "collections.abc.Sequence.count.__name__ == 'count'"
  category: identity
  kind: python_call_eq
  function: Sequence.count.__name__.__eq__
  args: ["count"]
  expected: true

invariant abc_extra262.Sequence.count.qualname:
  description: "collections.abc.Sequence.count.__qualname__ == 'Sequence.count'"
  category: identity
  kind: python_call_eq
  function: Sequence.count.__qualname__.__eq__
  args: ["Sequence.count"]
  expected: true

# ---------------------------------------------------------------------------
