# ---------------------------------------------------------------------------
# Mapping.get __class__.__name__ — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra262.Mapping.get.class_name:
  description: "collections.abc.Mapping.get.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Mapping.get.__class__.__name__.__eq__
  args: ["function"]
  expected: true
