# ---------------------------------------------------------------------------
# MutableSequence mixin method __name__ and __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra262.MutableSequence.append.name:
  description: "collections.abc.MutableSequence.append.__name__ == 'append'"
  category: identity
  kind: python_call_eq
  function: MutableSequence.append.__name__.__eq__
