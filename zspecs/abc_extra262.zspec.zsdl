  category: identity
  kind: python_call_eq
  function: MutableMapping.update.__qualname__.__eq__
  args: ["MutableMapping.update"]
  expected: true

invariant abc_extra262.MutableMapping.pop.name:
  description: "collections.abc.MutableMapping.pop.__name__ == 'pop'"
  category: identity
  kind: python_call_eq
  function: MutableMapping.pop.__name__.__eq__
