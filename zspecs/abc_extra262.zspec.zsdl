invariant abc_extra262.MutableMapping.pop.qualname:
  description: "collections.abc.MutableMapping.pop.__qualname__ == 'MutableMapping.pop'"
  category: identity
  kind: python_call_eq
  function: MutableMapping.pop.__qualname__.__eq__
  args: ["MutableMapping.pop"]
