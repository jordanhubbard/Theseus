spec: io_extra378
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.open.__module__ == '_io' — io.open is implemented in the C extension _io, not the pure Python io wrapper; its __name__ is 'open'"
    - "io.open_code.__module__ == '_io' — open_code is also a C-level function in _io; available since Python 3.8"
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — POSIX seek-whence constants exposed as module-level integers"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open function identity — __name__ and __module__
# ---------------------------------------------------------------------------

table io_extra378.open_identity:
  description: "io.open function identity — __name__ and __module__; io.open is a C function implemented in the _io extension; its __name__ is 'open' and __module__ is '_io'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioopen378

  columns: [id, function, args, expected]
  rows:
    - [open_name,   io.open.__name__.__eq__,   ["open"], true]
    - [open_module, io.open.__module__.__eq__, ["_io"],  true]

# ---------------------------------------------------------------------------
# io SEEK constants — SEEK_SET, SEEK_CUR, SEEK_END
# ---------------------------------------------------------------------------

table io_extra378.seek_constants:
  description: "io SEEK constants — SEEK_SET==0, SEEK_CUR==1, SEEK_END==2; these are POSIX whence-argument constants exposed at module level; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: ioseek378

  columns: [id, function, args, expected]
  rows:
    - [seek_set, io.SEEK_SET.__eq__, [0], true]
    - [seek_cur, io.SEEK_CUR.__eq__, [1], true]
    - [seek_end, io.SEEK_END.__eq__, [2], true]

# ---------------------------------------------------------------------------
# io.open_code function identity — __name__ and __module__ (Python 3.8+)
# ---------------------------------------------------------------------------

table io_extra378.open_code_identity:
  description: "io.open_code function identity — __name__ and __module__; open_code is a C-level function in the _io extension added in Python 3.8; its __name__ is 'open_code' and __module__ is '_io'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioopencode378

  columns: [id, function, args, expected]
  rows:
    - [open_code_name,   io.open_code.__name__.__eq__,   ["open_code"], true]
    - [open_code_module, io.open_code.__module__.__eq__, ["_io"],       true]
