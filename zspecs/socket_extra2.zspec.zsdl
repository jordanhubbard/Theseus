spec: socket_extra2
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "Python 3 socket module documentation — https://docs.python.org/3/library/socket.html"
    - "POSIX.1-2017 — AF_INET = 2, SOCK_STREAM = 1 (universally stable)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, _socket.zspec.zsdl, and socket_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX integer values; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW integer values; IPPROTO_IP/TCP/UDP; SOL_SOCKET; SHUT_RD/WR/RDWR; socket/herror/gaierror class names; gethostname/getdefaulttimeout/inet_aton/inet_ntoa/htonl/ntohl function names; getdefaulttimeout()==None; inet_aton vectors; htonl(0)==0."
    - "socket_extra.zspec.zsdl covers: create_connection/create_server/setdefaulttimeout/htons/ntohs function names; setdefaulttimeout(None)==None; inet_aton broadcast/len; inet_ntoa loopback/broadcast/zero; htons/ntohs/ntohl zero; htonl(1) little-endian."
    - "_socket.zspec.zsdl covers: _socket.socket/__name__, _socket.error/__name__=='error', _socket.error.__bases__[0]=='OSError', gethostname/getaddrinfo names, AF_INET==2, SOCK_STREAM==1, IPPROTO_TCP/UDP, gethostname() returns str."
    - "This spec focuses on: AddressFamily/SocketKind enum class name checks; getfqdn() return type; socket.error alias (__name__=='OSError'); socket.timeout class name and base class."
    - "AF_UNIX is POSIX-only (not available on Windows). This spec targets POSIX platforms (macOS/Linux/FreeBSD)."
    - "AF_INET6's integer value differs by platform (10 on Linux, 30 on macOS) — only the class name 'AddressFamily' is checked here."
    - "socket.error is an alias for OSError in Python 3.3+; socket.error.__name__ == 'OSError'."
    - "socket.timeout is an alias for TimeoutError in Python 3.3+; socket.timeout.__name__ == 'TimeoutError' and its base is OSError."
    - "getfqdn() is a pure-Python function in socket module that returns the fully-qualified domain name as a str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O failures. Class checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class name or pure-computation checks."
  codes: {}

# ---------------------------------------------------------------------------
# AddressFamily enum class name checks
# The integer values are tested in socket.zspec.zsdl; this spec checks enum class names.
# AF_UNIX is POSIX-only (macOS/Linux/FreeBSD) — not available on Windows.
# ---------------------------------------------------------------------------

invariant socket_extra2.address_family.inet_class:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily'"
  category: address_family
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra2.address_family.inet6_class:
  description: "socket.AF_INET6.__class__.__name__ == 'AddressFamily'"
  category: address_family
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra2.address_family.unix_class:
  description: "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (POSIX only)"
  category: address_family
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# SocketKind enum class name checks
# The integer values are tested in socket.zspec.zsdl; this spec checks enum class names.
# ---------------------------------------------------------------------------

invariant socket_extra2.socket_kind.stream_class:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'"
  category: socket_kind
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra2.socket_kind.dgram_class:
  description: "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind'"
  category: socket_kind
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra2.socket_kind.raw_class:
  description: "socket.SOCK_RAW.__class__.__name__ == 'SocketKind'"
  category: socket_kind
  kind: python_call_eq
  function: SOCK_RAW.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# Integer value checks for universally stable constants
# (These are canonical cross-platform values; AF_INET6 is intentionally omitted
#  as its value differs between Linux (10) and macOS (30).)
# ---------------------------------------------------------------------------

invariant socket_extra2.constants.AF_INET_value:
  description: "socket.AF_INET == 2 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra2.constants.SOCK_STREAM_value:
  description: "socket.SOCK_STREAM == 1 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra2.constants.SOCK_DGRAM_value:
  description: "socket.SOCK_DGRAM == 2 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# gethostname() — return type check
# (function name already in socket.zspec.zsdl; _socket covers str return type
#  for _socket.gethostname; this spec covers socket.gethostname)
# ---------------------------------------------------------------------------

invariant socket_extra2.gethostname.class_name:
  description: "socket.gethostname().__class__.__name__ == 'str'"
  category: functions
  kind: python_call_eq
  function: gethostname
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# getfqdn() — returns the fully-qualified domain name as a str
# ---------------------------------------------------------------------------

invariant socket_extra2.getfqdn.class_name:
  description: "socket.getfqdn().__class__.__name__ == 'str'"
  category: functions
  kind: python_call_eq
  function: getfqdn
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error — alias for OSError since Python 3.3
# socket.error.__name__ == 'OSError' (the alias picks up the aliased class name)
# ---------------------------------------------------------------------------

invariant socket_extra2.error.name:
  description: "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout — alias for TimeoutError since Python 3.3
# socket.timeout.__name__ == 'TimeoutError'
# socket.timeout.__bases__[0].__name__ == 'OSError'
# ---------------------------------------------------------------------------

invariant socket_extra2.timeout.name:
  description: "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError"
  category: exceptions
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra2.timeout.base_class:
  description: "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError"
  category: exceptions
  kind: python_call_eq
  function: timeout.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"
