spec: threading_extra976
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ identity for threading.Thread and threading.Event methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra976.thread_method_qualnames:
  description: "threading.Thread method __qualname__ identity"
  kind: python_call_eq
  category: thread_qualnames
  id_prefix: th976tm
  columns: [id, function, args, expected]
  rows:
    - [th976tm001, threading.Thread.__init__.__qualname__.__eq__, ["Thread.__init__"], true]
    - [th976tm002, threading.Thread.start.__qualname__.__eq__,    ["Thread.start"],    true]
    - [th976tm003, threading.Thread.run.__qualname__.__eq__,      ["Thread.run"],      true]
    - [th976tm004, threading.Thread.join.__qualname__.__eq__,     ["Thread.join"],     true]
    - [th976tm005, threading.Thread.is_alive.__qualname__.__eq__, ["Thread.is_alive"], true]
    - [th976tm006, threading.Thread.getName.__qualname__.__eq__,  ["Thread.getName"],  true]
    - [th976tm007, threading.Thread.setName.__qualname__.__eq__,  ["Thread.setName"],  true]

table threading_extra976.event_method_qualnames:
  description: "threading.Event method __qualname__ identity"
  kind: python_call_eq
  category: event_qualnames
  id_prefix: th976em
  columns: [id, function, args, expected]
  rows:
    - [th976em001, threading.Event.set.__qualname__.__eq__,    ["Event.set"],    true]
    - [th976em002, threading.Event.clear.__qualname__.__eq__,  ["Event.clear"],  true]
    - [th976em003, threading.Event.wait.__qualname__.__eq__,   ["Event.wait"],   true]
    - [th976em004, threading.Event.is_set.__qualname__.__eq__, ["Event.is_set"], true]

table threading_extra976.lock_barrier_qualnames:
  description: "threading.Lock and threading.Barrier method __qualname__ identity"
  kind: python_call_eq
  category: sync_qualnames
  id_prefix: th976lb
  columns: [id, function, args, expected]
  rows:
    - [th976lb001, threading.Barrier.__init__.__qualname__.__eq__,  ["Barrier.__init__"],  true]
    - [th976lb002, threading.Barrier.wait.__qualname__.__eq__,      ["Barrier.wait"],      true]
    - [th976lb003, threading.Barrier.reset.__qualname__.__eq__,     ["Barrier.reset"],     true]
    - [th976lb004, threading.Barrier.abort.__qualname__.__eq__,     ["Barrier.abort"],     true]
    - [th976lb005, threading.Timer.__init__.__qualname__.__eq__,    ["Timer.__init__"],    true]
    - [th976lb006, threading.Timer.run.__qualname__.__eq__,         ["Timer.run"],         true]
    - [th976lb007, threading.Timer.cancel.__qualname__.__eq__,      ["Timer.cancel"],      true]
