spec: io_extra113
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra112.zspec.zsdl."
    - "This spec covers: io.FileIO, io.BufferedReader, io.BufferedWriter, and io.TextIOWrapper method class names and class hierarchy."
    - "All four concrete io types (FileIO, BufferedReader, BufferedWriter, TextIOWrapper) have __module__ == '_io' (C extension)."
    - "type(io.FileIO.read).__name__ == 'method_descriptor' (C extension method_descriptor, not wrapper_descriptor)."
    - "type(io.FileIO.write).__name__ == 'method_descriptor'; type(io.FileIO.readinto).__name__ == 'method_descriptor'."
    - "type(io.BufferedReader.read).__name__ == 'method_descriptor'; type(io.BufferedReader.read1).__name__ == 'method_descriptor'."
    - "type(io.BufferedReader.peek).__name__ == 'method_descriptor'."
    - "type(io.BufferedWriter.write).__name__ == 'method_descriptor'; type(io.BufferedWriter.flush).__name__ == 'method_descriptor'."
    - "type(io.TextIOWrapper.read).__name__ == 'method_descriptor'; type(io.TextIOWrapper.readline).__name__ == 'method_descriptor'."
    - "type(io.TextIOWrapper.write).__name__ == 'method_descriptor'."
    - "io.FileIO method __qualname__ uses 'FileIO.' prefix (e.g. 'FileIO.read'), not '_RawIOBase.' prefix."
    - "io.BufferedReader method __qualname__ uses 'BufferedReader.' prefix (e.g. 'BufferedReader.read')."
    - "io.TextIOWrapper method __qualname__ uses 'TextIOWrapper.' prefix (e.g. 'TextIOWrapper.read')."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase'; io.FileIO.__mro__.__len__() == 4 (FileIO, _RawIOBase, _IOBase, object)."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'; io.BufferedReader.__mro__.__len__() == 4 (BufferedReader, _BufferedIOBase, _IOBase, object)."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase'; io.TextIOWrapper.__mro__.__len__() == 4 (TextIOWrapper, _TextIOBase, _IOBase, object)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO method class names and __qualname__ strings
# FileIO is a C extension type (from _io module); its methods are method_descriptor
# objects. The __qualname__ prefix is 'FileIO.', matching the defining class name.
# io.FileIO.__bases__[0].__name__ == '_RawIOBase'; mro len == 4.
# ---------------------------------------------------------------------------

table io_extra113.FileIO_method_types:
  description: "io.FileIO method type names and __qualname__: read/write/readinto are method_descriptor; qualnames use 'FileIO.' prefix; FileIO.__bases__[0]='_RawIOBase', __mro__ len=4"
  kind: python_call_eq
  category: class_names
  id_prefix: iocls113a

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_read_type,     "FileIO.read.__class__.__name__.__eq__",     ["method_descriptor"], true, "type(io.FileIO.read).__name__ == 'method_descriptor' (C extension type)"]
    - [fileio_write_type,    "FileIO.write.__class__.__name__.__eq__",    ["method_descriptor"], true, "type(io.FileIO.write).__name__ == 'method_descriptor' (C extension type)"]
    - [fileio_readinto_type, "FileIO.readinto.__class__.__name__.__eq__", ["method_descriptor"], true, "type(io.FileIO.readinto).__name__ == 'method_descriptor' (C extension type)"]
    - [fileio_read_qn,       "FileIO.read.__qualname__.__eq__",           ["FileIO.read"],       true, "io.FileIO.read.__qualname__ == 'FileIO.read' (qualname uses the defining C class name 'FileIO')"]
    - [fileio_write_qn,      "FileIO.write.__qualname__.__eq__",          ["FileIO.write"],      true, "io.FileIO.write.__qualname__ == 'FileIO.write'"]
    - [fileio_readinto_qn,   "FileIO.readinto.__qualname__.__eq__",       ["FileIO.readinto"],   true, "io.FileIO.readinto.__qualname__ == 'FileIO.readinto'"]
    - [fileio_base_name,     "FileIO.__bases__[0].__name__.__eq__",       ["_RawIOBase"],        true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (concrete C type inheriting from the C base _RawIOBase)"]
    - [fileio_mro_len,       "FileIO.__mro__.__len__",                    [],                    4,    "io.FileIO.__mro__.__len__() == 4 (FileIO, _RawIOBase, _IOBase, object)"]

# ---------------------------------------------------------------------------
# io.BufferedReader and io.BufferedWriter method class names
# Both are C extension types from _io module with method_descriptor methods.
# BufferedReader provides read, read1, peek; BufferedWriter provides write, flush.
# Both inherit from _BufferedIOBase; mro len == 4.
# ---------------------------------------------------------------------------

table io_extra113.BufferedReader_BufferedWriter_method_types:
  description: "io.BufferedReader and BufferedWriter method type names: read/read1/peek/write/flush are method_descriptor; qualnames use class-name prefix; both have __mro__ len=4"
  kind: python_call_eq
  category: class_names
  id_prefix: iocls113b

  columns: [id, function, args, expected, description]
  rows:
    - [bufrd_read_type,   "BufferedReader.read.__class__.__name__.__eq__",   ["method_descriptor"], true, "type(io.BufferedReader.read).__name__ == 'method_descriptor'"]
    - [bufrd_read1_type,  "BufferedReader.read1.__class__.__name__.__eq__",  ["method_descriptor"], true, "type(io.BufferedReader.read1).__name__ == 'method_descriptor'"]
    - [bufrd_peek_type,   "BufferedReader.peek.__class__.__name__.__eq__",   ["method_descriptor"], true, "type(io.BufferedReader.peek).__name__ == 'method_descriptor'"]
    - [bufrd_read_qn,     "BufferedReader.read.__qualname__.__eq__",         ["BufferedReader.read"],  true, "io.BufferedReader.read.__qualname__ == 'BufferedReader.read'"]
    - [bufrd_base_name,   "BufferedReader.__bases__[0].__name__.__eq__",     ["_BufferedIOBase"],   true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'"]
    - [bufrd_mro_len,     "BufferedReader.__mro__.__len__",                  [],                    4,    "io.BufferedReader.__mro__.__len__() == 4 (BufferedReader, _BufferedIOBase, _IOBase, object)"]
    - [bufwr_write_type,  "BufferedWriter.write.__class__.__name__.__eq__",  ["method_descriptor"], true, "type(io.BufferedWriter.write).__name__ == 'method_descriptor'"]
    - [bufwr_flush_type,  "BufferedWriter.flush.__class__.__name__.__eq__",  ["method_descriptor"], true, "type(io.BufferedWriter.flush).__name__ == 'method_descriptor'"]
    - [bufwr_write_qn,    "BufferedWriter.write.__qualname__.__eq__",        ["BufferedWriter.write"], true, "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write'"]
    - [bufwr_base_name,   "BufferedWriter.__bases__[0].__name__.__eq__",     ["_BufferedIOBase"],   true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase'"]
    - [bufwr_mro_len,     "BufferedWriter.__mro__.__len__",                  [],                    4,    "io.BufferedWriter.__mro__.__len__() == 4 (BufferedWriter, _BufferedIOBase, _IOBase, object)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper method class names
# TextIOWrapper is a C extension type; its methods are method_descriptor.
# __qualname__ prefix is 'TextIOWrapper.'.
# TextIOWrapper.__bases__[0].__name__ == '_TextIOBase'; mro len == 4.
# ---------------------------------------------------------------------------

table io_extra113.TextIOWrapper_method_types:
  description: "io.TextIOWrapper method type names: read/readline/write are method_descriptor; qualnames use 'TextIOWrapper.' prefix; __bases__[0]='_TextIOBase', __mro__ len=4"
  kind: python_call_eq
  category: class_names
  id_prefix: iocls113c

  columns: [id, function, args, expected, description]
  rows:
    - [txtwrap_read_type,     "TextIOWrapper.read.__class__.__name__.__eq__",     ["method_descriptor"], true, "type(io.TextIOWrapper.read).__name__ == 'method_descriptor'"]
    - [txtwrap_readline_type, "TextIOWrapper.readline.__class__.__name__.__eq__", ["method_descriptor"], true, "type(io.TextIOWrapper.readline).__name__ == 'method_descriptor'"]
    - [txtwrap_write_type,    "TextIOWrapper.write.__class__.__name__.__eq__",    ["method_descriptor"], true, "type(io.TextIOWrapper.write).__name__ == 'method_descriptor'"]
    - [txtwrap_read_qn,       "TextIOWrapper.read.__qualname__.__eq__",           ["TextIOWrapper.read"],     true, "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read'"]
    - [txtwrap_readline_qn,   "TextIOWrapper.readline.__qualname__.__eq__",       ["TextIOWrapper.readline"], true, "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline'"]
    - [txtwrap_write_qn,      "TextIOWrapper.write.__qualname__.__eq__",          ["TextIOWrapper.write"],    true, "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write'"]
    - [txtwrap_base_name,     "TextIOWrapper.__bases__[0].__name__.__eq__",       ["_TextIOBase"],            true, "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (concrete C type inheriting from C base _TextIOBase)"]
    - [txtwrap_mro_len,       "TextIOWrapper.__mro__.__len__",                    [],                        4,    "io.TextIOWrapper.__mro__.__len__() == 4 (TextIOWrapper, _TextIOBase, _IOBase, object)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra113.FileIO.read_is_method_descriptor:
  description: "type(io.FileIO.read).__name__ == 'method_descriptor' (FileIO is a C extension type from the _io module; its methods are method_descriptor objects, distinct from the 'wrapper_descriptor' used for operator slots like __eq__)"
  category: class_names
  kind: python_call_eq
  function: "FileIO.read.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

invariant io_extra113.FileIO.base_is_RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (FileIO directly subclasses the C extension type _RawIOBase, not the Python-level RawIOBase ABC; the MRO is (FileIO, _RawIOBase, _IOBase, object) with length 4)"
  category: class_names
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra113.FileIO.mro_len_4:
  description: "io.FileIO.__mro__.__len__() == 4 (FileIO's MRO is (FileIO, _RawIOBase, _IOBase, object); as a concrete C extension type that bypasses the Python-level ABCs, its MRO is 4 entries — shorter than if it went through the Python ABC layer)"
  category: class_names
  kind: python_call_eq
  function: "FileIO.__mro__.__len__"
  args: []
  expected: 4

invariant io_extra113.BufferedReader.mro_len_4:
  description: "io.BufferedReader.__mro__.__len__() == 4 (BufferedReader's MRO is (BufferedReader, _BufferedIOBase, _IOBase, object); same length-4 pattern as FileIO and TextIOWrapper — the concrete C types all bypass the Python ABC layer)"
  category: class_names
  kind: python_call_eq
  function: "BufferedReader.__mro__.__len__"
  args: []
  expected: 4

invariant io_extra113.TextIOWrapper.base_is_TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (TextIOWrapper directly subclasses the C extension _TextIOBase, giving an MRO of (TextIOWrapper, _TextIOBase, _IOBase, object) with length 4; the Python-level TextIOBase ABC is not in this MRO)"
  category: class_names
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

