spec: lodash_issafeinteger
version: ">=4.0.0"
backend: node(lodash.issafeinteger)

docs: https://lodash.com/docs/#isSafeInteger

provenance:
  derived_from:
    - "lodash.issafeinteger README — https://www.npmjs.com/package/lodash.issafeinteger"
    - "Test vectors verified with lodash.issafeinteger@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.issafeinteger exports the _.isSafeInteger function directly as module.exports."
    - "isSafeInteger checks if value is a safe integer (within Number.MAX_SAFE_INTEGER bounds)."
    - "Number.MAX_SAFE_INTEGER is 9007199254740991. Values above this return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_issafeinteger.issafeinteger:
  kind: node_module_call_eq
  function: ~
  category: issafeinteger
  id_prefix: lisi

  columns: [id, args, expected]
  rows:
    - [small,    [3],                  true]
    - [neg,      [-100],               true]
    - [max_safe, [9007199254740991],   true]
    - [overflow, [9007199254740992],   false]
    - [float,    [1.5],                false]
    - [zero,     [0],                  true]

