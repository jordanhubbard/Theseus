spec: abc_extra66
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#abstract-base-classes — Python ABC documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra65.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, update_abstractmethods/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, all length tables, abstractproperty/abstractclassmethod/abstractstaticmethod qualnames/names/bases, ABCMeta.register/__instancecheck__/__subclasscheck__ qualname string equality and code attribute chains, class __mro__.__len__() tables, class __dict__ tables, class __class__ identity, __repr__/__weakref__/__eq__ class names, abc.__package__/__all__ membership, __loader__/__spec__/__file__ class names, __spec__ attributes, ABCMeta method __qualname__ string equality, ABCMeta.register code attribute type chains, abc.__spec__.__class__.__name__=='ModuleSpec', abc.__spec__.name=='abc', abc.__name__=='abc', abstractmethod/update_abstractmethods/get_cache_token doc content, ABC/__doc__.__contains__('inheritance'), ABCMeta/__doc__.__contains__('Base'), abc.__spec__.origin=='frozen', abc.__loader__.__class__.__name__=='type'."
    - "This spec covers (abccode66 namespace): wave 237 theme — ABCMeta method code objects + ABC hierarchy deep dive. NEW in extra66: ABCMeta.register.__code__.co_name=='register'; ABCMeta.register.__code__.co_argcount==2 (self + subclass); update_abstractmethods.__code__.co_name=='update_abstractmethods'; update_abstractmethods.__code__.co_argcount==1 (cls); ABC.__dict__.__class__.__name__=='mappingproxy'; ABC.__dict__.__contains__('__abstractmethods__')==True. ABCMeta.__init__ is a C extension (wrapper_descriptor) in Python 3.14 and has no __code__ attribute — excluded."
    - "abc.ABCMeta.register.__code__.co_name == 'register'. ABCMeta.register is a Python function defined in abc.py; its code object's co_name is the function's simple name 'register'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_argcount == 2. ABCMeta.register takes self (the ABCMeta class) and subclass; co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods'. update_abstractmethods is a module-level function; its code object's co_name is 'update_abstractmethods'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_argcount == 1. update_abstractmethods takes only cls; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'. Python class __dict__ is always a mappingproxy; ABC.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') == True. ABC sets __abstractmethods__ = frozenset() as a class attribute to mark itself as a concrete (non-abstract) subclass of ABCMeta; '__abstractmethods__' is in ABC.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__init__ is a C extension wrapper_descriptor in Python 3.14 and has no __code__ attribute — it is not included in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta.register code object checks — extra66
#
# Wave 237 theme: ABCMeta method code objects.
#
# ABCMeta.register.__code__.co_name == 'register'
# ABCMeta.register.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table abc_extra66.ABCMeta_register_code:
  description: "abc ABCMeta.register code object attribute checks in abccode66 namespace — wave 237 theme: ABCMeta method code objects; ABCMeta.register.__code__.co_name=='register' (ABCMeta.register is a Python function in abc.py; its code object stores the function's simple name); ABCMeta.register.__code__.co_argcount==2 (self + subclass); NEW in extra66: first co_name and co_argcount checks for ABCMeta.register in the abccode66 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode66

  columns: [id, function, args, expected, description]
  rows:
    - [register_co_name,     ABCMeta.register.__code__.co_name.__eq__,     ["register"], true, "ABCMeta.register.__code__.co_name == 'register' — ABCMeta.register is a Python function defined in abc.py; its code object's co_name is the function's simple name 'register'; NEW in extra66: first co_name.__eq__('register') check for ABCMeta.register in the abccode66 namespace; verified with Python 3.14.3"]
    - [register_co_argcount, ABCMeta.register.__code__.co_argcount.__eq__, [2],          true, "ABCMeta.register.__code__.co_argcount == 2 — ABCMeta.register takes self (the ABCMeta class) and subclass; co_argcount is 2; NEW in extra66: first co_argcount.__eq__(2) check for ABCMeta.register in the abccode66 namespace; verified with Python 3.14.3"]

