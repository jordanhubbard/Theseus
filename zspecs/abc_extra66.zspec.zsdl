invariant abc_extra66.ABCMeta_register_co_name:
  description: "abc.ABCMeta.register.__code__.co_name.__eq__('register') returns True — ABCMeta.register is a Python function in abc.py; its code object's co_name is 'register'; NEW in extra66: first standalone co_name invariant for ABCMeta.register in the abccode66 namespace; wave 237 first code object name invariant for ABCMeta.register; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_name.__eq__
  args: ["register"]
  expected: true

invariant abc_extra66.ABCMeta_register_co_argcount_2:
  description: "abc.ABCMeta.register.__code__.co_argcount.__eq__(2) returns True — ABCMeta.register takes self and subclass; co_argcount is 2; NEW in extra66: first standalone co_argcount invariant for ABCMeta.register in the abccode66 namespace; wave 237 first code object argcount invariant for ABCMeta.register; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra66.update_abstractmethods_co_name:
  description: "abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods') returns True — abc.update_abstractmethods is a module-level function; its code object's co_name is 'update_abstractmethods'; NEW in extra66: first standalone co_name invariant for update_abstractmethods in the abccode66 namespace; wave 237 first code object name invariant for update_abstractmethods; verified with Python 3.14.3"
  category: code
