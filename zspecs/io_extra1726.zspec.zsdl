spec: io_extra1726
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "io types do not define comparison operators in their own __dict__."
    - "io.IOBase.__dict__.__contains__('__lt__') is False — IOBase is a C extension type with no ordering."
    - "io.BytesIO.__dict__.__contains__('__lt__') is False — BytesIO does not define comparison operators."
    - "io.StringIO.__dict__.__contains__('__lt__') is False — StringIO does not define comparison operators."
    - "io.FileIO.__dict__.__contains__('__lt__') is False — FileIO does not define comparison operators."
    - "None of the IO types define __le__, __gt__, __ge__, or __ne__ in their own __dict__."
    - "IO objects are not ordered; the protocol is absent from all IO class dicts."
    - "io.IOBase.__dict__.__contains__('__eq__') is False — IOBase does not define __eq__ in its own dict."
    - "io.BytesIO.__dict__.__contains__('__eq__') is False — BytesIO does not define __eq__ in its own dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra1726.comparison_protocol:
  description: "io types comparison protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1726

  columns: [id, function, args, expected]
  rows:
    - ["io1726001", "io.IOBase.__dict__.__contains__",   ["__lt__"], false]
    - ["io1726002", "io.IOBase.__dict__.__contains__",   ["__le__"], false]
    - ["io1726003", "io.IOBase.__dict__.__contains__",   ["__gt__"], false]
    - ["io1726004", "io.IOBase.__dict__.__contains__",   ["__ge__"], false]
    - ["io1726005", "io.IOBase.__dict__.__contains__",   ["__ne__"], false]
    - ["io1726006", "io.BytesIO.__dict__.__contains__",  ["__lt__"], false]
    - ["io1726007", "io.BytesIO.__dict__.__contains__",  ["__le__"], false]
    - ["io1726008", "io.BytesIO.__dict__.__contains__",  ["__gt__"], false]
    - ["io1726009", "io.BytesIO.__dict__.__contains__",  ["__ge__"], false]
    - ["io1726010", "io.BytesIO.__dict__.__contains__",  ["__ne__"], false]
    - ["io1726011", "io.StringIO.__dict__.__contains__", ["__lt__"], false]
    - ["io1726012", "io.StringIO.__dict__.__contains__", ["__le__"], false]
    - ["io1726013", "io.StringIO.__dict__.__contains__", ["__gt__"], false]
    - ["io1726014", "io.StringIO.__dict__.__contains__", ["__ge__"], false]
    - ["io1726015", "io.StringIO.__dict__.__contains__", ["__ne__"], false]
    - ["io1726016", "io.FileIO.__dict__.__contains__",   ["__lt__"], false]
    - ["io1726017", "io.FileIO.__dict__.__contains__",   ["__le__"], false]
    - ["io1726018", "io.FileIO.__dict__.__contains__",   ["__gt__"], false]
    - ["io1726019", "io.FileIO.__dict__.__contains__",   ["__ge__"], false]
    - ["io1726020", "io.FileIO.__dict__.__contains__",   ["__ne__"], false]

table io_extra1726.eq_hash_protocol:
  description: "io types __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1726

  columns: [id, function, args, expected]
  rows:
    - ["io1726021", "io.IOBase.__dict__.__contains__",   ["__eq__"],   false]
    - ["io1726022", "io.IOBase.__dict__.__contains__",   ["__hash__"], false]
    - ["io1726023", "io.BytesIO.__dict__.__contains__",  ["__eq__"],   false]
    - ["io1726024", "io.BytesIO.__dict__.__contains__",  ["__hash__"], false]
    - ["io1726025", "io.StringIO.__dict__.__contains__", ["__eq__"],   false]
