table is_word_character.isWordCharacter:
  kind: node_module_call_eq
  function: isWordCharacter
  category: predicate
  id_prefix: iswc

  columns: [id, args, expected]
  rows:
    - [letter,    ["a"],  true]
    - [digit,     ["1"],  true]
    - [underscore,["_"],  true]
    - [space,     [" "],  false]
    - [symbol,    ["!"],  false]

