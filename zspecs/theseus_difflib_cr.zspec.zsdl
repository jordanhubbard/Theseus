spec: theseus_difflib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_difflib_cr)
blocks: difflib

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/difflib.html"
  not_derived_from:
    - "CPython source: Lib/difflib.py (internal implementation)"
  notes:
    - "Clean-room difflib module. Do NOT import difflib."
    - "SequenceMatcher(a, b): compute similarity between two sequences."
    - "ratio(): return similarity ratio [0, 1]."
    - "get_matching_blocks(): return list of matching triples (i, j, n)."
    - "unified_diff(a, b): generate unified diff lines."
    - "get_close_matches(word, possibilities): return best matches."

error_model: python_exceptions

invariant theseus_difflib_cr.difflib2_ratio:
  description: "SequenceMatcher('abc','abc').ratio() == 1.0"
  category: SequenceMatcher
  kind: python_call_eq
  function: difflib2_ratio
  args: []
  expected: 1.0

invariant theseus_difflib_cr.difflib2_close_matches:
  description: "get_close_matches('appel', ['ape','apple','peach']) returns ['apple']"
  category: get_close_matches
  kind: python_call_eq
  function: difflib2_close_matches
  args: []
  expected: true

invariant theseus_difflib_cr.difflib2_unified_diff:
  description: "unified_diff on changed lines yields diff output"
  category: unified_diff
  kind: python_call_eq
  function: difflib2_unified_diff
  args: []
  expected: true
