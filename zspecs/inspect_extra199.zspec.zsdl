spec: inspect_extra199
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect module-level attributes — __name__, __package__, __spec__.name, __file__.__class__.__name__, and __name__.__len__() for isfunction, isclass, getmembers, signature."
    - "inspect.__name__ == 'inspect' — the module's __name__ attribute is its fully-qualified import name. Verified with Python 3.14.3."
    - "inspect.__package__ == '' — inspect is a top-level module with no package prefix; __package__ is the empty string. Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' — the ModuleSpec object's .name attribute equals the module name. Verified with Python 3.14.3."
    - "inspect.__file__.__class__.__name__ == 'str' — __file__ is a plain Python string path to inspect.py; its __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters. Verified with Python 3.14.3."
    - "inspect.isclass.__name__.__len__() == 7 — 'isclass' has 7 characters. Verified with Python 3.14.3."
    - "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters. Verified with Python 3.14.3."
    - "inspect.signature.__name__.__len__() == 9 — 'signature' has 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module identity — __name__, __package__, __spec__.name
#
# inspect.__name__.__eq__('inspect') == True
# inspect.__package__.__eq__('') == True
# inspect.__spec__.name.__eq__('inspect') == True
#
# inspect is a top-level stdlib module; __package__ is the empty string
# and __spec__.name matches __name__. New to extra199.
# ---------------------------------------------------------------------------

table inspect_extra199.module_identity:
  description: "inspect module __name__, __package__, __spec__.name; top-level stdlib module; __package__ is empty string; __spec__.name matches __name__; new to extra199"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule199

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_inspect,
       __name__.__eq__,
       ["inspect"],
       true,
       "inspect.__name__.__eq__('inspect') == True — the module's __name__ attribute is its fully-qualified import name 'inspect'; str.__eq__('inspect') returns True; new to extra199"]
    - [module_package_eq_empty,
       __package__.__eq__,
       [""],
       true,
       "inspect.__package__.__eq__('') == True — inspect is a top-level module with no package prefix; __package__ is the empty string; str.__eq__('') returns True; new to extra199"]
    - [module_spec_name_eq_inspect,
       __spec__.name.__eq__,
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — __spec__ is a ModuleSpec object; its .name attribute equals the module name 'inspect'; str.__eq__('inspect') returns True; new to extra199"]

# ---------------------------------------------------------------------------
# Table 2: inspect module __file__ class and isfunction/isclass name lengths
#
# inspect.__file__.__class__.__name__.__eq__('str') == True
# inspect.isfunction.__name__.__len__() == 10
# inspect.isclass.__name__.__len__() == 7
#
# __file__ is a plain str path; isfunction.__name__ is 'isfunction' (10 chars);
# isclass.__name__ is 'isclass' (7 chars). New to extra199.
# ---------------------------------------------------------------------------

table inspect_extra199.file_class_and_isfunction_isclass_lens:
  description: "inspect __file__.__class__.__name__=='str'; isfunction.__name__.__len__()==10; isclass.__name__.__len__()==7; new to extra199"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmodule199

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_name_eq_str,
       __file__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__file__.__class__.__name__.__eq__('str') == True — __file__ is a plain Python string path to inspect.py; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra199"]
    - [isfunction_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — isfunction.__name__ is 'isfunction' which has 10 characters; str.__len__() returns 10; new to extra199"]
    - [isclass_name_len_7,
       isclass.__name__.__len__,
       [],
       7,
       "inspect.isclass.__name__.__len__() == 7 — isclass.__name__ is 'isclass' which has 7 characters; str.__len__() returns 7; new to extra199"]

# ---------------------------------------------------------------------------
# Table 3: inspect getmembers and signature name lengths
#
# inspect.getmembers.__name__.__len__() == 10
# inspect.signature.__name__.__len__() == 9
#
# getmembers is a utility function returning all members of an object;
# 'getmembers' has 10 chars. signature introspects callable signatures;
# 'signature' has 9 chars. New to extra199.
# ---------------------------------------------------------------------------

table inspect_extra199.getmembers_signature_name_lens:
  description: "inspect getmembers.__name__.__len__()==10; signature.__name__.__len__()==9; new to extra199"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmodule199

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_len_10,
       getmembers.__name__.__len__,
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — getmembers.__name__ is 'getmembers' which has 10 characters; str.__len__() returns 10; new to extra199"]
    - [signature_name_len_9,
       signature.__name__.__len__,
       [],
       9,
       "inspect.signature.__name__.__len__() == 9 — signature.__name__ is 'signature' which has 9 characters; str.__len__() returns 9; new to extra199"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra199
# ---------------------------------------------------------------------------

invariant inspect_extra199.module_name:
  description: "inspect.__name__ == 'inspect' — top-level stdlib module name; new to extra199"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra199.module_package:
  description: "inspect.__package__ == '' — top-level module; __package__ is empty string; new to extra199"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant inspect_extra199.module_spec_name:
  description: "inspect.__spec__.name == 'inspect' — ModuleSpec.name matches module __name__; new to extra199"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra199.file_class_name:
  description: "inspect.__file__.__class__.__name__ == 'str' — __file__ is a plain Python string path; new to extra199"
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra199.isfunction_name_len:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra199"
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra199.isclass_name_len:
  description: "inspect.isclass.__name__.__len__() == 7 — 'isclass' has 7 characters; new to extra199"
  kind: python_call_eq
  function: isclass.__name__.__len__
  args: []
  expected: 7

invariant inspect_extra199.getmembers_name_len:
  description: "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters; new to extra199"
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra199.signature_name_len:
  description: "inspect.signature.__name__.__len__() == 9 — 'signature' has 9 characters; new to extra199"
  kind: python_call_eq
  function: signature.__name__.__len__
  args: []
  expected: 9

