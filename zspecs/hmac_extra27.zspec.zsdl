spec: hmac_extra27
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra26.zspec.zsdl — covers HMAC method __module__ (update/digest/hexdigest/copy); HMAC.__init__.__qualname__/__module__; HMAC.__name__.__eq__; HMAC.blocksize value."
    - "hmac_extra25.zspec.zsdl — covers HMAC.digest_size/block_size __class__.__name__ at class level; HMAC method qualnames re-anchored from extra25."
    - "hmac_extra24.zspec.zsdl — covers HMAC.update/digest/hexdigest/copy __qualname__.__eq__ and __qualname__.__len__."
    - "hmac_extra23.zspec.zsdl — covers new/digest/compare_digest __qualname__.__len__; HMAC.__module__.__eq__."
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__; HMAC.__qualname__.__len__==4; HMAC.__name__.__len__==4."
    - "hmac_extra19.zspec.zsdl — covers new/__qualname__.__eq__ and digest/__qualname__.__eq__ standalone from extra19."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
    - "hmac_extra14.zspec.zsdl — covers new/digest/compare_digest __qualname__.__eq__; HMAC.__qualname__.__eq__."
  notes:
    - "This spec extends hmac through hmac_extra26; it does NOT duplicate invariants present in those files."
    - "Focus: hmac.HMAC.__qualname__ re-anchored from extra27 namespace (extra17 covers from extra17, extra14 covers from extra14 — cross-namespace anchor for extra27); hmac.HMAC.__bases__[0].__name__ re-anchored from extra27 (extra17 covers this from extra17 namespace); compare_digest.__qualname__/__module__ re-anchored from extra27 (extra14 covers __qualname__, extra17 covers __module__, no prior spec uses extra27 namespace); hmac.digest.__module__ re-anchored from extra27 (extra17 covers from extra17); HMAC.update/__qualname__ and HMAC.hexdigest/__qualname__ re-anchored from extra27 (extra24/25 cover from those namespaces)."
    - "hmac.HMAC.__qualname__ == 'HMAC': covered by extra14 and extra17 in their namespaces. Re-anchored from extra27 for independent regression coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__bases__[0].__name__ == 'object': covered by extra17 (using method/method_args pattern). Re-anchored from extra27 namespace. HMAC directly subclasses object (no intermediate mixin). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__qualname__ == 'compare_digest': covered by extra14 from extra14 namespace. Re-anchored from extra27. On CPython 3.12 compare_digest is in _hashlib C extension. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__module__ == '_hashlib': covered by extra17 from extra17 namespace. Re-anchored from extra27. Novel namespace anchor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__module__ == 'hmac': covered by extra17 from extra17 namespace. Re-anchored from extra27 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update.__qualname__ == 'HMAC.update' and hmac.HMAC.hexdigest.__qualname__ == 'HMAC.hexdigest': covered by extra24/25. Re-anchored from extra27 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC class identity — __qualname__ and __bases__[0].__name__ re-anchored
# from extra27 namespace
#
# hmac_extra14 covers HMAC.__qualname__.__eq__('HMAC') from extra14.
# hmac_extra17 covers both HMAC.__qualname__ and HMAC.__bases__[0].__name__
# from extra17. These invariants anchor the same properties from extra27
# for independent regression coverage.
# HMAC directly subclasses object: __bases__ == (<class 'object'>,).
# ---------------------------------------------------------------------------

invariant hmac_extra27.HMAC.qualname:
  description: "hmac.HMAC.__qualname__ == 'HMAC' — class qualname, re-anchored from extra27 namespace"
  category: class_identity
  kind: python_call_eq
  function: "HMAC.__qualname__.__eq__"
  args: ["HMAC"]
  expected: true

invariant hmac_extra27.HMAC.base_class_name:
  description: "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC directly subclasses object, anchored from extra27"
  category: type_metadata
  kind: python_call_eq
  function: "HMAC.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# compare_digest.__qualname__ and __module__ — re-anchored from extra27
#
# hmac_extra14 covers compare_digest.__qualname__.__eq__ from extra14.
# hmac_extra17 covers compare_digest.__module__ from extra17.
# On CPython 3.12, compare_digest is in the _hashlib C extension, so its
# __module__ == '_hashlib'. These invariants anchor both properties from
# the extra27 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra27.compare_digest.qualname:
  description: "hmac.compare_digest.__qualname__ == 'compare_digest' — module-level function qualname, anchored from extra27"
  category: function_qualnames
  kind: python_call_eq
  function: compare_digest.__qualname__.__eq__
  args: ["compare_digest"]
  expected: true

invariant hmac_extra27.compare_digest.module:
  description: "hmac.compare_digest.__module__ == '_hashlib' — C extension implementation, anchored from extra27"
  category: module_metadata
  kind: python_call_eq
  function: compare_digest.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.digest.__module__ — re-anchored from extra27 namespace
#
# hmac_extra17 covers digest.__module__ from extra17 namespace.
# hmac_extra26 covers HMAC method __module__ (instance methods: update/
# digest/hexdigest/copy) but NOT the module-level hmac.digest function.
# This invariant anchors hmac.digest.__module__ from the extra27 namespace.
# hmac.digest is a module-level function defined in hmac.py: __module__ == 'hmac'.
# ---------------------------------------------------------------------------

invariant hmac_extra27.digest.module:
  description: "hmac.digest.__module__ == 'hmac' — module-level digest function defined in hmac, anchored from extra27"
  category: module_metadata
  kind: python_call_eq
  function: digest.__module__.__eq__
  args: ["hmac"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC.update and HMAC.hexdigest __qualname__ — re-anchored from extra27
#
# hmac_extra24 covers all four HMAC method qualnames (__eq__ and __len__).
# hmac_extra25 re-anchors the same qualnames from extra25 namespace.
# hmac_extra26 covers the method __module__ values (not __qualname__).
# These two invariants anchor HMAC.update and HMAC.hexdigest __qualname__
# from the extra27 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

table hmac_extra27.HMAC_method_qualnames_anchor:
  description: "HMAC.update and HMAC.hexdigest __qualname__ — anchored from extra27 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hmacmq27

  columns: [id, function, args, expected]
  rows:
    - [update,    "HMAC.update.__qualname__.__eq__",    ["HMAC.update"],    true]
    - [hexdigest, "HMAC.hexdigest.__qualname__.__eq__", ["HMAC.hexdigest"], true]
