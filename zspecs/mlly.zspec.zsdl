spec: mlly
version: ">=1.0.0"
backend: node(mlly)

docs: https://github.com/unjs/mlly#readme

provenance:
  derived_from:
    - "mlly README — https://github.com/unjs/mlly#readme"
    - "Test vectors verified with mlly via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "mlly source"
  notes:
    - "Module utilities for ESM/CJS detection and resolution — used by Vite/Vitest internals."
    - "Install: npm install mlly"
    - "v1 CJS-importable; named exports include detectSyntax / hasESMSyntax / hasCJSSyntax / fileURLToPath / pathToFileURL."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Syntax functions never throw on string input; resolution helpers throw on missing modules."
  stderr: "null"
  stickiness: "N/A — pure string analysis."
  codes: {}

invariant mlly.detectSyntax_esm_hasESM_true:
  description: "detectSyntax('import x from \"y\"').hasESM is true"
  category: detectSyntax
  kind: node_chain_eq
  entry: named
  function: detectSyntax
  entry_args: ["import x from \"y\""]
  chain:
    - {get: hasESM}
  expected: true

invariant mlly.detectSyntax_esm_hasCJS_false:
  description: "detectSyntax of pure ESM has hasCJS false"
  category: detectSyntax
  kind: node_chain_eq
  entry: named
  function: detectSyntax
  entry_args: ["import x from \"y\""]
  chain:
    - {get: hasCJS}
  expected: false

invariant mlly.detectSyntax_cjs_hasCJS_true:
  description: "detectSyntax of pure CJS has hasCJS true"
  category: detectSyntax
  kind: node_chain_eq
  entry: named
  function: detectSyntax
  entry_args: ["const x = require(\"y\")"]
  chain:
    - {get: hasCJS}
  expected: true

invariant mlly.detectSyntax_cjs_hasESM_false:
  description: "detectSyntax of pure CJS has hasESM false"
  category: detectSyntax
  kind: node_chain_eq
  entry: named
  function: detectSyntax
  entry_args: ["const x = require(\"y\")"]
  chain:
    - {get: hasESM}
  expected: false

invariant mlly.hasESMSyntax_import_true:
  description: "hasESMSyntax detects 'import' statement"
  category: hasESMSyntax
  kind: node_chain_eq
  entry: named
  function: hasESMSyntax
  entry_args: ["import x from \"y\""]
  chain: []
  expected: true

invariant mlly.hasESMSyntax_plain_false:
  description: "hasESMSyntax on plain assignment is false"
  category: hasESMSyntax
  kind: node_chain_eq
  entry: named
  function: hasESMSyntax
  entry_args: ["const x = 1"]
  chain: []
  expected: false

invariant mlly.hasCJSSyntax_require_true:
  description: "hasCJSSyntax detects 'require' call"
  category: hasCJSSyntax
  kind: node_chain_eq
  entry: named
  function: hasCJSSyntax
  entry_args: ["const x = require(\"y\")"]
  chain: []
  expected: true

invariant mlly.detectSyntax_mixed_isMixed:
  description: "detectSyntax on file with both ESM and CJS sets isMixed true"
  category: detectSyntax
  kind: node_chain_eq
  entry: named
  function: detectSyntax
  entry_args: ["import x from \"y\"; module.exports = 1;"]
  chain:
    - {get: isMixed}
  expected: true

invariant mlly.detectSyntax_pure_esm_isMixed_false:
  description: "Pure ESM is not mixed"
  category: detectSyntax
  kind: node_chain_eq
  entry: named
  function: detectSyntax
  entry_args: ["import x from \"y\""]
  chain:
    - {get: isMixed}
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:25:14Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
