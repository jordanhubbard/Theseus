spec: hashlib_extra220
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "verified with Python 3.14.3."
    - "'sha224' in hashlib.algorithms_guaranteed == True; 'sha384' in hashlib.algorithms_guaranteed == True."
    - "'sha3_224' in hashlib.algorithms_guaranteed == True; 'shake_128' in hashlib.algorithms_guaranteed == True."
    - "hashlib.md5.__name__ == 'openssl_md5'; hashlib.sha256.__name__ == 'openssl_sha256'; hashlib.sha512.__name__ == 'openssl_sha512'."
    - "hashlib.md5.__module__ == '_hashlib'; hashlib.sha256.__module__ == '_hashlib'; hashlib.sha512.__module__ == '_hashlib'."
    - "hashlib.md5().digest_size == 16; hashlib.md5().block_size == 64; hashlib.md5().name == 'md5'."
    - "hashlib.sha1().digest_size == 20; hashlib.sha1().block_size == 64; hashlib.sha1().name == 'sha1'."
    - "hashlib.sha512().digest_size == 64; hashlib.sha512().block_size == 128; hashlib.sha512().name == 'sha512'."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# algorithms_guaranteed — SHA-224, SHA-384, SHA3-224, SHAKE-128 membership
#
# 'sha224'   in hashlib.algorithms_guaranteed == True
# 'sha384'   in hashlib.algorithms_guaranteed == True
# 'sha3_224' in hashlib.algorithms_guaranteed == True
# 'shake_128' in hashlib.algorithms_guaranteed == True
# ---------------------------------------------------------------------------

table hashlib_extra220.algorithms_guaranteed_extra:
  description: "hashlib.algorithms_guaranteed extended membership checks in hashlib220 namespace — wave 220 theme: sha224, sha384, sha3_224, shake_128 are all present in algorithms_guaranteed on conforming Python builds; sha224 and sha384 are FIPS 180-4 truncated SHA-2 variants; sha3_224 is a FIPS 202 SHA-3 variant; shake_128 is a FIPS 202 extendable-output function; verified with Python 3.14.3"
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlib220

  columns: [id, function, args, expected, description]
  rows:
    - [sha224_in_guaranteed,   "hashlib.algorithms_guaranteed.__contains__",  ["sha224"],   true,  "'sha224' in hashlib.algorithms_guaranteed — FIPS 180-4 SHA-224 must be present"]
    - [sha384_in_guaranteed,   "hashlib.algorithms_guaranteed.__contains__",  ["sha384"],   true,  "'sha384' in hashlib.algorithms_guaranteed — FIPS 180-4 SHA-384 must be present"]
    - [sha3_224_in_guaranteed, "hashlib.algorithms_guaranteed.__contains__",  ["sha3_224"], true,  "'sha3_224' in hashlib.algorithms_guaranteed — FIPS 202 SHA3-224 must be present"]
    - [shake_128_in_guaranteed,"hashlib.algorithms_guaranteed.__contains__",  ["shake_128"],true,  "'shake_128' in hashlib.algorithms_guaranteed — FIPS 202 SHAKE-128 must be present"]

# ---------------------------------------------------------------------------
# hashlib module function __name__ and __module__ checks
#
# hashlib.md5.__name__      == 'openssl_md5'
# hashlib.sha256.__name__   == 'openssl_sha256'
# hashlib.sha512.__name__   == 'openssl_sha512'
# hashlib.md5.__module__    == '_hashlib'
# hashlib.sha256.__module__ == '_hashlib'
# ---------------------------------------------------------------------------

table hashlib_extra220.hash_function_identity:
  description: "hashlib hash constructor function __name__ and __module__ checks in hashlib220a namespace — wave 220 theme: md5.__name__ == 'openssl_md5'; sha256.__name__ == 'openssl_sha256'; sha512.__name__ == 'openssl_sha512'; all three are bound to OpenSSL-backed constructors in the _hashlib C extension module; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib220a

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name,       "hashlib.md5.__name__.__eq__",       ["openssl_md5"],    true,  "hashlib.md5.__name__ == 'openssl_md5' — md5 is bound to the OpenSSL-backed constructor"]
    - [sha256_name,    "hashlib.sha256.__name__.__eq__",    ["openssl_sha256"], true,  "hashlib.sha256.__name__ == 'openssl_sha256' — sha256 is bound to the OpenSSL-backed constructor"]
    - [sha512_name,    "hashlib.sha512.__name__.__eq__",    ["openssl_sha512"], true,  "hashlib.sha512.__name__ == 'openssl_sha512' — sha512 is bound to the OpenSSL-backed constructor"]
    - [md5_module,     "hashlib.md5.__module__.__eq__",     ["_hashlib"],       true,  "hashlib.md5.__module__ == '_hashlib' — md5 constructor is implemented in the _hashlib C extension"]
    - [sha256_module,  "hashlib.sha256.__module__.__eq__",  ["_hashlib"],       true,  "hashlib.sha256.__module__ == '_hashlib' — sha256 constructor is implemented in the _hashlib C extension"]

# ---------------------------------------------------------------------------
# Hash object .name, .digest_size, .block_size attributes
#
# hashlib.md5().name        == 'md5'
# hashlib.md5().digest_size == 16
# hashlib.md5().block_size  == 64
# hashlib.sha1().digest_size == 20
# hashlib.sha1().block_size  == 64
# hashlib.sha512().digest_size == 64
# hashlib.sha512().block_size  == 128
# ---------------------------------------------------------------------------

table hashlib_extra220.hash_object_attributes:
  description: "hashlib hash object .name, .digest_size, and .block_size attribute checks in hashlib220b namespace — wave 220 theme: md5 digest_size=16 block_size=64; sha1 digest_size=20 block_size=64; sha512 digest_size=64 block_size=128; these are stable cryptographic properties defined by FIPS 180-4; verified with Python 3.14.3"
  kind: python_call_eq
  category: attributes
  id_prefix: hashlib220b

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_attr,        "hashlib.md5().name.__eq__",         ["md5"],  true,  "hashlib.md5().name == 'md5' — the .name attribute is the canonical algorithm name accepted by hashlib.new()"]
    - [md5_digest_size,      "hashlib.md5().digest_size.__eq__",  [16],     true,  "hashlib.md5().digest_size == 16 — MD5 produces 128-bit (16-byte) digests"]
    - [md5_block_size,       "hashlib.md5().block_size.__eq__",   [64],     true,  "hashlib.md5().block_size == 64 — MD5 operates on 512-bit (64-byte) blocks"]
    - [sha1_digest_size,     "hashlib.sha1().digest_size.__eq__", [20],     true,  "hashlib.sha1().digest_size == 20 — SHA-1 produces 160-bit (20-byte) digests per FIPS 180-4"]
    - [sha512_digest_size,   "hashlib.sha512().digest_size.__eq__",[64],    true,  "hashlib.sha512().digest_size == 64 — SHA-512 produces 512-bit (64-byte) digests per FIPS 180-4"]
    - [sha512_block_size,    "hashlib.sha512().block_size.__eq__", [128],   true,  "hashlib.sha512().block_size == 128 — SHA-512 operates on 1024-bit (128-byte) blocks per FIPS 180-4"]

# ---------------------------------------------------------------------------
# Hash object .name attribute for sha1 and sha512
# ---------------------------------------------------------------------------

invariant hashlib_extra220.sha1_name_attr:
  description: "hashlib.sha1().name == 'sha1' — the .name attribute of a SHA-1 hash object is the canonical algorithm name string 'sha1'; this is the same name accepted by hashlib.new(); verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "hashlib.sha1().name.__eq__"
  args: ["sha1"]
  expected: true

invariant hashlib_extra220.sha512_name_attr:
  description: "hashlib.sha512().name == 'sha512' — the .name attribute of a SHA-512 hash object is the canonical algorithm name string 'sha512'; this is the same name accepted by hashlib.new(); verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "hashlib.sha512().name.__eq__"
  args: ["sha512"]
  expected: true

invariant hashlib_extra220.sha512_module:
  description: "hashlib.sha512.__module__ == '_hashlib' — the sha512 constructor is implemented in the _hashlib C extension module on CPython/OpenSSL builds; the __module__ attribute reflects the implementation module; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "hashlib.sha512.__module__.__eq__"
  args: ["_hashlib"]
  expected: true
