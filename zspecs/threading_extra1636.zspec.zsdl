spec: threading_extra1636
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __subclasshook__/__instancecheck__/__subclasscheck__"
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Barrier, and Timer are pure Python classes using the default 'type' metaclass — NOT ABCMeta"
    - "None of the threading classes define __subclasshook__, __instancecheck__, or __subclasscheck__ in their own __dict__"
    - "threading.RLock is a C extension type (_thread.RLock) and does not define any ABC virtual subclassing hooks"
    - "threading.local is _thread._local, a C extension type; no virtual subclassing hooks"
    - "isinstance(threading.Thread(target=lambda: None), threading.Thread) is True via standard type.__instancecheck__"
    - "issubclass(threading.Timer, threading.Thread) is True — Timer inherits directly from Thread; MRO is [Timer, Thread, object]"
    - "issubclass(threading.BoundedSemaphore, threading.Semaphore) is True — BoundedSemaphore is a subclass of Semaphore"
    - "isinstance(threading.Thread(target=lambda: None), collections.abc.Callable) is False — Thread does not define __call__, and collections.abc.Callable.__subclasshook__ checks for __call__"
    - "threading.Thread.__dict__ does not contain __subclasshook__; it does contain __weakref__ and standard thread lifecycle methods"
    - "threading.Event.__dict__ does not contain __subclasshook__ but does contain set/clear/wait/is_set"
    - "threading.Condition.__dict__ does not contain __subclasshook__ but does contain wait/notify/notify_all/__enter__/__exit__"
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra1636.thread_no_virtual_subclassing:
  description: "threading classes (Thread, Event, Condition, Semaphore, Barrier, BoundedSemaphore, Timer) do not define __subclasshook__, __instancecheck__, or __subclasscheck__; they use the default type metaclass"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1636nv

  columns: [id, function, args, expected]
  rows:
    - ["th1636nv001", "threading.Thread.__dict__.__contains__",          ["__subclasshook__"],   false]
    - ["th1636nv002", "threading.Thread.__dict__.__contains__",          ["__instancecheck__"],  false]
    - ["th1636nv003", "threading.Thread.__dict__.__contains__",          ["__subclasscheck__"],  false]
    - ["th1636nv004", "threading.Event.__dict__.__contains__",           ["__subclasshook__"],   false]
    - ["th1636nv005", "threading.Event.__dict__.__contains__",           ["__instancecheck__"],  false]
    - ["th1636nv006", "threading.Event.__dict__.__contains__",           ["__subclasscheck__"],  false]
    - ["th1636nv007", "threading.Condition.__dict__.__contains__",       ["__subclasshook__"],   false]
    - ["th1636nv008", "threading.Condition.__dict__.__contains__",       ["__instancecheck__"],  false]
    - ["th1636nv009", "threading.Condition.__dict__.__contains__",       ["__subclasscheck__"],  false]
    - ["th1636nv010", "threading.Semaphore.__dict__.__contains__",       ["__subclasshook__"],   false]
    - ["th1636nv011", "threading.Semaphore.__dict__.__contains__",       ["__instancecheck__"],  false]
    - ["th1636nv012", "threading.Semaphore.__dict__.__contains__",       ["__subclasscheck__"],  false]
    - ["th1636nv013", "threading.BoundedSemaphore.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["th1636nv014", "threading.Barrier.__dict__.__contains__",         ["__subclasshook__"],   false]
    - ["th1636nv015", "threading.Timer.__dict__.__contains__",           ["__subclasshook__"],   false]
    - ["th1636nv016", "threading.RLock.__dict__.__contains__",           ["__subclasshook__"],   false]
    - ["th1636nv017", "threading.local.__dict__.__contains__",           ["__subclasshook__"],   false]
    - ["th1636nv018", "threading.Thread.__dict__.__contains__",          ["__abstractmethods__"], false]
    - ["th1636nv019", "threading.Event.__dict__.__contains__",           ["__abstractmethods__"], false]
    - ["th1636nv020", "threading.Condition.__dict__.__contains__",       ["__abstractmethods__"], false]
    - ["th1636nv021", "threading.Thread.__class__.__name__.__eq__",          ["type"],    true]
    - ["th1636nv022", "threading.Event.__class__.__name__.__eq__",           ["type"],    true]
    - ["th1636nv023", "threading.Condition.__class__.__name__.__eq__",       ["type"],    true]
    - ["th1636nv024", "threading.Semaphore.__class__.__name__.__eq__",       ["type"],    true]
    - ["th1636nv025", "threading.BoundedSemaphore.__class__.__name__.__eq__", ["type"],   true]
    - ["th1636nv026", "threading.Thread.__class__.__name__.__eq__",          ["ABCMeta"], false]
    - ["th1636nv027", "threading.Event.__class__.__name__.__eq__",           ["ABCMeta"], false]
    - ["th1636nv028", "threading.Condition.__class__.__name__.__eq__",       ["ABCMeta"], false]
    - ["th1636nv029", "threading.Thread.__name__.__eq__",    ["Thread"],    true]
    - ["th1636nv030", "threading.Thread.__module__.__eq__",  ["threading"], true]

table threading_extra1636.threading_isinstance_checks:
  description: "isinstance/issubclass behaviors for threading objects; standard type.__instancecheck__ is used (no ABCMeta hooks); checks threading.Thread is NOT a collections.abc.Callable because Thread lacks __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1636ic

  columns: [id, function, args, expected]
  rows:
    - ["th1636ic001", "threading.Thread.__dict__.__contains__",          ["__call__"],     false]
    - ["th1636ic002", "threading.Event.__dict__.__contains__",           ["__call__"],     false]
    - ["th1636ic003", "threading.Condition.__dict__.__contains__",       ["__call__"],     false]
    - ["th1636ic004", "threading.Semaphore.__dict__.__contains__",       ["__call__"],     false]
    - ["th1636ic005", "threading.Barrier.__dict__.__contains__",         ["__call__"],     false]
    - ["th1636ic006", "threading.Timer.__dict__.__contains__",           ["__call__"],     false]
    - ["th1636ic007", "threading.Thread.__dict__.__contains__",          ["__iter__"],     false]
    - ["th1636ic008", "threading.Thread.__dict__.__contains__",          ["__next__"],     false]
    - ["th1636ic009", "threading.Thread.__dict__.__contains__",          ["start"],        true]
    - ["th1636ic010", "threading.Thread.__dict__.__contains__",          ["run"],          true]
    - ["th1636ic011", "threading.Thread.__dict__.__contains__",          ["join"],         true]
    - ["th1636ic012", "threading.Thread.__dict__.__contains__",          ["is_alive"],     true]
    - ["th1636ic013", "threading.Event.__dict__.__contains__",           ["set"],          true]
    - ["th1636ic014", "threading.Event.__dict__.__contains__",           ["clear"],        true]
    - ["th1636ic015", "threading.Event.__dict__.__contains__",           ["wait"],         true]
    - ["th1636ic016", "threading.Event.__dict__.__contains__",           ["is_set"],       true]
    - ["th1636ic017", "threading.Condition.__dict__.__contains__",       ["wait"],         true]
    - ["th1636ic018", "threading.Condition.__dict__.__contains__",       ["notify"],       true]
    - ["th1636ic019", "threading.Condition.__dict__.__contains__",       ["notify_all"],   true]
    - ["th1636ic020", "threading.Condition.__dict__.__contains__",       ["__enter__"],    true]
    - ["th1636ic021", "threading.Condition.__dict__.__contains__",       ["__exit__"],     true]
    - ["th1636ic022", "threading.Semaphore.__dict__.__contains__",       ["acquire"],      true]
    - ["th1636ic023", "threading.Semaphore.__dict__.__contains__",       ["release"],      true]
    - ["th1636ic024", "threading.Barrier.__dict__.__contains__",         ["wait"],         true]
    - ["th1636ic025", "threading.Barrier.__dict__.__contains__",         ["reset"],        true]
    - ["th1636ic026", "threading.Barrier.__dict__.__contains__",         ["abort"],        true]
    - ["th1636ic027", "threading.Timer.__dict__.__contains__",           ["cancel"],       true]
    - ["th1636ic028", "threading.Timer.__dict__.__contains__",           ["run"],          true]
    - ["th1636ic029", "threading.Thread.__dict__.__class__.__name__.__eq__",    ["mappingproxy"], true]
    - ["th1636ic030", "threading.Condition.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]

