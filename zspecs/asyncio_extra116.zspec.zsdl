spec: asyncio_extra116
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra115.zspec.zsdl."
    - "This spec covers: wave 256 theme — asyncio module-level coroutine function co_varnames lengths and co_qualname checks not covered in extra65-extra115. Prior specs covered: sleep co_varnames.__class__.__name__=='tuple' (extra65), sleep co_varnames[0]=='delay' (extra65), gather co_varnames.__class__.__name__=='tuple' (extra65). NOT previously covered: sleep/gather/wait/ensure_future co_varnames.__len__() values. NEW in extra116: sleep.__code__.co_varnames.__len__()==5 ('delay','result','loop','future','h'); gather.__code__.co_varnames.__len__()==9 (9 locals including return_exceptions and loop variables); wait.__code__.co_varnames.__len__()==4 ('fs','timeout','return_when','loop'); ensure_future.__code__.co_varnames.__len__()==4; sleep.__code__.co_qualname=='sleep' (len=5); gather.__code__.co_qualname=='gather' (len=6); wait.__code__.co_qualname=='wait' (len=4); ensure_future.__code__.co_qualname=='ensure_future' (len=13). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.sleep.__code__.co_varnames == ('delay', 'result', 'loop', 'future', 'h') — 5 locals: 2 parameters (delay, result) plus 3 local vars (loop, future, h). co_argcount==2 (delay and result; result has a default but is positional). co_qualname=='sleep' (module-level coroutine). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.gather.__code__.co_varnames.__len__()==9 — gather takes *coros_or_futures plus return_exceptions keyword; 9 locals: 'return_exceptions','coros_or_futures','loop','cur_task','_done_callback','arg_to_fut','done_futs','arg','fut'. co_argcount==0 (all args are variadic or keyword-only). co_qualname=='gather'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.wait.__code__.co_varnames.__len__()==4 ('fs','timeout','return_when','loop'). co_argcount==1 (fs is the only positional; timeout and return_when are keyword-only). co_qualname=='wait'. asyncio.ensure_future.__code__.co_varnames.__len__()==4. co_argcount==1. co_qualname=='ensure_future' (len=13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio coroutine function co_varnames lengths — extra116
#
# Wave 256 theme: sleep, gather, wait, ensure_future co_varnames __len__().
#
# asyncio.sleep.__code__.co_varnames.__len__()          == 5  ('delay','result','loop','future','h')
# asyncio.gather.__code__.co_varnames.__len__()         == 9  (most locals of any function in spec)
# asyncio.wait.__code__.co_varnames.__len__()           == 4  ('fs','timeout','return_when','loop')
# asyncio.ensure_future.__code__.co_varnames.__len__()  == 4  (tied with wait)
# ---------------------------------------------------------------------------

table asyncio_extra116.asyncio_coroutine_co_varnames_len:
  description: "asyncio coroutine function co_varnames length checks in asynciocoro116 namespace — wave 256 theme: asyncio.sleep.__code__.co_varnames.__len__()==5 ('delay','result','loop','future','h': 2 params plus 3 locals; sleep is defined as 'async def sleep(delay, result=None)' so co_argcount=2 and 3 extra locals); asyncio.sleep.__code__.co_varnames.__len__.__eq__ is tested indirectly via table length check; asyncio.gather.__code__.co_varnames.__len__()==9 (most locals in spec: 'return_exceptions','coros_or_futures','loop','cur_task','_done_callback','arg_to_fut','done_futs','arg','fut'; gather uses *coros_or_futures variadic so co_argcount==0 but co_varnames has 9 entries); asyncio.wait.__code__.co_varnames.__len__()==4 ('fs','timeout','return_when','loop'; co_argcount==1 because only fs is positional, timeout and return_when are keyword-only); asyncio.ensure_future.__code__.co_varnames.__len__()==4 (tied with wait; 'coro_or_future' is parameter plus 3 locals); compare co_varnames lengths: wait==ensure_future==4 (tied, fewest) < sleep==5 < gather==9 (most); compare co_argcount: gather==0 < wait==ensure_future==1 < sleep==2; note: gather has the most co_varnames despite co_argcount==0 because it contains many loop-scope locals; all coroutines are in asyncio.tasks module (asyncio.sleep.__module__=='asyncio.tasks', len=13); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: asynciocoro116

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_var_len,   sleep.__code__.co_varnames.__len__,          [], 5, "sleep.__code__.co_varnames.__len__() == 5 ('delay','result','loop','future','h'); verified with Python 3.14.3"]
    - [gather_var_len,  gather.__code__.co_varnames.__len__,         [], 9, "gather.__code__.co_varnames.__len__() == 9 (most locals in spec: return_exceptions + 8 loop vars); verified with Python 3.14.3"]
    - [wait_var_len,    wait.__code__.co_varnames.__len__,           [], 4, "wait.__code__.co_varnames.__len__() == 4 ('fs','timeout','return_when','loop'); verified with Python 3.14.3"]
    - [ef_var_len,      ensure_future.__code__.co_varnames.__len__,  [], 4, "ensure_future.__code__.co_varnames.__len__() == 4 (tied with wait, fewest in spec); verified with Python 3.14.3"]
    - [sleep_argc,      sleep.__code__.co_argcount.__eq__,           [2], true, "sleep.__code__.co_argcount == 2 (delay and result); verified with Python 3.14.3"]
    - [gather_argc,     gather.__code__.co_argcount.__eq__,          [0], true, "gather.__code__.co_argcount == 0 (all args are variadic or keyword-only); verified with Python 3.14.3"]
    - [wait_argc,       wait.__code__.co_argcount.__eq__,            [1], true, "wait.__code__.co_argcount == 1 (fs only; timeout and return_when are keyword-only); verified with Python 3.14.3"]
    - [ef_argc,         ensure_future.__code__.co_argcount.__eq__,   [1], true, "ensure_future.__code__.co_argcount == 1; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio coroutine function co_qualname checks — extra116
#
# Wave 256 theme: sleep, gather, wait, ensure_future co_qualname values.
#
# asyncio.sleep.__code__.co_qualname         == 'sleep'           (len=5, shortest)
# asyncio.wait.__code__.co_qualname          == 'wait'            (len=4, shortest)
# asyncio.gather.__code__.co_qualname        == 'gather'          (len=6)
# asyncio.ensure_future.__code__.co_qualname == 'ensure_future'   (len=13, longest)
# ---------------------------------------------------------------------------

table asyncio_extra116.asyncio_coroutine_co_qualname:
  description: "asyncio coroutine function co_qualname checks in asynciocoro116 namespace — wave 256 theme: for module-level async functions, co_qualname equals the function name (no class prefix); asyncio.sleep.__code__.co_qualname.__eq__('sleep')==True (len=5; co_qualname matches __name__ and __qualname__ for module-level functions; sleep is the shortest co_qualname in spec); asyncio.sleep.__code__.co_qualname.__len__()==5; asyncio.wait.__code__.co_qualname.__eq__('wait')==True (len=4; shortest co_qualname in spec); asyncio.wait.__code__.co_qualname.__len__()==4; asyncio.gather.__code__.co_qualname.__eq__('gather')==True (len=6); asyncio.gather.__code__.co_qualname.__len__()==6; asyncio.ensure_future.__code__.co_qualname.__eq__('ensure_future')==True (len=13; longest co_qualname in spec; co_qualname==__qualname__=='ensure_future'); asyncio.ensure_future.__code__.co_qualname.__len__()==13; compare co_qualname lengths: wait=4 (shortest) < sleep=5 < gather=6 < ensure_future=13 (longest); all four functions are in asyncio.tasks module (__module__=='asyncio.tasks', len=13); note coincidence: ensure_future.__code__.co_qualname.__len__()==13 == ensure_future.__module__.__len__()==13 ('asyncio.tasks'=13); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: asynciocoro116a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_coq_eq,   sleep.__code__.co_qualname.__eq__,          ["sleep"],          true, "sleep.__code__.co_qualname == 'sleep' (len=5, module-level co_qualname==name); verified with Python 3.14.3"]
    - [sleep_coq_len,  sleep.__code__.co_qualname.__len__,         [],                 5,    "sleep.__code__.co_qualname.__len__() == 5 ('sleep'=5); verified with Python 3.14.3"]
    - [wait_coq_eq,    wait.__code__.co_qualname.__eq__,           ["wait"],           true, "wait.__code__.co_qualname == 'wait' (len=4, shortest co_qualname in spec); verified with Python 3.14.3"]
    - [wait_coq_len,   wait.__code__.co_qualname.__len__,          [],                 4,    "wait.__code__.co_qualname.__len__() == 4 ('wait'=4, shortest); verified with Python 3.14.3"]
    - [gather_coq_eq,  gather.__code__.co_qualname.__eq__,         ["gather"],         true, "gather.__code__.co_qualname == 'gather' (len=6); verified with Python 3.14.3"]
    - [gather_coq_len, gather.__code__.co_qualname.__len__,        [],                 6,    "gather.__code__.co_qualname.__len__() == 6 ('gather'=6); verified with Python 3.14.3"]
    - [ef_coq_eq,      ensure_future.__code__.co_qualname.__eq__,  ["ensure_future"],  true, "ensure_future.__code__.co_qualname == 'ensure_future' (len=13, longest in spec); verified with Python 3.14.3"]
    - [ef_coq_len,     ensure_future.__code__.co_qualname.__len__, [],                 13,   "ensure_future.__code__.co_qualname.__len__() == 13 (longest co_qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio coroutine function module and name cross-checks — extra116
#
# Wave 256 theme: module identity and name-length cross-checks.
#
# asyncio.sleep.__module__          == 'asyncio.tasks'  (len=13)
# asyncio.gather.__module__         == 'asyncio.tasks'  (len=13)
# asyncio.wait.__module__           == 'asyncio.tasks'  (len=13)
# asyncio.ensure_future.__module__  == 'asyncio.tasks'  (len=13)
# ---------------------------------------------------------------------------

table asyncio_extra116.asyncio_coroutine_module_names:
  description: "asyncio coroutine function module and name cross-checks in asynciocoro116 namespace — wave 256 theme: all four coroutine functions in this spec share the same __module__ 'asyncio.tasks' (len=13); asyncio.sleep.__module__.__eq__('asyncio.tasks')==True; asyncio.sleep.__module__.__len__()==13; asyncio.gather.__module__.__eq__('asyncio.tasks')==True; asyncio.wait.__module__.__eq__('asyncio.tasks')==True; asyncio.ensure_future.__module__.__eq__('asyncio.tasks')==True; note: all four functions are defined in Lib/asyncio/tasks.py and exposed via asyncio.__init__.py; asyncio.sleep.__name__.__len__()==5; asyncio.gather.__name__.__len__()==6; asyncio.wait.__name__.__len__()==4 (shortest name in spec); asyncio.ensure_future.__name__.__len__()==13 (longest name in spec; coincidentally equal to module name len=13); compare name lengths: wait=4 (shortest) < sleep=5 < gather=6 < ensure_future=13 (longest); co_varnames len ordering mirrors name complexity: wait=4 co_varnames < sleep=5 co_varnames < gather=9 co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoro116b

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_mod_eq,   sleep.__module__.__eq__,          ["asyncio.tasks"], true, "sleep.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [sleep_mod_len,  sleep.__module__.__len__,         [],                13,   "sleep.__module__.__len__() == 13 ('asyncio.tasks'=13); verified with Python 3.14.3"]
    - [gather_mod_eq,  gather.__module__.__eq__,         ["asyncio.tasks"], true, "gather.__module__ == 'asyncio.tasks' (same module as sleep); verified with Python 3.14.3"]
    - [wait_mod_eq,    wait.__module__.__eq__,           ["asyncio.tasks"], true, "wait.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [ef_mod_eq,      ensure_future.__module__.__eq__,  ["asyncio.tasks"], true, "ensure_future.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [sleep_name_len, sleep.__name__.__len__,           [],                5,    "sleep.__name__.__len__() == 5 ('sleep'=5); verified with Python 3.14.3"]
    - [gather_name_len,gather.__name__.__len__,          [],                6,    "gather.__name__.__len__() == 6 ('gather'=6); verified with Python 3.14.3"]
    - [wait_name_len,  wait.__name__.__len__,            [],                4,    "wait.__name__.__len__() == 4 ('wait'=4, shortest name); verified with Python 3.14.3"]
    - [ef_name_len,    ensure_future.__name__.__len__,   [],                13,   "ensure_future.__name__.__len__() == 13 (longest name; ties with module len=13); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra116
# ---------------------------------------------------------------------------

invariant asyncio_extra116.sleep_co_varnames_len_5:
  description: "asyncio.sleep.__code__.co_varnames.__len__() == 5 — co_varnames==('delay','result','loop','future','h'): 2 parameters (delay, result) plus 3 local variables (loop, future, h); sleep is defined as 'async def sleep(delay, result=None)' so co_argcount=2; the 3 extra locals are loop (event loop), future (asyncio.Future), and h (handle returned by loop.call_later); asyncio.sleep.__code__.co_qualname=='sleep' (len=5; co_qualname==co_name==__name__ for module-level functions); asyncio.sleep.__module__=='asyncio.tasks' (len=13); co_varnames.__len__()==5 is NOT the same as co_argcount==2 (the tuple contains all locals, not just params); compare: wait co_varnames len=4 (fewer; simpler implementation) vs sleep co_varnames len=5 vs gather co_varnames len=9 (most complex); first standalone sleep co_varnames length invariant in asynciocoro116 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: sleep.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant asyncio_extra116.gather_co_varnames_len_9:
  description: "asyncio.gather.__code__.co_varnames.__len__() == 9 — co_varnames==('return_exceptions','coros_or_futures','loop','cur_task','_done_callback','arg_to_fut','done_futs','arg','fut'): gather uses *coros_or_futures variadic so co_argcount==0 (no positional parameters in the traditional sense), but co_varnames has 9 entries including keyword-only param return_exceptions plus 8 local vars; asyncio.gather.__code__.co_qualname=='gather' (len=6); asyncio.gather.__module__=='asyncio.tasks'; this is the most co_varnames of any function in this spec (9 > sleep=5 > wait==ensure_future==4); gather's 9 locals reflect its complexity: it must build a mapping from arg to future (arg_to_fut), track done futures (done_futs), iterate over args (arg, fut), and manage the current task (cur_task) plus the done callback (_done_callback); first standalone gather co_varnames length invariant in asynciocoro116 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: gather.__code__.co_varnames.__len__
  args: []
  expected: 9

invariant asyncio_extra116.wait_co_qualname_len_4:
  description: "asyncio.wait.__code__.co_qualname.__len__() == 4 — 'wait'=4 chars; this is the shortest co_qualname in this spec; asyncio.wait.__code__.co_qualname.__eq__('wait')==True; co_qualname=='wait'==co_name==__name__ (all equal for module-level functions); asyncio.wait.__code__.co_argcount==1 (fs is the single positional parameter; timeout and return_when are keyword-only); asyncio.wait.__code__.co_varnames.__len__()==4 ('fs','timeout','return_when','loop'); note coincidence: wait co_qualname len=4 == wait co_varnames len=4 (both 4); asyncio.wait.__module__=='asyncio.tasks' (len=13); compare co_qualname lengths: wait=4 (shortest) < sleep=5 < gather=6 < ensure_future=13 (longest); first standalone wait co_qualname length invariant in asynciocoro116 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: wait.__code__.co_qualname.__len__
  args: []
  expected: 4

invariant asyncio_extra116.ensure_future_co_qualname_len_13:
  description: "asyncio.ensure_future.__code__.co_qualname.__len__() == 13 — 'ensure_future'=13 chars; this is the longest co_qualname in this spec; asyncio.ensure_future.__code__.co_qualname.__eq__('ensure_future')==True; co_qualname=='ensure_future'==co_name==__name__ (all equal for module-level functions); asyncio.ensure_future.__code__.co_argcount==1; asyncio.ensure_future.__code__.co_varnames.__len__()==4; note coincidence: ensure_future co_qualname len=13 == ensure_future.__module__.__len__()==13 ('asyncio.tasks'=13); asyncio.ensure_future wraps a coroutine or awaitable in a Task or returns it unchanged if already a Future; compare co_qualname lengths: wait=4 < sleep=5 < gather=6 < ensure_future=13 (longest, 7 chars more than gather); first standalone ensure_future co_qualname length invariant in asynciocoro116 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: ensure_future.__code__.co_qualname.__len__
  args: []
  expected: 13

invariant asyncio_extra116.gather_co_argcount_0:
  description: "asyncio.gather.__code__.co_argcount == 0 — gather is defined as 'async def gather(*coros_or_futures, return_exceptions=False)': *coros_or_futures is a VAR_POSITIONAL (*args) parameter not counted in co_argcount; return_exceptions is keyword-only not counted in co_argcount; so co_argcount==0; asyncio.gather.__code__.co_varnames.__len__()==9 (9 locals despite co_argcount==0); asyncio.gather.__code__.co_qualname=='gather' (len=6); asyncio.gather.__module__=='asyncio.tasks'; compare co_argcount values in spec: gather==0 (fewest) < wait==ensure_future==1 < sleep==2 (most); gather has the most co_varnames (9) despite the fewest co_argcount (0) — because all its complexity lives in local variables; first standalone gather co_argcount==0 invariant in asynciocoro116 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: gather.__code__.co_argcount.__eq__
  args: [0]
  expected: true
