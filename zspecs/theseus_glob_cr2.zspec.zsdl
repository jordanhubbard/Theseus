spec: theseus_glob_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_glob_cr2)
blocks: glob

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html"
  notes:
    - "Clean-room glob escape utility. Do NOT import glob."
    - "escape(pathname): escape all special characters (*, ?, [, ]) so they match literally."
    - "glob2_escape(): escape('a[b]c') == 'a[[]b]c' — brackets are escaped."
    - "glob2_escape_star(): escape('*.txt') == '[*].txt' — star is escaped."
    - "glob2_escape_question(): escape('a?.b') == 'a[?].b' — question mark is escaped."
    - "Zero-arg invariant signatures — def glob2_escape(): return hardcoded_result"
    - "Escaping replaces * with [*], ? with [?], [ with [[], ] with []]."
    - "This allows literal matching of filenames that contain glob special characters."
    - "Export: escape(pathname) -> str."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_glob_cr2.escape:
  description: "escape('a[b]c') == 'a[[]b]c'"
  category: escape
  kind: python_call_eq
  function: glob2_escape
  args: []
  expected: "a[[]b]c"

invariant theseus_glob_cr2.escape_star:
  description: "escape('*.txt') == '[*].txt'"
  category: escape
  kind: python_call_eq
  function: glob2_escape_star
  args: []
  expected: "[*].txt"

invariant theseus_glob_cr2.escape_question:
  description: "escape('a?.b') == 'a[?].b'"
  category: escape
  kind: python_call_eq
  function: glob2_escape_question
  args: []
  expected: "a[?].b"
