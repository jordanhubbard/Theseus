spec: threading_extra250
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading synchronization primitive class identity — Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition."
    - "threading.Lock.__name__ == 'lock' (lowercase) — Lock is a factory function returning a _thread.lock C-level object; the returned instance's type name is 'lock' (lowercase). threading.Lock.__name__ == 'lock'. Verified with Python 3.14.3."
    - "threading.Lock().__class__.__name__ == 'lock' — instances returned by threading.Lock() have __class__.__name__ 'lock'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' — RLock is a Python class in Lib/threading.py; __name__ is 'RLock'. Verified with Python 3.14.3."
    - "threading.RLock().__class__.__name__ == 'RLock' — RLock instances have __class__.__name__ 'RLock'. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore'; __module__ == 'threading'; __bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'; __bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event'; __module__ == 'threading'; __bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition'; __bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock and RLock class identity
#
# threading.Lock.__name__ == 'lock'  (lowercase — C-level type)
# threading.RLock.__name__ == 'RLock'
# threading.RLock.__module__ == 'threading'
#
# Lock is a C-level factory returning _thread.lock instances; its __name__
# is lowercase 'lock'. RLock is a Python class with __name__ 'RLock'.
# New to extra250.
# ---------------------------------------------------------------------------

table threading_extra250.lock_rlck_class_identity:
  description: "threading.Lock and RLock class __name__, __module__ identity; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: thr250lock

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,
       Lock.__name__.__eq__,
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — Lock is the C-level _thread.lock factory; its __name__ is lowercase 'lock'; str.__eq__('lock') returns True; new to extra250"]
    - [rlock_name_eq,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — RLock is a Python reentrant lock class defined in Lib/threading.py; its __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra250"]
    - [rlock_module_eq,
       RLock.__module__.__eq__,
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra250"]
    - [lock_name_len_4,
       Lock.__name__.__len__,
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — 'lock' has 4 characters; __len__() returns 4; new to extra250"]
    - [rlock_name_len_5,
       RLock.__name__.__len__,
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — 'RLock' has 5 characters; __len__() returns 5; new to extra250"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and BoundedSemaphore class identity
#
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Semaphore.__module__ == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
#
# Semaphore is a pure-Python class. BoundedSemaphore extends Semaphore.
# New to extra250.
# ---------------------------------------------------------------------------

table threading_extra250.semaphore_class_identity:
  description: "threading.Semaphore and BoundedSemaphore class __name__, __module__, __bases__; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: thr250sem

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_eq,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is the counting semaphore class defined in Lib/threading.py; __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra250"]
    - [semaphore_module_eq,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra250"]
    - [semaphore_bases0_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra250"]
    - [boundedsemaphore_name_eq,
       BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore is a semaphore with an upper bound; __name__ is 'BoundedSemaphore'; str.__eq__('BoundedSemaphore') returns True; new to extra250"]
    - [boundedsemaphore_bases0_semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore extends Semaphore; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra250"]

# ---------------------------------------------------------------------------
# Table 3: threading.Event and Condition class identity
#
# threading.Event.__name__ == 'Event'
# threading.Event.__module__ == 'threading'
# threading.Event.__bases__[0].__name__ == 'object'
# threading.Condition.__name__ == 'Condition'
# threading.Condition.__module__ == 'threading'
# threading.Condition.__bases__[0].__name__ == 'object'
#
# Both Event and Condition are pure-Python synchronization classes defined
# in Lib/threading.py, both inheriting directly from object. New to extra250.
# ---------------------------------------------------------------------------

table threading_extra250.event_condition_class_identity:
  description: "threading.Event and Condition class __name__, __module__, __bases__; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: thr250evt

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is the flag-based thread synchronization class; __name__ is 'Event'; str.__eq__('Event') returns True; new to extra250"]
    - [event_module_eq,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra250"]
    - [event_bases0_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra250"]
    - [condition_name_eq,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is the monitor-style synchronization primitive; __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra250"]
    - [condition_bases0_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra250"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra250
# ---------------------------------------------------------------------------

invariant threading_extra250.Lock.name_eq:
  description: "threading.Lock.__name__ == 'lock' — Lock is a C-level factory; __name__ is lowercase 'lock'; new to extra250"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra250.RLock.name_eq:
  description: "threading.RLock.__name__ == 'RLock' — RLock is a Python reentrant lock; new to extra250"
  category: identity
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra250.RLock.module_eq:
  description: "threading.RLock.__module__ == 'threading' — RLock is defined in Lib/threading.py; new to extra250"
  category: identity
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra250.Semaphore.name_eq:
  description: "threading.Semaphore.__name__ == 'Semaphore' — the counting semaphore class; new to extra250"
  category: identity
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra250.Semaphore.module_eq:
  description: "threading.Semaphore.__module__ == 'threading' — Semaphore is in Lib/threading.py; new to extra250"
  category: identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra250.Semaphore.bases0_is_object:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits from object; new to extra250"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra250.BoundedSemaphore.name_eq:
  description: "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — bounded variant of Semaphore; new to extra250"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra250.BoundedSemaphore.bases0_is_semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore; new to extra250"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra250.Event.name_eq:
  description: "threading.Event.__name__ == 'Event' — flag-based synchronization; new to extra250"
  category: identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra250.Event.module_eq:
  description: "threading.Event.__module__ == 'threading' — Event is defined in Lib/threading.py; new to extra250"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra250.Event.bases0_is_object:
  description: "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object; new to extra250"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra250.Condition.name_eq:
  description: "threading.Condition.__name__ == 'Condition' — monitor-style sync primitive; new to extra250"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra250.Condition.bases0_is_object:
  description: "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object; new to extra250"
  category: identity
  kind: python_call_eq
  function: "Condition.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
