spec: ast_extra12
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, arithmetic/statement node classnames"
    - "ast_extra.zspec.zsdl — covers parse/__name__/__module__/returns_module_node, dump/__name__, get_docstring/__name__, fix_missing_locations/__name__, NodeVisitor/__name__, NodeTransformer/__name__/__bases__[0], AST/__name__, literal_eval standalone round-trips"
    - "ast_extra2.zspec.zsdl — covers literal_eval value checks for int/str/list/dict/bool/None"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer/Module/FunctionDef/Constant/Name/AST/Expr/ClassDef"
    - "ast_extra4.zspec.zsdl — covers __qualname__ for literal_eval/get_docstring/dump/walk/fix_missing_locations/NodeVisitor/NodeTransformer/AST/Module/Constant/parse; literal_eval type checks"
    - "ast_extra5.zspec.zsdl — covers __qualname__ for FunctionDef/Expr/ClassDef/Name/If/For/Import/Call/Assign/Return/AsyncFunctionDef/AsyncFor/AsyncWith/With/Delete; unparse/__qualname__/__module__, copy_location/__qualname__/__module__, increment_lineno/__qualname__/__module__"
    - "ast_extra6.zspec.zsdl — covers __name__ for Module/Constant/Name/Expr/FunctionDef/ClassDef/If/Return/Assign/Call/Import/For (table); walk.__name__; NodeVisitor.__bases__[0]; AST.__bases__[0]; AsyncFunctionDef/__name__, With/__name__, Delete/__name__"
    - "ast_extra7.zspec.zsdl — covers abstract bases mod/stmt/expr/__name__; BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue __name__/__qualname__; BinOp/While/Tuple __module__; Module MRO[0]/MRO[2]; parse body __len__"
    - "ast_extra8.zspec.zsdl — covers operator/cmpop/boolop/unaryop/expr_context abstract base __name__; Add/Sub/Mult/Div/Mod/Pow/FloorDiv operator node __name__; Eq/NotEq/Lt/LtE/Gt/GtE cmpop node __name__; And/Or boolop __name__; Not/UAdd/USub unaryop __name__; PyCF_ONLY_AST value; NodeTransformer MRO[1].__name__; parse mode='eval' returns Expression"
    - "ast_extra9.zspec.zsdl — covers NodeVisitor/NodeTransformer __name__.__eq__; get_source_segment.__module__; BitAnd/BitOr/BitXor/LShift/RShift/MatMult/Invert bitwise operator __name__; Is/IsNot/In/NotIn cmpop __name__; Load/Store/Del expr_context __name__; parse/dump __module__.__eq__"
    - "ast_extra10.zspec.zsdl — covers helper node __name__ for arg/arguments/keyword/alias/withitem; Global/Nonlocal/Yield/YieldFrom/Await/Subscript/Attribute/Starred __name__; arg/alias __module__"
    - "ast_extra11.zspec.zsdl — covers __qualname__ for helper nodes (arg/arguments/keyword/alias/withitem) and access/async expression nodes (Subscript/Attribute/Starred/Yield/Global/Nonlocal); withitem/__module__, keyword/__module__"
  notes:
    - "This spec extends ast_extra11.zspec.zsdl."
    - "ast.NamedExpr/__name__/__qualname__/__module__ not verified in any prior ast spec."
    - "ast.JoinedStr/__name__/__qualname__/__module__ not verified in any prior ast spec."
    - "ast.IfExp/__name__/__qualname__/__module__ not verified in any prior ast spec."
    - "ast.Lambda/__name__/__qualname__/__module__ not verified in any prior ast spec."
    - "ast.FormattedValue/__name__/__qualname__/__module__ not verified in any prior ast spec."
    - "ast.Expression/__name__/__module__ not verified in any prior ast spec."
    - "ast.Interactive/__name__/__module__ not verified in any prior ast spec."
    - "ast.unparse/__name__/__qualname__/__module__ not verified in any prior ast spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Expression-mode and interactive-mode parse nodes — __name__ and __module__
#
# ast_extra8 covers parse mode='eval' returns Expression but does not check
# ast.Expression.__name__ or ast.Interactive.__name__ as standalone invariants.
# No prior ast spec verifies __name__ for Expression or Interactive.
# ---------------------------------------------------------------------------

invariant ast_extra12.Expression.name:
  description: "ast.Expression.__name__ == 'Expression' — parse-mode expression root node"
  category: class_names
  kind: python_call_eq
  function: Expression.__name__.__eq__
  args: ["Expression"]
  expected: true

invariant ast_extra12.Interactive.name:
  description: "ast.Interactive.__name__ == 'Interactive' — parse-mode interactive root node"
  category: class_names
  kind: python_call_eq
  function: Interactive.__name__.__eq__
  args: ["Interactive"]
  expected: true

invariant ast_extra12.Expression.module:
  description: "ast.Expression.__module__ == 'ast' — Expression node defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: Expression.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra12.Interactive.module:
  description: "ast.Interactive.__module__ == 'ast' — Interactive node defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: Interactive.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# NamedExpr, JoinedStr, IfExp, Lambda, FormattedValue — __name__ checks
#
# These expression nodes appear in Python 3.8+ and have not been verified
# by any prior ast spec. All are defined in the ast module.
# ---------------------------------------------------------------------------

table ast_extra12.expr_node_names:
  kind: python_call_eq
  category: class_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [NamedExpr,     NamedExpr.__name__.__eq__,     ["NamedExpr"],     true]
    - [JoinedStr,     JoinedStr.__name__.__eq__,     ["JoinedStr"],     true]
    - [IfExp,         IfExp.__name__.__eq__,         ["IfExp"],         true]
    - [Lambda,        Lambda.__name__.__eq__,        ["Lambda"],        true]
    - [FormattedValue, FormattedValue.__name__.__eq__, ["FormattedValue"], true]

# ---------------------------------------------------------------------------
# NamedExpr, JoinedStr, IfExp, Lambda, FormattedValue — __qualname__ checks
#
# None of the prior ast specs have verified __qualname__ for these five nodes.
# For module-level classes, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table ast_extra12.expr_node_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [NamedExpr,     NamedExpr.__qualname__.__eq__,     ["NamedExpr"],     true]
    - [JoinedStr,     JoinedStr.__qualname__.__eq__,     ["JoinedStr"],     true]
    - [IfExp,         IfExp.__qualname__.__eq__,         ["IfExp"],         true]
    - [Lambda,        Lambda.__qualname__.__eq__,        ["Lambda"],        true]
    - [FormattedValue, FormattedValue.__qualname__.__eq__, ["FormattedValue"], true]

# ---------------------------------------------------------------------------
# ast.unparse — __name__, __qualname__, __module__
#
# ast.unparse was added in Python 3.9. No prior ast spec verifies any
# attribute of ast.unparse. It is a plain Python function in the ast module.
# ---------------------------------------------------------------------------

invariant ast_extra12.unparse.name:
  description: "ast.unparse.__name__ == 'unparse' — function name check"
  category: function_names
  kind: python_call_eq
  function: unparse.__name__.__eq__
  args: ["unparse"]
  expected: true

invariant ast_extra12.unparse.qualname:
  description: "ast.unparse.__qualname__ == 'unparse' — function qualname check"
  category: function_qualnames
  kind: python_call_eq
  function: unparse.__qualname__.__eq__
  args: ["unparse"]
  expected: true

invariant ast_extra12.unparse.module:
  description: "ast.unparse.__module__ == 'ast' — unparse is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: unparse.__module__.__eq__
  args: ["ast"]
  expected: true
