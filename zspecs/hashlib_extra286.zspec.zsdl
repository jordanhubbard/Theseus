spec: hashlib_extra286
version: ">=3.6"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec extends hashlib.zspec.zsdl through hashlib_extra285.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "hashlib_extra285.zspec.zsdl covers: sha256(b'abc').hexdigest() and sha256(b'').hexdigest() known vectors; sha256 digest() length; sha256 name/digest_size/block_size attributes."
    - "This spec focuses on: sha512 block_size (128) and digest_size (64); sha1 block_size (64) and digest_size (20); md5 block_size (64) and digest_size (16); sha3_256 block_size (136) and digest_size (32); hashlib.new('sha256').name == 'sha256'; hashlib.new('sha512').name == 'sha512'."
    - "hashlib.sha512().block_size == 128 (SHA-512 uses 1024-bit = 128-byte blocks). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha512().digest_size == 64 (SHA-512 produces 512-bit = 64-byte digests). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha1().block_size == 64 (SHA-1 uses 512-bit = 64-byte blocks). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha1().digest_size == 20 (SHA-1 produces 160-bit = 20-byte digests). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.md5().block_size == 64 (MD5 uses 512-bit = 64-byte blocks). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.md5().digest_size == 16 (MD5 produces 128-bit = 16-byte digests). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_256().block_size == 136 (Keccak rate = 1600 - 2*256 = 1088 bits = 136 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_256().digest_size == 32 (SHA3-256 produces 256-bit = 32-byte digests). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new('sha256').name == 'sha256' — new() factory returns a HASH object with the correct name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new('sha512').name == 'sha512' — new() factory returns a HASH object with the correct name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "hashlib constructors (sha512, sha1, md5, sha3_256) return HASH objects; .block_size and .digest_size are integer attributes; .name is a str attribute."
  stderr: "null"
  stickiness: "HASH objects carry mutable state; each test creates a fresh instance."
  codes: {}

# ---------------------------------------------------------------------------
# hashlib.sha512 — block_size and digest_size attributes
# SHA-512 uses a 1024-bit (128-byte) block size and produces a 512-bit (64-byte) digest.
# ---------------------------------------------------------------------------

invariant hashlib_extra286.sha512.block_size:
  description: "hashlib.sha512().block_size == 128 — SHA-512 uses 1024-bit (128-byte) blocks; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha512
  args: []
  method: block_size.__eq__
  method_args: [128]
  expected: true

invariant hashlib_extra286.sha512.digest_size:
  description: "hashlib.sha512().digest_size == 64 — SHA-512 produces a 512-bit (64-byte) digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha512
  args: []
  method: digest_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1 — block_size and digest_size attributes
# SHA-1 uses a 512-bit (64-byte) block size and produces a 160-bit (20-byte) digest.
# ---------------------------------------------------------------------------

invariant hashlib_extra286.sha1.block_size:
  description: "hashlib.sha1().block_size == 64 — SHA-1 uses 512-bit (64-byte) blocks; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha1
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra286.sha1.digest_size:
  description: "hashlib.sha1().digest_size == 20 — SHA-1 produces a 160-bit (20-byte) digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha1
  args: []
  method: digest_size.__eq__
  method_args: [20]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5 — block_size and digest_size attributes
# MD5 uses a 512-bit (64-byte) block size and produces a 128-bit (16-byte) digest.
# ---------------------------------------------------------------------------

invariant hashlib_extra286.md5.block_size:
  description: "hashlib.md5().block_size == 64 — MD5 uses 512-bit (64-byte) blocks; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: md5
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra286.md5.digest_size:
  description: "hashlib.md5().digest_size == 16 — MD5 produces a 128-bit (16-byte) digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: md5
  args: []
  method: digest_size.__eq__
  method_args: [16]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256 — block_size and digest_size attributes
# SHA3-256 uses a Keccak sponge with rate = 1600 - 2*256 = 1088 bits = 136 bytes.
# ---------------------------------------------------------------------------

invariant hashlib_extra286.sha3_256.block_size:
  description: "hashlib.sha3_256().block_size == 136 — Keccak rate = 1600 - 2*256 bits = 136 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha3_256
  args: []
  method: block_size.__eq__
  method_args: [136]
  expected: true

invariant hashlib_extra286.sha3_256.digest_size:
  description: "hashlib.sha3_256().digest_size == 32 — SHA3-256 produces a 256-bit (32-byte) digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha3_256
  args: []
  method: digest_size.__eq__
  method_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() — name attribute of the returned HASH object
# hashlib.new('sha256') and hashlib.new('sha512') return HASH objects whose
# .name attribute equals the algorithm name string passed to new().
# ---------------------------------------------------------------------------

invariant hashlib_extra286.new_sha256.name:
  description: "hashlib.new('sha256').name == 'sha256' — new() factory preserves the algorithm name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: api
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra286.new_sha512.name:
  description: "hashlib.new('sha512').name == 'sha512' — new() factory preserves the algorithm name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: api
  kind: python_call_eq
  function: new
  args: ["sha512"]
  method: name.__eq__
  method_args: ["sha512"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() — raises ValueError for unknown algorithm name
# hashlib.new() must raise ValueError when given an unrecognised algorithm name.
# ---------------------------------------------------------------------------

invariant hashlib_extra286.new.unknown_algo_raises:
  description: "hashlib.new('not_a_real_algo') raises ValueError — unknown algorithm names are rejected; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: new
  args: ["not_a_real_algo"]
  raises: ValueError
