spec: io_extra283
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io_extra282 covers IncrementalNewlineDecoder, open_code, FileIO method types, StringIO/BytesIO module identity."
    - "This spec focuses on StringIO and BytesIO method __qualname__ values."
    - "All StringIO methods accessed at the class level are method_descriptor objects; their __qualname__ follows 'StringIO.<method>'."
    - "All BytesIO methods accessed at the class level also follow 'BytesIO.<method>' for __qualname__."
    - "io.StringIO.read.__qualname__ == 'StringIO.read' — confirmed for all methods listed."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read' — confirmed for all methods listed."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO method __qualname__ — confirmed at class level (method_descriptor)
# All qualnames follow the pattern 'StringIO.<method>'
# ---------------------------------------------------------------------------

table io_extra283.stringio_method_qualnames:
  description: "io.StringIO method __qualname__ values — all follow 'StringIO.<method>'"
  kind: python_call_eq
  category: method_identity
  id_prefix: sio_qn

  columns: [id, function, args, expected, description]
  rows:
    - [read,     StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true, "io.StringIO.read.__qualname__ == 'StringIO.read'"]
    - [write,    StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true, "io.StringIO.write.__qualname__ == 'StringIO.write'"]
    - [getvalue, StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true, "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue'"]
    - [seek,     StringIO.seek.__qualname__.__eq__,     ["StringIO.seek"],     true, "io.StringIO.seek.__qualname__ == 'StringIO.seek'"]
    - [tell,     StringIO.tell.__qualname__.__eq__,     ["StringIO.tell"],     true, "io.StringIO.tell.__qualname__ == 'StringIO.tell'"]
    - [truncate, StringIO.truncate.__qualname__.__eq__, ["StringIO.truncate"], true, "io.StringIO.truncate.__qualname__ == 'StringIO.truncate'"]
    - [readline, StringIO.readline.__qualname__.__eq__, ["StringIO.readline"], true, "io.StringIO.readline.__qualname__ == 'StringIO.readline'"]

# ---------------------------------------------------------------------------
# BytesIO method __qualname__ — confirmed at class level (method_descriptor)
# All qualnames follow the pattern 'BytesIO.<method>'
# ---------------------------------------------------------------------------

table io_extra283.bytesio_method_qualnames:
  description: "io.BytesIO method __qualname__ values — all follow 'BytesIO.<method>'"
  kind: python_call_eq
  category: method_identity
  id_prefix: bio_qn

  columns: [id, function, args, expected, description]
  rows:
    - [read,     BytesIO.read.__qualname__.__eq__,     ["BytesIO.read"],     true, "io.BytesIO.read.__qualname__ == 'BytesIO.read'"]
    - [write,    BytesIO.write.__qualname__.__eq__,    ["BytesIO.write"],    true, "io.BytesIO.write.__qualname__ == 'BytesIO.write'"]
    - [getvalue, BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true, "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue'"]
    - [seek,     BytesIO.seek.__qualname__.__eq__,     ["BytesIO.seek"],     true, "io.BytesIO.seek.__qualname__ == 'BytesIO.seek'"]
    - [tell,     BytesIO.tell.__qualname__.__eq__,     ["BytesIO.tell"],     true, "io.BytesIO.tell.__qualname__ == 'BytesIO.tell'"]
    - [truncate, BytesIO.truncate.__qualname__.__eq__, ["BytesIO.truncate"], true, "io.BytesIO.truncate.__qualname__ == 'BytesIO.truncate'"]
    - [readline, BytesIO.readline.__qualname__.__eq__, ["BytesIO.readline"], true, "io.BytesIO.readline.__qualname__ == 'BytesIO.readline'"]

# ---------------------------------------------------------------------------
# StringIO class identity
# ---------------------------------------------------------------------------

invariant io_extra283.StringIO.class_name:
  description: "io.StringIO.__name__ == 'StringIO'"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra283.StringIO.is_type:
  description: "io.StringIO.__class__.__name__ == 'type' — StringIO is a plain class object"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# BytesIO class identity
# ---------------------------------------------------------------------------

invariant io_extra283.BytesIO.class_name:
  description: "io.BytesIO.__name__ == 'BytesIO'"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra283.BytesIO.is_type:
  description: "io.BytesIO.__class__.__name__ == 'type' — BytesIO is a plain class object"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — module-level constant
# ---------------------------------------------------------------------------

invariant io_extra283.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — default I/O buffer size is 128 KiB"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra283.DEFAULT_BUFFER_SIZE.is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
