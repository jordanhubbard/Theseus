spec: decimal_extra300
version: ">=3.0"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "getcontext() returns the thread-local decimal Context with default precision 28."
    - "Default Emax is 999999 and default Emin is -999999 (not 999999999)."
    - "localcontext() returns a decimal.ContextManager instance (not a Context directly)."
    - "Context.__bases__[0].__name__ == 'object' — Context has no custom base class."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getcontext() — default thread-local Context attributes
# ---------------------------------------------------------------------------

invariant decimal_extra300.context.class_name:
  description: "getcontext().__class__.__name__ == 'Context'"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: __class__
  method_chain: __name__
  expected: "Context"

invariant decimal_extra300.context.prec:
  description: "getcontext().prec.__eq__(28) — default precision is 28 significant digits"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: prec
  method_chain: __eq__
  method_chain_args: [28]
  expected: true

invariant decimal_extra300.context.rounding:
  description: "getcontext().rounding.__eq__('ROUND_HALF_EVEN')"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  method_chain: __eq__
  method_chain_args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra300.context.Emax:
  description: "getcontext().Emax.__eq__(999999) — default maximum exponent"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emax
  method_chain: __eq__
  method_chain_args: [999999]
  expected: true

invariant decimal_extra300.context.Emin:
  description: "getcontext().Emin.__eq__(-999999) — default minimum exponent"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emin
  method_chain: __eq__
  method_chain_args: [-999999]
  expected: true

# ---------------------------------------------------------------------------
# localcontext() — returns a ContextManager
# ---------------------------------------------------------------------------

invariant decimal_extra300.localcontext.class_name:
  description: "localcontext().__class__.__name__ == 'ContextManager'"
  category: localcontext
  kind: python_call_eq
  function: localcontext
  args: []
  method: __class__
  method_chain: __name__
  expected: "ContextManager"

# ---------------------------------------------------------------------------
# Context class metadata — accessed via dotted attribute chains on the class
# ---------------------------------------------------------------------------

invariant decimal_extra300.Context.class_name:
  description: "Context.__name__ == 'Context'"
  category: class_metadata
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra300.Context.module:
  description: "Context.__module__ == 'decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra300.Context.bases_object:
  description: "Context.__bases__[0].__name__ == 'object' — Context inherits directly from object"
  category: class_metadata
  kind: python_call_eq
  function: "Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
