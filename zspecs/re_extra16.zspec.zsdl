spec: re_extra16
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra15.zspec.zsdl."
    - "re_extra15 covers: fullmatch('ab+', ...) match/none; split whitespace three-word and comma; findall digit runs and alpha runs; escape dot and dollar."
    - "re_extra14 covers: RegexFlag.__name__/__qualname__/__module__; RegexFlag base IntFlag; compile(r'[a-z]+').pattern; match group(2); match groups().__len__; subn digit result/count; match digit start/end."
    - "re_extra12 covers: IGNORECASE|MULTILINE==10; search named group; search capture group 1; sub whitespace collapse to space; split single spaces."
    - "re_extra7 covers: RegexFlag member values IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/NOFLAG; match span start/end."
    - "NOT yet covered: re.sub(r'\\s+', '-', 'hello world foo') == 'hello-world-foo' — hyphen replacement (prior sub uses space replacement)."
    - "NOT yet covered: re.findall(r'\\w+', 'hello world') == ['hello', 'world'] — word-token extraction."
    - "NOT yet covered: re.search(r'[A-Z]', 'hello World').group() == 'W' — find first uppercase letter."
    - "NOT yet covered: re.sub(r'[aeiou]', '*', 'hello') == 'h*ll*' — vowel replacement."
    - "NOT yet covered: re.findall(r'[A-Z]', 'Hello World') == ['H', 'W'] — extract uppercase letters."
    - "NOT yet covered: re.match(r'(\\d+)\\.(\\d+)', '3.14').group(1) == '3' — first group of a decimal match."
    - "NOT yet covered: re.match(r'(\\d+)\\.(\\d+)', '3.14').group(2) == '14' — second group of a decimal match."
    - "re.sub(r'\\s+', '-', 'hello world foo') == 'hello-world-foo' — whitespace replaced with hyphen, not space."
    - "re.findall(r'\\w+', 'hello world') == ['hello', 'world'] — r'\\w+' matches word characters."
    - "re.search(r'[A-Z]', 'hello World').group() == 'W' — finds first uppercase in mixed string."
    - "re.sub(r'[aeiou]', '*', 'hello') == 'h*ll*' — two vowels 'e' and 'o' replaced."
    - "re.findall(r'[A-Z]', 'Hello World') == ['H', 'W'] — two uppercase letters extracted."
    - "re.match(r'(\\d+)\\.(\\d+)', '3.14').group(1) == '3'; group(2) == '14' — integer and fractional parts."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.sub — whitespace-to-hyphen and vowel replacement
#
# re_extra12 covers sub(r'\s+', ' ', 'a  b  c') == 'a b c' (collapse to space).
# No prior spec uses hyphen '-' as the replacement string for whitespace.
# re.sub(r'\s+', '-', 'hello world foo') == 'hello-world-foo'.
#
# No prior spec covers sub with a character class pattern [aeiou].
# re.sub(r'[aeiou]', '*', 'hello') replaces 'e' and 'o' with '*'.
# ---------------------------------------------------------------------------

invariant re_extra16.sub.whitespace_to_hyphen:
  description: "re.sub(r'\\s+', '-', 'hello world foo') == 'hello-world-foo' — whitespace replaced with hyphen"
  category: sub
  kind: python_call_eq
  function: sub
  args: ["\\s+", "-", "hello world foo"]
  expected: "hello-world-foo"

invariant re_extra16.sub.vowel_replacement:
  description: "re.sub(r'[aeiou]', '*', 'hello') == 'h*ll*' — vowels replaced with asterisk"
  category: sub
  kind: python_call_eq
  function: sub
  args: ["[aeiou]", "*", "hello"]
  expected: "h*ll*"

# ---------------------------------------------------------------------------
# re.findall — word tokens and uppercase letters
#
# re_extra15 covers findall(r'\d+', ...) and findall(r'[a-z]+', ...).
# No prior spec uses r'\w+' to extract word tokens.
# No prior spec uses r'[A-Z]' to extract uppercase letters.
# ---------------------------------------------------------------------------

invariant re_extra16.findall.word_tokens:
  description: "re.findall(r'\\w+', 'hello world') == ['hello', 'world'] — word-token extraction"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\w+", "hello world"]
  expected: ["hello", "world"]

invariant re_extra16.findall.uppercase_letters:
  description: "re.findall(r'[A-Z]', 'Hello World') == ['H', 'W'] — uppercase letter extraction"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["[A-Z]", "Hello World"]
  expected: ["H", "W"]

# ---------------------------------------------------------------------------
# re.search — first uppercase letter in mixed-case string
#
# Prior search vectors use \d+ and \w+ patterns, and named groups.
# No prior spec uses [A-Z] as the search pattern.
# re.search(r'[A-Z]', 'hello World').group() == 'W'.
# ---------------------------------------------------------------------------

invariant re_extra16.search.first_uppercase:
  description: "re.search(r'[A-Z]', 'hello World').group() == 'W' — first uppercase letter"
  category: search
  kind: python_call_eq
  function: search
  args: ["[A-Z]", "hello World"]
  method: group
  method_args: []
  expected: "W"

# ---------------------------------------------------------------------------
# re.match — two-group decimal pattern
#
# re_extra14 covers match(r'(\w+)\s+(\w+)', ...).group(2) == 'bar'.
# No prior spec uses a decimal pattern r'(\d+)\.(\d+)' to extract integer
# and fractional parts as separate capture groups.
# re.match(r'(\d+)\.(\d+)', '3.14').group(1) == '3'
# re.match(r'(\d+)\.(\d+)', '3.14').group(2) == '14'
# ---------------------------------------------------------------------------

invariant re_extra16.match.decimal_group1:
  description: "re.match(r'(\\d+)\\.(\\d+)', '3.14').group(1) == '3' — integer part"
  category: match_groups
  kind: python_call_eq
  function: match
  args: ["(\\d+)\\.(\\d+)", "3.14"]
  method: group
  method_args: [1]
  expected: "3"

invariant re_extra16.match.decimal_group2:
  description: "re.match(r'(\\d+)\\.(\\d+)', '3.14').group(2) == '14' — fractional part"
  category: match_groups
  kind: python_call_eq
  function: match
  args: ["(\\d+)\\.(\\d+)", "3.14"]
  method: group
  method_args: [2]
  expected: "14"

# ---------------------------------------------------------------------------
# Table: sub replacement vectors — new replacement characters
#
# Groups sub-with-hyphen and sub-with-asterisk in one table.
# No prior spec has a sub-replacement-character variety table.
# ---------------------------------------------------------------------------

table re_extra16.sub_replacement_vectors:
  description: "re.sub replacement character variety vectors"
  kind: python_call_eq
  category: sub
  id_prefix: sr

  columns: [id, function, args, expected]
  rows:
    - [ws_hyphen, sub, ["\\s+",   "-", "hello world foo"], "hello-world-foo"]
    - [vowels,    sub, ["[aeiou]", "*", "hello"],           "h*ll*"]

# ---------------------------------------------------------------------------
# Table: findall pattern variety
#
# Groups findall with \w+ and [A-Z] patterns in one indexed table.
# ---------------------------------------------------------------------------

table re_extra16.findall_pattern_variety:
  description: "re.findall pattern variety vectors"
  kind: python_call_eq
  category: findall
  id_prefix: fp

  columns: [id, function, args, expected]
  rows:
    - [word_tokens,     findall, ["\\w+",  "hello world"], ["hello", "world"]]
    - [uppercase_chars, findall, ["[A-Z]", "Hello World"], ["H", "W"]]
