spec: decimal_extra19
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra through decimal_extra18."
    - "decimal_extra3 covers DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow __bases__.__getitem__ (index form, no __name__ chain)."
    - "No prior spec covers Decimal.__bases__[0].__name__, Context.__bases__[0].__name__, or the signal exception __bases__[0].__name__ using the chained dot notation."
    - "No prior spec covers DecimalException.__mro__ items beyond index 0 (ArithmeticError, Exception, BaseException, object)."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal is a direct subclass of object."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context is a direct subclass of object."
    - "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — all signal exceptions inherit from DecimalException."
    - "decimal.FloatOperation.__bases__[0].__name__ == 'DecimalException' — FloatOperation is also a DecimalException signal."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Direct-base __name__ for Decimal and Context (both inherit from object)
# and for the five signal exception classes that inherit from DecimalException.
#
# Prior specs use function: X.__bases__.__getitem__ with index arg — a call
# that returns the base class object itself.  This spec instead chains to
# .__name__.__eq__ to record the base-class name as a string comparison,
# a distinct expression form not previously used for these seven classes.
# ---------------------------------------------------------------------------

table decimal_extra19.bases_name:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base_name

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_object,   "Decimal.__bases__[0].__name__.__eq__",       ["object"],           true, "Decimal inherits directly from object"]
    - [context_object,   "Context.__bases__[0].__name__.__eq__",       ["object"],           true, "Context inherits directly from object"]
    - [clamped_exc,      "Clamped.__bases__[0].__name__.__eq__",       ["DecimalException"], true, "Clamped inherits from DecimalException"]
    - [inexact_exc,      "Inexact.__bases__[0].__name__.__eq__",       ["DecimalException"], true, "Inexact inherits from DecimalException"]
    - [rounded_exc,      "Rounded.__bases__[0].__name__.__eq__",       ["DecimalException"], true, "Rounded inherits from DecimalException"]
    - [subnormal_exc,    "Subnormal.__bases__[0].__name__.__eq__",     ["DecimalException"], true, "Subnormal inherits from DecimalException"]
    - [floatop_exc,      "FloatOperation.__bases__[0].__name__.__eq__", ["DecimalException"], true, "FloatOperation inherits from DecimalException"]

# ---------------------------------------------------------------------------
# DecimalException MRO — full chain beyond index 0
#
# decimal_extra covers Decimal.__mro__.__getitem__ at index 1 (object) only.
# No spec records the DecimalException MRO beyond its own name.
# The full chain: DecimalException → ArithmeticError → Exception →
# BaseException → object.
# ---------------------------------------------------------------------------

invariant decimal_extra19.DecimalException.mro_1:
  description: "decimal.DecimalException.__mro__[1].__name__ == 'ArithmeticError' — second MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "DecimalException.__mro__[1].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra19.DecimalException.mro_2:
  description: "decimal.DecimalException.__mro__[2].__name__ == 'Exception' — third MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "DecimalException.__mro__[2].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant decimal_extra19.DecimalException.mro_3:
  description: "decimal.DecimalException.__mro__[3].__name__ == 'BaseException' — fourth MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "DecimalException.__mro__[3].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant decimal_extra19.DecimalException.mro_4:
  description: "decimal.DecimalException.__mro__[4].__name__ == 'object' — fifth and final MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "DecimalException.__mro__[4].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra19.Decimal.mro_0:
  description: "decimal.Decimal.__mro__[0].__name__ == 'Decimal' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: "Decimal.__mro__[0].__name__.__eq__"
  args: ["Decimal"]
  expected: true
