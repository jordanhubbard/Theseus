# ---------------------------------------------------------------------------
# Table 1: itertools C-type class names for islice, groupby, repeat
#
# Wave 288 theme: itertools C extension type metaclass identity — islice,
# groupby, and repeat are all 'type' class objects.
#
# itertools.islice.__class__.__name__ == 'type'
# itertools.groupby.__class__.__name__ == 'type'
# itertools.repeat.__class__.__name__ == 'type'
# itertools.islice.__name__ == 'islice'
#
# islice, groupby, and repeat are C extension types defined in
# itertoolsmodule.c. As class objects they are instances of the metaclass
# 'type'. islice returns selected elements from an iterable using stop/start/
# step slicing. groupby groups consecutive elements by a key function. repeat
# repeats a value a fixed or infinite number of times. New to extra159.
# ---------------------------------------------------------------------------

table itertools_extra159.c_type_class_names:
  description: "itertools: islice.__class__.__name__ 'type', groupby.__class__.__name__ 'type', repeat.__class__.__name__ 'type', islice.__name__ 'islice'; wave 288; new to extra159"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsctcn159

  columns: [id, function, args, expected, description]
  rows:
    - [islice_class_name_eq_type,
       "islice.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — islice is a C extension type in itertoolsmodule.c that returns selected elements from an iterable using stop, start, and step arguments; as a class object its __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra159"]
    - [groupby_class_name_eq_type,
       "groupby.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a C extension type in itertoolsmodule.c that groups consecutive elements of an iterable by a common key function; as a class object its __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra159"]
    - [repeat_class_name_eq_type,
       "repeat.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — repeat is a C extension type in itertoolsmodule.c that creates an iterator returning a single value a fixed or infinite number of times; as a class object its __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra159"]
    - [islice_name_eq_islice,
       "islice.__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — the C extension type islice has __name__ 'islice'; str.__eq__('islice') returns True; new to extra159"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __name__ and __module__ for groupby and repeat
#
# Wave 288 theme: itertools C extension type __name__ and __module__ attributes
# for groupby and repeat.
#
# itertools.groupby.__name__ == 'groupby'
# itertools.repeat.__name__ == 'repeat'
# itertools.islice.__module__ == 'itertools'
# itertools.groupby.__module__ == 'itertools'
# itertools.repeat.__module__ == 'itertools'
#
# groupby and repeat are C extension types in itertoolsmodule.c. Their __name__
# attributes are the simple type names 'groupby' and 'repeat'. All types in
# the itertools module report __module__ == 'itertools', reflecting the module
# they are declared in. New to extra159.
# ---------------------------------------------------------------------------

table itertools_extra159.c_type_name_and_module:
  description: "itertools: groupby.__name__ 'groupby', repeat.__name__ 'repeat', islice/__module__ 'itertools', groupby/__module__ 'itertools', repeat/__module__ 'itertools'; wave 288; new to extra159"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsctnm159

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_eq_groupby,
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — the C extension type groupby has __name__ 'groupby'; it groups consecutive elements of an iterable that share the same key function value; str.__eq__('groupby') returns True; new to extra159"]
    - [repeat_name_eq_repeat,
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — the C extension type repeat has __name__ 'repeat'; it creates an iterator returning a single object a fixed or infinite number of times; str.__eq__('repeat') returns True; new to extra159"]
    - [islice_module_eq_itertools,
       "islice.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is a C extension type in itertoolsmodule.c; its __module__ attribute is 'itertools' reflecting the module it is declared in; str.__eq__('itertools') returns True; new to extra159"]
    - [groupby_module_eq_itertools,
       "groupby.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is a C extension type in itertoolsmodule.c; its __module__ attribute is 'itertools' reflecting the module it is declared in; str.__eq__('itertools') returns True; new to extra159"]
    - [repeat_module_eq_itertools,
