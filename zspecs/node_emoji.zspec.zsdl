spec: node_emoji
version: ">=1.0.0"
backend: node(node-emoji)

docs: https://github.com/omnidan/node-emoji#readme

provenance:
  derived_from:
    - "node-emoji README — https://github.com/omnidan/node-emoji#readme"
    - "Test vectors verified with node-emoji@1.11.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "node-emoji source"
  notes:
    - "node-emoji exports { get, which, has, unemojify, emojify, ... }."
    - "get(name) returns the emoji character for the given emoji name."
    - "Returns the emoji Unicode character as a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "get returns emoji string. No errors for valid emoji names."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_emoji.get:
  kind: node_module_call_eq
  function: get
  category: get
  id_prefix: emoji

  columns: [id, args, expected]
  rows:
    - [smile,   ["smile"],    "😄"]
    - [coffee,  ["coffee"],   "☕"]
    - [heart,   ["heart"],    "❤️"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:51:14Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
