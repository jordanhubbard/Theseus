spec: theseus_profile_cr
version: ">=3.8"
backend: python_cleanroom(theseus_profile_cr)
blocks: profile

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
  not_derived_from:
    - "CPython source: Lib/profile.py"
  notes:
    - "Clean-room profile module. Do NOT import profile."
    - "Profile class for pure-Python profiling."

error_model: python_exceptions

invariant theseus_profile_cr.profile2_run:
  description: "Profile.run executes statement and returns Stats"
  category: behavior
  kind: python_call_eq
  function: profile2_run
  args: []
  expected: true

invariant theseus_profile_cr.profile2_runcall:
  description: "Profile.runcall calls function and records stats"
  category: behavior
  kind: python_call_eq
  function: profile2_runcall
  args: []
  expected: true

invariant theseus_profile_cr.profile2_stats:
  description: "Stats.get_stats_profile returns function stats"
  category: behavior
  kind: python_call_eq
  function: profile2_stats
  args: []
  expected: true
