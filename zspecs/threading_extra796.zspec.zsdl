spec: threading_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any third-party threading extension"
  notes:
    - "Covers threading.Semaphore, Event, and Timer method qualnames"
    - "All checks are pure __qualname__ attribute reads — no thread instantiation required"
  created_at: "2026-04-12"

table threading_extra796.name:
  description: "threading.Semaphore and Event method qualname identity checks"
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: th796xx
  columns: [id, function, args, expected]
  rows:
    - [th796xx001, threading.Semaphore.__init__.__qualname__.__eq__, ["Semaphore.__init__"], true]
    - [th796xx002, threading.Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true]
    - [th796xx003, threading.Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true]
    - [th796xx004, threading.Semaphore.__enter__.__qualname__.__eq__, ["Semaphore.__enter__"], true]
    - [th796xx005, threading.Semaphore.__exit__.__qualname__.__eq__, ["Semaphore.__exit__"], true]
    - [th796xx006, threading.Event.__init__.__qualname__.__eq__, ["Event.__init__"], true]
    - [th796xx007, threading.Event.set.__qualname__.__eq__, ["Event.set"], true]
    - [th796xx008, threading.Event.clear.__qualname__.__eq__, ["Event.clear"], true]
    - [th796xx009, threading.Event.wait.__qualname__.__eq__, ["Event.wait"], true]
    - [th796xx010, threading.Event.is_set.__qualname__.__eq__, ["Event.is_set"], true]
    - [th796xx011, threading.Timer.__init__.__qualname__.__eq__, ["Timer.__init__"], true]
    - [th796xx012, threading.Timer.run.__qualname__.__eq__, ["Timer.run"], true]
