spec: theseus_pathlib_cr5
version: ">=3.9"
backend: python_cleanroom(theseus_pathlib_cr5)
blocks: pathlib

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
  notes:
    - "Clean-room extended pathlib utilities. Do NOT import pathlib or os.path."
    - "PurePosixPath.match(pattern): return True if path matches glob-style pattern."
    - "PurePosixPath.is_absolute(): return True if path starts with '/'."
    - "PurePosixPath.parts: tuple of path components including root '/'."
    - "pathlib5_match(): PurePosixPath('/a/b/c.py').match('*.py') == True."
    - "pathlib5_is_absolute(): PurePosixPath('/a/b').is_absolute() == True."
    - "pathlib5_parts(): PurePosixPath('/a/b/c').parts == ('/', 'a', 'b', 'c')."
    - "Zero-arg invariant signatures — def pathlib5_match(): return hardcoded_result"
    - "match: compare the last components against the pattern; '*.py' matches any .py file."
    - "is_absolute: pure string check — True if path starts with '/' (POSIX)."
    - "parts: split by '/', include '/' as root; ('/a/b/c').parts == ('/', 'a', 'b', 'c')."
    - "Export: PurePath, PurePosixPath, PureWindowsPath (pure path classes only)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_pathlib_cr5.match:
  description: "PurePosixPath('/a/b/c.py').match('*.py') == True"
  category: match
  kind: python_call_eq
  function: pathlib5_match
  args: []
  expected: true

invariant theseus_pathlib_cr5.is_absolute:
  description: "PurePosixPath('/a/b').is_absolute() == True"
  category: is_absolute
  kind: python_call_eq
  function: pathlib5_is_absolute
  args: []
  expected: true

invariant theseus_pathlib_cr5.parts:
  description: "PurePosixPath('/a/b/c').parts == ('/', 'a', 'b', 'c')"
  category: parts
  kind: python_call_eq
  function: pathlib5_parts
  args: []
  expected: ["/", "a", "b", "c"]
