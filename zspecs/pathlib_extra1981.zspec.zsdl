spec: pathlib_extra1981
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra1966.zspec.zsdl — covers __enter__/__exit__/__del__ dict-presence"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "None of the pathlib classes define __sizeof__ in their own __dict__ — inherited from object."
    - "None of the pathlib classes define __length_hint__ — path objects are not length-hintable iterators."
    - "None of the pathlib classes define __floor__, __ceil__, or __trunc__ — paths are not numeric types."
    - "pathlib.PurePath.__mro__ == [PurePath, object]; pathlib.Path.__mro__ == [Path, PurePath, object]."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath also inherit from PurePath with no numeric protocol."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — pathlib classes
# pathlib classes do not override __sizeof__; they inherit it from object.
# None define __sizeof__ in their own __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra1981.sizeof_protocol:
  description: "pathlib class __dict__.__contains__('__sizeof__') — all False (inherited from object)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1981

  columns: [id, function, args, expected]
  rows:
    - ["pl1981001", "pathlib.PurePath.__dict__.__contains__",        ["__sizeof__"], false]
    - ["pl1981002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__sizeof__"], false]
    - ["pl1981003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__sizeof__"], false]
    - ["pl1981004", "pathlib.Path.__dict__.__contains__",            ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — pathlib classes
# __length_hint__ supports PEP 424 iterator length estimation.
# pathlib path objects are not iterators; none define __length_hint__.
# ---------------------------------------------------------------------------

table pathlib_extra1981.length_hint_protocol:
  description: "pathlib class __dict__.__contains__('__length_hint__') — all False (not length-hintable iterators)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1981

  columns: [id, function, args, expected]
  rows:
    - ["pl1981005", "pathlib.PurePath.__dict__.__contains__",        ["__length_hint__"], false]
    - ["pl1981006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__length_hint__"], false]
    - ["pl1981007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__length_hint__"], false]
    - ["pl1981008", "pathlib.Path.__dict__.__contains__",            ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — pathlib classes
# pathlib types represent filesystem paths, not numeric values.
# The math rounding protocol (__floor__, __ceil__, __trunc__) does not apply.
# ---------------------------------------------------------------------------

table pathlib_extra1981.floor_protocol:
  description: "pathlib class __dict__.__contains__('__floor__') — all False (non-numeric types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1981

  columns: [id, function, args, expected]
  rows:
    - ["pl1981009",  "pathlib.PurePath.__dict__.__contains__",        ["__floor__"], false]
    - ["pl1981010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__floor__"], false]
    - ["pl1981011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__floor__"], false]
    - ["pl1981012", "pathlib.Path.__dict__.__contains__",            ["__floor__"], false]

