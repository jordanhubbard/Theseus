spec: decimal_extra108
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra107.zspec.zsdl."
    - "This spec covers: decimal.Decimal.__new__ qualname and type; decimal.Decimal.__complex__ qualname; decimal.Decimal.is_nan, is_finite, is_zero, is_signed qualnames and types."
    - "decimal.Decimal.__new__ type is 'builtin_function_or_method'; qualname == 'Decimal.__new__' (len 15)."
    - "decimal.Decimal has no __index__ attribute (hasattr returns False)."
    - "decimal.Decimal.__complex__.__qualname__ == 'Decimal.__complex__' (len 19)."
    - "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (len 14); type 'method_descriptor'."
    - "decimal.Decimal.is_finite.__qualname__ == 'Decimal.is_finite' (len 17); type 'method_descriptor'."
    - "decimal.Decimal.is_zero.__qualname__ == 'Decimal.is_zero' (len 15); type 'method_descriptor'."
    - "decimal.Decimal.is_signed.__qualname__ == 'Decimal.is_signed' (len 17); type 'method_descriptor'."
    - "is_finite and is_signed share qualname length 17; is_nan is shortest at 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__new__ qualname and type
# type(decimal.Decimal.__new__).__name__ == 'builtin_function_or_method'.
# decimal.Decimal.__new__.__qualname__ == 'Decimal.__new__' (15 chars).
# decimal.Decimal has no __index__ attribute.
# decimal.Decimal.__complex__.__qualname__ == 'Decimal.__complex__' (19 chars).
# ---------------------------------------------------------------------------

table decimal_extra108.Decimal_new_complex_qualnames:
  description: "decimal.Decimal.__new__ type='builtin_function_or_method', qualname='Decimal.__new__'(15); no __index__; __complex__ qualname='Decimal.__complex__'(19)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decnew108a

  columns: [id, function, args, expected, description]
  rows:
    - [new_type,            "Decimal.__new__.__class__.__name__.__eq__",      ["builtin_function_or_method"],  true,  "type(decimal.Decimal.__new__).__name__ == 'builtin_function_or_method' (C builtin; creates a new Decimal instance)"]
    - [new_qn_eq,           "Decimal.__new__.__qualname__.__eq__",            ["Decimal.__new__"],             true,  "decimal.Decimal.__new__.__qualname__ == 'Decimal.__new__' (C builtin function; allocates the Decimal object)"]
    - [new_qn_len,          "Decimal.__new__.__qualname__.__len__",           [],                              15,    "decimal.Decimal.__new__.__qualname__.__len__() == 15 ('Decimal.__new__' has 15 chars)"]
    - [complex_qn_eq,       "Decimal.__complex__.__qualname__.__eq__",        ["Decimal.__complex__"],         true,  "decimal.Decimal.__complex__.__qualname__ == 'Decimal.__complex__' (converts Decimal to complex number)"]
    - [complex_qn_len,      "Decimal.__complex__.__qualname__.__len__",       [],                              19,    "decimal.Decimal.__complex__.__qualname__.__len__() == 19 ('Decimal.__complex__' has 19 chars)"]
    - [complex_gt_new_len,  "Decimal.__complex__.__qualname__.__len__.__gt__", [15],                           true,  "len('Decimal.__complex__') > len('Decimal.__new__') (19 > 15; complex is 4 chars longer)"]
    - [new_ne_complex_str,  "Decimal.__new__.__qualname__.__eq__",            ["Decimal.__complex__"],         false, "decimal.Decimal.__new__.__qualname__ != 'Decimal.__complex__' (distinct qualname strings)"]
    - [new_type_ne_md,      "Decimal.__new__.__class__.__name__.__eq__",      ["method_descriptor"],           false, "type(decimal.Decimal.__new__).__name__ != 'method_descriptor' (it is 'builtin_function_or_method', not 'method_descriptor')"]

# ---------------------------------------------------------------------------
# decimal.Decimal.is_nan and decimal.Decimal.is_finite qualnames and types
# Both are 'method_descriptor' (C extension tp_methods entries).
# is_nan: 'Decimal.is_nan' (14 chars; shortest in this group).
# is_finite: 'Decimal.is_finite' (17 chars).
# ---------------------------------------------------------------------------

table decimal_extra108.Decimal_is_nan_is_finite_qualnames:
  description: "decimal.Decimal.is_nan qualname='Decimal.is_nan'(14), is_finite qualname='Decimal.is_finite'(17); both type 'method_descriptor'; is_nan shortest in group"
  kind: python_call_eq
  category: qualnames
  id_prefix: decnan108b

  columns: [id, function, args, expected, description]
  rows:
    - [is_nan_type,         "Decimal.is_nan.__class__.__name__.__eq__",       ["method_descriptor"],    true,  "type(decimal.Decimal.is_nan).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [is_nan_qn_eq,        "Decimal.is_nan.__qualname__.__eq__",             ["Decimal.is_nan"],       true,  "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (returns True if the value is a NaN)"]
    - [is_nan_qn_len,       "Decimal.is_nan.__qualname__.__len__",            [],                       14,    "decimal.Decimal.is_nan.__qualname__.__len__() == 14 ('Decimal.is_nan' has 14 chars; shortest in this group)"]
    - [is_finite_type,      "Decimal.is_finite.__class__.__name__.__eq__",    ["method_descriptor"],    true,  "type(decimal.Decimal.is_finite).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [is_finite_qn_eq,     "Decimal.is_finite.__qualname__.__eq__",          ["Decimal.is_finite"],    true,  "decimal.Decimal.is_finite.__qualname__ == 'Decimal.is_finite' (returns True if the value is finite, i.e., not Infinity or NaN)"]
    - [is_finite_qn_len,    "Decimal.is_finite.__qualname__.__len__",         [],                       17,    "decimal.Decimal.is_finite.__qualname__.__len__() == 17 ('Decimal.is_finite' has 17 chars)"]
    - [is_finite_gt_nan,    "Decimal.is_finite.__qualname__.__len__.__gt__",  [14],                     true,  "len('Decimal.is_finite') > len('Decimal.is_nan') (17 > 14; is_finite is three chars longer than is_nan)"]
    - [is_nan_ne_is_finite, "Decimal.is_nan.__qualname__.__eq__",             ["Decimal.is_finite"],    false, "decimal.Decimal.is_nan.__qualname__ != 'Decimal.is_finite' (distinct qualname strings though both test membership)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.is_zero and decimal.Decimal.is_signed qualnames and types
# Both are 'method_descriptor' (C extension tp_methods entries).
# is_zero: 'Decimal.is_zero' (15 chars).
# is_signed: 'Decimal.is_signed' (17 chars; same length as is_finite).
# ---------------------------------------------------------------------------

table decimal_extra108.Decimal_is_zero_is_signed_qualnames:
  description: "decimal.Decimal.is_zero qualname='Decimal.is_zero'(15), is_signed qualname='Decimal.is_signed'(17); both type 'method_descriptor'; is_signed shares len 17 with is_finite"
  kind: python_call_eq
  category: qualnames
  id_prefix: decnan108c

  columns: [id, function, args, expected, description]
  rows:
    - [is_zero_type,        "Decimal.is_zero.__class__.__name__.__eq__",      ["method_descriptor"],    true,  "type(decimal.Decimal.is_zero).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [is_zero_qn_eq,       "Decimal.is_zero.__qualname__.__eq__",            ["Decimal.is_zero"],      true,  "decimal.Decimal.is_zero.__qualname__ == 'Decimal.is_zero' (returns True if the value is zero)"]
    - [is_zero_qn_len,      "Decimal.is_zero.__qualname__.__len__",           [],                       15,    "decimal.Decimal.is_zero.__qualname__.__len__() == 15 ('Decimal.is_zero' has 15 chars)"]
    - [is_signed_type,      "Decimal.is_signed.__class__.__name__.__eq__",    ["method_descriptor"],    true,  "type(decimal.Decimal.is_signed).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [is_signed_qn_eq,     "Decimal.is_signed.__qualname__.__eq__",          ["Decimal.is_signed"],    true,  "decimal.Decimal.is_signed.__qualname__ == 'Decimal.is_signed' (returns True if the value has a negative sign)"]
    - [is_signed_qn_len,    "Decimal.is_signed.__qualname__.__len__",         [],                       17,    "decimal.Decimal.is_signed.__qualname__.__len__() == 17 ('Decimal.is_signed' has 17 chars; same length as is_finite)"]
    - [is_signed_gt_zero,   "Decimal.is_signed.__qualname__.__len__.__gt__",  [15],                     true,  "len('Decimal.is_signed') > len('Decimal.is_zero') (17 > 15; is_signed is two chars longer than is_zero)"]
    - [signed_eq_finite_len, "Decimal.is_signed.__qualname__.__len__.__eq__", [17],                     true,  "len('Decimal.is_signed') == len('Decimal.is_finite') == 17 (is_signed and is_finite share identical qualname length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra108.Decimal.__new___qualname:
  description: "decimal.Decimal.__new__.__qualname__ == 'Decimal.__new__' (length 15; type is 'builtin_function_or_method' — a C builtin rather than a 'method_descriptor' or 'wrapper_descriptor'; __new__ allocates and returns a new Decimal instance; 'Decimal.' (8) + '__new__' (7) == 15; decimal.Decimal has no __index__ attribute)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__new__.__qualname__.__eq__"
  args: ["Decimal.__new__"]
  expected: true

invariant decimal_extra108.Decimal.__complex___qualname_len:
  description: "decimal.Decimal.__complex__.__qualname__.__len__() == 19 ('Decimal.__complex__' has 19 characters; 'Decimal.' (8) + '__complex__' (11) == 19; __complex__ converts the Decimal value to a Python complex number; decimal.Decimal has no __index__ method, which would enable integer index conversion)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__complex__.__qualname__.__len__"
  args: []
  expected: 19

invariant decimal_extra108.Decimal.is_nan_qualname:
  description: "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (length 14; type is 'method_descriptor' — a C extension tp_methods entry; is_nan is the shortest qualname among the four is_* methods examined — is_nan(14) < is_zero(15) < is_finite/is_signed(17); it returns True if the Decimal is a quiet or signaling NaN)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_nan.__qualname__.__eq__"
  args: ["Decimal.is_nan"]
  expected: true

invariant decimal_extra108.Decimal.is_finite_qualname_len:
  description: "decimal.Decimal.is_finite.__qualname__.__len__() == 17 ('Decimal.is_finite' has 17 characters; 'Decimal.' (8) + 'is_finite' (9) == 17; type is 'method_descriptor'; is_finite and is_signed share this qualname length of 17; is_finite returns True when the Decimal is neither infinite nor NaN)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_finite.__qualname__.__len__"
  args: []
  expected: 17

invariant decimal_extra108.Decimal.is_zero_qualname_len:
  description: "decimal.Decimal.is_zero.__qualname__.__len__() == 15 ('Decimal.is_zero' has 15 characters; 'Decimal.' (8) + 'is_zero' (7) == 15; type is 'method_descriptor'; it falls between is_nan(14) and is_finite/is_signed(17) in qualname length; is_zero returns True for both positive and negative zero in the decimal representation)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_zero.__qualname__.__len__"
  args: []
  expected: 15
