spec: chokidar
version: ">=4.0.0"
backend: node(chokidar)

docs: https://github.com/paulmillr/chokidar#readme

provenance:
  derived_from:
    - "chokidar README — https://github.com/paulmillr/chokidar#readme"
    - "Test vectors verified with chokidar via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "chokidar source"
  notes:
    - "File-watcher with normalised cross-platform behaviour — used by webpack, vite, vitest."
    - "Install: npm install chokidar"
    - "v5 ESM only; default export is an object with watch() factory and FSWatcher class."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Watcher emits 'error' events; never throws synchronously on watch()."
  stderr: "null"
  stickiness: "Watchers persist file handles; .close() shuts down."
  codes: {}

invariant chokidar.has_watch_function:
  description: "watch() factory is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.watch.constructor.name"}
  expected: "Function"

invariant chokidar.has_FSWatcher_class:
  description: "FSWatcher class is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.FSWatcher.constructor.name"}
  expected: "Function"

invariant chokidar.watch_arity:
  description: "watch takes (paths, options?) — function.length 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.watch.length"}
  expected: 1
