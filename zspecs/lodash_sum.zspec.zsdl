spec: lodash_sum
version: ">=4.0.0"
backend: node(lodash.sum)

docs: https://lodash.com/docs/#sum

provenance:
  derived_from:
    - "lodash.sum README — https://www.npmjs.com/package/lodash.sum"
    - "Test vectors verified with lodash.sum@4.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sum exports the _.sum function directly as module.exports."
    - "sum(array) computes the sum of the values in array."
    - "Returns 0 for an empty array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number. Returns 0 for empty array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sum.sum:
  kind: node_module_call_eq
  function: ~
  category: sum
  id_prefix: lsum

  columns: [id, args, expected]
  rows:
    - [four_ints,  [[1, 2, 3, 4]],  10]
    - [empty,      [[]],            0]
    - [single,     [[5]],           5]
    - [negatives,  [[-1, -2, -3]],  -6]
    - [mixed,      [[-1, 1]],       0]

