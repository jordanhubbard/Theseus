spec: asyncio_extra265
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "asyncio is a package: __name__ == 'asyncio', __package__ == 'asyncio', __spec__.name == 'asyncio'."
    - "asyncio.__loader__ is a SourceFileLoader instance: __loader__.__class__.__name__ == 'SourceFileLoader'."
    - "asyncio.__all__ is a tuple (not a list) containing all public names re-exported from the package."
    - "Key members in __all__: 'Task', 'Future', 'Queue', 'sleep', 'get_event_loop_policy'."
    - "get_event_loop_policy is a plain Python function defined in asyncio.events; __module__ == 'asyncio.events'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — __name__, __package__, __spec__, __loader__
#
# asyncio is a package so __name__ and __package__ are both 'asyncio'.
# __spec__ is a ModuleSpec object; __loader__ is SourceFileLoader (package init).
# ---------------------------------------------------------------------------

invariant asyncio_extra265.identity.module_name:
  description: "asyncio.__name__ == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra265.identity.package:
  description: "asyncio.__package__ == 'asyncio' — package-level module"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra265.identity.spec_class:
  description: "asyncio.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant asyncio_extra265.identity.spec_name:
  description: "asyncio.__spec__.name == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra265.identity.loader_class:
  description: "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.__all__ — type and key member checks
#
# asyncio.__all__ is a tuple (not a list). It contains all public names
# re-exported by the asyncio package including Task, Future, Queue, sleep,
# get_event_loop_policy and many others.
# ---------------------------------------------------------------------------

invariant asyncio_extra265.all.type_is_tuple:
  description: "type(asyncio.__all__).__name__ == 'tuple' — asyncio exports __all__ as a tuple"
  category: all
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra265.all.contains_Task:
  description: "'Task' in asyncio.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Task"]
  expected: true

invariant asyncio_extra265.all.contains_Future:
  description: "'Future' in asyncio.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Future"]
  expected: true

invariant asyncio_extra265.all.contains_Queue:
  description: "'Queue' in asyncio.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Queue"]
  expected: true

invariant asyncio_extra265.all.contains_sleep:
  description: "'sleep' in asyncio.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["sleep"]
  expected: true

invariant asyncio_extra265.all.contains_get_event_loop_policy:
  description: "'get_event_loop_policy' in asyncio.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["get_event_loop_policy"]
  expected: true

# ---------------------------------------------------------------------------
# get_event_loop_policy — function identity
#
# asyncio.get_event_loop_policy is a plain Python function defined in
# asyncio.events. Its __name__, __qualname__, __module__, and class all
# confirm the expected import and definition location.
# ---------------------------------------------------------------------------

invariant asyncio_extra265.get_event_loop_policy.name:
  description: "asyncio.get_event_loop_policy.__name__ == 'get_event_loop_policy'"
  category: get_event_loop_policy
  kind: python_call_eq
  function: get_event_loop_policy.__name__.__eq__
  args: ["get_event_loop_policy"]
  expected: true

invariant asyncio_extra265.get_event_loop_policy.qualname:
  description: "asyncio.get_event_loop_policy.__qualname__ == 'get_event_loop_policy'"
  category: get_event_loop_policy
  kind: python_call_eq
  function: get_event_loop_policy.__qualname__.__eq__
  args: ["get_event_loop_policy"]
  expected: true

invariant asyncio_extra265.get_event_loop_policy.module:
  description: "asyncio.get_event_loop_policy.__module__ == 'asyncio.events' — defined in the events submodule"
  category: get_event_loop_policy
  kind: python_call_eq
  function: get_event_loop_policy.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra265.get_event_loop_policy.class:
  description: "asyncio.get_event_loop_policy.__class__.__name__ == 'function' — plain Python function"
  category: get_event_loop_policy
  kind: python_call_eq
  function: get_event_loop_policy.__class__.__name__.__eq__
  args: ["function"]
  expected: true
