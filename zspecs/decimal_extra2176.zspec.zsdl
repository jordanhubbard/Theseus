spec: decimal_extra2176
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal and decimal.Context do NOT define __iter__ or __next__ in their own __dict__ — decimal numbers and arithmetic contexts are not iterators."
    - "decimal.DecimalException, decimal.InvalidOperation, and decimal.DivisionByZero do not define any iterator protocol methods in their __dict__."
    - "No decimal class defines __aiter__, __anext__, __await__, __length_hint__, __reversed__, or __missing__ in its own __dict__."
    - "decimal.Decimal defines rich arithmetic operators (__add__, __sub__, __mul__, __truediv__, __pow__, etc.) but no iteration protocol."
    - "decimal.Context defines arithmetic context methods (prec, rounding, Emin, Emax) but no iteration protocol."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __iter__ dict-presence across decimal classes — all absent
#
# Decimal numbers and arithmetic contexts are not iterators.
# ---------------------------------------------------------------------------

table decimal_extra2176.iter_absent:
  description: "decimal classes __iter__ dict-presence — all false; decimal types are not iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2176
  columns: [id, function, args, expected]
  rows:
    - ["dc2176001", "decimal.Decimal.__dict__.__contains__",          ["__iter__"], false]
    - ["dc2176002", "decimal.Context.__dict__.__contains__",          ["__iter__"], false]
    - ["dc2176003", "decimal.DecimalException.__dict__.__contains__", ["__iter__"], false]
    - ["dc2176004", "decimal.InvalidOperation.__dict__.__contains__", ["__iter__"], false]
    - ["dc2176005", "decimal.DivisionByZero.__dict__.__contains__",   ["__iter__"], false]

