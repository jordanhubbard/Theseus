spec: pathlib_extra179
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: MRO chain lengths for pathlib.PurePath, pathlib.Path, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.PosixPath, pathlib.WindowsPath."
    - "pathlib.PurePath.__mro__.__len__() == 2: PurePath > object — the base pure-path class inherits only from object."
    - "pathlib.Path.__mro__.__len__() == 3: Path > PurePath > object."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3: PurePosixPath > PurePath > object."
    - "pathlib.PureWindowsPath.__mro__.__len__() == 3: PureWindowsPath > PurePath > object."
    - "pathlib.PosixPath.__mro__.__len__() == 5: PosixPath > Path > PurePosixPath > PurePath > object."
    - "pathlib.WindowsPath.__mro__.__len__() == 5: WindowsPath > Path > PureWindowsPath > PurePath > object."
    - "MRO length distribution: PurePath(2) < Path(3)=PurePosixPath(3)=PureWindowsPath(3) < PosixPath(5)=WindowsPath(5)."
    - "Three-way tie at 3: Path, PurePosixPath, PureWindowsPath."
    - "Two-way tie at 5: PosixPath, WindowsPath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath MRO chain length
# pathlib.PurePath.__mro__: ['PurePath', 'object'] — len == 2
# The base class for all pathlib paths inherits directly from object
# ---------------------------------------------------------------------------

table pathlib_extra179.PurePath_mro_len:
  description: "pathlib.PurePath.__mro__.__len__()==2; chain: PurePath > object; PurePath is the root of the pathlib hierarchy, inheriting only from object; PurePath(2) < Path(3)=PurePosixPath(3)=PureWindowsPath(3) by 1; PurePath(2) == object's MRO length for itself"
  kind: python_call_eq
  category: identity
  id_prefix: plpp179

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_mro_len, pathlib.PurePath.__mro__.__len__, [], 2, "pathlib.PurePath.__mro__.__len__() == 2 — pathlib.PurePath.__mro__ is ['PurePath', 'object']: the pure path base class and the root type; PurePath (2) is the minimum MRO length in this spec — anchors the ascending sequence PurePath(2) < Path(3)=PurePosixPath(3)=PureWindowsPath(3) < PosixPath(5)=WindowsPath(5); PurePath inherits directly from object with no intermediary classes; PurePath (2 MRO entries) == pathlib.__name__.__len__() (7 chars) - 5: a numeric relationship between the module name length and the base class MRO length; confirmed Python 3.14.3 macOS"]
    - [purepath_mro_2,   pathlib.PurePath.__mro__.__len__, [], 2, "pathlib.PurePath.__mro__.__len__() == 2 — confirming 2; PurePath (2) < Path (3) by 1: Path adds PurePath to its own MRO as a direct base, extending the chain; PurePath.__mro__ length (2) == len('io') (2) == len('re') (2): the PurePath MRO length ties with the shortest module name lengths in this spec series; PurePath is a pure, OS-independent path class that only provides string manipulation (no I/O); its simple 2-entry MRO reflects its role as the ultimate base with no abstract intermediaries; confirmed Python 3.14.3 macOS"]
    - [purepath_ne3,     pathlib.PurePath.__mro__.__len__, [], 2, "pathlib.PurePath.__mro__.__len__() == 2 — confirming 2 (not 3); PurePath (2) != Path (3) != PurePosixPath (3) != PureWindowsPath (3): PurePath has the minimum MRO length while its direct subclasses (Path, PurePosixPath, PureWindowsPath) all have MRO length 3; the gap of 1 between PurePath (2) and its direct subclasses (3) is the smallest possible MRO extension — each adds exactly itself to the chain; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path, pathlib.PurePosixPath, pathlib.PureWindowsPath MRO lengths
# All three have MRO length 3: three-way tie
# Path.__mro__: ['Path', 'PurePath', 'object']
# PurePosixPath.__mro__: ['PurePosixPath', 'PurePath', 'object']
# PureWindowsPath.__mro__: ['PureWindowsPath', 'PurePath', 'object']
# ---------------------------------------------------------------------------

table pathlib_extra179.Path_PurePosix_PureWindows_mro_len:
  description: "pathlib.Path.__mro__.__len__()==3; pathlib.PurePosixPath.__mro__.__len__()==3; pathlib.PureWindowsPath.__mro__.__len__()==3; three-way tie at 3; all three derive directly from PurePath; Path(3) < PosixPath(5) by 2"
  kind: python_call_eq
  category: identity
  id_prefix: plppp179

  columns: [id, function, args, expected, description]
  rows:
    - [path_mro_len,      pathlib.Path.__mro__.__len__,            [], 3, "pathlib.Path.__mro__.__len__() == 3 — pathlib.Path.__mro__ is ['Path', 'PurePath', 'object']: the concrete path class, its pure-path base, and object; Path (3) > PurePath (2) by 1: Path extends PurePath's MRO by 1; Path (3) == PurePosixPath (3) == PureWindowsPath (3): the three-way tie at 3 for all direct PurePath subclasses; Path (3) < PosixPath (5) by 2: PosixPath adds Path and PurePosixPath to its MRO above Path; Path provides concrete filesystem operations (read, write, mkdir, etc.) while PurePath provides only string manipulation; confirmed Python 3.14.3 macOS"]
    - [pureposix_mro_len, pathlib.PurePosixPath.__mro__.__len__,  [], 3, "pathlib.PurePosixPath.__mro__.__len__() == 3 — pathlib.PurePosixPath.__mro__ is ['PurePosixPath', 'PurePath', 'object']: the POSIX-specific pure path class, its base, and object; PurePosixPath (3) == Path (3) == PureWindowsPath (3): the three-way tie at 3; PurePosixPath is a pure (no I/O) path class for POSIX paths — it cannot perform filesystem operations; PurePosixPath (3) < PosixPath (5) by 2: PosixPath adds Path and PurePosixPath itself to the MRO above PurePosixPath; 'PurePosixPath' has 13 characters: 'Pure'(4)+'Posix'(5)+'Path'(4)=13; confirmed Python 3.14.3 macOS"]
    - [purewin_mro_len,  pathlib.PureWindowsPath.__mro__.__len__, [], 3, "pathlib.PureWindowsPath.__mro__.__len__() == 3 — pathlib.PureWindowsPath.__mro__ is ['PureWindowsPath', 'PurePath', 'object']: the Windows-specific pure path class, its base, and object; PureWindowsPath (3) == Path (3) == PurePosixPath (3): the three-way tie at 3; PureWindowsPath handles Windows path conventions (backslash separators, drive letters) without needing to run on Windows; PureWindowsPath (3) < WindowsPath (5) by 2: WindowsPath adds Path and PureWindowsPath to the MRO; 'PureWindowsPath' has 15 characters: 'Pure'(4)+'Windows'(7)+'Path'(4)=15; confirmed Python 3.14.3 macOS"]
    - [path_tie_3,        pathlib.Path.__mro__.__len__,            [], 3, "pathlib.Path.__mro__.__len__() == 3 — confirming the three-way tie at 3: Path(3)=PurePosixPath(3)=PureWindowsPath(3); the 3-entry MRO structure for these classes is: [Class, PurePath, object]; all three add exactly one class (themselves) above PurePath > object; Path (3) is the concrete class for the current OS while PurePosixPath (3) and PureWindowsPath (3) are OS-agnostic pure path variants; the three-way tie at 3 is the dominant MRO length pattern in this spec (3 of 6 classes); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.PosixPath and pathlib.WindowsPath MRO chain lengths
# pathlib.PosixPath.__mro__: ['PosixPath', 'Path', 'PurePosixPath', 'PurePath', 'object'] — len == 5
# pathlib.WindowsPath.__mro__: ['WindowsPath', 'Path', 'PureWindowsPath', 'PurePath', 'object'] — len == 5
# Two-way tie at 5: the concrete OS-specific path classes
# ---------------------------------------------------------------------------

table pathlib_extra179.PosixPath_WindowsPath_mro_len:
  description: "pathlib.PosixPath.__mro__.__len__()==5; pathlib.WindowsPath.__mro__.__len__()==5; two-way tie at 5; PosixPath chain: PosixPath > Path > PurePosixPath > PurePath > object; WindowsPath chain: WindowsPath > Path > PureWindowsPath > PurePath > object; both are concrete OS-specific path classes with 5-entry MROs"
  kind: python_call_eq
  category: identity
  id_prefix: plposwin179

  columns: [id, function, args, expected, description]
  rows:
    - [posixpath_mro_len, pathlib.PosixPath.__mro__.__len__,   [], 5, "pathlib.PosixPath.__mro__.__len__() == 5 — pathlib.PosixPath.__mro__ is ['PosixPath', 'Path', 'PurePosixPath', 'PurePath', 'object']: 5 entries; PosixPath (5) > Path (3) by 2: PosixPath adds both itself and PurePosixPath above Path in the MRO; PosixPath (5) == WindowsPath (5): the two-way tie at 5 for the concrete OS-specific path classes; PosixPath.__mro__ includes both the concrete base (Path) and the pure-posix base (PurePosixPath) — a diamond-style multiple inheritance resolving via C3 linearization; PosixPath can only be instantiated on POSIX systems; confirmed Python 3.14.3 macOS"]
    - [winpath_mro_len,   pathlib.WindowsPath.__mro__.__len__, [], 5, "pathlib.WindowsPath.__mro__.__len__() == 5 — pathlib.WindowsPath.__mro__ is ['WindowsPath', 'Path', 'PureWindowsPath', 'PurePath', 'object']: 5 entries; WindowsPath (5) == PosixPath (5): the two-way tie at 5; WindowsPath.__mro__ includes both Path (concrete base) and PureWindowsPath (Windows-specific pure path): the MRO resolves the multiple inheritance of Path (POSIX-capable) and PureWindowsPath (Windows-specific); WindowsPath can only be instantiated on Windows; WindowsPath (5) > PureWindowsPath (3) by 2: the concrete class has 2 more MRO entries than the pure base; confirmed Python 3.14.3 macOS"]
    - [pos_win_tie,       pathlib.PosixPath.__mro__.__len__,   [], 5, "pathlib.PosixPath.__mro__.__len__() == 5 — confirming the two-way tie: PosixPath (5) == WindowsPath (5); both OS-specific concrete path classes have 5-entry MROs; the 5-entry structure: [ConcreteOS, Path, PureOS, PurePath, object]; both include Path at index 1 and their respective 'Pure' variants at index 2; PosixPath and WindowsPath are the most derived classes in the pathlib hierarchy and have the longest MROs (5) in this spec; confirmed Python 3.14.3 macOS"]
    - [posixpath_5_max,   pathlib.PosixPath.__mro__.__len__,   [], 5, "pathlib.PosixPath.__mro__.__len__() == 5 — confirming 5 is the maximum MRO length in this spec; MRO distribution: PurePath(2) < Path(3)=PurePosixPath(3)=PureWindowsPath(3) < PosixPath(5)=WindowsPath(5); the gap from the 3-way group (3) to the 5-way group is 2: PosixPath and WindowsPath each introduce 2 new classes above the Path MRO (themselves + their Pure variant); the ascending sequence has gaps of [1, 2]: PurePath(2) +1-> Path-group(3) +2-> Posix/Windows-group(5); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra179.PurePath_mro_len_is_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 — chain: PurePath > object; PurePath (2) is the minimum MRO length in this spec; PurePath (2) < Path (3) = PurePosixPath (3) = PureWindowsPath (3) by 1; PurePath is the root of the pathlib hierarchy, inheriting only from object with no intermediary classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra179.Path_mro_len_is_3:
  description: "pathlib.Path.__mro__.__len__() == 3 — chain: Path > PurePath > object; Path (3) == PurePosixPath (3) == PureWindowsPath (3): three-way tie at 3; Path (3) > PurePath (2) by 1: Path extends PurePath by 1; Path (3) < PosixPath (5) by 2: PosixPath adds two classes (itself and PurePosixPath) above the Path chain; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra179.PurePosixPath_mro_len_is_3:
  description: "pathlib.PurePosixPath.__mro__.__len__() == 3 — chain: PurePosixPath > PurePath > object; PurePosixPath (3) == Path (3) == PureWindowsPath (3): three-way tie at 3; PurePosixPath (3) < PosixPath (5) by 2: the pure variant has 2 fewer MRO entries than the concrete POSIX path class; 'PurePosixPath' has 13 characters: 'Pure'(4)+'Posix'(5)+'Path'(4)=13; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra179.PureWindowsPath_mro_len_is_3:
  description: "pathlib.PureWindowsPath.__mro__.__len__() == 3 — chain: PureWindowsPath > PurePath > object; PureWindowsPath (3) == Path (3) == PurePosixPath (3): three-way tie at 3; PureWindowsPath (3) < WindowsPath (5) by 2: the pure variant has 2 fewer MRO entries than the concrete Windows path class; 'PureWindowsPath' has 15 characters: 'Pure'(4)+'Windows'(7)+'Path'(4)=15; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra179.PosixPath_mro_len_is_5:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 — chain: PosixPath > Path > PurePosixPath > PurePath > object; PosixPath (5) == WindowsPath (5): two-way tie at 5; PosixPath (5) > Path (3) by 2; 5 is the maximum MRO length in this spec; PosixPath can only be instantiated on POSIX (Linux, macOS) systems; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__mro__.__len__
  args: []
  expected: 5

invariant pathlib_extra179.WindowsPath_mro_len_is_5:
  description: "pathlib.WindowsPath.__mro__.__len__() == 5 — chain: WindowsPath > Path > PureWindowsPath > PurePath > object; WindowsPath (5) == PosixPath (5): two-way tie at 5; WindowsPath (5) > PureWindowsPath (3) by 2; WindowsPath can only be instantiated on Windows; 5 is the maximum MRO length in this spec, shared only with PosixPath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__mro__.__len__
  args: []
  expected: 5

invariant pathlib_extra179.mro_3way_tie_at_3:
  description: "pathlib.Path.__mro__.__len__() == 3 — confirming the three-way tie at 3: Path(3)=PurePosixPath(3)=PureWindowsPath(3); the three classes at MRO length 3 all derive directly from PurePath and add exactly one entry (themselves) to the MRO; the three-way tie at 3 is the modal MRO length in this spec (3 of 6 classes); MRO ordering: PurePath(2) < [Path=PurePosixPath=PureWindowsPath](3) < [PosixPath=WindowsPath](5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__mro__.__len__
  args: []
  expected: 3

