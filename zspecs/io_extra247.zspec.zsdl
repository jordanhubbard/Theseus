spec: io_extra247
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "_io_extra.zspec.zsdl — covers _io-backend IOBase and RawIOBase with __module__ == '_io'"
  notes:
    - "This spec covers: io.IOBase and io.RawIOBase class identity — __name__, __module__, __qualname__, __bases__[0].__name__, __class__.__name__."
    - "io.IOBase.__module__ == 'io' — IOBase is the ABC wrapper defined in the pure Python io module, NOT the _io C extension."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase directly wraps the C extension type _IOBase."
    - "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase is an ABC, so its metaclass is ABCMeta, not type."
    - "io.RawIOBase.__module__ == 'io' — same as IOBase; the ABC wrapper is in the io module."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — RawIOBase extends the C extension _RawIOBase."
    - "io.RawIOBase.__class__.__name__ == 'ABCMeta' — RawIOBase is also an ABC with ABCMeta as metaclass."
    - "IMPORTANT: This spec uses backend python_module(io). The io module ABCs have __module__ == 'io', unlike the _io C types which have __module__ == '_io'."
    - "IOBase.__name__ == 'IOBase' — length 6; verified Python 3.14.3 macOS."
    - "IOBase.__module__ == 'io' — length 2; verified Python 3.14.3 macOS."
    - "IOBase.__bases__[0].__name__ == '_IOBase' — length 7; verified Python 3.14.3 macOS."
    - "RawIOBase.__name__ == 'RawIOBase' — length 9; verified Python 3.14.3 macOS."
    - "RawIOBase.__module__ == 'io' — length 2; verified Python 3.14.3 macOS."
    - "RawIOBase.__bases__[0].__name__ == '_RawIOBase' — length 10; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase class identity — __name__, __module__, __qualname__
# IOBase is an ABC (ABCMeta metaclass) wrapping the C type _IOBase.
# Its __module__ is 'io' (the pure Python ABC layer), not '_io'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra247.IOBase_name_module_qualname:
  description: "io.IOBase class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobase247

  columns: [id, function, args, expected]
  rows:
    - [iobase_name_eq,      IOBase.__name__.__eq__,      ["IOBase"], true]
    - [iobase_name_not_raw, IOBase.__name__.__eq__,      ["RawIOBase"], false]
    - [iobase_module_eq,    IOBase.__module__.__eq__,    ["io"],     true]
    - [iobase_module_not,   IOBase.__module__.__eq__,    ["_io"],    false]
    - [iobase_qualname_eq,  IOBase.__qualname__.__eq__,  ["IOBase"], true]

# ---------------------------------------------------------------------------
# io.IOBase __name__, __module__, __bases__[0].__name__ string lengths
# __name__='IOBase' len=6, __module__='io' len=2, __bases__[0].__name__='_IOBase' len=7
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra247.IOBase_name_module_lengths:
  description: "io.IOBase class identity string lengths: __name__=6, __module__=2, __bases__[0].__name__=7; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobase247

  columns: [id, function, args, expected]
  rows:
    - [iobase_name_len,    IOBase.__name__.__len__,    [], 6]
    - [iobase_module_len,  IOBase.__module__.__len__,  [], 2]
    - [iobase_qualname_len, IOBase.__qualname__.__len__, [], 6]

# ---------------------------------------------------------------------------
# io.RawIOBase class identity — __name__, __module__, __qualname__
# RawIOBase is an ABC (ABCMeta metaclass) wrapping the C type _RawIOBase.
# Its __module__ is 'io' (the pure Python ABC layer), not '_io'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra247.RawIOBase_name_module_qualname:
  description: "io.RawIOBase class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioraw247

  columns: [id, function, args, expected]
  rows:
    - [rawiobase_name_eq,      RawIOBase.__name__.__eq__,      ["RawIOBase"], true]
    - [rawiobase_name_not_buf, RawIOBase.__name__.__eq__,      ["BufferedIOBase"], false]
    - [rawiobase_module_eq,    RawIOBase.__module__.__eq__,    ["io"],        true]
    - [rawiobase_module_not,   RawIOBase.__module__.__eq__,    ["_io"],       false]
    - [rawiobase_qualname_eq,  RawIOBase.__qualname__.__eq__,  ["RawIOBase"], true]

# ---------------------------------------------------------------------------
# io.RawIOBase __name__, __module__ string lengths
# __name__='RawIOBase' len=9, __module__='io' len=2, __bases__[0].__name__='_RawIOBase' len=10
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra247.RawIOBase_name_module_lengths:
  description: "io.RawIOBase class identity string lengths: __name__=9, __module__=2, __bases__[0].__name__=10; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioraw247

  columns: [id, function, args, expected]
  rows:
    - [rawiobase_name_len,    RawIOBase.__name__.__len__,    [], 9]
    - [rawiobase_module_len,  RawIOBase.__module__.__len__,  [], 2]
    - [rawiobase_qualname_len, RawIOBase.__qualname__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra247.IOBase.name_eq:
  description: "io.IOBase.__name__ == 'IOBase' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra247.IOBase.module_is_io:
  description: "io.IOBase.__module__ == 'io' — IOBase is the ABC in the pure Python io module, not the _io C extension; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra247.IOBase.module_not_underscore_io:
  description: "io.IOBase.__module__ != '_io' — the io ABC layer has module 'io', unlike the underlying C type which has '_io'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["_io"]
  expected: false

invariant io_extra247.IOBase.base_name_eq:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase directly wraps the C extension type _IOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra247.IOBase.class_is_ABCMeta:
  description: "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase is an abstract base class, so its metaclass is ABCMeta, not type; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra247.RawIOBase.name_eq:
  description: "io.RawIOBase.__name__ == 'RawIOBase' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra247.RawIOBase.module_is_io:
  description: "io.RawIOBase.__module__ == 'io' — RawIOBase is the ABC in the pure Python io module, not the _io C extension; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra247.RawIOBase.base_name_eq:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — RawIOBase directly extends the C extension type _RawIOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra247.RawIOBase.class_is_ABCMeta:
  description: "io.RawIOBase.__class__.__name__ == 'ABCMeta' — RawIOBase is an abstract base class, so its metaclass is ABCMeta, not type; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true
