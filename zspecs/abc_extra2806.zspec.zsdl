spec: abc_extra2806
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra.zspec.zsdl — covers abstractmethod.__isabstractmethod__, ABC.__subclasshook__, ABC.__abstractmethods__, ABCMeta.__instancecheck__, get_cache_token"
    - "abc_extra2.zspec.zsdl — covers __name__, __module__, __qualname__, metaclass identity for ABC, ABCMeta, abstractmethod"
    - "abc_extra2791.zspec.zsdl — covers __iand__, __ior__, __ixor__ dict-presence checks"
  notes:
    - "Wave 634 theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place shift/power operators)."
    - "None of the abc public objects define __ilshift__, __irshift__, or __ipow__ in their __dict__."
    - "ABCMeta is a metaclass (type of type); ABC is the abstract base class helper; abstractmethod is a decorator."
    - "abc.abstractproperty was removed in Python 3.13; it is not covered in this spec."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — __ilshift__/__irshift__/__ipow__ dict-presence checks
#
# ABCMeta is the metaclass for abstract base classes. Its __dict__ contains
# metaclass machinery (__instancecheck__, __subclasscheck__, register, etc.)
# but no in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2806.abcmeta_operator_dict:
  description: "abc.ABCMeta __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2806am

  columns: [id, function, args, expected]
  rows:
    - ["ab2806am_ils",  abc.ABCMeta.__dict__.__contains__, ["__ilshift__"],  false]
    - ["ab2806am_irs",  abc.ABCMeta.__dict__.__contains__, ["__irshift__"],  false]
    - ["ab2806am_ipo",  abc.ABCMeta.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# abc.ABC — __ilshift__/__irshift__/__ipow__ dict-presence checks
#
# ABC is the convenience helper class for creating abstract base classes via
# inheritance. Its __dict__ is minimal (only __doc__ and __abstractmethods__).
# It does not define in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2806.abc_operator_dict:
  description: "abc.ABC __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2806abc

  columns: [id, function, args, expected]
  rows:
    - ["ab2806abc_ils",  abc.ABC.__dict__.__contains__, ["__ilshift__"],  false]
    - ["ab2806abc_irs",  abc.ABC.__dict__.__contains__, ["__irshift__"],  false]
    - ["ab2806abc_ipo",  abc.ABC.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# abc.abstractmethod — __ilshift__/__irshift__/__ipow__ dict-presence checks
#
# abstractmethod is a pure-Python decorator function. Its __dict__ holds only
# __isabstractmethod__ == True and the usual function attributes. It does not
# implement in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2806.abstractmethod_operator_dict:
  description: "abc.abstractmethod __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2806abm

  columns: [id, function, args, expected]
  rows:
    - ["ab2806abm_ils",  abc.abstractmethod.__dict__.__contains__, ["__ilshift__"],  false]
    - ["ab2806abm_irs",  abc.abstractmethod.__dict__.__contains__, ["__irshift__"],  false]
    - ["ab2806abm_ipo",  abc.abstractmethod.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# Full cross-type matrix — ABCMeta, ABC, abstractmethod × three in-place shift/power operator dunders
#
# Consolidates the 3×3 dict-presence check (excluding deprecated abstractproperty)
# in one table. Every cell is False: ABCMeta, ABC, and abstractmethod do not
# define <<=, >>=, or **= operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table abc_extra2806.all_types_ilshift_irshift_ipow_matrix:
  description: "Full 3×3 dict-presence matrix for abc.ABCMeta, abc.ABC, abc.abstractmethod vs __ilshift__/__irshift__/__ipow__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2806mx

  columns: [id, function, args, expected]
  rows:
    - ["ab2806mx_am_ils",  abc.ABCMeta.__dict__.__contains__,        ["__ilshift__"],  false]
    - ["ab2806mx_am_irs",  abc.ABCMeta.__dict__.__contains__,        ["__irshift__"],  false]
    - ["ab2806mx_am_ipo",  abc.ABCMeta.__dict__.__contains__,        ["__ipow__"],     false]
    - ["ab2806mx_ac_ils",  abc.ABC.__dict__.__contains__,            ["__ilshift__"],  false]
    - ["ab2806mx_ac_irs",  abc.ABC.__dict__.__contains__,            ["__irshift__"],  false]
    - ["ab2806mx_ac_ipo",  abc.ABC.__dict__.__contains__,            ["__ipow__"],     false]
    - ["ab2806mx_ab_ils",  abc.abstractmethod.__dict__.__contains__, ["__ilshift__"],  false]
    - ["ab2806mx_ab_irs",  abc.abstractmethod.__dict__.__contains__, ["__irshift__"],  false]
    - ["ab2806mx_ab_ipo",  abc.abstractmethod.__dict__.__contains__, ["__ipow__"],     false]
