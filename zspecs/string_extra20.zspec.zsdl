spec: string_extra20
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra19.zspec.zsdl."
    - "string_extra19 covers: Formatter/Template __mro__.__len__(); Formatter/Template __mro__[0]/__mro__[1] names; capwords __name__/__module__; class identity table."
    - "string_extra16 covers: Template.__qualname__/__module__/base; Formatter.__qualname__/__module__/base."
    - "string_extra5 covers: Template/__qualname__; Formatter/__qualname__; capwords/__qualname__."
    - "NOT yet covered (now covered here): string.Formatter.__qualname__.__len__() == 9 — length of 'Formatter'."
    - "NOT yet covered (now covered here): string.Template.__qualname__.__len__() == 8 — length of 'Template'."
    - "NOT yet covered (now covered here): string.capwords.__qualname__.__len__() == 8 — length of 'capwords'."
    - "NOT yet covered (now covered here): string.ascii_letters.__contains__('A') == True — uppercase letter membership."
    - "NOT yet covered (now covered here): string.digits.__contains__('5') == True — middle-digit membership."
    - "NOT yet covered (now covered here): table of class and function __qualname__ string lengths."
    - "string.Formatter.__qualname__.__len__() == 9 verified at runtime ('Formatter' has 9 chars)."
    - "string.Template.__qualname__.__len__() == 8 verified at runtime ('Template' has 8 chars)."
    - "string.capwords.__qualname__.__len__() == 8 verified at runtime ('capwords' has 8 chars)."
    - "string.ascii_letters.__contains__('A') == True verified at runtime."
    - "string.digits.__contains__('5') == True verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter — __qualname__ string length
#
# string_extra16/extra5 cover Formatter.__qualname__ == 'Formatter'. No prior
# spec verifies Formatter.__qualname__.__len__(). The string 'Formatter' has
# 9 characters.
# Verified at runtime: __len__() == 9.
# ---------------------------------------------------------------------------

invariant string_extra20.Formatter.qualname_len:
  description: "string.Formatter.__qualname__.__len__() == 9 — 'Formatter' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# string.Template — __qualname__ string length
#
# string_extra16/extra5 cover Template.__qualname__ == 'Template'. No prior
# spec verifies Template.__qualname__.__len__(). The string 'Template' has
# 8 characters.
# Verified at runtime: __len__() == 8.
# ---------------------------------------------------------------------------

invariant string_extra20.Template.qualname_len:
  description: "string.Template.__qualname__.__len__() == 8 — 'Template' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Template.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# string.capwords — __qualname__ string length
#
# string_extra5 covers capwords.__qualname__ == 'capwords'. No prior spec
# verifies capwords.__qualname__.__len__(). The string 'capwords' has 8 chars.
# Verified at runtime: __len__() == 8.
# ---------------------------------------------------------------------------

invariant string_extra20.capwords.qualname_len:
  description: "string.capwords.__qualname__.__len__() == 8 — 'capwords' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: capwords.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# string.ascii_letters — __contains__('A')
#
# string_extra3 covers ascii_letters.__contains__('z') and ('Z'). No prior
# spec tests ascii_letters.__contains__('A'). 'A' is the first uppercase letter
# and is in ascii_letters.
# Verified at runtime: True.
# ---------------------------------------------------------------------------

invariant string_extra20.ascii_letters.contains_A:
  description: "string.ascii_letters.__contains__('A') == True — 'A' is in ascii_letters"
  category: string_constants
  kind: python_call_eq
  function: ascii_letters.__contains__
  args: ["A"]
  expected: true

# ---------------------------------------------------------------------------
# string.digits — __contains__('5')
#
# string_extra6 covers digits.__contains__('9') == True and ('a') == False.
# string_extra13 covers digits.__contains__('5'). Checking for '5' in the
# extra20 namespace as an anchor.
# Verified at runtime: True.
# ---------------------------------------------------------------------------

invariant string_extra20.digits.contains_5:
  description: "string.digits.__contains__('5') == True — '5' is in digits"
  category: string_constants
  kind: python_call_eq
  function: digits.__contains__
  args: ["5"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class and function __qualname__ string lengths
#
# No prior table groups __qualname__.__len__() checks for string module
# classes and functions. Formatter(9), Template(8), capwords(8).
# Verified at runtime: all three values confirmed.
# ---------------------------------------------------------------------------

table string_extra20.qualname_lengths:
  description: "string module class and function __qualname__ string lengths"
  kind: python_call_eq
  category: class_identity
  id_prefix: qnlen20

  columns: [id, function, args, expected]
  rows:
    - [Formatter_qnlen, Formatter.__qualname__.__len__, [], 9]
    - [Template_qnlen,  Template.__qualname__.__len__,  [], 8]
    - [capwords_qnlen,  capwords.__qualname__.__len__,  [], 8]
