spec: abc_extra1651
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__, __set_name__, __class_getitem__"
    - "Covers: abc.ABC and abc.ABCMeta do not define __init_subclass__ in their own __dict__ (ABC subclassing machinery is handled by ABCMeta.__new__, not __init_subclass__); object's class protocol methods (__init_subclass__ present, __set_name__ absent, __class_getitem__ absent in Python 3.14); object.__subclasshook__ is present (defined on object, not ABCMeta); abc module-level attr presence."
    - "Python 3.14.4 on macOS/Darwin 25.4.0: object.__init_subclass__ is True; object.__set_name__ is False; object.__class_getitem__ is False (object does NOT define __class_getitem__ in 3.14 — only specific classes like Future, Task, Queue that explicitly opt in to generics do so). abc.ABC.__dict__ contains: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl. ABCMeta.__dict__ contains (non-underscore): __new__, register, __instancecheck__, __subclasscheck__, _dump_registry. abc has no __all__ attribute."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: abc.ABC and abc.ABCMeta do not define __init_subclass__
# The ABC subclassing machinery is implemented via ABCMeta.__new__,
# which intercepts class creation to collect __abstractmethods__.
# Neither ABC nor ABCMeta override __init_subclass__ — that hook,
# inherited from object, is not needed for ABC's mechanism.
# ---------------------------------------------------------------------------

table abc_extra1651.no_custom_init_subclass:
  description: "abc.ABC and abc.ABCMeta do not define __init_subclass__ in their own __dict__; ABCMeta subclassing is handled by ABCMeta.__new__ instead"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1651nc

  columns: [id, function, args, expected]
  rows:
    - ["ab1651nc001", "abc.ABC.__dict__.__contains__",     ["__init_subclass__"],  false]
    - ["ab1651nc002", "abc.ABCMeta.__dict__.__contains__", ["__init_subclass__"],  false]
    - ["ab1651nc003", "abc.ABC.__dict__.__contains__",     ["__set_name__"],       false]
    - ["ab1651nc004", "abc.ABCMeta.__dict__.__contains__", ["__set_name__"],       false]
    - ["ab1651nc005", "abc.ABC.__dict__.__contains__",     ["__class_getitem__"],  false]
    - ["ab1651nc006", "abc.ABCMeta.__dict__.__contains__", ["__class_getitem__"],  false]
    - ["ab1651nc007", "abc.ABCMeta.__dict__.__contains__", ["__new__"],            true]
    - ["ab1651nc008", "abc.ABCMeta.__dict__.__contains__", ["register"],           true]
    - ["ab1651nc009", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"],  true]
    - ["ab1651nc010", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"],  true]
    - ["ab1651nc011", "abc.ABCMeta.__dict__.__contains__", ["_dump_registry"],     true]
    - ["ab1651nc012", "abc.ABCMeta.__dict__.__contains__", ["__prepare__"],        false]
    - ["ab1651nc013", "abc.ABCMeta.__dict__.__contains__", ["__call__"],           false]
    - ["ab1651nc014", "abc.ABCMeta.__dict__.__contains__", ["__setattr__"],        false]
    - ["ab1651nc015", "abc.ABC.__dict__.__contains__",     ["__abstractmethods__"], true]
    - ["ab1651nc016", "abc.ABC.__dict__.__contains__",     ["_abc_impl"],          true]
    - ["ab1651nc017", "abc.ABC.__dict__.__contains__",     ["__slots__"],          true]
    - ["ab1651nc018", "abc.ABC.__dict__.__contains__",     ["__doc__"],            true]
    - ["ab1651nc019", "abc.ABC.__dict__.__contains__",     ["__module__"],         true]
    - ["ab1651nc020", "abc.ABC.__dict__.__contains__",     ["__subclasshook__"],   false]
    - ["ab1651nc021", "abc.ABCMeta.__dict__.__contains__", ["__subclasshook__"],   false]

# ---------------------------------------------------------------------------
# Table 2: object class protocol methods
# object is the root of the class hierarchy and defines the DEFAULT
# implementations of class creation hooks.
# object.__init_subclass__ — True: object defines the default no-op hook
# object.__set_name__      — False: object does NOT define __set_name__
#                            (__set_name__ is a descriptor protocol method
#                            called by type.__new__ on descriptors, not on object)
# object.__class_getitem__  — False: object does NOT define __class_getitem__
#                            in Python 3.14 (only specific generic-capable
#                            classes like list, dict, tuple, Future, Task
#                            define it explicitly).
# object.__subclasshook__  — True: defined on object (not on ABCMeta);
#                            used by ABCMeta.__subclasscheck__ as the
#                            customization hook for virtual subclass checks.
# ---------------------------------------------------------------------------

table abc_extra1651.object_class_protocol:
  description: "object's class creation and descriptor protocol methods: __init_subclass__ present, __set_name__ absent, __class_getitem__ absent, __subclasshook__ present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1651ob

  columns: [id, function, args, expected]
  rows:
    - ["ab1651ob001", "object.__dict__.__contains__", ["__init_subclass__"],  true]
    - ["ab1651ob002", "object.__dict__.__contains__", ["__set_name__"],       false]
    - ["ab1651ob003", "object.__dict__.__contains__", ["__class_getitem__"],  false]
    - ["ab1651ob004", "object.__dict__.__contains__", ["__subclasshook__"],   true]
    - ["ab1651ob005", "object.__dict__.__contains__", ["__init__"],           true]
    - ["ab1651ob006", "object.__dict__.__contains__", ["__new__"],            true]
    - ["ab1651ob007", "object.__dict__.__contains__", ["__del__"],            false]
    - ["ab1651ob008", "object.__dict__.__contains__", ["__repr__"],           true]
    - ["ab1651ob009", "object.__dict__.__contains__", ["__str__"],            true]
    - ["ab1651ob010", "object.__dict__.__contains__", ["__eq__"],             true]
    - ["ab1651ob011", "object.__dict__.__contains__", ["__hash__"],           true]
    - ["ab1651ob012", "object.__dict__.__contains__", ["__doc__"],            true]
    - ["ab1651ob013", "object.__dict__.__contains__", ["__dir__"],            true]
    - ["ab1651ob014", "object.__dict__.__contains__", ["__format__"],         true]
    - ["ab1651ob015", "object.__dict__.__contains__", ["__sizeof__"],         true]
    - ["ab1651ob016", "object.__dict__.__contains__", ["__reduce__"],         true]
    - ["ab1651ob017", "object.__dict__.__contains__", ["__reduce_ex__"],      true]
    - ["ab1651ob018", "object.__dict__.__contains__", ["__getattribute__"],   true]
    - ["ab1651ob019", "object.__dict__.__contains__", ["__setattr__"],        true]
    - ["ab1651ob020", "object.__dict__.__contains__", ["__delattr__"],        true]
    - ["ab1651ob021", "object.__dict__.__contains__", ["__lt__"],             false]
    - ["ab1651ob022", "object.__dict__.__contains__", ["__gt__"],             false]
    - ["ab1651ob023", "object.__dict__.__contains__", ["__le__"],             false]
    - ["ab1651ob024", "object.__dict__.__contains__", ["__ge__"],             false]
    - ["ab1651ob025", "object.__dict__.__contains__", ["__ne__"],             false]

# ---------------------------------------------------------------------------
# Table 3: abc module-level attribute presence
# Checks that key public names are present in abc.__dict__
# abc has no __all__ attribute (not defined by the abc module itself).
# ---------------------------------------------------------------------------

table abc_extra1651.abc_module_attrs:
  description: "abc module-level attribute presence — key public names, deprecated aliases, and module metadata"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1651ma

  columns: [id, function, args, expected]
  rows:
    - ["ab1651ma001", "abc.__dict__.__contains__", ["ABCMeta"],              true]
    - ["ab1651ma002", "abc.__dict__.__contains__", ["ABC"],                  true]
    - ["ab1651ma003", "abc.__dict__.__contains__", ["abstractmethod"],       true]
    - ["ab1651ma004", "abc.__dict__.__contains__", ["get_cache_token"],      true]
    - ["ab1651ma005", "abc.__dict__.__contains__", ["update_abstractmethods"], true]
    - ["ab1651ma006", "abc.__dict__.__contains__", ["abstractclassmethod"],  true]
    - ["ab1651ma007", "abc.__dict__.__contains__", ["abstractstaticmethod"], true]
    - ["ab1651ma008", "abc.__dict__.__contains__", ["abstractproperty"],     true]
    - ["ab1651ma009", "abc.__dict__.__contains__", ["__all__"],              false]
    - ["ab1651ma010", "abc.__dict__.__contains__", ["__version__"],          false]
    - ["ab1651ma011", "abc.__dict__.__contains__", ["__name__"],             true]
    - ["ab1651ma012", "abc.__dict__.__contains__", ["__package__"],          true]
    - ["ab1651ma013", "abc.__dict__.__contains__", ["__doc__"],              true]
    - ["ab1651ma014", "abc.__dict__.__contains__", ["__spec__"],             true]
    - ["ab1651ma015", "abc.__dict__.__contains__", ["__loader__"],           true]
    - ["ab1651ma016", "abc.__dict__.__contains__", ["__file__"],             true]
    - ["ab1651ma017", "abc.__dict__.__contains__", ["__builtins__"],         true]
    - ["ab1651ma018", "abc.__dict__.__contains__", ["__init_subclass__"],    false]
    - ["ab1651ma019", "abc.__dict__.__contains__", ["__set_name__"],         false]
    - ["ab1651ma020", "abc.__dict__.__contains__", ["__class_getitem__"],    false]
    - ["ab1651ma021", "abc.__dict__.__contains__", ["abstractmethod"],       true]
    - ["ab1651ma022", "abc.__dict__.__contains__", ["ABCError"],             false]
