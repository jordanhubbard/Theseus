spec: io_extra646
version: ">=3.9"
backend: python_module(io)
docs: "Behavioral spec for io.BufferedRandom, io.FileIO, and io.TextIOWrapper method qualnames and __doc__ class identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class and method reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Qualname strings reflect standard CPython class hierarchy naming."
    - "FileIO.mode is a getset_descriptor on the class, not a plain attribute."
  created_at: "2026-04-12T00:00:00Z"

table io_extra646.bufferedrandom_qualnames:
  description: "Qualnames of io.BufferedRandom methods as reported by __qualname__."
  kind: python_call_eq
  category: qualname
  id_prefix: io646rw
  columns: [id, function, args, expected]
  rows:
    - [io646rw001, io.BufferedRandom.__init__.__qualname__.__eq__, ["BufferedRandom.__init__"], true]
    - [io646rw002, io.BufferedRandom.read.__qualname__.__eq__, ["BufferedRandom.read"], true]
    - [io646rw003, io.BufferedRandom.write.__qualname__.__eq__, ["BufferedRandom.write"], true]
    - [io646rw004, io.BufferedRandom.seek.__qualname__.__eq__, ["BufferedRandom.seek"], true]
    - [io646rw005, io.BufferedRandom.tell.__qualname__.__eq__, ["BufferedRandom.tell"], true]
    - [io646rw006, io.BufferedRandom.flush.__qualname__.__eq__, ["BufferedRandom.flush"], true]

table io_extra646.doc_class_names:
  description: "Class name of __doc__ attribute for io.BufferedRandom and io.TextIOWrapper."
  kind: python_call_eq
  category: doc_type
  id_prefix: io646dc
  columns: [id, function, args, expected]
  rows:
    - [io646dc001, io.BufferedRandom.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io646dc002, io.TextIOWrapper.__doc__.__class__.__name__.__eq__, ["str"], true]

table io_extra646.fileio_qualnames:
  description: "Qualnames of io.FileIO methods and descriptor class name for io.FileIO.mode."
  kind: python_call_eq
  category: qualname
  id_prefix: io646fi
  columns: [id, function, args, expected]
  rows:
    - [io646fi001, io.FileIO.__init__.__qualname__.__eq__, ["FileIO.__init__"], true]
    - [io646fi002, io.FileIO.readinto.__qualname__.__eq__, ["FileIO.readinto"], true]
    - [io646fi003, io.FileIO.close.__qualname__.__eq__, ["FileIO.close"], true]
    - [io646fi004, io.FileIO.mode.__class__.__name__.__eq__, ["getset_descriptor"], true]
