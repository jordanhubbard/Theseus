spec: decimal_extra1561
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for decimal classes."
    - "decimal.Decimal is a full numeric type implementing __bool__, __int__, __float__, __complex__, __trunc__, __floor__, __ceil__, __round__, __abs__ in its own __dict__."
    - "decimal.Decimal does NOT define __index__ in its own __dict__ (not usable as a sequence index)."
    - "decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow do not define any numeric conversion dunders in their own __dict__."
    - "decimal.Decimal.__dict__ also contains arithmetic dunders: __add__, __sub__, __mul__, __truediv__, __floordiv__, __mod__, __pow__, __divmod__, __neg__, __pos__, and reflected variants."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal — numeric type conversion protocol dict-presence (rich: mostly True)
# ---------------------------------------------------------------------------

table decimal_extra1561.decimal_numeric_protocol:
  description: "decimal.Decimal.__dict__ numeric type conversion dunder presence"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: dc1561dc

  columns: [id, function, args, expected]
  rows:
    - [dc1561dc001, decimal.Decimal.__dict__.__contains__, ["__bool__"],    true]
    - [dc1561dc002, decimal.Decimal.__dict__.__contains__, ["__int__"],     true]
    - [dc1561dc003, decimal.Decimal.__dict__.__contains__, ["__float__"],   true]
    - [dc1561dc004, decimal.Decimal.__dict__.__contains__, ["__complex__"], true]
    - [dc1561dc005, decimal.Decimal.__dict__.__contains__, ["__index__"],   false]
    - [dc1561dc006, decimal.Decimal.__dict__.__contains__, ["__trunc__"],   true]
    - [dc1561dc007, decimal.Decimal.__dict__.__contains__, ["__floor__"],   true]
    - [dc1561dc008, decimal.Decimal.__dict__.__contains__, ["__ceil__"],    true]
    - [dc1561dc009, decimal.Decimal.__dict__.__contains__, ["__round__"],   true]
    - [dc1561dc010, decimal.Decimal.__dict__.__contains__, ["__abs__"],     true]

