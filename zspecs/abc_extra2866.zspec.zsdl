spec: ab2866
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [abc source, Python docs, https://docs.python.org/3/library/abc.html]
  not_derived_from: [abc_extra260.zspec.zsdl, abc_extra284.zspec.zsdl, abc_extra285.zspec.zsdl, any external dataset, abc_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence, abc_extra2836.zspec.zsdl — covers __rtruediv__/__rfloordiv__/__rmod__ dict-presence]
  notes: [Wave 638 theme — __rand__/__ror__/__rxor__ dict-presence checks for abc module types. Reflected bitwise AND, OR, and XOR operators. ABC/ABCMeta/abstractmethod/abstractclassmethod/abstractstaticmethod are abstract base class infrastructure not bitwise/set-like types — none define these dunders. abstractproperty exists in Python 3.14.4 but is excluded per campaign rules for 3.13+ removal; abstractclassmethod and abstractstaticmethod are deprecated but still present in Python 3.14.4. type(abc.abstractmethod(lambda: None)) yields function whose __dict__ also lacks these dunders. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table ab2866.rand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["ab2866001", operator.contains, [abc.ABC.__dict__, "__rand__"], false]
    - ["ab2866002", operator.contains, [abc.ABCMeta.__dict__, "__rand__"], false]
    - ["ab2866003", operator.contains, [abc.abstractmethod.__dict__, "__rand__"], false]
    - ["ab2866004", operator.contains, [abc.abstractclassmethod.__dict__, "__rand__"], false]
    - ["ab2866005", operator.contains, [abc.abstractstaticmethod.__dict__, "__rand__"], false]
    - ["ab2866006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__, "__rand__"], false]

