  rows:
    - ["re2176005", "re.Pattern.__dict__.__contains__",    ["__next__"], false]
    - ["re2176006", "re.Match.__dict__.__contains__",      ["__next__"], false]
    - ["re2176007", "re.RegexFlag.__dict__.__contains__",  ["__next__"], false]
    - ["re2176008", "re.error.__dict__.__contains__",      ["__next__"], false]

# ---------------------------------------------------------------------------
# Table 3: __aiter__ and __anext__ dict-presence — all absent
#
# The re module has no async support. No re class defines async iterator
# protocol methods in its own __dict__.
# ---------------------------------------------------------------------------

table re_extra2176.aiter_anext_absent:
  description: "re classes __aiter__ and __anext__ dict-presence — all false; re has no async iteration support"
