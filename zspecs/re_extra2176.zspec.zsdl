    - ["re2176010",  "re.Pattern.__dict__.__contains__",    ["__anext__"], false]
    - ["re2176011",  "re.Match.__dict__.__contains__",      ["__aiter__"], false]
    - ["re2176012",  "re.Match.__dict__.__contains__",      ["__anext__"], false]
    - ["re2176013",  "re.RegexFlag.__dict__.__contains__",  ["__aiter__"], false]
    - ["re2176014",  "re.RegexFlag.__dict__.__contains__",  ["__anext__"], false]
    - ["re2176015",  "re.error.__dict__.__contains__",      ["__aiter__"], false]
    - ["re2176016",  "re.error.__dict__.__contains__",      ["__anext__"], false]

# ---------------------------------------------------------------------------
# Table 4: __await__, __length_hint__, __reversed__, __missing__ — all absent
#
# re classes are not awaitable, provide no size hint, do not support reverse
# iteration, and are not dict subclasses.
# ---------------------------------------------------------------------------

