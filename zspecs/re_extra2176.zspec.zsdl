spec: re_extra2176
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.Pattern, re.Match, re.RegexFlag, and re.error do NOT define __iter__ or __next__ in their own __dict__."
    - "re.Pattern.finditer() returns an iterator over Match objects but Pattern itself is not an iterator and has no __iter__ or __next__ in its __dict__."
    - "re.RegexFlag is an IntFlag enum subclass; enum members are iterable via the class but RegexFlag.__dict__ does not contain __iter__ or __next__ directly."
    - "re.error.__dict__ contains only __doc__, __firstlineno__, __init__, __module__, __static_attributes__, __weakref__ — the iterator protocol methods are absent."
    - "No re class defines __aiter__, __anext__, __await__, __length_hint__, __reversed__, or __missing__ in its own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __iter__ dict-presence across re classes — all absent
#
# Pattern, Match, RegexFlag, and error are not iterators.
# Pattern.finditer() returns an external iterator; the pattern itself is not.
# ---------------------------------------------------------------------------

table re_extra2176.iter_absent:
  description: "re classes __iter__ dict-presence — all false; re types are not iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2176
  columns: [id, function, args, expected]
  rows:
    - ["re2176001", "re.Pattern.__dict__.__contains__",    ["__iter__"], false]
    - ["re2176002", "re.Match.__dict__.__contains__",      ["__iter__"], false]
    - ["re2176003", "re.RegexFlag.__dict__.__contains__",  ["__iter__"], false]
    - ["re2176004", "re.error.__dict__.__contains__",      ["__iter__"], false]

# ---------------------------------------------------------------------------
# Table 2: __next__ dict-presence across re classes — all absent
# ---------------------------------------------------------------------------

table re_extra2176.next_absent:
  description: "re classes __next__ dict-presence — all false"
  kind: python_call_eq
  category: dict_contains
