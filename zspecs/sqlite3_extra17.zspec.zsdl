spec: sqlite3_extra17
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra16.zspec.zsdl."
    - "sqlite3_extra16 covers: Warning/__name__ standalone; Warning/__bases__[0]/__name__; InterfaceError/__bases__[0]/__name__; DatabaseError subclass __bases__[0]/__name__ table."
    - "sqlite3_extra15 covers: sqlite_version __class__.__name__; Error/__name__; DatabaseError/__name__; OperationalError/__name__; DatabaseError/__bases__[0].__name__; OperationalError/__bases__[0].__name__; PARSE_DECLTYPES == 1."
    - "sqlite3_extra14 covers: Cursor/Connection/Row __name__/__module__/__qualname__ table; connect/__qualname__; complete_statement boolean results."
    - "sqlite3_extra12 covers: Warning/InterfaceError/ProgrammingError __name__; Error/DatabaseError __module__; connect/__qualname__."
    - "No prior spec covers: register_adapter.__module__ — the C extension origin of register_adapter; verified at runtime."
    - "No prior spec covers: register_converter.__module__ — the C extension origin of register_converter; verified at runtime."
    - "No prior spec covers: enable_callback_tracebacks.__module__ — C extension function; verified at runtime."
    - "No prior spec covers: paramstyle.__class__.__name__ == 'str' — DB-API 2.0 paramstyle attribute type; verified at runtime."
    - "No prior spec covers: apilevel.__class__.__name__ == 'str' — DB-API 2.0 apilevel attribute type; verified at runtime."
    - "No prior spec covers: threadsafety.__class__.__name__ == 'int' — DB-API 2.0 threadsafety attribute type; verified at runtime."
    - "No prior spec covers: sqlite_version_info.__class__.__name__ == 'tuple' — version info tuple type; extra15 checks sqlite_version __class__.__name__ == 'str' only."
    - "sqlite3.register_adapter.__module__ == '_sqlite3' — implemented in the C extension; not checked in any prior spec."
    - "sqlite3.register_converter.__module__ == '_sqlite3' — implemented in the C extension; not checked in any prior spec."
    - "sqlite3.enable_callback_tracebacks.__module__ == '_sqlite3' — C extension function; not checked in any prior spec."
    - "sqlite3.paramstyle == 'qmark' — DB-API 2.0 required attribute; class is str."
    - "sqlite3.apilevel == '2.0' — DB-API 2.0 required attribute; class is str."
    - "sqlite3.threadsafety == 3 — DB-API 2.0 required attribute; class is int."
    - "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple' — runtime version tuple."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3 C extension function __module__ attributes — register_adapter,
# register_converter, enable_callback_tracebacks
#
# sqlite3_extra14 checks connect/__qualname__; extra12 checks connect/__module__.
# register_adapter, register_converter, and enable_callback_tracebacks are
# C extension functions whose __module__ == '_sqlite3'. No prior spec covers
# any of these three functions' __module__ attribute.
# ---------------------------------------------------------------------------

invariant sqlite3_extra17.register_adapter.module:
  description: "sqlite3.register_adapter.__module__ == '_sqlite3' — implemented in the C extension"
  category: function_attrs
  kind: python_call_eq
  function: register_adapter.__module__.__eq__
  args: ["_sqlite3"]
  expected: true

invariant sqlite3_extra17.register_converter.module:
  description: "sqlite3.register_converter.__module__ == '_sqlite3' — implemented in the C extension"
  category: function_attrs
  kind: python_call_eq
  function: register_converter.__module__.__eq__
  args: ["_sqlite3"]
  expected: true

invariant sqlite3_extra17.enable_callback_tracebacks.module:
  description: "sqlite3.enable_callback_tracebacks.__module__ == '_sqlite3' — C extension function"
  category: function_attrs
  kind: python_call_eq
  function: enable_callback_tracebacks.__module__.__eq__
  args: ["_sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# DB-API 2.0 attribute types — paramstyle, apilevel, threadsafety
#
# DB-API 2.0 (PEP 249) requires paramstyle (str), apilevel (str), and
# threadsafety (int) on every compliant module. No prior sqlite3 spec checks
# these three attributes' __class__.__name__ values.
# ---------------------------------------------------------------------------

invariant sqlite3_extra17.paramstyle.class_name:
  description: "sqlite3.paramstyle.__class__.__name__ == 'str' — DB-API 2.0 paramstyle is a string"
  category: module_attrs
  kind: python_call_eq
  function: paramstyle.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra17.apilevel.class_name:
  description: "sqlite3.apilevel.__class__.__name__ == 'str' — DB-API 2.0 apilevel is a string"
  category: module_attrs
  kind: python_call_eq
  function: apilevel.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra17.threadsafety.class_name:
  description: "sqlite3.threadsafety.__class__.__name__ == 'int' — DB-API 2.0 threadsafety is an int"
  category: module_attrs
  kind: python_call_eq
  function: threadsafety.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version_info.__class__.__name__
#
# sqlite3_extra15 checks sqlite_version.__class__.__name__ == 'str' (the
# string form). sqlite_version_info is the tuple form; no prior spec checks
# its __class__.__name__.
# ---------------------------------------------------------------------------

invariant sqlite3_extra17.sqlite_version_info.class_name:
  description: "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple' — runtime version tuple"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version_info.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# C extension function __module__ table — register_adapter, register_converter,
# enable_callback_tracebacks
#
# Consolidates the three C-extension function __module__ checks into a single
# table for coverage completeness. All return '_sqlite3'.
# ---------------------------------------------------------------------------

table sqlite3_extra17.c_function_modules:
  description: "sqlite3 C extension functions — __module__ == '_sqlite3'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: cfmod17

  columns: [id, function, args, expected]
  rows:
    - [register_adapter_mod,          register_adapter.__module__.__eq__,          ["_sqlite3"], true]
    - [register_converter_mod,        register_converter.__module__.__eq__,        ["_sqlite3"], true]
    - [enable_callback_tracebacks_mod, enable_callback_tracebacks.__module__.__eq__, ["_sqlite3"], true]
    - [connect_mod,                   connect.__module__.__eq__,                   ["_sqlite3"], true]
    - [complete_statement_mod,        complete_statement.__module__.__eq__,        ["_sqlite3"], true]
