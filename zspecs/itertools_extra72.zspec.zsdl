# ---------------------------------------------------------------------------
# Standalone invariants — extra72
# ---------------------------------------------------------------------------

invariant itertools_extra72.permutations_doc_str:
  description: "itertools.permutations.__doc__.__class__.__name__.__eq__('str') == True — permutations has a C-level str docstring; wave 238 __doc__ class identity; new to extra72"
  kind: python_call_eq
  function: permutations.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra72.permutations_doc_contains_permutations:
  description: "itertools.permutations.__doc__.__contains__('permutations') == True — 'permutations' appears in the permutations docstring; wave 238 __doc__ content; new to extra72"
  kind: python_call_eq
  function: permutations.__doc__.__contains__
  args: ["permutations"]
  expected: true

