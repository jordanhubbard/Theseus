#
# Wave 238 theme: zip_longest and filterfalse C type docstrings.
#
# zip_longest.__doc__.__class__.__name__   == 'str'
# zip_longest.__doc__.__contains__('zip_longest') == True
# filterfalse.__doc__.__class__.__name__   == 'str'
# filterfalse.__doc__.__contains__('function') == True
#   NOTE: 'filterfalse' does NOT appear in the filterfalse docstring body;
#   the docstring reads 'Return those items of iterable for which function(item) is false.'
#
# No prior itertools spec checks these types via itertdoc72. New to extra72.
