table itertools_extra72.zip_longest_filterfalse_doc:
  description: "zip_longest/__doc__ is str and contains 'zip_longest'; filterfalse/__doc__ is str and contains 'function'; wave 238 __doc__; new to extra72"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc72

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_doc_class_name_eq_str,
       zip_longest.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.zip_longest.__doc__.__class__.__name__.__eq__('str') == True — zip_longest is a C extension type in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks zip_longest.__doc__.__class__.__name__ via itertdoc72; new to extra72"]
    - [zip_longest_doc_contains_zip_longest,
       zip_longest.__doc__.__contains__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__doc__.__contains__('zip_longest') == True — the zip_longest type docstring reads 'Return a zip_longest object whose .__next__() method returns a tuple...' and uses the word 'zip_longest' (11 chars); str.__contains__('zip_longest') returns True; no prior itertools spec checks zip_longest.__doc__.__contains__ via itertdoc72; new to extra72"]
    - [filterfalse_doc_class_name_eq_str,
       filterfalse.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.filterfalse.__doc__.__class__.__name__.__eq__('str') == True — filterfalse is a C extension type in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks filterfalse.__doc__.__class__.__name__ via itertdoc72; new to extra72"]
    - [filterfalse_doc_contains_function,
       filterfalse.__doc__.__contains__,
       ["function"],
       true,
       "itertools.filterfalse.__doc__.__contains__('function') == True — the filterfalse type docstring reads 'Return those items of iterable for which function(item) is false.' and uses the word 'function' (8 chars); NOTE: 'filterfalse' itself does NOT appear in the docstring body; str.__contains__('function') returns True; no prior itertools spec checks filterfalse.__doc__.__contains__ via itertdoc72; new to extra72"]

