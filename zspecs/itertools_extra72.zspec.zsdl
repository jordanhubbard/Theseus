spec: itertools_extra72
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra71.zspec.zsdl."
    - "Wave 238 theme: remaining itertools C type __doc__ content — permutations, compress, dropwhile, takewhile, zip_longest, filterfalse, repeat, starmap, count."
    - "permutations.__doc__.__class__.__name__ == 'str' — permutations is a C type with a str docstring. Verified with Python 3.14.3."
    - "permutations.__doc__.__contains__('permutations') == True — the word 'permutations' appears in the permutations docstring. Verified with Python 3.14.3."
    - "compress.__doc__.__class__.__name__ == 'str' — compress is a C type with a str docstring. Verified with Python 3.14.3."
    - "compress.__doc__.__contains__('data') == True — the word 'data' appears in the compress docstring ('Return data elements corresponding to true selector elements.'). NOTE: 'compress' does NOT appear in the compress docstring body. Verified with Python 3.14.3."
    - "dropwhile.__doc__.__class__.__name__ == 'str' — dropwhile is a C type with a str docstring. Verified with Python 3.14.3."
    - "dropwhile.__doc__.__contains__('Drop') == True — the word 'Drop' appears in the dropwhile docstring ('Drop items from the iterable while predicate(item) is true.'). NOTE: 'dropwhile' does NOT appear in the docstring. Verified with Python 3.14.3."
    - "takewhile.__doc__.__class__.__name__ == 'str' — takewhile is a C type with a str docstring. Verified with Python 3.14.3."
    - "takewhile.__doc__.__contains__('successive') == True — the word 'successive' appears in the takewhile docstring. NOTE: 'takewhile' does NOT appear in the docstring body. Verified with Python 3.14.3."
    - "zip_longest.__doc__.__class__.__name__ == 'str' — zip_longest is a C type with a str docstring. Verified with Python 3.14.3."
    - "zip_longest.__doc__.__contains__('zip_longest') == True — the word 'zip_longest' appears in the zip_longest docstring. Verified with Python 3.14.3."
    - "filterfalse.__doc__.__class__.__name__ == 'str' — filterfalse is a C type with a str docstring. Verified with Python 3.14.3."
    - "filterfalse.__doc__.__contains__('function') == True — the word 'function' appears in the filterfalse docstring. NOTE: 'filterfalse' does NOT appear in the docstring body. Verified with Python 3.14.3."
    - "repeat.__doc__.__class__.__name__ == 'str' — repeat is a C type with a str docstring containing the word 'repeat'. Verified with Python 3.14.3."
    - "starmap.__doc__.__class__.__name__ == 'str' — starmap is a C type with a str docstring. Verified with Python 3.14.3."
    - "count.__doc__.__class__.__name__ == 'str' — count is a C type with a str docstring containing the word 'count'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# permutations and compress __doc__ — extra72
#
# Wave 238 theme: permutations and compress C type docstrings.
#
# permutations.__doc__.__class__.__name__ == 'str'
# permutations.__doc__.__contains__('permutations') == True
# compress.__doc__.__class__.__name__ == 'str'
# compress.__doc__.__contains__('data') == True
#   NOTE: 'compress' does NOT appear in the compress docstring body;
#   the docstring reads 'Return data elements corresponding to true selector elements.'
#
# No prior itertools spec checks these types via itertdoc72. New to extra72.
# ---------------------------------------------------------------------------

table itertools_extra72.permutations_compress_doc:
  description: "permutations/__doc__ is str and contains 'permutations'; compress/__doc__ is str and contains 'data'; wave 238 __doc__; new to extra72"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc72

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_doc_class_name_eq_str,
       permutations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.permutations.__doc__.__class__.__name__.__eq__('str') == True — permutations is a C extension type in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks permutations.__doc__.__class__.__name__ via itertdoc72; new to extra72"]
    - [permutations_doc_contains_permutations,
       permutations.__doc__.__contains__,
       ["permutations"],
       true,
       "itertools.permutations.__doc__.__contains__('permutations') == True — the permutations type docstring reads 'Return successive r-length permutations of elements in the iterable.' and uses the word 'permutations' (12 chars); str.__contains__('permutations') returns True; no prior itertools spec checks permutations.__doc__.__contains__ via itertdoc72; new to extra72"]
    - [compress_doc_class_name_eq_str,
       compress.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.compress.__doc__.__class__.__name__.__eq__('str') == True — compress is a C extension type in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks compress.__doc__.__class__.__name__ via itertdoc72; new to extra72"]
    - [compress_doc_contains_data,
       compress.__doc__.__contains__,
       ["data"],
       true,
       "itertools.compress.__doc__.__contains__('data') == True — the compress type docstring reads 'Return data elements corresponding to true selector elements.' and uses the word 'data' (4 chars); NOTE: 'compress' does NOT appear in the docstring body; str.__contains__('data') returns True; no prior itertools spec checks compress.__doc__.__contains__ via itertdoc72; new to extra72"]

# ---------------------------------------------------------------------------
# dropwhile and takewhile __doc__ — extra72
#
# Wave 238 theme: dropwhile and takewhile C type docstrings.
#
# dropwhile.__doc__.__class__.__name__ == 'str'
# dropwhile.__doc__.__contains__('Drop') == True
#   NOTE: The word 'dropwhile' does NOT appear in the docstring;
#   the docstring reads 'Drop items from the iterable while predicate(item) is true.'
# takewhile.__doc__.__class__.__name__ == 'str'
# takewhile.__doc__.__contains__('successive') == True
#   NOTE: The word 'takewhile' does NOT appear in the docstring;
#   the docstring reads 'Return successive entries from an iterable...'
#
# No prior itertools spec checks these types via itertdoc72. New to extra72.
# ---------------------------------------------------------------------------

table itertools_extra72.dropwhile_takewhile_doc:
  description: "dropwhile/__doc__ is str and contains 'Drop'; takewhile/__doc__ is str and contains 'successive'; wave 238 __doc__; new to extra72"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc72

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_doc_class_name_eq_str,
       dropwhile.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.dropwhile.__doc__.__class__.__name__.__eq__('str') == True — dropwhile is a C extension type in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks dropwhile.__doc__.__class__.__name__ via itertdoc72; new to extra72"]
    - [dropwhile_doc_contains_Drop,
       dropwhile.__doc__.__contains__,
       ["Drop"],
       true,
       "itertools.dropwhile.__doc__.__contains__('Drop') == True — the dropwhile type docstring reads 'Drop items from the iterable while predicate(item) is true. Afterwards, return every element until the iterable is exhausted.' and starts with the word 'Drop' (4 chars); NOTE: 'dropwhile' itself does NOT appear in the docstring; str.__contains__('Drop') returns True; no prior itertools spec checks dropwhile.__doc__.__contains__ via itertdoc72; new to extra72"]
    - [takewhile_doc_class_name_eq_str,
       takewhile.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.takewhile.__doc__.__class__.__name__.__eq__('str') == True — takewhile is a C extension type in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks takewhile.__doc__.__class__.__name__ via itertdoc72; new to extra72"]
    - [takewhile_doc_contains_successive,
       takewhile.__doc__.__contains__,
       ["successive"],
       true,
       "itertools.takewhile.__doc__.__contains__('successive') == True — the takewhile type docstring reads 'Return successive entries from an iterable as long as the predicate evaluates to true for each entry.' and uses the word 'successive' (10 chars); NOTE: 'takewhile' itself does NOT appear in the docstring; str.__contains__('successive') returns True; no prior itertools spec checks takewhile.__doc__.__contains__ via itertdoc72; new to extra72"]

