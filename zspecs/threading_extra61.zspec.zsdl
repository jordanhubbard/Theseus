spec: threading_extra61
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra60.zspec.zsdl."
    - "Wave 226 theme: __loader__ attribute chains (depth 2+): __loader__.__name__.__len__(), __loader__.__name__.__class__.__name__; __spec__.origin values; __spec__.submodule_search_locations checks; __version__ attribute presence/absence."
    - "threading is a pure-Python module (Lib/threading.py). Its __loader__ is an instance of SourceFileLoader from _frozen_importlib_external. SourceFileLoader instances do not have a __name__ attribute (they have .name for the module's own name, not the loader class name). The loader class name is accessed via __loader__.__class__.__name__ == 'SourceFileLoader' (16 chars, verified extra60). Wave 226 adds the depth-2 chain: __loader__.__class__.__name__.__len__() == 16."
    - "threading.__spec__.origin is a str (the absolute filesystem path to threading.py). The depth-2 check is __spec__.origin.__class__.__name__.__eq__('str'). extra60 checked __spec__.__class__.__name__.__eq__('ModuleSpec'); wave 226 goes deeper into the spec by checking the origin field's type."
    - "threading.__spec__.submodule_search_locations is None — threading is a regular module (not a package), so there are no subpackage search paths. The NoneType check uses __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). New to extra61."
    - "threading.__dict__.__contains__('__version__') is False — threading does not expose a __version__ attribute. CPython stdlib modules are versioned with Python itself and generally do not define __version__ in their module namespace. Note: threading internally uses _thread (a C extension), but threading itself does not define __version__. New to extra61."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.__loader__.__class__.__name__.__len__() — depth-2 chain — extra61
#
# Wave 226 theme: __loader__ attribute chains (depth 2+).
#
# extra60 covered: __loader__.__class__.__name__.__eq__('SourceFileLoader') == True
# Wave 226 goes deeper: __loader__.__class__.__name__.__len__() == 16
#
# threading.__loader__ is a SourceFileLoader instance (not the class itself).
# SourceFileLoader instances have no __name__ attribute; the loader class name
# is accessed via __loader__.__class__.__name__ == 'SourceFileLoader'.
# 'SourceFileLoader' has 16 characters: S-o-u-r-c-e-F-i-l-e-L-o-a-d-e-r.
#
# Note: threading internally imports _thread (Modules/_threadmodule.c, a C
# extension). But threading itself is Lib/threading.py — a pure-Python source
# file. The __loader__ attribute reflects the loader for the threading module
# itself, not for _thread. The loader class name is 'SourceFileLoader' (16 chars).
#
# No prior threading spec has a table row checking __loader__.__class__.__name__.__len__()==16.
# New to extra61.
# ---------------------------------------------------------------------------

table threading_extra61.loader_name_len:
  description: "threading.__loader__.__class__.__name__.__len__()==16 — 'SourceFileLoader' is 16 chars; depth-2 chain beyond the __eq__ check in extra60; wave 226 __loader__ depth-2 chain; new to extra61"
  kind: python_call_eq
  category: string_length
  id_prefix: thrdspec61

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_len_eq_16,
       __loader__.__class__.__name__.__len__,
       [],
       16,
       "threading.__loader__.__class__.__name__.__len__() == 16 — threading.__loader__ is a SourceFileLoader instance; SourceFileLoader instances (unlike classes) do not expose __name__ directly, so the loader class name is reached via __loader__.__class__.__name__; the string 'SourceFileLoader' has exactly 16 characters (S-o-u-r-c-e-F-i-l-e-L-o-a-d-e-r); __len__() on a str returns the character count as a Python int; this is a depth-3 attribute chain (__loader__ → __class__ → __name__ → __len__()) probing the loader class name length; threading is implemented in Lib/threading.py (a pure-Python source file) even though it internally imports _thread (a C extension); the __loader__ reflects the loader for the threading.py source file itself, not for _thread; extra60 verified __eq__('SourceFileLoader') == True; wave 226 adds the __len__ depth check; no prior threading spec has a table row checking __loader__.__class__.__name__.__len__()==16; new to extra61"]

# ---------------------------------------------------------------------------
# threading.__spec__.origin type check — extra61
#
# Wave 226 theme: __spec__.origin values.
#
# threading.__spec__.origin is the filesystem path to threading.py — a str.
# For pure-Python stdlib modules loaded by SourceFileLoader, the ModuleSpec
# origin field is always a str containing the absolute path to the .py source
# file. Example: '/opt/homebrew/.../lib/python3.14/threading.py'
#
# The depth-2 check: __spec__.origin.__class__.__name__.__eq__('str')
# — origin is a str whose __class__ is str, and str.__name__ == 'str' (3 chars).
#
# extra60 checked __spec__.__class__.__name__.__eq__('ModuleSpec') (the spec
# object's class). Wave 226 goes one level deeper: checking the type of the
# origin field itself.
#
# Contrast with C builtin modules (itertools): itertools.__spec__.origin == 'built-in'
# (also a str, but a sentinel value rather than a file path).
#
# No prior threading spec has a table row checking __spec__.origin.__class__.__name__.__eq__('str').
# New to extra61.
# ---------------------------------------------------------------------------

table threading_extra61.spec_origin_type:
  description: "threading.__spec__.origin.__class__.__name__.__eq__('str')==true — spec origin is a str (file path) for pure-Python modules; wave 226 __spec__.origin depth check; no prior threading spec has table rows for __spec__.origin type; new to extra61"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdspec61

  columns: [id, function, args, expected, description]
  rows:
    - [spec_origin_class_name_eq_str,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__spec__.origin.__class__.__name__.__eq__('str') == True — threading.__spec__.origin is a Python str object containing the absolute filesystem path to the threading.py source file (e.g., '/opt/homebrew/.../lib/python3.14/threading.py'); for pure-Python stdlib modules loaded by SourceFileLoader, the ModuleSpec.origin field is always a str set to the source file path; the depth-2 chain (__spec__ → origin → __class__ → __name__ → __eq__) checks the type of the origin value itself; extra60 checked __spec__.__class__.__name__ (the ModuleSpec class); wave 226 checks __spec__.origin.__class__.__name__ (the origin value's type); threading is a pure-Python module providing Thread, Lock, Event, Semaphore, Condition, Barrier, and Timer classes as high-level wrappers around the lower-level _thread C extension; its spec origin is a str file path pointing to Lib/threading.py; no prior threading spec has a table row checking __spec__.origin.__class__.__name__.__eq__('str'); new to extra61"]

# ---------------------------------------------------------------------------
# threading.__spec__.submodule_search_locations — NoneType check — extra61
#
# Wave 226 theme: __spec__.submodule_search_locations checks.
#
# threading is a regular module, not a package. Its __spec__.submodule_search_locations
# is None. The NoneType check confirms that threading is not a package and has
# no subpackage search paths.
#
# The check: __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — None.__class__ is NoneType, NoneType.__name__ == 'NoneType' (8 chars).
#
# No prior threading spec has a table row checking __spec__.submodule_search_locations.
# New to extra61.
# ---------------------------------------------------------------------------

table threading_extra61.spec_submodule_search_locations:
  description: "threading.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')==true — threading is not a package, submodule_search_locations is None; wave 226 submodule_search_locations check; new to extra61"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdspec61

  columns: [id, function, args, expected, description]
  rows:
    - [spec_submodule_search_locations_is_none,
       __spec__.submodule_search_locations.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — threading is a regular Python module (not a package); Python packages (directories containing __init__.py or namespace packages) set ModuleSpec.submodule_search_locations to a list-like object of filesystem paths enabling the import system to search for submodules within the package; regular modules like threading have submodule_search_locations == None, indicating there are no subpackage search paths; None.__class__ is the built-in NoneType and NoneType.__name__ == 'NoneType' (8 chars); threading is a single-file module (Lib/threading.py) that provides thread synchronization primitives; it is not a package even though it internally imports _thread; no prior threading spec has a table row checking __spec__.submodule_search_locations; new to extra61"]

# ---------------------------------------------------------------------------
# threading.__dict__.__contains__('__version__') — extra61
#
# Wave 226 theme: __version__ attribute presence/absence.
#
# threading does NOT define a __version__ attribute. CPython stdlib modules
# are versioned with Python itself and do not expose __version__ in their
# module namespace. threading.__dict__.__contains__('__version__') is False.
#
# Note: threading imports from _thread (which also has no __version__), but
# threading itself does not define or re-export any __version__ either.
#
# No prior threading spec has a table row checking __dict__.__contains__('__version__').
# New to extra61.
# ---------------------------------------------------------------------------

table threading_extra61.version_absence:
  description: "threading.__dict__.__contains__('__version__')==false — threading has no __version__ attribute; CPython stdlib modules do not define __version__; wave 226 __version__ presence/absence check; new to extra61"
  kind: python_call_eq
  category: membership
  id_prefix: thrdspec61

  columns: [id, function, args, expected, description]
  rows:
    - [dict_not_contains_version,
       __dict__.__contains__,
       ["__version__"],
       false,
       "threading.__dict__.__contains__('__version__') == False — threading does not define a __version__ attribute in its module namespace; CPython stdlib pure-Python modules (threading, functools, inspect) are versioned with Python itself and do not expose a standalone __version__ string; threading imports from _thread (Modules/_threadmodule.c) and re-exports several internal names, but __version__ is not among them; third-party packages typically define __version__ for version introspection via importlib.metadata or direct access, but stdlib modules rely on sys.version; '__version__' is not a key in threading.__dict__; no prior threading spec has a table row checking __dict__.__contains__('__version__'); new to extra61"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant threading_extra61.loader_class_name_len_is_16:
  description: "threading.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 chars; depth-2 __loader__ chain beyond extra60's __eq__ check; wave 226; new to extra61"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant threading_extra61.spec_origin_is_str:
  description: "threading.__spec__.origin.__class__.__name__.__eq__('str') == True — spec origin is a str file path for pure-Python modules; wave 226 __spec__.origin depth check; new to extra61"
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra61.spec_submodule_search_locations_is_NoneType:
  description: "threading.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — threading is not a package; submodule_search_locations is None; wave 226; new to extra61"
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant threading_extra61.no_version_in_dict:
  description: "threading.__dict__.__contains__('__version__') == False — threading has no __version__; CPython stdlib modules are versioned with Python itself; wave 226; new to extra61"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__version__"]
  expected: false
