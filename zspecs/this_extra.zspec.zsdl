spec: this_extra
version: ">=3.9"
backend: python_module(this)

docs: https://docs.python.org/3/library/this.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/this.html — Python this module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/this.py"
  notes:
    - "Extends this.zspec.zsdl with additional type, size, and membership invariants for s and d."
    - "this.s is a str containing the ROT-13-encoded Zen of Python text."
    - "this.d is a dict mapping every ROT-13 ciphertext letter to its plaintext counterpart."
    - "this.d covers both uppercase A-Z and lowercase a-z, giving exactly 52 entries."
    - "this.d.__contains__('A') == True and this.d.__contains__('a') == True."
    - "this.s.__contains__('Gur') == True — the encoded text begins with 'Gur Mra bs Clguba'."
    - "this.d.__class__.__name__ == 'dict' — d is a plain Python dict."
    - "this.s.__class__.__name__ == 'str' — s is a plain Python str."
    - "Verified with Python 3.12: len(this.d) == 52, 'A' in this.d, 'a' in this.d."
    - "All expected values verified by running Python 3.12 this module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Type checks — s and d
# ---------------------------------------------------------------------------

invariant this_extra.s.is_str:
  description: "this.s.__class__.__name__ == 'str' — s is a str"
  category: types
  kind: python_call_eq
  function: s.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant this_extra.d.is_dict:
  description: "this.d.__class__.__name__ == 'dict' — d is a dict"
  category: types
  kind: python_call_eq
  function: d.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# Size check — d has exactly 52 entries (A-Z and a-z)
# ---------------------------------------------------------------------------

invariant this_extra.d.len_52:
  description: "this.d.__len__() == 52 — maps all 26 uppercase and 26 lowercase ROT-13 letters"
  category: size
  kind: python_call_eq
  function: d.__len__
  args: []
  method: __eq__
  method_args: [52]
  expected: true

# ---------------------------------------------------------------------------
# Membership checks — both cases present in d
# ---------------------------------------------------------------------------

invariant this_extra.d.contains_uppercase_A:
  description: "this.d.__contains__('A') == True — uppercase letters are keys in d"
  category: membership
  kind: python_call_eq
  function: d.__contains__
  args: ["A"]
  expected: true

invariant this_extra.d.contains_lowercase_a:
  description: "this.d.__contains__('a') == True — lowercase letters are keys in d"
  category: membership
  kind: python_call_eq
  function: d.__contains__
  args: ["a"]
  expected: true

# ---------------------------------------------------------------------------
# Encoded text prefix — s starts with ROT-13 encoded 'The'
# ---------------------------------------------------------------------------

invariant this_extra.s.contains_Gur:
  description: "this.s.__contains__('Gur') == True — encoded text begins with 'Gur Mra bs Clguba'"
  category: contents
  kind: python_call_eq
  function: s.__contains__
  args: ["Gur"]
  expected: true

invariant this_extra.s.contains_encoded_title:
  description: "this.s.__contains__('Gur Mra bs Clguba') == True — ROT-13 of 'The Zen of Python'"
  category: contents
  kind: python_call_eq
  function: s.__contains__
  args: ["Gur Mra bs Clguba"]
  expected: true

# ---------------------------------------------------------------------------
# ROT-13 spot-checks for lowercase mappings in d
# ---------------------------------------------------------------------------

table this_extra.d.lowercase_cipher_mappings:
  kind: python_call_eq
  category: cipher
  id_prefix: lower_cipher

  columns: [id, function, args, expected]
  rows:
    - [a_to_n, d.__getitem__, ["a"], "n"]
    - [n_to_a, d.__getitem__, ["n"], "a"]
    - [g_to_t, d.__getitem__, ["g"], "t"]
    - [t_to_g, d.__getitem__, ["t"], "g"]
    - [z_to_m, d.__getitem__, ["z"], "m"]

# ---------------------------------------------------------------------------
# d returns str values (not ints or other types)
# ---------------------------------------------------------------------------

invariant this_extra.d.value_type_is_str:
  description: "this.d['A'] is a str (the decoded character)"
  category: types
  kind: python_call_eq
  function: d.__getitem__
  args: ["A"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
