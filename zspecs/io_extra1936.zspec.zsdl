spec: io_extra1936
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO are not descriptor types."
    - "None of the io classes define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "io module __class__.__name__ == 'module'; io class objects have __class__.__name__ == 'type'."
  created_at: "2026-04-12"
error_model: python_exceptions

table io_extra1936.descriptor_get:
  description: "io types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1936

  columns: [id, function, args, expected]
  rows:
    - ["io1936001", "io.IOBase.__dict__.__contains__",       ["__get__"], false]
    - ["io1936002", "io.RawIOBase.__dict__.__contains__",    ["__get__"], false]
    - ["io1936003", "io.BufferedIOBase.__dict__.__contains__", ["__get__"], false]
    - ["io1936004", "io.TextIOBase.__dict__.__contains__",   ["__get__"], false]
    - ["io1936005", "io.BytesIO.__dict__.__contains__",      ["__get__"], false]
    - ["io1936006", "io.StringIO.__dict__.__contains__",     ["__get__"], false]
    - ["io1936007", "io.FileIO.__dict__.__contains__",       ["__get__"], false]

