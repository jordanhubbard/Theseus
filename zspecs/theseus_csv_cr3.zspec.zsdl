spec: theseus_csv_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_csv_cr3)
blocks: csv

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html"
    - "RFC 4180 — CSV format"
  notes:
    - "Clean-room extended CSV utilities. Do NOT import csv."
    - "DictReader(f, fieldnames=None): read rows as OrderedDict/dict using header."
    - "DictWriter(f, fieldnames): write dicts to CSV file-like object."
    - "csv3_dictreader(): DictReader(['name,age', 'Alice,30'], fieldnames already in header)."
    - "csv3_dictwriter(): write {'x': '1'} to StringIO then read back — returns True."
    - "csv3_fieldnames(): DictReader with explicit fieldnames=['a','b'] has those fieldnames."
    - "Zero-arg invariant signatures — def csv3_dictreader(): return hardcoded_result"
    - "DictReader can accept a list of strings as input (each string is a row)."
    - "Export: DictReader(iterable, fieldnames=None), DictWriter(f, fieldnames)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_csv_cr3.dictreader:
  description: "DictReader reads header row and returns dicts"
  category: DictReader
  kind: python_call_eq
  function: csv3_dictreader
  args: []
  expected: "Alice"

invariant theseus_csv_cr3.dictwriter:
  description: "DictWriter writes dict rows to string buffer"
  category: DictWriter
  kind: python_call_eq
  function: csv3_dictwriter
  args: []
  expected: true

invariant theseus_csv_cr3.fieldnames:
  description: "DictReader with explicit fieldnames has correct fieldnames attribute"
  category: fieldnames
  kind: python_call_eq
  function: csv3_fieldnames
  args: []
  expected: ["a", "b"]
