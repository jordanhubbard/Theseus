spec: pathlib_extra196
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "pathlib.Path.__name__ == 'Path' (len=4); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__qualname__ == 'Path' (len=4); top-level class; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__class__.__name__ == 'type'; Path is a plain type; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__doc__.__class__.__name__ == 'str'; docstring present and is a plain string; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8); confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__doc__.__class__.__name__ == 'str'; docstring present; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__mro__.__len__() == 3: [Path, PurePath, object]; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path class identity attributes
# __name__(Path,4), __module__(pathlib,7), __qualname__(Path,4)
# ---------------------------------------------------------------------------

table pathlib_extra196.path_class_identity:
  description: "pathlib.Path class identity: __name__='Path'(4), __module__='pathlib'(7), __qualname__='Path'(4)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibclassid196

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_eq,      pathlib.Path.__name__.__eq__,             ["Path"],    true, "pathlib.Path.__name__ == 'Path'; confirmed Python 3.14.3 macOS"]
    - [path_name_len,     pathlib.Path.__name__.__len__,            [],          4,    "pathlib.Path.__name__.__len__() == 4 — P(1)a(2)t(3)h(4); confirmed Python 3.14.3 macOS"]
    - [path_module_eq,    pathlib.Path.__module__.__eq__,           ["pathlib"], true, "pathlib.Path.__module__ == 'pathlib'; confirmed Python 3.14.3 macOS"]
    - [path_module_len,   pathlib.Path.__module__.__len__,          [],          7,    "pathlib.Path.__module__.__len__() == 7 — p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [path_qualname_eq,  pathlib.Path.__qualname__.__eq__,         ["Path"],    true, "pathlib.Path.__qualname__ == 'Path'; top-level class, qualname equals simple name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path metaclass and docstring identity
# __class__(type), __doc__.__class__.__name__(str)
# ---------------------------------------------------------------------------

table pathlib_extra196.path_meta_doc:
  description: "pathlib.Path metaclass and docstring: __class__.__name__='type', __doc__.__class__.__name__='str'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibclassid196

  columns: [id, function, args, expected, description]
  rows:
    - [path_class_eq,     pathlib.Path.__class__.__name__.__eq__,         ["type"], true, "pathlib.Path.__class__.__name__ == 'type'; Path is a plain Python type; confirmed Python 3.14.3 macOS"]
    - [path_doc_cls_eq,   pathlib.Path.__doc__.__class__.__name__.__eq__, ["str"],  true, "pathlib.Path.__doc__.__class__.__name__ == 'str'; docstring is a plain Python string; confirmed Python 3.14.3 macOS"]
    - [path_qualname_len, pathlib.Path.__qualname__.__len__,              [],       4,    "pathlib.Path.__qualname__.__len__() == 4; qualname == name for top-level class; confirmed Python 3.14.3 macOS"]
    - [path_class_len,    pathlib.Path.__class__.__name__.__len__,        [],       4,    "pathlib.Path.__class__.__name__.__len__() == 4 — t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [purepath_name_eq,  pathlib.PurePath.__name__.__eq__,               ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePath class identity attributes
# __name__(PurePath,8), __module__(pathlib,7), __doc__.__class__.__name__(str)
# ---------------------------------------------------------------------------

table pathlib_extra196.purepath_class_identity:
  description: "pathlib.PurePath class identity: __name__='PurePath'(8), __module__='pathlib'(7), __doc__.__class__.__name__='str'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibclassid196

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_name_len,   pathlib.PurePath.__name__.__len__,              [],          8,    "pathlib.PurePath.__name__.__len__() == 8 — P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"]
    - [purepath_module_eq,  pathlib.PurePath.__module__.__eq__,             ["pathlib"], true, "pathlib.PurePath.__module__ == 'pathlib'; confirmed Python 3.14.3 macOS"]
    - [purepath_module_len, pathlib.PurePath.__module__.__len__,            [],          7,    "pathlib.PurePath.__module__.__len__() == 7; same module as Path; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_cls_eq, pathlib.PurePath.__doc__.__class__.__name__.__eq__, ["str"], true, "pathlib.PurePath.__doc__.__class__.__name__ == 'str'; docstring is a plain Python string; confirmed Python 3.14.3 macOS"]
    - [path_name_lt_pure,   pathlib.Path.__name__.__len__,                  [],          4,    "pathlib.Path.__name__.__len__() == 4 < PurePath.__name__.__len__() == 8; Path name shorter; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra196.path_name_eq:
  description: "pathlib.Path.__name__ == 'Path' — class name length 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra196.path_module_eq:
  description: "pathlib.Path.__module__ == 'pathlib' — attributed to the pathlib module (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra196.path_qualname_eq:
  description: "pathlib.Path.__qualname__ == 'Path' — top-level class, qualname equals simple class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__qualname__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra196.path_class_name_eq:
  description: "pathlib.Path.__class__.__name__ == 'type' — Path is a plain Python type (not ABCMeta); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra196.path_doc_class_eq:
  description: "pathlib.Path.__doc__.__class__.__name__ == 'str' — docstring is a plain Python string (not None); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra196.purepath_name_eq:
  description: "pathlib.PurePath.__name__ == 'PurePath' — base class name length 8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra196.purepath_module_eq:
  description: "pathlib.PurePath.__module__ == 'pathlib' — attributed to the pathlib module (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra196.purepath_doc_class_eq:
  description: "pathlib.PurePath.__doc__.__class__.__name__ == 'str' — PurePath docstring is a plain Python string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
