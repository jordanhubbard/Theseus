invariant asyncio_extra74.LifoQueue_name:
  description: "asyncio.LifoQueue.__name__.__eq__('LifoQueue') returns True — LifoQueue is a Python class in asyncio/queues.py; __name__ is 'LifoQueue'; NEW in extra74: first standalone __name__ invariant for LifoQueue in asynciomore74 namespace; wave 240; verified with Python 3.14.3"
  category: identity
