spec: asyncio_extra74
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra73.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition __name__/__module__/__qualname__, Task/Future __name__/__module__/__qualname__/__class__.__name__, CancelledError/InvalidStateError/TimeoutError identity, QueueEmpty/QueueFull identity, gather/sleep/wait/__name__/__qualname__, class __dict__/__mro__/__all__ metadata, method qualname/name equality and length tables, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, exception hierarchy, Queue/Lock/Event/Semaphore __init__ code object attributes, Condition/BoundedSemaphore __init__ code objects, TaskGroup identity, gather code object, Queue.put/get/qsize/empty code objects, asyncio.run class and code object."
    - "This spec covers (asynciomore74 namespace): wave 240 theme — asyncio LifoQueue/PriorityQueue deeper identity + Semaphore/BoundedSemaphore code attrs. NEW in extra74: LifoQueue.__name__=='LifoQueue'; LifoQueue.__module__=='asyncio.queues'; LifoQueue.__bases__[0].__name__=='Queue'; LifoQueue.__mro__.__len__()==4 (LifoQueue, Queue, _LoopBoundMixin, object); PriorityQueue.__name__=='PriorityQueue'; PriorityQueue.__bases__[0].__name__=='Queue'; PriorityQueue.__mro__.__len__()==4; Semaphore.acquire.__code__.co_name=='acquire'; Semaphore.acquire.__code__.co_argcount==1 (just self); BoundedSemaphore.acquire.__code__.co_name=='acquire'; BoundedSemaphore.release.__code__.co_name=='release'."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue'. LifoQueue is defined as a Python class in asyncio/queues.py; its __name__ is 'LifoQueue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__module__ == 'asyncio.queues'. LifoQueue is defined in Lib/asyncio/queues.py; __module__ is 'asyncio.queues'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'. LifoQueue directly subclasses Queue; __bases__[0].__name__ is 'Queue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__mro__.__len__() == 4. The MRO is (LifoQueue, Queue, _LoopBoundMixin, object) — 4 entries. Note: in Python 3.14 Queue also inherits _LoopBoundMixin, so MRO depth is 4, not 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue'. PriorityQueue is a Python class in asyncio/queues.py; __name__ is 'PriorityQueue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'. PriorityQueue directly subclasses Queue; __bases__[0].__name__ is 'Queue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__mro__.__len__() == 4. The MRO is (PriorityQueue, Queue, _LoopBoundMixin, object) — 4 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.acquire.__code__.co_name == 'acquire'. Semaphore.acquire is a pure Python async method in asyncio/locks.py; its code object's co_name is 'acquire'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.acquire.__code__.co_argcount == 1. Semaphore.acquire takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.acquire.__code__.co_name == 'acquire'. BoundedSemaphore.acquire is a pure Python async method; co_name is 'acquire'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.release.__code__.co_name == 'release'. BoundedSemaphore.release is a pure Python method; co_name is 'release'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio LifoQueue identity checks — extra74
#
# Wave 240 theme: LifoQueue/PriorityQueue deeper identity.
#
# LifoQueue.__name__ == 'LifoQueue'
# LifoQueue.__module__ == 'asyncio.queues'
# LifoQueue.__bases__[0].__name__ == 'Queue'
# LifoQueue.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table asyncio_extra74.LifoQueue_identity:
  description: "asyncio LifoQueue identity attribute checks in asynciomore74 namespace — wave 240 theme: LifoQueue/PriorityQueue deeper identity; LifoQueue.__name__=='LifoQueue'; LifoQueue.__module__=='asyncio.queues'; LifoQueue.__bases__[0].__name__=='Queue' (direct base class); LifoQueue.__mro__.__len__()==4 (LifoQueue, Queue, _LoopBoundMixin, object — 4 entries in Python 3.14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomore74

  columns: [id, function, args, expected, description]
  rows:
    - [lifoqueue_name,        LifoQueue.__name__.__eq__,                ["LifoQueue"],       true, "LifoQueue.__name__ == 'LifoQueue' — Python class in asyncio/queues.py; verified with Python 3.14.3"]
    - [lifoqueue_module,      LifoQueue.__module__.__eq__,              ["asyncio.queues"],  true, "LifoQueue.__module__ == 'asyncio.queues' — defined in Lib/asyncio/queues.py; verified with Python 3.14.3"]
    - [lifoqueue_base_name,   "LifoQueue.__bases__[0].__name__.__eq__", ["Queue"],           true, "LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue directly subclasses Queue; verified with Python 3.14.3"]
    - [lifoqueue_mro_len,     LifoQueue.__mro__.__len__,                [],                  4,    "LifoQueue.__mro__.__len__() == 4 — MRO: (LifoQueue, Queue, _LoopBoundMixin, object); verified with Python 3.14.3"]

