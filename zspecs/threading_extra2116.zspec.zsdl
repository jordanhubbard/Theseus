spec: threading_extra2116
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2116 (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks for threading module types."
    - "Theme: set/dict merge operators (union, intersection, symmetric-difference) — NOT numeric bitwise ops."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread does NOT define any of the nine operators — it is a thread lifecycle manager, not a collection type."
    - "threading.Lock (alias for _thread.lock) does NOT define any of the nine operators — it is a mutex primitive with acquire/release semantics only."
    - "threading.Event does NOT define any of the nine operators — it is a flag-based synchronization primitive; its set/clear/wait interface is not the Python set type protocol."
    - "threading.Condition does NOT define any of the nine operators — it is a monitor-style synchronization primitive."
    - "threading.Semaphore does NOT define any of the nine operators — it is a counting semaphore, not a set or dict type."
    - "threading.BoundedSemaphore does NOT define any of the nine operators — same rationale as Semaphore."
    - "threading.Barrier does NOT define any of the nine operators — it is a phase synchronization barrier."
    - "threading.local does NOT define any of the nine operators — it provides thread-local storage, not set/dict merging."
    - "threading.Timer does NOT define any of the nine operators — it is a Thread subclass for delayed execution."
    - "No threading synchronization primitive requires set-union, intersection, or symmetric-difference semantics; their purpose is mutual exclusion and signaling, not data combination."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __or__ / __ror__ / __ior__ dict-presence (dict-merge / set-union)
#
# None of the threading types define these in their own __dict__.
# Synchronization primitives have no set-union or dict-merge semantics.
# ---------------------------------------------------------------------------

table threading_extra2116.or_operator:
  description: "threading types __or__/__ror__/__ior__ dict-presence checks — all False (no dict-merge/set-union protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2116

  columns: [id, function, args, expected]
  rows:
    - ["th2116001", "threading.Thread.__dict__.__contains__", ["__or__"], false]
    - ["th2116002", "threading.Thread.__dict__.__contains__", ["__ror__"], false]
    - ["th2116003", "threading.Thread.__dict__.__contains__", ["__ior__"], false]
    - ["th2116004", "threading.Lock.__dict__.__contains__", ["__or__"], false]
    - ["th2116005", "threading.Lock.__dict__.__contains__", ["__ror__"], false]
    - ["th2116006", "threading.Lock.__dict__.__contains__", ["__ior__"], false]
    - ["th2116007", "threading.Event.__dict__.__contains__", ["__or__"], false]
    - ["th2116008", "threading.Event.__dict__.__contains__", ["__ror__"], false]
    - ["th2116009", "threading.Event.__dict__.__contains__", ["__ior__"], false]
    - ["th2116010", "threading.Condition.__dict__.__contains__", ["__or__"], false]
    - ["th2116011", "threading.Condition.__dict__.__contains__", ["__ror__"], false]
    - ["th2116012", "threading.Condition.__dict__.__contains__", ["__ior__"], false]
    - ["th2116013", "threading.Semaphore.__dict__.__contains__", ["__or__"], false]
    - ["th2116014", "threading.Semaphore.__dict__.__contains__", ["__ror__"], false]
    - ["th2116015", "threading.Semaphore.__dict__.__contains__", ["__ior__"], false]
    - ["th2116016", "threading.BoundedSemaphore.__dict__.__contains__", ["__or__"], false]
    - ["th2116017", "threading.BoundedSemaphore.__dict__.__contains__", ["__ror__"], false]
    - ["th2116018", "threading.BoundedSemaphore.__dict__.__contains__", ["__ior__"], false]
    - ["th2116019", "threading.Barrier.__dict__.__contains__", ["__or__"], false]
    - ["th2116020", "threading.Barrier.__dict__.__contains__", ["__ror__"], false]
    - ["th2116021", "threading.Barrier.__dict__.__contains__", ["__ior__"], false]

# ---------------------------------------------------------------------------
# Table 2: __and__ / __rand__ / __iand__ dict-presence (set-intersection)
#
# None of the threading types define these in their own __dict__.
# The & operator has no defined meaning for threading primitives.
# ---------------------------------------------------------------------------

