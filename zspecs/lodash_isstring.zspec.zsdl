spec: lodash_isstring
version: ">=4.0.0"
backend: node(lodash.isstring)

docs: https://lodash.com/docs/#isString

provenance:
  derived_from:
    - "lodash.isstring README — https://www.npmjs.com/package/lodash.isstring"
    - "Test vectors verified with lodash.isstring@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isstring exports the _.isString function directly as module.exports."
    - "isString checks if value is classified as a primitive string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isstring.isstring:
  kind: node_module_call_eq
  function: ~
  category: isstring
  id_prefix: liss

  columns: [id, args, expected]
  rows:
    - [yes_str,    ["hello"],     true]
    - [empty_str,  [""],          true]
    - [number,     [42],          false]
    - [array,      [[1, 2]],      false]
    - [object,     [{"a": 1}],   false]
    - [null_val,   [null],        false]

