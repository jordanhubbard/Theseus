spec: big_js
version: ">=7.0.1"
backend: node(big.js)

docs: https://www.npmjs.com/package/big.js

provenance:
  derived_from:
    - "big.js README — https://www.npmjs.com/package/big.js"
    - "Test vectors verified with big.js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "big.js source"
  notes:
    - "big.js is an npm package. Install: npm install big.js"
    - "Big(value) constructs an arbitrary-precision decimal; callable without new."
    - "plus()/minus()/times()/div() return new Big instances; toString() serializes."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns precise decimal value as Big instance or string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table big_js.toString:
  kind: node_factory_call_eq
  factory: ~
  method: toString
  category: format
  id_prefix: bigstr

  columns: [id, factory_args, expected]
  rows:
    - [decimal, ["3.14"],  "3.14"]
    - [integer, ["42"],    "42"]

table big_js.toFixed:
  kind: node_factory_call_eq
  factory: ~
  method: toFixed
  category: format
  id_prefix: bigfixed

  columns: [id, factory_args, method_args, expected]
  rows:
    - [two_places,   ["1.005"], [2], "1.01"]
    - [three_places, ["3.14159"], [3], "3.142"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:52:15Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
