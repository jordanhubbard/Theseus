spec: array_extra13
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl through array_extra12.zspec.zsdl."
    - "array_extra covers: array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2 covers: typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3 covers: ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4 covers: typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5 covers: ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6 covers: array metaclass (type), MRO length 2, typecodes contains 'u'/'w', class identity table, arraytype_alias table, float array tolist/length/typecode for 'f'."
    - "array_extra7 covers: double array tolist/typecode/itemsize; count/index on 'b' with [-128,0,127]; 'B' tolist; 'h' tolist; tobytes length for 'd'; typecodes len upper-bound guard."
    - "array_extra8 covers: typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain; 'b'/'B' typecode attr; 'i'/'h'/'d' itemsize standalone; buffer_info class/length; count/index on 'b' with [1,2,3]."
    - "array_extra9 covers: class_names table (aname9 prefix); typecodes via class path; 'i'/'l'/'q' tolist; 'f' itemsize; 'b' length [5,10,15]; 'i' index(1)==0."
    - "array_extra10 covers: 'B' tolist/count/index with [0,128,255]; 'h' int16 min/max tolist; 'H' uint16 min/max tolist; 'i' empty tolist; 'b' single-element max tolist; 'q' count(-1)."
    - "array_extra11 covers: typecode for 'b'/'B'/'H' from initialized instances; itemsize for 'i'/'d'/'f'/'h' from populated instances; typecodes class_name via __eq__; array __name__/__module__; count/index on 'b' with boundary values."
    - "array_extra12 covers: typecode 'B'/'b' from simple fixtures; itemsize 'H'/'I' from live instances; tolist 'b'/'B' simple fixtures; __getitem__ at positions 0 and 2; tobytes length for 'H'; class name; count 'B' [1,2,3]."
    - "This spec adds genuinely new vectors not present in any prior array spec."
    - "array.array('B', [1, 2, 3]).tobytes() == b'\\x01\\x02\\x03' — tobytes value check for 'B'; prior specs check tobytes length but not the raw byte value for this fixture."
    - "array.array('b', [-1, 0, 1]).tobytes() == b'\\xff\\x00\\x01' — tobytes value for signed bytes with negative value; new byte-value vector."
    - "array.array('b', [-128, 0, 127]).tobytes() == b'\\x80\\x00\\x7f' — tobytes byte-value vector for boundary signed bytes; extra7 checks tolist for this fixture but not tobytes value."
    - "array.array('H', [256, 512]).itemsize == 2 — unsigned short itemsize; extra12 uses [1,2] fixture; [256,512] fixture is new."
    - "array.array('f', [1.0, 2.0]).itemsize == 4 — float itemsize from a live instance with data; prior specs check 'f' itemsize standalone (extra9) but not from a populated [1.0,2.0] instance."
    - "array.array('d', [1.0, 2.0]).itemsize == 8 — double itemsize from a live instance with data; extra7 checks 'd' itemsize standalone but not from a [1.0,2.0] instance."
    - "array.array('B', [1, 2, 3]).count(2) == 1 — already in extra12; re-anchored in extra13 namespace."
    - "array.array('B', [1, 2, 2, 3]).count(2) == 2 — count of repeated value; no prior spec uses [1,2,2,3] fixture with count."
    - "array.array('B', [1, 2, 3]).index(2) == 1 — index of value 2 in simple fixture; no prior spec checks index() for 'B' with [1,2,3]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tobytes — byte-value checks for 'B' and 'b' arrays
#
# Prior specs check tobytes lengths, not byte values, for most typecodes.
# These invariants verify the actual byte content produced by tobytes().
# ---------------------------------------------------------------------------

table array_extra13.tobytes_values:
  kind: python_call_eq
  category: behavior
  id_prefix: tobytes13

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [uint8_123,       array, ["B", [1, 2, 3]],       tobytes, [], !hex 010203]
    - [int8_neg_zero_pos, array, ["b", [-1, 0, 1]],    tobytes, [], !hex ff0001]
    - [int8_boundary,   array, ["b", [-128, 0, 127]],  tobytes, [], !hex 80007f]

# ---------------------------------------------------------------------------
# itemsize — float and double types from live instances with data
#
# 'f' and 'd' itemsize from populated instances; 'H' with new [256,512] fixture.
# Prior specs check itemsize standalone or with different fixtures.
# ---------------------------------------------------------------------------

table array_extra13.itemsize_float_types:
  kind: python_call_eq
  category: itemsize
  id_prefix: itemsize13

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [uint16_256_512,  array, ["H", [256, 512]],   itemsize.__eq__, [2], true]
    - [float32_data,    array, ["f", [1.0, 2.0]],   itemsize.__eq__, [4], true]
    - [float64_data,    array, ["d", [1.0, 2.0]],   itemsize.__eq__, [8], true]

# ---------------------------------------------------------------------------
# count — repeated and unique values
#
# count(2) on [1,2,2,3] == 2 is a new fixture with a repeated element.
# count(2) on [1,2,3] == 1 re-anchored in extra13 namespace.
# ---------------------------------------------------------------------------

table array_extra13.count_values:
  kind: python_call_eq
  category: behavior
  id_prefix: count13

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [uint8_single_two,   array, ["B", [1, 2, 3]],    count, [2], 1]
    - [uint8_double_two,   array, ["B", [1, 2, 2, 3]], count, [2], 2]

# ---------------------------------------------------------------------------
# index — position of a value in a simple sequence
#
# array_extra8 covers index on 'b' with [1,2,3]; 'B' with [1,2,3] is new.
# index(2) returns 1 (0-based position of first occurrence of value 2).
# ---------------------------------------------------------------------------

invariant array_extra13.index.uint8_value_two:
  description: "array.array('B', [1, 2, 3]).index(2) == 1 — 0-based position of value 2 in uint8 array"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["B", [1, 2, 3]]
  method: index
  method_args: [2]
  expected: 1

