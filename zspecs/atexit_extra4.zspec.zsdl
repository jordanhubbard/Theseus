spec: atexit_extra4
version: ">=3.9"
backend: python_module(atexit)

docs: https://docs.python.org/3/library/atexit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/atexit.html — Python atexit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/atexitmodule.c"
  notes:
    - "Extends atexit.zspec.zsdl, atexit_extra.zspec.zsdl, atexit_extra2.zspec.zsdl, and atexit_extra3.zspec.zsdl."
    - "atexit.zspec covers: __name__ table for register/unregister/_ncallbacks/_clear; module __name__; _ncallbacks() == 0; callable checks."
    - "atexit_extra covers: register/unregister/_clear/_run_exitfuncs __name__ and __class__.__name__; _ncallbacks/__name__; module __name__."
    - "atexit_extra2 covers: unregister/_clear/_run_exitfuncs/__module__; register/__qualname__; unregister/__qualname__."
    - "atexit_extra3 covers: _clear/_run_exitfuncs/_ncallbacks __qualname__."
    - "NOT yet covered in any prior spec: _ncallbacks/__module__, _ncallbacks/__class__.__name__."
    - "NOT yet covered in any prior spec: atexit.__package__ == '' (empty string — atexit is a top-level built-in module)."
    - "NOT yet covered in any prior spec: atexit.__spec__.name == 'atexit' (ModuleSpec.name attribute)."
    - "atexit is a built-in C extension module. Its __package__ is the empty string (not None)."
    - "atexit.__spec__.name == 'atexit' — the ModuleSpec name matches the module __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _ncallbacks — __module__ and __class__.__name__
#
# atexit_extra covers __name__ and __class__.__name__ for register/unregister/
# _clear/_run_exitfuncs; atexit_extra3 covers __qualname__ for _ncallbacks.
# No prior spec records __module__ or __class__.__name__ for _ncallbacks.
# As a C builtin, _ncallbacks.__class__.__name__ == 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

invariant atexit_extra4._ncallbacks.module:
  description: "atexit._ncallbacks.__module__ == 'atexit' — C builtin reports module as 'atexit'"
  category: function_identity
  kind: python_call_eq
  function: _ncallbacks.__module__.__eq__
  args: ["atexit"]
  expected: true

invariant atexit_extra4._ncallbacks.class_name:
  description: "atexit._ncallbacks.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: _ncallbacks.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level metadata — __package__ and __spec__.name
#
# atexit is a built-in C extension module with no parent package.
# __package__ is the empty string (not None) for top-level built-in modules.
# __spec__.name is the canonical name from the ModuleSpec and equals __name__.
# No prior atexit spec covers either of these module attributes.
# ---------------------------------------------------------------------------

invariant atexit_extra4.module.package:
  description: "atexit.__package__ == '' — top-level built-in module has empty package string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant atexit_extra4.module.spec_name:
  description: "atexit.__spec__.name == 'atexit' — ModuleSpec name matches module __name__"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["atexit"]
  expected: true
