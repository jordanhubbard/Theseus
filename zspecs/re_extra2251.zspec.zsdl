spec: re_extra2251
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl"
    - "re_extra1771.zspec.zsdl"
  notes:
    - "Wave 2251, theme: callable protocol and function-attribute dict-presence."
    - "Checks __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in re class __dict__s."
    - "re.Pattern and re.Match are C extension types (sre); neither defines callable-protocol or function-attribute dunders."
    - "re.error is a Python exception subclass; also absent of callable-protocol dunders."
    - "Positive anchor rows verify real method membership (match, search, sub, group, start, etc.)."
  created_at: "2026-04-12"

table re_extra2251.callable_protocol_pattern:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["re2251001", re.Pattern.__dict__.__contains__,  ["__call__"],       false]
    - ["re2251002", re.Pattern.__dict__.__contains__,  ["__code__"],       false]
    - ["re2251003", re.Pattern.__dict__.__contains__,  ["__globals__"],    false]
    - ["re2251004", re.Pattern.__dict__.__contains__,  ["__defaults__"],   false]
    - ["re2251005", re.Pattern.__dict__.__contains__,  ["__kwdefaults__"], false]
    - ["re2251006", re.Pattern.__dict__.__contains__,  ["__annotations__"],false]
    - ["re2251007", re.Pattern.__dict__.__contains__,  ["__builtins__"],   false]

table re_extra2251.callable_protocol_match:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["re2251008", re.Match.__dict__.__contains__,    ["__call__"],       false]
    - ["re2251009", re.Match.__dict__.__contains__,    ["__code__"],       false]
    - ["re2251010", re.Match.__dict__.__contains__,    ["__globals__"],    false]
    - ["re2251011", re.Match.__dict__.__contains__,    ["__defaults__"],   false]
    - ["re2251012", re.Match.__dict__.__contains__,    ["__kwdefaults__"], false]
    - ["re2251013", re.Match.__dict__.__contains__,    ["__annotations__"],false]
    - ["re2251014", re.Match.__dict__.__contains__,    ["__builtins__"],   false]

table re_extra2251.callable_protocol_error:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["re2251015", re.error.__dict__.__contains__,    ["__call__"],       false]
    - ["re2251016", re.error.__dict__.__contains__,    ["__code__"],       false]
    - ["re2251017", re.error.__dict__.__contains__,    ["__globals__"],    false]
    - ["re2251018", re.error.__dict__.__contains__,    ["__defaults__"],   false]
    - ["re2251019", re.error.__dict__.__contains__,    ["__kwdefaults__"], false]
    - ["re2251020", re.error.__dict__.__contains__,    ["__annotations__"],false]
    - ["re2251021", re.error.__dict__.__contains__,    ["__builtins__"],   false]

table re_extra2251.positive_anchors:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["re2251022", re.Pattern.__dict__.__contains__,  ["match"],          true]
    - ["re2251023", re.Pattern.__dict__.__contains__,  ["search"],         true]
    - ["re2251024", re.Pattern.__dict__.__contains__,  ["fullmatch"],      true]
    - ["re2251025", re.Pattern.__dict__.__contains__,  ["findall"],        true]
    - ["re2251026", re.Pattern.__dict__.__contains__,  ["finditer"],       true]
    - ["re2251027", re.Pattern.__dict__.__contains__,  ["sub"],            true]
    - ["re2251028", re.Pattern.__dict__.__contains__,  ["split"],          true]
    - ["re2251029", re.Pattern.__dict__.__contains__,  ["flags"],          true]
    - ["re2251030", re.Pattern.__dict__.__contains__,  ["pattern"],        true]
    - ["re2251031", re.Pattern.__dict__.__contains__,  ["groups"],         true]
    - ["re2251032", re.Pattern.__dict__.__contains__,  ["groupindex"],     true]
    - ["re2251033", re.Match.__dict__.__contains__,    ["group"],          true]
    - ["re2251034", re.Match.__dict__.__contains__,    ["start"],          true]
    - ["re2251035", re.Match.__dict__.__contains__,    ["end"],            true]
    - ["re2251036", re.Match.__dict__.__contains__,    ["span"],           true]
    - ["re2251037", re.Match.__dict__.__contains__,    ["groups"],         true]
    - ["re2251038", re.Match.__dict__.__contains__,    ["groupdict"],      true]
    - ["re2251039", re.Match.__dict__.__contains__,    ["expand"],         true]
    - ["re2251040", re.Match.__dict__.__contains__,    ["re"],             true]
    - ["re2251041", re.Match.__dict__.__contains__,    ["string"],         true]
    - ["re2251042", re.Match.__dict__.__contains__,    ["pos"],            true]
    - ["re2251043", re.error.__dict__.__contains__,    ["__init__"],       true]
    - ["re2251044", re.error.__dict__.__contains__,    ["__doc__"],        true]
