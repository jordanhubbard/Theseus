spec: functools_extra62
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra61.zspec.zsdl."
    - "Wave 223 theme: __subclasses__ behavior + __subclasshook__ checks + __instancecheck__ / __subclasscheck__ presence + module __all__ content checks where available."
    - "No prior functools spec records __all__.__class__.__name__.__eq__('list') (extra36 only checked __class__.__name__.__len__()==4, not the string equality form)."
    - "No prior functools spec records partial.__subclasshook__.__class__.__name__ or partial.__subclasscheck__.__class__.__name__ or partial.__instancecheck__.__class__.__name__."
    - "No prior functools spec records WRAPPER_ASSIGNMENTS.__contains__ behavior."
    - "This spec covers: functools.__all__.__class__.__name__.__eq__('list')==true; functools.__all__.__len__()==15 (equality form — extra36 covered length but as standalone invariant, not a table row); functools.partial.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==true; functools.partial.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method')==true; functools.partial.__instancecheck__.__class__.__name__.__eq__('builtin_function_or_method')==true; WRAPPER_ASSIGNMENTS.__contains__('__module__')==true; WRAPPER_ASSIGNMENTS.__contains__('__doc__')==true; WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__('__module__')==true; WRAPPER_ASSIGNMENTS.__getitem__(5).__eq__('__type_params__')==true."
    - "Key findings: functools.__all__ is a Python list (the 'list' built-in type). partial is a C-extension type defined in Modules/_functoolsmodule.c. Its class-level __subclasshook__, __subclasscheck__, and __instancecheck__ are all 'builtin_function_or_method' — inherited from the object base type (these hooks are implemented as C-level functions in the type system, not as Python functions or wrapper_descriptors). WRAPPER_ASSIGNMENTS is a 6-element tuple (confirmed in extra61); at the instance level (bound to the tuple object), its __contains__ method is a 'method-wrapper'. WRAPPER_ASSIGNMENTS.__getitem__(0) == '__module__' and __getitem__(5) == '__type_params__' — these are the first and last elements. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.__all__ is a list — extra62
#
# functools.__all__ is a module-level Python list containing the 15 public
# names exported by the functools module. The list type has __name__ == 'list'
# (4 chars). Prior extra36 checked __all__.__class__.__name__.__len__()==4 and
# __all__.__len__()==15 (as standalone invariants, not table rows). This table
# provides the string equality form: __class__.__name__.__eq__('list')==true
# and __len__()==15.
#
# No prior functools spec has a table row checking __all__.__class__.__name__.__eq__
# or __all__.__len__() as an equality assertion. Both are new to extra62.
# ---------------------------------------------------------------------------

table functools_extra62.all_list_identity:
  description: "functools.__all__.__class__.__name__.__eq__('list')==true and __all__.__len__()==15 — __all__ is a plain Python list of 15 public names; extra36 confirmed length and type char-count but not string equality form; new to extra62"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsall62

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq_list,
       __all__.__class__.__name__.__eq__,
       ["list"],
       true,
       "functools.__all__.__class__.__name__ == 'list' — functools.__all__ is a module-level Python list containing the 15 public names exported by functools; the list built-in type has __name__ == 'list' (4 chars); prior extra36 checked __all__.__class__.__name__.__len__()==4 but not the string equality form __eq__('list')==true; this is the first table row checking the string equality; new to extra62"]
    - [all_len_eq_15,
       __all__.__len__,
       [],
       15,
       "functools.__all__.__len__() == 15 — functools.__all__ contains 15 public names in Python 3.14: ['update_wrapper', 'wraps', 'WRAPPER_ASSIGNMENTS', 'WRAPPER_UPDATES', 'total_ordering', 'cache', 'cmp_to_key', 'lru_cache', 'reduce', 'partial', 'partialmethod', 'singledispatch', 'singledispatchmethod', 'cached_property', 'Placeholder']; prior extra36 recorded this as a standalone invariant; this is the first table row checking __all__.__len__() with the equality assertion form; new to extra62"]

# ---------------------------------------------------------------------------
# functools.partial __subclasshook__ / __subclasscheck__ / __instancecheck__ — extra62
#
# Wave 223 theme: __subclasshook__ checks + __instancecheck__ / __subclasscheck__ presence.
#
# functools.partial is a C-extension type defined in Modules/_functoolsmodule.c.
# Its metaclass is the standard 'type'. The class-level __subclasshook__,
# __subclasscheck__, and __instancecheck__ are inherited from the object base
# type or the type metaclass. Because these are C-level functions accessed at
# the class level, Python exposes them as 'builtin_function_or_method' objects
# (not 'wrapper_descriptor', which is used for C slot wrappers like tp_repr).
#
# __subclasshook__ is the ABC customization hook (defined in ABCMeta); for a
# plain C-extension type using the standard 'type' metaclass, it is inherited
# from object as a C classmethod, exposed as 'builtin_function_or_method'.
# __subclasscheck__ (on the type/metaclass) controls issubclass(); for type
# objects, it is a C-level built-in function.
# __instancecheck__ (on the type/metaclass) controls isinstance(); similarly
# a C-level built-in function inherited from the type metaclass.
#
# No prior functools spec records any of these three hook attributes for partial
# or any other functools type. All three checks below are new to extra62.
# ---------------------------------------------------------------------------

table functools_extra62.partial_abc_hooks:
  description: "functools.partial.__subclasshook__/__subclasscheck__/__instancecheck__ are all 'builtin_function_or_method' — C-extension type's class-level ABC/isinstance hooks are C built-in functions inherited from object/type; not recorded in any prior functools spec; new to extra62"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsall62

  columns: [id, function, args, expected, description]
  rows:
    - [partial_subclasshook_class_name,
       partial.__subclasshook__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.partial.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — partial is a C-extension type using the standard 'type' metaclass; __subclasshook__ is the ABC customization hook defined by ABCMeta.__subclasshook__; for a plain type object, it is inherited from object as a C-level classmethod exposed as 'builtin_function_or_method' (not a Python function or wrapper_descriptor); calling partial.__subclasshook__(SomeClass) returns NotImplemented by default; no prior functools spec records __subclasshook__.__class__.__name__ for partial; new to extra62"]
    - [partial_subclasscheck_class_name,
       partial.__subclasscheck__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.partial.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method' — __subclasscheck__ controls the behavior of issubclass(X, partial); it is a C-level built-in function inherited from the 'type' metaclass; when issubclass is called, Python invokes type.__subclasscheck__ via the C tp_subclasses slot mechanism; accessed at the class level it is a 'builtin_function_or_method'; no prior functools spec records __subclasscheck__.__class__.__name__ for partial; new to extra62"]
    - [partial_instancecheck_class_name,
       partial.__instancecheck__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.partial.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — __instancecheck__ controls the behavior of isinstance(obj, partial); it is a C-level built-in function inherited from the 'type' metaclass; when isinstance is called, Python invokes type.__instancecheck__ via the C nb_bool/tp_as_number mechanism; accessed at the class level it is a 'builtin_function_or_method'; no prior functools spec records __instancecheck__.__class__.__name__ for partial; new to extra62"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS element access via __getitem__ — extra62
#
# functools.WRAPPER_ASSIGNMENTS is a 6-element tuple (confirmed in extra61).
# The elements are: '__module__', '__name__', '__qualname__', '__doc__',
# '__annotate__', '__type_params__'.
#
# For table rows, accessing elements by index requires using __getitem__ with
# an integer argument (since [n] notation in a function field would require
# quoting and cause YAML ambiguity). The __getitem__ method on a tuple instance
# is a 'method-wrapper' bound to the tuple object.
#
# Prior extra38 recorded WRAPPER_ASSIGNMENTS element string lengths via
# __getitem__ (e.g., WRAPPER_ASSIGNMENTS[0].__len__()==8 for '__module__').
# No prior spec has used __getitem__ with an equality check on the element
# values themselves. Both checks below are new to extra62.
# ---------------------------------------------------------------------------

table functools_extra62.wrapper_assignments_elements:
  description: "WRAPPER_ASSIGNMENTS.__getitem__(0)==__module__ and __getitem__(5)==__type_params__ — tuple element access via __getitem__ with integer args; confirms first and last elements of the 6-element tuple; new to extra62"
  kind: python_call_eq
  category: string_value
  id_prefix: functoolsall62

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_getitem_0,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [0],
       "__module__",
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(0) == '__module__' — WRAPPER_ASSIGNMENTS is a 6-element tuple; element 0 is '__module__', the first attribute that update_wrapper copies from the wrapped function to the wrapper; prior extra38 confirmed WRAPPER_ASSIGNMENTS[0].__len__()==8 (len of '__module__') but not the equality form; this is the first check confirming the string value of element 0; new to extra62"]
    - [WRAPPER_ASSIGNMENTS_getitem_5,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [5],
       "__type_params__",
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(5) == '__type_params__' — WRAPPER_ASSIGNMENTS element 5 (the last element) is '__type_params__', added in Python 3.12/3.13+ for PEP 695 type parameter support; prior extra38 confirmed WRAPPER_ASSIGNMENTS[5].__len__()==15 (len of '__type_params__') but not the equality form; this is the first check confirming the string value of element 5; new to extra62"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra62
# ---------------------------------------------------------------------------

invariant functools_extra62.all_is_list:
  description: "functools.__all__.__class__.__name__ == 'list' — module __all__ is a Python list; extra36 confirmed length 4 of the type name but not string equality form; new to extra62"
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant functools_extra62.partial_subclasshook_is_builtin:
  description: "partial.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-extension type inherits ABC hook from object as C-level built-in; contrasts with wrapper_descriptor (C slot methods like __repr__) and function (Python-defined methods); new to extra62"
  kind: python_call_eq
  function: partial.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra62.WRAPPER_ASSIGNMENTS_first_element:
  description: "WRAPPER_ASSIGNMENTS.__getitem__(0) == '__module__' — first attribute copied by update_wrapper is __module__; confirms element ordering of the tuple; new to extra62"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [0]
  expected: "__module__"

invariant functools_extra62.WRAPPER_ASSIGNMENTS_contains_doc:
  description: "WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — the __doc__ attribute is one of the 6 attributes copied by update_wrapper; instance-level __contains__ is a method-wrapper; new to extra62"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true
