spec: alphanum_sort
version: ">=1.0.0"
backend: node(alphanum-sort)

docs: https://github.com/TrySound/alphanum-sort#readme

provenance:
  derived_from:
    - "alphanum-sort README — https://github.com/TrySound/alphanum-sort#readme"
    - "Test vectors verified with alphanum-sort via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "alphanum-sort source"
  notes:
    - "Natural-order sort — 'a2' before 'a10', not after as in lexicographic order."
    - "Install: npm install alphanum-sort"
    - "v1 CJS; module export IS the sort function."
    - "{insensitive: true} folds case for comparison."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string arrays."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant alphanum_sort.basic_natural_order:
  description: "['a10', 'a2', 'a1'] sorts to ['a1', 'a2', 'a10'] — numbers compared numerically"
  category: sort
  kind: node_chain_eq
  entry: module
  entry_args: [["a10", "a2", "a1"]]
  chain: []
  expected: ["a1", "a2", "a10"]

invariant alphanum_sort.file_naming:
  description: "Common file-name natural sort — file2 before file10"
  category: sort
  kind: node_chain_eq
  entry: module
  entry_args: [["file9", "file1", "file10", "file2"]]
  chain: []
  expected: ["file1", "file2", "file9", "file10"]

invariant alphanum_sort.letters_only:
  description: "Pure-alpha input falls back to lexicographic order"
  category: sort
  kind: node_chain_eq
  entry: module
  entry_args: [["cat", "apple", "banana"]]
  chain: []
  expected: ["apple", "banana", "cat"]

invariant alphanum_sort.case_sensitive_default:
  description: "Default is case-sensitive (uppercase before lowercase per ASCII)"
  category: sort
  kind: node_chain_eq
  entry: module
  entry_args: [["B", "a", "C", "b"]]
  chain: []
  expected: ["B", "C", "a", "b"]

invariant alphanum_sort.case_insensitive_option:
  description: "{insensitive: true} folds case during comparison"
  category: sort
  kind: node_chain_eq
  entry: module
  entry_args: [["B", "a", "C", "b"], {insensitive: true}]
  chain: []
  expected: ["a", "B", "b", "C"]

invariant alphanum_sort.empty_array:
  description: "Empty array returns empty array"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [[]]
  chain: []
  expected: []

invariant alphanum_sort.single_element:
  description: "Single-element array returns the same element"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [["lonely"]]
  chain: []
  expected: ["lonely"]

invariant alphanum_sort.numeric_substring:
  description: "Numeric substrings compared numerically not lexicographically"
  category: sort
  kind: node_chain_eq
  entry: module
  entry_args: [["x100", "x99", "x9"]]
  chain: []
  expected: ["x9", "x99", "x100"]
