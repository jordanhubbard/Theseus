spec: concurrent_futures_extra281
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra280.zspec.zsdl — covers InterpreterPoolExecutor (Python 3.14) class identity; concurrent.futures.interpreter and concurrent.futures._base submodule identity"
    - "concurrent_futures_extra28.zspec.zsdl — covers __all__ metadata, class __dict__.__class__.__name__.__len__(), Future internal method qualname lengths, function __module__ lengths"
    - "concurrent_futures_extra.zspec.zsdl — covers Future/ThreadPoolExecutor/ProcessPoolExecutor/__name__/__module__, CancelledError/TimeoutError/BrokenExecutor identity, wait/as_completed names, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED type checks"
  notes:
    - "This spec covers: concurrent.futures.thread submodule identity (__name__, __spec__.name, __package__, __loader__.__class__.__name__); concurrent.futures.process submodule identity (same fields); concurrent.futures.__name__, __package__, __spec__.name, __loader__.__class__.__name__, __file__ endswith __init__.py; ThreadPoolExecutor class identity from thread submodule (__module__, __bases__[0].__name__, __mro__.__len__()); ProcessPoolExecutor class identity from process submodule; ThreadPoolExecutor/ProcessPoolExecutor method __qualname__ lengths."
    - "concurrent.futures.__name__ == 'concurrent.futures' (len=18); __package__ == 'concurrent.futures' (len=18); __loader__.__class__.__name__ == 'SourceFileLoader'; __file__ ends with '__init__.py'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' (len=25); __package__ == 'concurrent.futures' (len=18); __loader__.__class__.__name__ == 'SourceFileLoader'; no __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.process.__name__ == 'concurrent.futures.process' (len=26); __package__ == 'concurrent.futures' (len=18); __loader__.__class__.__name__ == 'SourceFileLoader'; no __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; __bases__[0].__name__ == 'Executor'; __mro__.__len__() == 3 ([ThreadPoolExecutor, Executor, object]); __name__.__len__() == 18. ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; __bases__[0].__name__ == 'Executor'; __mro__.__len__() == 3; __name__.__len__() == 19. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "ThreadPoolExecutor method __qualname__ lengths: submit=25, shutdown=27, __init__=27, map=12 (inherited from Executor). ProcessPoolExecutor method __qualname__ lengths: submit=26, shutdown=28, __init__=28, map=23. ProcessPoolExecutor.map is NOT inherited from Executor (it overrides it, hence 'ProcessPoolExecutor.map' len=23 vs 'Executor.map' len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures top-level package identity — extra281
#
# concurrent.futures.__name__             == 'concurrent.futures'   (len=18)
# concurrent.futures.__package__          == 'concurrent.futures'   (len=18)
# concurrent.futures.__spec__.name        == 'concurrent.futures'
# concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'
# ---------------------------------------------------------------------------

table concurrent_futures_extra281.cf_package_identity:
  description: "concurrent.futures top-level package identity checks in extra281 namespace — __name__=='concurrent.futures' (len=18); __package__=='concurrent.futures' (len=18); __loader__.__class__.__name__=='SourceFileLoader'; __file__ ends with '__init__.py'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfpkg281

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,     concurrent.futures.__name__.__eq__,                      ["concurrent.futures"], true,  "concurrent.futures.__name__ == 'concurrent.futures'; verified with Python 3.14.3"]
    - [name_len,    concurrent.futures.__name__.__len__,                     [],                     18,    "concurrent.futures.__name__.__len__() == 18 ('concurrent.futures'=18); verified with Python 3.14.3"]
    - [pkg_eq,      concurrent.futures.__package__.__eq__,                   ["concurrent.futures"], true,  "concurrent.futures.__package__ == 'concurrent.futures' (self-referential for packages); verified with Python 3.14.3"]
    - [spec_eq,     concurrent.futures.__spec__.name.__eq__,                 ["concurrent.futures"], true,  "concurrent.futures.__spec__.name == 'concurrent.futures'; verified with Python 3.14.3"]
    - [loader_eq,   concurrent.futures.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"],   true,  "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.thread and process submodule identity — extra281
#
# concurrent.futures.thread.__name__  == 'concurrent.futures.thread'  (len=25)
# concurrent.futures.process.__name__ == 'concurrent.futures.process' (len=26)
# Both have __package__ == 'concurrent.futures' (len=18)
# Both use SourceFileLoader and have no __all__
# ---------------------------------------------------------------------------

table concurrent_futures_extra281.cf_submodule_identity:
  description: "concurrent.futures.thread and .process submodule identity in extra281 namespace — thread.__name__='concurrent.futures.thread' (len=25); process.__name__='concurrent.futures.process' (len=26); both have __package__=='concurrent.futures'; both are SourceFileLoader modules; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfsubmod281

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,    concurrent.futures.thread.__name__.__eq__,                      ["concurrent.futures.thread"],  true,  "concurrent.futures.thread.__name__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [thread_name_len,   concurrent.futures.thread.__name__.__len__,                     [],                             25,    "concurrent.futures.thread.__name__.__len__() == 25 ('concurrent.futures.thread'=25); verified with Python 3.14.3"]
    - [thread_spec_eq,    concurrent.futures.thread.__spec__.name.__eq__,                 ["concurrent.futures.thread"],  true,  "concurrent.futures.thread.__spec__.name == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [thread_pkg_eq,     concurrent.futures.thread.__package__.__eq__,                   ["concurrent.futures"],         true,  "concurrent.futures.thread.__package__ == 'concurrent.futures'; verified with Python 3.14.3"]
    - [thread_loader_eq,  concurrent.futures.thread.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"],            true,  "concurrent.futures.thread.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [process_name_eq,   concurrent.futures.process.__name__.__eq__,                     ["concurrent.futures.process"], true,  "concurrent.futures.process.__name__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [process_name_len,  concurrent.futures.process.__name__.__len__,                    [],                             26,    "concurrent.futures.process.__name__.__len__() == 26 ('concurrent.futures.process'=26); verified with Python 3.14.3"]
    - [process_spec_eq,   concurrent.futures.process.__spec__.name.__eq__,                ["concurrent.futures.process"], true,  "concurrent.futures.process.__spec__.name == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [process_pkg_eq,    concurrent.futures.process.__package__.__eq__,                  ["concurrent.futures"],         true,  "concurrent.futures.process.__package__ == 'concurrent.futures'; verified with Python 3.14.3"]
    - [process_loader_eq, concurrent.futures.process.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"],           true,  "concurrent.futures.process.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor class identity — extra281
#
# ThreadPoolExecutor.__module__            == 'concurrent.futures.thread'  (len=25)
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ThreadPoolExecutor.__mro__.__len__()     == 3  ([ThreadPoolExecutor, Executor, object])
# ThreadPoolExecutor.__name__.__len__()    == 18
#
# ProcessPoolExecutor.__module__            == 'concurrent.futures.process' (len=26)
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# ProcessPoolExecutor.__mro__.__len__()     == 3  ([ProcessPoolExecutor, Executor, object])
# ProcessPoolExecutor.__name__.__len__()    == 19
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra281.ThreadPoolExecutor.module_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in the thread implementation submodule"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra281.ThreadPoolExecutor.base_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — direct subclass of the abstract Executor base class"
  category: class_hierarchy
  kind: python_call_eq
  function: "ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra281.ThreadPoolExecutor.mro_len:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra281.ProcessPoolExecutor.module_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in the process implementation submodule"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra281.ProcessPoolExecutor.base_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — direct subclass of the abstract Executor base class"
  category: class_hierarchy
  kind: python_call_eq
  function: "ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra281.ProcessPoolExecutor.mro_len:
  description: "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ProcessPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra281.ThreadPoolExecutor.submit_qualname_len:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__() == 25 — 'ThreadPoolExecutor.submit' is 25 characters"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__len__
  args: []
  expected: 25

invariant concurrent_futures_extra281.ThreadPoolExecutor.map_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — map is inherited from the abstract Executor base (len=12, NOT 'ThreadPoolExecutor.map')"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra281.ProcessPoolExecutor.map_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' — ProcessPoolExecutor overrides map (len=23), unlike ThreadPoolExecutor which inherits it"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.map.__qualname__.__eq__
  args: ["ProcessPoolExecutor.map"]
  expected: true

invariant concurrent_futures_extra281.ProcessPoolExecutor.shutdown_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.shutdown' is 28 characters; longest of the ProcessPoolExecutor method qualnames surveyed"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__qualname__.__len__
  args: []
  expected: 28
