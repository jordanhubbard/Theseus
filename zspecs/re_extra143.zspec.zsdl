spec: re_extra143
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re module-level function __doc__ lengths (compile=65, match=109, search=112, sub=326, findall=258, subn=447, finditer=163, fullmatch=103, split=385, purge=35, escape=40), re.error/__doc__ length (333), re.RegexFlag class identity and MRO, and re.__version__ identity."
    - "All re module-level functions (compile, match, search, etc.) are 'function' instances, not builtin_function_or_method."
    - "re.error is an alias for re.PatternError (they are the same object); __name__ == 'PatternError' (12), not 'error'."
    - "re.error.__doc__ is 333 characters; the docstring covers msg, pattern, pos, lineno, colno attributes."
    - "re.__version__ == '2.2.1' (5 characters)."
    - "re.RegexFlag.__class__.__name__ == 'EnumType'; __bases__[0].__name__ == 'IntFlag'; MRO length == 7."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __doc__ lengths: compile, match, search, sub
# All are pure Python 'function' instances.
# compile.__doc__ == 65 chars (single-sentence); match.__doc__ == 109.
# search.__doc__ == 112; sub.__doc__ == 326 (longest simple-group: 4 params).
# ---------------------------------------------------------------------------

table re_extra143.function_doc_len_compile_match_search_sub:
  description: "re function __doc__ lengths: compile=65, match=109, search=112, sub=326; all are 'function' class"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redoc143

  columns: [id, function, args, expected]
  rows:
    - [compile_cls_eq,  compile.__class__.__name__.__eq__,  ["function"], true]
    - [compile_doc_len, compile.__doc__.__len__,             [],           65]
    - [match_cls_eq,    match.__class__.__name__.__eq__,     ["function"], true]
    - [match_doc_len,   match.__doc__.__len__,               [],           109]
    - [search_cls_eq,   search.__class__.__name__.__eq__,    ["function"], true]
    - [search_doc_len,  search.__doc__.__len__,              [],           112]
    - [sub_cls_eq,      sub.__class__.__name__.__eq__,       ["function"], true]
    - [sub_doc_len,     sub.__doc__.__len__,                 [],           326]

# ---------------------------------------------------------------------------
# re module-level function __doc__ lengths: findall, subn, finditer, fullmatch
# findall.__doc__ == 258; subn.__doc__ == 447 (longest in the module).
# finditer.__doc__ == 163; fullmatch.__doc__ == 103.
# ---------------------------------------------------------------------------

table re_extra143.function_doc_len_findall_subn_finditer_fullmatch:
  description: "re function __doc__ lengths: findall=258, subn=447 (longest), finditer=163, fullmatch=103"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redoc143

  columns: [id, function, args, expected]
  rows:
    - [findall_doc_len,   findall.__doc__.__len__,    [],  258]
    - [subn_doc_len,      subn.__doc__.__len__,       [],  447]
    - [finditer_doc_len,  finditer.__doc__.__len__,   [],  163]
    - [fullmatch_doc_len, fullmatch.__doc__.__len__,  [],  103]

# ---------------------------------------------------------------------------
# re module-level function __doc__ lengths: split, purge, escape
# split.__doc__ == 385; purge.__doc__ == 35 (shortest function doc).
# escape.__doc__ == 40.
# ---------------------------------------------------------------------------

table re_extra143.function_doc_len_split_purge_escape:
  description: "re function __doc__ lengths: split=385, purge=35 (shortest), escape=40"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redoc143

  columns: [id, function, args, expected]
  rows:
    - [split_doc_len,   split.__doc__.__len__,   [],  385]
    - [purge_doc_len,   purge.__doc__.__len__,   [],  35]
    - [escape_doc_len,  escape.__doc__.__len__,  [],  40]

# ---------------------------------------------------------------------------
# re.error / re.PatternError identity
# re.error is an alias for re.PatternError (same object in Python 3.12+).
# __name__ == 'PatternError' (12), not 'error'.
# __module__ == 're' (2); __bases__[0].__name__ == 'Exception'.
# __doc__ length == 333 (covers msg, pattern, pos, lineno, colno attributes).
# ---------------------------------------------------------------------------

table re_extra143.error_PatternError_identity:
  description: "re.error is re.PatternError; __name__='PatternError' (12), __module__='re' (2), __bases__[0]='Exception', __doc__ len=333"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerr143

  columns: [id, function, args, expected]
  rows:
    - [err_name_eq,    error.__name__.__eq__,                  ["PatternError"],  true]
    - [err_name_len,   error.__name__.__len__,                 [],                12]
    - [err_qn_eq,      error.__qualname__.__eq__,              ["PatternError"],  true]
    - [err_module_eq,  error.__module__.__eq__,                ["re"],            true]
    - [err_module_len, error.__module__.__len__,               [],                2]
    - [err_cls_eq,     error.__class__.__name__.__eq__,        ["type"],          true]
    - [err_base0_eq,   "error.__bases__[0].__name__.__eq__",   ["Exception"],     true]
    - [err_doc_cls_eq, error.__doc__.__class__.__name__.__eq__, ["str"],          true]
    - [err_doc_len,    error.__doc__.__len__,                  [],                333]

# ---------------------------------------------------------------------------
# re.RegexFlag class identity and MRO
# RegexFlag.__name__ == 'RegexFlag' (9), __module__ == 're' (2).
# __class__.__name__ == 'EnumType' (not 'type').
# __bases__[0].__name__ == 'IntFlag'; MRO length == 7.
# MRO: RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object.
# ---------------------------------------------------------------------------

table re_extra143.RegexFlag_identity_mro:
  description: "re.RegexFlag class identity: __name__='RegexFlag' (9), __module__='re' (2), __class__.__name__='EnumType', __bases__[0]='IntFlag'; MRO length 7"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerflag143

  columns: [id, function, args, expected]
  rows:
    - [rflag_name_eq,    RegexFlag.__name__.__eq__,           ["RegexFlag"], true]
    - [rflag_name_len,   RegexFlag.__name__.__len__,          [],            9]
    - [rflag_module_eq,  RegexFlag.__module__.__eq__,         ["re"],        true]
    - [rflag_module_len, RegexFlag.__module__.__len__,        [],            2]
    - [rflag_qn_eq,      RegexFlag.__qualname__.__eq__,       ["RegexFlag"], true]
    - [rflag_cls_eq,     RegexFlag.__class__.__name__.__eq__, ["EnumType"],  true]
    - [rflag_base0_eq,   "RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"], true]
    - [rflag_mro_len,    "RegexFlag.__mro__.__len__",         [],            7]
    - [rflag_mro0_eq,    "RegexFlag.__mro__[0].__name__.__eq__", ["RegexFlag"], true]
    - [rflag_mro1_eq,    "RegexFlag.__mro__[1].__name__.__eq__", ["IntFlag"],   true]
    - [rflag_mro2_eq,    "RegexFlag.__mro__[2].__name__.__eq__", ["int"],       true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra143.compile.doc_len_65:
  description: "re.compile.__doc__.__len__() == 65 (a single-sentence docstring: 'Compile a regular expression pattern, returning a Pattern object.'; the shortest function docstring in the re module alongside purge (35) and escape (40))"
  category: doc_identity
  kind: python_call_eq
  function: compile.__doc__.__len__
  args: []
  expected: 65

invariant re_extra143.subn.doc_len_447:
  description: "re.subn.__doc__.__len__() == 447 (the longest function docstring in the re module; subn is like sub but returns a (string, count) tuple, requiring extra explanation of the count return value and its interaction with the count parameter)"
  category: doc_identity
  kind: python_call_eq
  function: subn.__doc__.__len__
  args: []
  expected: 447

invariant re_extra143.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' (re.error is an alias for re.PatternError introduced in Python 3.13; the canonical name stored in __name__ is 'PatternError', not 'error'; the alias is kept for backward compatibility)"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra143.error.doc_len_333:
  description: "re.error.__doc__.__len__() == 333 (the PatternError docstring documents five instance attributes: msg, pattern, pos, lineno, and colno; at 333 characters it is longer than Match.__doc__ (92) and Pattern.__doc__ (35))"
  category: doc_identity
  kind: python_call_eq
  function: error.__doc__.__len__
  args: []
  expected: 333

invariant re_extra143.RegexFlag.class_is_EnumType:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' (not 'type'; RegexFlag is an IntFlag enum and its metaclass is EnumType, the metaclass for all enum.Enum subclasses; this distinguishes it from plain Python classes)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant re_extra143.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO is: RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object — the deepest MRO in the re module, reflecting enum IntFlag's multi-level mixin chain through int and the Flag/Enum hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__mro__.__len__"
  args: []
  expected: 7

invariant re_extra143.split.doc_len_385:
  description: "re.split.__doc__.__len__() == 385 (the second-longest function docstring in the re module after subn (447); split has a longer doc than sub (326) because it explains the grouping behaviour and empty-pattern edge cases)"
  category: doc_identity
  kind: python_call_eq
  function: split.__doc__.__len__
  args: []
  expected: 385

