spec: hashlib_extra149
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra148.zspec.zsdl — covers hashlib.file_digest/__qualname__.__eq__('file_digest') / __module__.__eq__('hashlib') / __class__.__name__.__eq__('function') / __code__.co_argcount==2 / __code__.co_name equality / hashlib.__spec__.name.__eq__('hashlib') / hashlib.__doc__.__len__()==2098 (table + invariants)."
    - "hashlib_extra147.zspec.zsdl — covers hashlib.sha3_256/sha3_512/sha3_224/sha3_384 __name__ equality strings (all 'openssl_sha3_NNN', len 16) / sha3_256/__class__.__name__.__eq__('builtin_function_or_method') / sha3_256/__module__.__eq__('_hashlib') / shake_128/shake_256 __name__ equality (len 17) (table + invariants)."
    - "hashlib_extra146.zspec.zsdl — covers hashlib.pbkdf2_hmac and hashlib.scrypt function identity / pbkdf2_hmac/__qualname__/__len__()==11 / pbkdf2_hmac/__module__.__eq__('_hashlib') / scrypt/__module__.__eq__('_hashlib') / blake2b/__module__.__eq__('_blake2') / blake2s/__module__.__eq__('_blake2') (table + invariants)."
    - "hashlib_extra145.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') / membership checks / sha256/__name__.__eq__('openssl_sha256') / md5/__name__.__eq__('openssl_md5') (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra148."
    - "Wave 312 theme: hashlib.__all__ — __all__.__class__.__name__.__eq__('tuple') (hashlib.__all__ is a tuple, not a list) / __all__.__len__()==19 / __all__.__contains__('md5')==True / __all__.__contains__('sha256')==True / __all__.__contains__('new')==True / __all__.__contains__('file_digest')==True / __all__.__contains__('algorithms_guaranteed')==True / __all__.__contains__('blake2b')==True / __all__.__contains__('pbkdf2_hmac')==True."
    - "hashlib.__all__.__class__.__name__ == 'tuple' (not 'list'; hashlib uses a tuple for __all__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.__all__) == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'new' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'file_digest' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'algorithms_guaranteed' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pbkdf2_hmac' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__all__ is a tuple (class name 'tuple', 5 chars), not a list. This is unusual — most Python stdlib modules use a list for __all__. The 19-element tuple includes all public constructors (md5, sha1, sha224, sha256, sha384, sha512, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256, blake2b, blake2s), the two key-derivation functions (pbkdf2_hmac, scrypt), the generic constructor (new), the file utility (file_digest), and the algorithm-name sets (algorithms_guaranteed, algorithms_available)."
    - "Note: The 'tuple' class name is 5 chars, whereas 'list' (the more common __all__ type) is 4 chars. socket.__all__ is a list (238 entries); struct.__all__ is a list (8 entries); hashlib.__all__ is a tuple (19 entries). The socket __all__ (238) is the largest by far."
    - "Note: hashlib.__all__.__len__() == 19. This 19-element tuple grows as new hash functions are added: file_digest (added Python 3.11) is already present, as are sha3_224/sha3_256/sha3_384/sha3_512 and shake_128/shake_256 (added Python 3.6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__all__.__class__.__name__.__eq__('tuple')
# hashlib.__all__.__class__.__name__.__len__()==5
# hashlib.__all__.__len__()==19
# hashlib.__all__.__contains__('md5')
#
# Wave 312 theme: hashlib.__all__ is a tuple with 19 entries.
#
# hashlib.__all__ is a tuple (not a list), which is unusual among stdlib modules.
# Its length is 19, containing all public constructors, key-derivation functions,
# the generic constructor, the file utility, and the algorithm-name sets.
# No prior hashlib spec anchors __all__ class name or length as a table under
# hashdoc149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra149.all_class_and_length:
  description: "hashlib.__all__/__class__.__name__.__eq__('tuple')==True / __class__.__name__.__len__()==5 / __all__.__len__()==19 / __all__.__contains__('md5')==True — __all__ is a tuple (not a list; unusual among stdlib modules); 19 elements covering all constructors, kdf functions, algorithm-name sets; 'tuple' is 5 chars vs 'list' (4 chars); extra99 anchors algorithms_guaranteed length; first hashdoc149 anchor for __all__ class name and length"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc149

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_tuple,      __all__.__class__.__name__.__eq__,  ["tuple"], true, "hashlib.__all__.__class__.__name__ == 'tuple' (not a list; hashlib uses a tuple for __all__)"]
    - [all_class_name_len,   __all__.__class__.__name__.__len__,  [],        5,    "hashlib.__all__.__class__.__name__.__len__() is 5 ('tuple' = 5 chars; 1 more than 'list' at 4)"]
    - [all_len_19,           __all__.__len__,                    [],        19,   "hashlib.__all__.__len__() is 19 (all constructors, kdf functions, algorithm-name sets, file utility)"]
    - [all_contains_md5,     __all__.__contains__,               ["md5"],   true, "hashlib.__all__.__contains__('md5') == True (md5 is among the 19 public names)"]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('sha256')
# hashlib.__all__.__contains__('new')
# hashlib.__all__.__contains__('file_digest')
# hashlib.__all__.__contains__('algorithms_guaranteed')
#
# Wave 312 theme: membership of key names in hashlib.__all__.
#
# sha256 (the most widely-used hash), new (the generic constructor), file_digest
# (the file utility added in Python 3.11), and algorithms_guaranteed (the set of
# guaranteed algorithm names) are all present in hashlib.__all__.
# No prior hashlib spec anchors __all__.__contains__ checks as a table under hashdoc149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra149.all_contains_key_names:
  description: "hashlib.__all__.__contains__('sha256')==True / __contains__('new')==True / __contains__('file_digest')==True / __contains__('algorithms_guaranteed')==True — sha256 is the most widely-used hash; new is the generic constructor; file_digest was added Python 3.11; algorithms_guaranteed is one of the two name-set exports; all four are present in the 19-element tuple; first hashdoc149 anchor for these membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc149

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_sha256,             __all__.__contains__, ["sha256"],             true, "hashlib.__all__.__contains__('sha256') == True (most widely-used SHA-2 hash)"]
    - [all_contains_new,                __all__.__contains__, ["new"],                true, "hashlib.__all__.__contains__('new') == True (generic constructor for any supported algorithm)"]
    - [all_contains_file_digest,        __all__.__contains__, ["file_digest"],        true, "hashlib.__all__.__contains__('file_digest') == True (file utility added Python 3.11)"]
    - [all_contains_alg_guaranteed,     __all__.__contains__, ["algorithms_guaranteed"], true, "hashlib.__all__.__contains__('algorithms_guaranteed') == True (set of always-available algorithm names)"]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('blake2b')
# hashlib.__all__.__contains__('pbkdf2_hmac')
# hashlib.__all__.__contains__('sha3_256')
# hashlib.__all__.__contains__('algorithms_available')
#
# Wave 312 theme: membership of additional names in hashlib.__all__.
#
# blake2b (BLAKE2 hash), pbkdf2_hmac (PBKDF2 key-derivation), sha3_256 (SHA-3),
# and algorithms_available (the platform-dependent name set) are all present.
# No prior hashlib spec anchors these __contains__ checks as a table under hashdoc149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra149.all_contains_additional_names:
  description: "hashlib.__all__.__contains__('blake2b')==True / __contains__('pbkdf2_hmac')==True / __contains__('sha3_256')==True / __contains__('algorithms_available')==True — blake2b added Python 3.6; pbkdf2_hmac is the PBKDF2 key-derivation function; sha3_256 is the standard 256-bit SHA-3 hash; algorithms_available is the platform-dependent superset of algorithms_guaranteed; all four are present in the 19-element tuple; first hashdoc149 anchor for these additional membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc149

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_blake2b,           __all__.__contains__, ["blake2b"],           true, "hashlib.__all__.__contains__('blake2b') == True (BLAKE2b hash; added Python 3.6)"]
    - [all_contains_pbkdf2_hmac,       __all__.__contains__, ["pbkdf2_hmac"],       true, "hashlib.__all__.__contains__('pbkdf2_hmac') == True (PBKDF2 key-derivation function)"]
    - [all_contains_sha3_256,          __all__.__contains__, ["sha3_256"],          true, "hashlib.__all__.__contains__('sha3_256') == True (256-bit SHA-3; part of SHA-3 family added Python 3.6)"]
    - [all_contains_alg_available,     __all__.__contains__, ["algorithms_available"], true, "hashlib.__all__.__contains__('algorithms_available') == True (platform-dependent superset of algorithms_guaranteed)"]

# ---------------------------------------------------------------------------
# hashlib.__all__.__class__.__name__.__eq__('tuple') — standalone
#
# hashlib.__all__.__class__.__name__ is 'tuple'. Among the stdlib modules covered
# by this spec series, hashlib is the only one that uses a tuple for __all__ rather
# than a list: socket.__all__ is a list (238 entries), struct.__all__ is a list
# (8 entries). The use of a tuple signals that the set of public names is
# intentionally fixed and immutable — callers should not modify it.
# No prior hashlib spec anchors __all__.__class__.__name__.__eq__('tuple')
# as a standalone under hashdoc149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra149.all_class_tuple:
  description: "hashlib.__all__.__class__.__name__.__eq__('tuple') == True — 'tuple' (5 chars); hashlib uses a tuple for __all__ (unusual; most stdlib modules use a list); socket.__all__ is a list (238 entries); struct.__all__ is a list (8 entries); tuple signals immutable/fixed public interface; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc149"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__len__()==19 — standalone
#
# hashlib.__all__.__len__() is 19. The 19 public names are:
# algorithms_available, algorithms_guaranteed, blake2b, blake2s, file_digest,
# md5, new, pbkdf2_hmac, sha1, sha224, sha256, sha384, sha3_224, sha3_256,
# sha3_384, sha3_512, sha512, shake_128, shake_256.
# Comparing module __all__ lengths: struct.__all__ (8) < hashlib.__all__ (19) <<
# socket.__all__ (238). No prior hashlib spec anchors this as a standalone
# under hashdoc149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra149.all_len_19:
  description: "hashlib.__all__.__len__() == 19 — 19 public names: 14 constructors + 2 kdf functions + new + file_digest + 2 algorithm-name sets; length ordering: struct(8) < hashlib(19) << socket(238); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc149"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('md5') — standalone
#
# hashlib.__all__.__contains__('md5') is True. MD5 (Message Digest Algorithm 5)
# is one of the oldest hash functions in hashlib. Despite being cryptographically
# broken for security-sensitive applications, it remains widely used for checksums
# and data integrity. Its 3-char name 'md5' is the shortest constructor name in
# hashlib.__all__ (shorter than 'sha1' at 4 chars). No prior hashlib spec anchors
# __all__.__contains__('md5') as a standalone under hashdoc149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra149.all_contains_md5:
  description: "hashlib.__all__.__contains__('md5') == True — 'md5' (3 chars; shortest constructor name in __all__); MD5 remains in __all__ despite cryptographic weaknesses (still used for checksums); 3-char name is shorter than 'sha1' (4), 'sha256' (6), etc.; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc149"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('sha256') — standalone
#
# hashlib.__all__.__contains__('sha256') is True. SHA-256 is the most widely
# deployed hash function in the hashlib API — it is the recommended choice for
# general-purpose cryptographic hashing. Its 6-char name 'sha256' is present
# in the 19-element tuple. extra145 anchors sha256.__name__.__eq__('openssl_sha256');
# no prior hashlib spec anchors __all__.__contains__('sha256') as a standalone
# under hashdoc149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra149.all_contains_sha256:
  description: "hashlib.__all__.__contains__('sha256') == True — 'sha256' (6 chars); most widely-deployed hash in hashlib API; recommended for general-purpose cryptographic hashing; extra145 anchors sha256.__name__ equality; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc149"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('file_digest') — standalone
#
# hashlib.__all__.__contains__('file_digest') is True. file_digest was added to
# hashlib in Python 3.11 and is the only Python-level function (class 'function',
# __module__ == 'hashlib') in the public API — all other entries in __all__ are
# either C-level constructors (builtin_function_or_method from _hashlib or _blake2)
# or C-level classes (type). extra148 anchors file_digest identity attributes;
# no prior hashlib spec anchors __all__.__contains__('file_digest') as a standalone
# under hashdoc149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra149.all_contains_file_digest:
  description: "hashlib.__all__.__contains__('file_digest') == True — 'file_digest' (11 chars); only Python-level function (class 'function') in hashlib.__all__ (all others are C-level); added Python 3.11; extra148 anchors file_digest identity; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc149"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('algorithms_guaranteed') — standalone
#
# hashlib.__all__.__contains__('algorithms_guaranteed') is True.
# algorithms_guaranteed is a frozenset-like set (actually a set) of hash algorithm
# names guaranteed to be available on all platforms. extra145 anchors
# algorithms_guaranteed.__class__.__name__ == 'set' and __len__()==14; no prior
# hashlib spec anchors __all__.__contains__('algorithms_guaranteed') as a standalone
# under hashdoc149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra149.all_contains_algorithms_guaranteed:
  description: "hashlib.__all__.__contains__('algorithms_guaranteed') == True — 'algorithms_guaranteed' (22 chars; longest name in __all__); a set of 14 algorithm names guaranteed on all platforms (extra145 anchors set class and length); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc149"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["algorithms_guaranteed"]
  expected: true
