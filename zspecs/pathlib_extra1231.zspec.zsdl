spec: pathlib_extra1231
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.__dict__.__contains__ checks for module-level names: Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath; pathlib.PurePath.__dict__.__contains__ checks for comparison dunders __lt__, __le__, __gt__, __ge__ and properties parents, suffixes, anchor, drive, root"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.__dict__.__contains__ for module-level class names exported by pathlib; checks pathlib.__dict__.__contains__ for names that should NOT be present (e.g. io-owned, os-owned names); checks pathlib.PurePath.__dict__.__contains__ for ordering comparison dunders (__lt__, __le__, __gt__, __ge__) and remaining pure-path properties (parents, suffixes, anchor, drive, root) not yet checked in _extra1216; none of these pathlib.__dict__.__contains__ or ordering-dunder membership checks were covered in _extra1201, _extra1216, or any prior pathlib_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1231.module_dict_contains_classes:
  description: "pathlib.__dict__.__contains__ checks for module-level class names — Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath all present in pathlib.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1231mc
  columns: [id, function, args, expected]
  rows:
    - [pl1231mc001, pathlib.__dict__.__contains__, ["Path"],            true]
    - [pl1231mc002, pathlib.__dict__.__contains__, ["PurePath"],        true]
    - [pl1231mc003, pathlib.__dict__.__contains__, ["PurePosixPath"],   true]
    - [pl1231mc004, pathlib.__dict__.__contains__, ["PureWindowsPath"], true]
    - [pl1231mc005, pathlib.__dict__.__contains__, ["PosixPath"],       true]
    - [pl1231mc006, pathlib.__dict__.__contains__, ["WindowsPath"],     true]
    - [pl1231mc007, pathlib.__dict__.__contains__, ["IOBase"],          false]
    - [pl1231mc008, pathlib.__dict__.__contains__, ["BytesIO"],         false]
    - [pl1231mc009, pathlib.__dict__.__contains__, ["Decimal"],         false]
    - [pl1231mc010, pathlib.__dict__.__contains__, ["Pattern"],         false]

table pathlib_extra1231.purepath_dict_contains_ordering_dunders:
  description: "pathlib.PurePath.__dict__.__contains__ checks for ordering comparison dunders — __lt__, __le__, __gt__, __ge__ all present in PurePath.__dict__; unrelated dunders absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1231od
  columns: [id, function, args, expected]
  rows:
    - [pl1231od001, pathlib.PurePath.__dict__.__contains__, ["__lt__"],      true]
    - [pl1231od002, pathlib.PurePath.__dict__.__contains__, ["__le__"],      true]
    - [pl1231od003, pathlib.PurePath.__dict__.__contains__, ["__gt__"],      true]
    - [pl1231od004, pathlib.PurePath.__dict__.__contains__, ["__ge__"],      true]
    - [pl1231od005, pathlib.PurePath.__dict__.__contains__, ["__add__"],     false]
    - [pl1231od006, pathlib.PurePath.__dict__.__contains__, ["__sub__"],     false]
    - [pl1231od007, pathlib.PurePath.__dict__.__contains__, ["__mul__"],     false]
    - [pl1231od008, pathlib.PurePath.__dict__.__contains__, ["__len__"],     false]

table pathlib_extra1231.purepath_dict_contains_properties:
  description: "pathlib.PurePath.__dict__.__contains__ checks for pure-path properties not yet checked in _extra1216 — parents, suffixes, anchor, drive, root present; filesystem-only attributes absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1231pp
  columns: [id, function, args, expected]
  rows:
    - [pl1231pp001, pathlib.PurePath.__dict__.__contains__, ["parents"],  true]
    - [pl1231pp002, pathlib.PurePath.__dict__.__contains__, ["suffixes"], true]
    - [pl1231pp003, pathlib.PurePath.__dict__.__contains__, ["anchor"],   true]
    - [pl1231pp004, pathlib.PurePath.__dict__.__contains__, ["drive"],    true]
    - [pl1231pp005, pathlib.PurePath.__dict__.__contains__, ["root"],     true]
    - [pl1231pp006, pathlib.PurePath.__dict__.__contains__, ["stat"],     false]
    - [pl1231pp007, pathlib.PurePath.__dict__.__contains__, ["exists"],   false]
    - [pl1231pp008, pathlib.PurePath.__dict__.__contains__, ["iterdir"],  false]
    - [pl1231pp009, pathlib.PurePath.__dict__.__contains__, ["is_dir"],   false]
    - [pl1231pp010, pathlib.PurePath.__dict__.__contains__, ["is_mount"], false]
