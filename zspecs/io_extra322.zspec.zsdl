spec: io_extra322
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper behavioral invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# TextIOWrapper wraps a binary BytesIO stream as a text (str) stream.
# TextIOWrapper(BytesIO(b'hello'), encoding='utf-8').read() == 'hello'
# readable() == True; writable() == True (BytesIO is both readable and writable)
# encoding == 'utf-8'; errors == 'strict'; line_buffering == False
# TextIOWrapper.__doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

invariant io_extra322.TextIOWrapper.read_eq_hello:
  description: "io.TextIOWrapper(io.BytesIO(b'hello'), encoding='utf-8').read().__eq__('hello') == True — reading UTF-8-wrapped bytes yields the decoded string; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "TextIOWrapper(BytesIO(b'hello'), encoding='utf-8').read().__eq__"
  args: ["hello"]
  expected: true

invariant io_extra322.TextIOWrapper.readable:
  description: "io.TextIOWrapper(io.BytesIO(b'hello'), encoding='utf-8').readable() == True — TextIOWrapper over a readable BytesIO reports readable; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "TextIOWrapper(BytesIO(b'hello'), encoding='utf-8').readable"
  args: []
  expected: true

invariant io_extra322.TextIOWrapper.writable:
  description: "io.TextIOWrapper(io.BytesIO(b''), encoding='utf-8').writable() == True — TextIOWrapper over a BytesIO (which is both readable and writable) reports writable; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "TextIOWrapper(BytesIO(b''), encoding='utf-8').writable"
  args: []
  expected: true

invariant io_extra322.TextIOWrapper.encoding:
  description: "io.TextIOWrapper(io.BytesIO(b'hello'), encoding='utf-8').encoding.__eq__('utf-8') == True — encoding attribute reflects the encoding passed at construction; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "TextIOWrapper(BytesIO(b'hello'), encoding='utf-8').encoding.__eq__"
  args: ["utf-8"]
  expected: true

invariant io_extra322.TextIOWrapper.line_buffering:
  description: "io.TextIOWrapper(io.BytesIO(b'hello'), encoding='utf-8').line_buffering == False — line_buffering defaults to False when not explicitly enabled; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "TextIOWrapper(BytesIO(b'hello'), encoding='utf-8').line_buffering.__eq__"
  args: [false]
  expected: true

invariant io_extra322.TextIOWrapper.errors:
  description: "io.TextIOWrapper(io.BytesIO(b'hello'), encoding='utf-8').errors.__eq__('strict') == True — errors attribute defaults to 'strict'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "TextIOWrapper(BytesIO(b'hello'), encoding='utf-8').errors.__eq__"
  args: ["strict"]
  expected: true

invariant io_extra322.TextIOWrapper.doc_class_name:
  description: "io.TextIOWrapper.__doc__.__class__.__name__ == 'str' — the docstring of TextIOWrapper is a str instance; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: TextIOWrapper.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# TextIOWrapper class identity: name, module, metaclass
# ---------------------------------------------------------------------------

table io_extra322.TextIOWrapper_class_identity:
  description: "io.TextIOWrapper class identity: __name__, __module__, __class__.__name__"
  kind: python_call_eq
  category: classnames
  id_prefix: iotextio322

  columns: [id, function, args, expected]
  rows:
    - [name_eq,       TextIOWrapper.__name__.__eq__,                ["TextIOWrapper"], true]
    - [module_eq,     TextIOWrapper.__module__.__eq__,              ["_io"],           true]
    - [meta_eq,       TextIOWrapper.__class__.__name__.__eq__,      ["type"],          true]
    - [doc_str_cls,   TextIOWrapper.__doc__.__class__.__name__.__eq__, ["str"],        true]

# ---------------------------------------------------------------------------
# TextIOWrapper attribute descriptor class names
# encoding: member_descriptor; errors: getset_descriptor;
# line_buffering: member_descriptor; readable/writable: method_descriptor
# ---------------------------------------------------------------------------

table io_extra322.TextIOWrapper_descriptor_classes:
  description: "io.TextIOWrapper descriptor class names: encoding, errors, line_buffering, readable, writable"
  kind: python_call_eq
  category: classnames
  id_prefix: iotextio322

  columns: [id, function, args, expected]
  rows:
    - [encoding_cls,    TextIOWrapper.encoding.__class__.__name__.__eq__,      ["member_descriptor"],  true]
    - [errors_cls,      TextIOWrapper.errors.__class__.__name__.__eq__,         ["getset_descriptor"],  true]
    - [linebuf_cls,     TextIOWrapper.line_buffering.__class__.__name__.__eq__, ["member_descriptor"],  true]
    - [readable_cls,    TextIOWrapper.readable.__class__.__name__.__eq__,       ["method_descriptor"],  true]
    - [writable_cls,    TextIOWrapper.writable.__class__.__name__.__eq__,       ["method_descriptor"],  true]
