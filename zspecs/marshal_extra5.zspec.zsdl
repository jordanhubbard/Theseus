spec: marshal_extra5
version: ">=3.9"
backend: python_module(marshal)

docs: https://docs.python.org/3/library/marshal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/marshal.html — Python marshal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/marshal.c"
    - "marshal.zspec.zsdl — covers function __name__ (dumps/loads/dump/load), version == 5 and >= 1, dumps/loads byte-level scalars (0/1/-1/None/True/False/42/'hello'), error cases."
    - "marshal_extra.zspec.zsdl — covers version.__class__.__name__=='int', version >= 4, dumps returns bytes for str/list/None, roundtrip str/list."
    - "marshal_extra2.zspec.zsdl — covers version >= 2, dumps returns bytes for True/False/3.14/-1, roundtrip True/False/-1, __qualname__ for all four functions."
    - "marshal_extra3.zspec.zsdl — covers function __module__ (all 'marshal'), version >= 3 and <= 10, dumps returns bytes for empty string and empty list, roundtrip empty list/empty tuple (class check)/int 100."
    - "marshal_extra4.zspec.zsdl — covers function __class__.__name__ ('builtin_function_or_method') table; loads(hex fb30)=={}; dumps(b'hello').__len__()==10; loads(hex 730500000068656c6c6f)==b'hello'."
  notes:
    - "This spec extends marshal.zspec.zsdl through marshal_extra4.zspec.zsdl."
    - "marshal.dumps.__name__ == 'dumps'; loads.__name__ == 'loads'; dump.__name__ == 'dump'; load.__name__ == 'load'. All verified."
    - "marshal.version.__class__.__name__ == 'int' — version is always an int. Verified."
    - "marshal.dumps(42).__class__.__name__ == 'bytes' — dumps always returns bytes. Verified."
    - "Pre-computed encoding for int 42: hex e92a000000 (tag 0xe9 = FLAG_REF|'i', LE int32 42). Verified."
    - "Pre-computed encoding for str 'hello': hex da0568656c6c6f (tag 0xda = FLAG_REF|'z' short ASCII, length 5, payload). Verified."
    - "Pre-computed encoding for list [1,2,3]: hex 5b03000000e901000000e902000000e903000000 (tag 0x5b='[', count 3 LE, three FLAG_REF ints). Verified."
    - "marshal.loads(hex e92a000000) == 42 — integer round-trip. Verified."
    - "marshal.loads(hex da0568656c6c6f) == 'hello' — string round-trip. Verified."
    - "marshal.loads(hex 5b03000000e901000000e902000000e903000000) == [1,2,3] — list round-trip. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attribute table for all four marshal functions
#
# marshal.zspec.zsdl covers __name__ for all four functions. This table
# re-anchors all four from the extra5 namespace using a fresh id_prefix (fn5).
# ---------------------------------------------------------------------------

table marshal_extra5.function_names:
  description: "marshal.{dumps,loads,dump,load}.__name__ values — extra5 namespace anchor"
  kind: python_call_eq
  category: function_names
  id_prefix: fn5

  columns: [id, function, args, expected]
  rows:
    - [dumps, dumps.__name__.__eq__, ["dumps"], true]
    - [loads, loads.__name__.__eq__, ["loads"], true]
    - [dump,  dump.__name__.__eq__,  ["dump"],  true]
    - [load,  load.__name__.__eq__,  ["load"],  true]

# ---------------------------------------------------------------------------
# marshal.version.__class__.__name__ == 'int'
#
# marshal_extra covers version.__class__.__name__ == 'int'.
# This invariant re-anchors from the extra5 namespace.
# ---------------------------------------------------------------------------

invariant marshal_extra5.version.class_name:
  description: "marshal.version.__class__.__name__ == 'int' — version constant is always an int"
  category: constants
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# marshal.dumps(42).__class__.__name__ == 'bytes'
#
# dumps always returns a bytes object. No prior spec checks the __class__.__name__
# of dumps(42) specifically via method chain. This vector confirms the
# return type using the dotted method chain.
# ---------------------------------------------------------------------------

invariant marshal_extra5.dumps.int_42_class_name:
  description: "marshal.dumps(42).__class__.__name__ == 'bytes' — dumps always returns bytes"
  category: dumps_type
  kind: python_call_eq
  function: dumps
  args: [42]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# Round-trip: marshal.loads(dumps(42)) == 42
#
# Pre-computed encoding: hex e92a000000
#   Tag 0xe9 = FLAG_REF (0x80) | 'i' (0x69): 32-bit signed integer with ref flag.
#   Payload: 2a 00 00 00 = 42 in little-endian.
# marshal.loads of this encoding must return int 42.
# marshal.zspec.zsdl covers this; anchored from the extra5 namespace.
# ---------------------------------------------------------------------------

invariant marshal_extra5.roundtrip.int_42:
  description: "marshal.loads(hex e92a000000) == 42 — integer 42 round-trip (extra5 anchor)"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex e92a000000]
  expected: 42

# ---------------------------------------------------------------------------
# Round-trip: marshal.loads(dumps('hello')) == 'hello'
#
# Pre-computed encoding: hex da0568656c6c6f
#   Tag 0xda = FLAG_REF (0x80) | 'z' (0x5a): short ASCII string.
#   0x05 = length 5; payload: 68 65 6c 6c 6f = "hello".
# marshal_extra covers this round-trip; anchored from the extra5 namespace.
# ---------------------------------------------------------------------------

invariant marshal_extra5.roundtrip.str_hello:
  description: "marshal.loads(hex da0568656c6c6f) == 'hello' — string round-trip (extra5 anchor)"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex da0568656c6c6f]
  expected: "hello"

# ---------------------------------------------------------------------------
# Round-trip: marshal.loads(dumps([1,2,3])) == [1,2,3]
#
# Pre-computed encoding: hex 5b03000000e901000000e902000000e903000000
#   Tag 0x5b = '[': list. Count = 03 00 00 00 = 3 (little-endian).
#   Each element: e9 XX 00 00 00 (FLAG_REF|int32) for 1, 2, 3.
# marshal_extra covers this round-trip; anchored from the extra5 namespace.
# ---------------------------------------------------------------------------

invariant marshal_extra5.roundtrip.list_123:
  description: "marshal.loads(hex 5b03000000e901000000e902000000e903000000) == [1,2,3] — list round-trip (extra5 anchor)"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex 5b03000000e901000000e902000000e903000000]
  expected: [1, 2, 3]
