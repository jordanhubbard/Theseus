spec: io_extra106
version: ">=3.9"
backend: python_module(io)
extends: io_extra99

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec extends io_extra99.zspec.zsdl."
    - "This spec covers: io.BufferedReader and io.BufferedWriter method class names and __qualname__ values; io.FileIO method class names and __qualname__ values; io.BufferedRandom method class names."
    - "All BufferedReader, BufferedWriter, and FileIO methods are C extension method_descriptors (not Python functions), so their __class__.__name__ == 'method_descriptor'."
    - "io.BufferedReader.read.__qualname__ = 'BufferedReader.read' (length 19)."
    - "io.BufferedReader.readline.__qualname__ = 'BufferedReader.readline' (length 23)."
    - "io.BufferedReader.seek.__qualname__ = 'BufferedReader.seek' (length 19)."
    - "io.BufferedReader.peek.__qualname__ = 'BufferedReader.peek' (length 19)."
    - "io.BufferedReader.read1.__qualname__ = 'BufferedReader.read1' (length 20)."
    - "io.BufferedWriter.write.__qualname__ = 'BufferedWriter.write' (length 20)."
    - "io.BufferedWriter.flush.__qualname__ = 'BufferedWriter.flush' (length 20)."
    - "io.FileIO.read.__qualname__ = 'FileIO.read' (length 11)."
    - "io.FileIO.write.__qualname__ = 'FileIO.write' (length 12)."
    - "io.FileIO.readinto.__qualname__ = 'FileIO.readinto' (length 15)."
    - "io.BufferedRandom.read, write, seek are all method_descriptors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader method class names
# BufferedReader is a C extension type from _io. Its methods are exposed as
# method_descriptors (C-level slot descriptors), not Python functions.
# ---------------------------------------------------------------------------

table io_extra106.BufferedReader_method_class_names:
  description: "io.BufferedReader method class names: read, readline, seek, peek, read1 are all 'method_descriptor' because BufferedReader is a C extension type"
  kind: python_call_eq
  category: method_class_names
  id_prefix: iobufmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [br_read_cls,     BufferedReader.read.__class__.__name__.__eq__,     ["method_descriptor"], true,  "BufferedReader.read.__class__.__name__ == 'method_descriptor' (C extension method, not a Python function)"]
    - [br_readline_cls, BufferedReader.readline.__class__.__name__.__eq__, ["method_descriptor"], true,  "BufferedReader.readline.__class__.__name__ == 'method_descriptor'"]
    - [br_seek_cls,     BufferedReader.seek.__class__.__name__.__eq__,     ["method_descriptor"], true,  "BufferedReader.seek.__class__.__name__ == 'method_descriptor'"]
    - [br_peek_cls,     BufferedReader.peek.__class__.__name__.__eq__,     ["method_descriptor"], true,  "BufferedReader.peek.__class__.__name__ == 'method_descriptor'"]
    - [br_read1_cls,    BufferedReader.read1.__class__.__name__.__eq__,    ["method_descriptor"], true,  "BufferedReader.read1.__class__.__name__ == 'method_descriptor'"]
    - [br_read_not_fn,  BufferedReader.read.__class__.__name__.__eq__,     ["function"],          false, "BufferedReader.read.__class__.__name__ is NOT 'function' (it is a C-level descriptor, not a Python def)"]

# ---------------------------------------------------------------------------
# io.BufferedWriter method class names
# BufferedWriter is also a C extension type. Its methods are method_descriptors.
# ---------------------------------------------------------------------------

table io_extra106.BufferedWriter_method_class_names:
  description: "io.BufferedWriter method class names: write and flush are 'method_descriptor' because BufferedWriter is a C extension type"
  kind: python_call_eq
  category: method_class_names
  id_prefix: iobufmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [bw_write_cls,    BufferedWriter.write.__class__.__name__.__eq__,    ["method_descriptor"], true,  "BufferedWriter.write.__class__.__name__ == 'method_descriptor'"]
    - [bw_flush_cls,    BufferedWriter.flush.__class__.__name__.__eq__,    ["method_descriptor"], true,  "BufferedWriter.flush.__class__.__name__ == 'method_descriptor'"]
    - [bw_write_not_fn, BufferedWriter.write.__class__.__name__.__eq__,    ["function"],          false, "BufferedWriter.write.__class__.__name__ is NOT 'function'"]

# ---------------------------------------------------------------------------
# io.BufferedReader and io.BufferedWriter method __qualname__ values and lengths
# __qualname__ is 'ClassName.method_name' for C extension method_descriptors.
# ---------------------------------------------------------------------------

table io_extra106.BufferedReader_BufferedWriter_method_qualnames:
  description: "io.BufferedReader and io.BufferedWriter method __qualname__ values and lengths; C method_descriptors carry the class-qualified name"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iobufmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [br_read_qn,     BufferedReader.read.__qualname__.__eq__,     ["BufferedReader.read"],     true, "BufferedReader.read.__qualname__ == 'BufferedReader.read'"]
    - [br_read_qn_len, BufferedReader.read.__qualname__.__len__,    [],                          19,   "BufferedReader.read.__qualname__.__len__() == 19 ('BufferedReader.read' has 19 characters)"]
    - [br_rdln_qn,     BufferedReader.readline.__qualname__.__eq__, ["BufferedReader.readline"], true, "BufferedReader.readline.__qualname__ == 'BufferedReader.readline'"]
    - [br_rdln_qn_len, BufferedReader.readline.__qualname__.__len__, [],                         23,   "BufferedReader.readline.__qualname__.__len__() == 23 ('BufferedReader.readline' has 23 characters)"]
    - [br_seek_qn,     BufferedReader.seek.__qualname__.__eq__,     ["BufferedReader.seek"],     true, "BufferedReader.seek.__qualname__ == 'BufferedReader.seek'"]
    - [br_seek_qn_len, BufferedReader.seek.__qualname__.__len__,    [],                          19,   "BufferedReader.seek.__qualname__.__len__() == 19 ('BufferedReader.seek' has 19 characters)"]
    - [bw_write_qn,    BufferedWriter.write.__qualname__.__eq__,    ["BufferedWriter.write"],    true, "BufferedWriter.write.__qualname__ == 'BufferedWriter.write'"]
    - [bw_write_qn_len, BufferedWriter.write.__qualname__.__len__,  [],                          20,   "BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter.write' has 20 characters)"]
    - [bw_flush_qn,    BufferedWriter.flush.__qualname__.__eq__,    ["BufferedWriter.flush"],    true, "BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush'"]
    - [bw_flush_qn_len, BufferedWriter.flush.__qualname__.__len__,  [],                          20,   "BufferedWriter.flush.__qualname__.__len__() == 20 ('BufferedWriter.flush' has 20 characters)"]

# ---------------------------------------------------------------------------
# io.FileIO method class names and __qualname__ values
# FileIO is also a C extension type (_io.FileIO). Its methods are method_descriptors.
# ---------------------------------------------------------------------------

table io_extra106.FileIO_method_class_names_and_qualnames:
  description: "io.FileIO method class names (all method_descriptor) and __qualname__ values: read, write, readinto"
  kind: python_call_eq
  category: method_class_names
  id_prefix: iobufmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [fio_read_cls,      FileIO.read.__class__.__name__.__eq__,        ["method_descriptor"],  true, "FileIO.read.__class__.__name__ == 'method_descriptor' (C extension method)"]
    - [fio_write_cls,     FileIO.write.__class__.__name__.__eq__,       ["method_descriptor"],  true, "FileIO.write.__class__.__name__ == 'method_descriptor'"]
    - [fio_rdinto_cls,    FileIO.readinto.__class__.__name__.__eq__,    ["method_descriptor"],  true, "FileIO.readinto.__class__.__name__ == 'method_descriptor'"]
    - [fio_read_qn,       FileIO.read.__qualname__.__eq__,              ["FileIO.read"],        true, "FileIO.read.__qualname__ == 'FileIO.read'"]
    - [fio_write_qn,      FileIO.write.__qualname__.__eq__,             ["FileIO.write"],       true, "FileIO.write.__qualname__ == 'FileIO.write'"]
    - [fio_rdinto_qn,     FileIO.readinto.__qualname__.__eq__,          ["FileIO.readinto"],    true, "FileIO.readinto.__qualname__ == 'FileIO.readinto'"]
    - [fio_rdinto_qn_len, FileIO.readinto.__qualname__.__len__,         [],                     15,   "FileIO.readinto.__qualname__.__len__() == 15 ('FileIO.readinto' has 15 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra106.BufferedReader.read_is_method_descriptor:
  description: "io.BufferedReader.read.__class__.__name__ == 'method_descriptor' (BufferedReader is a C extension type from _io; its methods are exposed as C-level method_descriptors, not Python functions)"
  category: method_class_names
  kind: python_call_eq
  function: BufferedReader.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra106.BufferedWriter.write_qualname_len:
  description: "io.BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter.write' is exactly 20 characters; C method_descriptors store the class-qualified name)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedWriter.write.__qualname__.__len__
  args: []
  expected: 20

invariant io_extra106.BufferedReader.readline_qualname:
  description: "io.BufferedReader.readline.__qualname__ == 'BufferedReader.readline' (method qualnames use the 'ClassName.method' pattern; 'BufferedReader.readline' has 23 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedReader.readline.__qualname__.__eq__
  args: ["BufferedReader.readline"]
  expected: true

invariant io_extra106.FileIO.read_is_method_descriptor:
  description: "io.FileIO.read.__class__.__name__ == 'method_descriptor' (FileIO is a C extension type from _io; its read method is a C-level method_descriptor)"
  category: method_class_names
  kind: python_call_eq
  function: FileIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra106.BufferedReader.peek_qualname:
  description: "io.BufferedReader.peek.__qualname__.__len__() == 19 ('BufferedReader.peek' has 19 characters; same length as BufferedReader.read and BufferedReader.seek)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedReader.peek.__qualname__.__len__
  args: []
  expected: 19

