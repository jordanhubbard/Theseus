spec: re_extra100
version: ">=3.9"
backend: python_module(re)
extends: re_extra99

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra99.zspec.zsdl."
    - "This spec covers: re.Pattern and re.Match class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and Pattern/Match method class names."
    - "re.Pattern.__name__ = 'Pattern' — the bare type name."
    - "re.Pattern.__module__ = 're' — Pattern is registered in the re module (not '_sre')."
    - "re.Pattern.__qualname__ = 'Pattern' (length 7)."
    - "re.Pattern.__bases__[0].__name__ = 'object' — Pattern extends object directly."
    - "re.Pattern.__mro__.__len__() = 2 (only Pattern and object)."
    - "re.Pattern.__class__.__name__ = 'type' — Pattern is an instance of the standard type metaclass."
    - "re.Match.__name__ = 'Match' — the bare type name."
    - "re.Match.__module__ = 're' — Match is registered in the re module."
    - "re.Match.__qualname__ = 'Match' (length 5)."
    - "re.Match.__bases__[0].__name__ = 'object' — Match extends object directly."
    - "re.Match.__mro__.__len__() = 2 (only Match and object)."
    - "re.Match.__class__.__name__ = 'type' — Match is an instance of the standard type metaclass."
    - "re.Pattern methods (match, search, findall, finditer, sub, split, fullmatch) are all 'method_descriptor'."
    - "re.Match methods (group, groups, span, start, end) are all 'method_descriptor'."
    - "re.Pattern.match.__qualname__ = 'Pattern.match'; re.Match.group.__qualname__ = 'Match.group'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity
# re.Pattern is a C extension type (from _sre module) but is registered in 're'.
# It extends object directly; its metaclass is 'type'.
# MRO length == 2 (Pattern, object only).
# ---------------------------------------------------------------------------

table re_extra100.Pattern_class_identity:
  description: "re.Pattern class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternid100

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,       Pattern.__name__.__eq__,                    ["Pattern"], true,  "re.Pattern.__name__ == 'Pattern' (bare type name, no module prefix)"]
    - [pat_module_eq,     Pattern.__module__.__eq__,                  ["re"],      true,  "re.Pattern.__module__ == 're' (Pattern is registered in the re module, not '_sre')"]
    - [pat_qualname_eq,   Pattern.__qualname__.__eq__,                ["Pattern"], true,  "re.Pattern.__qualname__ == 'Pattern' (same as __name__; no enclosing class)"]
    - [pat_base_eq,       "Pattern.__bases__[0].__name__.__eq__",       ["object"],  true,  "re.Pattern.__bases__[0].__name__ == 'object' (Pattern directly extends object)"]
    - [pat_mro_len,       Pattern.__mro__.__len__,                    [],          2,     "re.Pattern.__mro__.__len__() == 2 (MRO is [Pattern, object])"]
    - [pat_cls_name,      Pattern.__class__.__name__.__eq__,          ["type"],    true,  "re.Pattern.__class__.__name__ == 'type' (Pattern uses the standard type metaclass)"]
    - [pat_name_not_sre,  Pattern.__name__.__eq__,                    ["SRE_Pattern"], false, "re.Pattern.__name__ is NOT 'SRE_Pattern' (the old internal name was removed)"]
    - [pat_mod_not_sre,   Pattern.__module__.__eq__,                  ["_sre"],    false, "re.Pattern.__module__ is NOT '_sre' (it is registered in the public 're' module)"]
    - [pat_qn_len,        Pattern.__qualname__.__len__,               [],          7,     "re.Pattern.__qualname__.__len__() == 7 ('Pattern' has 7 characters)"]
    - [pat_mro_not_3,     Pattern.__mro__.__len__.__eq__,             [3],         false, "re.Pattern.__mro__.__len__() is NOT 3 (no intermediate base between Pattern and object)"]

# ---------------------------------------------------------------------------
# re.Match class identity
# re.Match mirrors re.Pattern: C extension type, registered in 're',
# extends object directly, metaclass is 'type', MRO length == 2.
# ---------------------------------------------------------------------------

table re_extra100.Match_class_identity:
  description: "re.Match class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternid100

  columns: [id, function, args, expected, description]
  rows:
    - [match_name_eq,      Match.__name__.__eq__,                    ["Match"],   true,  "re.Match.__name__ == 'Match' (bare type name)"]
    - [match_module_eq,    Match.__module__.__eq__,                  ["re"],      true,  "re.Match.__module__ == 're' (Match is registered in the re module)"]
    - [match_qualname_eq,  Match.__qualname__.__eq__,                ["Match"],   true,  "re.Match.__qualname__ == 'Match' (no enclosing class)"]
    - [match_base_eq,      "Match.__bases__[0].__name__.__eq__",       ["object"],  true,  "re.Match.__bases__[0].__name__ == 'object' (Match directly extends object)"]
    - [match_mro_len,      Match.__mro__.__len__,                    [],          2,     "re.Match.__mro__.__len__() == 2 (MRO is [Match, object])"]
    - [match_cls_name,     Match.__class__.__name__.__eq__,          ["type"],    true,  "re.Match.__class__.__name__ == 'type' (Match uses the standard type metaclass)"]
    - [match_qn_len,       Match.__qualname__.__len__,               [],          5,     "re.Match.__qualname__.__len__() == 5 ('Match' has 5 characters)"]
    - [match_mod_not_sre,  Match.__module__.__eq__,                  ["_sre"],    false, "re.Match.__module__ is NOT '_sre'"]

# ---------------------------------------------------------------------------
# re.Pattern method class names
# All methods on Pattern (match, search, findall, finditer, sub, split,
# fullmatch) are 'method_descriptor' — C methods registered via PyMethodDef.
# ---------------------------------------------------------------------------

table re_extra100.Pattern_method_class_names:
  description: "re.Pattern methods (match, search, findall, finditer, sub, split, fullmatch) all have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: repatternid100

  columns: [id, function, args, expected, description]
  rows:
    - [pat_match_cls,      Pattern.match.__class__.__name__.__eq__,     ["method_descriptor"], true, "Pattern.match is a method_descriptor (C method via PyMethodDef)"]
    - [pat_search_cls,     Pattern.search.__class__.__name__.__eq__,    ["method_descriptor"], true, "Pattern.search is a method_descriptor (C method via PyMethodDef)"]
    - [pat_findall_cls,    Pattern.findall.__class__.__name__.__eq__,   ["method_descriptor"], true, "Pattern.findall is a method_descriptor (C method via PyMethodDef)"]
    - [pat_finditer_cls,   Pattern.finditer.__class__.__name__.__eq__,  ["method_descriptor"], true, "Pattern.finditer is a method_descriptor (C method via PyMethodDef)"]
    - [pat_sub_cls,        Pattern.sub.__class__.__name__.__eq__,       ["method_descriptor"], true, "Pattern.sub is a method_descriptor (C method via PyMethodDef)"]
    - [pat_split_cls,      Pattern.split.__class__.__name__.__eq__,     ["method_descriptor"], true, "Pattern.split is a method_descriptor (C method via PyMethodDef)"]
    - [pat_fullmatch_cls,  Pattern.fullmatch.__class__.__name__.__eq__, ["method_descriptor"], true, "Pattern.fullmatch is a method_descriptor (C method via PyMethodDef)"]
    - [pat_match_name_eq,  Pattern.match.__name__.__eq__,               ["match"],             true, "Pattern.match.__name__ == 'match' (method_descriptor carries the bare method name)"]
    - [pat_search_name_eq, Pattern.search.__name__.__eq__,              ["search"],            true, "Pattern.search.__name__ == 'search'"]
    - [pat_sub_name_eq,    Pattern.sub.__name__.__eq__,                 ["sub"],               true, "Pattern.sub.__name__ == 'sub'"]
    - [pat_match_qn_eq,    Pattern.match.__qualname__.__eq__,           ["Pattern.match"],     true, "Pattern.match.__qualname__ == 'Pattern.match' (dotted qualname with class prefix)"]
    - [pat_match_not_fn,   Pattern.match.__class__.__name__.__eq__,     ["function"],          false, "Pattern.match is NOT a 'function' (it is a C method_descriptor, not a Python def)"]

# ---------------------------------------------------------------------------
# re.Match method class names
# All methods on Match (group, groups, span, start, end) are 'method_descriptor'.
# ---------------------------------------------------------------------------

table re_extra100.Match_method_class_names:
  description: "re.Match methods (group, groups, span, start, end) all have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: repatternid100

  columns: [id, function, args, expected, description]
  rows:
    - [match_group_cls,    Match.group.__class__.__name__.__eq__,   ["method_descriptor"], true, "Match.group is a method_descriptor (C method via PyMethodDef)"]
    - [match_groups_cls,   Match.groups.__class__.__name__.__eq__,  ["method_descriptor"], true, "Match.groups is a method_descriptor (C method via PyMethodDef)"]
    - [match_span_cls,     Match.span.__class__.__name__.__eq__,    ["method_descriptor"], true, "Match.span is a method_descriptor (C method via PyMethodDef)"]
    - [match_start_cls,    Match.start.__class__.__name__.__eq__,   ["method_descriptor"], true, "Match.start is a method_descriptor (C method via PyMethodDef)"]
    - [match_end_cls,      Match.end.__class__.__name__.__eq__,     ["method_descriptor"], true, "Match.end is a method_descriptor (C method via PyMethodDef)"]
    - [match_group_name,   Match.group.__name__.__eq__,             ["group"],             true, "Match.group.__name__ == 'group'"]
    - [match_span_name,    Match.span.__name__.__eq__,              ["span"],              true, "Match.span.__name__ == 'span'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra100.Pattern.name_eq_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (the compiled regex type is named 'Pattern' in Python 3.7+; the old internal name 'SRE_Pattern' is no longer visible through the public API)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra100.Pattern.module_eq_re:
  description: "re.Pattern.__module__ == 're' (despite being implemented in the _sre C extension, the Pattern type is registered with __module__ = 're' as part of the public API)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra100.Pattern.mro_len_2:
  description: "re.Pattern.__mro__.__len__() == 2 (the MRO of Pattern is [Pattern, object]; there are no intermediate base classes)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra100.Match.module_eq_re:
  description: "re.Match.__module__ == 're' (Match is also registered in the public re module, just like Pattern)"
  category: class_identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra100.Pattern.match_is_method_descriptor:
  description: "re.Pattern.match.__class__.__name__ == 'method_descriptor' (Pattern is a C extension type; its methods are exposed via PyMethodDef as method_descriptor objects, not as Python 'function' objects)"
  category: method_class_names
  kind: python_call_eq
  function: Pattern.match.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

