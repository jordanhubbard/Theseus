spec: multiprocessing_extra270
version: ">=3.4"
backend: python_module(multiprocessing.spawn)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/spawn.py"
    - "multiprocessing_extra269.zspec.zsdl — covers multiprocessing.synchronize module identity; Semaphore, Lock, Event, BoundedSemaphore, Condition, RLock class identity"
  notes:
    - "This spec covers: multiprocessing.spawn module identity (__name__, __spec__.name, __name__.__len__(), __package__, __loader__.__class__.__name__); multiprocessing.forkserver module identity (__name__, __spec__.name, __name__.__len__(), __package__, __loader__.__class__.__name__); multiprocessing.forkserver.ForkServer class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); multiprocessing.forkserver public function qualnames (main, read_signed, write_signed). NEW in extra270: multiprocessing.spawn.__name__=='multiprocessing.spawn' (len=21); multiprocessing.spawn.__spec__.name=='multiprocessing.spawn'; multiprocessing.spawn.__package__=='multiprocessing'; multiprocessing.spawn.__loader__.__class__.__name__=='SourceFileLoader'; multiprocessing.forkserver.__name__=='multiprocessing.forkserver' (len=26); multiprocessing.forkserver.__spec__.name=='multiprocessing.forkserver'; multiprocessing.forkserver.__package__=='multiprocessing'; multiprocessing.forkserver.__loader__.__class__.__name__=='SourceFileLoader'; ForkServer.__module__=='multiprocessing.forkserver'; ForkServer.__bases__[0].__name__=='object'; ForkServer.__mro__.__len__()==2; forkserver.main.__qualname__=='main'; forkserver.read_signed.__qualname__=='read_signed'; forkserver.write_signed.__qualname__=='write_signed'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.spawn.__name__.__len__() == 21 — 'multiprocessing.spawn' is 21 characters: 'multiprocessing'=15+'.spawn'=6=21. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.forkserver.__name__.__len__() == 26 — 'multiprocessing.forkserver' is 26 characters: 'multiprocessing'=15+'.forkserver'=11=26. This is longer than multiprocessing.spawn (len=21) and multiprocessing.synchronize (len=27 is longer). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.forkserver.ForkServer.__mro__.__len__() == 2 — ForkServer's MRO is [ForkServer, object] (length=2); ForkServer is a direct subclass of object with no intermediate base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Both multiprocessing.spawn and multiprocessing.forkserver use SourceFileLoader as their __loader__ class, confirming they are plain source (.py) modules, not frozen or built-in. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.spawn module identity — extra270
#
# multiprocessing.spawn.__name__             == 'multiprocessing.spawn'
# multiprocessing.spawn.__spec__.name        == 'multiprocessing.spawn'
# multiprocessing.spawn.__name__.__len__()   == 21
# multiprocessing.spawn.__package__          == 'multiprocessing'
# multiprocessing.spawn.__loader__.__class__.__name__  == 'SourceFileLoader'
# ---------------------------------------------------------------------------

table multiprocessing_extra270.mp_spawn_module_identity:
  description: "multiprocessing.spawn module identity checks in mpspawn270 namespace — multiprocessing.spawn is defined in Lib/multiprocessing/spawn.py; its __name__ is 'multiprocessing.spawn' (len=21: 'multiprocessing'=15+'.spawn'=6); __spec__.name is also 'multiprocessing.spawn'; __name__.__len__()==21; __package__ is 'multiprocessing' (parent package); __loader__.__class__.__name__ is 'SourceFileLoader' (plain source module, not frozen); multiprocessing.spawn contains helper functions for spawning new processes including freeze_support, get_command_line, get_executable, get_preparation_data; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpspawn270

  columns: [id, function, args, expected, description]
  rows:
    - [spawn_name_eq,     multiprocessing.spawn.__name__.__eq__,                        ["multiprocessing.spawn"],  true, "multiprocessing.spawn.__name__ == 'multiprocessing.spawn'; verified with Python 3.14.3"]
    - [spawn_spec_eq,     multiprocessing.spawn.__spec__.name.__eq__,                   ["multiprocessing.spawn"],  true, "multiprocessing.spawn.__spec__.name == 'multiprocessing.spawn'; verified with Python 3.14.3"]
    - [spawn_name_len,    multiprocessing.spawn.__name__.__len__,                       [],                         21,   "multiprocessing.spawn.__name__.__len__() == 21 ('multiprocessing.spawn'=21); verified with Python 3.14.3"]
    - [spawn_pkg_eq,      multiprocessing.spawn.__package__.__eq__,                     ["multiprocessing"],        true, "multiprocessing.spawn.__package__ == 'multiprocessing' (parent package); verified with Python 3.14.3"]
    - [spawn_loader_eq,   multiprocessing.spawn.__loader__.__class__.__name__.__eq__,   ["SourceFileLoader"],       true, "multiprocessing.spawn.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.forkserver module identity and ForkServer class — extra270
#
# multiprocessing.forkserver.__name__             == 'multiprocessing.forkserver'
# multiprocessing.forkserver.__spec__.name        == 'multiprocessing.forkserver'
# multiprocessing.forkserver.__name__.__len__()   == 26
# multiprocessing.forkserver.__package__          == 'multiprocessing'
# multiprocessing.forkserver.__loader__.__class__.__name__  == 'SourceFileLoader'
# ForkServer.__name__                             == 'ForkServer'
# ForkServer.__module__                           == 'multiprocessing.forkserver'
# ForkServer.__qualname__                         == 'ForkServer'
# ForkServer.__bases__[0].__name__                == 'object'
# ForkServer.__mro__.__len__()                    == 2
# forkserver.main.__qualname__                    == 'main'
# forkserver.read_signed.__qualname__             == 'read_signed'
# forkserver.write_signed.__qualname__            == 'write_signed'
# ---------------------------------------------------------------------------

table multiprocessing_extra270.mp_forkserver_module_and_class_identity:
  description: "multiprocessing.forkserver module identity and ForkServer class identity checks in mpforkserver270 namespace — multiprocessing.forkserver is defined in Lib/multiprocessing/forkserver.py; its __name__ is 'multiprocessing.forkserver' (len=26: 'multiprocessing'=15+'.forkserver'=11); __spec__.name is also 'multiprocessing.forkserver'; __name__.__len__()==26; __package__ is 'multiprocessing'; __loader__.__class__.__name__ is 'SourceFileLoader' (same as spawn); ForkServer is the single class in forkserver with MRO [ForkServer, object] (len=2); ForkServer.__name__.__eq__('ForkServer')==True; ForkServer.__module__.__eq__('multiprocessing.forkserver')==True; ForkServer.__qualname__.__eq__('ForkServer')==True; ForkServer.__bases__[0].__name__.__eq__('object')==True; ForkServer.__mro__.__len__()==2; forkserver.main.__qualname__.__eq__('main')==True; forkserver.read_signed.__qualname__.__eq__('read_signed')==True; forkserver.write_signed.__qualname__.__eq__('write_signed')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpforkserver270

  columns: [id, function, args, expected, description]
  rows:
    - [fs_mod_name_eq,    multiprocessing.forkserver.__name__.__eq__,                       ["multiprocessing.forkserver"],  true, "multiprocessing.forkserver.__name__ == 'multiprocessing.forkserver'; verified with Python 3.14.3"]
    - [fs_mod_spec_eq,    multiprocessing.forkserver.__spec__.name.__eq__,                  ["multiprocessing.forkserver"],  true, "multiprocessing.forkserver.__spec__.name == 'multiprocessing.forkserver'; verified with Python 3.14.3"]
    - [fs_mod_name_len,   multiprocessing.forkserver.__name__.__len__,                      [],                              26,   "multiprocessing.forkserver.__name__.__len__() == 26 ('multiprocessing.forkserver'=26); verified with Python 3.14.3"]
    - [fs_mod_pkg_eq,     multiprocessing.forkserver.__package__.__eq__,                    ["multiprocessing"],             true, "multiprocessing.forkserver.__package__ == 'multiprocessing'; verified with Python 3.14.3"]
    - [fs_mod_loader_eq,  multiprocessing.forkserver.__loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],            true, "multiprocessing.forkserver.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [fscls_name_eq,     multiprocessing.forkserver.ForkServer.__name__.__eq__,            ["ForkServer"],                  true, "multiprocessing.forkserver.ForkServer.__name__ == 'ForkServer'; verified with Python 3.14.3"]
    - [fscls_mod_eq,      multiprocessing.forkserver.ForkServer.__module__.__eq__,          ["multiprocessing.forkserver"],  true, "multiprocessing.forkserver.ForkServer.__module__ == 'multiprocessing.forkserver'; verified with Python 3.14.3"]
    - [fscls_qn_eq,       multiprocessing.forkserver.ForkServer.__qualname__.__eq__,        ["ForkServer"],                  true, "multiprocessing.forkserver.ForkServer.__qualname__ == 'ForkServer'; verified with Python 3.14.3"]
    - [fscls_base0_eq,    "multiprocessing.forkserver.ForkServer.__bases__[0].__name__.__eq__", ["object"],                  true, "multiprocessing.forkserver.ForkServer.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [fscls_mro_len,     multiprocessing.forkserver.ForkServer.__mro__.__len__,            [],                              2,    "multiprocessing.forkserver.ForkServer.__mro__.__len__() == 2 — [ForkServer, object]; verified with Python 3.14.3"]
    - [main_qn_eq,        multiprocessing.forkserver.main.__qualname__.__eq__,              ["main"],                        true, "multiprocessing.forkserver.main.__qualname__ == 'main' (module-level function); verified with Python 3.14.3"]
    - [read_qn_eq,        multiprocessing.forkserver.read_signed.__qualname__.__eq__,       ["read_signed"],                 true, "multiprocessing.forkserver.read_signed.__qualname__ == 'read_signed'; verified with Python 3.14.3"]
    - [write_qn_eq,       multiprocessing.forkserver.write_signed.__qualname__.__eq__,      ["write_signed"],                true, "multiprocessing.forkserver.write_signed.__qualname__ == 'write_signed'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra270
# ---------------------------------------------------------------------------

invariant multiprocessing_extra270.spawn_name_eq:
  description: "multiprocessing.spawn.__name__.__eq__('multiprocessing.spawn') returns True — the module's __name__ is 'multiprocessing.spawn' (len=21: 'multiprocessing'=15+'.spawn'=6=21); multiprocessing.spawn.__spec__.name is also 'multiprocessing.spawn'; multiprocessing.spawn provides the core infrastructure for the 'spawn' start method for new processes (the default on macOS and Windows); multiprocessing.spawn.__package__ is 'multiprocessing'; compare module name lengths within multiprocessing: spawn=21, forkserver=26, synchronize=27 (longest); NEW in extra270: first standalone multiprocessing.spawn module name invariant in mpspawn270 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.spawn.__name__.__eq__
  args: ["multiprocessing.spawn"]
  expected: true

invariant multiprocessing_extra270.spawn_name_len_is_21:
  description: "multiprocessing.spawn.__name__.__len__() == 21 — multiprocessing.spawn.__name__ is 'multiprocessing.spawn' (21 characters: 'multiprocessing'=15+'.spawn'=6=21); multiprocessing.spawn.__spec__.name.__len__() is also 21; compare submodule name lengths: spawn=21, forkserver=26 (longer), synchronize=27 (longest); multiprocessing.spawn.__package__ is 'multiprocessing' (len=15); NEW in extra270: first standalone multiprocessing.spawn name length invariant in mpspawn270 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.spawn.__name__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra270.spawn_loader_is_SourceFileLoader:
  description: "multiprocessing.spawn.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — multiprocessing.spawn is a plain Python source module loaded by importlib.machinery.SourceFileLoader; it is not frozen, not a C extension, and not a built-in; the SourceFileLoader class is used for all standard .py source files; multiprocessing.forkserver.__loader__.__class__.__name__ is also 'SourceFileLoader' (both spawn and forkserver are plain source modules); multiprocessing.spawn.__package__ is 'multiprocessing'; NEW in extra270: first standalone multiprocessing.spawn loader class name invariant in mpspawn270 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.spawn.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant multiprocessing_extra270.forkserver_name_len_is_26:
  description: "multiprocessing.forkserver.__name__.__len__() == 26 — multiprocessing.forkserver.__name__ is 'multiprocessing.forkserver' (26 characters: 'multiprocessing'=15+'.forkserver'=11=26); multiprocessing.forkserver.__spec__.name is also 'multiprocessing.forkserver' (len=26); compare: multiprocessing.spawn.__name__.__len__() is 21, multiprocessing.synchronize.__name__.__len__() is 27; forkserver is one character shorter than synchronize; multiprocessing.forkserver.__package__ is 'multiprocessing'; NEW in extra270: first standalone multiprocessing.forkserver name length invariant in mpforkserver270 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.forkserver.__name__.__len__
  args: []
  expected: 26

invariant multiprocessing_extra270.ForkServer_module_is_forkserver:
  description: "multiprocessing.forkserver.ForkServer.__module__.__eq__('multiprocessing.forkserver') returns True — ForkServer is defined in Lib/multiprocessing/forkserver.py; its __module__ is 'multiprocessing.forkserver' (len=26); ForkServer is a direct subclass of object (MRO [ForkServer, object], len=2); ForkServer manages the lifecycle of the forkserver helper process used when start method is 'forkserver' (Linux only); ForkServer.__qualname__ is 'ForkServer'; ForkServer.__name__.__len__() is 10 ('ForkServer'=10); NEW in extra270: first standalone ForkServer.__module__ invariant in mpforkserver270 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.forkserver.ForkServer.__module__.__eq__
  args: ["multiprocessing.forkserver"]
  expected: true

invariant multiprocessing_extra270.ForkServer_mro_len_is_2:
  description: "multiprocessing.forkserver.ForkServer.__mro__.__len__() == 2 — ForkServer's MRO is [ForkServer, object] (length=2); ForkServer is a direct subclass of object with no intermediate base class; this is the shortest possible MRO for a new-style Python class; compare: multiprocessing.synchronize.Semaphore.__mro__.__len__() is 3 (has SemLock in chain); ForkServer.__bases__[0].__name__ is 'object'; ForkServer.__module__ is 'multiprocessing.forkserver'; NEW in extra270: first standalone ForkServer MRO length invariant in mpforkserver270 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.forkserver.ForkServer.__mro__.__len__
  args: []
  expected: 2
