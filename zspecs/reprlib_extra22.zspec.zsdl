spec: reprlib_extra22
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib_extra21.zspec.zsdl."
    - "Prior specs covered: reprlib.__name__/__package__; repr/__name__/__module__; recursive_repr/__name__/__module__/__qualname__; aRepr/__class__.__name__; Repr/__name__/__module__/__qualname__; Repr.__bases__[0].__name__; all Repr method __name__/__qualname__ lengths; aRepr class identity lengths; reprlib.repr.__name__.__len__(); reprlib.recursive_repr.__name__.__len__(); Repr.__name__.__len__()."
    - "This spec covers: reprlib.__all__.__len__() (== 3); Repr.__reduce__.__qualname__.__len__() and __name__.__len__(); Repr.__mro__.__len__() (== 2); Repr.__bases__[0].__name__.__len__() ('object', len 6); Repr.__dict__.__class__.__name__ ('mappingproxy', len 12); Repr.repr_frozenset.__qualname__.__len__() (== 19); Repr instance defaults: maxother/maxstring/maxlevel/maxdict/maxlist/maxtuple/maxset/maxfrozenset/maxarray/maxdeque."
    - "reprlib.__all__ == ['Repr', 'repr', 'recursive_repr']; len == 3. Verified at runtime."
    - "Repr.__reduce__.__qualname__ == 'object.__reduce__'; len == 17. Verified at runtime."
    - "Repr.__reduce__.__name__ == '__reduce__'; len == 10. Verified at runtime."
    - "Repr.__mro__.__len__() == 2 — Repr inherits from object only. Verified at runtime."
    - "Repr.__bases__[0].__name__ == 'object'; len == 6. Verified at runtime."
    - "Repr.__dict__.__class__.__name__ == 'mappingproxy'; len == 12. Verified at runtime."
    - "Repr.repr_frozenset.__qualname__ == 'Repr.repr_frozenset'; len == 19. Verified at runtime."
    - "Repr().maxother == 30. Verified at runtime."
    - "Repr().maxstring == 30. Verified at runtime."
    - "Repr().maxlevel == 6. Verified at runtime."
    - "Repr().maxdict == 4. Verified at runtime."
    - "Repr().maxlist == 6. Verified at runtime."
    - "Repr().maxtuple == 6. Verified at runtime."
    - "Repr().maxset == 6. Verified at runtime."
    - "Repr().maxfrozenset == 6. Verified at runtime."
    - "Repr().maxarray == 5. Verified at runtime."
    - "Repr().maxdeque == 6. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reprlib.__all__.__len__()
#
# reprlib.__all__ == ['Repr', 'repr', 'recursive_repr'] — exactly three names
# are exported from the public API. len == 3. No prior spec verifies __len__()
# on reprlib.__all__ itself.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra22.all.len:
  description: "len(reprlib.__all__) == 3 — reprlib exports exactly three names: Repr, repr, recursive_repr"
  category: module_structure
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Repr.__reduce__ qualname and name lengths
#
# Repr inherits __reduce__ from object. Therefore:
#   Repr.__reduce__.__qualname__ == 'object.__reduce__' (17 chars)
#   Repr.__reduce__.__name__    == '__reduce__'         (10 chars)
# No prior spec verifies these lengths.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra22.Repr.reduce_qualname_len:
  description: "len(reprlib.Repr.__reduce__.__qualname__) == 17 — 'object.__reduce__' is 17 characters"
  category: class_identity
  kind: python_call_eq
  function: Repr.__reduce__.__qualname__.__len__
  args: []
  expected: 17

invariant reprlib_extra22.Repr.reduce_name_len:
  description: "len(reprlib.Repr.__reduce__.__name__) == 10 — '__reduce__' is 10 characters"
  category: class_identity
  kind: python_call_eq
  function: Repr.__reduce__.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Repr.__mro__ length
#
# reprlib.Repr inherits solely from object, so Repr.__mro__ == (Repr, object).
# len == 2. This is the minimal MRO for a single-inheritance class.
# No prior spec verifies Repr.__mro__.__len__().
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra22.Repr.mro_len:
  description: "len(reprlib.Repr.__mro__) == 2 — Repr inherits only from object"
  category: class_identity
  kind: python_call_eq
  function: Repr.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Repr.__bases__[0].__name__.__len__()
#
# Repr.__bases__ == (object,); the base class name is 'object', which is
# 6 characters. No prior spec verifies this __len__() on the base class name.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra22.Repr.base_name_len:
  description: "len(reprlib.Repr.__bases__[0].__name__) == 6 — 'object' is 6 characters"
  category: class_identity
  kind: python_call_eq
  function: "Repr.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Repr.__dict__.__class__.__name__.__len__()
#
# Repr.__dict__ is a mappingproxy (the standard class namespace wrapper).
# len('mappingproxy') == 12. No prior spec verifies this chain.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra22.Repr.dict_class_name_len:
  description: "len(reprlib.Repr.__dict__.__class__.__name__) == 12 — 'mappingproxy' is 12 characters"
  category: class_identity
  kind: python_call_eq
  function: Repr.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: reprlib.__all__ membership checks
#
# reprlib.__all__ contains exactly three names. These eq-checks confirm each
# expected public name is present via membership test using __contains__.
# No prior spec verifies __all__ membership for reprlib.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra22.all_membership:
  description: "reprlib.__all__ membership — confirms Repr, repr, recursive_repr are exported"
  kind: python_call_eq
  category: module_structure
  id_prefix: rl22am

  columns: [id, function, args, expected]
  rows:
    - [repr_in_all,           "__all__.__contains__",  ["repr"],           true]
    - [Repr_in_all,           "__all__.__contains__",  ["Repr"],           true]
    - [recursive_repr_in_all, "__all__.__contains__",  ["recursive_repr"], true]
    - [all_len,               "__all__.__len__",        [],                 3]

# ---------------------------------------------------------------------------
# Table: Repr instance default limits
#
# A default reprlib.Repr() instance has well-defined default limits for each
# container type. These defaults govern the maximum number of elements shown
# and the maximum string/int length. No prior spec verifies these defaults.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra22.Repr_instance_defaults:
  description: "reprlib.Repr() instance default limit attributes — maxother/maxstring/maxlevel/maxdict/maxlist/maxtuple/maxset/maxfrozenset/maxarray/maxdeque"
  kind: python_call_eq
  category: constants
  id_prefix: rl22rid

  columns: [id, function, args, expected, description]
  rows:
    - [maxother,     aRepr.maxother.__eq__,     [30], true, "maxother default is 30"]
    - [maxstring,    aRepr.maxstring.__eq__,     [30], true, "maxstring default is 30"]
    - [maxlevel,     aRepr.maxlevel.__eq__,      [6],  true, "maxlevel default is 6"]
    - [maxdict,      aRepr.maxdict.__eq__,       [4],  true, "maxdict default is 4"]
    - [maxlist,      aRepr.maxlist.__eq__,        [6],  true, "maxlist default is 6"]
    - [maxtuple,     aRepr.maxtuple.__eq__,      [6],  true, "maxtuple default is 6"]
    - [maxset,       aRepr.maxset.__eq__,        [6],  true, "maxset default is 6"]
    - [maxfrozenset, aRepr.maxfrozenset.__eq__,  [6],  true, "maxfrozenset default is 6"]
    - [maxarray,     aRepr.maxarray.__eq__,      [5],  true, "maxarray default is 5"]
    - [maxdeque,     aRepr.maxdeque.__eq__,      [6],  true, "maxdeque default is 6"]
