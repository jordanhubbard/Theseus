spec: multiprocessing_extra1246
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing __doc__ class checks for module, Process, Queue, Lock, Pool, Manager, Pipe, Value, Array, Semaphore, Event, Condition"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that multiprocessing classes Queue, Lock, Pool, Manager, Pipe, Value, Array, Semaphore, Event, Condition have str __doc__; module __doc__ is NoneType; Process.__doc__ is NoneType; distinct from extra1231 (__dict__.__contains__), extra1201 (__bases__.__len__), extra1216 (__mro__.__len__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1246.class_doc_is_str:
  description: "multiprocessing classes Queue, Lock, Pool, Manager, Pipe, Value, Array, Semaphore, Event, Condition have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: mp1246cs
  columns: [id, function, args, expected]
  rows:
    - [mp1246cs001, multiprocessing.Queue.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [mp1246cs002, multiprocessing.Lock.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [mp1246cs003, multiprocessing.Pool.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [mp1246cs004, multiprocessing.Manager.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [mp1246cs005, multiprocessing.Pipe.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [mp1246cs006, multiprocessing.Value.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [mp1246cs007, multiprocessing.Array.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [mp1246cs008, multiprocessing.Semaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [mp1246cs009, multiprocessing.Event.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [mp1246cs010, multiprocessing.Condition.__doc__.__class__.__name__.__eq__, ["str"], true]

table multiprocessing_extra1246.module_and_process_doc_is_nonetype:
  description: "multiprocessing module __doc__ and Process.__doc__ are NoneType; str classes are not NoneType"
  kind: python_call_eq
  category: doc_class
  id_prefix: mp1246mn
  columns: [id, function, args, expected]
  rows:
    - [mp1246mn001, multiprocessing.__doc__.__class__.__name__.__eq__,        ["NoneType"], true]
    - [mp1246mn002, multiprocessing.Process.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
    - [mp1246mn003, multiprocessing.__doc__.__class__.__name__.__eq__,        ["str"],      false]
    - [mp1246mn004, multiprocessing.Process.__doc__.__class__.__name__.__eq__, ["str"],     false]
    - [mp1246mn005, multiprocessing.Queue.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [mp1246mn006, multiprocessing.Lock.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [mp1246mn007, multiprocessing.Pool.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [mp1246mn008, multiprocessing.Value.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [mp1246mn009, multiprocessing.Array.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [mp1246mn010, multiprocessing.Event.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]

table multiprocessing_extra1246.doc_class_not_int_or_float:
  description: "multiprocessing class __doc__ class name is not int, float, or list for all str-documented classes"
  kind: python_call_eq
  category: doc_class
  id_prefix: mp1246nf
  columns: [id, function, args, expected]
  rows:
    - [mp1246nf001, multiprocessing.Queue.__doc__.__class__.__name__.__eq__,     ["int"],   false]
    - [mp1246nf002, multiprocessing.Queue.__doc__.__class__.__name__.__eq__,     ["float"], false]
    - [mp1246nf003, multiprocessing.Lock.__doc__.__class__.__name__.__eq__,      ["int"],   false]
    - [mp1246nf004, multiprocessing.Pool.__doc__.__class__.__name__.__eq__,      ["int"],   false]
    - [mp1246nf005, multiprocessing.Manager.__doc__.__class__.__name__.__eq__,   ["int"],   false]
    - [mp1246nf006, multiprocessing.Pipe.__doc__.__class__.__name__.__eq__,      ["int"],   false]
    - [mp1246nf007, multiprocessing.Value.__doc__.__class__.__name__.__eq__,     ["int"],   false]
    - [mp1246nf008, multiprocessing.Array.__doc__.__class__.__name__.__eq__,     ["int"],   false]
    - [mp1246nf009, multiprocessing.Semaphore.__doc__.__class__.__name__.__eq__, ["int"],   false]
    - [mp1246nf010, multiprocessing.Condition.__doc__.__class__.__name__.__eq__, ["int"],   false]
