spec: marked
version: ">=4.0.0"
backend: node(marked)

docs: https://marked.js.org/

provenance:
  derived_from:
    - "marked README — https://github.com/markedjs/marked#readme"
    - "Test vectors verified with marked@18.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "marked source: src/marked.ts"
  notes:
    - "marked exports { marked } as a named export."
    - "marked(markdown) returns HTML string."
    - "Headings are wrapped in <h1>...<h6> tags with a trailing newline."
    - "Paragraphs are wrapped in <p> tags."
    - "Bold (**text**) produces <strong>text</strong>."
    - "Output includes trailing newlines after block-level elements."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an HTML string. No errors for valid markdown."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table marked.headings:
  kind: node_module_call_eq
  function: marked
  category: headings
  id_prefix: md_h

  columns: [id, args, expected]
  rows:
    - [h1,  ["# Hello"],   "<h1>Hello</h1>\n"]

table marked.inline:
  kind: node_module_call_eq
  function: marked
  category: inline
  id_prefix: md_inline

  columns: [id, args, expected]
  rows:
    - [bold,    ["**bold**"],      "<p><strong>bold</strong></p>\n"]
    - [italic,  ["*italic*"],      "<p><em>italic</em></p>\n"]

table marked.paragraph:
  kind: node_module_call_eq
  function: marked
  category: paragraph
  id_prefix: md_p

  columns: [id, args, expected]
  rows:
    - [plain,  ["Hello world"],  "<p>Hello world</p>\n"]
