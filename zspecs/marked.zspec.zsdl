spec: marked
version: ">=14.0.0"
backend: node(marked)

docs: https://www.npmjs.com/package/marked

provenance:
  derived_from:
    - "marked README — https://www.npmjs.com/package/marked"
    - "Test vectors verified with marked via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "marked source"
  notes:
    - "marked is an npm package. Install: npm install marked"
    - "marked.parse(markdown) converts a Markdown string to HTML."
    - "Headings produce <h1>...</h1>\\n, paragraphs produce <p>...</p>\\n."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns HTML string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table marked.parse:
  kind: node_module_call_eq
  function: parse
  category: render
  id_prefix: mkd

  columns: [id, args, expected]
  rows:
    - [heading, ["# Hello"],   "<h1>Hello</h1>\n"]
    - [bold,    ["**bold**"],  "<p><strong>bold</strong></p>\n"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:08:30Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
