spec: socket_extra116
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra115.zspec.zsdl — covers socket error class __name__/__module__ equality / exception base class identity (all inherit from OSError) / builtin alias exception module and name lengths (table + invariants)."
    - "socket_extra113.zspec.zsdl — covers socket.socket.send/recv/listen/accept/setsockopt/getsockopt qualname equality and type identity (table + invariants)."
    - "socket_extra112.zspec.zsdl — covers AddressFamily/SocketKind enum .name equality and lengths / socket.socket MRO structure / socket.socket.bind and connect qualname lengths (table + invariants)."
    - "socket_extra110.zspec.zsdl — covers socket.socket context manager methods / socket.__repr__ qualname / socket.socket.__module__/__qualname__ equality (table + invariants)."
    - "socket_extra109.zspec.zsdl — covers socket.socket Python-defined method co_argcount values and qualnames (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra115; it does NOT duplicate invariants present in those files."
    - "Wave 276 theme: socket.socket fileno/setblocking/settimeout/gettimeout/makefile method qualnames not yet covered — socket_extra113 anchors send/recv/listen/accept/setsockopt/getsockopt; socket_extra109 anchors Python-defined method co_argcount and qualnames; socket_extra112 anchors bind/connect qualname lengths; NOT YET covered: fileno/setblocking/settimeout/gettimeout/makefile qualname equality, qualname lengths, and type identities."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__qualname__ == 'socket.setblocking'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__qualname__ == 'socket.settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__qualname__ == 'socket.gettimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__qualname__ == 'socket.makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('socket.fileno') == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('socket.setblocking') == 18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('socket.settimeout') == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('socket.gettimeout') == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('socket.makefile') == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.fileno).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.setblocking).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.settimeout).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.gettimeout).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.makefile).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The qualname prefix is 'socket.' (not 'socket.socket.') because these are methods of the C-level _socket.socket type, whose __qualname__ is 'socket'. This is distinct from Python-level classes where the qualname would include the module-qualified class name. socket.socket.makefile is a Python function (defined in Lib/socket.py) while the others are C-level method_descriptor objects from Modules/socketmodule.c."
    - "Note: settimeout and gettimeout share the same qualname length (17 chars each: 'socket.settimeout' and 'socket.gettimeout'). They differ only in 'set' vs 'get' prefix (3 chars each)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.fileno.__qualname__.__eq__('socket.fileno')
# socket.socket.setblocking.__qualname__.__eq__('socket.setblocking')
# socket.socket.settimeout.__qualname__.__eq__('socket.settimeout')
# socket.socket.gettimeout.__qualname__.__eq__('socket.gettimeout')
# socket.socket.makefile.__qualname__.__eq__('socket.makefile')
#
# Wave 276 theme: socket.socket method qualname equality.
#
# fileno/setblocking/settimeout/gettimeout are C-level method_descriptors with
# qualname prefix 'socket.' (from the C-level _socket.socket type). makefile is
# a Python function in Lib/socket.py with the same qualname pattern. socket_extra113
# anchors send/recv/listen/accept/setsockopt/getsockopt qualnames; socket_extra109
# anchors Python-defined co_argcount and qualnames. These five are not yet covered.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra116.socket_method_qualname_equality:
  description: "socket.fileno.__qualname__.__eq__('socket.fileno')==True / socket.setblocking.__qualname__.__eq__('socket.setblocking')==True / socket.settimeout.__qualname__.__eq__('socket.settimeout')==True / socket.gettimeout.__qualname__.__eq__('socket.gettimeout')==True / socket.makefile.__qualname__.__eq__('socket.makefile')==True — all five use 'socket.' prefix (from C-level _socket.socket type __qualname__=='socket'); fileno/setblocking/settimeout/gettimeout are method_descriptor; makefile is function; extra113 anchors send/recv/etc; first sockmethod116 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockmethod116

  columns: [id, function, args, expected, description]
  rows:
    - [fileno_qualname_eq,      "socket.fileno.__qualname__.__eq__",      ["socket.fileno"],      true, "socket.socket.fileno.__qualname__ is 'socket.fileno' (C-level method; 'socket.' prefix from _socket.socket type)"]
    - [setblocking_qualname_eq, "socket.setblocking.__qualname__.__eq__", ["socket.setblocking"], true, "socket.socket.setblocking.__qualname__ is 'socket.setblocking' (C-level method; sets blocking/non-blocking mode)"]
    - [settimeout_qualname_eq,  "socket.settimeout.__qualname__.__eq__",  ["socket.settimeout"],  true, "socket.socket.settimeout.__qualname__ is 'socket.settimeout' (C-level method; sets socket timeout in seconds)"]
    - [gettimeout_qualname_eq,  "socket.gettimeout.__qualname__.__eq__",  ["socket.gettimeout"],  true, "socket.socket.gettimeout.__qualname__ is 'socket.gettimeout' (C-level method; returns current timeout value)"]
    - [makefile_qualname_eq,    "socket.makefile.__qualname__.__eq__",    ["socket.makefile"],    true, "socket.socket.makefile.__qualname__ is 'socket.makefile' (Python function in Lib/socket.py; wraps socket as file object)"]

# ---------------------------------------------------------------------------
# socket.socket.fileno.__qualname__.__len__() == 13
# socket.socket.setblocking.__qualname__.__len__() == 18
# socket.socket.settimeout.__qualname__.__len__() == 17
# socket.socket.gettimeout.__qualname__.__len__() == 17
# socket.socket.makefile.__qualname__.__len__() == 15
#
# Wave 276 theme: socket.socket method qualname lengths.
#
# 'socket.fileno' is 13 chars (shortest); 'socket.makefile' is 15; 'socket.settimeout'
# and 'socket.gettimeout' are both 17 (sharing the same qualname length with only
# 'set'/'get' swap); 'socket.setblocking' is 18 (longest). No prior socket spec
# anchors these five qualname lengths as a grouped table. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra116.socket_method_qualname_lengths:
  description: "socket.fileno.__qualname__.__len__()==13 / socket.setblocking.__qualname__.__len__()==18 / socket.settimeout.__qualname__.__len__()==17 / socket.gettimeout.__qualname__.__len__()==17 / socket.makefile.__qualname__.__len__()==15 — fileno=13 (shortest), makefile=15, settimeout=gettimeout=17 (tied; same prefix 'socket.' and same suffix length with 'set'/'get' swap), setblocking=18 (longest); no prior spec anchors these lengths; first sockmethod116 anchor for qualname lengths"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockmethod116

  columns: [id, function, args, expected, description]
  rows:
    - [fileno_qualname_len,      "socket.fileno.__qualname__.__len__",      [], 13, "socket.socket.fileno.__qualname__.__len__() is 13 (len('socket.fileno')==13; shortest of the five)"]
    - [setblocking_qualname_len, "socket.setblocking.__qualname__.__len__", [], 18, "socket.socket.setblocking.__qualname__.__len__() is 18 (len('socket.setblocking')==18; longest of the five)"]
    - [settimeout_qualname_len,  "socket.settimeout.__qualname__.__len__",  [], 17, "socket.socket.settimeout.__qualname__.__len__() is 17 (len('socket.settimeout')==17; tied with gettimeout)"]
    - [gettimeout_qualname_len,  "socket.gettimeout.__qualname__.__len__",  [], 17, "socket.socket.gettimeout.__qualname__.__len__() is 17 (len('socket.gettimeout')==17; tied with settimeout; only 'set'/'get' differs)"]
    - [makefile_qualname_len,    "socket.makefile.__qualname__.__len__",    [], 15, "socket.socket.makefile.__qualname__.__len__() is 15 (len('socket.makefile')==15; Python function; between fileno and settimeout)"]

# ---------------------------------------------------------------------------
# type(socket.socket.fileno).__name__.__eq__('method_descriptor')
# type(socket.socket.setblocking).__name__.__eq__('method_descriptor')
# type(socket.socket.settimeout).__name__.__eq__('method_descriptor')
# type(socket.socket.gettimeout).__name__.__eq__('method_descriptor')
# type(socket.socket.makefile).__name__.__eq__('function')
#
# Wave 276 theme: socket.socket method type identity.
#
# fileno, setblocking, settimeout, and gettimeout are all method_descriptor
# (C-level methods from Modules/socketmodule.c). makefile is a Python 'function'
# (defined in Lib/socket.py). This type distinction separates the C implementation
# from the Python wrapper. No prior socket spec anchors these five type identities
# as a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra116.socket_method_type_identity:
  description: "socket.fileno.__class__.__name__.__eq__('method_descriptor')==True / socket.setblocking.__class__.__name__.__eq__('method_descriptor')==True / socket.settimeout.__class__.__name__.__eq__('method_descriptor')==True / socket.gettimeout.__class__.__name__.__eq__('method_descriptor')==True / socket.makefile.__class__.__name__.__eq__('function')==True — fileno/setblocking/settimeout/gettimeout are C-level method_descriptor (from socketmodule.c); makefile is Python function (from Lib/socket.py); extra113 anchors send/recv type identity; first sockmethod116 anchor for these five type identities"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmethod116

  columns: [id, function, args, expected, description]
  rows:
    - [fileno_type_eq,      "socket.fileno.__class__.__name__.__eq__",      ["method_descriptor"], true, "socket.socket.fileno.__class__.__name__ is 'method_descriptor' (C-level; returns the file descriptor integer)"]
    - [setblocking_type_eq, "socket.setblocking.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.setblocking.__class__.__name__ is 'method_descriptor' (C-level; sets blocking or non-blocking I/O mode)"]
    - [settimeout_type_eq,  "socket.settimeout.__class__.__name__.__eq__",  ["method_descriptor"], true, "socket.socket.settimeout.__class__.__name__ is 'method_descriptor' (C-level; sets socket operation timeout)"]
    - [gettimeout_type_eq,  "socket.gettimeout.__class__.__name__.__eq__",  ["method_descriptor"], true, "socket.socket.gettimeout.__class__.__name__ is 'method_descriptor' (C-level; returns current timeout or None for blocking)"]
    - [makefile_type_eq,    "socket.makefile.__class__.__name__.__eq__",    ["function"],          true, "socket.socket.makefile.__class__.__name__ is 'function' (Python-level; wraps socket as a file-like object for read/write)"]

# ---------------------------------------------------------------------------
# socket.socket.fileno.__qualname__.__eq__('socket.fileno') — standalone
#
# socket.socket.fileno.__qualname__ is 'socket.fileno'. fileno() returns the
# integer file descriptor associated with the socket. The qualname 'socket.fileno'
# (13 chars) uses the 'socket.' prefix derived from the C-level _socket.socket
# type whose __qualname__ is 'socket'. This makes it the shortest qualname of
# the five methods in this spec. socket_extra113 anchors send/recv/listen/accept
# qualnames; no prior socket spec anchors fileno.__qualname__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra116.socket_fileno_qualname_eq:
  description: "socket.socket.fileno.__qualname__.__eq__('socket.fileno') == True — qualname is 'socket.fileno' (13 chars; shortest of the five; 'socket.'=7+'fileno'=6=13); method_descriptor type; returns the integer file descriptor; extra113 anchors send/recv qualnames; no prior spec anchors fileno qualname as standalone; first standalone under sockmethod116"
  category: function_identity
  kind: python_call_eq
  function: socket.fileno.__qualname__.__eq__
  args: ["socket.fileno"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setblocking.__qualname__.__len__() == 18 — standalone
#
# socket.socket.setblocking.__qualname__.__len__() is 18. 'socket.setblocking'
# has 18 chars: 'socket.' (7) + 'setblocking' (11) = 18. setblocking(flag) puts
# the socket into blocking (True) or non-blocking (False) mode. In non-blocking
# mode, socket operations raise BlockingIOError if they would block. 18 chars
# makes this the longest qualname of the five methods in this spec (one more than
# settimeout/gettimeout at 17). No prior socket spec anchors setblocking qualname
# length as a standalone under sockmethod116. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra116.socket_setblocking_qualname_len_18:
  description: "socket.socket.setblocking.__qualname__.__len__() == 18 — len('socket.setblocking')==18 ('socket.'=7+'setblocking'=11=18); longest of the five method qualnames; puts socket in blocking/non-blocking mode; non-blocking mode raises BlockingIOError; no prior spec anchors setblocking qualname length as standalone; first standalone under sockmethod116"
  category: function_identity
  kind: python_call_eq
  function: socket.setblocking.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# socket.socket.makefile.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.makefile.__class__.__name__ is 'function'. Unlike the C-level
# socket methods (fileno, setblocking, settimeout, gettimeout), makefile is a
# pure Python function defined in Lib/socket.py. It returns a file object
# associated with the socket, allowing socket I/O via the standard file API.
# The function type distinction separates makefile from the C-extension
# method_descriptors. No prior socket spec anchors makefile type identity as
# a standalone under sockmethod116. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra116.socket_makefile_class_function:
  description: "socket.socket.makefile.__class__.__name__.__eq__('function') == True — makefile is a Python function (not method_descriptor; defined in Lib/socket.py); returns file object for socket I/O using standard file API; contrasts with C-level method_descriptor for fileno/setblocking/settimeout/gettimeout; no prior spec anchors makefile type as standalone; first standalone under sockmethod116"
  category: type_identity
  kind: python_call_eq
  function: socket.makefile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.settimeout.__name__.__len__() == 10 — standalone
#
# socket.socket.settimeout.__name__.__len__() is 10. '__name__' for method
# descriptors is the bare method name without the class prefix. 'settimeout'
# has 10 chars: 'set' (3) + 'timeout' (7) = 10. This equals gettimeout.__name__
# (also 10 chars: 'get'(3)+'timeout'(7)=10). Their __name__ values are equal
# in length (both 10) while differing in the first 3 chars ('set' vs 'get').
# No prior socket spec anchors settimeout.__name__.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra116.socket_settimeout_name_len_10:
  description: "socket.socket.settimeout.__name__.__len__() == 10 — len('settimeout')==10 ('set'=3+'timeout'=7=10); equals gettimeout __name__ length (also 10; same suffix length; only 'set'/'get' differs); settimeout sets timeout in seconds (None for blocking, 0 for non-blocking); no prior spec anchors settimeout name length as standalone; first standalone under sockmethod116"
  category: function_identity
  kind: python_call_eq
  function: socket.settimeout.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# socket.socket.gettimeout.__qualname__.__len__() == 17 — standalone
#
# socket.socket.gettimeout.__qualname__.__len__() is 17. 'socket.gettimeout'
# has 17 chars: 'socket.' (7) + 'gettimeout' (10) = 17. gettimeout() returns
# the current timeout value for the socket: a float in seconds if a timeout is
# set, 0.0 if the socket is in non-blocking mode, or None if the socket is in
# blocking mode. settimeout shares the same qualname length (17). No prior socket
# spec anchors gettimeout qualname length as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra116.socket_gettimeout_qualname_len_17:
  description: "socket.socket.gettimeout.__qualname__.__len__() == 17 — len('socket.gettimeout')==17 ('socket.'=7+'gettimeout'=10=17); tied with settimeout qualname length (17); gettimeout returns float/0.0/None for timeout/non-blocking/blocking mode; no prior spec anchors gettimeout qualname length as standalone; first standalone under sockmethod116"
  category: function_identity
  kind: python_call_eq
  function: socket.gettimeout.__qualname__.__len__
  args: []
  expected: 17
