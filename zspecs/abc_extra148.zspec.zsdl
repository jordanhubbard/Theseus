spec: abc_extra148
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc module deprecated abstract decorator variants and get_cache_token identity. abc.abstractproperty.__name__=='abstractproperty' (len=16; deprecated since Python 3.3); abc.abstractproperty.__module__=='abc' (len=3; defined in Lib/abc.py); abc.abstractproperty.__bases__[0].__name__=='property' (abstractproperty inherits from property); abc.abstractclassmethod.__name__=='abstractclassmethod' (len=19; deprecated since Python 3.3); abc.abstractclassmethod.__bases__[0].__name__=='classmethod'; abc.abstractstaticmethod.__name__=='abstractstaticmethod' (len=20; deprecated since Python 3.3); abc.abstractstaticmethod.__bases__[0].__name__=='staticmethod'; abc.get_cache_token.__module__=='_abc' (len=4; comes from the C extension _abc, NOT from 'abc'); abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26; it is a C-level builtin, not a Python function); abc.ABCMeta.__name__.__len__()==7. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractproperty, abc.abstractclassmethod, abc.abstractstaticmethod are all deprecated since Python 3.3 but still present in abc.__dict__ on Python 3.14.3 (as confirmed in abc_extra146); they inherit from property, classmethod, and staticmethod respectively, adding __isabstractmethod__=True; name lengths: abstractstaticmethod(20) > abstractclassmethod(19) > abstractproperty(16); all have __module__=='abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__module__=='_abc' — get_cache_token comes from the C extension module _abc (Modules/_abc.c), not from the Python abc module; its __module__ is '_abc' (len=4, with leading underscore — the private C extension); abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26; it is a C-level builtin function); compare: abc.abstractmethod.__module__=='abc' (pure Python) vs abc.get_cache_token.__module__=='_abc' (C extension). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__name__.__len__()==7 — 'ABCMeta' has 7 characters ('A'+'B'+'C'+'M'+'e'+'t'+'a'=7); this length was established in abc_extra147. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc deprecated abstract decorator identity — extra148
#
# abc.abstractproperty.__name__.__eq__('abstractproperty')           == True
# abc.abstractproperty.__module__.__eq__('abc')                      == True
# abc.abstractproperty.__bases__[0].__name__.__eq__('property')      == True
# abc.abstractclassmethod.__name__.__eq__('abstractclassmethod')     == True
# abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod') == True
# abc.abstractstaticmethod.__name__.__eq__('abstractstaticmethod')   == True
# abc.abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod') == True
# ---------------------------------------------------------------------------

table abc_extra148.abc_deprecated_decorator_identity:
  description: "abc deprecated abstract decorator class identity checks in abcdep148 namespace — abc.abstractproperty.__name__=='abstractproperty' (len=16; deprecated since Python 3.3; use @property @abstractmethod instead); abc.abstractproperty.__module__=='abc' (len=3; defined in Lib/abc.py); abc.abstractproperty.__bases__[0].__name__=='property' (len=8; inherits from the builtin property class); abc.abstractclassmethod.__name__=='abstractclassmethod' (len=19; deprecated since Python 3.3; use @classmethod @abstractmethod instead); abc.abstractclassmethod.__module__=='abc' (len=3); abc.abstractclassmethod.__bases__[0].__name__=='classmethod' (len=11; inherits from builtin classmethod); abc.abstractstaticmethod.__name__=='abstractstaticmethod' (len=20; deprecated since Python 3.3; use @staticmethod @abstractmethod instead; the longest name of the three deprecated decorators); abc.abstractstaticmethod.__bases__[0].__name__=='staticmethod' (len=12; inherits from builtin staticmethod); name length ordering: abstractstaticmethod(20) > abstractclassmethod(19) > abstractproperty(16); all three have __module__=='abc'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdep148

  columns: [id, function, args, expected, description]
  rows:
    - [absprop_name_eq,   abc.abstractproperty.__name__.__eq__,                              ["abstractproperty"],    true,  "abc.abstractproperty.__name__ == 'abstractproperty' (len=16; deprecated since Python 3.3); verified with Python 3.14.3"]
    - [absprop_mod_eq,    abc.abstractproperty.__module__.__eq__,                             ["abc"],                 true,  "abc.abstractproperty.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [absprop_base_eq,   "abc.abstractproperty.__bases__[0].__name__.__eq__",                ["property"],            true,  "abc.abstractproperty.__bases__[0].__name__ == 'property' (len=8; inherits from builtin property); verified with Python 3.14.3"]
    - [abscls_name_eq,    abc.abstractclassmethod.__name__.__eq__,                            ["abstractclassmethod"], true,  "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19; deprecated since Python 3.3); verified with Python 3.14.3"]
    - [abscls_base_eq,    "abc.abstractclassmethod.__bases__[0].__name__.__eq__",             ["classmethod"],         true,  "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod' (len=11; inherits from builtin classmethod); verified with Python 3.14.3"]
    - [absstm_name_eq,    abc.abstractstaticmethod.__name__.__eq__,                           ["abstractstaticmethod"],true,  "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20; longest deprecated decorator name); verified with Python 3.14.3"]
    - [absstm_base_eq,    "abc.abstractstaticmethod.__bases__[0].__name__.__eq__",            ["staticmethod"],        true,  "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' (len=12; inherits from builtin staticmethod); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token identity — extra148
#
# abc.get_cache_token.__module__.__eq__('_abc')                     == True
# abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') == True
# ---------------------------------------------------------------------------

table abc_extra148.abc_get_cache_token_identity:
  description: "abc.get_cache_token identity checks in abctoken148 namespace — abc.get_cache_token.__module__=='_abc' (len=4; get_cache_token is defined in the C extension module _abc (Modules/_abc.c), NOT in the Python abc module; its __module__ is '_abc' with a leading underscore, the private C backing module; len('_abc')==4 whereas abc itself has len('abc')==3 — adding the underscore adds 1 char); abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26; it is a C-level builtin function, not a Python function — compare abc.abstractmethod.__class__.__name__=='type' since abstractmethod is a Python class); abc.get_cache_token returns an opaque integer token that changes each time a new virtual subclass is registered with an ABC, allowing caches to detect when ABC relationships have changed; get_cache_token.__module__.__len__()==4 ('_abc'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abctoken148

  columns: [id, function, args, expected, description]
  rows:
    - [token_mod_eq,   abc.get_cache_token.__module__.__eq__,                    ["_abc"],                      true,  "abc.get_cache_token.__module__ == '_abc' (len=4; C extension, not the Python abc module); verified with Python 3.14.3"]
    - [token_cls_eq,   abc.get_cache_token.__class__.__name__.__eq__,            ["builtin_function_or_method"], true,  "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (len=26; is a C-level builtin); verified with Python 3.14.3"]
    - [token_mod_len,  abc.get_cache_token.__module__.__len__,                   [],                            4,     "abc.get_cache_token.__module__.__len__() == 4 ('_abc'); verified with Python 3.14.3"]
    - [token_cls_len,  abc.get_cache_token.__class__.__name__.__len__,           [],                            26,    "abc.get_cache_token.__class__.__name__.__len__() == 26 ('builtin_function_or_method'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta name length and deprecated decorator name lengths — extra148
#
# abc.ABCMeta.__name__.__len__()                    == 7
# abc.abstractproperty.__name__.__len__()           == 16
# abc.abstractclassmethod.__name__.__len__()        == 19
# abc.abstractstaticmethod.__name__.__len__()       == 20
# ---------------------------------------------------------------------------

table abc_extra148.abc_name_lengths:
  description: "abc class name length checks in abcnamelen148 namespace — abc.ABCMeta.__name__.__len__()==7 ('ABCMeta': 'ABC'=3+'Meta'=4=7; the primary metaclass of the abc module); abc.abstractproperty.__name__.__len__()==16 ('abstractproperty': 'abstract'=8+'property'=8=16; the shortest of the three deprecated decorator names); abc.abstractclassmethod.__name__.__len__()==19 ('abstractclassmethod': 'abstract'=8+'classmethod'=11=19; middle length among the three deprecated decorators); abc.abstractstaticmethod.__name__.__len__()==20 ('abstractstaticmethod': 'abstract'=8+'staticmethod'=12=20; the longest deprecated decorator name; 1 char longer than abstractclassmethod because 'staticmethod'=12 > 'classmethod'=11); name length ordering: abstractstaticmethod(20) > abstractclassmethod(19) > abstractproperty(16) > ABCMeta(7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnamelen148

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_len,   abc.ABCMeta.__name__.__len__,             [],  7,   "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'); verified with Python 3.14.3"]
    - [absprop_len,   abc.abstractproperty.__name__.__len__,    [],  16,  "abc.abstractproperty.__name__.__len__() == 16 ('abstractproperty'); verified with Python 3.14.3"]
    - [abscls_len,    abc.abstractclassmethod.__name__.__len__, [],  19,  "abc.abstractclassmethod.__name__.__len__() == 19 ('abstractclassmethod'); verified with Python 3.14.3"]
    - [absstm_len,    abc.abstractstaticmethod.__name__.__len__,[], 20,  "abc.abstractstaticmethod.__name__.__len__() == 20 ('abstractstaticmethod'; longest deprecated decorator name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra148
# ---------------------------------------------------------------------------

invariant abc_extra148.abc_abstractproperty_module_eq:
  description: "abc.abstractproperty.__module__.__eq__('abc') returns True — abc.abstractproperty is defined in Lib/abc.py and its __module__ is 'abc' (len=3); abstractproperty is a class that inherits from the builtin property class and sets __isabstractmethod__=True; it has been deprecated since Python 3.3 in favor of combining @property with @abstractmethod; abstractproperty.__name__=='abstractproperty' (len=16); abstractproperty.__bases__[0].__name__=='property'; abstractproperty.__module__=='abc' (len=3; same as abstractmethod.__module__=='abc', ABCMeta.__module__=='abc', ABC.__module__=='abc'); compare: abc.get_cache_token.__module__=='_abc' (C extension, len=4) vs abc.abstractproperty.__module__=='abc' (pure Python, len=3); NEW in extra148: first standalone abc.abstractproperty.__module__ identity invariant in abcdep148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra148.abc_abstractproperty_bases0_is_property:
  description: "abc.abstractproperty.__bases__[0].__name__.__eq__('property') returns True — abc.abstractproperty inherits from the builtin property class; abstractproperty.__bases__[0].__name__=='property' (len=8); abstractproperty extends property by overriding __new__ to set __isabstractmethod__=True on the property descriptor; compare the deprecated decorator inheritance pattern: abstractproperty > property (len=8), abstractclassmethod > classmethod (len=11), abstractstaticmethod > staticmethod (len=12); all three inherit from builtin descriptor types; the recommended modern replacement for abstractproperty is to use @property @abstractmethod (stacked decorators); NEW in extra148: first standalone abc.abstractproperty.__bases__[0] name identity invariant in abcdep148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

invariant abc_extra148.abc_get_cache_token_module_is_abc_c:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token is a C-level builtin function defined in Modules/_abc.c; its __module__ is '_abc' (len=4), the private C extension module, NOT 'abc' (len=3) the Python module; this is a key distinction: most of abc's public API has __module__=='abc' (abstractmethod, abstractproperty, ABCMeta, ABC) but get_cache_token has __module__=='_abc' because it is a C-extension function exposed through abc's namespace; abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26); get_cache_token returns an opaque integer that increments each time a virtual subclass is registered (abc.ABCMeta.register()); this token is used to invalidate caches that depend on the ABC subclass relationship graph; NEW in extra148: first standalone abc.get_cache_token.__module__ identity invariant in abctoken148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra148.abc_get_cache_token_class_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.get_cache_token is a C-level builtin function; its __class__.__name__ is 'builtin_function_or_method' (len=26: the longest value in this spec); this type name is shared by all C-extension functions accessible from Python (e.g. len.__class__.__name__=='builtin_function_or_method', print.__class__.__name__=='builtin_function_or_method'); compare: abc.abstractmethod.__class__.__name__=='type' (abstractmethod is a Python class, not a C builtin); abc.ABCMeta.__class__.__name__=='type' (ABCMeta is also a class); abc.get_cache_token is unique in the abc module's public API in being a C-level builtin function (not a class and not a Python function); len('builtin_function_or_method')==26; NEW in extra148: first standalone abc.get_cache_token.__class__.__name__ identity invariant in abctoken148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra148.abc_ABCMeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — abc.ABCMeta.__name__ is 'ABCMeta' (7 chars: 'A'+'B'+'C'+'M'+'e'+'t'+'a'=7); this was first established in abc_extra147; repeated here as an anchor for the name length comparison table in extra148; name length ordering in this spec: abstractstaticmethod(20) > abstractclassmethod(19) > abstractproperty(16) > ABCMeta(7); ABCMeta.__name__.__len__()==7 is the baseline for the metaclass name; abc.ABCMeta.__module__=='abc' (len=3); abc.ABCMeta.__bases__[0].__name__=='type' (metaclass inheriting from type); abc.ABC.__class__.__name__=='ABCMeta' (ABC uses ABCMeta as its metaclass); the length 7 for 'ABCMeta' reflects the combined acronym 'ABC' (3 chars) plus 'Meta' (4 chars); NEW in extra148: first standalone abc.ABCMeta.__name__.__len__ length invariant in abcnamelen148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__len__
  args: []
  expected: 7

