spec: hashlib_extra229
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_blake2module.c"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.blake2b(b'hello').hexdigest().__len__() == 128 — blake2b default digest_size==64 bytes; hex-encoded to 128 chars; new to extra229."
    - "hashlib.blake2s(b'hello').hexdigest().__len__() == 64 — blake2s default digest_size==32 bytes; hex-encoded to 64 chars; new to extra229."
    - "hashlib.blake2b.__name__.__len__() == 7 — 'blake2b' is 7 characters; confirmed in extra103 via __name__.__eq__ but this anchors __len__() from extra229."
    - "hashlib.blake2s.__name__.__len__() == 7 — 'blake2s' is 7 characters; symmetric with blake2b."
    - "hashlib.blake2b().__class__.__name__ == 'blake2b' — the C type for blake2b instances is 'blake2b' from _blake2 module; not the HASH type from _hashlib."
    - "hashlib.sha256(b'hello').update(b'world').__class__.__name__ == 'NoneType' — update() always returns None; it modifies the hash object in-place."
    - "hashlib.md5(b'hello', usedforsecurity=False).hexdigest().__eq__(hashlib.md5(b'hello').hexdigest()) == True — usedforsecurity=False does not change the digest value."
    - "hashlib.sha256(b'hello').copy().hexdigest().__eq__(hashlib.sha256(b'hello').hexdigest()) == True — copy() produces an independent hash object with the same state."
    - "md5 hexdigest for b'hello' is '5d41402abc4b2a76b9719d911017c592' (32 chars). Verified Python 3.14.3."
    - "sha256 hexdigest for b'hello' is '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824'. Verified Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# blake2b and blake2s hexdigest lengths from instance calls
#
# hashlib.blake2b(b'hello').hexdigest().__len__() == 128
# hashlib.blake2s(b'hello').hexdigest().__len__() == 64
#
# blake2b default digest_size is 64 bytes; hex-encoding each byte as 2 chars
# gives 128 hex characters. blake2s default digest_size is 32 bytes = 64 hex
# chars. extra38 covers the method_chain form; this spec anchors via table
# using the __len__ call syntax in the function path.
# ---------------------------------------------------------------------------

table hashlib_extra229.blake2_hexdigest_lengths:
  description: "blake2b(b'hello').hexdigest().__len__()==128; blake2s(b'hello').hexdigest().__len__()==64; default sizes; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib229

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_hexdigest_len_128,
       "blake2b({type: bytes_ascii, value: 'hello'}).hexdigest().__len__",
       [],
       128,
       "hashlib.blake2b(b'hello').hexdigest().__len__() == 128 — blake2b default digest_size==64 bytes hex-encoded to 128 chars; BLAKE2b produces up to 512-bit output; default is 512-bit/64-byte = 128 hex chars; verified Python 3.14.3"]
    - [blake2s_hexdigest_len_64,
       "blake2s({type: bytes_ascii, value: 'hello'}).hexdigest().__len__",
       [],
       64,
       "hashlib.blake2s(b'hello').hexdigest().__len__() == 64 — blake2s default digest_size==32 bytes hex-encoded to 64 chars; BLAKE2s produces up to 256-bit output; default is 256-bit/32-byte = 64 hex chars; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# blake2b and blake2s __name__ lengths
#
# hashlib.blake2b.__name__.__len__() == 7
# hashlib.blake2s.__name__.__len__() == 7
#
# Both 'blake2b' and 'blake2s' are 7-character strings. extra103 anchors
# __name__.__eq__ but not the __len__() of the class __name__. New to extra229.
# ---------------------------------------------------------------------------

table hashlib_extra229.blake2_name_lengths:
  description: "blake2b.__name__.__len__()==7; blake2s.__name__.__len__()==7; both are 7-char names; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib229a

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_len_7, blake2b.__name__.__len__, [], 7, "hashlib.blake2b.__name__.__len__() == 7 — 'blake2b' is 7 characters ('blake2'=6 + 'b'=1); class name of the BLAKE2b C type from _blake2 module; extra103 anchors __name__.__eq__('blake2b') but not __len__()==7; new to extra229"]
    - [blake2s_name_len_7, blake2s.__name__.__len__, [], 7, "hashlib.blake2s.__name__.__len__() == 7 — 'blake2s' is 7 characters ('blake2'=6 + 's'=1); class name of the BLAKE2s C type from _blake2 module; symmetric with blake2b; new to extra229"]

# ---------------------------------------------------------------------------
# sha256.update() returns None — in-place mutation
#
# hashlib.sha256(b'hello').update(b'world').__class__.__name__ == 'NoneType'
#
# The update() method modifies the hash object in-place and returns None.
# This is a behavioral contract: callers must not use the return value.
# No prior hashlib spec anchors update() return type. New to extra229.
# ---------------------------------------------------------------------------

table hashlib_extra229.sha256_update_returns_none:
  description: "sha256(b'hello').update(b'world') returns None — update modifies in-place; __class__.__name__=='NoneType'; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib229b

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_update_none_class,
       "sha256({type: bytes_ascii, value: 'hello'}).update({type: bytes_ascii, value: 'world'}).__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "hashlib.sha256(b'hello').update(b'world').__class__.__name__.__eq__('NoneType') == True — update() returns None (NoneType); modifies in-place; return value must not be used; first update() return type anchor; new to extra229"]

# ---------------------------------------------------------------------------
# md5 with usedforsecurity=False gives identical hexdigest
#
# hashlib.md5(b'hello', usedforsecurity=False).hexdigest().__eq__(
#     hashlib.md5(b'hello').hexdigest()) == True
#
# usedforsecurity=False is a hint to the platform crypto library that the
# hash is not used for security purposes; it does not affect the digest value.
# New to extra229. md5 hexdigest for b'hello' == '5d41402abc4b2a76b9719d911017c592'.
# ---------------------------------------------------------------------------

table hashlib_extra229.md5_usedforsecurity_digest:
  description: "md5(b'hello', usedforsecurity=False).hexdigest().__len__()==32; hexdigest is '5d41402abc4b2a76b9719d911017c592'; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib229c

  columns: [id, function, args, expected, description]
  rows:
    - [md5_usedfor_hexdigest_len,
       "md5({type: bytes_ascii, value: 'hello'}, usedforsecurity=False).hexdigest().__len__",
       [],
       32,
       "hashlib.md5(b'hello', usedforsecurity=False).hexdigest().__len__() == 32 — MD5 always produces a 128-bit/16-byte digest hex-encoded to 32 chars; usedforsecurity=False does not change the output length; verified Python 3.14.3"]
    - [md5_usedfor_hexdigest_eq,
       "md5({type: bytes_ascii, value: 'hello'}, usedforsecurity=False).hexdigest().__eq__",
       ["5d41402abc4b2a76b9719d911017c592"],
       true,
       "hashlib.md5(b'hello', usedforsecurity=False).hexdigest().__eq__('5d41402abc4b2a76b9719d911017c592') == True — usedforsecurity=False does not alter the digest value; same as md5(b'hello').hexdigest(); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# sha256 copy() gives same hexdigest
#
# hashlib.sha256(b'hello').copy().hexdigest().__eq__(
#     hashlib.sha256(b'hello').hexdigest()) == True
#
# copy() creates an independent HASH object with the same current state.
# Since both are sha256(b'hello') with no further updates, they produce
# the same hexdigest. New to extra229.
# ---------------------------------------------------------------------------

table hashlib_extra229.sha256_copy_hexdigest_eq:
  description: "sha256(b'hello').copy().hexdigest().__eq__(sha256(b'hello').hexdigest()) == True; copy gives same digest; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib229d

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_copy_hexdigest_value,
       "sha256({type: bytes_ascii, value: 'hello'}).copy().hexdigest().__eq__",
       ["2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"],
       true,
       "hashlib.sha256(b'hello').copy().hexdigest().__eq__('2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824') == True — copy() gives an independent object with identical state; hexdigest matches sha256(b'hello').hexdigest(); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra229.blake2b_hexdigest_len_128:
  description: "hashlib.blake2b(b'hello').hexdigest().__len__() == 128 — BLAKE2b default digest_size is 64 bytes; hex-encoding produces 128 characters (2 hex chars per byte); 64*2=128; default is the maximum 512-bit output for BLAKE2b; extra38 covers blake2b hexdigest length via method_chain; this spec anchors it as a standalone in the extra229 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "blake2b({type: bytes_ascii, value: 'hello'}).hexdigest().__len__"
  args: []
  expected: 128

invariant hashlib_extra229.blake2s_hexdigest_len_64:
  description: "hashlib.blake2s(b'hello').hexdigest().__len__() == 64 — BLAKE2s default digest_size is 32 bytes; hex-encoding produces 64 characters; 32*2=64; default is the maximum 256-bit output for BLAKE2s; symmetric with blake2b (128); extra38 covers blake2s hexdigest length via method_chain; this spec anchors it as a standalone in the extra229 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "blake2s({type: bytes_ascii, value: 'hello'}).hexdigest().__len__"
  args: []
  expected: 64

invariant hashlib_extra229.sha256_update_returns_none:
  description: "hashlib.sha256(b'hello').update(b'world') returns None — update() modifies the HASH object in-place and always returns None; callers must not chain on the return value; __class__.__name__ is 'NoneType' confirming None return; this is a behavioral contract of the hashlib HASH interface; no prior hashlib spec anchors update() return type; first extra229 anchor for update() return NoneType; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256({type: bytes_ascii, value: 'hello'}).update({type: bytes_ascii, value: 'world'}).__class__.__name__.__eq__"
  args: ["NoneType"]
  expected: true

invariant hashlib_extra229.md5_usedforsecurity_hexdigest_len_32:
  description: "hashlib.md5(b'hello', usedforsecurity=False).hexdigest().__len__() == 32 — MD5 always produces a 128-bit digest hex-encoded to 32 characters; the usedforsecurity=False keyword does not affect the output length or value; it is a platform hint only; new to extra229; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "md5({type: bytes_ascii, value: 'hello'}, usedforsecurity=False).hexdigest().__len__"
  args: []
  expected: 32
