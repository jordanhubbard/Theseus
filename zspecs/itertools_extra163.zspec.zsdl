# ---------------------------------------------------------------------------
# Table 1: itertools.combinations and itertools.permutations class identity
#
# Wave 292 theme: itertools.combinations and itertools.permutations C extension
# type identity — name, module, and base class.
#
# itertools.combinations.__name__ == 'combinations'
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations.__bases__[0].__name__ == 'object'
# itertools.permutations.__name__ == 'permutations'
# itertools.permutations.__module__ == 'itertools'
#
# itertools.combinations(iterable, r) returns r-length subsequences of the
# input iterable choosing elements without replacement and without regard to
# order of the selected elements. itertools.permutations(iterable, r=None)
# returns all r-length permutations (ordered arrangements) of elements from
# the input iterable. Both are C extension types defined in itertoolsmodule.c.
# Their __name__ attributes are the simple type names, their __module__ is
# 'itertools', and they each inherit directly from object. New to extra163.
# ---------------------------------------------------------------------------

table itertools_extra163.combinations_and_permutations_identity:
  description: "itertools: combinations.__name__ 'combinations', combinations.__module__ 'itertools', combinations.__bases__[0].__name__ 'object', permutations.__name__ 'permutations', permutations.__module__ 'itertools'; wave 292; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscpi163

  columns: [id, function, args, expected, description]
  rows:
    - [comb_name_eq_combinations,
       "combinations.__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C extension type in itertoolsmodule.c that returns r-length subsequences of elements from the input iterable without replacement and without regard to order; its type __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra163"]
    - [comb_module_eq_itertools,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is a C extension type declared in the itertools module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra163"]
    - ["comb_bases_0_name_eq_object",
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations is a C extension type that inherits directly from object; its __bases__ tuple has a single element (object) whose __name__ is 'object'; str.__eq__('object') returns True; new to extra163"]
    - [perm_name_eq_permutations,
       "permutations.__name__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C extension type in itertoolsmodule.c that returns all r-length ordered arrangements of elements from the input iterable; its type __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra163"]
    - [perm_module_eq_itertools,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is a C extension type declared in the itertools module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra163"]

# ---------------------------------------------------------------------------
# Table 2: itertools.product identity and combinations/permutations class name
#
# Wave 292 theme: itertools.product C extension type identity and class name
# for combinations and permutations.
#
# itertools.product.__name__ == 'product'
# itertools.product.__module__ == 'itertools'
# itertools.product.__class__.__name__ == 'type'
# itertools.combinations.__class__.__name__ == 'type'
# itertools.permutations.__bases__[0].__name__ == 'object'
#
# itertools.product(iterables, repeat=1) returns the Cartesian product of the
# input iterables; it is equivalent to nested for-loops. It is a C extension
# type in itertoolsmodule.c. Like combinations and permutations, it has
# __class__.__name__ 'type' (all three are C extension class objects).
# itertools.permutations also inherits directly from object.
# New to extra163.
# ---------------------------------------------------------------------------

table itertools_extra163.product_identity_and_class_names:
  description: "itertools: product.__name__ 'product', product.__module__ 'itertools', product.__class__.__name__ 'type', combinations.__class__.__name__ 'type', permutations.__bases__[0].__name__ 'object'; wave 292; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolspici163

  columns: [id, function, args, expected, description]
  rows:
    - [prod_name_eq_product,
       "product.__name__.__eq__",
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C extension type in itertoolsmodule.c that returns the Cartesian product of input iterables equivalent to nested for-loops; its type __name__ is 'product'; str.__eq__('product') returns True; new to extra163"]
    - [prod_module_eq_itertools,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is a C extension type declared in the itertools module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra163"]
    - [prod_class_name_eq_type,
       "product.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C extension class object; as a class object its __class__ is the metaclass 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra163"]
    - [comb_class_name_eq_type,
       "combinations.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — combinations is a C extension class object; as a class object its __class__ is the metaclass 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra163"]
    - ["perm_bases_0_name_eq_object",
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations is a C extension type that inherits directly from object; its __bases__ tuple has a single element (object) whose __name__ is 'object'; str.__eq__('object') returns True; new to extra163"]

