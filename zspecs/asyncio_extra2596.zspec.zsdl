spec: asyncio_extra2596
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio concurrency primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 2596 theme: __get__, __set__, __delete__ descriptor protocol dict-presence — checking whether asyncio classes implement the descriptor protocol."
    - "All asyncio concurrency primitives (Queue, Task, Future, Lock, Event, Semaphore, BoundedSemaphore, Condition, Barrier) do NOT define __get__, __set__, or __delete__ in their own __dict__ on Python 3.14.4."
    - "These classes are not designed to be used as descriptors; they are concurrency primitives. The absence of __get__/__set__/__delete__ in their class __dict__ confirms they are ordinary (non-descriptor) classes."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table asyncio_extra2596.queue_descriptor_protocol:
  description: "asyncio.Queue __get__/__set__/__delete__ dict-presence — all False; not a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2596
  columns: [id, function, args, expected]
  rows:
    - ["as2596001", "asyncio.Queue.__dict__.__contains__",   ["__get__"],    false]
    - ["as2596002", "asyncio.Queue.__dict__.__contains__",   ["__set__"],    false]
    - ["as2596003", "asyncio.Queue.__dict__.__contains__",   ["__delete__"], false]
    - ["as2596004", "asyncio.Task.__dict__.__contains__",    ["__get__"],    false]
    - ["as2596005", "asyncio.Task.__dict__.__contains__",    ["__set__"],    false]
    - ["as2596006", "asyncio.Task.__dict__.__contains__",    ["__delete__"], false]

