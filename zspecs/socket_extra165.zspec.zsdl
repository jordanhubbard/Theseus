spec: socket_extra165
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra164.zspec.zsdl — covers socket.socket.__dict__ method membership (accept/close/detach/makefile/sendfile/dup/get_inheritable/set_inheritable) and meta-attributes (__len__()==28/__class__.__name__=='mappingproxy') (table + invariants)."
    - "socket_extra163.zspec.zsdl — covers socket.__spec__.origin type and content / submodule_search_locations NoneType / spec attribute lengths (table + invariants)."
    - "socket_extra162.zspec.zsdl — covers socket.socket.__repr__/__str__/__enter__/__exit__ qualname strings and lengths (table + invariants)."
    - "socket_extra161.zspec.zsdl — covers socket.socket.send/__recv/__sendto/__recvfrom qualname strings and lengths (table + invariants)."
    - "socket_extra160.zspec.zsdl — covers socket.socket.bind/__listen/__accept/__close qualname strings and lengths (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__/__init__.__qualname__/connect.__qualname__ (table + invariants)."
    - "socket_extra156.zspec.zsdl — covers socket.__spec__.__class__.__name__=='ModuleSpec' / socket.__spec__.name == 'socket' (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra164."
    - "Wave 347 theme: socket exception class identity — socket.error.__name__=='OSError' / socket.error.__module__=='builtins' / socket.timeout.__name__=='TimeoutError' / socket.timeout.__module__=='builtins' / socket.gaierror.__name__=='gaierror' / socket.gaierror.__module__=='socket' / socket.herror.__name__=='herror' / socket.herror.__module__=='socket'. socket.error IS OSError (they are the same object). socket.timeout IS TimeoutError. socket.gaierror and socket.herror are subclasses of OSError defined in socket."
    - "socket.error.__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__name__ == 'herror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.error IS OSError (socket.error is OSError == True). socket.error is not a separate class — it is literally the built-in OSError class. This alias was created for backward compatibility (pre-Python 3.3, socket.error was a distinct class). Since Python 3.3, socket.error == OSError. Because it is OSError, socket.error.__name__ == 'OSError' (7 chars) and socket.error.__module__ == 'builtins' (8 chars)."
    - "Note: socket.timeout IS TimeoutError (socket.timeout is TimeoutError == True). socket.timeout is an alias for the built-in TimeoutError class. TimeoutError is a subclass of OSError. socket.timeout.__name__ == 'TimeoutError' (12 chars = 'Timeout'=7 + 'Error'=5). socket.timeout.__module__ == 'builtins' (8 chars)."
    - "Note: socket.gaierror is NOT a builtin alias. socket.gaierror is a distinct class defined in Lib/socket.py as a subclass of OSError. Its __name__ == 'gaierror' (8 chars; lowercase, old convention) and __module__ == 'socket' (6 chars). 'gai' stands for 'get address info' — gaierror is raised by getaddrinfo() and getnameinfo() on failure."
    - "Note: socket.herror is NOT a builtin alias. socket.herror is a distinct class defined in Lib/socket.py as a subclass of OSError. Its __name__ == 'herror' (6 chars; lowercase, old convention) and __module__ == 'socket' (6 chars). 'herror' is a host error, raised by gethostbyname() and similar resolver functions."
    - "Note: gaierror.__bases__[0].__name__ == 'OSError' (7 chars). herror.__bases__[0].__name__ == 'OSError' (7 chars). Both gaierror and herror inherit directly from OSError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError')
# socket.error.__module__.__eq__('builtins')
# socket.timeout.__name__.__eq__('TimeoutError')
# socket.timeout.__module__.__eq__('builtins')
#
# Wave 347 theme: socket.error and socket.timeout are builtin aliases.
#
# socket.error IS OSError; socket.error.__name__ == 'OSError' (7 chars).
# socket.error.__module__ == 'builtins' (8 chars).
# socket.timeout IS TimeoutError; socket.timeout.__name__ == 'TimeoutError' (12 chars).
# socket.timeout.__module__ == 'builtins' (8 chars).
# No prior socket spec anchors socket.error.__name__ or socket.timeout.__name__ as a table
# under sockexc165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra165.error_timeout_builtin_aliases:
  description: "socket.error.__name__.__eq__('OSError')==True / error.__module__.__eq__('builtins')==True / socket.timeout.__name__.__eq__('TimeoutError')==True / timeout.__module__.__eq__('builtins')==True — error.__name__ is 'OSError' (7 chars; socket.error IS OSError — they are the same object; socket.error was a distinct class pre-Python 3.3; since 3.3 it is an alias for the built-in OSError; because it IS OSError, its __name__ is 'OSError' and __module__ is 'builtins'; 'OSError'=7 chars = 'OS'=2 + 'Error'=5); error.__module__ is 'builtins' (8 chars; the built-in module where OSError is defined; 'builtins' is the Python module containing all built-in exceptions and functions; 8 chars = 'built'=5 + 'ins'=3); timeout.__name__ is 'TimeoutError' (12 chars = 'Timeout'=7 + 'Error'=5; socket.timeout IS TimeoutError — same aliasing pattern as socket.error/OSError; TimeoutError is a subclass of OSError; since Python 3.3 socket.timeout is an alias for the built-in TimeoutError); timeout.__module__ is 'builtins' (8 chars; same as error.__module__; both socket.error and socket.timeout are builtins aliases); first sockexc165 anchor for error.__name__, error.__module__, timeout.__name__, and timeout.__module__"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc165

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_oserror,      "error.__name__.__eq__",   ["OSError"],     true, "socket.error.__name__ == 'OSError' (7 chars; socket.error IS OSError; same object; backward compatibility alias since Python 3.3)"]
    - [error_module_builtins,   "error.__module__.__eq__", ["builtins"],    true, "socket.error.__module__ == 'builtins' (8 chars; OSError is a built-in exception; __module__=='builtins' for all built-in exceptions)"]
    - [timeout_name_timeout,    "timeout.__name__.__eq__", ["TimeoutError"], true, "socket.timeout.__name__ == 'TimeoutError' (12 chars; socket.timeout IS TimeoutError; 'Timeout'=7 + 'Error'=5; subclass of OSError)"]
    - [timeout_module_builtins, "timeout.__module__.__eq__", ["builtins"],  true, "socket.timeout.__module__ == 'builtins' (8 chars; TimeoutError is a built-in exception; same __module__ as socket.error/OSError)"]

# ---------------------------------------------------------------------------
# socket.gaierror.__name__ and __module__
#
# Wave 347 theme: socket.gaierror is a distinct socket-defined exception.
#
# gaierror.__name__ == 'gaierror' (8 chars; lowercase; old naming; gai = get address info).
# gaierror.__module__ == 'socket' (6 chars; defined in Lib/socket.py; NOT a builtin).
# gaierror.__bases__[0].__name__ == 'OSError' (7 chars; inherits from OSError).
# error.__name__.__eq__('OSError') (confirmed; socket.error IS OSError).
# No prior socket spec anchors gaierror.__name__ or gaierror.__module__ as a table under
# sockexc165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra165.gaierror_identity:
  description: "socket.gaierror.__name__.__eq__('gaierror')==True / gaierror.__module__.__eq__('socket')==True / gaierror.__bases__[0].__name__.__eq__('OSError')==True / error.__name__.__eq__('OSError')==True — gaierror.__name__ is 'gaierror' (8 chars; lowercase; old Python exception naming convention; 'gai' stands for 'get address info' — gaierror is raised by getaddrinfo() and getnameinfo() on failure; distinct class, NOT an alias for a builtin; gaierror.__module__=='socket' confirms it is defined in Lib/socket.py); gaierror.__module__ is 'socket' (6 chars; the public socket module; this is the module where gaierror is defined as a class; contrasts with socket.error.__module__=='builtins'(8 chars)); gaierror.__bases__[0].__name__ is 'OSError' (7 chars; gaierror inherits directly from OSError; OSError is the appropriate base for network/address resolution errors; socket.error IS OSError so gaierror also IS-A socket.error); error.__name__ is 'OSError' (confirmed; socket.error IS OSError; the same string 'OSError' that gaierror inherits from); first sockexc165 anchor for gaierror.__name__, gaierror.__module__, gaierror.__bases__"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc165

  columns: [id, function, args, expected, description]
  rows:
    - [gaierror_name,          "gaierror.__name__.__eq__",               ["gaierror"], true, "socket.gaierror.__name__ == 'gaierror' (8 chars; lowercase; 'gai'=get address info; raised by getaddrinfo()/getnameinfo(); distinct class not a builtin alias)"]
    - [gaierror_module,        "gaierror.__module__.__eq__",             ["socket"],   true, "socket.gaierror.__module__ == 'socket' (6 chars; defined in Lib/socket.py; NOT a builtin; contrasts with error.__module__=='builtins')"]
    - [gaierror_bases_oserror, "gaierror.__bases__[0].__name__.__eq__",  ["OSError"],  true, "socket.gaierror.__bases__[0].__name__ == 'OSError' (7 chars; gaierror inherits from OSError; socket.error IS OSError so gaierror IS-A socket.error)"]
    - [error_name_oserror_b,   "error.__name__.__eq__",                  ["OSError"],  true, "socket.error.__name__ == 'OSError' (confirmed; socket.error IS OSError; the same string that gaierror.__bases__[0].__name__ returns)"]

# ---------------------------------------------------------------------------
# socket.herror.__name__ and __module__
#
# Wave 347 theme: socket.herror is a distinct socket-defined exception.
#
# herror.__name__ == 'herror' (6 chars; lowercase; h = host).
# herror.__module__ == 'socket' (6 chars; defined in Lib/socket.py).
# herror.__bases__[0].__name__ == 'OSError' (7 chars; inherits from OSError).
# gaierror.__name__.__eq__('gaierror') (confirmed).
# No prior socket spec anchors herror.__name__ or herror.__module__ as a table under
# sockexc165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra165.herror_identity:
  description: "socket.herror.__name__.__eq__('herror')==True / herror.__module__.__eq__('socket')==True / herror.__bases__[0].__name__.__eq__('OSError')==True / gaierror.__name__.__eq__('gaierror')==True — herror.__name__ is 'herror' (6 chars; lowercase; old naming convention; 'h' stands for 'host error' — herror is raised by gethostbyname() and similar resolver functions when a host lookup fails; distinct class, NOT an alias for a builtin; 6 chars < gaierror=8 chars by 2); herror.__module__ is 'socket' (6 chars; defined in Lib/socket.py; same module as gaierror; both gaierror and herror are socket-module exceptions with __module__=='socket'=6 chars; both contrast with socket.error and socket.timeout which have __module__=='builtins'=8 chars); herror.__bases__[0].__name__ is 'OSError' (7 chars; herror inherits from OSError; same base as gaierror; both herror and gaierror are subclasses of OSError defined in the socket module); gaierror.__name__ is 'gaierror' (confirmed; 8 chars; parallel exception to herror; gaierror for address info, herror for host resolution); first sockexc165 anchor for herror.__name__, herror.__module__, herror.__bases__"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc165

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name,           "herror.__name__.__eq__",               ["herror"],  true, "socket.herror.__name__ == 'herror' (6 chars; lowercase; 'h'=host error; raised by gethostbyname(); distinct class not a builtin alias)"]
    - [herror_module,         "herror.__module__.__eq__",             ["socket"],  true, "socket.herror.__module__ == 'socket' (6 chars; defined in Lib/socket.py; same module as gaierror; both are socket-defined OSError subclasses)"]
    - [herror_bases_oserror,  "herror.__bases__[0].__name__.__eq__",  ["OSError"], true, "socket.herror.__bases__[0].__name__ == 'OSError' (7 chars; herror inherits from OSError; same base as gaierror; both are OSError subclasses)"]
    - [gaierror_name_b,       "gaierror.__name__.__eq__",             ["gaierror"], true, "socket.gaierror.__name__ == 'gaierror' (confirmed; 8 chars; parallel to herror(6 chars); gaierror=8 > herror=6 by 2 chars)"]

# ---------------------------------------------------------------------------
# socket exception name lengths
#
# Wave 347 theme: length ordering for socket exception names.
#
# herror.__name__.__len__() == 6 ('herror' = 6 chars).
# error.__name__.__len__() == 7 ('OSError' = 7 chars).
# gaierror.__name__.__len__() == 8 ('gaierror' = 8 chars).
# timeout.__name__.__len__() == 12 ('TimeoutError' = 12 chars).
# No prior socket spec anchors socket exception name lengths as a table under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra165.exception_name_lengths:
  description: "socket.herror.__name__.__len__()==6 / error.__name__.__len__()==7 / gaierror.__name__.__len__()==8 / timeout.__name__.__len__()==12 — herror.__name__.__len__() is 6 ('herror' = 6 chars; shortest exception name in the socket module; lowercase 6-char name; 'herror'(6) < 'OSError'(7) < 'gaierror'(8) < 'TimeoutError'(12) in length ordering); error.__name__.__len__() is 7 ('OSError' = 'OS'=2 + 'Error'=5 = 7 chars; socket.error IS OSError; the builtin OSError name is 7 chars; middle-length in the ordering); gaierror.__name__.__len__() is 8 ('gaierror' = 'gai'=3 + 'error'=5 = 8 chars; the address-info exception; 8 chars > 'OSError'=7 by 1 char; gaierror.__module__.__len__()==6 == herror.__module__.__len__()==6 == 'socket'=6); timeout.__name__.__len__() is 12 ('TimeoutError' = 'Timeout'=7 + 'Error'=5 = 12 chars; socket.timeout IS TimeoutError; the longest exception name in this spec; 12 chars = 4 more than 'gaierror'=8); length ordering: 'herror'(6) < 'OSError'(7) < 'gaierror'(8) < 'TimeoutError'(12); first sockexc165 anchor for exception name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc165

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name_len_6,   "herror.__name__.__len__",   [], 6,  "socket.herror.__name__.__len__() is 6 ('herror' = 6 chars; shortest socket exception name; lowercase old convention)"]
    - [error_name_len_7,    "error.__name__.__len__",    [], 7,  "socket.error.__name__.__len__() is 7 ('OSError' = 'OS'=2 + 'Error'=5 = 7; socket.error IS OSError; builtin name)"]
    - [gaierror_name_len_8, "gaierror.__name__.__len__", [], 8,  "socket.gaierror.__name__.__len__() is 8 ('gaierror' = 'gai'=3 + 'error'=5 = 8; address-info exception; 1 char longer than 'OSError'=7)"]
    - [timeout_name_len_12, "timeout.__name__.__len__",  [], 12, "socket.timeout.__name__.__len__() is 12 ('TimeoutError' = 'Timeout'=7 + 'Error'=5 = 12; socket.timeout IS TimeoutError; longest name here)"]

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error.__name__ is 'OSError' (7 chars). socket.error is not a separate class —
# it is literally Python's built-in OSError (socket.error is OSError == True). This alias
# was introduced for backward compatibility: prior to Python 3.3, socket.error was a
# distinct exception class. Since Python 3.3, it is an alias for OSError. Because socket.error
# IS OSError, its __name__ is 'OSError' (the builtin class name). 'OSError' (7 chars) =
# 'OS'=2 + 'Error'=5. socket.error.__module__ == 'builtins' (8 chars; OSError is a builtin).
# No prior socket spec anchors socket.error.__name__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra165.error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — 'OSError' (7 chars = 'OS'=2 + 'Error'=5); socket.error IS OSError (same object; alias for backward compatibility since Python 3.3); error.__module__=='builtins' (8 chars; OSError is a built-in exception); socket.gaierror and socket.herror both inherit from OSError (gaierror.__bases__[0].__name__=='OSError'; herror.__bases__[0].__name__=='OSError'); length ordering: 'herror'(6) < 'OSError'(7) < 'gaierror'(8) < 'TimeoutError'(12); first sockexc165 standalone for error.__name__"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error.__module__.__eq__('builtins') — standalone
#
# socket.error.__module__ is 'builtins' (8 chars). Since socket.error IS OSError, its
# __module__ is 'builtins' — the Python module containing all built-in exceptions and
# built-in functions. 'builtins' (8 chars) is where OSError, TimeoutError, ValueError,
# TypeError, and all other built-in exception classes live. socket.timeout.__module__ is
# also 'builtins' (8 chars) because socket.timeout IS TimeoutError. In contrast,
# socket.gaierror.__module__ == 'socket' (6 chars) and socket.herror.__module__ == 'socket'
# (6 chars) because those are genuinely socket-module exceptions.
# No prior socket spec anchors socket.error.__module__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra165.error_module_builtins:
  description: "socket.error.__module__.__eq__('builtins') == True — 'builtins' (8 chars; the Python module containing all built-in exceptions); socket.error IS OSError so __module__=='builtins'; socket.timeout IS TimeoutError so timeout.__module__=='builtins' too; contrast with gaierror.__module__=='socket'(6) and herror.__module__=='socket'(6) — those are genuine socket-module exceptions; 'builtins'(8) > 'socket'(6) by 2 chars; first sockexc165 standalone for error.__module__"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError' (12 chars = 'Timeout'=7 + 'Error'=5).
# socket.timeout is an alias for Python's built-in TimeoutError class (socket.timeout is
# TimeoutError == True). TimeoutError is a subclass of OSError (since Python 3.3). Prior to
# Python 3.3, socket.timeout was a distinct exception class. Since 3.3, it is an alias for
# the built-in TimeoutError, following the same aliasing pattern as socket.error/OSError.
# 'TimeoutError' (12 chars) is the longest exception name in this spec.
# No prior socket spec anchors socket.timeout.__name__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra165.timeout_name_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — 'TimeoutError' (12 chars = 'Timeout'=7 + 'Error'=5; longest exception name in this spec); socket.timeout IS TimeoutError (same aliasing pattern as socket.error/OSError; backward compatibility alias since Python 3.3); TimeoutError is a subclass of OSError; timeout.__module__=='builtins'(8 chars; same as error.__module__); length ordering: 'herror'(6) < 'OSError'(7) < 'gaierror'(8) < 'TimeoutError'(12); first sockexc165 standalone for timeout.__name__"
  category: identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# socket.gaierror.__name__ is 'gaierror' (8 chars). socket.gaierror is NOT an alias for a
# built-in — it is a distinct exception class defined in Lib/socket.py. It is raised by
# getaddrinfo() and getnameinfo() when address-related errors occur. 'gai' stands for
# 'get address info'. gaierror inherits from OSError (gaierror.__bases__[0].__name__=='OSError').
# 'gaierror' (8 chars) uses the old lowercase convention (like struct.error and socket.herror).
# No prior socket spec anchors gaierror.__name__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra165.gaierror_name_gaierror:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — 'gaierror' (8 chars = 'gai'=3 + 'error'=5; 'gai' = get address info; raised by getaddrinfo() and getnameinfo()); gaierror is NOT a builtin alias (unlike socket.error/OSError and socket.timeout/TimeoutError); gaierror is a distinct class defined in Lib/socket.py; gaierror.__module__=='socket'(6); gaierror.__bases__[0].__name__=='OSError'(7); 'gaierror'(8) > 'OSError'(7) by 1 char; first sockexc165 standalone for gaierror.__name__"
  category: identity
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__module__.__eq__('socket') — standalone
#
# socket.gaierror.__module__ is 'socket' (6 chars). gaierror is defined in Lib/socket.py
# so its __module__ is 'socket'. This confirms gaierror is a genuine socket-module exception,
# unlike socket.error (which is OSError with __module__=='builtins') and socket.timeout
# (which is TimeoutError with __module__=='builtins'). 'socket' (6 chars) is the same as
# socket.herror.__module__ (both genuine socket exceptions with __module__=='socket').
# No prior socket spec anchors gaierror.__module__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra165.gaierror_module_socket:
  description: "socket.gaierror.__module__.__eq__('socket') == True — 'socket' (6 chars); gaierror is defined in Lib/socket.py (genuine socket-module exception); contrasts with error.__module__=='builtins'(8) and timeout.__module__=='builtins'(8) which are builtin aliases; herror.__module__=='socket'(6) — same as gaierror; both gaierror and herror are genuine socket exceptions with __module__=='socket'; 'socket'(6) < 'builtins'(8) by 2 chars; first sockexc165 standalone for gaierror.__module__"
  category: identity
  kind: python_call_eq
  function: gaierror.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror') — standalone
#
# socket.herror.__name__ is 'herror' (6 chars). socket.herror is NOT an alias for a built-in
# — it is a distinct exception class defined in Lib/socket.py. It is raised by gethostbyname()
# and similar host resolver functions on failure. 'h' stands for 'host'. herror inherits from
# OSError (herror.__bases__[0].__name__=='OSError'). 'herror' (6 chars) is the shortest
# exception name in this spec and uses the old lowercase convention (like gaierror).
# 'herror' (6 chars) is 2 chars shorter than 'gaierror' (8 chars).
# No prior socket spec anchors herror.__name__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra165.herror_name_herror:
  description: "socket.herror.__name__.__eq__('herror') == True — 'herror' (6 chars; 'h' = host error; raised by gethostbyname() and similar host resolver functions; shortest exception name in this spec); herror is NOT a builtin alias (distinct class defined in Lib/socket.py); herror.__module__=='socket'(6); herror.__bases__[0].__name__=='OSError'(7); 'herror'(6) < 'OSError'(7) < 'gaierror'(8) < 'TimeoutError'(12); first sockexc165 standalone for herror.__name__"
  category: identity
  kind: python_call_eq
  function: herror.__name__.__eq__
  args: ["herror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__module__.__eq__('socket') — standalone
#
# socket.herror.__module__ is 'socket' (6 chars). herror is defined in Lib/socket.py so its
# __module__ is 'socket'. This is the same as gaierror.__module__ (both genuine socket-module
# exceptions). Both herror and gaierror have __module__ == 'socket' (6 chars), while
# socket.error and socket.timeout have __module__ == 'builtins' (8 chars) because they are
# aliases for built-in exceptions. 'socket' (6 chars) < 'builtins' (8 chars) by 2 chars.
# No prior socket spec anchors herror.__module__ as a standalone under sockexc165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
