spec: collections_extra23
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra22.zspec.zsdl."
    - "collections_extra22 covers: __name__.__eq__ for all eight collections classes; defaultdict(int) missing key; UserDict/UserList length invariants."
    - "collections_extra21 covers: deque len; deque/__OrderedDict bases; Counter key counts; __qualname__.__eq__ table for five classes."
    - "No prior collections spec records __bases__[0].__name__.__eq__ for OrderedDict/ChainMap/Counter/UserDict/UserList/UserString/deque together in the extra23 namespace."
    - "OrderedDict and Counter both inherit directly from dict; ChainMap and UserDict from MutableMapping; UserList from MutableSequence; UserString from Sequence; deque from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — seven collections classes
#
# Verifies the name of the first (and only) base class for each collections
# class. OrderedDict and Counter inherit from dict; ChainMap and UserDict
# from MutableMapping; UserList from MutableSequence; UserString from Sequence;
# deque from object.
# No prior collections spec records all seven base names in one table in
# the extra23 namespace.
# ---------------------------------------------------------------------------

table collections_extra23.base_names:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra23.base_names.OrderedDict,
       "OrderedDict.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.OrderedDict.__bases__[0].__name__ == 'dict'"]
    - [collections_extra23.base_names.ChainMap,
       "ChainMap.__bases__[0].__name__.__eq__",
       ["MutableMapping"],
       true,
       "collections.ChainMap.__bases__[0].__name__ == 'MutableMapping'"]
    - [collections_extra23.base_names.Counter,
       "Counter.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.Counter.__bases__[0].__name__ == 'dict'"]
    - [collections_extra23.base_names.UserDict,
       "UserDict.__bases__[0].__name__.__eq__",
       ["MutableMapping"],
       true,
       "collections.UserDict.__bases__[0].__name__ == 'MutableMapping'"]
    - [collections_extra23.base_names.UserList,
       "UserList.__bases__[0].__name__.__eq__",
       ["MutableSequence"],
       true,
       "collections.UserList.__bases__[0].__name__ == 'MutableSequence'"]
    - [collections_extra23.base_names.UserString,
       "UserString.__bases__[0].__name__.__eq__",
       ["Sequence"],
       true,
       "collections.UserString.__bases__[0].__name__ == 'Sequence'"]
    - [collections_extra23.base_names.deque,
       "deque.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "collections.deque.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# OrderedDict.__module__.__eq__ — module anchor
#
# Verifies that OrderedDict is defined in the 'collections' module.
# No prior collections spec records this invariant in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra23.OrderedDict.module:
  description: "collections.OrderedDict.__module__ == 'collections' — class is defined in collections"
  category: class_attrs
  kind: python_call_eq
  function: OrderedDict.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
# UserDict.__module__.__eq__ — module anchor
#
# Verifies that UserDict is defined in the 'collections' module.
# No prior collections spec records this invariant in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra23.UserDict.module:
  description: "collections.UserDict.__module__ == 'collections' — class is defined in collections"
