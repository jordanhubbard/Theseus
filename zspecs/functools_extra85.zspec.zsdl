spec: functools_extra85
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra84.zspec.zsdl."
    - "This spec covers: functools partial C-type method __qualname__ lengths and partialmethod/singledispatch/singledispatchmethod/total_ordering code attributes (Wave 245)."
    - "partial.__call__.__qualname__ == 'partial.__call__' (len 16) — partial is a C type; __call__ is a slot wrapper with __qualname__. Verified with Python 3.14.3."
    - "partial.__repr__.__qualname__ == 'partial.__repr__' (len 16) — slot wrapper on the C partial type. Verified with Python 3.14.3."
    - "partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18) — slot wrapper on the C partial type. Verified with Python 3.14.3."
    - "partial.__setstate__.__qualname__ == 'partial.__setstate__' (len 20) — slot wrapper on the C partial type. Verified with Python 3.14.3."
    - "partial.__new__.__qualname__ == 'partial.__new__' (len 15) — slot wrapper on the C partial type. Verified with Python 3.14.3."
    - "partialmethod.__get__.__code__.co_varnames.__len__() == 6 — varnames: self, obj, cls, get, result, new_func. Verified with Python 3.14.3."
    - "partialmethod.__init__ has no __code__ — it is a wrapper_descriptor (C slot); accessing __code__ raises AttributeError. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_varnames.__len__() == 6 — varnames: cls, op, roots, root, opname, opfunc. Verified with Python 3.14.3."
    - "singledispatch.__code__.co_name == 'singledispatch' — code object name matches function name. Verified with Python 3.14.3."
    - "singledispatch.__code__.co_argcount == 1 — takes a single 'func' argument. Verified with Python 3.14.3."
    - "singledispatch.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "singledispatchmethod.__init__.__code__.co_name == '__init__' — code object name matches method name. Verified with Python 3.14.3."
    - "singledispatchmethod.__init__.__code__.co_argcount == 2 — self and func. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial C-type method __qualname__ lengths (short: __call__, __repr__, __new__) — extra85
#
# Wave 245 theme: partial C-type slot wrapper __qualname__ lengths.
#
# functools.partial.__call__.__qualname__.__len__()  == 16
# functools.partial.__repr__.__qualname__.__len__()  == 16
# functools.partial.__new__.__qualname__.__len__()   == 15
#
# No prior functools spec checks partial slot wrapper __qualname__ lengths via functoolsextra85. New to extra85.
# ---------------------------------------------------------------------------

table functools_extra85.partial_qualname_short:
  description: "partial.__call__/__repr__ __qualname__.__len__()==16; __new__ __qualname__.__len__()==15; wave 245 partial C-type slot wrapper __qualname__ lengths; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra85

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname_len_eq_16,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — partial is a C extension type defined in Modules/_functoolsmodule.c; its __call__ slot wrapper has __qualname__ == 'partial.__call__' (16 chars: 'partial.__call__'); str.__len__() returns 16; no prior functools spec checks partial.__call__.__qualname__.__len__() via functoolsextra85; new to extra85"]
    - [partial_repr_qualname_len_eq_16,
       "partial.__repr__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — partial is a C extension type; its __repr__ slot wrapper has __qualname__ == 'partial.__repr__' (16 chars: 'partial.__repr__'); str.__len__() returns 16; no prior functools spec checks partial.__repr__.__qualname__.__len__() via functoolsextra85; new to extra85"]
    - [partial_new_qualname_len_eq_15,
       "partial.__new__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — partial is a C extension type; its __new__ slot wrapper has __qualname__ == 'partial.__new__' (15 chars: 'partial.__new__'); str.__len__() returns 15; no prior functools spec checks partial.__new__.__qualname__.__len__() via functoolsextra85; new to extra85"]

# ---------------------------------------------------------------------------
# partial C-type method __qualname__ lengths (longer: __reduce__, __setstate__) — extra85
#
# Wave 245 theme: partial C-type slot wrapper __qualname__ lengths (longer names).
#
# functools.partial.__reduce__.__qualname__.__len__()   == 18
# functools.partial.__setstate__.__qualname__.__len__() == 20
#
# No prior functools spec checks partial __reduce__/__setstate__ __qualname__ lengths via functoolsextra85. New to extra85.
# ---------------------------------------------------------------------------

table functools_extra85.partial_qualname_long:
  description: "partial.__reduce__ __qualname__.__len__()==18; __setstate__ __qualname__.__len__()==20; wave 245 partial C-type slot wrapper __qualname__ lengths; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra85

  columns: [id, function, args, expected, description]
  rows:
    - [partial_reduce_qualname_len_eq_18,
       "partial.__reduce__.__qualname__.__len__",
       [],
       18,
       "functools.partial.__reduce__.__qualname__.__len__() == 18 — partial is a C extension type; its __reduce__ slot wrapper has __qualname__ == 'partial.__reduce__' (18 chars: 'partial.__reduce__'); str.__len__() returns 18; no prior functools spec checks partial.__reduce__.__qualname__.__len__() via functoolsextra85; new to extra85"]
    - [partial_setstate_qualname_len_eq_20,
       "partial.__setstate__.__qualname__.__len__",
       [],
       20,
       "functools.partial.__setstate__.__qualname__.__len__() == 20 — partial is a C extension type; its __setstate__ slot wrapper has __qualname__ == 'partial.__setstate__' (20 chars: 'partial.__setstate__'); str.__len__() returns 20; no prior functools spec checks partial.__setstate__.__qualname__.__len__() via functoolsextra85; new to extra85"]

# ---------------------------------------------------------------------------
# partialmethod.__get__ and total_ordering code varnames — extra85
#
# Wave 245 theme: partialmethod.__get__ and total_ordering code object varnames.
#
# functools.partialmethod.__get__.__code__.co_varnames.__len__() == 6
# functools.total_ordering.__code__.co_varnames.__len__()        == 6
#
# No prior functools spec checks partialmethod/__get__/total_ordering varnames via functoolsextra85. New to extra85.
# ---------------------------------------------------------------------------

table functools_extra85.partialmethod_total_ordering_varnames:
  description: "partialmethod.__get__.__code__.co_varnames.__len__()==6; total_ordering.__code__.co_varnames.__len__()==6; wave 245 partialmethod/total_ordering code varnames; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra85

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_get_code_varnames_len_eq_6,
       partialmethod.__get__.__code__.co_varnames.__len__,
       [],
       6,
       "functools.partialmethod.__get__.__code__.co_varnames.__len__() == 6 — partialmethod is a pure-Python class in Lib/functools.py; its __get__ method has co_varnames == ('self', 'obj', 'cls', 'get', 'result', 'new_func') — 6 local variable names; tuple.__len__() returns 6; no prior functools spec checks partialmethod.__get__.__code__.co_varnames.__len__() via functoolsextra85; new to extra85"]
    - [total_ordering_code_varnames_len_eq_6,
       total_ordering.__code__.co_varnames.__len__,
       [],
       6,
       "functools.total_ordering.__code__.co_varnames.__len__() == 6 — total_ordering is a pure-Python class decorator in Lib/functools.py; its code object has co_varnames == ('cls', 'op', 'roots', 'root', 'opname', 'opfunc') — 6 local variable names; tuple.__len__() returns 6; no prior functools spec checks total_ordering.__code__.co_varnames.__len__() via functoolsextra85; new to extra85"]

# ---------------------------------------------------------------------------
# singledispatch and singledispatchmethod.__init__ code attributes — extra85
#
# Wave 245 theme: singledispatch code attrs and singledispatchmethod.__init__ code attrs.
#
# functools.singledispatch.__code__.co_name                 == 'singledispatch'
# functools.singledispatch.__code__.co_argcount             == 1
# functools.singledispatch.__module__                       == 'functools'
# functools.singledispatchmethod.__init__.__code__.co_name  == '__init__'
# functools.singledispatchmethod.__init__.__code__.co_argcount == 2
#
# No prior functools spec checks singledispatch/singledispatchmethod code attrs via functoolsextra85. New to extra85.
# ---------------------------------------------------------------------------

table functools_extra85.singledispatch_singledispatchmethod_code:
  description: "singledispatch.__code__.co_name=='singledispatch', co_argcount==1, __module__=='functools'; singledispatchmethod.__init__ co_name=='__init__', co_argcount==2; wave 245; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra85

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_code_co_name_eq_singledispatch,
       singledispatch.__code__.co_name.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — singledispatch is a pure-Python decorator function defined in Lib/functools.py; its code object's co_name attribute records the function name 'singledispatch' (14 chars); str.__eq__('singledispatch') returns True; no prior functools spec checks singledispatch.__code__.co_name via functoolsextra85; new to extra85"]
    - [singledispatch_code_co_argcount_eq_1,
       singledispatch.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch(func) takes exactly one positional argument 'func'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior functools spec checks singledispatch.__code__.co_argcount via functoolsextra85; new to extra85"]
    - [singledispatch_module_eq_functools,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py and its __module__ attribute records 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks singledispatch.__module__ via functoolsextra85; new to extra85"]
    - [singledispatchmethod_init_code_co_name_eq___init__,
       singledispatchmethod.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "functools.singledispatchmethod.__init__.__code__.co_name.__eq__('__init__') == True — singledispatchmethod is a pure-Python class in Lib/functools.py; its __init__ method's code object co_name records '__init__' (8 chars); str.__eq__('__init__') returns True; no prior functools spec checks singledispatchmethod.__init__.__code__.co_name via functoolsextra85; new to extra85"]
    - [singledispatchmethod_init_code_co_argcount_eq_2,
       singledispatchmethod.__init__.__code__.co_argcount.__eq__,
       [2],
       true,
       "functools.singledispatchmethod.__init__.__code__.co_argcount.__eq__(2) == True — singledispatchmethod.__init__(self, func) takes two positional-or-keyword arguments: self and func; the code object's co_argcount is 2; int.__eq__(2) returns True; no prior functools spec checks singledispatchmethod.__init__.__code__.co_argcount via functoolsextra85; new to extra85"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra85
# ---------------------------------------------------------------------------

invariant functools_extra85.partial_call_qualname_len:
  description: "functools.partial.__call__.__qualname__.__len__() == 16 — partial.__call__ slot wrapper qualname is 'partial.__call__' (16 chars); wave 245 partial C-type slot wrapper __qualname__ lengths; new to extra85"
  kind: python_call_eq
  function: "partial.__call__.__qualname__.__len__"
  args: []
  expected: 16

invariant functools_extra85.partial_setstate_qualname_len:
  description: "functools.partial.__setstate__.__qualname__.__len__() == 20 — partial.__setstate__ slot wrapper qualname is 'partial.__setstate__' (20 chars); wave 245 partial C-type slot wrapper __qualname__ lengths; new to extra85"
  kind: python_call_eq
  function: "partial.__setstate__.__qualname__.__len__"
  args: []
  expected: 20

invariant functools_extra85.partialmethod_init_no_code:
  description: "functools.partialmethod.__init__.__code__ raises AttributeError — partialmethod.__init__ is a wrapper_descriptor (C slot) with no __code__ attribute; wave 245 partialmethod C-type identity; new to extra85"
  kind: python_call_raises
  function: partialmethod.__init__.__getattribute__
  args: ["__code__"]
  expected_exception: AttributeError

invariant functools_extra85.singledispatch_module:
  description: "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; wave 245 singledispatch identity; new to extra85"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra85.singledispatchmethod_init_co_argcount:
  description: "functools.singledispatchmethod.__init__.__code__.co_argcount.__eq__(2) == True — singledispatchmethod.__init__(self, func) has 2 positional-or-keyword args; wave 245 singledispatchmethod.__init__ code attrs; new to extra85"
  kind: python_call_eq
  function: singledispatchmethod.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true
