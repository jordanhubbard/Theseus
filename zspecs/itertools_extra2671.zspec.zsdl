spec: itertools_extra2671
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 625 theme: __sub__, __floordiv__, and __mod__ dict-presence checks (subtraction and integer division arithmetic)."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support numeric arithmetic protocols such as __sub__, __floordiv__, or __mod__."
    - "itertools.repeat does have a __len__ for finite repeats, but still defines none of __sub__, __floordiv__, __mod__."
    - "None of the itertools classes define __sub__, __floordiv__, or __mod__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2671.sub_protocol:
  description: "__sub__ is absent from all itertools iterator class __dict__s — lazy iterators do not support subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2671

  columns: [id, function, args, expected]
  rows:
    - ["it2671001", "itertools.chain.__dict__.__contains__",                         ["__sub__"], false]
    - ["it2671002", "itertools.count.__dict__.__contains__",                         ["__sub__"], false]
    - ["it2671003", "itertools.repeat.__dict__.__contains__",                        ["__sub__"], false]
    - ["it2671004", "itertools.cycle.__dict__.__contains__",                         ["__sub__"], false]
    - ["it2671005", "itertools.islice.__dict__.__contains__",                        ["__sub__"], false]
    - ["it2671006", "itertools.compress.__dict__.__contains__",                      ["__sub__"], false]
    - ["it2671007", "itertools.dropwhile.__dict__.__contains__",                     ["__sub__"], false]
    - ["it2671008", "itertools.takewhile.__dict__.__contains__",                     ["__sub__"], false]
    - ["it2671009", "itertools.starmap.__dict__.__contains__",                       ["__sub__"], false]
    - ["it2671010", "itertools.groupby.__dict__.__contains__",                       ["__sub__"], false]
    - ["it2671011", "itertools.filterfalse.__dict__.__contains__",                   ["__sub__"], false]
    - ["it2671012", "itertools.accumulate.__dict__.__contains__",                    ["__sub__"], false]
    - ["it2671013", "itertools.zip_longest.__dict__.__contains__",                   ["__sub__"], false]
    - ["it2671014", "itertools.pairwise.__dict__.__contains__",                      ["__sub__"], false]
    - ["it2671015", "itertools.product.__dict__.__contains__",                       ["__sub__"], false]
    - ["it2671016", "itertools.permutations.__dict__.__contains__",                  ["__sub__"], false]
    - ["it2671017", "itertools.combinations.__dict__.__contains__",                  ["__sub__"], false]
    - ["it2671018", "itertools.combinations_with_replacement.__dict__.__contains__",  ["__sub__"], false]

