# ---------------------------------------------------------------------------
# Combinatorics subgroup — product, permutations, combinations vs. all three
# ---------------------------------------------------------------------------

table itertools_extra2671.combinatorics_combined:
  description: "itertools combinatoric classes (product, permutations, combinations, combinations_with_replacement) define none of __sub__, __floordiv__, __mod__"
