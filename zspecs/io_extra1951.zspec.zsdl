spec: io_extra1951
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "io.BytesIO defines both __iter__ and __next__ in its own __dict__ (C implementation)."
    - "io.StringIO, io.BufferedReader, io.BufferedRandom, io.TextIOWrapper define __next__ but not __iter__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BufferedWriter define neither."
    - "No io class defines __contains__, __aiter__, or __anext__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table io_extra1951.contains_protocol:
  description: "io types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1951

  columns: [id, function, args, expected]
  rows:
    - ["io1951001", "io.IOBase.__dict__.__contains__",         ["__contains__"], false]
    - ["io1951002", "io.RawIOBase.__dict__.__contains__",      ["__contains__"], false]
    - ["io1951003", "io.BufferedIOBase.__dict__.__contains__", ["__contains__"], false]
    - ["io1951004", "io.TextIOBase.__dict__.__contains__",     ["__contains__"], false]
    - ["io1951005", "io.BytesIO.__dict__.__contains__",        ["__contains__"], false]
    - ["io1951006", "io.StringIO.__dict__.__contains__",       ["__contains__"], false]
    - ["io1951007", "io.FileIO.__dict__.__contains__",         ["__contains__"], false]
    - ["io1951008", "io.BufferedReader.__dict__.__contains__", ["__contains__"], false]
    - ["io1951009", "io.BufferedWriter.__dict__.__contains__", ["__contains__"], false]
    - ["io1951010", "io.BufferedRandom.__dict__.__contains__", ["__contains__"], false]
    - ["io1951011", "io.TextIOWrapper.__dict__.__contains__",  ["__contains__"], false]

