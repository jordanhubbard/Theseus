spec: functools_extra194
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.lru_cache.__name__ == 'lru_cache' (len=9); verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools'; verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache'; verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a plain Python function; verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' (len=5); verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools'; verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache'; verified with Python 3.14.3."
    - "len('cache')==5 < len('lru_cache')==9; cache name is shorter than lru_cache name; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache identity
#
# functools.lru_cache.__name__         == 'lru_cache' (len=9)
# functools.lru_cache.__module__       == 'functools'
# functools.lru_cache.__qualname__     == 'lru_cache'
# functools.lru_cache.__class__.__name__ == 'function'
#
# lru_cache is a decorator implemented as a plain Python function.
# Its __name__ and __qualname__ are both 'lru_cache'. New to extra194.
# ---------------------------------------------------------------------------

table functools_extra194.lru_cache_identity:
  description: "functools.lru_cache identity: __name__=='lru_cache' (len=9); __module__=='functools'; __qualname__=='lru_cache'; __class__.__name__=='function'; new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: functlrucache194

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — the decorator's __name__ is 'lru_cache' (len=9); str.__eq__('lru_cache') returns True; verified with Python 3.14.3; new to extra194"]
    - [name_len,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra194"]
    - [module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in the functools module; str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra194"]
    - [qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — top-level function so __qualname__ equals __name__; str.__eq__('lru_cache') returns True; verified with Python 3.14.3; new to extra194"]
    - [class_name_eq,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a plain Python function not a class; __class__.__name__ is 'function'; str.__eq__('function') returns True; verified with Python 3.14.3; new to extra194"]

# ---------------------------------------------------------------------------
# Table 2: functools.cache identity
#
# functools.cache.__name__         == 'cache' (len=5)
# functools.cache.__module__       == 'functools'
# functools.cache.__qualname__     == 'cache'
#
# cache is a simpler unbounded variant of lru_cache, added in Python 3.9.
# Its __name__ and __qualname__ are both 'cache'. New to extra194.
# ---------------------------------------------------------------------------

table functools_extra194.cache_identity:
  description: "functools.cache identity: __name__=='cache' (len=5); __module__=='functools'; __qualname__=='cache'; new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: functlrucache194

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — the decorator's __name__ is 'cache' (len=5); str.__eq__('cache') returns True; verified with Python 3.14.3; new to extra194"]
    - [name_len,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters: c-a-c-h-e; str.__len__() returns 5; verified with Python 3.14.3; new to extra194"]
    - [module_eq,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in the functools module; str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra194"]
    - [qualname_eq,
       cache.__qualname__.__eq__,
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — top-level function so __qualname__ equals __name__; str.__eq__('cache') returns True; verified with Python 3.14.3; new to extra194"]

# ---------------------------------------------------------------------------
# Table 3: name length ordering — cache(5) < lru_cache(9)
#
# functools.cache.__name__.__len__()     == 5
# functools.lru_cache.__name__.__len__() == 9
# 5 < 9 confirms cache name is shorter than lru_cache name.
# New to extra194.
# ---------------------------------------------------------------------------

table functools_extra194.name_length_ordering:
  description: "cache.__name__.__len__()==5; lru_cache.__name__.__len__()==9; 5 < 9 so cache name is shorter; new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: functlrucache194

  columns: [id, function, args, expected, description]
  rows:
    - [cache_len5,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' is 5 characters; c-a-c-h-e; verified with Python 3.14.3; new to extra194"]
    - [lru_len9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' is 9 characters; l-r-u-_-c-a-c-h-e; verified with Python 3.14.3; new to extra194"]
    - [cache_lt_lru,
       cache.__name__.__lt__,
       ["lru_cache"],
       true,
       "functools.cache.__name__.__lt__('lru_cache') == True — 'cache' < 'lru_cache' lexicographically (c < l); str.__lt__ returns True; verified with Python 3.14.3; new to extra194"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra194
# ---------------------------------------------------------------------------

invariant functools_extra194.lru_cache_name_eq:
  description: "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache decorator's __name__ is 'lru_cache' (len=9: l-r-u-_-c-a-c-h-e); verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra194.lru_cache_module_eq:
  description: "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in the functools module; verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra194.lru_cache_qualname_eq:
  description: "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — top-level function so __qualname__ equals __name__ ('lru_cache', len=9); verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra194.lru_cache_class_name_eq:
  description: "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a plain Python function not a class or builtin; __class__.__name__ is 'function'; verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra194.cache_name_eq:
  description: "functools.cache.__name__.__eq__('cache') == True — cache decorator's __name__ is 'cache' (len=5: c-a-c-h-e); verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra194.cache_module_eq:
  description: "functools.cache.__module__.__eq__('functools') == True — cache is defined in the functools module; verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra194.cache_qualname_eq:
  description: "functools.cache.__qualname__.__eq__('cache') == True — top-level function so __qualname__ equals __name__ ('cache', len=5); verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra194.cache_name_len5:
  description: "functools.cache.__name__.__len__() == 5 — 'cache' has exactly 5 characters; str.__len__() returns 5; verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra194.lru_cache_name_len9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has exactly 9 characters; str.__len__() returns 9; verified with Python 3.14.3; new to extra194"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9
