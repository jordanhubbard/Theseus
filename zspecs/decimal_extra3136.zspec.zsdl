spec: dc3136
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (dc3136): __call__, __len__, __getitem__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "No decimal class defines __call__ in its own __dict__: decimal types are data holders and exception types, not callable wrappers."
    - "No decimal class defines __len__ in its own __dict__: decimal types do not implement the sized protocol."
    - "No decimal class defines __getitem__ in its own __dict__: decimal types do not support subscript access."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# No decimal class defines __call__ in its own __dict__; all false.
# Decimal and Context are arithmetic types; exception subclasses are exception types.
# ---------------------------------------------------------------------------

table dc3136.call:
  description: "decimal types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3136

  columns: [id, function, args, expected]
  rows:
    - ["dc3136001", operator.contains, [decimal.Decimal.__dict__,          "__call__"], false]
    - ["dc3136002", operator.contains, [decimal.Context.__dict__,           "__call__"], false]
    - ["dc3136003", operator.contains, [decimal.DecimalException.__dict__,  "__call__"], false]
    - ["dc3136004", operator.contains, [decimal.InvalidOperation.__dict__,  "__call__"], false]
    - ["dc3136005", operator.contains, [decimal.Overflow.__dict__,          "__call__"], false]
    - ["dc3136006", operator.contains, [decimal.Underflow.__dict__,         "__call__"], false]

