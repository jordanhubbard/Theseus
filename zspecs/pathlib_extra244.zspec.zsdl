spec: pathlib_extra244
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method identity contracts — stat, chmod, exists, glob __name__ and __qualname__ checks."
    - "pathlib.Path.stat.__name__ == 'stat' — length 4; verified Python 3.14.3 macOS."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' — length 9; verified Python 3.14.3 macOS."
    - "pathlib.Path.chmod.__name__ == 'chmod' — length 5; verified Python 3.14.3 macOS."
    - "pathlib.Path.chmod.__qualname__ == 'Path.chmod' — length 10; verified Python 3.14.3 macOS."
    - "pathlib.Path.exists.__name__ == 'exists' — length 6; verified Python 3.14.3 macOS."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists' — length 11; verified Python 3.14.3 macOS."
    - "pathlib.Path.glob.__name__ == 'glob' — length 4; verified Python 3.14.3 macOS."
    - "pathlib.Path.glob.__qualname__ == 'Path.glob' — length 9; verified Python 3.14.3 macOS."
    - "All four methods are defined directly on Path (not a parent class); __qualname__ uses 'Path.' prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.stat method identity contracts
# stat() returns an os.stat_result for the path.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra244.Path.stat.name_eq:
  description: "pathlib.Path.stat.__name__ == 'stat' — method name is 'stat'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.stat.__name__.__eq__
  args: ["stat"]
  expected: true

invariant pathlib_extra244.Path.stat.name_len:
  description: "len(pathlib.Path.stat.__name__) == 4 — 'stat' has 4 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.stat.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra244.Path.stat.qualname_eq:
  description: "pathlib.Path.stat.__qualname__ == 'Path.stat' — qualname is 'Path.stat'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.stat.__qualname__.__eq__
  args: ["Path.stat"]
  expected: true

invariant pathlib_extra244.Path.stat.qualname_len:
  description: "len(pathlib.Path.stat.__qualname__) == 9 — 'Path.stat' has 9 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.stat.__qualname__.__len__
  args: []
  expected: 9

