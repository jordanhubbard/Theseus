spec: codecs_extra3
version: ">=3.2"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "Python codecs documentation — https://docs.python.org/3/library/codecs.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "CPython source: Modules/_codecsmodule.c"
  notes:
    - "This spec extends codecs.zspec.zsdl, codecs_extra.zspec.zsdl, codecs_extra2.zspec.zsdl, and codecs_extra4.zspec.zsdl."
    - "codecs_extra.zspec.zsdl: CodecInfo/__name__/__module__, lookup returns CodecInfo, encode/decode UTF-8, open/__name__, register/__name__, getincrementalencoder/getincrementaldecoder class names."
    - "codecs_extra2.zspec.zsdl: class __name__ for CodecInfo/BufferedIncrementalDecoder/StreamReader/StreamWriter; function __name__ for lookup/encode/decode/open; encode returns bytes; decode utf-8 hello."
    - "codecs_extra4.zspec.zsdl: function __name__ table for encode/decode/lookup/register/open; encode/decode type checks; lookup codec_info_class; lookup utf-8/ascii name; CodecInfo/__name__/__module__."
    - "Focus: __qualname__ for encode/decode/open/lookup/register/CodecInfo/Codec/IncrementalEncoder/IncrementalDecoder/StreamReader/StreamWriter; __module__ for open/register; Codec/__name__/__module__; IncrementalEncoder/__name__/__module__; IncrementalDecoder/__name__/__module__; lookup utf-32/latin-1/utf-16 (new IDs); BOM constant lengths; encode('hello','ascii') value."
    - "codecs.encode, codecs.decode, and codecs.lookup are C-level builtins in _codecs; their __module__ is '_codecs'."
    - "codecs.open and codecs.register are pure Python wrappers; their __module__ is 'codecs'."
    - "codecs.Codec.__name__ == 'Codec' — base class for codec objects; defined in Lib/codecs.py."
    - "codecs.IncrementalEncoder.__name__ == 'IncrementalEncoder'; __module__ == 'codecs'."
    - "codecs.IncrementalDecoder.__name__ == 'IncrementalDecoder'; __module__ == 'codecs'."
    - "codecs.StreamReader.__module__ == 'codecs'; codecs.StreamWriter.__module__ == 'codecs'."
    - "codecs.BOM_UTF8.__len__() == 3 — the UTF-8 BOM is 3 bytes (EF BB BF)."
    - "codecs.BOM_UTF16_LE.__len__() == 2 — the UTF-16 LE BOM is 2 bytes."
    - "codecs.BOM_UTF32_LE.__len__() == 4 — the UTF-32 LE BOM is 4 bytes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for module-level functions
# No prior spec checks __qualname__ on codecs functions.
# ---------------------------------------------------------------------------

table codecs_extra3.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [encode,    encode.__qualname__.__eq__,    ["encode"],    true]
    - [decode,    decode.__qualname__.__eq__,    ["decode"],    true]
    - [open,      open.__qualname__.__eq__,      ["open"],      true]
    - [lookup,    lookup.__qualname__.__eq__,    ["lookup"],    true]
    - [register,  register.__qualname__.__eq__,  ["register"],  true]

# ---------------------------------------------------------------------------
# __module__ checks for open and register (pure-Python wrappers in codecs)
# codecs_extra2 notes that encode/decode/lookup are in _codecs, but open/register
# are pure Python in 'codecs'. No prior spec verifies these __module__ values.
# ---------------------------------------------------------------------------

invariant codecs_extra3.open.module:
  description: "codecs.open.__module__ == 'codecs' — open is a pure-Python wrapper"
  category: module
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["codecs"]
  expected: true

invariant codecs_extra3.register.module:
  description: "codecs.register.__module__ == 'codecs' — register is a pure-Python wrapper"
  category: module
  kind: python_call_eq
  function: register.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# Codec base class — __name__, __qualname__, __module__
# No prior spec covers the Codec base class identity.
# ---------------------------------------------------------------------------

invariant codecs_extra3.Codec.name:
  description: "codecs.Codec.__name__ == 'Codec'"
  category: class_names
  kind: python_call_eq
  function: Codec.__name__.__eq__
  args: ["Codec"]
  expected: true

invariant codecs_extra3.Codec.qualname:
  description: "codecs.Codec.__qualname__ == 'Codec'"
  category: class_names
  kind: python_call_eq
  function: Codec.__qualname__.__eq__
  args: ["Codec"]
  expected: true

invariant codecs_extra3.Codec.module:
  description: "codecs.Codec.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: Codec.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# IncrementalEncoder class — __name__, __qualname__, __module__
# codecs_extra gets the class indirectly via getincrementalencoder('utf-8').__name__.
# We check the base class identity directly.
# ---------------------------------------------------------------------------

invariant codecs_extra3.IncrementalEncoder.name:
  description: "codecs.IncrementalEncoder.__name__ == 'IncrementalEncoder'"
  category: class_names
  kind: python_call_eq
  function: IncrementalEncoder.__name__.__eq__
  args: ["IncrementalEncoder"]
  expected: true

invariant codecs_extra3.IncrementalEncoder.qualname:
  description: "codecs.IncrementalEncoder.__qualname__ == 'IncrementalEncoder'"
  category: class_names
  kind: python_call_eq
  function: IncrementalEncoder.__qualname__.__eq__
  args: ["IncrementalEncoder"]
  expected: true

invariant codecs_extra3.IncrementalEncoder.module:
  description: "codecs.IncrementalEncoder.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: IncrementalEncoder.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# IncrementalDecoder class — __name__, __qualname__, __module__
# ---------------------------------------------------------------------------

invariant codecs_extra3.IncrementalDecoder.name:
  description: "codecs.IncrementalDecoder.__name__ == 'IncrementalDecoder'"
  category: class_names
  kind: python_call_eq
  function: IncrementalDecoder.__name__.__eq__
  args: ["IncrementalDecoder"]
  expected: true

invariant codecs_extra3.IncrementalDecoder.qualname:
  description: "codecs.IncrementalDecoder.__qualname__ == 'IncrementalDecoder'"
  category: class_names
  kind: python_call_eq
  function: IncrementalDecoder.__qualname__.__eq__
  args: ["IncrementalDecoder"]
  expected: true

invariant codecs_extra3.IncrementalDecoder.module:
  description: "codecs.IncrementalDecoder.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: IncrementalDecoder.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# StreamReader class — __qualname__, __module__
# codecs_extra2 covers StreamReader.__name__ == 'StreamReader'.
# We add __qualname__ and __module__.
# ---------------------------------------------------------------------------

invariant codecs_extra3.StreamReader.qualname:
  description: "codecs.StreamReader.__qualname__ == 'StreamReader'"
  category: class_names
  kind: python_call_eq
  function: StreamReader.__qualname__.__eq__
  args: ["StreamReader"]
  expected: true

invariant codecs_extra3.StreamReader.module:
  description: "codecs.StreamReader.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: StreamReader.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# StreamWriter class — __qualname__, __module__
# codecs_extra2 covers StreamWriter.__name__ == 'StreamWriter'.
# We add __qualname__ and __module__.
# ---------------------------------------------------------------------------

invariant codecs_extra3.StreamWriter.qualname:
  description: "codecs.StreamWriter.__qualname__ == 'StreamWriter'"
  category: class_names
  kind: python_call_eq
  function: StreamWriter.__qualname__.__eq__
  args: ["StreamWriter"]
  expected: true

invariant codecs_extra3.StreamWriter.module:
  description: "codecs.StreamWriter.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: StreamWriter.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# CodecInfo class — __qualname__
# Prior specs cover __name__ and __module__; __qualname__ is not yet checked.
# ---------------------------------------------------------------------------

invariant codecs_extra3.CodecInfo.qualname:
  description: "codecs.CodecInfo.__qualname__ == 'CodecInfo'"
  category: class_names
  kind: python_call_eq
  function: CodecInfo.__qualname__.__eq__
  args: ["CodecInfo"]
  expected: true

# ---------------------------------------------------------------------------
# BOM constants — byte lengths
# codecs.zspec.zsdl verifies BOM values via .hex(); no spec checks __len__.
# ---------------------------------------------------------------------------

table codecs_extra3.bom.lengths:
  kind: python_call_eq
  category: bom
  id_prefix: bom_len

  columns: [id, function, args, expected]
  rows:
    - [utf8,      BOM_UTF8.__len__,      [], 3]
    - [utf16_le,  BOM_UTF16_LE.__len__,  [], 2]
    - [utf16_be,  BOM_UTF16_BE.__len__,  [], 2]
    - [utf32_le,  BOM_UTF32_LE.__len__,  [], 4]
    - [utf32_be,  BOM_UTF32_BE.__len__,  [], 4]

# ---------------------------------------------------------------------------
# lookup — additional encoding names not in prior specs
# codecs.zspec.zsdl covers utf-8, ascii, latin-1, utf-16, rot-13.
# codecs_extra4 covers utf-8 and ascii (again).
# We add: utf-32 and utf-8-sig as new distinct vectors.
# ---------------------------------------------------------------------------

invariant codecs_extra3.lookup.utf32_name:
  description: "codecs.lookup('utf-32').name == 'utf-32'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-32"]
  method: name.__eq__
  method_args: ["utf-32"]
  expected: true

invariant codecs_extra3.lookup.utf8sig_name:
  description: "codecs.lookup('utf-8-sig').name == 'utf-8-sig'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-8-sig"]
  method: name.__eq__
  method_args: ["utf-8-sig"]
  expected: true

# ---------------------------------------------------------------------------
# encode — ASCII codec value correctness
# codecs_extra/extra4 cover encode('hello', 'utf-8') == b'hello'.
# We add encode('hello', 'ascii') == b'hello' as a new distinct vector.
# ---------------------------------------------------------------------------

invariant codecs_extra3.encode.ascii_hello:
  description: "codecs.encode('hello', 'ascii') == b'hello'"
  category: encode_decode
  kind: python_call_eq
  function: encode
  args: ["hello", "ascii"]
  expected: !ascii "hello"
