spec: hashlib_extra8
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, hashlib_extra2.zspec.zsdl, hashlib_extra3.zspec.zsdl, hashlib_extra4.zspec.zsdl, hashlib_extra5.zspec.zsdl, hashlib_extra6.zspec.zsdl, hashlib_extra7.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "hashlib_extra3 covers md5.__name__=='openssl_md5' — not repeated here."
    - "hashlib_extra4/5 cover new.__name__=='new' and new.__module__=='hashlib' — not repeated here."
    - "hashlib_extra/2/3/4/5 cover algorithms_guaranteed/available class names — not repeated here."
    - "hashlib_extra4 covers algorithms_guaranteed.__contains__ for sha256/sha1/md5/sha512 — not repeated here."
    - "hashlib_extra7 covers algorithms_guaranteed.__contains__ for sha384/sha224 — not repeated here."
    - "No prior spec covers __qualname__ for any hashlib function or constructor."
    - "hashlib.new.__qualname__ == 'new' — __qualname__ for a module-level function equals __name__."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256' — the OpenSSL-backed constructor's qualname."
    - "hashlib.algorithms_available.__contains__('sha1') == True — always present on OpenSSL-backed builds."
    - "hashlib.algorithms_available.__contains__('sha3_256') == True — SHA-3 available via OpenSSL 1.1+."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True — per Python docs; covered in hashlib.zspec.zsdl via python_set_contains but not via __contains__ method call."
    - "hashlib.algorithms_guaranteed.__len__() >= 8 — Python 3.9+ guarantees at least sha1/sha224/sha256/sha384/sha512/md5/sha3_256/sha3_512."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for hashlib module-level functions and constructors
#
# No prior spec covers __qualname__ for any hashlib entity.
# For module-level functions and constructors, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant hashlib_extra8.new.qualname:
  description: "hashlib.new.__qualname__ == 'new'"
  category: qualnames
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["new"]
  expected: true

table hashlib_extra8.constructor_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [sha256, sha256.__qualname__.__eq__, ["openssl_sha256"], true]
    - [sha512, sha512.__qualname__.__eq__, ["openssl_sha512"], true]
    - [sha1,   sha1.__qualname__.__eq__,   ["openssl_sha1"],   true]
    - [md5,    md5.__qualname__.__eq__,    ["openssl_md5"],    true]
    - [sha224, sha224.__qualname__.__eq__, ["openssl_sha224"], true]
    - [sha384, sha384.__qualname__.__eq__, ["openssl_sha384"], true]

# ---------------------------------------------------------------------------
# algorithms_available — membership checks not yet covered
#
# hashlib_extra.zspec.zsdl covers sha256; hashlib_extra4 covers sha512/md5.
# This spec adds sha1 and sha3_256, which are not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant hashlib_extra8.algorithms_available.contains_sha1:
  description: "hashlib.algorithms_available.__contains__('sha1') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sha1"]
  expected: true

invariant hashlib_extra8.algorithms_available.contains_sha3_256:
  description: "hashlib.algorithms_available.__contains__('sha3_256') == True — SHA-3 on OpenSSL 1.1+"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — membership for sha3_512 and blake2s via __contains__
#
# hashlib.zspec.zsdl covers sha3_512/blake2s membership via python_set_contains
# kind (a different mechanism).  This spec verifies the same facts via the
# __contains__ dunder method — orthogonal test vector.
# ---------------------------------------------------------------------------

invariant hashlib_extra8.algorithms_guaranteed.contains_sha3_512:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_512"]
  expected: true

invariant hashlib_extra8.algorithms_guaranteed.contains_blake2s:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2s') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2s"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — minimum cardinality
#
# hashlib_extra3 covers __len__() >= 6.  Python 3.9+ guarantees at least
# sha1/sha224/sha256/sha384/sha512/md5/sha3_256/sha3_512 — eight algorithms —
# so __len__() >= 8 is a tighter bound not yet asserted.
# ---------------------------------------------------------------------------

invariant hashlib_extra8.algorithms_guaranteed.len_ge_8:
  description: "hashlib.algorithms_guaranteed.__len__() >= 8 — at least 8 algorithms guaranteed since Python 3.9"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  method: __ge__
  method_args: [8]
  expected: true
