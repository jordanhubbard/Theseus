spec: nntplib_extra3
version: ">=3.9,<3.13"
backend: python_module(nntplib)

docs: https://docs.python.org/3.11/library/nntplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/nntplib.html — Python nntplib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/nntplib.py"
  notes:
    - "This spec extends nntplib.zspec.zsdl and prior extras."
    - "nntplib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "nntplib.zspec.zsdl covers: all class __name__s (table), NNTP.__module__, NNTP.port==119, all hierarchy chains."
    - "nntplib_extra.zspec.zsdl covers: NNTP/NNTP_SSL __name__, NNTP.__module__, NNTP_SSL.__bases__[0]=='_NNTPBase', NNTPError/NNTPTemporaryError/NNTPPermanentError/NNTPReplyError/NNTPDataError __name__ and hierarchy."
    - "nntplib_extra2.zspec.zsdl covers: NNTP_SSL.__module__, NNTP/NNTP_SSL qualnames, NNTP.port type, NNTPProtocolError hierarchy, exception names table."
    - "This spec adds: qualnames for NNTPError and all subclasses (table); module affiliation for NNTPError and subclasses; NNTP/__class__.__name__ == 'type'."
    - "NNTPError.__qualname__ == 'NNTPError' — top-level class; qualname equals name."
    - "NNTPError.__module__ == 'nntplib' — all exception classes are defined in nntplib."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class qualnames
# For top-level classes, __qualname__ == __name__.
# None of the prior nntplib specs cover __qualname__ for the exception classes.
# nntplib_extra2 covers NNTP.__qualname__ and NNTP_SSL.__qualname__ already.
# ---------------------------------------------------------------------------

table nntplib_extra3.exception_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: excqualname

  columns: [id, function, args, expected]
  rows:
    - [NNTPError,          NNTPError.__qualname__.__eq__,          ["NNTPError"],          true]
    - [NNTPReplyError,     NNTPReplyError.__qualname__.__eq__,     ["NNTPReplyError"],     true]
    - [NNTPTemporaryError, NNTPTemporaryError.__qualname__.__eq__, ["NNTPTemporaryError"], true]
    - [NNTPPermanentError, NNTPPermanentError.__qualname__.__eq__, ["NNTPPermanentError"], true]
    - [NNTPProtocolError,  NNTPProtocolError.__qualname__.__eq__,  ["NNTPProtocolError"],  true]
    - [NNTPDataError,      NNTPDataError.__qualname__.__eq__,      ["NNTPDataError"],      true]

# ---------------------------------------------------------------------------
# Exception class module affiliation
# All NNTP exception classes are defined in the nntplib module.
# Not covered as standalone invariants in any prior nntplib spec.
# ---------------------------------------------------------------------------

invariant nntplib_extra3.module.NNTPError:
  description: "nntplib.NNTPError.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTPError.__module__.__eq__
  args: ["nntplib"]
  expected: true

invariant nntplib_extra3.module.NNTPTemporaryError:
  description: "nntplib.NNTPTemporaryError.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTPTemporaryError.__module__.__eq__
  args: ["nntplib"]
  expected: true

invariant nntplib_extra3.module.NNTPPermanentError:
  description: "nntplib.NNTPPermanentError.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTPPermanentError.__module__.__eq__
  args: ["nntplib"]
  expected: true

# ---------------------------------------------------------------------------
# NNTP and NNTP_SSL metaclass check — __class__.__name__ == 'type'
# Regular Python classes have type as their metaclass.
# Not covered in any prior nntplib spec.
# ---------------------------------------------------------------------------

table nntplib_extra3.metaclass_types:
  kind: python_call_eq
  category: class_types
  id_prefix: metaclass

  columns: [id, function, args, expected]
  rows:
    - [NNTP,     NNTP.__class__.__name__.__eq__,     ["type"], true]
    - [NNTP_SSL, NNTP_SSL.__class__.__name__.__eq__, ["type"], true]
