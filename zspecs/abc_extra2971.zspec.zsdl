spec: ab2971
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 645 — theme: __floor__, __ceil__, __index__ dict-presence (floor, ceiling, integer-index)."
    - "Tests operator.contains(SomeClass.__dict__, '__floor__') etc. for abc module classes."
    - "Classes covered: ABC, ABCMeta, and the built-in 'function' type (type of abc.abstractmethod(lambda: None))."
    - "abstractproperty is deliberately excluded (deprecated and removed in Python 3.13)."
    - "None of ABC, ABCMeta, or the function type define __floor__, __ceil__, or __index__ in their own __dict__."
    - "ABC.__module__ == 'abc'; ABCMeta.__module__ == 'abc'; function.__module__ == 'builtins'."
    - "type(abc.abstractmethod(lambda: None)).__name__ == 'function' — the built-in function type."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# ABC, ABCMeta, and the function type do not define __floor__; all false.
# ---------------------------------------------------------------------------

table ab2971.floor:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_floor
  id_prefix: flr

  columns: [id, function, args, expected]
  rows:
    - ["flr_ABC",           operator.contains, [ABC.__dict__,                                "__floor__"], false]
    - ["flr_ABCMeta",       operator.contains, [ABCMeta.__dict__,                            "__floor__"], false]
    - ["flr_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — operator.contains(Cls.__dict__, '__ceil__')
#
# ABC, ABCMeta, and the function type do not define __ceil__; all false.
# ---------------------------------------------------------------------------

table ab2971.ceil:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_ceil
  id_prefix: ceil

  columns: [id, function, args, expected]
  rows:
    - ["ceil_ABC",           operator.contains, [ABC.__dict__,                                "__ceil__"], false]
    - ["ceil_ABCMeta",       operator.contains, [ABCMeta.__dict__,                            "__ceil__"], false]
    - ["ceil_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__ceil__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.contains(Cls.__dict__, '__index__')
#
# ABC, ABCMeta, and the function type do not define __index__; all false.
# ---------------------------------------------------------------------------

table ab2971.index:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_index
  id_prefix: idx

  columns: [id, function, args, expected]
  rows:
    - ["idx_ABC",           operator.contains, [ABC.__dict__,                                "__index__"], false]
    - ["idx_ABCMeta",       operator.contains, [ABCMeta.__dict__,                            "__index__"], false]
    - ["idx_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__index__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all three subjects plus supplementary
#
# Core cross-product: 3 subjects x 3 operators = 9 rows.  Padded with
# additional cross-checks on ABCMeta-derived and built-in dict lookup paths
# to bring the table to ~24 rows for consistency with the wave 645 target.
# All supplementary rows confirm the same absence of numeric dunder slots.
# ---------------------------------------------------------------------------

table ab2971.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_ABC_flr",              operator.contains, [ABC.__dict__,                                "__floor__"], false]
    - ["comb_ABC_ceil",             operator.contains, [ABC.__dict__,                                "__ceil__"],  false]
    - ["comb_ABC_idx",              operator.contains, [ABC.__dict__,                                "__index__"], false]
    - ["comb_ABCMeta_flr",          operator.contains, [ABCMeta.__dict__,                            "__floor__"], false]
    - ["comb_ABCMeta_ceil",         operator.contains, [ABCMeta.__dict__,                            "__ceil__"],  false]
    - ["comb_ABCMeta_idx",          operator.contains, [ABCMeta.__dict__,                            "__index__"], false]
    - ["comb_function_type_flr",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__floor__"], false]
    - ["comb_function_type_ceil",   operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__ceil__"],  false]
    - ["comb_function_type_idx",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__index__"], false]
    - ["comb_ABC_dict_flr2",        operator.contains, [ABC.__class__.__dict__,                      "__floor__"], false]
    - ["comb_ABC_dict_ceil2",       operator.contains, [ABC.__class__.__dict__,                      "__ceil__"],  false]
    - ["comb_ABC_dict_idx2",        operator.contains, [ABC.__class__.__dict__,                      "__index__"], false]
    - ["comb_ABCMeta_dict_flr2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__floor__"], false]
    - ["comb_ABCMeta_dict_ceil2",   operator.contains, [ABCMeta.__class__.__dict__,                  "__ceil__"],  false]
    - ["comb_ABCMeta_dict_idx2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__index__"], false]
    - ["comb_object_flr",           operator.contains, [object.__dict__,                             "__floor__"], false]
    - ["comb_object_ceil",          operator.contains, [object.__dict__,                             "__ceil__"],  false]
    - ["comb_object_idx",           operator.contains, [object.__dict__,                             "__index__"], false]
    - ["comb_type_flr",             operator.contains, [type.__dict__,                               "__floor__"], false]
    - ["comb_type_ceil",            operator.contains, [type.__dict__,                               "__ceil__"],  false]
    - ["comb_type_idx",             operator.contains, [type.__dict__,                               "__index__"], false]
    - ["comb_abstractmethod_flr",   operator.contains, [abstractmethod.__class__.__dict__,           "__floor__"], false]
    - ["comb_abstractmethod_ceil",  operator.contains, [abstractmethod.__class__.__dict__,           "__ceil__"],  false]
    - ["comb_abstractmethod_idx",   operator.contains, [abstractmethod.__class__.__dict__,           "__index__"], false]
