spec: statistics_extra4
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl, statistics_extra.zspec.zsdl, statistics_extra2.zspec.zsdl, and statistics_extra3.zspec.zsdl."
    - "Focus: __qualname__ attributes for statistics functions and the StatisticsError class; __module__ for mean."
    - "statistics.mean.__qualname__ == 'mean' — function qualname at module level equals simple name."
    - "statistics.median.__qualname__ == 'median'."
    - "statistics.mode.__qualname__ == 'mode'."
    - "statistics.stdev.__qualname__ == 'stdev'."
    - "statistics.variance.__qualname__ == 'variance'."
    - "statistics.pstdev.__qualname__ == 'pstdev'."
    - "statistics.pvariance.__qualname__ == 'pvariance'."
    - "statistics.fmean.__qualname__ == 'fmean'."
    - "statistics.geometric_mean.__qualname__ == 'geometric_mean'."
    - "statistics.harmonic_mean.__qualname__ == 'harmonic_mean'."
    - "statistics.median_low.__qualname__ == 'median_low'."
    - "statistics.median_high.__qualname__ == 'median_high'."
    - "statistics.StatisticsError.__qualname__ == 'StatisticsError'."
    - "statistics.mean.__module__ == 'statistics' — mean is defined in the statistics module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for statistics functions
# ---------------------------------------------------------------------------

table statistics_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [mean,          mean.__qualname__.__eq__,          ["mean"],          true]
    - [median,        median.__qualname__.__eq__,        ["median"],        true]
    - [mode,          mode.__qualname__.__eq__,          ["mode"],          true]
    - [stdev,         stdev.__qualname__.__eq__,         ["stdev"],         true]
    - [variance,      variance.__qualname__.__eq__,      ["variance"],      true]
    - [pstdev,        pstdev.__qualname__.__eq__,        ["pstdev"],        true]
    - [pvariance,     pvariance.__qualname__.__eq__,     ["pvariance"],     true]
    - [fmean,         fmean.__qualname__.__eq__,         ["fmean"],         true]
    - [geometric_mean, geometric_mean.__qualname__.__eq__, ["geometric_mean"], true]
    - [harmonic_mean, harmonic_mean.__qualname__.__eq__, ["harmonic_mean"], true]
    - [median_low,    median_low.__qualname__.__eq__,    ["median_low"],    true]
    - [median_high,   median_high.__qualname__.__eq__,   ["median_high"],   true]

# ---------------------------------------------------------------------------
# __qualname__ check for StatisticsError
# ---------------------------------------------------------------------------

invariant statistics_extra4.StatisticsError.qualname:
  description: "statistics.StatisticsError.__qualname__ == 'StatisticsError'"
  category: qualnames
  kind: python_call_eq
  function: StatisticsError.__qualname__.__eq__
  args: ["StatisticsError"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ check for mean
# ---------------------------------------------------------------------------

invariant statistics_extra4.mean.module:
  description: "statistics.mean.__module__ == 'statistics'"
  category: module
  kind: python_call_eq
  function: mean.__module__.__eq__
  args: ["statistics"]
  expected: true
