spec: statistics_extra4
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends prior statistics specs."
    - "Focus: __module__ and __name__ attributes for statistics functions; additional value-correctness invariants."
    - "statistics.fmean([1, 2, 3]) == 2.0 — fast floating-point mean."
    - "statistics.geometric_mean([1, 4, 16]) == 4.0 — geometric mean."
    - "statistics.harmonic_mean([1, 2, 4]) == 12/7 — harmonic mean."
    - "statistics.variance([2, 4, 4, 4, 5, 5, 7, 9]) == 4.571428571428571."
    - "statistics.stdev([2, 4, 4, 4, 5, 5, 7, 9]) == 2.138089935325932 (approx)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table statistics_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [fmean,          fmean.__name__.__eq__,          ["fmean"],          true]
    - [geometric_mean, geometric_mean.__name__.__eq__, ["geometric_mean"], true]
    - [harmonic_mean,  harmonic_mean.__name__.__eq__,  ["harmonic_mean"],  true]
    - [variance,       variance.__name__.__eq__,       ["variance"],       true]
    - [stdev,          stdev.__name__.__eq__,          ["stdev"],          true]
    - [pvariance,      pvariance.__name__.__eq__,      ["pvariance"],      true]
    - [pstdev,         pstdev.__name__.__eq__,         ["pstdev"],         true]

table statistics_extra4.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [fmean,          fmean.__module__.__eq__,          ["statistics"], true]
    - [geometric_mean, geometric_mean.__module__.__eq__, ["statistics"], true]
    - [harmonic_mean,  harmonic_mean.__module__.__eq__,  ["statistics"], true]
    - [variance,       variance.__module__.__eq__,       ["statistics"], true]
    - [stdev,          stdev.__module__.__eq__,          ["statistics"], true]

invariant statistics_extra4.fmean.three_values:
  description: "statistics.fmean([1, 2, 3]) == 2.0"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[1, 2, 3]]
  expected: 2.0

invariant statistics_extra4.fmean.single:
  description: "statistics.fmean([5]) == 5.0"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[5]]
  expected: 5.0

invariant statistics_extra4.geometric_mean.three_powers:
  description: "statistics.geometric_mean([1, 4, 16]) == 4.0"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[1, 4, 16]]
  expected: 4.0

invariant statistics_extra4.variance.known_dataset:
  description: "statistics.variance([2, 4, 4, 4, 5, 5, 7, 9]) == 4.571428571428571"
  category: variance
  kind: python_call_eq
  function: variance
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 4.571428571428571

invariant statistics_extra4.pvariance.known_dataset:
  description: "statistics.pvariance([2, 4, 4, 4, 5, 5, 7, 9]) == 4.0 — population variance"
  category: pvariance
  kind: python_call_eq
  function: pvariance
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 4.0

invariant statistics_extra4.median.even_count:
  description: "statistics.median([1, 2, 3, 4]) == 2.5"
  category: median
  kind: python_call_eq
  function: median
  args: [[1, 2, 3, 4]]
  expected: 2.5

invariant statistics_extra4.median_low.even_count:
  description: "statistics.median_low([1, 2, 3, 4]) == 2"
  category: median
  kind: python_call_eq
  function: median_low
  args: [[1, 2, 3, 4]]
  expected: 2

invariant statistics_extra4.median_high.even_count:
  description: "statistics.median_high([1, 2, 3, 4]) == 3"
  category: median
  kind: python_call_eq
  function: median_high
  args: [[1, 2, 3, 4]]
  expected: 3

invariant statistics_extra4.StatisticsError.class_name:
  description: "statistics.StatisticsError.__name__ == 'StatisticsError'"
  category: exceptions
  kind: python_call_eq
  function: StatisticsError.__name__.__eq__
  args: ["StatisticsError"]
  expected: true

invariant statistics_extra4.StatisticsError.base:
  description: "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError'"
  category: exceptions
  kind: python_call_eq
  function: StatisticsError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"
