spec: rlcompleter_extra2
version: ">=3.9"
backend: python_module(rlcompleter)

docs: https://docs.python.org/3/library/rlcompleter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/rlcompleter.html — Python rlcompleter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/rlcompleter.py"
  notes:
    - "Extends rlcompleter.zspec.zsdl and rlcompleter_extra.zspec.zsdl."
    - "rlcompleter (base) covers: Completer.__name__/__module__, complete/__name__/global_matches/__name__/attr_matches/__name__, Completer().complete('str',0)=='str(', complete('str',1)==None, global_matches returns list, global_matches('str') nonempty, Completer instantiable."
    - "rlcompleter_extra covers: Completer.__name__/__module__, __bases__[0].__name__=='object', __bases__.__len__()==1, complete/global_matches/attr_matches __name__ and is_function, module.__name__, Completer.__init__.__name__."
    - "This spec adds: Completer is a type object, Completer.__qualname__, method __qualname__ attrs, Completer().complete('int',0)=='int(' (new prefix), Completer with custom namespace returns matching name, get_class_members.__name__/__module__, complete method returns str at state 0 for 'print'."
    - "rlcompleter.Completer.__qualname__ == 'Completer' — top-level class, qualname equals name."
    - "rlcompleter.Completer.complete.__qualname__ == 'Completer.complete'."
    - "rlcompleter.get_class_members is a module-level helper function."
    - "Completer({'myvar': 42}).complete('myv', 0) == 'myvar' — namespace-scoped completion without appended paren (myvar is not callable)."
    - "Completer().complete('int', 0) == 'int(' — 'int' is a builtin callable, paren appended."
    - "Completer().complete('print', 0) == 'print(' — 'print' is a builtin callable."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Completer is a type object
# Not covered in rlcompleter or rlcompleter_extra.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra2.Completer.is_type:
  description: "type(rlcompleter.Completer).__name__ == 'type' — Completer is a class object"
  category: class_types
  kind: python_call_eq
  function: Completer.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ — Completer class and its three public methods
# Neither prior spec checks __qualname__ for rlcompleter symbols.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra2.Completer.qualname:
  description: "rlcompleter.Completer.__qualname__ == 'Completer'"
  category: qualnames
  kind: python_call_eq
  function: Completer.__qualname__.__eq__
  args: ["Completer"]
  expected: true

table rlcompleter_extra2.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [complete,       Completer.complete.__qualname__.__eq__,       ["Completer.complete"],       true]
    - [global_matches, Completer.global_matches.__qualname__.__eq__, ["Completer.global_matches"], true]
    - [attr_matches,   Completer.attr_matches.__qualname__.__eq__,   ["Completer.attr_matches"],   true]

# ---------------------------------------------------------------------------
# get_class_members — module-level helper function
# Not covered in any prior rlcompleter spec.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra2.get_class_members.name:
  description: "rlcompleter.get_class_members.__name__ == 'get_class_members'"
  category: module_functions
  kind: python_call_eq
  function: get_class_members.__name__.__eq__
  args: ["get_class_members"]
  expected: true

invariant rlcompleter_extra2.get_class_members.module:
  description: "rlcompleter.get_class_members.__module__ == 'rlcompleter'"
  category: module_functions
  kind: python_call_eq
  function: get_class_members.__module__.__eq__
  args: ["rlcompleter"]
  expected: true

invariant rlcompleter_extra2.get_class_members.is_function:
  description: "type(rlcompleter.get_class_members).__name__ == 'function'"
  category: module_functions
  kind: python_call_eq
  function: get_class_members.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — Completer().complete() with builtin callables
# Base spec covers 'str'; this spec adds 'int' and 'print' as new prefixes.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra2.complete.int_state0:
  description: "Completer().complete('int', 0) == 'int(' — 'int' is a builtin callable, paren appended"
  category: complete
  kind: python_call_eq
  function: Completer
  args: []
  method: complete
  method_args: ["int", 0]
  expected: "int("

invariant rlcompleter_extra2.complete.print_state0:
  description: "Completer().complete('print', 0) == 'print(' — 'print' is a builtin callable"
  category: complete
  kind: python_call_eq
  function: Completer
  args: []
  method: complete
  method_args: ["print", 0]
  expected: "print("

invariant rlcompleter_extra2.complete.int_state1:
  description: "Completer().complete('int', 1) == None — no second completion for bare 'int'"
  category: complete
  kind: python_call_eq
  function: Completer
  args: []
  method: complete
  method_args: ["int", 1]
  expected: null

# ---------------------------------------------------------------------------
# Behavioral — Completer with custom namespace
# Neither prior spec tests the optional namespace constructor argument.
# Completer({'myvar': 42}).complete('myv', 0) returns 'myvar' (not callable,
# so no paren is appended).
# ---------------------------------------------------------------------------

invariant rlcompleter_extra2.complete.namespace_match:
  description: "Completer({'myvar': 42}).complete('myv', 0) == 'myvar' — custom namespace completion without paren"
  category: complete
  kind: python_call_eq
  function: Completer
  args: [{"myvar": 42}]
  method: complete
  method_args: ["myv", 0]
  expected: "myvar"

invariant rlcompleter_extra2.complete.namespace_state1:
  description: "Completer({'myvar': 42}).complete('myv', 1) == None — no second match for unique prefix"
  category: complete
  kind: python_call_eq
  function: Completer
  args: [{"myvar": 42}]
  method: complete
  method_args: ["myv", 1]
  expected: null
