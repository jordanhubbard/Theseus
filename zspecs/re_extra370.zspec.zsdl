spec: re_extra370
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All re module top-level functions (compile, match, search, fullmatch, findall, finditer, sub, subn, split) report __module__ == 're'"
    - "Each function's __name__ matches its Python-level name exactly"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __name__ identity
# ---------------------------------------------------------------------------

table re_extra370.function_names:
  description: "re module function __name__ identity — compile, match, search, fullmatch, findall, finditer, sub, subn, split; each function's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: refnname370

  columns: [id, function, args, expected]
  rows:
    - [compile_name,   re.compile.__name__.__eq__,   ["compile"],   true]
    - [match_name,     re.match.__name__.__eq__,     ["match"],     true]
    - [search_name,    re.search.__name__.__eq__,    ["search"],    true]
    - [fullmatch_name, re.fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [findall_name,   re.findall.__name__.__eq__,   ["findall"],   true]
    - [finditer_name,  re.finditer.__name__.__eq__,  ["finditer"],  true]
    - [sub_name,       re.sub.__name__.__eq__,       ["sub"],       true]
    - [subn_name,      re.subn.__name__.__eq__,      ["subn"],      true]
    - [split_name,     re.split.__name__.__eq__,     ["split"],     true]

# ---------------------------------------------------------------------------
# re module function __module__ identity
# ---------------------------------------------------------------------------

table re_extra370.function_modules:
  description: "re module function __module__ identity — compile, match, search, fullmatch, findall, finditer, sub, subn, split all report __module__ == 're'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: refnmod370

  columns: [id, function, args, expected]
  rows:
    - [compile_module,   re.compile.__module__.__eq__,   ["re"], true]
    - [match_module,     re.match.__module__.__eq__,     ["re"], true]
    - [search_module,    re.search.__module__.__eq__,    ["re"], true]
    - [fullmatch_module, re.fullmatch.__module__.__eq__, ["re"], true]
    - [findall_module,   re.findall.__module__.__eq__,   ["re"], true]
    - [finditer_module,  re.finditer.__module__.__eq__,  ["re"], true]
    - [sub_module,       re.sub.__module__.__eq__,       ["re"], true]
    - [subn_module,      re.subn.__module__.__eq__,      ["re"], true]
    - [split_module,     re.split.__module__.__eq__,     ["re"], true]
