spec: uuid_extra142
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra141.zspec.zsdl — covers uuid.__dict__.__contains__('UUID'/'uuid1'/'uuid3'/'uuid4'/'uuid5'/'NAMESPACE_DNS'/'NAMESPACE_URL') / uuid.__dict__.__len__()==75 / uuid.__dict__.__class__.__name__.__eq__('dict') (table + invariants)."
    - "uuid_extra140.zspec.zsdl — covers uuid.UUID.__setattr__/__qualname__.__eq__('UUID.__setattr__') (len 16) / UUID.__getstate__/__qualname__.__eq__('UUID.__getstate__') (len 17) / UUID.__setstate__/__qualname__.__eq__('UUID.__setstate__') (len 17) / all three __class__.__name__.__eq__('function') (table + invariants)."
    - "uuid_extra139.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('urn'/'bytes_le'/'node'/'fields'/'__str__'/'__repr__'/'__hash__'/'variant') / UUID.__dict__.__len__()==37 / UUID.__doc__.__len__()==2787 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__package__.__eq__('') (table + invariants)."
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') (all four namespace constants) / NAMESPACE_DNS.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid_extra137.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('hex'/'int'/'bytes'/'version'/__slots__/__init__) / UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__spec__.name.__eq__('uuid') / uuid.__doc__.__len__()==1948 (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra141."
    - "Wave 330 theme: uuid.SafeUUID class namespace — SafeUUID.__dict__.__len__()==19 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / SafeUUID.__dict__.__contains__('safe') / SafeUUID.__dict__.__contains__('unsafe') / SafeUUID.__dict__.__contains__('unknown') / SafeUUID.__dict__.__contains__('_member_names_'). Also uuid.UUID.__dict__.__contains__('__setattr__')==True and uuid.UUID.__dict__.__contains__('is_safe')==True."
    - "uuid.SafeUUID.__dict__.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__contains__('safe') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__contains__('unsafe') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__contains__('unknown') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__contains__('_member_names_') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__setattr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('is_safe') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.SafeUUID.__dict__.__len__() == 19. SafeUUID is an IntEnum subclass with three members: safe (value 0), unsafe (value -1), and unknown (value -2). The 19-entry class dict includes the three member entries plus Enum infrastructure attributes: _member_names_, _value2member_map_, _generate_next_value_, _missing_, _member_map_, _member_type_, _new_member_, _use_args_, _unhashable_values_, _hashable_values_, _unhashable_values_map_, _value_repr_, and standard dunders (__doc__, __module__, __new__, __firstlineno__, __static_attributes__). The SafeUUID dict (19) is smaller than UUID.__dict__ (37) and larger than struct.error.__dict__ (3)."
    - "Note: uuid.UUID.__dict__.__contains__('__setattr__') == True. UUID defines a custom __setattr__ as a Python-level function to enforce immutability — any attempt to set an attribute on a UUID instance after creation raises TypeError. This is a key design feature: UUID objects are immutable (like tuples), using __setattr__ overriding rather than relying solely on __slots__. extra140 anchors UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') (16 chars) and __class__.__name__ == 'function'; this spec anchors UUID.__dict__.__contains__('__setattr__')."
    - "Note: uuid.UUID.__dict__.__contains__('is_safe') == True. 'is_safe' is a slot descriptor (member_descriptor) in UUID.__dict__ that stores the SafeUUID enum value indicating whether the UUID was generated using a platform-safe method (e.g., os.urandom) or not. It was added in Python 3.7 as part of the RFC 4122 update. UUID objects that predate Python 3.7 or are created without specifying is_safe will have is_safe == SafeUUID.unknown."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__len__()==19
# uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy')
# uuid.SafeUUID.__dict__.__contains__('safe')
# uuid.SafeUUID.__dict__.__contains__('unsafe')
#
# Wave 330 theme: SafeUUID class namespace size and type.
#
# SafeUUID is an IntEnum with three members (safe/unsafe/unknown). Its 19-entry class
# dict includes the three members plus Enum infrastructure attributes. extra95 anchors
# SafeUUID member values and __bases__[0].__name__; extra139 anchors
# SafeUUID.__dict__.__class__.__name__=='mappingproxy' as a standalone; no prior uuid
# spec anchors SafeUUID.__dict__.__len__()==19 or __contains__('safe'/'unsafe') as a
# table under uuidsafe142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra142.SafeUUID_dict_size_and_members:
  description: "uuid.SafeUUID.__dict__.__len__()==19 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy')==True / SafeUUID.__dict__.__contains__('safe')==True / SafeUUID.__dict__.__contains__('unsafe')==True — SafeUUID is an IntEnum with three members; 19-entry dict: 3 member entries + Enum infrastructure + dunders; SafeUUID(19) < UUID(37); mappingproxy (12 chars) as all class dicts; extra95 anchors member values; extra139 anchors SafeUUID dict class name; first uuidsafe142 anchor for SafeUUID dict len and safe/unsafe membership"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafe142

  columns: [id, function, args, expected, description]
  rows:
    - [SafeUUID_dict_len_19,      "SafeUUID.__dict__.__len__",                    [],              19,   "uuid.SafeUUID.__dict__.__len__() is 19 (3 enum members + Enum infrastructure + dunders)"]
    - [SafeUUID_dict_mappingproxy, "SafeUUID.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy' (12 chars; class dict is read-only proxy)"]
    - [SafeUUID_dict_safe,        "SafeUUID.__dict__.__contains__",               ["safe"],         true, "uuid.SafeUUID.__dict__.__contains__('safe') == True (enum member; value 0; UUID was generated safely)"]
    - [SafeUUID_dict_unsafe,      "SafeUUID.__dict__.__contains__",               ["unsafe"],       true, "uuid.SafeUUID.__dict__.__contains__('unsafe') == True (enum member; value -1; UUID was not safely generated)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__contains__('unknown')
# uuid.SafeUUID.__dict__.__contains__('_member_names_')
# uuid.UUID.__dict__.__contains__('__setattr__')
# uuid.UUID.__dict__.__contains__('is_safe')
#
# Wave 330 theme: SafeUUID unknown member and UUID immutability/safety attributes.
#
# SafeUUID.unknown is the third enum member (value -2), used when it is unknown whether
# the UUID was safely generated. _member_names_ is a standard Enum infrastructure attribute.
# UUID.__dict__.__contains__('__setattr__') is True (UUID defines __setattr__ to enforce
# immutability). UUID.__dict__.__contains__('is_safe') is True ('is_safe' stores the
# SafeUUID enum value on each UUID instance). No prior uuid spec anchors these four
# as a table under uuidsafe142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra142.SafeUUID_unknown_and_UUID_immutability:
  description: "uuid.SafeUUID.__dict__.__contains__('unknown')==True / SafeUUID.__dict__.__contains__('_member_names_')==True / uuid.UUID.__dict__.__contains__('__setattr__')==True / UUID.__dict__.__contains__('is_safe')==True — SafeUUID.unknown is the third member (value -2; safety unknown); _member_names_ is Enum infrastructure; UUID.__setattr__ enforces immutability (raises TypeError on assignment); is_safe stores SafeUUID value per UUID; extra140 anchors UUID.__setattr__ qualname; first uuidsafe142 anchor for these four"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafe142

  columns: [id, function, args, expected, description]
  rows:
    - [SafeUUID_dict_unknown,      "SafeUUID.__dict__.__contains__",  ["unknown"],       true, "uuid.SafeUUID.__dict__.__contains__('unknown') == True (third SafeUUID member; value -2; safety status unknown)"]
    - [SafeUUID_dict_member_names, "SafeUUID.__dict__.__contains__",  ["_member_names_"], true, "uuid.SafeUUID.__dict__.__contains__('_member_names_') == True (Enum infrastructure; list of member name strings)"]
    - [UUID_dict_setattr,          "UUID.__dict__.__contains__",      ["__setattr__"],   true, "uuid.UUID.__dict__.__contains__('__setattr__') == True (Python function; raises TypeError to enforce UUID immutability)"]
    - [UUID_dict_is_safe,          "UUID.__dict__.__contains__",      ["is_safe"],       true, "uuid.UUID.__dict__.__contains__('is_safe') == True (member_descriptor slot; stores SafeUUID enum value per instance)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__len__()==19
# uuid.UUID.__dict__.__len__()==37
# uuid.__dict__.__len__()==75
#
# Wave 330 theme: three uuid dict sizes in ascending order.
#
# The three uuid namespace sizes are SafeUUID(19) < UUID(37) < module(75). SafeUUID
# is the smallest because it is a compact enum with only 3 members. UUID is mid-sized
# because it has 37 entries including slots, properties, comparison operators, and
# pickling support. The module dict (75) is the largest. extra139 anchors
# UUID.__dict__.__len__()==37; extra141 anchors uuid.__dict__.__len__()==75; no prior
# uuid spec anchors the three-way size comparison as a table under uuidsafe142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra142.uuid_dict_sizes_three_way:
  description: "uuid.SafeUUID.__dict__.__len__()==19 / uuid.UUID.__dict__.__len__()==37 / uuid.__dict__.__len__()==75 — three-way size ordering: SafeUUID(19) < UUID(37) < module(75); SafeUUID compact (3 members + Enum infra); UUID mid-sized (slots + properties + operators + pickling); module largest (classes + functions + constants + metadata + internals); extra139 anchors UUID len; extra141 anchors module len; first uuidsafe142 anchor for the three-way table"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafe142

  columns: [id, function, args, expected, description]
  rows:
    - [SafeUUID_dict_len_19,  "SafeUUID.__dict__.__len__", [], 19, "uuid.SafeUUID.__dict__.__len__() is 19 (smallest uuid class dict; 3 members + Enum infrastructure)"]
    - [UUID_dict_len_37,      "UUID.__dict__.__len__",     [], 37, "uuid.UUID.__dict__.__len__() is 37 (mid-sized; slots + properties + operators + pickling support)"]
    - [module_dict_len_75,    "__dict__.__len__",          [], 75, "uuid.__dict__.__len__() is 75 (largest; classes + generators + NAMESPACE_* constants + internals + metadata)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__len__()==19 — standalone
#
# uuid.SafeUUID.__dict__.__len__() is 19. SafeUUID is an IntEnum subclass with three
# members: safe (0), unsafe (-1), unknown (-2). The 19-entry class dict includes the
# 3 member entries and 16 Enum/IntEnum infrastructure attributes: _member_names_,
# _value2member_map_, _generate_next_value_, _missing_, _member_map_, _member_type_,
# _new_member_, _use_args_, _unhashable_values_, _hashable_values_,
# _unhashable_values_map_, _value_repr_, and standard dunders (__doc__, __module__,
# __new__, __firstlineno__, __static_attributes__). extra95 anchors SafeUUID member
# values; no prior uuid spec anchors SafeUUID.__dict__.__len__()==19 as a standalone
# under uuidsafe142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra142.SafeUUID_dict_len_19:
  description: "uuid.SafeUUID.__dict__.__len__() == 19 — 3 enum members (safe/unsafe/unknown) + 16 Enum infrastructure entries (_member_names_/_value2member_map_/_generate_next_value_/_missing_/_member_map_/_member_type_/_new_member_/_use_args_/_unhashable_values_/_hashable_values_/_unhashable_values_map_/_value_repr_/__doc__/__module__/__new__/__firstlineno__/__static_attributes__); SafeUUID(19) < UUID(37) < module(75); extra95 anchors member values; no prior uuid spec anchors this as a standalone; first standalone under uuidsafe142"
  category: identity
  kind: python_call_eq
  function: "SafeUUID.__dict__.__len__"
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__contains__('safe') — standalone
#
# uuid.SafeUUID.__dict__.__contains__('safe') is True. SafeUUID.safe is the IntEnum
# member with value 0, indicating that the UUID was generated using a platform-safe
# method (such as os.urandom or the operating system's UUID generation facility). A
# UUID with is_safe == SafeUUID.safe guarantees that no two processes can generate
# the same UUID at the same time, even in multi-processing environments. extra95 anchors
# SafeUUID.safe.value == 0; no prior uuid spec anchors SafeUUID.__dict__.__contains__
# ('safe') as a standalone under uuidsafe142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra142.SafeUUID_dict_contains_safe:
  description: "uuid.SafeUUID.__dict__.__contains__('safe') == True — SafeUUID.safe is the enum member with value 0; indicates UUID generated via platform-safe method (os.urandom/OS facility); guarantees no two processes generate the same UUID simultaneously; extra95 anchors value==0; no prior uuid spec anchors this as a standalone; first standalone under uuidsafe142"
  category: identity
  kind: python_call_eq
  function: "SafeUUID.__dict__.__contains__"
  args: ["safe"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__setattr__') — standalone
#
# uuid.UUID.__dict__.__contains__('__setattr__') is True. UUID defines its own
# __setattr__ as a Python-level function that always raises TypeError, preventing any
# attribute from being set on a UUID instance after creation. This is part of UUID's
# immutability design: UUIDs use __slots__ to restrict what attributes exist, and
# __setattr__ to prevent modification of those slots after initialization. The immutability
# makes UUIDs safe to use as dictionary keys and set members. extra140 anchors
# UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') (16 chars) and
# __class__.__name__ == 'function'; no prior uuid spec anchors
# UUID.__dict__.__contains__('__setattr__') as a standalone under uuidsafe142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra142.UUID_dict_contains_setattr:
  description: "uuid.UUID.__dict__.__contains__('__setattr__') == True — UUID defines __setattr__ as a Python function that raises TypeError; enforces immutability (no attribute modification after creation); complements __slots__ (restricts attributes); makes UUID safe as dict keys/set members; extra140 anchors qualname 'UUID.__setattr__' (16 chars) and class 'function'; no prior uuid spec anchors this as a standalone; first standalone under uuidsafe142"
  category: identity
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('is_safe') — standalone
#
# uuid.UUID.__dict__.__contains__('is_safe') is True. 'is_safe' is a member_descriptor
# (slot descriptor) in UUID.__dict__ that stores a SafeUUID enum value on each UUID
# instance. The is_safe attribute was added in Python 3.7 as part of PEP 8 compliance
# for RFC 4122 updates, providing a way to indicate whether a UUID was generated using
# a platform-safe method. Typical values are SafeUUID.safe (0), SafeUUID.unsafe (-1),
# or SafeUUID.unknown (-2). extra137 anchors UUID.__dict__.__contains__('__slots__')
# and '__init__'; no prior uuid spec anchors UUID.__dict__.__contains__('is_safe')
# as a standalone under uuidsafe142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra142.UUID_dict_contains_is_safe:
  description: "uuid.UUID.__dict__.__contains__('is_safe') == True — member_descriptor slot; stores SafeUUID enum value per UUID instance; added Python 3.7 (RFC 4122 update); values: SafeUUID.safe(0)/unsafe(-1)/unknown(-2); extra95 anchors SafeUUID member values; extra137 anchors UUID __slots__ and __init__ dict membership; no prior uuid spec anchors this as a standalone; first standalone under uuidsafe142"
  category: identity
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["is_safe"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__contains__('unknown') — standalone
#
# uuid.SafeUUID.__dict__.__contains__('unknown') is True. SafeUUID.unknown is the
# third SafeUUID member, with value -2. It indicates that the safety of the UUID
# generation method is unknown — for example, when a UUID is created from an integer,
# bytes, or string value rather than being freshly generated by uuid1()/uuid4(). All
# UUID instances created by the uuid module from raw data (rather than generated) will
# have is_safe == SafeUUID.unknown. No prior uuid spec anchors
# SafeUUID.__dict__.__contains__('unknown') as a standalone under uuidsafe142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra142.SafeUUID_dict_contains_unknown:
  description: "uuid.SafeUUID.__dict__.__contains__('unknown') == True — third SafeUUID member; value -2; indicates unknown generation safety; UUIDs created from raw data (int/bytes/str) get is_safe==SafeUUID.unknown; the three members by value: unsafe(-1) < unknown(-2)? no: safe(0) > unknown(-2)? values: safe=0/unsafe=-1/unknown=-2; extra95 anchors safe.value==0 and unsafe.value==-1; no prior uuid spec anchors this as a standalone; first standalone under uuidsafe142"
  category: identity
  kind: python_call_eq
  function: "SafeUUID.__dict__.__contains__"
  args: ["unknown"]
  expected: true
