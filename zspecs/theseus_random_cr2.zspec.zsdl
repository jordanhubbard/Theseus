spec: theseus_random_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_random_cr2)
blocks: random

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html"
    - "https://en.wikipedia.org/wiki/Box%E2%80%93Muller_transform"
  notes:
    - "Clean-room extended random utilities. Do NOT import random or secrets."
    - "May use os.urandom or time.time_ns for seeding only."
    - "uniform(a, b): return float in [a, b]; uniform(0, 1) is in [0.0, 1.0]."
    - "gauss(mu, sigma): Gaussian deviate via Box-Muller transform; returns float."
    - "randrange(stop): integer in [0, stop); randrange(10) is in range(10)."
    - "random2_uniform(): 0.0 <= uniform(0, 1) <= 1.0 — returns True."
    - "random2_randrange(): randrange(10) in range(10) — returns True."
    - "random2_gauss_type(): isinstance(gauss(0, 1), float) — returns True."
    - "Zero-arg invariant signatures — def random2_uniform(): return bool"
    - "Export: uniform(a, b) -> float, gauss(mu, sigma) -> float, randrange(stop) -> int."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_random_cr2.uniform:
  description: "uniform(0, 1) is in [0.0, 1.0]"
  category: uniform
  kind: python_call_eq
  function: random2_uniform
  args: []
  expected: true

invariant theseus_random_cr2.randrange:
  description: "randrange(10) is in range(10)"
  category: randrange
  kind: python_call_eq
  function: random2_randrange
  args: []
  expected: true

invariant theseus_random_cr2.gauss_type:
  description: "gauss(0, 1) returns a float"
  category: gauss
  kind: python_call_eq
  function: random2_gauss_type
  args: []
  expected: true
