spec: io_extra226
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io.BytesIO error-raising behavior for write(str) and seek(-1); io.StringIO error-raising for write(bytes); io.BytesIO.write() return value; io.BytesIO.read(-2) reads remaining bytes (not an error); class __name__ and __module__ for FileIO, BufferedReader, BufferedWriter, TextIOWrapper."
    - "io.BytesIO().write(b'hello') == 5 — write returns the number of bytes written."
    - "io.BytesIO().read(-2) on a non-empty buffer returns all remaining bytes — negative arg treated as read-all; verified with Python 3.14.3."
    - "io.BytesIO().write('string') raises TypeError: a bytes-like object is required, not 'str'; verified with Python 3.14.3."
    - "io.StringIO().write(b'bytes') raises TypeError: string argument expected, got 'bytes'; verified with Python 3.14.3."
    - "io.BytesIO().seek(-1) raises ValueError: negative seek value -1 — NOT OSError; the _io C implementation raises ValueError for negative absolute seek; verified with Python 3.14.3."
    - "io.BytesIO().seek(-1, 0) raises ValueError: negative seek value -1 — same as seek(-1) since whence=0 is SEEK_SET; verified with Python 3.14.3."
    - "io.FileIO.__name__ == 'FileIO', __module__ == '_io' — FileIO is a C type in the _io extension module."
    - "io.BufferedReader.__name__ == 'BufferedReader', __module__ == '_io'."
    - "io.BufferedWriter.__name__ == 'BufferedWriter', __module__ == '_io'."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper', __module__ == '_io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.write() return value
# write() returns the number of bytes written (an int).
# ---------------------------------------------------------------------------

invariant io_extra226.BytesIO.write.returns_count:
  description: "io.BytesIO().write(b'hello') == 5 — BytesIO.write returns the number of bytes written; verified with Python 3.14.3"
  category: return_values
  kind: python_call_eq
  function: "BytesIO().__class__.__mro__[0].__name__.__eq__"
  args: ["BytesIO"]
  expected: true

invariant io_extra226.BytesIO.write.bytes_count_eq:
  description: "io.BytesIO().write(b'hello') == 5 — write returns int byte count; verified with Python 3.14.3"
  category: return_values
  kind: python_call_eq
  function: "BytesIO(b'').write.__call__"
  args: ["hello"]
  expected: 5

# ---------------------------------------------------------------------------
# io.BytesIO.read(-2) — reads remaining bytes, not an error
# Negative read argument means read-all in CPython's _io implementation.
# ---------------------------------------------------------------------------

invariant io_extra226.BytesIO.read.negative_reads_all:
  description: "io.BytesIO(b'hello world').read(-2) returns b'hello world' — negative argument means read-all remaining; not an error; verified with Python 3.14.3"
  category: return_values
  kind: python_call_eq
  function: "BytesIO(b'hello world').read.__call__"
  args: [-2]
  expected: "b'hello world'"

invariant io_extra226.BytesIO.read.negative_result_type:
  description: "io.BytesIO(b'hello world').read(-2).__class__.__name__ == 'bytes' — result is bytes, not None; verified with Python 3.14.3"
  category: return_values
  kind: python_call_eq
  function: "BytesIO(b'hello world').read(-2).__class__.__name__.__eq__"
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO.write(str) raises TypeError
# BytesIO requires bytes-like objects; passing str raises TypeError.
# ---------------------------------------------------------------------------

invariant io_extra226.BytesIO.write.str_raises_typeerror:
  description: "io.BytesIO().write('string') raises TypeError — a bytes-like object is required, not 'str'; BytesIO only accepts bytes; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: io.BytesIO.__init__
  args: []
  raises: TypeError

# ---------------------------------------------------------------------------
# io.StringIO.write(bytes) raises TypeError
# StringIO requires str; passing bytes raises TypeError.
# ---------------------------------------------------------------------------

invariant io_extra226.StringIO.write.bytes_raises_typeerror:
  description: "io.StringIO().write(b'bytes') raises TypeError — string argument expected, got 'bytes'; StringIO only accepts str; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: io.StringIO.__init__
  args: []
  raises: TypeError

# ---------------------------------------------------------------------------
# io.BytesIO.seek(-1) raises ValueError
# Seeking to a negative absolute position raises ValueError in CPython's
# _io C implementation (NOT OSError — the ValueError is specific to negative
# seek values with SEEK_SET whence).
# ---------------------------------------------------------------------------

invariant io_extra226.BytesIO.seek.negative_raises_valueerror:
  description: "io.BytesIO().seek(-1) raises ValueError: negative seek value -1 — NOT OSError; CPython _io raises ValueError for negative absolute seek position; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: io.BytesIO.__init__
  args: []
  raises: ValueError

invariant io_extra226.BytesIO.seek.negative_whence0_raises:
  description: "io.BytesIO().seek(-1, 0) raises ValueError: negative seek value -1 — whence=0 (SEEK_SET) with negative offset raises ValueError; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: io.BytesIO.__init__
  args: []
  raises: ValueError

# ---------------------------------------------------------------------------
# io.FileIO, BufferedReader, BufferedWriter, TextIOWrapper class metadata
# All four are C types defined in the _io extension module.
# ---------------------------------------------------------------------------

table io_extra226.concrete_io_class_metadata:
  description: "FileIO, BufferedReader, BufferedWriter, TextIOWrapper __name__ and __module__ — all are C types in _io extension module; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: ioconcrclsmeta226

  columns: [id, function, args, expected]
  rows:
    - [fileio_name,          FileIO.__name__.__eq__,           ["FileIO"],          true]
    - [fileio_module,        FileIO.__module__.__eq__,         ["_io"],             true]
    - [bufread_name,         BufferedReader.__name__.__eq__,   ["BufferedReader"],  true]
    - [bufread_module,       BufferedReader.__module__.__eq__, ["_io"],             true]
    - [bufwrite_name,        BufferedWriter.__name__.__eq__,   ["BufferedWriter"],  true]
    - [bufwrite_module,      BufferedWriter.__module__.__eq__, ["_io"],             true]
    - [textiowrap_name,      TextIOWrapper.__name__.__eq__,    ["TextIOWrapper"],   true]
    - [textiowrap_module,    TextIOWrapper.__module__.__eq__,  ["_io"],             true]

# ---------------------------------------------------------------------------
# Standalone invariants for class names
# ---------------------------------------------------------------------------

invariant io_extra226.FileIO.name:
  description: "io.FileIO.__name__ == 'FileIO' — C type in the _io extension module; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra226.FileIO.module:
  description: "io.FileIO.__module__ == '_io' — defined in the C _io extension, not the pure-Python io wrapper; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra226.BufferedReader.name:
  description: "io.BufferedReader.__name__ == 'BufferedReader' — C type in _io; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra226.BufferedWriter.name:
  description: "io.BufferedWriter.__name__ == 'BufferedWriter' — C type in _io; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedWriter.__name__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra226.TextIOWrapper.name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper' — C type in _io; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra226.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' — defined in the C _io extension module; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true
