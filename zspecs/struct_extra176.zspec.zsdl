spec: struct_extra176
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — pack/unpack/calcsize core vectors."
    - "struct_extra.zspec.zsdl through struct_extra175.zspec.zsdl — prior extras."
  notes:
    - "This spec covers struct.Struct class identity and compiled Struct instance size and format attributes."
    - "struct.Struct.__name__ == 'Struct' (len=6) — the class name is the 6-character string 'Struct'."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the C extension _struct, not in the Python wrapper."
    - "struct.Struct.__qualname__ == 'Struct' — Struct is a top-level class; qualname equals name."
    - "struct.Struct('i').size == 4 — format 'i' is one native 32-bit signed int; 4 bytes."
    - "struct.Struct('i').format == 'i' — the format attribute reflects the format string passed to the constructor."
    - "struct.Struct('2i').size == 8 — format '2i' is two native 32-bit signed ints; 2*4 = 8 bytes."
    - "struct.Struct('2i').format == '2i' — the format attribute is '2i' as passed."
    - "struct.Struct('4B').size == 4 — format '4B' is four unsigned chars; 4*1 = 4 bytes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct class identity — __name__, __module__, __qualname__
#
# struct.Struct.__name__     == 'Struct'   (len=6)
# struct.Struct.__module__   == '_struct'  (C extension, not the Python wrapper)
# struct.Struct.__qualname__ == 'Struct'
#
# struct.Struct is a compiled struct object class implemented in the C
# extension _struct. Its __module__ is '_struct', not 'struct'. The class
# name is the 6-character string 'Struct'. New to extra176.
# ---------------------------------------------------------------------------

table struct_extra176.struct_class_identity:
  description: "Struct.__name__=='Struct' (len=6); __module__=='_struct'; __qualname__=='Struct'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: structstruct176

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,
       "Struct.__name__.__eq__",
       ["Struct"],
       true,
       "struct.Struct.__name__.__eq__('Struct') == True — Struct is the compiled struct class name; __name__ is 'Struct'; str.__eq__('Struct') returns True; new to extra176"]
    - [struct_name_len_6,
       "Struct.__name__.__len__",
       [],
       6,
       "struct.Struct.__name__.__len__() == 6 — 'Struct' has 6 characters (S-t-r-u-c-t); str.__len__() returns 6; new to extra176"]
    - [struct_module_eq,
       "Struct.__module__.__eq__",
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — Struct is implemented in Modules/_struct.c; its __module__ is '_struct', not 'struct'; str.__eq__('_struct') returns True; new to extra176"]
    - [struct_qualname_eq,
       "Struct.__qualname__.__eq__",
       ["Struct"],
       true,
       "struct.Struct.__qualname__.__eq__('Struct') == True — Struct is a top-level class; its __qualname__ equals its __name__, which is 'Struct'; str.__eq__('Struct') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct('i') and struct.Struct('2i') — size and format
#
# struct.Struct('i').size   == 4   (one 32-bit signed int = 4 bytes)
# struct.Struct('i').format == 'i'
# struct.Struct('2i').size  == 8   (two 32-bit signed ints = 8 bytes)
# struct.Struct('2i').format == '2i'
#
# The format character 'i' represents a native 32-bit signed integer (4 bytes).
# A repeat count prefix (e.g. '2i') multiplies the size. The format attribute
# on a compiled Struct always reflects the string passed to the constructor.
# New to extra176.
# ---------------------------------------------------------------------------

table struct_extra176.struct_i_format_size:
  description: "Struct('i').size==4, format=='i'; Struct('2i').size==8, format=='2i'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: structstruct176

  columns: [id, function, args, expected, description]
  rows:
    - [struct_i_size_4,
       "Struct('i').size.__eq__",
       [4],
       true,
       "struct.Struct('i').size.__eq__(4) == True — format 'i' is a native 32-bit signed int; 32/8 = 4 bytes; size is an int attribute on compiled Struct objects; new to extra176"]
    - [struct_i_format_eq,
       "Struct('i').format.__eq__",
       ["i"],
       true,
       "struct.Struct('i').format.__eq__('i') == True — the format attribute reflects the format string passed to the Struct constructor; for Struct('i') the format is 'i'; new to extra176"]
    - [struct_2i_size_8,
       "Struct('2i').size.__eq__",
       [8],
       true,
       "struct.Struct('2i').size.__eq__(8) == True — format '2i' is two native 32-bit signed ints; 2 * 4 = 8 bytes; new to extra176"]
    - [struct_2i_format_eq,
       "Struct('2i').format.__eq__",
       ["2i"],
       true,
       "struct.Struct('2i').format.__eq__('2i') == True — the format attribute for Struct('2i') is '2i', exactly as passed to the constructor; new to extra176"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct('4B') — size; additional format variants
#
# struct.Struct('4B').size == 4   (four unsigned chars = 4 bytes)
# struct.Struct('4B').format == '4B'
# struct.Struct('i').size != 8   (i is 4, not 8)
#
# The format character 'B' represents an unsigned char (1 byte). '4B' means
# four consecutive unsigned chars for a total of 4 bytes. This demonstrates
# that size depends on both the character width and the repeat count.
# New to extra176.
# ---------------------------------------------------------------------------

table struct_extra176.struct_4B_format_size:
  description: "Struct('4B').size==4, format=='4B'; size is repeat*width; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: structstruct176

  columns: [id, function, args, expected, description]
  rows:
    - [struct_4B_size_4,
       "Struct('4B').size.__eq__",
       [4],
       true,
       "struct.Struct('4B').size.__eq__(4) == True — format '4B' is four unsigned chars; 'B' is 1 byte and the repeat count 4 gives 4 * 1 = 4 bytes; new to extra176"]
    - [struct_4B_format_eq,
       "Struct('4B').format.__eq__",
       ["4B"],
       true,
       "struct.Struct('4B').format.__eq__('4B') == True — the format attribute for Struct('4B') is '4B', exactly as passed to the constructor; new to extra176"]
    - [struct_i_size_not_8,
       "Struct('i').size.__eq__",
       [8],
       false,
       "struct.Struct('i').size.__eq__(8) == False — format 'i' is a single 32-bit int (4 bytes), not 8; 8 bytes would be format 'q' (64-bit long long) or '2i'; new to extra176"]
    - [struct_4B_size_not_8,
       "Struct('4B').size.__eq__",
       [8],
       false,
       "struct.Struct('4B').size.__eq__(8) == False — format '4B' is four unsigned chars (4 bytes), not 8; new to extra176"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra176
# ---------------------------------------------------------------------------

invariant struct_extra176.struct_name_eq:
  description: "struct.Struct.__name__ == 'Struct' — the compiled struct class has a 6-character name; new to extra176"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra176.struct_name_len_6:
  description: "struct.Struct.__name__.__len__() == 6 — 'Struct' has 6 characters (S-t-r-u-c-t); new to extra176"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__len__
  args: []
  expected: 6

invariant struct_extra176.struct_module_eq:
  description: "struct.Struct.__module__ == '_struct' — Struct is a C-extension class in Modules/_struct.c; new to extra176"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra176.struct_qualname_eq:
  description: "struct.Struct.__qualname__ == 'Struct' — Struct is top-level; qualname equals name; new to extra176"
  category: identity
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra176.struct_i_size_4:
  description: "struct.Struct('i').size == 4 — one native 32-bit signed int is 4 bytes; new to extra176"
  category: identity
  kind: python_call_eq
  function: "Struct('i').size.__eq__"
  args: [4]
  expected: true

invariant struct_extra176.struct_i_format_eq:
  description: "struct.Struct('i').format == 'i' — format attribute reflects the constructor argument; new to extra176"
  category: identity
  kind: python_call_eq
  function: "Struct('i').format.__eq__"
  args: ["i"]
  expected: true

invariant struct_extra176.struct_2i_size_8:
  description: "struct.Struct('2i').size == 8 — two native 32-bit ints = 2 * 4 = 8 bytes; new to extra176"
  category: identity
  kind: python_call_eq
  function: "Struct('2i').size.__eq__"
  args: [8]
  expected: true

invariant struct_extra176.struct_4B_size_4:
  description: "struct.Struct('4B').size == 4 — four unsigned chars = 4 * 1 = 4 bytes; new to extra176"
  category: identity
  kind: python_call_eq
  function: "Struct('4B').size.__eq__"
  args: [4]
  expected: true

