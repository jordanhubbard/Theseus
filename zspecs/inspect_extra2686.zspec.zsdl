spec: inspect_extra2686
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 626 theme: __and__, __or__, and __xor__ dict-presence checks (bitwise AND, OR, XOR operators)."
    - "inspect.Parameter is an introspection value object; it does not implement bitwise operator protocols."
    - "inspect.BoundArguments wraps a signature binding; it exposes .args and .kwargs but does not define __and__, __or__, or __xor__ itself."
    - "inspect.Signature is a callable signature descriptor; it defines __eq__ and __hash__ but not __and__, __or__, or __xor__."
    - "inspect.FullArgSpec is a namedtuple subclass; namedtuples inherit tuple methods but do not define __and__, __or__, or __xor__ in their own __dict__."
    - "None of these four inspect types define __and__, __or__, or __xor__ in their own class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2686.and_protocol:
  description: "__and__ is absent from all inspect type __dict__s — none define bitwise AND directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2686

  columns: [id, function, args, expected]
  rows:
    - ["in2686001", "inspect.Parameter.__dict__.__contains__",       ["__and__"], false]
    - ["in2686002", "inspect.BoundArguments.__dict__.__contains__",  ["__and__"], false]
    - ["in2686003", "inspect.Signature.__dict__.__contains__",       ["__and__"], false]
    - ["in2686004", "inspect.FullArgSpec.__dict__.__contains__",     ["__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2686.or_protocol:
  description: "__or__ is absent from all inspect type __dict__s — none define bitwise OR directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2686

  columns: [id, function, args, expected]
  rows:
    - ["in2686005", "inspect.Parameter.__dict__.__contains__",       ["__or__"], false]
    - ["in2686006", "inspect.BoundArguments.__dict__.__contains__",  ["__or__"], false]
    - ["in2686007", "inspect.Signature.__dict__.__contains__",       ["__or__"], false]
    - ["in2686008", "inspect.FullArgSpec.__dict__.__contains__",     ["__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2686.xor_protocol:
  description: "__xor__ is absent from all inspect type __dict__s — none define bitwise XOR directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2686

  columns: [id, function, args, expected]
  rows:
    - ["in2686009",  "inspect.Parameter.__dict__.__contains__",       ["__xor__"], false]
    - ["in2686010",  "inspect.BoundArguments.__dict__.__contains__",  ["__xor__"], false]
    - ["in2686011",  "inspect.Signature.__dict__.__contains__",       ["__xor__"], false]
    - ["in2686012",  "inspect.FullArgSpec.__dict__.__contains__",     ["__xor__"], false]

# ---------------------------------------------------------------------------
# Combined per-type view — all four inspect types vs. all three protocols
# ---------------------------------------------------------------------------

table inspect_extra2686.signature_combined:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, and inspect.FullArgSpec define none of __and__, __or__, __xor__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2686

  columns: [id, function, args, expected]
  rows:
    - ["in2686013", "inspect.Parameter.__dict__.__contains__",       ["__and__"],  false]
    - ["in2686014", "inspect.Parameter.__dict__.__contains__",       ["__or__"],   false]
    - ["in2686015", "inspect.Parameter.__dict__.__contains__",       ["__xor__"],  false]
    - ["in2686016", "inspect.Signature.__dict__.__contains__",       ["__and__"],  false]
    - ["in2686017", "inspect.Signature.__dict__.__contains__",       ["__or__"],   false]
    - ["in2686018", "inspect.Signature.__dict__.__contains__",       ["__xor__"],  false]
    - ["in2686019", "inspect.BoundArguments.__dict__.__contains__",  ["__and__"],  false]
    - ["in2686020", "inspect.BoundArguments.__dict__.__contains__",  ["__or__"],   false]
    - ["in2686021", "inspect.BoundArguments.__dict__.__contains__",  ["__xor__"],  false]
    - ["in2686022", "inspect.FullArgSpec.__dict__.__contains__",     ["__and__"],  false]
    - ["in2686023", "inspect.FullArgSpec.__dict__.__contains__",     ["__or__"],   false]
    - ["in2686024", "inspect.FullArgSpec.__dict__.__contains__",     ["__xor__"],  false]
