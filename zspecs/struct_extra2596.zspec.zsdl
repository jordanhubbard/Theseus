spec: struct_extra2596
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence — checking whether struct.Struct implements the descriptor protocol in its own class __dict__."
    - "struct.Struct is a compiled struct format object. It caches a format string and provides binary pack/unpack methods."
    - "struct.Struct.__dict__.__contains__('__get__') == False — Struct objects are not descriptors; they do not implement __get__. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__set__') == False — Struct objects do not define __set__; they are not data descriptors. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__delete__') == False — Struct objects do not define __delete__, confirming non-descriptor status. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__set_name__') == False — __set_name__ is also absent."
    - "Note: struct.Struct.__dict__ contains getset_descriptor typed values (format, size) but the Struct class itself does not implement __get__/__set__/__delete__."
    - "struct.Struct defines __setattr__ and __delattr__ in its own __dict__. These are instance attribute interception hooks, NOT the descriptor protocol methods __set__ and __delete__."
    - "struct.Struct.__dict__.__contains__('pack') == True — pack() encodes values to bytes using the compiled format."
    - "struct.Struct.__dict__.__contains__('unpack') == True — unpack() decodes bytes back into values."
    - "struct.Struct.__dict__.__contains__('format') == True — format is a getset_descriptor exposing the format string."
    - "struct.Struct.__dict__.__contains__('size') == True — size is a getset_descriptor exposing the computed byte size."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ absence — struct.Struct does not implement the non-data descriptor protocol
#
# For a class to act as a non-data descriptor, it must define __get__ in its
# own __dict__. struct.Struct does not. Struct objects are compiled format
# caches, not attribute lookup interceptors.
# ---------------------------------------------------------------------------

table struct_extra2596.get_absent:
  description: "__get__ is absent from struct.Struct.__dict__ — Struct objects do not implement the non-data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2596

  columns: [id, function, args, expected]
  rows:
    - ["st2596001", "struct.Struct.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ and __delete__ absence — struct.Struct is not a data descriptor
#
# A data descriptor must define __set__ and/or __delete__. struct.Struct
# defines neither. Note: struct.Struct DOES define __setattr__ and __delattr__
# (instance attribute hooks) — those are different from the descriptor protocol.
# ---------------------------------------------------------------------------

table struct_extra2596.set_delete_absent:
  description: "__set__ and __delete__ are absent from struct.Struct.__dict__ — Struct is not a data descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2596

  columns: [id, function, args, expected]
  rows:
    - ["st2596002", "struct.Struct.__dict__.__contains__", ["__set__"],      false]
    - ["st2596003", "struct.Struct.__dict__.__contains__", ["__delete__"],   false]
    - ["st2596004", "struct.Struct.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# __setattr__/__delattr__ present — confirming the distinction from descriptor protocol
#
# struct.Struct defines __setattr__ and __delattr__ for its own instances
# (to prevent mutation of the format string). These are NOT the descriptor
# protocol methods __set__ and __delete__.
# ---------------------------------------------------------------------------

table struct_extra2596.setattr_delattr_not_descriptor:
  description: "__setattr__ and __delattr__ are present; they are instance hooks distinct from descriptor protocol __set__/__delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2596

  columns: [id, function, args, expected]
  rows:
    - ["st2596005", "struct.Struct.__dict__.__contains__", ["__setattr__"], true]
    - ["st2596006", "struct.Struct.__dict__.__contains__", ["__delattr__"], true]
    - ["st2596007", "struct.Struct.__dict__.__contains__", ["__set__"],     false]
    - ["st2596008", "struct.Struct.__dict__.__contains__", ["__delete__"],  false]

# ---------------------------------------------------------------------------
# Pack/unpack API and format descriptors present in struct.Struct.__dict__
#
# These True entries confirm the struct API is present and that the
# __dict__ lookup mechanism works correctly.
# ---------------------------------------------------------------------------

table struct_extra2596.api_present:
  description: "Binary encoding API and format/size descriptors are present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2596

  columns: [id, function, args, expected]
  rows:
    - ["st2596009", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st2596010", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st2596011", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st2596012", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2596013", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2596014", "struct.Struct.__dict__.__contains__", ["format"],      true]
    - ["st2596015", "struct.Struct.__dict__.__contains__", ["size"],        true]
    - ["st2596016", "struct.Struct.__dict__.__contains__", ["__sizeof__"],  true]
