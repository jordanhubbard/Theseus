spec: inspect_extra2146
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2146 (_extra2146): numeric conversion protocol dict-presence checks — __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__ for inspect types."
    - "Theme: numeric conversion protocol dict-presence — checking whether numeric dunder methods (math.trunc, math.floor, math.ceil, integer index protocol, complex conversion, truth testing, int conversion) are defined at the class level in __dict__ for inspect types."
    - "inspect.Parameter, Signature, BoundArguments, FullArgSpec, FrameInfo are plain Python classes/namedtuples with no numeric conversion dunders in their own __dict__."
    - "inspect.BufferFlags is an IntFlag (Python 3.12+). Despite being an integer-like enum, it does NOT define __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, or __int__ in its own __dict__. These are inherited from int and Flag via MRO. Verified: {k for k in inspect.BufferFlags.__dict__ if k in TARGET} == set()."
    - "inspect.Format is an IntEnum (Python 3.12+). Same as BufferFlags: no numeric conversion dunders in its own __dict__. Verified: {k for k in inspect.Format.__dict__ if k in TARGET} == set()."
    - "inspect._ParameterKind is an IntEnum. Same pattern: no numeric conversion dunders in its own __dict__."
    - "Although IntEnum/IntFlag classes support int(), bool(), trunc(), etc. at runtime, these capabilities come from int in the MRO, not from __dict__ entries on the enum class itself."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: numeric conversion protocol dict-presence for inspect structural types
#
# Parameter, Signature, BoundArguments are introspection classes for function
# signatures. FullArgSpec and FrameInfo are namedtuple subclasses. None define
# numeric conversion dunders.
# ---------------------------------------------------------------------------

table inspect_extra2146.structural_types_numeric_protocol:
  description: "inspect structural types (Parameter, Signature, BoundArguments, FullArgSpec, FrameInfo) numeric conversion protocol dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2146

  columns: [id, function, args, expected]
  rows:
    - ["in2146001", "inspect.Parameter.__dict__.__contains__",      ["__trunc__"],   false]
    - ["in2146002", "inspect.Parameter.__dict__.__contains__",      ["__floor__"],   false]
    - ["in2146003", "inspect.Parameter.__dict__.__contains__",      ["__ceil__"],    false]
    - ["in2146004", "inspect.Parameter.__dict__.__contains__",      ["__index__"],   false]
    - ["in2146005", "inspect.Parameter.__dict__.__contains__",      ["__complex__"], false]
    - ["in2146006", "inspect.Parameter.__dict__.__contains__",      ["__bool__"],    false]
    - ["in2146007", "inspect.Parameter.__dict__.__contains__",      ["__int__"],     false]
    - ["in2146008", "inspect.Signature.__dict__.__contains__",      ["__trunc__"],   false]
    - ["in2146009", "inspect.Signature.__dict__.__contains__",      ["__floor__"],   false]
    - ["in2146010", "inspect.Signature.__dict__.__contains__",      ["__ceil__"],    false]
    - ["in2146011", "inspect.Signature.__dict__.__contains__",      ["__index__"],   false]
    - ["in2146012", "inspect.Signature.__dict__.__contains__",      ["__complex__"], false]
    - ["in2146013", "inspect.Signature.__dict__.__contains__",      ["__bool__"],    false]
    - ["in2146014", "inspect.Signature.__dict__.__contains__",      ["__int__"],     false]
    - ["in2146015", "inspect.BoundArguments.__dict__.__contains__", ["__trunc__"],   false]
    - ["in2146016", "inspect.BoundArguments.__dict__.__contains__", ["__floor__"],   false]
    - ["in2146017", "inspect.BoundArguments.__dict__.__contains__", ["__ceil__"],    false]
    - ["in2146018", "inspect.BoundArguments.__dict__.__contains__", ["__index__"],   false]
    - ["in2146019", "inspect.BoundArguments.__dict__.__contains__", ["__complex__"], false]
    - ["in2146020", "inspect.BoundArguments.__dict__.__contains__", ["__bool__"],    false]
    - ["in2146021", "inspect.BoundArguments.__dict__.__contains__", ["__int__"],     false]
    - ["in2146022", "inspect.FullArgSpec.__dict__.__contains__",    ["__trunc__"],   false]
    - ["in2146023", "inspect.FullArgSpec.__dict__.__contains__",    ["__index__"],   false]
    - ["in2146024", "inspect.FullArgSpec.__dict__.__contains__",    ["__bool__"],    false]
    - ["in2146025", "inspect.FullArgSpec.__dict__.__contains__",    ["__int__"],     false]

# ---------------------------------------------------------------------------
# Table 2: numeric conversion protocol dict-presence for inspect.FrameInfo
#          and inspect._ParameterKind
#
# FrameInfo is a namedtuple subclass for frame/lineno/filename etc.
# _ParameterKind is an IntEnum defining POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD,
# VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD. Despite inheriting from int, it
# does NOT define numeric dunders in its own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2146.frameinfo_parameterkind_numeric_protocol:
  description: "inspect.FrameInfo and inspect._ParameterKind numeric conversion protocol dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2146

  columns: [id, function, args, expected]
  rows:
    - ["in2146026", "inspect.FrameInfo.__dict__.__contains__",      ["__trunc__"],   false]
    - ["in2146027", "inspect.FrameInfo.__dict__.__contains__",      ["__floor__"],   false]
    - ["in2146028", "inspect.FrameInfo.__dict__.__contains__",      ["__ceil__"],    false]
    - ["in2146029", "inspect.FrameInfo.__dict__.__contains__",      ["__index__"],   false]
    - ["in2146030", "inspect.FrameInfo.__dict__.__contains__",      ["__complex__"], false]
    - ["in2146031", "inspect.FrameInfo.__dict__.__contains__",      ["__bool__"],    false]
    - ["in2146032", "inspect.FrameInfo.__dict__.__contains__",      ["__int__"],     false]
    - ["in2146033", "inspect._ParameterKind.__dict__.__contains__", ["__trunc__"],   false]
    - ["in2146034", "inspect._ParameterKind.__dict__.__contains__", ["__floor__"],   false]
    - ["in2146035", "inspect._ParameterKind.__dict__.__contains__", ["__ceil__"],    false]
    - ["in2146036", "inspect._ParameterKind.__dict__.__contains__", ["__index__"],   false]
    - ["in2146037", "inspect._ParameterKind.__dict__.__contains__", ["__complex__"], false]
    - ["in2146038", "inspect._ParameterKind.__dict__.__contains__", ["__bool__"],    false]
    - ["in2146039", "inspect._ParameterKind.__dict__.__contains__", ["__int__"],     false]

# ---------------------------------------------------------------------------
# Table 3: numeric conversion protocol dict-presence for inspect.BufferFlags
#          and inspect.Format (IntFlag / IntEnum types)
#
# Both BufferFlags (IntFlag) and Format (IntEnum) are integer-backed enum
# types introduced in Python 3.12. At runtime they support int(), bool(),
# math.trunc(), math.floor(), math.ceil(), and operator.index() because
# int defines these in its __dict__. However, neither BufferFlags nor Format
# define any of these dunders in their OWN __dict__ — they rely entirely on
# MRO inheritance from int (and Flag for BufferFlags).
# ---------------------------------------------------------------------------

table inspect_extra2146.enum_types_numeric_protocol:
  description: "inspect.BufferFlags (IntFlag) and inspect.Format (IntEnum) numeric conversion protocol dict-presence — all False (inherited via MRO from int, not in class own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2146

  columns: [id, function, args, expected]
  rows:
    - ["in2146040", "inspect.BufferFlags.__dict__.__contains__", ["__trunc__"],   false]
    - ["in2146041", "inspect.BufferFlags.__dict__.__contains__", ["__floor__"],   false]
    - ["in2146042", "inspect.BufferFlags.__dict__.__contains__", ["__ceil__"],    false]
    - ["in2146043", "inspect.BufferFlags.__dict__.__contains__", ["__index__"],   false]
    - ["in2146044", "inspect.BufferFlags.__dict__.__contains__", ["__complex__"], false]
    - ["in2146045", "inspect.BufferFlags.__dict__.__contains__", ["__bool__"],    false]
    - ["in2146046", "inspect.BufferFlags.__dict__.__contains__", ["__int__"],     false]
    - ["in2146047", "inspect.Format.__dict__.__contains__",      ["__trunc__"],   false]
    - ["in2146048", "inspect.Format.__dict__.__contains__",      ["__floor__"],   false]
    - ["in2146049", "inspect.Format.__dict__.__contains__",      ["__ceil__"],    false]
    - ["in2146050", "inspect.Format.__dict__.__contains__",      ["__index__"],   false]
    - ["in2146051", "inspect.Format.__dict__.__contains__",      ["__complex__"], false]
    - ["in2146052", "inspect.Format.__dict__.__contains__",      ["__bool__"],    false]
    - ["in2146053", "inspect.Format.__dict__.__contains__",      ["__int__"],     false]
