spec: functools_extra1756
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "functools.partial: C extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "functools.cached_property: Python class — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "functools.partialmethod: Python class — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "functools._lru_cache_wrapper: C extension wrapper type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "Complementary checks: functools.reduce.__class__.__name__ is 'builtin_function_or_method'; functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES are tuples."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for functools types
#
# Wave 564 theme: which functools types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# functools.partial: C extension type (Modules/_functoolsmodule.c) — a
#   partial function application wrapper; not a numeric type, no arithmetic
#   operators defined in __dict__.
# functools.cached_property: Python class (Lib/functools.py) — a descriptor
#   for caching property values; not numeric, no arithmetic operators.
# functools.partialmethod: Python class (Lib/functools.py) — a descriptor
#   variant for partial method application; not numeric, no arithmetic operators.
# functools._lru_cache_wrapper: C extension type wrapping cached callables;
#   not numeric, no arithmetic operators in __dict__.
# ---------------------------------------------------------------------------

table functools_extra1756.arithmetic_operators:
  description: "functools types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1756

  columns: [id, function, args, expected]
  rows:
    - ["fu1756001", "functools.partial.__dict__.__contains__", ["__add__"], false]
    - ["fu1756002", "functools.partial.__dict__.__contains__", ["__sub__"], false]
    - ["fu1756003", "functools.partial.__dict__.__contains__", ["__mul__"], false]
    - ["fu1756004", "functools.partial.__dict__.__contains__", ["__truediv__"], false]
    - ["fu1756005", "functools.partial.__dict__.__contains__", ["__floordiv__"], false]
    - ["fu1756006", "functools.partial.__dict__.__contains__", ["__pow__"], false]
    - ["fu1756007", "functools.partial.__dict__.__contains__", ["__neg__"], false]
    - ["fu1756008", "functools.partial.__dict__.__contains__", ["__pos__"], false]
    - ["fu1756009", "functools.cached_property.__dict__.__contains__", ["__add__"], false]
    - ["fu1756010", "functools.cached_property.__dict__.__contains__", ["__sub__"], false]
    - ["fu1756011", "functools.cached_property.__dict__.__contains__", ["__mul__"], false]
    - ["fu1756012", "functools.cached_property.__dict__.__contains__", ["__neg__"], false]
    - ["fu1756013", "functools.partialmethod.__dict__.__contains__", ["__add__"], false]
    - ["fu1756014", "functools.partialmethod.__dict__.__contains__", ["__mul__"], false]
    - ["fu1756015", "functools.partialmethod.__dict__.__contains__", ["__truediv__"], false]
    - ["fu1756016", "functools._lru_cache_wrapper.__dict__.__contains__", ["__add__"], false]
    - ["fu1756017", "functools._lru_cache_wrapper.__dict__.__contains__", ["__sub__"], false]
    - ["fu1756018", "functools._lru_cache_wrapper.__dict__.__contains__", ["__pow__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary module-level attribute checks for functools
#
# Unique checks not covered in earlier waves:
# - functools.reduce is a builtin_function_or_method (not a Python function)
# - functools.WRAPPER_ASSIGNMENTS is a module-level tuple (the list of attrs
#   copied by functools.wraps/update_wrapper from wrapped to wrapper function)
# - functools.WRAPPER_UPDATES is a module-level tuple (the list of attrs
#   updated, i.e. __dict__ merged)
# These checks confirm module-level structure and type identity of well-known
# functools constants, contrasting with the class __dict__ checks above.
# ---------------------------------------------------------------------------

table functools_extra1756.module_level_attributes:
  description: "functools module-level attribute class name checks — reduce is builtin, WRAPPER_ASSIGNMENTS/UPDATES are tuples — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1756

  columns: [id, function, args, expected]
  rows:
    - ["fu1756019", "functools.reduce.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["fu1756020", "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__", ["tuple"], true]
    - ["fu1756021", "functools.WRAPPER_UPDATES.__class__.__name__.__eq__", ["tuple"], true]
    - ["fu1756022", "functools.partial.__dict__.__contains__", ["__add__"], false]
    - ["fu1756023", "functools.partial.__dict__.__contains__", ["__floordiv__"], false]
    - ["fu1756024", "functools.partialmethod.__dict__.__contains__", ["__neg__"], false]
    - ["fu1756025", "functools._lru_cache_wrapper.__dict__.__contains__", ["__neg__"], false]
