spec: inspect_extra115
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra114.zspec.zsdl."
    - "This spec covers: inspect.FrameInfo and inspect.Traceback namedtuple-style classes — _fields contents, _field_defaults length, __qualname__, __name__ length; wave 266."
    - "inspect.FrameInfo._fields[0] == 'frame'. Verified with Python 3.14.3."
    - "inspect.FrameInfo._fields[1] == 'filename'. Verified with Python 3.14.3."
    - "inspect.FrameInfo._fields[2] == 'lineno'. Verified with Python 3.14.3."
    - "inspect.FrameInfo._fields.__len__() == 6. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__qualname__ == 'FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo._field_defaults.__len__() == 0. Verified with Python 3.14.3."
    - "inspect.Traceback._fields[0] == 'filename'. Verified with Python 3.14.3."
    - "inspect.Traceback._fields[2] == 'function'. Verified with Python 3.14.3."
    - "inspect.Traceback._fields.__len__() == 5. Verified with Python 3.14.3."
    - "inspect.Traceback.__qualname__ == 'Traceback'. Verified with Python 3.14.3."
    - "inspect.Traceback._field_defaults.__len__() == 0. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FrameInfo _fields contents and __qualname__
#
# Wave 266 theme: inspect.FrameInfo is a named-tuple-like class (NamedTuple
# subclass added in Python 3.5, revised in 3.11). Its _fields tuple lists the
# six field names in order: 'frame', 'filename', 'lineno', 'function',
# 'code_context', 'index'. The _field_defaults dict is empty (no defaults).
# Previously covered: __class__.__name__, __mro__.__len__, __bases__[0].__name__
# (in extra113/114). New here: _fields[0], _fields[1], _fields[2], __qualname__,
# _field_defaults.__len__.
#
# FrameInfo._fields[0] == 'frame'
# FrameInfo._fields[1] == 'filename'
# FrameInfo._fields[2] == 'lineno'
# FrameInfo.__qualname__ == 'FrameInfo'
# FrameInfo._field_defaults.__len__() == 0
#
# New to extra115.
# ---------------------------------------------------------------------------

table inspect_extra115.frameinfo_fields:
  description: "inspect.FrameInfo _fields: [0]='frame', [1]='filename', [2]='lineno'; _field_defaults len=0; __qualname__='FrameInfo'; 6 fields total; NamedTuple subclass; wave 266; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectfif115

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_fields0,
       "FrameInfo._fields.__getitem__",
       [0],
       "frame",
       "inspect.FrameInfo._fields[0] == 'frame' — the first field of FrameInfo is the frame object; tuple.__getitem__(0) returns 'frame'; new to extra115"]
    - [frameinfo_fields1,
       "FrameInfo._fields.__getitem__",
       [1],
       "filename",
       "inspect.FrameInfo._fields[1] == 'filename' — the second field is the source filename string; tuple.__getitem__(1) returns 'filename'; new to extra115"]
    - [frameinfo_fields2,
       "FrameInfo._fields.__getitem__",
       [2],
       "lineno",
       "inspect.FrameInfo._fields[2] == 'lineno' — the third field is the line number integer; tuple.__getitem__(2) returns 'lineno'; new to extra115"]
    - [frameinfo_fields_len,
       "FrameInfo._fields.__len__",
       [],
       6,
       "inspect.FrameInfo._fields.__len__() == 6 — FrameInfo has 6 fields: frame, filename, lineno, function, code_context, index; tuple.__len__() returns 6; new to extra115"]
    - [frameinfo_qualname,
       "FrameInfo.__qualname__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__qualname__.__eq__('FrameInfo') == True — FrameInfo is a top-level class; __qualname__ equals __name__; str.__eq__('FrameInfo') returns True; new to extra115"]
    - [frameinfo_field_defaults_len,
       "FrameInfo._field_defaults.__len__",
       [],
       0,
       "inspect.FrameInfo._field_defaults.__len__() == 0 — FrameInfo has no default values for any field; all fields are required; dict.__len__() returns 0; new to extra115"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Traceback _fields contents and __qualname__
#
# Wave 266 theme: inspect.Traceback is similar to FrameInfo but with 5 fields
# (omitting 'frame'): 'filename', 'lineno', 'function', 'code_context', 'index'.
# The _field_defaults dict is also empty. __qualname__ == 'Traceback'. The
# first field is 'filename' (unlike FrameInfo where first field is 'frame').
# Previously covered: __module__, __mro__.__len__ (in earlier specs).
# New here: _fields[0], _fields[2], _fields[3], _fields[4], __qualname__,
# _field_defaults.__len__.
#
# Traceback._fields[0] == 'filename'
# Traceback._fields[2] == 'function'
# Traceback._fields.__len__() == 5
# Traceback.__qualname__ == 'Traceback'
# Traceback._field_defaults.__len__() == 0
#
# New to extra115.
# ---------------------------------------------------------------------------

table inspect_extra115.traceback_fields:
  description: "inspect.Traceback _fields: [0]='filename', [2]='function', len=5; _field_defaults len=0; __qualname__='Traceback'; 5 fields (no frame field unlike FrameInfo); wave 266; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspecttbf115

  columns: [id, function, args, expected, description]
  rows:
    - [traceback_fields0,
       "Traceback._fields.__getitem__",
       [0],
       "filename",
       "inspect.Traceback._fields[0] == 'filename' — Traceback first field is filename; differs from FrameInfo whose first field is 'frame'; tuple.__getitem__(0) returns 'filename'; new to extra115"]
    - [traceback_fields2,
       "Traceback._fields.__getitem__",
       [2],
       "function",
       "inspect.Traceback._fields[2] == 'function' — the third Traceback field is the function name string; tuple.__getitem__(2) returns 'function'; new to extra115"]
    - [traceback_fields3,
       "Traceback._fields.__getitem__",
       [3],
       "code_context",
       "inspect.Traceback._fields[3] == 'code_context' — the fourth Traceback field is the list of source lines; tuple.__getitem__(3) returns 'code_context'; new to extra115"]
    - [traceback_fields4,
       "Traceback._fields.__getitem__",
       [4],
       "index",
       "inspect.Traceback._fields[4] == 'index' — the fifth and last Traceback field is the index into code_context; tuple.__getitem__(4) returns 'index'; new to extra115"]
    - [traceback_fields_len,
       "Traceback._fields.__len__",
       [],
       5,
       "inspect.Traceback._fields.__len__() == 5 — Traceback has 5 fields; one fewer than FrameInfo (6) because it lacks the 'frame' field; tuple.__len__() returns 5; new to extra115"]
    - [traceback_qualname,
       "Traceback.__qualname__.__eq__",
       ["Traceback"],
       true,
       "inspect.Traceback.__qualname__.__eq__('Traceback') == True — Traceback is a top-level class in the inspect module; __qualname__ equals __name__; str.__eq__('Traceback') returns True; new to extra115"]
    - [traceback_field_defaults_len,
       "Traceback._field_defaults.__len__",
       [],
       0,
       "inspect.Traceback._field_defaults.__len__() == 0 — Traceback has no default field values; all fields are required; dict.__len__() returns 0; new to extra115"]

# ---------------------------------------------------------------------------
# Table 3: FrameInfo vs Traceback name and field count comparison
#
# Wave 266 theme: Both FrameInfo and Traceback are exposed in inspect as
# named-tuple-like classes. Their __name__ values are both 9 characters long
# ('FrameInfo' and 'Traceback'). The field count differs: FrameInfo has 6
# fields, Traceback has 5. Both reside in module 'inspect'. Both have empty
# _field_defaults. Both have __qualname__ equal to their __name__.
#
# FrameInfo.__name__.__len__() == 9
# Traceback.__name__.__len__() == 9
# FrameInfo._fields.__len__() == 6  (one more than Traceback)
# Traceback._fields.__len__() == 5  (one fewer than FrameInfo)
#
# New to extra115.
# ---------------------------------------------------------------------------

table inspect_extra115.frameinfo_traceback_comparison:
  description: "inspect.FrameInfo vs Traceback: both __name__ len=9, FrameInfo _fields len=6 vs Traceback _fields len=5; both _field_defaults empty; both module='inspect'; wave 266; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectftc115

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_len,
       "FrameInfo.__name__.__len__",
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — 'FrameInfo' has 9 chars: F-r-a-m-e-I-n-f-o; same length as 'Traceback'; str.__len__() returns 9; new to extra115"]
    - [traceback_name_len,
       "Traceback.__name__.__len__",
       [],
       9,
       "inspect.Traceback.__name__.__len__() == 9 — 'Traceback' has 9 chars: T-r-a-c-e-b-a-c-k; same length as 'FrameInfo'; str.__len__() returns 9; new to extra115"]
    - [frameinfo_fields_len_6,
       "FrameInfo._fields.__len__",
       [],
       6,
       "inspect.FrameInfo._fields.__len__() == 6 — FrameInfo has 6 fields including 'frame'; one more than Traceback; tuple.__len__() returns 6; new to extra115"]
    - [traceback_fields_len_5,
       "Traceback._fields.__len__",
       [],
       5,
       "inspect.Traceback._fields.__len__() == 5 — Traceback has 5 fields; omits 'frame' compared to FrameInfo; tuple.__len__() returns 5; new to extra115"]
    - [frameinfo_module_eq,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in the inspect module; str.__eq__('inspect') returns True; new to extra115"]
    - [traceback_module_eq,
       "Traceback.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in the inspect module; str.__eq__('inspect') returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra115
# ---------------------------------------------------------------------------

invariant inspect_extra115.frameinfo_fields0:
  description: "inspect.FrameInfo._fields[0] == 'frame' — first field is the frame object; wave 266; new to extra115"
  kind: python_call_eq
  function: "FrameInfo._fields.__getitem__"
  args: [0]
  expected: "frame"

invariant inspect_extra115.traceback_fields0:
  description: "inspect.Traceback._fields[0] == 'filename' — first Traceback field is filename not frame; wave 266; new to extra115"
  kind: python_call_eq
  function: "Traceback._fields.__getitem__"
  args: [0]
  expected: "filename"

invariant inspect_extra115.frameinfo_fields_len:
  description: "inspect.FrameInfo._fields.__len__() == 6 — six fields: frame, filename, lineno, function, code_context, index; wave 266; new to extra115"
  kind: python_call_eq
  function: FrameInfo._fields.__len__
  args: []
  expected: 6

invariant inspect_extra115.traceback_fields_len:
  description: "inspect.Traceback._fields.__len__() == 5 — five fields; one fewer than FrameInfo; wave 266; new to extra115"
  kind: python_call_eq
  function: Traceback._fields.__len__
  args: []
  expected: 5

invariant inspect_extra115.frameinfo_qualname:
  description: "inspect.FrameInfo.__qualname__ == 'FrameInfo' — top-level class; __qualname__ equals __name__; wave 266; new to extra115"
  kind: python_call_eq
  function: FrameInfo.__qualname__.__eq__
  args: ["FrameInfo"]
  expected: true
