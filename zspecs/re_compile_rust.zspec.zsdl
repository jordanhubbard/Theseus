spec: re_compile_rust
version: ">=3.9"
backend: rust_module(re_compile_rust)

docs: https://docs.python.org/3/library/re.html#re.compile

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html#re.compile — Python re.compile documentation"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "Clean-room Rust reimplementation of Python re.compile, exposed via PyO3."
    - "compile(pattern) returns a compiled regular expression object (Pattern)."
    - "compile(pattern).pattern == pattern — stores the original pattern."
    - "compile(r'\\d+').groups == 0 — no capture groups."
    - "compile(r'(\\w+)').groups == 1 — one capture group."
    - "compile(r'\\d+').match('123').__bool__() == True — match returns Match object."
    - "compile(r'\\d+').match('abc').__bool__() == False — no match returns None."
    - "compile(r'\\w+').search('hello world').__bool__() == True."
    - "All test vectors verified against Python 3.14.3 re module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Pattern.pattern — returns the original pattern string
table re_compile_rust.pattern.vectors:
  kind: python_call_eq
  category: pattern
  id_prefix: rcp
  function: compile
  method: pattern

  columns: [id, args, expected]
  rows:
    - [digits,  ["\\d+"],    "\\d+"]
    - [word,    ["\\w+"],    "\\w+"]
    - [alpha,   ["[a-z]+"],  "[a-z]+"]
    - [literal, ["hello"],   "hello"]

# Pattern.groups — number of capture groups
table re_compile_rust.groups.vectors:
  kind: python_call_eq
  category: groups
  id_prefix: rcg
  function: compile
  method: groups

  columns: [id, args, expected]
  rows:
    - [no_groups,  ["\\d+"],        0]
    - [one_group,  ["(\\w+)"],      1]
    - [two_groups, ["(\\d+)(\\w+)"],2]

# Pattern.match — match at start, result as bool via __bool__
table re_compile_rust.match.vectors:
  kind: python_call_eq
  category: match
  id_prefix: rcm
  function: compile
  method: match
  method_chain: __bool__

  columns: [id, args, method_args, expected]
  rows:
    - [digits_ok,   ["\\d+"],   ["123abc"],   true]
    - [digits_fail, ["\\d+"],   ["abc123"],   false]
    - [word_ok,     ["\\w+"],   ["hello"],    true]
    - [exact_fail,  ["hello"],  ["world"],    false]

# Pattern.search — search anywhere, result as bool
table re_compile_rust.search.vectors:
  kind: python_call_eq
  category: search
  id_prefix: rcs
  function: compile
  method: search
  method_chain: __bool__

  columns: [id, args, method_args, expected]
  rows:
    - [digits_found,  ["\\d+"],  ["abc 123 def"],  true]
    - [digits_absent, ["\\d+"],  ["no digits"],    false]
    - [word_found,    ["\\w+"],  ["hello world"],  true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T21:59:34Z
  iterations: 1
  pass_count: 14
  fail_count: 0
  total_invariants: 14
  notes: Synthesis succeeded in 1 iteration(s). 14 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
