spec: threading_extra537
version: ">=3.9"
backend: python_module(threading)
docs: "Cover threading.Barrier method identity and BrokenBarrierError class identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: exception_is_failure

table threading_extra537.barrier_identity:
  description: "threading.Barrier class and method identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: thb

  columns: [id, function, args, expected]
  rows:
    - [thb001, threading.Barrier.__name__.__eq__, ["Barrier"], true]
    - [thb002, threading.Barrier.__module__.__eq__, ["threading"], true]
    - [thb003, "threading.Barrier.__bases__[0].__name__.__eq__", ["object"], true]
    - [thb004, threading.Barrier.wait.__name__.__eq__, ["wait"], true]
    - [thb005, threading.Barrier.reset.__name__.__eq__, ["reset"], true]
    - [thb006, threading.Barrier.abort.__name__.__eq__, ["abort"], true]

table threading_extra537.barrier_properties:
  description: "threading.Barrier property descriptor class checks"
  kind: python_call_eq
  category: identity
  id_prefix: tbp

  columns: [id, function, args, expected]
  rows:
    - [tbp001, threading.Barrier.parties.__class__.__name__.__eq__, ["property"], true]
    - [tbp002, threading.Barrier.n_waiting.__class__.__name__.__eq__, ["property"], true]
    - [tbp003, threading.Barrier.broken.__class__.__name__.__eq__, ["property"], true]

table threading_extra537.broken_barrier_error_identity:
  description: "threading.BrokenBarrierError class identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: tbe

  columns: [id, function, args, expected]
  rows:
    - [tbe001, threading.BrokenBarrierError.__name__.__eq__, ["BrokenBarrierError"], true]
    - [tbe002, threading.BrokenBarrierError.__module__.__eq__, ["threading"], true]
    - [tbe003, "threading.BrokenBarrierError.__bases__[0].__name__.__eq__", ["Exception"], true]
