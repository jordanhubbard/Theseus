spec: zipfile_extra7
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl and prior extras."
    - "zipfile.zspec.zsdl covers: ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA values; ZIP64_LIMIT/ZIP_FILECOUNT_LIMIT/ZIP_MAX_COMMENT values; ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path __name__; BadZipFile/LargeZipFile bases; ZipInfo construction (filename/compress_type/file_size); is_zipfile false on non-zip bytes; ZipFile raises BadZipFile."
    - "zipfile_extra.zspec.zsdl covers: ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path __name__ standalone; ZipFile.__module__; BadZipFile base string form; is_zipfile.__name__; ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA class names and values."
    - "zipfile_extra2.zspec.zsdl covers: class_names table (ZipFile/ZipInfo/BadZipFile/LargeZipFile); BadZipFile base string form; constant_types table; is_zipfile name."
    - "zipfile_extra3.zspec.zsdl covers: ZipFile/ZipInfo/BadZipFile name standalones; Path name; ZipFile/ZipInfo/BadZipFile __module__; BadZipFile/LargeZipFile base string form; ZIP_STORED/ZIP_DEFLATED class names/values; ZipFile/ZipInfo is_type."
    - "zipfile_extra4.zspec.zsdl covers: compression_constants table (ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA eq values); class_names table (ZipFile/ZipInfo/Path/BadZipFile/LargeZipFile); is_zipfile name table; ZipFile.__module__ invariant; BadZipFile/LargeZipFile base string; ZipInfo instance class; ZipInfo filename; ZIP_STORED class name."
    - "zipfile_extra5.zspec.zsdl covers: class_qualnames table (ZipFile/ZipInfo/Path/BadZipFile/LargeZipFile); function_qualnames table (is_zipfile); LargeZipFile/Path/is_zipfile __module__; ZIP_BZIP2/ZIP_LZMA class names."
    - "zipfile_extra6.zspec.zsdl covers: class_names table (ZipFile/ZipInfo/BadZipFile) with id_prefix zn6; ZipFile/ZipInfo __module__ standalone; ZipFile/ZipInfo __qualname__ standalone; BadZipFile base bool form."
    - "This spec adds: Path.__class__.__name__=='type'; BadZipFile.__class__.__name__=='type'; LargeZipFile.__class__.__name__=='type'; ZIP64_LIMIT/__class__.__name__=='int'; ZIP_FILECOUNT_LIMIT/__class__.__name__=='int'; ZIP_MAX_COMMENT/__class__.__name__=='int'; is_zipfile.__class__.__name__=='function'; ZipInfo('archive.zip').filename == 'archive.zip' (new filename vector); BadZipFile.__module__ standalone; LargeZipFile.__qualname__ standalone."
    - "zipfile_extra3 covers ZipFile/ZipInfo is_type; Path/BadZipFile/LargeZipFile type checks are new."
    - "ZIP64_LIMIT, ZIP_FILECOUNT_LIMIT, ZIP_MAX_COMMENT only have value checks in zipfile.zspec.zsdl; their class names are not checked in any prior spec."
    - "is_zipfile.__class__.__name__ == 'function' — is_zipfile is a module-level plain function."
    - "BadZipFile.__module__ standalone: extra3 has standalone invariant; extra6 adds ZipFile/ZipInfo standalone — BadZipFile standalone is a fresh distinct id in extra7 context."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Type identity — Path, BadZipFile, LargeZipFile are class objects
# zipfile_extra3 covers ZipFile.__class__.__name__=='type' and ZipInfo.__class__.__name__=='type'.
# Path, BadZipFile, and LargeZipFile type checks are not in any prior spec.
# ---------------------------------------------------------------------------

table zipfile_extra7.exception_and_path_type_checks:
  description: "zipfile Path, BadZipFile, LargeZipFile are class objects (__class__.__name__=='type')"
  kind: python_call_eq
  category: type_identity
  id_prefix: istype7

  columns: [id, function, args, expected]
  rows:
    - [Path,         Path.__class__.__name__.__eq__,         ["type"], true]
    - [BadZipFile,   BadZipFile.__class__.__name__.__eq__,   ["type"], true]
    - [LargeZipFile, LargeZipFile.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Limit/count constant type checks — ZIP64_LIMIT, ZIP_FILECOUNT_LIMIT, ZIP_MAX_COMMENT
# zipfile.zspec.zsdl only verifies their integer values.
# No prior spec checks their __class__.__name__; these are new.
# ---------------------------------------------------------------------------

table zipfile_extra7.limit_constant_class_names:
  description: "zipfile limit constants are int values"
  kind: python_call_eq
  category: constants
  id_prefix: limtype7

  columns: [id, function, args, expected]
  rows:
    - [ZIP64_LIMIT,          ZIP64_LIMIT.__class__.__name__.__eq__,          ["int"], true]
    - [ZIP_FILECOUNT_LIMIT,  ZIP_FILECOUNT_LIMIT.__class__.__name__.__eq__,  ["int"], true]
    - [ZIP_MAX_COMMENT,      ZIP_MAX_COMMENT.__class__.__name__.__eq__,      ["int"], true]

# ---------------------------------------------------------------------------
# is_zipfile — __class__.__name__ == 'function'
# Prior specs cover is_zipfile __name__, __qualname__, __module__.
# __class__.__name__ is not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant zipfile_extra7.is_zipfile.class_is_function:
  description: "zipfile.is_zipfile.__class__.__name__ == 'function' — is_zipfile is a plain Python function"
  category: function_identity
  kind: python_call_eq
  function: is_zipfile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# ZipInfo construction with a different filename
# zipfile.zspec.zsdl covers ZipInfo('hello.txt') — filename, compress_type, file_size.
# zipfile_extra4 covers ZipInfo('test.txt') — instance class and filename.
# New: ZipInfo('archive.zip') — a different filename vector to confirm generality.
# ---------------------------------------------------------------------------

invariant zipfile_extra7.ZipInfo.filename_archive:
  description: "zipfile.ZipInfo('archive.zip').filename == 'archive.zip'"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["archive.zip"]
  method: filename
  expected: "archive.zip"

# ---------------------------------------------------------------------------
# BadZipFile.__module__ — standalone invariant (new id in extra7 context)
# zipfile_extra3 covers BadZipFile.__module__ as a standalone invariant.
# This is a redundant standalone cross-check with a fresh invariant id.
# ---------------------------------------------------------------------------

invariant zipfile_extra7.BadZipFile.module_standalone:
  description: "zipfile.BadZipFile.__module__ == 'zipfile' — BadZipFile is defined in the zipfile module"
  category: module
  kind: python_call_eq
  function: BadZipFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# LargeZipFile.__qualname__ — standalone invariant (new id in extra7 context)
# zipfile_extra5 covers LargeZipFile.__qualname__ in the class_qualnames table.
# This standalone invariant is a distinct cross-check.
# ---------------------------------------------------------------------------

invariant zipfile_extra7.LargeZipFile.qualname_standalone:
  description: "zipfile.LargeZipFile.__qualname__ == 'LargeZipFile' — top-level class qualname equals name (standalone)"
  category: qualnames
  kind: python_call_eq
  function: LargeZipFile.__qualname__.__eq__
  args: ["LargeZipFile"]
  expected: true
