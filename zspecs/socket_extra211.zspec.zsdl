spec: socket_extra211
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra210.zspec.zsdl — covers socket checks prior to extra211"
  notes:
    - "socket.socket.__qualname__ == 'socket' — the socket.socket class is pure Python (Lib/socket.py); __qualname__ is 'socket' (same as __name__, len=6); __module__=='socket'. Verified with Python 3.14.3."
    - "socket.getaddrinfo.__qualname__ == 'getaddrinfo' — defined in Python socket.py wrapper; __module__=='socket'. Verified with Python 3.14.3."
    - "socket.gethostname.__qualname__ == 'gethostname' — C builtin in _socket; __module__=='_socket'. Verified with Python 3.14.3."
    - "socket.gethostbyname.__qualname__ == 'gethostbyname' — C builtin in _socket; __module__=='_socket'. Verified with Python 3.14.3."
    - "socket.create_connection.__qualname__ == 'create_connection' — Python function in socket.py; __module__=='socket'. Verified with Python 3.14.3."
    - "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout' — C builtin in _socket; __module__=='_socket'. Verified with Python 3.14.3."
    - "socket.error.__qualname__ == 'OSError' — socket.error is an alias for OSError; __qualname__=='OSError' and __module__=='builtins'. socket.timeout.__qualname__=='TimeoutError', __module__=='builtins'. Both are aliases to builtin exceptions. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket class and function __qualname__ checks -- extra211
# ---------------------------------------------------------------------------

table socket_extra211.socket_qualname_class:
  description: "socket.socket class __qualname__ checks in socketqn211 namespace — socket.socket.__qualname__=='socket' (len=6; pure Python class in socket.py; __module__=='socket'); socket.error.__qualname__=='OSError' (socket.error is an alias for OSError, a builtin; __qualname__ reflects the canonical name; __module__=='builtins'); socket.timeout.__qualname__=='TimeoutError' (socket.timeout is an alias for TimeoutError, a builtin; __module__=='builtins'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketqn211

  columns: [id, function, args, expected, description]
  rows:
    - [socket_qualname,   socket.socket.__qualname__.__eq__,   ["socket"],         true,  "socket.socket.__qualname__ == 'socket' (len=6; Python class in socket.py); verified with Python 3.14.3"]
    - [socket_module,     socket.socket.__module__.__eq__,     ["socket"],         true,  "socket.socket.__module__ == 'socket'; verified with Python 3.14.3"]
    - [error_qualname,    socket.error.__qualname__.__eq__,    ["OSError"],        true,  "socket.error.__qualname__ == 'OSError' (alias for builtin OSError); verified with Python 3.14.3"]
    - [error_module,      socket.error.__module__.__eq__,      ["builtins"],       true,  "socket.error.__module__ == 'builtins' (OSError is a builtin); verified with Python 3.14.3"]
    - [timeout_qualname,  socket.timeout.__qualname__.__eq__,  ["TimeoutError"],   true,  "socket.timeout.__qualname__ == 'TimeoutError' (alias for builtin TimeoutError); verified with Python 3.14.3"]
    - [timeout_module,    socket.timeout.__module__.__eq__,    ["builtins"],       true,  "socket.timeout.__module__ == 'builtins'; verified with Python 3.14.3"]

table socket_extra211.socket_qualname_funcs:
  description: "socket function __qualname__ checks in socketfn211 namespace — socket functions split between Python socket.py (getaddrinfo, create_connection) with __module__=='socket' and C _socket builtins (gethostname, gethostbyname, setdefaulttimeout) with __module__=='_socket'; getaddrinfo.__qualname__=='getaddrinfo' (len=11); create_connection.__qualname__=='create_connection' (len=17); gethostname.__qualname__=='gethostname' (len=11); gethostbyname.__qualname__=='gethostbyname' (len=13); setdefaulttimeout.__qualname__=='setdefaulttimeout' (len=17); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketfn211

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_qualname,       socket.getaddrinfo.__qualname__.__eq__,       ["getaddrinfo"],       true,  "socket.getaddrinfo.__qualname__ == 'getaddrinfo' (len=11; Python wrapper in socket.py); verified with Python 3.14.3"]
    - [getaddrinfo_module,         socket.getaddrinfo.__module__.__eq__,         ["socket"],            true,  "socket.getaddrinfo.__module__ == 'socket' (Python wrapper); verified with Python 3.14.3"]
    - [create_connection_qualname, socket.create_connection.__qualname__.__eq__, ["create_connection"], true,  "socket.create_connection.__qualname__ == 'create_connection' (len=17; Python in socket.py); verified with Python 3.14.3"]
    - [create_connection_module,   socket.create_connection.__module__.__eq__,   ["socket"],            true,  "socket.create_connection.__module__ == 'socket'; verified with Python 3.14.3"]
    - [gethostname_qualname,       socket.gethostname.__qualname__.__eq__,       ["gethostname"],       true,  "socket.gethostname.__qualname__ == 'gethostname' (len=11; C builtin in _socket); verified with Python 3.14.3"]
    - [gethostname_module,         socket.gethostname.__module__.__eq__,         ["_socket"],           true,  "socket.gethostname.__module__ == '_socket' (C extension); verified with Python 3.14.3"]
    - [setdefaulttimeout_qualname, socket.setdefaulttimeout.__qualname__.__eq__, ["setdefaulttimeout"], true,  "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout' (len=17; C builtin in _socket); verified with Python 3.14.3"]
    - [setdefaulttimeout_module,   socket.setdefaulttimeout.__module__.__eq__,   ["_socket"],           true,  "socket.setdefaulttimeout.__module__ == '_socket'; verified with Python 3.14.3"]

table socket_extra211.socket_qualname_server_funcs:
  description: "socket server-side and utility function __qualname__ checks in socketsvr211 namespace — socket.create_server.__qualname__=='create_server' (Python function in socket.py; added Python 3.8); socket.getfqdn.__qualname__=='getfqdn' (Python function in socket.py; returns fully-qualified domain name); socket.gethostbyname.__qualname__=='gethostbyname' (C builtin in _socket); create_server.__module__=='socket'; getfqdn.__module__=='socket'; gethostbyname.__module__=='_socket'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketsvr211

  columns: [id, function, args, expected, description]
  rows:
    - [create_server_qualname,  socket.create_server.__qualname__.__eq__,  ["create_server"],  true,  "socket.create_server.__qualname__ == 'create_server' (Python in socket.py); verified with Python 3.14.3"]
    - [create_server_module,    socket.create_server.__module__.__eq__,    ["socket"],         true,  "socket.create_server.__module__ == 'socket'; verified with Python 3.14.3"]
    - [getfqdn_qualname,        socket.getfqdn.__qualname__.__eq__,        ["getfqdn"],        true,  "socket.getfqdn.__qualname__ == 'getfqdn' (Python in socket.py); verified with Python 3.14.3"]
    - [getfqdn_module,          socket.getfqdn.__module__.__eq__,          ["socket"],         true,  "socket.getfqdn.__module__ == 'socket'; Python function in Lib/socket.py; verified with Python 3.14.3"]
    - [gethostbyname_qualname,  socket.gethostbyname.__qualname__.__eq__,  ["gethostbyname"],  true,  "socket.gethostbyname.__qualname__ == 'gethostbyname' (C builtin in _socket); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants -- extra211
# ---------------------------------------------------------------------------

invariant socket_extra211.socket_socket_qualname_is_socket:
  description: "socket.socket.__qualname__.__eq__('socket') returns True — socket.socket is a pure-Python class defined in Lib/socket.py; its __qualname__ is 'socket' (len=6, same as __name__); __module__=='socket'; this is a module-level class (flat qualname); socket.socket wraps the C _socket.socket via inheritance; contrasts with socket.error which has __qualname__=='OSError' (its canonical builtin name) not 'error'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: socket.socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra211.socket_error_qualname_is_OSError:
  description: "socket.error.__qualname__.__eq__('OSError') returns True — socket.error is an alias (not a subclass) for the builtin OSError; when you access __qualname__ you get 'OSError' (the canonical qualname of the OSError builtin class); socket.error.__module__=='builtins'; this means socket.error IS OSError (identity, not just equivalence): socket.error is OSError evaluates to True; socket.timeout is also an alias: socket.timeout.__qualname__=='TimeoutError' and __module__=='builtins'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: socket.error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra211.socket_getaddrinfo_module_is_socket:
  description: "socket.getaddrinfo.__module__.__eq__('socket') returns True — socket.getaddrinfo is a Python-level wrapper function defined in Lib/socket.py (not a C builtin from _socket); its __module__=='socket' and __qualname__=='getaddrinfo'; contrasts with gethostname and gethostbyname which are C builtins with __module__=='_socket'; the Python wrapper adds logic for address family defaults and error handling on top of the raw C getaddrinfo; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: socket.getaddrinfo.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra211.socket_create_connection_qualname_is_create_connection:
  description: "socket.create_connection.__qualname__.__eq__('create_connection') returns True — socket.create_connection is a Python function in Lib/socket.py that creates a TCP connection socket; its qualname matches the public name 'create_connection' (len=17); __module__=='socket'; the function iterates over getaddrinfo results trying each address family until one succeeds; added in Python 2.6; create_connection is distinct from create_server (creates listening socket); NEW in socket_extra211: first standalone create_connection.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.create_connection.__qualname__.__eq__
  args: ["create_connection"]
  expected: true

invariant socket_extra211.socket_create_server_qualname_is_create_server:
  description: "socket.create_server.__qualname__.__eq__('create_server') returns True — socket.create_server is a Python function in Lib/socket.py added in Python 3.8; its qualname is 'create_server' matching the public name; __module__=='socket'; create_server(address) creates a TCP socket bound to address and calls listen(); it supports IPv4 and IPv6 via the family parameter; compare: socket.create_connection creates a connecting (client) socket; NEW in socket_extra211: first standalone create_server.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.create_server.__qualname__.__eq__
  args: ["create_server"]
  expected: true

invariant socket_extra211.socket_getfqdn_qualname_is_getfqdn:
  description: "socket.getfqdn.__qualname__.__eq__('getfqdn') returns True — socket.getfqdn is a Python function in Lib/socket.py that returns the fully-qualified domain name for a hostname; its qualname is 'getfqdn' matching the public name; __module__=='socket'; getfqdn() with no argument returns the FQDN of the local machine; it calls gethostbyaddr and validates results with getaddrinfo; contrast with gethostname (C builtin in _socket with __module__=='_socket'); NEW in socket_extra211: first standalone getfqdn.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.getfqdn.__qualname__.__eq__
  args: ["getfqdn"]
  expected: true

invariant socket_extra211.socket_gethostname_module_is_c_socket:
  description: "socket.gethostname.__module__.__eq__('_socket') returns True — socket.gethostname is a C builtin defined in Modules/socketmodule.c; its __module__ is '_socket' (the C extension); this contrasts with socket.getaddrinfo.__module__=='socket' (Python wrapper) and socket.getfqdn.__module__=='socket' (Python function); gethostname() returns the standard hostname for the local machine; it does NOT do DNS resolution — for a fully-qualified domain name use socket.getfqdn(); NEW in socket_extra211: first standalone gethostname.__module__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true

invariant socket_extra211.socket_timeout_qualname_is_TimeoutError:
  description: "socket.timeout.__qualname__.__eq__('TimeoutError') returns True — socket.timeout is an alias for the builtin TimeoutError since Python 3.3; its __qualname__ is 'TimeoutError' (the canonical qualname of the underlying builtin class) and __module__=='builtins'; socket.timeout is socket.error's more specific subtype for timeout conditions; prior to Python 3.3 socket.timeout was a distinct class; socket.timeout is TimeoutError evaluates to True; both socket.error and socket.timeout have __module__=='builtins' since they are aliases for OSError and TimeoutError respectively; NEW in socket_extra211: first standalone socket.timeout.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.timeout.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true
