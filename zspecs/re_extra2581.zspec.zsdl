spec: re_extra2581
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flag constants"
    - "re_extra1771.zspec.zsdl — covers async protocol dict-presence"
  notes:
    - "Wave 2581 theme: __call__ dict-presence. None of the re classes define __call__ in their own __dict__."
    - "re.Pattern does NOT define __call__ — calling pattern(text) is NOT supported; use pattern.match(text) instead."
    - "re.Match does NOT define __call__ in its own __dict__ — match objects are data containers, not functors."
    - "re.error (alias re.PatternError in Python 3.13+) does NOT define __call__ — it is an exception class."
    - "re.Pattern.__dict__ DOES contain comparison dunders: __eq__, __ge__, __gt__, __hash__, __le__, __lt__, __ne__."
    - "re.Pattern.__dict__ DOES contain __class_getitem__, __copy__, __deepcopy__, __repr__."
    - "re.Match.__dict__ DOES contain __getitem__ and __repr__ but NOT __call__ or __iter__."
    - "In Python 3.13+, re.error is an alias for re.PatternError; both refer to the same class."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ dict-presence — re.Pattern, re.Match, re.error
# ---------------------------------------------------------------------------

table re_extra2581.re_types_no_call:
  description: "__call__ is absent from re.Pattern, re.Match, and re.error __dict__s — none are callable objects"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2581

  columns: [id, function, args, expected]
  rows:
    - ["re2581001", "re.Pattern.__dict__.__contains__", ["__call__"], false]
    - ["re2581002", "re.Match.__dict__.__contains__",   ["__call__"], false]
    - ["re2581003", "re.error.__dict__.__contains__",   ["__call__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern DOES define comparison protocol but NOT __call__
# __eq__, __hash__, __repr__ are in Pattern.__dict__; __call__ is not
# ---------------------------------------------------------------------------

table re_extra2581.pattern_comparison_protocol:
  description: "re.Pattern defines __eq__, __hash__, __repr__ (comparison/identity) but not __call__ (not a functor)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2581

  columns: [id, function, args, expected]
  rows:
    - ["re2581004", "re.Pattern.__dict__.__contains__", ["__eq__"],           true]
    - ["re2581005", "re.Pattern.__dict__.__contains__", ["__hash__"],         true]
    - ["re2581006", "re.Pattern.__dict__.__contains__", ["__repr__"],         true]
    - ["re2581007", "re.Pattern.__dict__.__contains__", ["__call__"],         false]
    - ["re2581008", "re.Pattern.__dict__.__contains__", ["__iter__"],         false]
    - ["re2581009", "re.Pattern.__dict__.__contains__", ["__class_getitem__"], true]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern defines copy protocol (__copy__, __deepcopy__)
# but NOT __call__
# ---------------------------------------------------------------------------

table re_extra2581.pattern_copy_protocol:
  description: "re.Pattern defines __copy__ and __deepcopy__ (copy protocol) but not __call__ or __iter__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2581

  columns: [id, function, args, expected]
  rows:
    - ["re2581010", "re.Pattern.__dict__.__contains__", ["__copy__"],     true]
    - ["re2581011", "re.Pattern.__dict__.__contains__", ["__deepcopy__"], true]
    - ["re2581012", "re.Pattern.__dict__.__contains__", ["__call__"],     false]
    - ["re2581013", "re.Pattern.__dict__.__contains__", ["__ne__"],       true]
    - ["re2581014", "re.Pattern.__dict__.__contains__", ["__ge__"],       true]

# ---------------------------------------------------------------------------
# Complementary: re.Match defines __getitem__ and __repr__ but NOT __call__
# Match objects support index access (match[group_name]) but are not functors
# ---------------------------------------------------------------------------

table re_extra2581.match_getitem_not_callable:
  description: "re.Match defines __getitem__ (index access) and __repr__ but NOT __call__ or __iter__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2581

  columns: [id, function, args, expected]
  rows:
    - ["re2581015", "re.Match.__dict__.__contains__", ["__getitem__"], true]
    - ["re2581016", "re.Match.__dict__.__contains__", ["__repr__"],    true]
    - ["re2581017", "re.Match.__dict__.__contains__", ["__call__"],    false]
    - ["re2581018", "re.Match.__dict__.__contains__", ["__iter__"],    false]
    - ["re2581019", "re.error.__dict__.__contains__", ["__init__"],    true]
    - ["re2581020", "re.error.__dict__.__contains__", ["__call__"],    false]
