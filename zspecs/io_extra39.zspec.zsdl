spec: io_extra39
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra38.zspec.zsdl — covers StringIO/BytesIO/BufferedWriter/TextIOWrapper/BufferedRWPair/BufferedRandom __mro__.__len__()==4; StringIO/TextIOWrapper __bases__[0].__name__.__len__()==11 ('_TextIOBase'); BytesIO/BufferedWriter/BufferedRWPair/BufferedRandom __bases__[0].__name__.__len__()==15 ('_BufferedIOBase'); SEEK_CUR/SEEK_END __class__.__name__.__len__()==3; StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline."
  notes:
    - "This spec extends io_extra38.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO/BufferedWriter/TextIOWrapper/BufferedRWPair/BufferedRandom; __bases__[0].__name__/__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/TextIOWrapper/BytesIO/BufferedWriter/BufferedRWPair/BufferedRandom; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper method qualname lengths."
    - "This spec covers NEW angles: io.FileIO.__mro__.__len__()==4; io.BufferedReader.__mro__.__len__()==4; io.FileIO.__bases__[0].__name__.__len__()==10 ('_RawIOBase'); io.BufferedReader.__bases__[0].__name__.__len__()==15 ('_BufferedIOBase'); io.FileIO.__name__.__len__()==6 and __qualname__.__len__()==6; io.BufferedReader.__name__.__len__()==14 and __qualname__.__len__()==14; io.BufferedReader method __qualname__.__len__() for read(19)/readline(23)/readinto(23)/peek(19); io.FileIO method __qualname__.__len__() for read(11)/write(12)/seek(11)/readinto(15)."
    - "io.FileIO.__mro__ == [FileIO, _RawIOBase, _IOBase, object] — len 4. '_RawIOBase' len == 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__mro__ == [BufferedReader, _BufferedIOBase, _IOBase, object] — len 4. '_BufferedIOBase' len == 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (19). readline == 'BufferedReader.readline' (23). readinto == 'BufferedReader.readinto' (23). peek == 'BufferedReader.peek' (19). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.FileIO.read.__qualname__ == 'FileIO.read' (11). write == 'FileIO.write' (12). seek == 'FileIO.seek' (11). readinto == 'FileIO.readinto' (15). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FileIO and BufferedReader __mro__.__len__() == 4
#
# io_extra38 covered StringIO/BytesIO/BufferedWriter/TextIOWrapper/BufferedRWPair/BufferedRandom.
# FileIO and BufferedReader were not included in any prior __mro__.__len__() check.
# Both have MRO depth 4:
#   FileIO       -> _RawIOBase    -> _IOBase -> object
#   BufferedReader -> _BufferedIOBase -> _IOBase -> object
# ---------------------------------------------------------------------------

table io_extra39.file_reader_mro_len:
  description: "io.FileIO and BufferedReader __mro__.__len__() == 4 — both have MRO depth 4"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ifrm39

  columns: [id, function, args, expected]
  rows:
    - [FileIO,         FileIO.__mro__.__len__,         [], 4]
    - [BufferedReader, BufferedReader.__mro__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# FileIO and BufferedReader __bases__[0].__name__.__len__()
#
# FileIO inherits from _RawIOBase (len 10).
# BufferedReader inherits from _BufferedIOBase (len 15).
# No prior io spec checks __bases__[0].__name__.__len__() for either class.
# ---------------------------------------------------------------------------

invariant io_extra39.FileIO_base_name_len:
  description: "io.FileIO.__bases__[0].__name__.__len__() == 10 — '_RawIOBase' has 10 characters"
  category: class_introspection
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__len__"
  args: []
  expected: 10

invariant io_extra39.BufferedReader_base_name_len:
  description: "io.BufferedReader.__bases__[0].__name__.__len__() == 15 — '_BufferedIOBase' has 15 characters"
  category: class_introspection
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# FileIO and BufferedReader __name__.__len__() and __qualname__.__len__()
#
# FileIO.__name__ == 'FileIO' (len 6). FileIO.__qualname__ == 'FileIO' (len 6).
# BufferedReader.__name__ == 'BufferedReader' (len 14). __qualname__ same (14).
# No prior io spec covers __qualname__.__len__() for FileIO or BufferedReader
# (only __name__.__len__() context existed in earlier specs for other classes).
# ---------------------------------------------------------------------------

table io_extra39.class_name_qualname_lens:
  description: "io.FileIO and BufferedReader __name__.__len__() and __qualname__.__len__()"
  kind: python_call_eq
  category: class_introspection
  id_prefix: icnq39

  columns: [id, function, args, expected]
  rows:
    - [FileIO_name_len,           FileIO.__name__.__len__,           [], 6]
    - [FileIO_qualname_len,       FileIO.__qualname__.__len__,       [], 6]
    - [BufferedReader_name_len,   BufferedReader.__name__.__len__,   [], 14]
    - [BufferedReader_qualname_len, BufferedReader.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# BufferedReader method __qualname__.__len__()
#
# io_extra38 covered StringIO/BytesIO/TextIOWrapper method qualname lengths.
# No prior spec checks BufferedReader method qualname lengths.
# BufferedReader.read     -> 'BufferedReader.read'     (len 19)
# BufferedReader.readline -> 'BufferedReader.readline' (len 23)
# BufferedReader.readinto -> 'BufferedReader.readinto' (len 23)
# BufferedReader.peek     -> 'BufferedReader.peek'     (len 19)
# ---------------------------------------------------------------------------

table io_extra39.BufferedReader_method_qualname_lens:
  description: "io.BufferedReader method __qualname__ lengths — read(19)/readline(23)/readinto(23)/peek(19)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ibrm39

  columns: [id, function, args, expected]
  rows:
    - [read,     BufferedReader.read.__qualname__.__len__,     [], 19]
    - [readline, BufferedReader.readline.__qualname__.__len__, [], 23]
    - [readinto, BufferedReader.readinto.__qualname__.__len__, [], 23]
    - [peek,     BufferedReader.peek.__qualname__.__len__,     [], 19]

# ---------------------------------------------------------------------------
# FileIO method __qualname__.__len__()
#
# No prior spec checks FileIO method qualname lengths.
# FileIO.read     -> 'FileIO.read'     (len 11)
# FileIO.write    -> 'FileIO.write'    (len 12)
# FileIO.seek     -> 'FileIO.seek'     (len 11)
# FileIO.readinto -> 'FileIO.readinto' (len 15)
# ---------------------------------------------------------------------------

table io_extra39.FileIO_method_qualname_lens:
  description: "io.FileIO method __qualname__ lengths — read(11)/write(12)/seek(11)/readinto(15)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ifm39

  columns: [id, function, args, expected]
  rows:
    - [read,     FileIO.read.__qualname__.__len__,     [], 11]
    - [write,    FileIO.write.__qualname__.__len__,    [], 12]
    - [seek,     FileIO.seek.__qualname__.__len__,     [], 11]
    - [readinto, FileIO.readinto.__qualname__.__len__, [], 15]
