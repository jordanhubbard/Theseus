spec: theseus_faulthandler_cr
version: ">=3.0"
backend: python_cleanroom(theseus_faulthandler_cr)
blocks: faulthandler

docs: https://docs.python.org/3/library/faulthandler.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/faulthandler.html"
  not_derived_from:
    - "CPython source: Modules/faulthandler.c"
  notes:
    - "Clean-room faulthandler module. Do NOT import faulthandler."

error_model: python_exceptions

invariant theseus_faulthandler_cr.faulthandler2_enable:
  description: "enable() and disable() functions exist"
  category: behavior
  kind: python_call_eq
  function: faulthandler2_enable
  args: []
  expected: true

invariant theseus_faulthandler_cr.faulthandler2_is_enabled:
  description: "is_enabled() returns a boolean"
  category: behavior
  kind: python_call_eq
  function: faulthandler2_is_enabled
  args: []
  expected: true

invariant theseus_faulthandler_cr.faulthandler2_dump_traceback:
  description: "dump_traceback() function exists"
  category: behavior
  kind: python_call_eq
  function: faulthandler2_dump_traceback
  args: []
  expected: true
