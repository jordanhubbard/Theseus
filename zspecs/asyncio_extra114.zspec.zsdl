spec: asyncio_extra114
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra113.zspec.zsdl."
    - "This spec covers: wave 255 theme — asyncio.Condition and asyncio.BoundedSemaphore class identity and method qualnames not covered in extra110-extra113. NEW in extra114: asyncio.Condition.__name__=='Condition' (len=9); asyncio.Condition.__module__=='asyncio.locks' (len=13); asyncio.Condition.__mro__.__len__()==4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin'; asyncio.Condition.notify_all.__qualname__=='Condition.notify_all' (len=20, co_argcount=1); asyncio.Condition.wait_for.__qualname__=='Condition.wait_for' (len=18, co_argcount=2); asyncio.Condition.notify.__qualname__=='Condition.notify' (len=16, co_argcount=2); asyncio.Condition.__init__.__qualname__=='Condition.__init__' (len=18, co_argcount=2); asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16); asyncio.BoundedSemaphore.__mro__.__len__()==5; asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore'; asyncio.BoundedSemaphore.__init__.__qualname__=='BoundedSemaphore.__init__' (len=25, co_argcount=2); asyncio.BoundedSemaphore.release.__qualname__=='BoundedSemaphore.release' (len=24, co_argcount=1). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Condition.__mro__.__len__() == 4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); same depth as asyncio.Semaphore.__mro__.__len__()==4. asyncio.Condition.notify_all.__qualname__=='Condition.notify_all' (len=20: 'Condition.'=10+'notify_all'=10=20; longest method qualname in spec). asyncio.Condition.notify.__code__.co_argcount==2 (self and n — n is the number of waiting coroutines to wake up, default=1). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__mro__.__len__() == 5 ([BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); one deeper than Semaphore (len=4) because BoundedSemaphore inherits from Semaphore. asyncio.BoundedSemaphore.__init__.__qualname__=='BoundedSemaphore.__init__' (len=25: 'BoundedSemaphore.'=17+'__init__'=8=25). asyncio.BoundedSemaphore.release.__qualname__=='BoundedSemaphore.release' (len=24: 'BoundedSemaphore.'=17+'release'=7=24). Note: BoundedSemaphore.locked and BoundedSemaphore.acquire inherit from Semaphore, so their qualnames use 'Semaphore.' prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Condition class identity — extra114
#
# Wave 255 theme: Condition __name__, __module__, __mro__, __bases__ identity.
#
# asyncio.Condition.__name__                == 'Condition'            (len=9)
# asyncio.Condition.__module__              == 'asyncio.locks'        (len=13)
# asyncio.Condition.__mro__.__len__()       == 4
# asyncio.Condition.__bases__[0].__name__   == '_ContextManagerMixin'
# ---------------------------------------------------------------------------

table asyncio_extra114.asyncio_condition_identity:
  description: "asyncio.Condition class identity checks in asynciocond114 namespace — wave 255 theme: asyncio.Condition.__name__.__eq__('Condition')==True (len=9: 'Condition'=9; Condition provides a synchronization primitive that allows coroutines to wait for some condition to be true); asyncio.Condition.__name__.__len__()==9; asyncio.Condition.__qualname__.__eq__('Condition')==True (len=9; qualname equals name for a top-level class); asyncio.Condition.__module__.__eq__('asyncio.locks')==True (len=13: 'asyncio.locks'=13; same module as Event and Semaphore from extra113); asyncio.Condition.__module__.__len__()==13; asyncio.Condition.__mro__.__len__()==4 (MRO=[Condition, _ContextManagerMixin, _LoopBoundMixin, object]; 4-level chain — same depth as Semaphore from extra113); asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Condition supports 'async with' syntax; same as Semaphore from extra113); compare: Condition.__name__ len=9 matches Semaphore.__name__ len=9 (both 9 chars); compare: Condition.__mro__.__len__()==4 matches Semaphore.__mro__.__len__()==4; compare: BoundedSemaphore.__mro__.__len__()==5 (one deeper than Condition because it adds Semaphore as intermediate); asyncio.Condition.__module__.__len__()==13 matches asyncio.Semaphore.__module__.__len__()==13 (both in asyncio.locks); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocond114

  columns: [id, function, args, expected, description]
  rows:
    - [cond_name_eq,       asyncio.Condition.__name__.__eq__,                           ["Condition"],           true, "Condition.__name__ == 'Condition' (len=9); verified with Python 3.14.3"]
    - [cond_name_len,      asyncio.Condition.__name__.__len__,                          [],                      9,    "Condition.__name__.__len__() == 9 ('Condition'=9); verified with Python 3.14.3"]
    - [cond_qn_eq,         asyncio.Condition.__qualname__.__eq__,                       ["Condition"],           true, "Condition.__qualname__ == 'Condition' (len=9, qualname equals name for top-level class); verified with Python 3.14.3"]
    - [cond_module_eq,     asyncio.Condition.__module__.__eq__,                         ["asyncio.locks"],       true, "Condition.__module__ == 'asyncio.locks' (len=13, same as Event and Semaphore); verified with Python 3.14.3"]
    - [cond_module_len,    asyncio.Condition.__module__.__len__,                        [],                      13,   "Condition.__module__.__len__() == 13 ('asyncio.locks'=13); verified with Python 3.14.3"]
    - [cond_mro_len,       asyncio.Condition.__mro__.__len__,                           [],                      4,    "Condition.__mro__.__len__() == 4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [cond_base_eq,       "asyncio.Condition.__bases__[0].__name__.__eq__",            ["_ContextManagerMixin"], true, "Condition.__bases__[0].__name__ == '_ContextManagerMixin' (supports 'async with'); verified with Python 3.14.3"]

