# ---------------------------------------------------------------------------
# Standalone invariants — extra114
# ---------------------------------------------------------------------------

invariant asyncio_extra114.Condition_notify_all_qualname_len_20:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — 'Condition.notify_all' = 'Condition.'=10 + 'notify_all'=10 = 20; this is the longest method qualname in this spec; asyncio.Condition.notify_all.__qualname__.__eq__('Condition.notify_all')==True; asyncio.Condition.notify_all.__code__.co_argcount==1 (self only — notify_all wakes ALL waiting coroutines; compare: Condition.notify.__code__.co_argcount==2 — notify wakes n waiters where n is a parameter); asyncio.Condition.notify_all.__code__.co_name=='notify_all'; compare qualname lengths in spec: Condition.wait=14 (shortest) < Condition.notify=16 < Condition.wait_for=Condition.__init__=18 (tied) < Condition.notify_all=20 (longest); 'notify_all' (10 chars) is the longest method name, while 'wait' (4 chars) is the shortest; asyncio.Condition.__module__=='asyncio.locks' (len=13); asyncio.Condition.__mro__.__len__()==4; NEW in extra114: first standalone Condition.notify_all qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra114.Condition_name_len_9_eq_Semaphore:
  description: "asyncio.Condition.__name__.__len__() == 9 — 'Condition'=9 chars; asyncio.Condition.__name__.__eq__('Condition')==True; compare: asyncio.Semaphore.__name__.__len__()==9 (also 9 chars — 'Semaphore'=9) — Condition and Semaphore have the same class name length; asyncio.BoundedSemaphore.__name__.__len__()==16 (7 chars longer than Condition); asyncio.Event.__name__.__len__()==5 (4 chars shorter than Condition); class name length ordering from extra113 and extra114: Event=5 < Condition=Semaphore=9 (tied) < BoundedSemaphore=16; asyncio.Condition.__module__=='asyncio.locks' (len=13); asyncio.Condition.__mro__.__len__()==4; asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin'; NEW in extra114: first standalone Condition name length invariant; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__name__.__len__
  args: []
  expected: 9

invariant asyncio_extra114.BoundedSemaphore_mro_len_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — BoundedSemaphore MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=5); this is the deepest MRO in this spec; asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore is a direct subclass of Semaphore, adding one extra level to Semaphore's MRO of 4); compare MRO lengths across asyncio lock classes: Event.__mro__.__len__()==3 < Semaphore.__mro__.__len__()==Condition.__mro__.__len__()==4 (tied) < BoundedSemaphore.__mro__.__len__()==5 (deepest); asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16); asyncio.BoundedSemaphore.__module__=='asyncio.locks' (len=13); asyncio.BoundedSemaphore raises ValueError if release() is called more times than acquire() — the extra check is the only difference from Semaphore; NEW in extra114: first standalone BoundedSemaphore MRO length invariant; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5

invariant asyncio_extra114.BoundedSemaphore_init_qualname_len_25:
  description: "asyncio.BoundedSemaphore.__init__.__qualname__.__len__() == 25 — 'BoundedSemaphore.__init__' = 'BoundedSemaphore.'=17 + '__init__'=8 = 25; this is the longest method qualname in this spec; asyncio.BoundedSemaphore.__init__.__qualname__.__eq__('BoundedSemaphore.__init__')==True; asyncio.BoundedSemaphore.__init__.__code__.co_argcount==2 (self and value — value is the initial counter value, same as Semaphore.__init__); compare qualname lengths for __init__ methods: Condition.__init__=18 < Semaphore.__init__=18 (tied, from extra113) < BoundedSemaphore.__init__=25 (longest — 7 chars more because 'BoundedSemaphore.'=17 vs 'Condition.'=10 vs 'Semaphore.'=10); note: BoundedSemaphore.release.__qualname__.__len__()==24 (one shorter than __init__=25); asyncio.BoundedSemaphore.__name__.__len__()==16; asyncio.BoundedSemaphore.__mro__.__len__()==5; NEW in extra114: first standalone BoundedSemaphore.__init__ qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__init__.__qualname__.__len__
  args: []
  expected: 25

invariant asyncio_extra114.BoundedSemaphore_release_qualname_len_24:
  description: "asyncio.BoundedSemaphore.release.__qualname__.__len__() == 24 — 'BoundedSemaphore.release' = 'BoundedSemaphore.'=17 + 'release'=7 = 24; asyncio.BoundedSemaphore.release.__qualname__.__eq__('BoundedSemaphore.release')==True; asyncio.BoundedSemaphore.release.__code__.co_argcount==1 (self only); asyncio.BoundedSemaphore.release.__code__.co_name=='release'; BoundedSemaphore.release overrides Semaphore.release to add a ValueError check (raises if the semaphore would exceed the initial bound value); note: BoundedSemaphore.locked and BoundedSemaphore.acquire are INHERITED from Semaphore — their qualnames are 'Semaphore.locked' (len=16) and 'Semaphore.acquire' (len=17), NOT 'BoundedSemaphore.*'; compare: BoundedSemaphore.release qualname len=24 vs BoundedSemaphore.__init__ qualname len=25 (one char longer); asyncio.BoundedSemaphore.__name__.__len__()==16; asyncio.BoundedSemaphore.__mro__.__len__()==5; NEW in extra114: first standalone BoundedSemaphore.release qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.release.__qualname__.__len__
  args: []
  expected: 24
