spec: hashlib_extra77
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra76.zspec.zsdl — covers file_digest/__code__/co_argcount/__eq__(2) / file_digest/__code__/co_varnames/__class__/__name__=='tuple' / new/__qualname__=='__hash_new' / new/__code__/co_argcount/__eq__(1) / blake2b/__qualname__=='blake2b' / blake2s/__qualname__=='blake2s' / sha3_256/__qualname__=='openssl_sha3_256' / algorithms_guaranteed/__contains__('sha256'/'md5') (table + invariants)."
    - "hashlib_extra75.zspec.zsdl — covers md5/sha256/sha1/sha512/__doc__/__class__/__name__=='str' / file_digest/__doc__.__class__.__name__=='str' / pbkdf2_hmac/__doc__.__class__.__name__=='str' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra76; it does NOT duplicate invariants present in those files."
    - "Wave 241 theme: hashlib blake2b/blake2s class identity deeper."
    - "hashlib.blake2b.__name__ == 'blake2b' — blake2b class name is 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2' — blake2b is defined in the C extension _blake2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__bases__[0].__name__ == 'object' — blake2b directly subclasses object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__.__len__() == 2 — MRO is [blake2b, object], length 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__class__.__name__ == 'mappingproxy' — C type __dict__ is a mappingproxy. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s' — blake2s class name is 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2' — blake2s is defined in the C extension _blake2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__bases__[0].__name__ == 'object' — blake2s directly subclasses object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__.__len__() == 2 — MRO is [blake2s, object], length 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__.__class__.__name__ == 'str' — blake2b has a string docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b __name__ and __module__
#
# Wave 241 theme: hashlib blake2b/blake2s class identity deeper.
#
# hashlib.blake2b is a C type defined in the _blake2 extension module.
# Its __name__ is 'blake2b' and __module__ is '_blake2'. No prior hashlib
# spec checks blake2b.__name__ or blake2b.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra77.blake2b_name_module:
  description: "hashlib.blake2b/__name__.__eq__('blake2b')==True / blake2b/__module__.__eq__('_blake2')==True — blake2b is a C type; __name__ is 'blake2b'; __module__ is '_blake2' (the C extension); no prior hashlib spec checks blake2b.__name__ or blake2b.__module__; first name and module anchor for blake2b"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore77

  columns: [id, function, args, expected]
  rows:
    - [blake2b_name_blake2b,    blake2b.__name__.__eq__,   ["blake2b"], true]
    - [blake2b_module__blake2,  blake2b.__module__.__eq__,  ["_blake2"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b __bases__[0].__name__ and __mro__.__len__()
#
# Wave 241 theme: hashlib blake2b class hierarchy identity.
#
# hashlib.blake2b directly subclasses object (__bases__[0].__name__ == 'object').
# Its MRO is [blake2b, object], so __mro__.__len__() == 2. No prior hashlib
# spec checks blake2b.__bases__[0].__name__ or blake2b.__mro__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra77.blake2b_bases_mro:
  description: "hashlib.blake2b/__bases__[0]/__name__.__eq__('object')==True / blake2b/__mro__.__len__()==2 — blake2b directly subclasses object; MRO is [blake2b, object] with length 2; no prior hashlib spec checks blake2b.__bases__[0].__name__ or blake2b.__mro__.__len__(); first bases and MRO length anchor for blake2b"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore77

  columns: [id, function, args, expected]
  rows:
    - ["blake2b_bases0_object", "blake2b.__bases__[0].__name__.__eq__", ["object"], true]
    - [blake2b_mro_len_2,       blake2b.__mro__.__len__,                [],         2]

# ---------------------------------------------------------------------------
# hashlib.blake2s __name__ and __module__
#
# Wave 241 theme: hashlib blake2s class identity (mirrors blake2b).
#
# hashlib.blake2s is a C type defined in the _blake2 extension module.
# Its __name__ is 'blake2s' and __module__ is '_blake2'. No prior hashlib
# spec checks blake2s.__name__ or blake2s.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra77.blake2s_name_module:
  description: "hashlib.blake2s/__name__.__eq__('blake2s')==True / blake2s/__module__.__eq__('_blake2')==True — blake2s is a C type; __name__ is 'blake2s'; __module__ is '_blake2' (the C extension); no prior hashlib spec checks blake2s.__name__ or blake2s.__module__; first name and module anchor for blake2s"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore77

  columns: [id, function, args, expected]
  rows:
    - [blake2s_name_blake2s,   blake2s.__name__.__eq__,   ["blake2s"], true]
    - [blake2s_module__blake2, blake2s.__module__.__eq__,  ["_blake2"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2s __bases__[0].__name__ / __mro__.__len__() / __dict__.__class__.__name__
# + blake2b.__doc__.__class__.__name__
#
# Wave 241 theme: hashlib blake2s class hierarchy + dict class + blake2b doc class.
#
# hashlib.blake2s directly subclasses object; MRO length is 2. blake2b and
# blake2s __dict__ are mappingproxy objects. blake2b has a string docstring.
# No prior hashlib spec checks blake2s.__bases__[0].__name__, blake2s.__mro__.__len__(),
# blake2b.__dict__.__class__.__name__, or blake2b.__doc__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra77.blake2s_hierarchy_and_dict_doc:
  description: "hashlib.blake2s/__bases__[0]/__name__.__eq__('object')==True / blake2s/__mro__.__len__()==2 / blake2b/__dict__/__class__/__name__.__eq__('mappingproxy')==True / blake2b/__doc__/__class__/__name__.__eq__('str')==True — blake2s subclasses object with MRO length 2; blake2b __dict__ is a mappingproxy; blake2b has a string docstring; no prior hashlib spec checks these attributes; first combined hierarchy+dict+doc anchor for blake2b/blake2s"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore77

  columns: [id, function, args, expected]
  rows:
    - ["blake2s_bases0_object",       "blake2s.__bases__[0].__name__.__eq__",      ["object"],      true]
    - [blake2s_mro_len_2,              blake2s.__mro__.__len__,                     [],              2]
    - [blake2b_dict_class_mappingproxy, blake2b.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [blake2b_doc_class_str,          blake2b.__doc__.__class__.__name__.__eq__,   ["str"],         true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__name__ is 'blake2b'. No prior hashlib spec checks
# blake2b.__name__. First __name__ standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra77.blake2b_name_blake2b:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — blake2b C type has __name__ 'blake2b'; no prior hashlib spec checks blake2b.__name__; first __name__ standalone for blake2b"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# hashlib.blake2b.__module__ is '_blake2'. No prior hashlib spec checks
# blake2b.__module__. First __module__ standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra77.blake2b_module__blake2:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — blake2b is defined in the _blake2 C extension module; no prior hashlib spec checks blake2b.__module__; first __module__ standalone for blake2b"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__mro__.__len__() == 2 — standalone
#
# hashlib.blake2b.__mro__ is (blake2b, object), length 2. No prior hashlib
# spec checks blake2b.__mro__.__len__(). First MRO length standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra77.blake2b_mro_len_2:
  description: "hashlib.blake2b.__mro__.__len__() == 2 — MRO is (blake2b, object), length 2; no prior hashlib spec checks blake2b.__mro__.__len__(); first MRO length standalone for blake2b"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# hashlib.blake2s.__module__.__eq__('_blake2') — standalone
#
# hashlib.blake2s.__module__ is '_blake2'. No prior hashlib spec checks
# blake2s.__module__. First __module__ standalone for blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra77.blake2s_module__blake2:
  description: "hashlib.blake2s.__module__.__eq__('_blake2') == True — blake2s is defined in the _blake2 C extension module; no prior hashlib spec checks blake2s.__module__; first __module__ standalone for blake2s"
  category: class_identity
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# hashlib.blake2b.__dict__ is a mappingproxy (C types use mappingproxy for
# their namespace). No prior hashlib spec checks blake2b.__dict__.__class__.__name__.
# First __dict__ class standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra77.blake2b_dict_class_mappingproxy:
  description: "hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') == True — C types use mappingproxy for their __dict__; no prior hashlib spec checks blake2b.__dict__.__class__.__name__; first __dict__ class standalone for blake2b"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
