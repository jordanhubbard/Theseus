spec: hashlib_extra84
version: ">=3.9"
extends: hashlib_extra83
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra83.zspec.zsdl — covers sha256/sha512/md5/sha1/blake2b/blake2s __doc__.__class__.__name__ and algorithms_guaranteed/algorithms_available membership (table + invariants)."
    - "hashlib_extra82.zspec.zsdl — covers sha1/sha224/sha384/sha3_224/sha3_384/sha3_512/shake_128/shake_256 __name__/__qualname__/__module__/__class__.__name__ (table + invariants)."
    - "hashlib_extra81.zspec.zsdl — covers sha256/__name__/__qualname__/__module__ / md5/__name__/__qualname__/__module__ / new/__class__/__name__/__module__/__qualname__ / algorithms_available/__class__/__name__ / sha512/__name__ (table + invariants)."
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants and hexdigest/__class__/__name__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra83; it does NOT duplicate invariants present in those files."
    - "Wave 248 theme: hashlib sha256/sha512/md5/sha1 __qualname__ string value and length, plus sha3_256/sha3_512/sha224/sha384/blake2b/blake2s/new qualname lengths and algorithms_guaranteed.__len__()."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256' — the qualname is 'openssl_sha256' (14 chars). No prior hashlib spec checks sha256.__qualname__.__eq__ or __len__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__.__len__() == 14 — 'openssl_sha512' is 14 chars. No prior hashlib spec checks sha512.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__.__len__() == 11 — 'openssl_md5' is 11 chars. No prior hashlib spec checks md5.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__len__() == 12 — 'openssl_sha1' is 12 chars. No prior hashlib spec checks sha1.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__.__len__() == 14 — 'openssl_sha224' is 14 chars. No prior hashlib spec checks sha224.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__.__len__() == 14 — 'openssl_sha384' is 14 chars. No prior hashlib spec checks sha384.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__len__() == 16 — 'openssl_sha3_256' is 16 chars. No prior hashlib spec checks sha3_256.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__.__len__() == 16 — 'openssl_sha3_512' is 16 chars. No prior hashlib spec checks sha3_512.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__.__len__() == 7 — 'blake2b' is 7 chars. No prior hashlib spec checks blake2b.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__.__len__() == 7 — 'blake2s' is 7 chars. No prior hashlib spec checks blake2s.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__.__len__() == 10 — '__hash_new' is 10 chars. No prior hashlib spec checks new.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__class__.__name__ == 'str' — the docstring is a str. No prior hashlib spec checks new.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14 — there are 14 guaranteed algorithms. No prior hashlib spec checks algorithms_guaranteed.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256/__qualname__.__eq__('openssl_sha256') / sha512/__qualname__.__len__()
# hashlib.md5/__qualname__.__len__() / sha1/__qualname__.__len__()
#
# Wave 248 theme: sha256 qualname string value and sha512/md5/sha1 qualname lengths.
#
# sha256.__qualname__ == 'openssl_sha256' (14 chars). sha512.__qualname__ is
# 'openssl_sha512' (14 chars). md5.__qualname__ is 'openssl_md5' (11 chars).
# sha1.__qualname__ is 'openssl_sha1' (12 chars). No prior hashlib spec checks
# any of these __qualname__.__eq__ or __qualname__.__len__() values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra84.sha256_qualname_and_sha_lengths:
  description: "hashlib.sha256/__qualname__.__eq__('openssl_sha256')==True / sha512/__qualname__/__len__()==14 / md5/__qualname__/__len__()==11 / sha1/__qualname__/__len__()==12 — sha256 qualname is 'openssl_sha256'; sha512/md5/sha1 openssl qualname lengths are 14/11/12; no prior hashlib spec checks sha256.__qualname__.__eq__ or any __qualname__.__len__(); first qualname value and length anchor for sha256/sha512/md5/sha1"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra84

  columns: [id, function, args, expected]
  rows:
    - [sha256_qualname_eq_openssl_sha256, sha256.__qualname__.__eq__, ["openssl_sha256"], true]
    - [sha512_qualname_len_14,            sha512.__qualname__.__len__, [],                14]
    - [md5_qualname_len_11,               md5.__qualname__.__len__,    [],                11]
    - [sha1_qualname_len_12,              sha1.__qualname__.__len__,   [],                12]

# ---------------------------------------------------------------------------
# hashlib.sha224/__qualname__.__len__() / sha384/__qualname__.__len__()
# hashlib.sha3_256/__qualname__.__len__() / sha3_512/__qualname__.__len__()
#
# Wave 248 theme: sha224/sha384/sha3_256/sha3_512 qualname lengths.
#
# sha224.__qualname__ is 'openssl_sha224' (14), sha384 is 'openssl_sha384' (14).
# sha3_256 is 'openssl_sha3_256' (16), sha3_512 is 'openssl_sha3_512' (16).
# No prior hashlib spec checks any of these __qualname__.__len__() values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra84.sha224_sha384_sha3_qualname_lengths:
  description: "hashlib.sha224/__qualname__/__len__()==14 / sha384/__qualname__/__len__()==14 / sha3_256/__qualname__/__len__()==16 / sha3_512/__qualname__/__len__()==16 — openssl-backed SHA variants have qualname lengths 14/14/16/16; no prior hashlib spec checks any of these __qualname__.__len__() values; first qualname length anchor for sha224/sha384/sha3_256/sha3_512"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra84

  columns: [id, function, args, expected]
  rows:
    - [sha224_qualname_len_14,  sha224.__qualname__.__len__,   [], 14]
    - [sha384_qualname_len_14,  sha384.__qualname__.__len__,   [], 14]
    - [sha3_256_qualname_len_16, sha3_256.__qualname__.__len__, [], 16]
    - [sha3_512_qualname_len_16, sha3_512.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__qualname__.__len__() / blake2s/__qualname__.__len__()
# hashlib.new/__qualname__.__len__() / new/__doc__/__class__/__name__
#
# Wave 248 theme: blake2b/blake2s/new qualname lengths and new docstring class name.
#
# blake2b.__qualname__ is 'blake2b' (7), blake2s is 'blake2s' (7).
# new.__qualname__ is '__hash_new' (10). new.__doc__.__class__.__name__ == 'str'.
# No prior hashlib spec checks any of these __qualname__.__len__() or new.__doc__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra84.blake2_new_qualname_lengths:
  description: "hashlib.blake2b/__qualname__/__len__()==7 / blake2s/__qualname__/__len__()==7 / new/__qualname__/__len__()==10 / new/__doc__/__class__/__name__.__eq__('str')==True — blake2b/blake2s qualnames are short non-openssl names; new's qualname is '__hash_new' (10 chars); new's docstring is a str; no prior hashlib spec checks these __qualname__.__len__() or new.__doc__.__class__.__name__; first qualname length anchor for blake2b/blake2s/new"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra84

  columns: [id, function, args, expected]
  rows:
    - [blake2b_qualname_len_7,        blake2b.__qualname__.__len__,               [],      7]
    - [blake2s_qualname_len_7,        blake2s.__qualname__.__len__,               [],      7]
    - [new_qualname_len_10,           new.__qualname__.__len__,                   [],      10]
    - [new_doc_class_name_str,        new.__doc__.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__() / algorithms_guaranteed.__contains__('sha224')
# hashlib.algorithms_guaranteed.__contains__('sha3_224') / algorithms_guaranteed.__contains__('shake_128')
#
# Wave 248 theme: algorithms_guaranteed length and extended membership.
#
# algorithms_guaranteed has 14 members (sha1, sha224, sha256, sha384, sha512,
# sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256, md5, blake2b, blake2s).
# sha224, sha3_224, shake_128 are guaranteed. No prior hashlib spec checks
# algorithms_guaranteed.__len__() or __contains__ for sha224/sha3_224/shake_128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra84.algorithms_guaranteed_len_and_membership:
  description: "hashlib.algorithms_guaranteed/__len__()==14 / __contains__('sha224')==True / __contains__('sha3_224')==True / __contains__('shake_128')==True — algorithms_guaranteed has 14 members; sha224/sha3_224/shake_128 are all guaranteed; no prior hashlib spec checks algorithms_guaranteed.__len__() or these three __contains__ calls; first length and extended membership anchor for algorithms_guaranteed"
  kind: python_call_eq
  category: module_attrs
  id_prefix: hashlibextra84

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_len_14,      algorithms_guaranteed.__len__,           [],            14]
    - [algorithms_guaranteed_sha224,      algorithms_guaranteed.__contains__,      ["sha224"],    true]
    - [algorithms_guaranteed_sha3_224,    algorithms_guaranteed.__contains__,      ["sha3_224"],  true]
    - [algorithms_guaranteed_shake_128,   algorithms_guaranteed.__contains__,      ["shake_128"], true]

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__eq__('openssl_sha256') — standalone
#
# sha256.__qualname__ is 'openssl_sha256'. No prior hashlib spec checks
# sha256.__qualname__.__eq__. First qualname __eq__ standalone for hashlib.sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra84.sha256_qualname_openssl_sha256:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256') == True — sha256 is backed by OpenSSL; its qualname is 'openssl_sha256'; no prior hashlib spec checks sha256.__qualname__.__eq__; first qualname eq standalone for hashlib.sha256"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__len__() — standalone
#
# sha256.__qualname__ is 14 chars. No prior hashlib spec checks this.
# First __qualname__.__len__() standalone for hashlib.sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra84.sha256_qualname_len_14:
  description: "hashlib.sha256.__qualname__.__len__() == 14 — 'openssl_sha256' is 14 characters; no prior hashlib spec checks sha256.__qualname__.__len__(); first qualname length standalone for hashlib.sha256"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__len__() — standalone
#
# blake2b.__qualname__ is 'blake2b' (7 chars). No prior hashlib spec checks
# blake2b.__qualname__.__len__(). First qualname length standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra84.blake2b_qualname_len_7:
  description: "hashlib.blake2b.__qualname__.__len__() == 7 — 'blake2b' is 7 characters (not openssl-prefixed); no prior hashlib spec checks blake2b.__qualname__.__len__(); first qualname length standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__() — standalone
#
# algorithms_guaranteed has 14 members. No prior hashlib spec checks
# algorithms_guaranteed.__len__(). First __len__ standalone for algorithms_guaranteed.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra84.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — there are 14 algorithms guaranteed on all Python platforms; no prior hashlib spec checks algorithms_guaranteed.__len__(); first __len__ standalone for hashlib.algorithms_guaranteed"
  category: module_attrs
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.new.__doc__.__class__.__name__.__eq__('str') — standalone
#
# new.__doc__ is a str (not None). No prior hashlib spec checks
# new.__doc__.__class__.__name__. First __doc__.__class__.__name__ standalone
# for hashlib.new. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra84.new_doc_class_name_str:
  description: "hashlib.new.__doc__.__class__.__name__.__eq__('str') == True — hashlib.new has a docstring and it is a str object; no prior hashlib spec checks new.__doc__.__class__.__name__; first __doc__.__class__.__name__ standalone for hashlib.new"
  category: class_attrs
  kind: python_call_eq
  function: new.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
