spec: torch_rust
version: ">=3.9"
backend: rust_module(torch_rust)

docs: https://pytorch.org/docs/stable/index.html

provenance:
  derived_from:
    - "https://pytorch.org/docs/stable/index.html — PyTorch documentation"
  not_derived_from:
    - "torch source: torch/__init__.py"
  notes:
    - "PyTorch is a deep learning framework."
    - "torch.tensor([1.0, 2.0, 3.0]).sum().item() == 6.0."
    - "torch.tensor([1.0, 2.0, 3.0]).mean().item() == 2.0."
    - "torch.tensor([1.0, 2.0, 3.0]).shape[0] == 3."
    - "torch.zeros(3).tolist() == [0.0, 0.0, 0.0]."
    - "torch.ones(3).sum().item() == 3.0."
    - "Expose torch_sum(lst) -> float: torch.tensor(lst).sum().item()."
    - "Expose torch_mean(lst) -> float: torch.tensor(lst).mean().item()."
    - "Expose torch_shape0(lst) -> int: torch.tensor(lst).shape[0]."
    - "Expose torch_zeros_len(n) -> int: len(torch.zeros(n).tolist())."
    - "All test vectors verified against torch 2.6.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# torch_sum — sum of tensor
table torch_rust.tensor.sum:
  kind: python_call_eq
  category: sum
  id_prefix: tch_sum
  function: torch_sum

  columns: [id, args, expected]
  rows:
    - [three_vals, [[1.0, 2.0, 3.0]], 6.0]
    - [zeros,      [[0.0, 0.0, 0.0]], 0.0]
    - [one,        [[5.0]],           5.0]

# torch_mean — mean of tensor
table torch_rust.tensor.mean:
  kind: python_call_eq
  category: mean
  id_prefix: tch_mean
  function: torch_mean

  columns: [id, args, expected]
  rows:
    - [three, [[1.0, 2.0, 3.0]], 2.0]
    - [sym,   [[0.0, 0.0]],      0.0]

# torch_shape0 — first dimension size
table torch_rust.tensor.shape0:
  kind: python_call_eq
  category: shape0
  id_prefix: tch_sh
  function: torch_shape0

  columns: [id, args, expected]
  rows:
    - [three, [[1.0, 2.0, 3.0]], 3]
    - [one,   [[5.0]],           1]

# torch_zeros_len — zeros tensor length
invariant torch_rust.zeros.length:
  description: "torch.zeros(3) has length 3"
  category: zeros
  kind: python_call_eq
  function: torch_zeros_len
  args: [3]
  expected: 3

