spec: io_extra59
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra58.zspec.zsdl — covers BytesIO/StringIO/BufferedReader/BufferedWriter/open __module__.__len__()==3 (NOVEL in extra58); class __module__.__eq__() namespace anchors for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/'_io'; IOBase/RawIOBase/'io'; open/'_io'."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality for read/write/seek/tell/getvalue."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase and module."
    - "io_extra55.zspec.zsdl — covers BytesIO method qualname lengths and StringIO method qualname lengths."
    - "io_extra54.zspec.zsdl — covers io concrete class __class__.__qualname__.__eq__('type') for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper; IOBase.__class__.__qualname__.__eq__('ABCMeta'); open.__class__.__qualname__.__eq__('builtin_function_or_method'); DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int')."
    - "io_extra53.zspec.zsdl — covers concrete io class __class__.__name__.__len__()==4; IOBase.__class__.__name__.__eq__('ABCMeta'); open.__name__/__qualname__.__len__()==4; open.__class__.__name__.__eq__('builtin_function_or_method')."
    - "io_extra52.zspec.zsdl — covers BufferedRandom.__module__.__len__()==3; IncrementalNewlineDecoder.__module__.__len__()==3."
    - "io_extra35.zspec.zsdl — covers FileIO.__module__.__len__()==3; TextIOWrapper.__module__.__len__()==3."
    - "io_extra34.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__len__()==2."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra25.zspec.zsdl — covers open.__module__.__eq__('_io')."
    - "io_extra47.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__bases__[0].__name__ — IOBase.__module__=='io'; RawIOBase.__module__=='io'; BufferedIOBase.__module__=='io'; TextIOBase.__module__=='io'."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
  notes:
    - "This spec extends io_extra58.zspec.zsdl."
    - "Prior specs collectively covered: __module__.__eq__() for all major io classes (io_extra22/io_extra45/io_extra46/io_extra47); __module__.__len__() for FileIO/TextIOWrapper (io_extra35); BufferedRandom/IncrementalNewlineDecoder (io_extra52); IOBase/RawIOBase/BufferedIOBase/TextIOBase (io_extra34, len==2); BytesIO/StringIO/BufferedReader/BufferedWriter/open (io_extra58, len==3); DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int') (io_extra54); open.__module__.__eq__('_io') (io_extra25/io_extra6); open.__name__.__eq__('open') (io_extra3); open.__qualname__.__eq__('open') (io_extra33)."
    - "This spec covers: io.DEFAULT_BUFFER_SIZE.__class__.__module__.__eq__('builtins') (NOVEL — no prior io spec chains DEFAULT_BUFFER_SIZE.__class__.__module__; DEFAULT_BUFFER_SIZE is an int; int.__module__=='builtins'; novel class-module-of-constant anchor in ioconst59 namespace); io.DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int') (namespace anchor from io_extra54; consolidated here); io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__('int') (namespace anchor from io_extra22; consolidated); io.BufferedIOBase.__module__.__eq__('io') (namespace anchor; io_extra47 covers this for IOBase/RawIOBase/BufferedIOBase/TextIOBase; consolidated in ioconst59); io.TextIOBase.__module__.__eq__('io') (namespace anchor; io_extra47); io.BufferedIOBase.__module__.__len__()==2 (namespace anchor; io_extra34 covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__len__()==2; consolidated); io.TextIOBase.__module__.__len__()==2 (namespace anchor; io_extra34); io.DEFAULT_BUFFER_SIZE.__class__.__module__.__len__()==8 (NOVEL — 'builtins' has 8 characters; no prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__module__.__len__(); novel length anchor in ioconst59 namespace)."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__module__ == 'builtins'. DEFAULT_BUFFER_SIZE is an int constant (131072 on macOS/Darwin 25.4.0). Its __class__ is int. int.__module__ == 'builtins'. No prior io spec chains through DEFAULT_BUFFER_SIZE.__class__.__module__. Novel class-module-of-constant invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__module__.__len__() == 8. 'builtins' has 8 characters. No prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__module__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__qualname__ == 'int'. io_extra54 covers this as a novel invariant. Consolidated as ioconst59 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'. io_extra22 covers this. Consolidated as ioconst59 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__module__ == 'io'. io_extra47 covers this for IOBase/RawIOBase/BufferedIOBase/TextIOBase. The abstract base classes report __module__ == 'io' (the public module name) even though they are implemented in the C extension _io. Consolidated as ioconst59 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__module__ == 'io'. io_extra47 covers this. Consolidated as ioconst59 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__module__.__len__() == 2. 'io' has 2 characters. io_extra34 covers all four abstract bases __module__.__len__()==2. Consolidated as ioconst59 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__module__.__len__() == 2. 'io' has 2 characters. io_extra34 covers this. Consolidated as ioconst59 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE class identity (ioconst59 namespace anchors)
#
# DEFAULT_BUFFER_SIZE is the integer constant that specifies the default
# buffer size for buffered I/O operations (131072 = 128 KiB on macOS/Darwin).
# Its __class__ is int. int.__module__ == 'builtins'; int.__name__ == 'int';
# int.__qualname__ == 'int'.
#
#   DEFAULT_BUFFER_SIZE.__class__.__name__     == 'int'      (io_extra22 anchor)
#   DEFAULT_BUFFER_SIZE.__class__.__qualname__ == 'int'      (io_extra54 anchor)
#   DEFAULT_BUFFER_SIZE.__class__.__module__   == 'builtins' (NOVEL in ioconst59)
#
# DEFAULT_BUFFER_SIZE.__class__.__module__.__len__() == 8    (NOVEL in ioconst59)
# 'builtins' has 8 characters.
#
# No prior io spec chains through DEFAULT_BUFFER_SIZE.__class__.__module__.
# This is the novel invariant axis for io_extra59.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra59.default_buffer_size_class:
  description: "io.DEFAULT_BUFFER_SIZE class identity: __class__.__name__.__eq__('int') (io_extra22 anchor); __class__.__qualname__.__eq__('int') (io_extra54 anchor); __class__.__module__.__eq__('builtins') (NOVEL — no prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__module__; int is a builtin type); all three equality anchors consolidated in ioconst59 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconst59eq

  columns: [id, function, args, expected]
  rows:
    - [DBS_class_name,     DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__,     ["int"],      true]
    - [DBS_class_qualname, DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__,  ["int"],      true]
    - [DBS_class_module,   DEFAULT_BUFFER_SIZE.__class__.__module__.__eq__,   ["builtins"], true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE __class__.__module__ length (novel length anchor)
#
# int.__module__ == 'builtins' which has 8 characters.
# No prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__module__.__len__().
# Novel length anchor in ioconst59 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra59.default_buffer_size_class_module_len:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__module__.__len__()==8 — 'builtins' has 8 characters; no prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__module__.__len__(); novel length anchor in ioconst59 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: ioconst59len

  columns: [id, function, args, expected]
  rows:
    - [DBS_class_module_len, DEFAULT_BUFFER_SIZE.__class__.__module__.__len__, [], 8]

# ---------------------------------------------------------------------------
# io abstract base class __module__ equality (ioconst59 namespace anchors)
#
# The four abstract base classes — IOBase, RawIOBase, BufferedIOBase,
# TextIOBase — are implemented in the C extension _io but report
# __module__ == 'io' (the public Python module). io_extra47 covers all four.
# This table consolidates BufferedIOBase and TextIOBase as ioconst59 anchors,
# complementing the io_extra58 anchors for IOBase and RawIOBase.
#
#   BufferedIOBase.__module__ == 'io'   (io_extra47)
#   TextIOBase.__module__     == 'io'   (io_extra47)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra59.abstract_base_module_eq:
  description: "io abstract base class __module__.__eq__('io') for BufferedIOBase/TextIOBase — abstract bases report public module name 'io' even though implemented in C extension _io; io_extra47 covers all four abstract bases; ioconst59 namespace anchors for BufferedIOBase/TextIOBase; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconst59abc

  columns: [id, function, args, expected]
  rows:
    - [BufferedIOBase_module_eq, BufferedIOBase.__module__.__eq__, ["io"], true]
    - [TextIOBase_module_eq,     TextIOBase.__module__.__eq__,     ["io"], true]

# ---------------------------------------------------------------------------
# io abstract base class __module__ lengths (ioconst59 namespace anchors)
#
# 'io' has 2 characters. io_extra34 covers all four abstract base classes.
# This table consolidates BufferedIOBase and TextIOBase as ioconst59 anchors,
# complementing the io_extra58 IOBase/RawIOBase anchors.
#
#   BufferedIOBase.__module__.__len__() == 2   (io_extra34)
#   TextIOBase.__module__.__len__()     == 2   (io_extra34)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra59.abstract_base_module_len:
  description: "io abstract base class __module__.__len__()==2 for BufferedIOBase/TextIOBase — 'io' has 2 characters; io_extra34 covers all four abstract bases; ioconst59 namespace anchors for BufferedIOBase/TextIOBase; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: ioconst59abclen

  columns: [id, function, args, expected]
  rows:
    - [BufferedIOBase_module_len, BufferedIOBase.__module__.__len__, [], 2]
    - [TextIOBase_module_len,     TextIOBase.__module__.__len__,     [], 2]
