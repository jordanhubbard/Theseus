spec: lodash_at
version: ">=4.0.0"
backend: node(lodash.at)

docs: https://lodash.com/docs/#at

provenance:
  derived_from:
    - "lodash.at README — https://www.npmjs.com/package/lodash.at"
    - "Test vectors verified with lodash.at@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.at exports the _.at function directly as module.exports."
    - "at(object, paths) creates an array of values for the given paths."
    - "Paths can be an array or spread as individual arguments."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of values at the given paths."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_at.at:
  kind: node_module_call_eq
  function: ~
  category: at
  id_prefix: lat

  columns: [id, args, expected]
  rows:
    - [two_paths,   [{"a": 1, "b": 2, "c": 3}, ["a", "c"]], [1, 3]]
    - [one_path,    [{"x": 42, "y": 7}, ["x"]],              [42]]
    - [nested_path, [{"a": {"b": 1}, "c": 2}, ["a.b", "c"]], [1, 2]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:18:07Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
