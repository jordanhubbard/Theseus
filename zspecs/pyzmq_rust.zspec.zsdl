  not_derived_from:
    - "pyzmq source: zmq/__init__.py"
  notes:
    - "pyzmq provides Python bindings for ZeroMQ."
    - "zmq.PUSH == 8 — PUSH socket type constant."
    - "zmq.PULL == 7 — PULL socket type constant."
    - "zmq.PUB == 1 — PUB socket type constant."
    - "zmq.SUB == 2 — SUB socket type constant."
    - "zmq.REQ == 3 — REQ socket type constant."
    - "zmq.REP == 4 — REP socket type constant."
    - "Expose zmq_push_const() -> int: zmq.PUSH."
    - "Expose zmq_pull_const() -> int: zmq.PULL."
    - "Expose zmq_pub_const() -> int: zmq.PUB."
    - "All test vectors verified against pyzmq 26.3.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

