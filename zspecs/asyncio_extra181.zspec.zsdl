spec: asyncio_extra181
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: asyncio.Semaphore and asyncio.BoundedSemaphore class identity — asyncio.Semaphore.__name__=='Semaphore' (len=9); asyncio.Semaphore.__module__=='asyncio.locks'; asyncio.Semaphore.__qualname__=='Semaphore'; asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (Semaphore inherits from _ContextManagerMixin, not object directly); asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16); asyncio.BoundedSemaphore.__module__=='asyncio.locks'; asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore'; asyncio.BoundedSemaphore.__mro__.__len__()==5 (BoundedSemaphore > Semaphore > _ContextManagerMixin > _LoopBoundMixin > object)."
    - "asyncio.Semaphore.__name__ == 'Semaphore' (len=9: S-e-m-a-p-h-o-r-e). Semaphore is an asyncio synchronization primitive that limits concurrent access to a shared resource. Its MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] giving __mro__.__len__()==4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e). BoundedSemaphore raises ValueError if released more times than acquired; it subclasses Semaphore directly. Its MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] giving __mro__.__len__()==5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'. asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'. Both classes are defined in the asyncio.locks submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'. asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'. Semaphore inherits from _ContextManagerMixin (enabling async context manager usage); BoundedSemaphore directly subclasses Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Semaphore class identity — __name__, __module__, __qualname__
#
# asyncio.Semaphore.__name__ == 'Semaphore' (len=9)
# asyncio.Semaphore.__module__ == 'asyncio.locks'
# asyncio.Semaphore.__qualname__ == 'Semaphore'
#
# Semaphore is defined in asyncio.locks and limits concurrent coroutine access.
# New to extra181.
# ---------------------------------------------------------------------------

table asyncio_extra181.semaphore_identity:
  description: "asyncio.Semaphore.__name__ 'Semaphore' len 9; __module__ 'asyncio.locks'; __qualname__ 'Semaphore'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosema181

  columns: [id, function, args, expected, description]
  rows:
    - [sema_name_eq,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "asyncio.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is an asyncio synchronization primitive limiting concurrent coroutine access; its __name__ is 'Semaphore' (9 chars: S-e-m-a-p-h-o-r-e); str.__eq__('Semaphore') returns True; new to extra181"]
    - [sema_name_len_9,
       Semaphore.__name__.__len__,
       [],
       9,
       "asyncio.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters: S-e-m-a-p-h-o-r-e; shorter than 'BoundedSemaphore'=16; NAME LENGTHS: Semaphore=9 < BoundedSemaphore=16; str.__len__() returns 9; new to extra181"]
    - [sema_module_eq,
       Semaphore.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Semaphore.__module__.__eq__('asyncio.locks') == True — Semaphore is defined in the asyncio.locks submodule, not in asyncio.__init__; its __module__ is 'asyncio.locks'; str.__eq__('asyncio.locks') returns True; new to extra181"]
    - [sema_qualname_eq,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "asyncio.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is a top-level class in asyncio.locks so its __qualname__ equals its __name__; str.__eq__('Semaphore') returns True; new to extra181"]
    - [sema_module_len,
       Semaphore.__module__.__len__,
       [],
       13,
       "asyncio.Semaphore.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters: asyncio=7 + '.'=1 + locks=5 = 13; str.__len__() returns 13; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Semaphore.__bases__ and base class identity
#
# asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'
#
# Semaphore directly subclasses _ContextManagerMixin (enabling async with usage).
# New to extra181.
# ---------------------------------------------------------------------------

table asyncio_extra181.semaphore_bases:
  description: "asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin'; Semaphore inherits async context manager support; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosema181

  columns: [id, function, args, expected, description]
  rows:
    - [sema_base0_name_eq,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["_ContextManagerMixin"],
       true,
       "asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin') == True — Semaphore's direct base class is _ContextManagerMixin which provides async context manager protocol support; str.__eq__('_ContextManagerMixin') returns True; new to extra181"]
    - [sema_bases_len_1,
       "Semaphore.__bases__.__len__",
       [],
       1,
       "asyncio.Semaphore.__bases__.__len__() == 1 — Semaphore has exactly one direct base class: _ContextManagerMixin; __bases__ is a 1-element tuple; tuple.__len__() returns 1; new to extra181"]
    - [sema_mro0_name_eq,
       "Semaphore.__mro__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "asyncio.Semaphore.__mro__[0].__name__.__eq__('Semaphore') == True — the first element of the MRO is always the class itself; __mro__[0] is Semaphore; str.__eq__('Semaphore') returns True; new to extra181"]
    - [sema_mro_len_4,
       Semaphore.__mro__.__len__,
       [],
       4,
       "asyncio.Semaphore.__mro__.__len__() == 4 — MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; 4 levels deep; tuple.__len__() returns 4; new to extra181"]
    - [sema_base0_name_len,
       "Semaphore.__bases__[0].__name__.__len__",
       [],
       20,
       "asyncio.Semaphore.__bases__[0].__name__.__len__() == 20 — '_ContextManagerMixin' has 20 characters; str.__len__() returns 20; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.BoundedSemaphore class identity — __name__, __module__, __bases__, __mro__
#
# asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16)
# asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'
# asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# asyncio.BoundedSemaphore.__mro__.__len__() == 5
#
# BoundedSemaphore subclasses Semaphore and raises ValueError on over-release.
# New to extra181.
# ---------------------------------------------------------------------------

table asyncio_extra181.boundedsemaphore_identity:
  description: "asyncio.BoundedSemaphore.__name__ 'BoundedSemaphore' len 16; __module__ 'asyncio.locks'; __bases__[0].__name__=='Semaphore'; __mro__.__len__()==5; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosema181

  columns: [id, function, args, expected, description]
  rows:
    - [bsema_name_eq,
       BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore raises ValueError if released more times than acquired; its __name__ is 'BoundedSemaphore' (16 chars: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e); str.__eq__('BoundedSemaphore') returns True; new to extra181"]
    - [bsema_name_len_16,
       BoundedSemaphore.__name__.__len__,
       [],
       16,
       "asyncio.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e; longer than 'Semaphore'=9; NAME LENGTHS: Semaphore=9 < BoundedSemaphore=16; str.__len__() returns 16; new to extra181"]
    - [bsema_module_eq,
       BoundedSemaphore.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.BoundedSemaphore.__module__.__eq__('asyncio.locks') == True — BoundedSemaphore is defined in the same asyncio.locks submodule as Semaphore; its __module__ is 'asyncio.locks'; str.__eq__('asyncio.locks') returns True; new to extra181"]
    - [bsema_base0_name_eq,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore's sole direct base class is asyncio.Semaphore; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra181"]
    - [bsema_mro_len_5,
       BoundedSemaphore.__mro__.__len__,
       [],
       5,
       "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; 5 levels deep; one deeper than Semaphore=4; tuple.__len__() returns 5; new to extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra181
# ---------------------------------------------------------------------------

invariant asyncio_extra181.semaphore_name_eq:
  description: "asyncio.Semaphore.__name__ == 'Semaphore' — asyncio synchronization primitive limiting concurrent coroutine access; name len=9 (S-e-m-a-p-h-o-r-e); new to extra181"
  category: identity
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra181.semaphore_module_eq:
  description: "asyncio.Semaphore.__module__ == 'asyncio.locks' — defined in the locks submodule alongside Lock, Event, Condition, BoundedSemaphore; new to extra181"
  category: identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra181.semaphore_qualname_eq:
  description: "asyncio.Semaphore.__qualname__ == 'Semaphore' — top-level class so __qualname__ equals __name__; new to extra181"
  category: identity
  kind: python_call_eq
  function: Semaphore.__qualname__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra181.semaphore_base0_name_eq:
  description: "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' — Semaphore inherits async context manager support from _ContextManagerMixin; new to extra181"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra181.boundedsemaphore_name_eq:
  description: "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' — raises ValueError on over-release unlike plain Semaphore; name len=16; new to extra181"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra181.boundedsemaphore_module_eq:
  description: "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' — defined in the same module as Semaphore; new to extra181"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra181.boundedsemaphore_base0_name_eq:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore directly subclasses asyncio.Semaphore; new to extra181"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra181.boundedsemaphore_mro_len_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; one level deeper than Semaphore=4; new to extra181"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5
