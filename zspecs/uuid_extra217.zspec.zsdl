  description: "uuid module __dict__ membership checks for UUID variant constants in uuid217b namespace — wave 217 theme: RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, RESERVED_FUTURE are the four UUID variant identifiers from RFC 4122; all are top-level names exported by uuid; confirmed present in uuid.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: uuid217b

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_RESERVED_NCS,       uuid.__dict__.__contains__, ["RESERVED_NCS"],       true, "uuid.__dict__.__contains__('RESERVED_NCS') == True — RESERVED_NCS is the NCS backward compatibility variant constant; exported as top-level name in uuid.__dict__; verified with Python 3.14.3"]
    - [dict_has_RFC_4122,            uuid.__dict__.__contains__, ["RFC_4122"],            true, "uuid.__dict__.__contains__('RFC_4122') == True — RFC_4122 is the RFC 4122 variant constant; exported as top-level name in uuid.__dict__; verified with Python 3.14.3"]
    - [dict_has_RESERVED_MICROSOFT, uuid.__dict__.__contains__, ["RESERVED_MICROSOFT"], true, "uuid.__dict__.__contains__('RESERVED_MICROSOFT') == True — RESERVED_MICROSOFT is the Microsoft backward compatibility variant constant; exported as top-level name in uuid.__dict__; verified with Python 3.14.3"]
    - [dict_has_RESERVED_FUTURE,    uuid.__dict__.__contains__, ["RESERVED_FUTURE"],    true, "uuid.__dict__.__contains__('RESERVED_FUTURE') == True — RESERVED_FUTURE is the reserved for future use variant constant; exported as top-level name in uuid.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants for uuid __dict__ membership checks
# ---------------------------------------------------------------------------

invariant uuid_extra217.dict_contains_UUID:
  description: "uuid.__dict__.__contains__('UUID') == True — UUID is the central class of the uuid module; 'UUID' appears as a key in uuid.__dict__; the UUID class represents an immutable UUID value and supports all four RFC 4122 UUID versions; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: uuid.__dict__.__contains__
  args: ["UUID"]
  expected: true

invariant uuid_extra217.dict_contains_uuid4:
  description: "uuid.__dict__.__contains__('uuid4') == True — uuid4 is exported as a top-level callable in the uuid module; 'uuid4' appears as a key in uuid.__dict__; uuid4 generates version-4 UUIDs using random or pseudo-random numbers per RFC 4122 section 4.4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: uuid.__dict__.__contains__
  args: ["uuid4"]
  expected: true

invariant uuid_extra217.dict_contains_NAMESPACE_DNS:
  description: "uuid.__dict__.__contains__('NAMESPACE_DNS') == True — NAMESPACE_DNS is the well-known DNS namespace UUID (6ba7b810-9dad-11d1-80b4-00c04fd430c8) defined in RFC 4122 Appendix C; 'NAMESPACE_DNS' appears as a key in uuid.__dict__; used as the namespace argument to uuid3() and uuid5() when generating name-based UUIDs for DNS names; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: uuid.__dict__.__contains__
  args: ["NAMESPACE_DNS"]
  expected: true

