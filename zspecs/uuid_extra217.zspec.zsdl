    - [dict_has_NAMESPACE_DNS,  uuid.__dict__.__contains__, ["NAMESPACE_DNS"],  true, "uuid.__dict__.__contains__('NAMESPACE_DNS') == True — NAMESPACE_DNS is the DNS namespace UUID (6ba7b810-9dad-11d1-80b4-00c04fd430c8) from RFC 4122; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_NAMESPACE_URL,  uuid.__dict__.__contains__, ["NAMESPACE_URL"],  true, "uuid.__dict__.__contains__('NAMESPACE_URL') == True — NAMESPACE_URL is the URL namespace UUID (6ba7b811-9dad-11d1-80b4-00c04fd430c8) from RFC 4122; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_NAMESPACE_OID,  uuid.__dict__.__contains__, ["NAMESPACE_OID"],  true, "uuid.__dict__.__contains__('NAMESPACE_OID') == True — NAMESPACE_OID is the ISO OID namespace UUID (6ba7b812-9dad-11d1-80b4-00c04fd430c8) from RFC 4122; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_NAMESPACE_X500, uuid.__dict__.__contains__, ["NAMESPACE_X500"], true, "uuid.__dict__.__contains__('NAMESPACE_X500') == True — NAMESPACE_X500 is the X.500 DN namespace UUID (6ba7b814-9dad-11d1-80b4-00c04fd430c8) from RFC 4122; exported as top-level name; verified with Python 3.14.3"]

