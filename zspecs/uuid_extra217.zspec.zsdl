table uuid_extra217.dict_membership_class_and_generators:
  description: "uuid module __dict__ membership checks for UUID class and generator functions in uuid217 namespace — wave 217 theme: UUID, uuid1, uuid3, uuid4, uuid5 are all top-level names exported by uuid; UUID is the main class; uuid1/3/4/5 are the version-specific factory functions per RFC 4122; confirmed present in uuid.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: uuid217

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_UUID,  uuid.__dict__.__contains__, ["UUID"],  true, "uuid.__dict__.__contains__('UUID') == True — UUID is the main class exported as a top-level name in uuid.__dict__; verified with Python 3.14.3"]
    - [dict_has_uuid1, uuid.__dict__.__contains__, ["uuid1"], true, "uuid.__dict__.__contains__('uuid1') == True — uuid1 generates a UUID from a host ID and current time; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_uuid3, uuid.__dict__.__contains__, ["uuid3"], true, "uuid.__dict__.__contains__('uuid3') == True — uuid3 generates a UUID from a namespace and name using MD5; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_uuid4, uuid.__dict__.__contains__, ["uuid4"], true, "uuid.__dict__.__contains__('uuid4') == True — uuid4 generates a random UUID; exported as top-level name; verified with Python 3.14.3"]
    - [dict_has_uuid5, uuid.__dict__.__contains__, ["uuid5"], true, "uuid.__dict__.__contains__('uuid5') == True — uuid5 generates a UUID from a namespace and name using SHA-1; exported as top-level name; verified with Python 3.14.3"]

