spec: functools_extra28
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra27.zspec.zsdl."
    - "functools_extra27 covers: combined __qualname__.__len__ table for nine core functools callables; standalone qualname_len invariants for wraps/cache/partialmethod."
    - "functools_extra26 covers: combined __qualname__.__eq__ table for reduce/lru_cache/cache/wraps/total_ordering/singledispatch/cached_property/partialmethod; standalone qualname invariants for reduce/lru_cache/cache/wraps/total_ordering."
    - "No prior functools spec records __qualname__.__eq__ for partial.__call__, partial.__new__, cached_property.__set_name__, cached_property.__get__, partialmethod.__get__ together in the extra28 namespace."
    - "Focus: __qualname__ values for instance/special methods on partial, cached_property, and partialmethod; and the simple qualname of functools.lru_cache as a function."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — it is a top-level function (not a class), so qualname equals its name."
    - "functools.partialmethod.__qualname__ == 'partialmethod' — class qualname, confirming module-level definition."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — partial special methods
#
# functools.partial is a C-level type. Its __call__ and __new__ special
# methods have nested qualnames confirming their scope within partial.
# No prior functools spec records these in the extra28 namespace.
# ---------------------------------------------------------------------------

table functools_extra28.partial_method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra28.partial_method_qualnames.call,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__ == 'partial.__call__'"]
    - [functools_extra28.partial_method_qualnames.new,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__ == 'partial.__new__'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — cached_property instance methods
#
# functools.cached_property is a Python-level descriptor class. Its
# __set_name__ and __get__ methods carry nested qualnames.
# No prior functools spec records these in the extra28 namespace.
# ---------------------------------------------------------------------------

table functools_extra28.cached_property_method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra28.cached_property_method_qualnames.set_name,
       "cached_property.__set_name__.__qualname__.__eq__",
       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'"]
    - [functools_extra28.cached_property_method_qualnames.get,
       "cached_property.__get__.__qualname__.__eq__",
       ["cached_property.__get__"],
       true,
       "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__'"]

# ---------------------------------------------------------------------------
# partialmethod.__get__.__qualname__.__eq__ — standalone method qualname
#
# functools.partialmethod.__get__ is the descriptor protocol method.
# Its qualname 'partialmethod.__get__' confirms it is defined within the
# partialmethod class scope in Lib/functools.py.
# No prior functools spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra28.partialmethod.get.qualname:
  description: "functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__'"
  category: qualnames
  kind: python_call_eq
  function: "partialmethod.__get__.__qualname__.__eq__"
  args: ["partialmethod.__get__"]
  expected: true

# ---------------------------------------------------------------------------
# partialmethod.__qualname__.__eq__ — class-level qualname
#
# functools.partialmethod is a module-level class, so its qualname equals
# its name: 'partialmethod'.
# No prior functools spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra28.partialmethod.qualname:
  description: "functools.partialmethod.__qualname__ == 'partialmethod'"
  category: qualnames
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
  args: ["partialmethod"]
  expected: true

# ---------------------------------------------------------------------------
# lru_cache.__qualname__.__eq__ — function-level qualname
#
# functools.lru_cache is a top-level function (not a class). Its qualname
# is 'lru_cache', the same as its __name__.
# No prior functools spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra28.lru_cache.qualname:
  description: "functools.lru_cache.__qualname__ == 'lru_cache'"
  category: qualnames
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true
