spec: multiprocessing_extra418
version: ">=3.9"
backend: python_module(multiprocessing.connection)
docs: https://docs.python.org/3/library/multiprocessing.html#connection-objects
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#connection-objects — multiprocessing connection documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.connection.Connection.__name__ == 'Connection'"
    - "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'"
    - "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase'"
    - "multiprocessing.connection.Listener.__name__ == 'Listener'"
    - "multiprocessing.connection.Listener.__module__ == 'multiprocessing.connection'"
    - "multiprocessing.connection.Listener.__bases__[0].__name__ == 'object'"
    - "multiprocessing.connection.Client.__name__ == 'Client'"
    - "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection'"
    - "Client is a module-level function, not a class"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra418.connection_identity:
  description: "Verify class identity attributes of multiprocessing.connection.Connection"
  kind: python_call_eq
  category: identity
  id_prefix: mp418ci

  columns: [id, function, args, expected]
  rows:
    - [mp418ci001, multiprocessing.connection.Connection.__name__.__eq__, ["Connection"], true]
    - [mp418ci002, multiprocessing.connection.Connection.__module__.__eq__, ["multiprocessing.connection"], true]
    - [mp418ci003, "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__", ["_ConnectionBase"], true]

