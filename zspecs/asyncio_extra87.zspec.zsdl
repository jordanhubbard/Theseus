# Wave 247 theme: asyncio synchronization primitive __dict__ membership.
#
# Semaphore.__dict__.__contains__('acquire') == True
# Semaphore.__dict__.__contains__('release') == True
# Semaphore.__dict__.__contains__('locked') == True
# BoundedSemaphore.__dict__.__contains__('release') == True
# ---------------------------------------------------------------------------

table asyncio_extra87.Semaphore_dict_membership:
  description: "asyncio Semaphore and BoundedSemaphore __dict__ membership checks in asynciosyncdict87 namespace — wave 247 theme: asyncio synchronization primitive __dict__ membership; Semaphore.__dict__.__contains__('acquire')==True; Semaphore.__dict__.__contains__('release')==True; Semaphore.__dict__.__contains__('locked')==True; BoundedSemaphore.__dict__.__contains__('release')==True (BoundedSemaphore overrides release to enforce the bound); all are class-level methods defined directly on the class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosyncdict87

  columns: [id, function, args, expected, description]
  rows:
    - [sem_has_acquire,  "Semaphore.__dict__.__contains__",        ["acquire"], true, "Semaphore.__dict__.__contains__('acquire') == True — acquire is defined directly on Semaphore; verified with Python 3.14.3"]
    - [sem_has_release,  "Semaphore.__dict__.__contains__",        ["release"], true, "Semaphore.__dict__.__contains__('release') == True — release is defined directly on Semaphore; verified with Python 3.14.3"]
    - [sem_has_locked,   "Semaphore.__dict__.__contains__",        ["locked"],  true, "Semaphore.__dict__.__contains__('locked') == True — locked is defined directly on Semaphore; verified with Python 3.14.3"]
    - [bsem_has_release, "BoundedSemaphore.__dict__.__contains__", ["release"], true, "BoundedSemaphore.__dict__.__contains__('release') == True — BoundedSemaphore overrides release to enforce the bound; verified with Python 3.14.3"]

