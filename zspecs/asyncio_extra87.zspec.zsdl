spec: asyncio_extra87
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra86

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra86.zspec.zsdl."
    - "This spec covers: wave 247 theme — asyncio synchronization primitive __dict__ membership. NEW in extra87: Semaphore.__dict__.__contains__('acquire')==True; Semaphore.__dict__.__contains__('release')==True; Semaphore.__dict__.__contains__('locked')==True; BoundedSemaphore.__dict__.__contains__('release')==True (overrides parent to enforce bound); Event.__dict__.__contains__('wait')==True; Event.__dict__.__contains__('set')==True; Event.__dict__.__contains__('clear')==True; Event.__dict__.__contains__('is_set')==True; Condition.__dict__.__contains__('wait')==True; Condition.__dict__.__contains__('wait_for')==True; Condition.__dict__.__contains__('notify')==True; Condition.__dict__.__contains__('notify_all')==True; Lock.__dict__.__contains__('acquire')==True; Lock.__dict__.__contains__('release')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('acquire') == True. acquire is defined directly on Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('release') == True. release is defined directly on Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('locked') == True. locked is defined directly on Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__dict__.__contains__('release') == True. BoundedSemaphore overrides release to enforce the bound. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('wait') == True. wait is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('set') == True. set is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('clear') == True. clear is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('is_set') == True. is_set is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('wait') == True. wait is defined directly on Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('wait_for') == True. wait_for is defined directly on Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('notify') == True. notify is defined directly on Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('notify_all') == True. notify_all is defined directly on Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('acquire') == True. acquire is defined directly on Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('release') == True. release is defined directly on Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
