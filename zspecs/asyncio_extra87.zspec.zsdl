# ---------------------------------------------------------------------------
# Standalone invariants — extra87
# ---------------------------------------------------------------------------

invariant asyncio_extra87.Semaphore_has_acquire:
  description: "asyncio.Semaphore.__dict__.__contains__('acquire') returns True — acquire is a class-level coroutine method defined directly on Semaphore; NEW in extra87: first standalone __dict__.__contains__ invariant for Semaphore.acquire in asynciosyncdict87 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["acquire"]
  expected: true

invariant asyncio_extra87.Semaphore_has_locked:
  description: "asyncio.Semaphore.__dict__.__contains__('locked') returns True — locked is a class-level method defined directly on Semaphore returning whether the semaphore is locked; NEW in extra87: first standalone __dict__.__contains__ invariant for Semaphore.locked in asynciosyncdict87 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["locked"]
  expected: true

invariant asyncio_extra87.BoundedSemaphore_has_release:
  description: "asyncio.BoundedSemaphore.__dict__.__contains__('release') returns True — BoundedSemaphore overrides release from Semaphore to enforce the count bound; this override is present as a class-level method in BoundedSemaphore.__dict__; NEW in extra87: first standalone __dict__.__contains__ invariant for BoundedSemaphore.release in asynciosyncdict87 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__dict__.__contains__
  args: ["release"]
  expected: true

invariant asyncio_extra87.Condition_has_wait_for:
  description: "asyncio.Condition.__dict__.__contains__('wait_for') returns True — wait_for is a class-level coroutine method defined directly on Condition that waits until a predicate is true; NEW in extra87: first standalone __dict__.__contains__ invariant for Condition.wait_for in asynciosyncdict87 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["wait_for"]
  expected: true

invariant asyncio_extra87.Lock_has_acquire:
  description: "asyncio.Lock.__dict__.__contains__('acquire') returns True — acquire is a class-level coroutine method defined directly on Lock; Lock provides mutual exclusion; NEW in extra87: first standalone __dict__.__contains__ invariant for Lock.acquire in asynciosyncdict87 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["acquire"]
  expected: true
