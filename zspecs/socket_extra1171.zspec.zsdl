spec: socket_extra1171
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.__all__ __class__.__name__ and __contains__ for 'socket'/'error'/'timeout'/'AF_INET'/'SOCK_STREAM', socket.AF_INET.__int__() equality to 2 and SOCK_STREAM.__int__() equality to 1, socket.AF_INET6.__int__() class name, socket.AddressFamily/__class__ attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1171.all_class_name_and_contains:
  description: "socket.__all__ __class__.__name__ and __contains__ membership checks for expected names"
  kind: python_call_eq
  category: all_class_name_contains
  id_prefix: sk1171al
  columns: [id, function, args, expected]
  rows:
    - [sk1171al001, socket.__all__.__class__.__name__.__eq__,                  ["list"],        true]
    - [sk1171al002, socket.__all__.__class__.__qualname__.__eq__,              ["list"],        true]
    - [sk1171al003, socket.__all__.__class__.__module__.__eq__,                ["builtins"],    true]
    - [sk1171al004, socket.__all__.__contains__,                               ["socket"],      true]
    - [sk1171al005, socket.__all__.__contains__,                               ["error"],       true]
    - [sk1171al006, socket.__all__.__contains__,                               ["timeout"],     true]
    - [sk1171al007, socket.__all__.__contains__,                               ["AF_INET"],     true]
    - [sk1171al008, socket.__all__.__contains__,                               ["SOCK_STREAM"], true]
    - [sk1171al009, socket.__all__.__class__.__name__.__class__.__name__.__eq__, ["str"],       true]
    - [sk1171al010, socket.__all__.__class__.__module__.__class__.__name__.__eq__, ["str"],     true]

table socket_extra1171.af_inet_sock_stream_int_eq:
  description: "socket.AF_INET.__int__() equality to 2 and SOCK_STREAM.__int__() equality to 1"
  kind: python_call_eq
  category: af_inet_sock_stream_int_eq
  id_prefix: sk1171ie
  columns: [id, function, args, expected]
  rows:
    - [sk1171ie001, socket.AF_INET.__int__().__eq__,                           [2],             true]
    - [sk1171ie002, socket.SOCK_STREAM.__int__().__eq__,                       [1],             true]
    - [sk1171ie003, socket.AF_INET.__int__().__class__.__name__.__eq__,        ["int"],         true]
    - [sk1171ie004, socket.SOCK_STREAM.__int__().__class__.__name__.__eq__,    ["int"],         true]
    - [sk1171ie005, socket.AF_INET.__int__().__class__.__module__.__eq__,      ["builtins"],    true]
    - [sk1171ie006, socket.SOCK_STREAM.__int__().__class__.__module__.__eq__,  ["builtins"],    true]
    - [sk1171ie007, socket.AF_INET6.__int__().__class__.__name__.__eq__,       ["int"],         true]
    - [sk1171ie008, socket.AF_INET6.__int__().__class__.__module__.__eq__,     ["builtins"],    true]
    - [sk1171ie009, socket.AF_INET6.__int__().__class__.__qualname__.__eq__,   ["int"],         true]

table socket_extra1171.address_family_class_and_sock_kind_attrs:
  description: "socket.AddressFamily __class__ type attrs and SocketKind __name__/__qualname__/__module__ identity"
  kind: python_call_eq
  category: address_family_sock_kind_attrs
  id_prefix: sk1171ak
  columns: [id, function, args, expected]
  rows:
    - [sk1171ak001, socket.AddressFamily.__class__.__name__.__eq__,            ["EnumType"],    true]
    - [sk1171ak002, socket.AddressFamily.__class__.__module__.__eq__,          ["enum"],        true]
    - [sk1171ak003, socket.AddressFamily.__name__.__eq__,                      ["AddressFamily"], true]
    - [sk1171ak004, socket.AddressFamily.__qualname__.__eq__,                  ["AddressFamily"], true]
    - [sk1171ak005, socket.AddressFamily.__module__.__eq__,                    ["socket"],      true]
    - [sk1171ak006, socket.SocketKind.__class__.__name__.__eq__,               ["EnumType"],    true]
    - [sk1171ak007, socket.SocketKind.__class__.__module__.__eq__,             ["enum"],        true]
    - [sk1171ak008, socket.SocketKind.__name__.__eq__,                         ["SocketKind"],  true]
    - [sk1171ak009, socket.SocketKind.__qualname__.__eq__,                     ["SocketKind"],  true]
    - [sk1171ak010, socket.SocketKind.__module__.__eq__,                       ["socket"],      true]
