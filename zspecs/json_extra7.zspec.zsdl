spec: json_extra7
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format, December 2017"
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl, _json.zspec.zsdl, _json_extra.zspec.zsdl, json_decoder.zspec.zsdl, json_encoder.zspec.zsdl, json_extra.zspec.zsdl, json_extra2.zspec.zsdl, json_extra3.zspec.zsdl, json_extra4.zspec.zsdl, json_extra5.zspec.zsdl, and json_extra6.zspec.zsdl."
    - "Focus: __qualname__ checks for json functions and classes, __module__ checks, and JSONDecodeError base class."
    - "json.JSONDecoder.__module__ == 'json.decoder' — the class is defined in Lib/json/decoder.py."
    - "json.JSONEncoder.__module__ == 'json.encoder' — the class is defined in Lib/json/encoder.py."
    - "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — JSONDecodeError is a subclass of ValueError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# qualname — module-level functions (table)
# ---------------------------------------------------------------------------

table json_extra7.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [loads, loads.__qualname__.__eq__, ["loads"], true]
    - [dumps, dumps.__qualname__.__eq__, ["dumps"], true]
    - [load,  load.__qualname__.__eq__,  ["load"],  true]
    - [dump,  dump.__qualname__.__eq__,  ["dump"],  true]
    - [JSONDecoder, JSONDecoder.__qualname__.__eq__, ["JSONDecoder"], true]
    - [JSONEncoder, JSONEncoder.__qualname__.__eq__, ["JSONEncoder"], true]

# ---------------------------------------------------------------------------
# qualname — JSONDecodeError
# ---------------------------------------------------------------------------

invariant json_extra7.JSONDecodeError.qualname:
  description: "json.JSONDecodeError.__qualname__ == 'JSONDecodeError'"
  category: qualnames
  kind: python_call_eq
  function: JSONDecodeError.__qualname__.__eq__
  args: ["JSONDecodeError"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ — JSONDecoder and JSONEncoder live in sub-modules
# ---------------------------------------------------------------------------

invariant json_extra7.JSONDecoder.module:
  description: "json.JSONDecoder.__module__ == 'json.decoder'"
  category: modules
  kind: python_call_eq
  function: JSONDecoder.__module__.__eq__
  args: ["json.decoder"]
  expected: true

invariant json_extra7.JSONEncoder.module:
  description: "json.JSONEncoder.__module__ == 'json.encoder'"
  category: modules
  kind: python_call_eq
  function: JSONEncoder.__module__.__eq__
  args: ["json.encoder"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecodeError base class — inherits from ValueError
# ---------------------------------------------------------------------------

invariant json_extra7.JSONDecodeError.base_is_ValueError:
  description: "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError'"
  category: hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"
