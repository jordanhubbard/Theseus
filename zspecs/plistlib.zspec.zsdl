spec: plistlib
version: ">=3.4"
backend: python_module(plistlib)

docs: https://docs.python.org/3/library/plistlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/plistlib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/plistlib.py (internal implementation)"
  notes:
    - "plistlib.loads(data) parses a plist byte string and returns the corresponding Python object."
    - "plistlib.dumps(value) serializes a Python object to a plist byte string (XML format by default)."
    - "plistlib.load(fp) and plistlib.dump(value, fp) work on file-like objects."
    - "plistlib.FMT_XML is an IntEnum member with value 1; plistlib.FMT_BINARY has value 2."
    - "plistlib.UID is a class wrapping an integer unique identifier used in binary plists from Cocoa archives."
    - "plistlib.InvalidFileException is raised for malformed plist data; it subclasses ValueError."
    - "dumps({'key': 'value'}) returns bytes whose class name is 'bytes'."
    - "Round-trip: plistlib.loads(plistlib.dumps(42)) == 42."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "plistlib.loads/load raise InvalidFileException for malformed plist data; dumps raises TypeError for unsupported Python types."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

table plistlib.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [loads, loads.__name__.__eq__, ["loads"], true]
    - [dumps, dumps.__name__.__eq__, ["dumps"], true]
    - [load,  load.__name__.__eq__,  ["load"],  true]
    - [dump,  dump.__name__.__eq__,  ["dump"],  true]

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

table plistlib.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [invalid_file_exception, InvalidFileException.__name__.__eq__, ["InvalidFileException"], true]
    - [uid,                    UID.__name__.__eq__,                  ["UID"],                  true]

# ---------------------------------------------------------------------------
# Module affiliation
# ---------------------------------------------------------------------------

invariant plistlib.loads_module:
  description: "plistlib.loads.__module__ == 'plistlib'"
  category: module
  kind: python_call_eq
  function: loads.__module__.__eq__
  args: ["plistlib"]
  expected: true

# ---------------------------------------------------------------------------
# FMT_XML constant — IntEnum member, value >= 1
# ---------------------------------------------------------------------------

invariant plistlib.FMT_XML_value_ge_1:
  description: "plistlib.FMT_XML >= 1 — FMT_XML is an IntEnum constant with positive value"
  category: constants
  kind: python_call_eq
  function: FMT_XML.__ge__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Hierarchy — InvalidFileException subclasses ValueError
# ---------------------------------------------------------------------------

invariant plistlib.invalid_file_exception_base:
  description: "plistlib.InvalidFileException.__bases__[0].__name__ == 'ValueError'"
  category: hierarchy
  kind: python_call_eq
  function: InvalidFileException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# dumps — returns bytes
# ---------------------------------------------------------------------------

invariant plistlib.dumps_returns_bytes:
  description: "plistlib.dumps({'key': 'value'}) returns a bytes object"
  category: dumps
  kind: python_call_eq
  function: dumps
  args: [{"key": "value"}]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# dumps/loads round-trip
# ---------------------------------------------------------------------------

invariant plistlib.dumps_integer_returns_bytes:
  description: "plistlib.dumps(42) returns a bytes object"
  category: dumps
  kind: python_call_eq
  function: dumps
  args: [42]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

