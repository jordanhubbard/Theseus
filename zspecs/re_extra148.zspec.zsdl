spec: re_extra148
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.RegexFlag enum identity and member values, re.error (alias re.PatternError) class identity, and re.Pattern attribute descriptor __qualname__ values — new territory not covered in re_extra146 (doc lengths) or re_extra147 (Pattern/Match method qualnames and type identity)."
    - "Key finding: re.error.__name__ == 'PatternError' (not 'error'); re.error is an alias for re.PatternError; both refer to the same class object."
    - "re.PatternError.__name__ == 'PatternError' (len=12); __module__ == 're' (len=2); MRO length == 4: [PatternError, Exception, BaseException, object]."
    - "re.PatternError.__doc__.__len__() == 333 (the PatternError/error docstring covers the exception's attributes: msg, pattern, pos, lineno, colno, endpos)."
    - "re.RegexFlag.__name__ == 'RegexFlag' (len=9); __module__ == 're'; MRO length == 7 (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object)."
    - "re.RegexFlag member values: NOFLAG=0, IGNORECASE=2, LOCALE=4, UNICODE=32, MULTILINE=8, DOTALL=16, VERBOSE=64, DEBUG=128, ASCII=256."
    - "re.Pattern attribute descriptor __qualname__ values: flags='Pattern.flags' (13), groups='Pattern.groups' (14), pattern='Pattern.pattern' (15), groupindex='Pattern.groupindex' (18)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.PatternError (re.error) class identity
# re.error.__name__ == 'PatternError' (not 'error'); len=12.
# __module__ == 're'; MRO length == 4: [PatternError, Exception, BaseException, object].
# __doc__ len == 333.
# ---------------------------------------------------------------------------

table re_extra148.PatternError_class_identity:
  description: "re.error class identity: __name__='PatternError' (12, not 'error'), __module__='re', MRO length=4, __doc__ len=333"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerr148

  columns: [id, function, args, expected, description]
  rows:
    - [err_name_eq,    error.__name__.__eq__,                    ["PatternError"], true, "re.error.__name__ == 'PatternError' (not 'error'; re.error is an alias for re.PatternError; the actual class name is PatternError)"]
    - [err_name_len,   error.__name__.__len__,                   [],               12,   "re.error.__name__.__len__() == 12 ('PatternError' has 12 characters; the class has been renamed from 'error' to 'PatternError')"]
    - [err_qname_eq,   error.__qualname__.__eq__,                ["PatternError"], true, "re.error.__qualname__ == 'PatternError' (top-level class; qualname equals name)"]
    - [err_module_eq,  error.__module__.__eq__,                  ["re"],           true, "re.error.__module__ == 're' (the PatternError exception is part of the public re module namespace)"]
    - [err_cls_eq,     error.__class__.__name__.__eq__,          ["type"],         true, "re.error.__class__.__name__ == 'type' (a regular exception class with metaclass 'type')"]
    - [err_mro_len,    "error.__mro__.__len__",                  [],               4,    "re.error.__mro__.__len__() == 4 (MRO: [PatternError, Exception, BaseException, object]; 4-entry chain typical of simple exception classes)"]
    - [err_base0_eq,   "error.__bases__[0].__name__.__eq__",     ["Exception"],    true, "re.error.__bases__[0].__name__ == 'Exception' (PatternError directly subclasses Exception)"]
    - [err_doc_cls,    error.__doc__.__class__.__name__.__eq__,  ["str"],          true, "re.error.__doc__ is a str (non-None; the PatternError docstring documents the exception attributes)"]
    - [err_doc_len,    error.__doc__.__len__,                    [],               333,  "re.error.__doc__.__len__() == 333 (333 characters; documents the msg, pattern, pos, lineno, colno attributes of PatternError)"]

# ---------------------------------------------------------------------------
# re.RegexFlag enum identity and MRO
# __name__ == 'RegexFlag' (len=9); __module__ == 're'; MRO length == 7.
# MRO: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object].
# __doc__ len == 15 ('An enumeration.').
# ---------------------------------------------------------------------------

table re_extra148.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag' (9), __module__='re', MRO length=7 ([RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]), __doc__ len=15"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerflag148

  columns: [id, function, args, expected, description]
  rows:
    - [rf_name_eq,    RegexFlag.__name__.__eq__,                    ["RegexFlag"], true, "re.RegexFlag.__name__ == 'RegexFlag' (the enum type for regex compilation flags)"]
    - [rf_name_len,   RegexFlag.__name__.__len__,                   [],            9,    "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters)"]
    - [rf_qname_eq,   RegexFlag.__qualname__.__eq__,                ["RegexFlag"], true, "re.RegexFlag.__qualname__ == 'RegexFlag' (top-level class; qualname equals name)"]
    - [rf_module_eq,  RegexFlag.__module__.__eq__,                  ["re"],        true, "re.RegexFlag.__module__ == 're' (the RegexFlag enum is part of the public re module namespace)"]
    - [rf_mro_len,    "RegexFlag.__mro__.__len__",                  [],            7,    "re.RegexFlag.__mro__.__len__() == 7 (MRO: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; 7-entry chain due to enum/int multiple inheritance)"]
    - [rf_base0_eq,   "RegexFlag.__bases__[0].__name__.__eq__",     ["IntFlag"],   true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag directly subclasses IntFlag from the enum module)"]
    - [rf_doc_eq,     RegexFlag.__doc__.__eq__,                     ["An enumeration."], true, "re.RegexFlag.__doc__ == 'An enumeration.' (the standard default docstring generated by the enum metaclass; len=15)"]
    - [rf_doc_len,    RegexFlag.__doc__.__len__,                    [],            15,   "re.RegexFlag.__doc__.__len__() == 15 ('An enumeration.' has 15 characters; the generic enum docstring)"]

# ---------------------------------------------------------------------------
# re.RegexFlag member values
# NOFLAG=0, IGNORECASE=2, LOCALE=4, UNICODE=32, MULTILINE=8,
# DOTALL=16, VERBOSE=64, DEBUG=128, ASCII=256.
# ---------------------------------------------------------------------------

table re_extra148.RegexFlag_member_values:
  description: "re.RegexFlag member values: NOFLAG=0, IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64, DEBUG=128, ASCII=256"
  kind: python_call_eq
  category: constants
  id_prefix: rerflag148

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_val,      RegexFlag.NOFLAG.__eq__,      [0],   true, "re.RegexFlag.NOFLAG == 0 (integer value 0; represents no flags; the zero flag added to explicitly signal no flags are set)"]
    - [icase_val,       RegexFlag.IGNORECASE.__eq__,  [2],   true, "re.RegexFlag.IGNORECASE == 2 (integer value 2; also accessible as re.I; makes pattern matching case-insensitive)"]
    - [locale_val,      RegexFlag.LOCALE.__eq__,      [4],   true, "re.RegexFlag.LOCALE == 4 (integer value 4; also accessible as re.L; makes matching locale-aware; deprecated)"]
    - [multi_val,       RegexFlag.MULTILINE.__eq__,   [8],   true, "re.RegexFlag.MULTILINE == 8 (integer value 8; also accessible as re.M; makes ^ and $ match at line boundaries)"]
    - [dotall_val,      RegexFlag.DOTALL.__eq__,      [16],  true, "re.RegexFlag.DOTALL == 16 (integer value 16; also accessible as re.S; makes . match any character including newline)"]
    - [unicode_val,     RegexFlag.UNICODE.__eq__,     [32],  true, "re.RegexFlag.UNICODE == 32 (integer value 32; also accessible as re.U; enables Unicode matching; default for str patterns)"]
    - [verbose_val,     RegexFlag.VERBOSE.__eq__,     [64],  true, "re.RegexFlag.VERBOSE == 64 (integer value 64; also accessible as re.X; allows adding whitespace and comments to patterns)"]
    - [debug_val,       RegexFlag.DEBUG.__eq__,       [128], true, "re.RegexFlag.DEBUG == 128 (integer value 128; displays debug information about the compiled pattern)"]
    - [ascii_val,       RegexFlag.ASCII.__eq__,       [256], true, "re.RegexFlag.ASCII == 256 (integer value 256; also accessible as re.A; makes \\w, \\W, \\b, etc. match only ASCII characters)"]

# ---------------------------------------------------------------------------
# re.Pattern attribute descriptor __qualname__ values
# flags='Pattern.flags' (13), groups='Pattern.groups' (14),
# pattern='Pattern.pattern' (15), groupindex='Pattern.groupindex' (18).
# ---------------------------------------------------------------------------

table re_extra148.Pattern_descriptor_qualnames:
  description: "re.Pattern attribute descriptor __qualname__ values: flags=13, groups=14, pattern=15, groupindex=18"
  kind: python_call_eq
  category: qualname
  id_prefix: rerflag148

  columns: [id, function, args, expected, description]
  rows:
    - [flags_qeq,       Pattern.flags.__qualname__.__eq__,      ["Pattern.flags"],      true, "re.Pattern.flags.__qualname__ == 'Pattern.flags' (len=13; attribute descriptor for the integer flags used to compile the pattern)"]
    - [flags_qlen,      Pattern.flags.__qualname__.__len__,     [],                     13,   "re.Pattern.flags.__qualname__.__len__() == 13 ('Pattern.flags' has 13 characters; shortest Pattern descriptor qualname)"]
    - [groups_qeq,      Pattern.groups.__qualname__.__eq__,     ["Pattern.groups"],     true, "re.Pattern.groups.__qualname__ == 'Pattern.groups' (len=14; attribute descriptor for the number of capturing groups in the pattern)"]
    - [groups_qlen,     Pattern.groups.__qualname__.__len__,    [],                     14,   "re.Pattern.groups.__qualname__.__len__() == 14 ('Pattern.groups' has 14 characters)"]
    - [pattern_qeq,     Pattern.pattern.__qualname__.__eq__,    ["Pattern.pattern"],    true, "re.Pattern.pattern.__qualname__ == 'Pattern.pattern' (len=15; attribute descriptor for the original pattern string used to compile this regex)"]
    - [pattern_qlen,    Pattern.pattern.__qualname__.__len__,   [],                     15,   "re.Pattern.pattern.__qualname__.__len__() == 15 ('Pattern.pattern' has 15 characters; note that 'Pattern.' prefix (8) + 'pattern' (7) = 15)"]
    - [gindex_qeq,      Pattern.groupindex.__qualname__.__eq__, ["Pattern.groupindex"], true, "re.Pattern.groupindex.__qualname__ == 'Pattern.groupindex' (len=18; attribute descriptor for the dict mapping group names to group numbers; longest Pattern attribute qualname)"]
    - [gindex_qlen,     Pattern.groupindex.__qualname__.__len__,[],                     18,   "re.Pattern.groupindex.__qualname__.__len__() == 18 ('Pattern.groupindex' has 18 characters; 'Pattern.' (8) + 'groupindex' (10) = 18; the longest Pattern attribute descriptor qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra148.error.name_eq_PatternError:
  description: "re.error.__name__ == 'PatternError' (not 'error') — re.error is an alias that points to the re.PatternError class; the class was renamed to PatternError but the 'error' alias is maintained for backward compatibility; re.error is re.PatternError evaluates to True"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra148.error.mro_len_4:
  description: "re.error.__mro__.__len__() == 4 (MRO: [PatternError, Exception, BaseException, object]; a straightforward 4-entry chain; this contrasts with re.RegexFlag whose MRO has 7 entries due to the IntFlag/Flag/Enum/ReprEnum inheritance hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

invariant re_extra148.error.doc_len_333:
  description: "re.error.__doc__.__len__() == 333 (the PatternError docstring is 333 characters long; it documents all exception attributes: msg (error message), pattern (the pattern that caused the error), pos (position in pattern where error occurred), lineno, colno, and endpos)"
  category: doc_identity
  kind: python_call_eq
  function: error.__doc__.__len__
  args: []
  expected: 333

invariant re_extra148.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; the 7-entry chain reflects IntFlag's dual inheritance from int and Flag; this is significantly longer than re.Pattern.__mro__ (len=2) and re.error.__mro__ (len=4)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__mro__.__len__"
  args: []
  expected: 7

invariant re_extra148.RegexFlag.ASCII_val_256:
  description: "re.RegexFlag.ASCII == 256 (integer value 256; the largest RegexFlag member value; ASCII=256 is a power of 2 (2**8) and makes \\w, \\d, \\b etc. match only ASCII characters, overriding the default Unicode matching for str patterns)"
  category: constants
  kind: python_call_eq
  function: RegexFlag.ASCII.__eq__
  args: [256]
  expected: true

invariant re_extra148.Pattern.groupindex_qualname_len_18:
  description: "re.Pattern.groupindex.__qualname__.__len__() == 18 ('Pattern.groupindex' has 18 characters; the longest Pattern attribute descriptor qualname; 'Pattern.' prefix (8) + 'groupindex' (10) = 18; groupindex maps named group identifiers to their ordinal number)"
  category: qualname
  kind: python_call_eq
  function: Pattern.groupindex.__qualname__.__len__
  args: []
  expected: 18

invariant re_extra148.Pattern.flags_qualname_eq:
  description: "re.Pattern.flags.__qualname__ == 'Pattern.flags' (len=13) — the flags attribute descriptor gives the integer flags used to compile the pattern; it is a member_descriptor (a C-level data descriptor), not a Python property; its __qualname__ follows the same 'Pattern.<attr>' pattern as the Pattern methods from re_extra147"
  category: qualname
  kind: python_call_eq
  function: Pattern.flags.__qualname__.__eq__
  args: ["Pattern.flags"]
  expected: true

invariant re_extra148.RegexFlag.name_len_9:
  description: "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters; same length as 'fullmatch' — the longest re function __name__ from re_extra146 — but RegexFlag is a class name, not a function name)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__name__.__len__
  args: []
  expected: 9
