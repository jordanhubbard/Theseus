spec: pathlib_extra1546
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers path component properties and operator presence"
  notes:
    - "Wave 550 (_extra1546): bitwise operator __dict__ presence checks for pathlib module classes."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ (the / path-join operator) in its own __dict__, but does NOT define any bitwise operators (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__)."
    - "pathlib.PurePath does define comparison operators: __hash__, __eq__, __lt__, __le__, __gt__, __ge__ are in PurePath.__dict__. These wave 550 tables focus specifically on bitwise operators, which are entirely absent."
    - "pathlib.PurePosixPath.__dict__ is minimal: __doc__, __module__, __slots__, __static_attributes__, parser — no bitwise operators and no comparison operators at this level (inherited from PurePath)."
    - "pathlib.PureWindowsPath.__dict__ mirrors PurePosixPath in structure — minimal, with no bitwise operators."
    - "pathlib.Path.__dict__ contains filesystem-access methods (stat, open, read_bytes, read_text, write_bytes, write_text, exists, is_file, is_dir, mkdir, unlink, etc.) but no bitwise operators."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1546.purepath_bitwise_ops_absent:
  description: "pathlib.PurePath bitwise operator absence — all bitwise operators absent from pathlib.PurePath.__dict__; PurePath defines the / operator (__truediv__) and comparison operators but no bitwise operators; wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: pl1546pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1546pp001,
       pathlib.PurePath.__dict__.__contains__,
       ["__and__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__and__') == False — pathlib.PurePath is the base class for pure path manipulation; it overloads / via __truediv__ for path joining but defines no bitwise AND operator; __and__ is absent from PurePath.__dict__; verified with Python 3.14.3"]
    - [pl1546pp002,
       pathlib.PurePath.__dict__.__contains__,
       ["__or__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__or__') == False — pathlib.PurePath does not define __or__ in its own __dict__; | is not a path-joining operator; verified with Python 3.14.3"]
    - [pl1546pp003,
       pathlib.PurePath.__dict__.__contains__,
       ["__xor__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__xor__') == False — pathlib.PurePath does not define __xor__ in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp004,
       pathlib.PurePath.__dict__.__contains__,
       ["__invert__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__invert__') == False — pathlib.PurePath does not define __invert__ (unary ~) in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp005,
       pathlib.PurePath.__dict__.__contains__,
       ["__lshift__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__lshift__') == False — pathlib.PurePath does not define __lshift__ in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp006,
       pathlib.PurePath.__dict__.__contains__,
       ["__rshift__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rshift__') == False — pathlib.PurePath does not define __rshift__ in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp007,
       pathlib.PurePath.__dict__.__contains__,
       ["__rand__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rand__') == False — pathlib.PurePath does not define __rand__ (reflected bitwise AND) in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp008,
       pathlib.PurePath.__dict__.__contains__,
       ["__ror__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__ror__') == False — pathlib.PurePath does not define __ror__ (reflected bitwise OR) in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp009,
       pathlib.PurePath.__dict__.__contains__,
       ["__rxor__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rxor__') == False — pathlib.PurePath does not define __rxor__ (reflected bitwise XOR) in its own __dict__; verified with Python 3.14.3"]
    - [pl1546pp010,
       pathlib.PurePath.__dict__.__contains__,
       ["__truediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — positive anchor: pathlib.PurePath does define __truediv__ in its own __dict__; the / operator is overloaded for path joining (PurePath('/etc') / 'passwd' yields PurePath('/etc/passwd')); __truediv__ is present while all bitwise operators are absent; verified with Python 3.14.3"]
    - [pl1546pp011,
       pathlib.PurePath.__dict__.__contains__,
       ["__rtruediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__rtruediv__') == True — positive anchor: pathlib.PurePath defines __rtruediv__ in its own __dict__ (the reflected / operator enabling 'base' / PurePath('rel')); contrast: no reflected bitwise operators (__rand__, __ror__, __rxor__) are defined; verified with Python 3.14.3"]
    - [pl1546pp012,
       pathlib.PurePath.__dict__.__contains__,
       ["__hash__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__hash__') == True — positive anchor: pathlib.PurePath defines __hash__ in its own __dict__; PurePath objects are hashable (case-folded on Windows, case-sensitive on POSIX); paths can be used as dict keys or set members; __hash__ is present while all bitwise operators are absent; verified with Python 3.14.3"]

