spec: decimal_extra113
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra112.zspec.zsdl."
    - "This spec covers: decimal.Decimal comparison method qualnames not yet covered."
    - "decimal_extra105 covered Decimal.compare.__qualname__ == 'Decimal.compare' (len 15) and __len__()."
    - "No prior decimal spec has covered Decimal.compare_total, compare_signal, compare_total_mag, max, or min qualnames."
    - "decimal.Decimal.compare_total.__qualname__ == 'Decimal.compare_total' (len 21)."
    - "decimal.Decimal.compare_signal.__qualname__ == 'Decimal.compare_signal' (len 22)."
    - "decimal.Decimal.compare_total_mag.__qualname__ == 'Decimal.compare_total_mag' (len 25)."
    - "decimal.Decimal.max.__qualname__ == 'Decimal.max' (len 11)."
    - "decimal.Decimal.min.__qualname__ == 'Decimal.min' (len 11)."
    - "All five are method_descriptor objects (C extension methods from _decimal)."
    - "Length ordering: compare_total_mag(25) > compare_signal(22) > compare_total(21) > compare(15) > max(11) == min(11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.compare_total and compare_signal qualnames
# compare_total.__qualname__ == 'Decimal.compare_total' (21 chars).
# compare_signal.__qualname__ == 'Decimal.compare_signal' (22 chars).
# compare_total performs a total order comparison that treats NaN values
# and signed zeros as distinct; compare_signal is like compare() but signals
# InvalidOperation for every NaN. Both are method_descriptor objects.
# decimal_extra105 covered Decimal.compare qualname (len 15); the _total, _signal,
# and _total_mag variants were NOT covered in any prior decimal_extra spec.
# ---------------------------------------------------------------------------

table decimal_extra113.compare_total_signal_qualnames:
  description: "decimal.Decimal.compare_total.__qualname__='Decimal.compare_total'(21); compare_signal.__qualname__='Decimal.compare_signal'(22); both method_descriptor; equality assertions novel; prior specs covered compare(15) only"
  kind: python_call_eq
  category: method_identity
  id_prefix: deccmptots113a

  columns: [id, function, args, expected, description]
  rows:
    - [ct_qn_eq,      "Decimal.compare_total.__qualname__.__eq__",         ["Decimal.compare_total"],  true,  "decimal.Decimal.compare_total.__qualname__ == 'Decimal.compare_total' (21 chars; compare_total implements total-order comparison treating NaN and signed zeros as distinct values)"]
    - [ct_qn_len,     "Decimal.compare_total.__qualname__.__len__",        [],                         21,    "decimal.Decimal.compare_total.__qualname__.__len__() == 21 ('Decimal.compare_total' has 21 characters: 'Decimal.'(8)+'compare_total'(13)==21)"]
    - [cs_qn_eq,      "Decimal.compare_signal.__qualname__.__eq__",        ["Decimal.compare_signal"], true,  "decimal.Decimal.compare_signal.__qualname__ == 'Decimal.compare_signal' (22 chars; compare_signal is like compare but signals InvalidOperation for every NaN, including quiet NaN)"]
    - [cs_qn_len,     "Decimal.compare_signal.__qualname__.__len__",       [],                         22,    "decimal.Decimal.compare_signal.__qualname__.__len__() == 22 ('Decimal.compare_signal' has 22 characters: 'Decimal.'(8)+'compare_signal'(14)==22)"]
    - [cs_gt_ct,      "Decimal.compare_signal.__qualname__.__len__.__gt__", [21],                      true,  "len('Decimal.compare_signal') > len('Decimal.compare_total') (22 > 21; 'compare_signal'(14) is 1 char longer than 'compare_total'(13))"]
    - [ct_type,       "Decimal.compare_total.__class__.__name__.__eq__",   ["method_descriptor"],      true,  "type(decimal.Decimal.compare_total).__name__ == 'method_descriptor' (C extension method from Modules/_decimal/_decimal.c)"]
    - [cs_type,       "Decimal.compare_signal.__class__.__name__.__eq__",  ["method_descriptor"],      true,  "type(decimal.Decimal.compare_signal).__name__ == 'method_descriptor' (C extension method; same type as compare_total)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.compare_total_mag qualname
# compare_total_mag.__qualname__ == 'Decimal.compare_total_mag' (25 chars).
# compare_total_mag performs a total-order comparison of the magnitudes of two
# Decimal values, ignoring the sign. It is the longest compare variant qualname.
# 'compare_total_mag'(17) vs 'compare_total'(13) vs 'compare_signal'(14) vs 'compare'(7).
# No prior decimal_extra spec has covered compare_total_mag at all.
# ---------------------------------------------------------------------------

table decimal_extra113.compare_total_mag_qualname:
  description: "decimal.Decimal.compare_total_mag.__qualname__='Decimal.compare_total_mag'(25); longest compare-family qualname; compare_total_mag>compare_signal(22)>compare_total(21)>compare(15); method_descriptor"
  kind: python_call_eq
  category: method_identity
  id_prefix: deccmptotm113b

  columns: [id, function, args, expected, description]
  rows:
    - [ctm_qn_eq,     "Decimal.compare_total_mag.__qualname__.__eq__",        ["Decimal.compare_total_mag"], true, "decimal.Decimal.compare_total_mag.__qualname__ == 'Decimal.compare_total_mag' (25 chars; compare_total_mag compares magnitudes in total order, ignoring sign)"]
    - [ctm_qn_len,    "Decimal.compare_total_mag.__qualname__.__len__",       [],                            25,   "decimal.Decimal.compare_total_mag.__qualname__.__len__() == 25 ('Decimal.compare_total_mag' has 25 characters: 'Decimal.'(8)+'compare_total_mag'(17)==25)"]
    - [ctm_gt_cs,     "Decimal.compare_total_mag.__qualname__.__len__.__gt__", [22],                         true, "len('Decimal.compare_total_mag') > len('Decimal.compare_signal') (25 > 22; compare_total_mag is the longest compare-family qualname)"]
    - [ctm_gt_ct,     "Decimal.compare_total_mag.__qualname__.__len__.__gt__", [21],                         true, "len('Decimal.compare_total_mag') > len('Decimal.compare_total') (25 > 21)"]
    - [ctm_type,      "Decimal.compare_total_mag.__class__.__name__.__eq__",  ["method_descriptor"],         true, "type(decimal.Decimal.compare_total_mag).__name__ == 'method_descriptor' (C extension method; same type as all other Decimal comparison methods)"]
    - [ctm_ne_ct_eq,  "Decimal.compare_total_mag.__qualname__.__eq__",        ["Decimal.compare_total"],     false, "decimal.Decimal.compare_total_mag.__qualname__ != 'Decimal.compare_total' (distinct methods: compare_total_mag(25) vs compare_total(21))"]
    - [ctm_ne_cs_eq,  "Decimal.compare_total_mag.__qualname__.__eq__",        ["Decimal.compare_signal"],    false, "decimal.Decimal.compare_total_mag.__qualname__ != 'Decimal.compare_signal' (distinct methods: compare_total_mag(25) vs compare_signal(22))"]

# ---------------------------------------------------------------------------
# decimal.Decimal.max and Decimal.min qualnames
# Decimal.max.__qualname__ == 'Decimal.max' (11 chars).
# Decimal.min.__qualname__ == 'Decimal.min' (11 chars).
# max and min follow the General Decimal Arithmetic specification: they return the
# larger (or smaller) of two Decimal values, ignoring NaN in the result if possible.
# Both qualnames have identical length (11 chars), matching the other in the pair.
# No prior decimal_extra spec has covered Decimal.max or Decimal.min qualnames.
# compare_total_mag(25) > compare_signal(22) > compare_total(21) > compare(15) > max(11) == min(11).
# ---------------------------------------------------------------------------

table decimal_extra113.max_min_qualnames:
  description: "decimal.Decimal.max.__qualname__='Decimal.max'(11); min.__qualname__='Decimal.min'(11); both method_descriptor; max/min == 11 == 'Decimal.max'.__len__; shortest compare-family qualnames; novel equality assertions"
  kind: python_call_eq
  category: method_identity
  id_prefix: deccmpmaxm113c

  columns: [id, function, args, expected, description]
  rows:
    - [max_qn_eq,     "Decimal.max.__qualname__.__eq__",          ["Decimal.max"],     true,  "decimal.Decimal.max.__qualname__ == 'Decimal.max' (11 chars; returns the larger of two Decimals following GDA specification; NaN handling differs from Python built-in max)"]
    - [max_qn_len,    "Decimal.max.__qualname__.__len__",         [],                  11,    "decimal.Decimal.max.__qualname__.__len__() == 11 ('Decimal.max' has 11 characters: 'Decimal.'(8)+'max'(3)==11)"]
    - [min_qn_eq,     "Decimal.min.__qualname__.__eq__",          ["Decimal.min"],     true,  "decimal.Decimal.min.__qualname__ == 'Decimal.min' (11 chars; returns the smaller of two Decimals following GDA specification; same length as Decimal.max.__qualname__)"]
    - [min_qn_len,    "Decimal.min.__qualname__.__len__",         [],                  11,    "decimal.Decimal.min.__qualname__.__len__() == 11 ('Decimal.min' has 11 characters: 'Decimal.'(8)+'min'(3)==11)"]
    - [max_eq_min,    "Decimal.max.__qualname__.__len__.__eq__",  [11],                true,  "len('Decimal.max') == len('Decimal.min') == 11 (max and min have identical qualname lengths; both use the 8-char 'Decimal.' prefix and a 3-char method name)"]
    - [max_type,      "Decimal.max.__class__.__name__.__eq__",    ["method_descriptor"], true, "type(decimal.Decimal.max).__name__ == 'method_descriptor' (C extension method from Modules/_decimal/_decimal.c; same type as compare_total, compare_signal, compare_total_mag)"]
    - [min_type,      "Decimal.min.__class__.__name__.__eq__",    ["method_descriptor"], true, "type(decimal.Decimal.min).__name__ == 'method_descriptor' (C extension method; same type as Decimal.max and all other Decimal comparison methods)"]
    - [ct_gt_max,     "Decimal.compare_total.__qualname__.__len__.__gt__", [11],        true,  "len('Decimal.compare_total') > len('Decimal.max') (21 > 11; compare_total is 10 chars longer than max in qualname length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra113.Decimal.compare_total_qualname_eq:
  description: "decimal.Decimal.compare_total.__qualname__ == 'Decimal.compare_total' (length 21; compare_total implements the total-order comparison defined in the General Decimal Arithmetic specification; unlike the standard compare() method, compare_total treats all NaN values and signed zeros (positive zero vs negative zero) as distinct, ordered values: -NaN < -sNaN < -Infinity < ... < -0 < +0 < ... < +Infinity < sNaN < NaN; compare_total returns Decimal(-1), Decimal(0), or Decimal(1); decimal_extra105 covered Decimal.compare.__qualname__ (len 15) and Context.compare.__qualname__ (len 15) but the compare_total, compare_signal, and compare_total_mag variants were NOT covered in any prior decimal_extra spec; this is the first equality assertion for compare_total qualname)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.compare_total.__qualname__.__eq__"
  args: ["Decimal.compare_total"]
  expected: true

invariant decimal_extra113.Decimal.compare_signal_qualname_eq:
  description: "decimal.Decimal.compare_signal.__qualname__ == 'Decimal.compare_signal' (length 22; compare_signal performs the same comparison as compare() but signals InvalidOperation for every NaN encountered, including quiet NaN (qNaN) as well as signaling NaN (sNaN); in standard compare(), quiet NaN causes a NaN result without signaling; compare_signal (len 22) is 1 character longer than compare_total (len 21) because 'compare_signal' (14 chars) is 1 char longer than 'compare_total' (13 chars); no prior decimal_extra spec has covered Decimal.compare_signal qualname in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.compare_signal.__qualname__.__eq__"
  args: ["Decimal.compare_signal"]
  expected: true

invariant decimal_extra113.Decimal.compare_total_mag_qualname_eq:
  description: "decimal.Decimal.compare_total_mag.__qualname__ == 'Decimal.compare_total_mag' (length 25; compare_total_mag performs a total-order comparison of the absolute magnitudes of two Decimal values, ignoring their signs; it is equivalent to calling compare_total(abs(self), abs(other)); 'Decimal.compare_total_mag' (25 chars) is the longest qualname among all Decimal comparison methods: compare_total_mag(25) > compare_signal(22) > compare_total(21) > compare(15) > max(11) == min(11); at 25 characters it equals the length of 'IncrementalNewlineDecoder' in the io module; no prior decimal_extra spec has covered compare_total_mag in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.compare_total_mag.__qualname__.__eq__"
  args: ["Decimal.compare_total_mag"]
  expected: true

invariant decimal_extra113.Decimal.max_qualname_eq:
  description: "decimal.Decimal.max.__qualname__ == 'Decimal.max' (length 11; Decimal.max(other, context=None) returns the larger of self and other, following the General Decimal Arithmetic specification; if one operand is a quiet NaN and the other is numeric, the numeric operand is returned without signaling; Decimal.max behaves differently from Python's built-in max() because it handles NaN according to GDA rules rather than Python's comparison protocol; 'Decimal.max' (11 chars) is the shortest among the comparison method qualnames covered in this spec: max(11) == min(11) < compare(15) < compare_total(21) < compare_signal(22) < compare_total_mag(25); no prior decimal_extra spec has covered Decimal.max qualname)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.max.__qualname__.__eq__"
  args: ["Decimal.max"]
  expected: true

invariant decimal_extra113.Decimal.min_qualname_eq:
  description: "decimal.Decimal.min.__qualname__ == 'Decimal.min' (length 11; Decimal.min(other, context=None) returns the smaller of self and other following the GDA specification; like Decimal.max, it handles NaN by returning the numeric operand when one operand is a quiet NaN; 'Decimal.min' (11 chars) is the same length as 'Decimal.max' (11 chars) — both use the 8-char 'Decimal.' prefix and a 3-char method name; together max and min are the shortest comparison method qualnames; no prior decimal_extra spec has covered Decimal.min qualname in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.min.__qualname__.__eq__"
  args: ["Decimal.min"]
  expected: true

