spec: xmlrpc_client_extra3
version: ">=3.9"
backend: python_module(xmlrpc.client)

docs: https://docs.python.org/3/library/xmlrpc.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xmlrpc.client.html — Python xmlrpc.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/client.py"
  notes:
    - "This spec extends xmlrpc_client.zspec.zsdl, xmlrpc_client_extra.zspec.zsdl, and xmlrpc_client_extra2.zspec.zsdl — it does NOT duplicate invariants already present there."
    - "xmlrpc_client_extra2.zspec.zsdl covers __qualname__ for: ServerProxy, Fault, ProtocolError, ResponseError, Error, Binary, DateTime (in its class_qualnames table), and __module__ for Fault/ProtocolError/Binary/DateTime/ResponseError/MultiCall/Unmarshaller/Marshaller, and loads/dumps __module__."
    - "This spec adds __qualname__ checks for: MultiCall, dumps, loads — none appear in any prior spec."
    - "xmlrpc_client.zspec.zsdl covers loads/__name__ and dumps/__name__ in its function_names table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — MultiCall, dumps, loads
# (xmlrpc_client_extra2 covers ServerProxy/Fault/ProtocolError/ResponseError/
#  Error/Binary/DateTime qualnames; this spec fills the remaining gaps)
# ---------------------------------------------------------------------------

table xmlrpc_client_extra3.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [MultiCall, MultiCall.__qualname__.__eq__, ["MultiCall"], true]
    - [dumps,     dumps.__qualname__.__eq__,     ["dumps"],     true]
    - [loads,     loads.__qualname__.__eq__,     ["loads"],     true]
