spec: inspect_extra1201
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.Parameter.POSITIONAL_ONLY.__eq__(0), inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1), inspect.Parameter.VAR_POSITIONAL.__eq__(2), inspect.Parameter.KEYWORD_ONLY.__eq__(3), inspect.Parameter.VAR_KEYWORD.__eq__(4), inspect.Parameter.empty.__class__.__name__, inspect.Parameter._ParameterKind.__module__, inspect.Parameter._ParameterKind.__qualname__ — not covered in _extra1171/_extra1186"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1201.parameter_kind_eq_values:
  description: "inspect.Parameter kind enum constants numeric __eq__ checks"
  kind: python_call_eq
  category: parameter_kind_eq_values
  id_prefix: ip1201pk
  columns: [id, function, args, expected]
  rows:
    - [ip1201pk001, inspect.Parameter.POSITIONAL_ONLY.__eq__,           [0],   true]
    - [ip1201pk002, inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__,     [1],   true]
    - [ip1201pk003, inspect.Parameter.VAR_POSITIONAL.__eq__,            [2],   true]
    - [ip1201pk004, inspect.Parameter.KEYWORD_ONLY.__eq__,              [3],   true]
    - [ip1201pk005, inspect.Parameter.VAR_KEYWORD.__eq__,               [4],   true]
    - [ip1201pk006, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,       ["_ParameterKind"],   true]
    - [ip1201pk007, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"],   true]
    - [ip1201pk008, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,        ["_ParameterKind"],   true]

table inspect_extra1201.parameter_empty_and_kind_module:
  description: "inspect.Parameter.empty class name and _ParameterKind module/qualname identity"
  kind: python_call_eq
  category: parameter_empty_and_kind_module
  id_prefix: ip1201pe
  columns: [id, function, args, expected]
  rows:
    - [ip1201pe001, inspect.Parameter.empty.__class__.__name__.__eq__,        ["_empty"],        true]
    - [ip1201pe002, inspect.Parameter._ParameterKind.__module__.__eq__,       ["inspect"],       true]
    - [ip1201pe003, inspect.Parameter._ParameterKind.__qualname__.__eq__,     ["_ParameterKind"], true]
    - [ip1201pe004, inspect.Parameter._ParameterKind.__class__.__name__.__eq__, ["EnumType"],    true]
    - [ip1201pe005, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,  ["_ParameterKind"], true]
    - [ip1201pe006, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__,   ["_ParameterKind"], true]
    - [ip1201pe007, inspect.Parameter.__module__.__eq__,                       ["inspect"],       true]
    - [ip1201pe008, inspect.Parameter.__qualname__.__eq__,                     ["Parameter"],     true]

table inspect_extra1201.parameter_class_identity:
  description: "inspect.Parameter class-level identity and additional empty checks"
  kind: python_call_eq
  category: parameter_class_identity
  id_prefix: ip1201ci
  columns: [id, function, args, expected]
  rows:
    - [ip1201ci001, inspect.Parameter.__class__.__name__.__eq__,               ["type"],          true]
    - [ip1201ci002, inspect.Parameter.empty.__class__.__qualname__.__eq__,     ["_empty"],        true]
    - [ip1201ci003, inspect.Parameter.POSITIONAL_ONLY.__eq__,                  [1],               false]
    - [ip1201ci004, inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__,            [0],               false]
    - [ip1201ci005, inspect.Parameter.VAR_POSITIONAL.__eq__,                   [3],               false]
    - [ip1201ci006, inspect.Parameter.KEYWORD_ONLY.__eq__,                     [2],               false]
    - [ip1201ci007, inspect.Parameter.VAR_KEYWORD.__eq__,                      [3],               false]
    - [ip1201ci008, inspect.Parameter._ParameterKind.__qualname__.__eq__,      ["inspect._ParameterKind"], false]
