spec: shutil_extra21
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra5.zspec.zsdl — covers __qualname__ equality for make_archive/unpack_archive and others"
    - "shutil_extra7.zspec.zsdl — covers get_unpack_formats.__qualname__ equality standalone"
    - "shutil_extra11.zspec.zsdl — covers which.__qualname__ and get_terminal_size.__qualname__ equality"
    - "shutil_extra19.zspec.zsdl — covers qualname lengths for copy/copy2/copytree/rmtree/disk_usage/which"
    - "shutil_extra20.zspec.zsdl — covers qualname lengths for copyfile/copystat/copymode/move"
  notes:
    - "This spec extends shutil.zspec.zsdl and all prior shutil_extra specs through shutil_extra20.zspec.zsdl."
    - "Focus: __qualname__ string lengths for archive/unpack/terminal functions — not covered as standalone length invariants in any prior shutil spec."
    - "shutil.get_archive_formats.__qualname__.__len__() == 19 — 'get_archive_formats' has 19 characters; qualname equality covered in extra5 but length not yet covered."
    - "shutil.get_unpack_formats.__qualname__.__len__() == 18 — 'get_unpack_formats' has 18 characters; qualname equality covered in extra7 but length not yet covered."
    - "shutil.make_archive.__qualname__.__len__() == 12 — 'make_archive' has 12 characters; qualname equality covered in extra5 but length not yet covered."
    - "shutil.unpack_archive.__qualname__.__len__() == 14 — 'unpack_archive' has 14 characters; qualname equality covered in extra5 but length not yet covered."
    - "shutil.get_terminal_size.__qualname__.__len__() == 17 — 'get_terminal_size' has 17 characters; qualname equality covered in extra11 but length not yet covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ length table — get_archive_formats, get_unpack_formats,
# make_archive, unpack_archive, get_terminal_size
#
# Prior specs cover __qualname__ equality for all five functions but no prior
# shutil spec covers the __len__() of any of these qualname strings.
# This table anchors qualname-length facts for five archive/utility functions
# in the extra21 namespace.
# ---------------------------------------------------------------------------

table shutil_extra21.qualname_lengths:
  description: "__qualname__ string length for archive and terminal-size shutil functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen21

  columns: [id, function, args, expected]
  rows:
    - [get_archive_formats, get_archive_formats.__qualname__.__len__, [], 19]
    - [get_unpack_formats,  get_unpack_formats.__qualname__.__len__,  [], 18]
    - [make_archive,        make_archive.__qualname__.__len__,        [], 12]
    - [unpack_archive,      unpack_archive.__qualname__.__len__,      [], 14]
    - [get_terminal_size,   get_terminal_size.__qualname__.__len__,   [], 17]

# ---------------------------------------------------------------------------
# Standalone qualname length invariants
# ---------------------------------------------------------------------------

invariant shutil_extra21.get_archive_formats.qualname_length:
  description: "shutil.get_archive_formats.__qualname__.__len__() == 19 — 'get_archive_formats' has 19 characters"
  category: function_identity
  kind: python_call_eq
  function: get_archive_formats.__qualname__.__len__
  args: []
  expected: 19

invariant shutil_extra21.get_unpack_formats.qualname_length:
  description: "shutil.get_unpack_formats.__qualname__.__len__() == 18 — 'get_unpack_formats' has 18 characters"
  category: function_identity
  kind: python_call_eq
  function: get_unpack_formats.__qualname__.__len__
  args: []
  expected: 18

invariant shutil_extra21.make_archive.qualname_length:
  description: "shutil.make_archive.__qualname__.__len__() == 12 — 'make_archive' has 12 characters"
  category: function_identity
  kind: python_call_eq
  function: make_archive.__qualname__.__len__
  args: []
  expected: 12

invariant shutil_extra21.unpack_archive.qualname_length:
  description: "shutil.unpack_archive.__qualname__.__len__() == 14 — 'unpack_archive' has 14 characters"
  category: function_identity
  kind: python_call_eq
  function: unpack_archive.__qualname__.__len__
  args: []
  expected: 14

invariant shutil_extra21.get_terminal_size.qualname_length:
  description: "shutil.get_terminal_size.__qualname__.__len__() == 17 — 'get_terminal_size' has 17 characters"
  category: function_identity
  kind: python_call_eq
  function: get_terminal_size.__qualname__.__len__
  args: []
  expected: 17
