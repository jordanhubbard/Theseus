spec: threading_extra190
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Thread.__init__.__name__ == '__init__' (len=8); verified with Python 3.14.3."
    - "threading.Thread.__repr__.__name__ == '__repr__' (len=8); verified with Python 3.14.3."
    - "threading.Thread.__class__.__name__ == 'type' — Thread is a plain Python class; verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading'; verified with Python 3.14.3."
    - "threading.Thread.__qualname__ == 'Thread'; verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object; verified with Python 3.14.3."
    - "threading.Thread.__mro__.__len__() == 2 — MRO is (Thread, object); verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len=15); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread class-level identity
#
# threading.Thread.__class__.__name__ == 'type'
# threading.Thread.__module__         == 'threading'
# threading.Thread.__qualname__       == 'Thread'
# threading.Thread.__bases__[0].__name__ == 'object'
#
# Thread is a plain Python class defined at module level.
# New to extra190.
# ---------------------------------------------------------------------------

table threading_extra190.thread_class_identity:
  description: "Thread.__class__.__name__=='type'; Thread.__module__=='threading'; Thread.__qualname__=='Thread'; Thread.__bases__[0].__name__=='object'; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthreaddunder190

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,
       Thread.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Thread.__class__.__name__.__eq__('type') == True — Thread is a plain Python class; its metaclass is type; str.__eq__ returns True; verified with Python 3.14.3; new to extra190"]
    - [module_eq,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in the threading module; str.__eq__ returns True; verified with Python 3.14.3; new to extra190"]
    - [qualname_eq,
       Thread.__qualname__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — top-level class so __qualname__ equals the simple name 'Thread'; str.__eq__ returns True; verified with Python 3.14.3; new to extra190"]
    - [base_object_eq,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread's only direct base class is object; str.__eq__ returns True; verified with Python 3.14.3; new to extra190"]
    - [mro_len,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — MRO is (Thread, object); tuple.__len__() returns 2; verified with Python 3.14.3; new to extra190"]

