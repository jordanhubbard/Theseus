spec: decimal_extra1321
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal.__str__, predicates, as_tuple, class_name, getcontext, error cases"
    - "decimal_extra.zspec.zsdl — covers predicates, to_eng_string, Context/BasicContext/ExtendedContext names, DefaultContext, ROUND_* modes"
    - "decimal_extra13.zspec.zsdl — covers Decimal/Context method qualnames and class identity"
  notes:
    - "Wave 535 theme: __repr__ and __str__ method class checks for decimal module classes."
    - "decimal.Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C extension type."
    - "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (length 16) — Decimal defines its own C-level __repr__."
    - "decimal.Context.__repr__.__class__.__name__ == 'wrapper_descriptor' — Context is also a C extension type."
    - "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' (length 16) — Context defines its own C-level __repr__."
    - "decimal.DecimalException.__repr__.__class__.__name__ == 'wrapper_descriptor' — inherits from BaseException."
    - "decimal.DecimalException.__repr__.__qualname__ == 'BaseException.__repr__' — no custom __repr__ on DecimalException."
    - "decimal.Decimal.__str__.__class__.__name__ == 'wrapper_descriptor' — Decimal defines __str__ as a C slot."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (length 15) — Decimal has its own __str__ formatting."
    - "decimal.Context.__str__.__class__.__name__ == 'wrapper_descriptor' — inherits from object."
    - "decimal.Context.__str__.__qualname__ == 'object.__str__' — Context does not define __str__."
    - "decimal.InvalidOperation and decimal.Overflow inherit __repr__ from BaseException."
    - "repr(decimal.Decimal).__class__.__name__ == 'str' — repr of the class object itself returns a str."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __repr__ class name checks: decimal.Decimal, decimal.Context, decimal.DecimalException
# Decimal and Context define their own C-level __repr__; DecimalException inherits from BaseException.
# All yield wrapper_descriptor since they are all C extension types.
# ---------------------------------------------------------------------------

table decimal_extra1321.repr_class_checks:
  description: "decimal.Decimal/Context/DecimalException __repr__.__class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: repr_class
  id_prefix: dc1321rc

  columns: [id, function, args, expected]
  rows:
    - [dc1321rc001, Decimal.__repr__.__class__.__name__.__eq__,          ["wrapper_descriptor"], true]
    - [dc1321rc002, Context.__repr__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]
    - [dc1321rc003, DecimalException.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [dc1321rc004, InvalidOperation.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [dc1321rc005, Overflow.__repr__.__class__.__name__.__eq__,          ["wrapper_descriptor"], true]
    - [dc1321rc006, Decimal.__repr__.__class__.__name__.__eq__,           ["function"],            false]
    - [dc1321rc007, Context.__repr__.__class__.__name__.__eq__,           ["function"],            false]
    - [dc1321rc008, Decimal.__repr__.__class__.__name__.__eq__,           ["slot_wrapper"],         false]
    - [dc1321rc009, DecimalException.__repr__.__class__.__name__.__eq__,  ["function"],            false]

# ---------------------------------------------------------------------------
# __repr__ qualname checks
# decimal.Decimal defines its own __repr__ — qualname == 'Decimal.__repr__' (length 16).
# decimal.Context defines its own __repr__ — qualname == 'Context.__repr__' (length 16).
# decimal.DecimalException inherits from BaseException — qualname == 'BaseException.__repr__'.
# decimal.InvalidOperation and decimal.Overflow also inherit from BaseException.
# ---------------------------------------------------------------------------

table decimal_extra1321.repr_qualname_checks:
  description: "decimal.Decimal/Context/DecimalException __repr__.__qualname__ values"
  kind: python_call_eq
  category: repr_qualname
  id_prefix: dc1321rq

  columns: [id, function, args, expected]
  rows:
    - [dc1321rq001, Decimal.__repr__.__qualname__.__eq__,         ["Decimal.__repr__"],         true]
    - [dc1321rq002, Decimal.__repr__.__qualname__.__len__,        [],                             16]
    - [dc1321rq003, Context.__repr__.__qualname__.__eq__,         ["Context.__repr__"],           true]
    - [dc1321rq004, Context.__repr__.__qualname__.__len__,        [],                             16]
    - [dc1321rq005, DecimalException.__repr__.__qualname__.__eq__,["BaseException.__repr__"],     true]
    - [dc1321rq006, InvalidOperation.__repr__.__qualname__.__eq__,["BaseException.__repr__"],     true]
    - [dc1321rq007, Overflow.__repr__.__qualname__.__eq__,        ["BaseException.__repr__"],     true]
    - [dc1321rq008, Decimal.__repr__.__qualname__.__eq__,         ["BaseException.__repr__"],     false]
    - [dc1321rq009, Context.__repr__.__qualname__.__eq__,         ["BaseException.__repr__"],     false]

# ---------------------------------------------------------------------------
# __str__ qualname checks
# decimal.Decimal defines its own __str__ — qualname == 'Decimal.__str__' (length 15).
# decimal.Context inherits __str__ from object — qualname == 'object.__str__'.
# decimal.DecimalException inherits __str__ from BaseException — qualname resolves accordingly.
# ---------------------------------------------------------------------------

table decimal_extra1321.str_qualname_checks:
  description: "decimal.Decimal/Context __str__.__qualname__ values"
  kind: python_call_eq
  category: str_qualname
  id_prefix: dc1321sq

  columns: [id, function, args, expected]
  rows:
    - [dc1321sq001, Decimal.__str__.__qualname__.__eq__,  ["Decimal.__str__"],  true]
    - [dc1321sq002, Decimal.__str__.__qualname__.__len__, [],                    15]
    - [dc1321sq003, Context.__str__.__qualname__.__eq__,  ["object.__str__"],    true]
    - [dc1321sq004, Decimal.__str__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [dc1321sq005, Context.__str__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [dc1321sq006, Decimal.__str__.__qualname__.__eq__,  ["object.__str__"],    false]
    - [dc1321sq007, Context.__str__.__qualname__.__eq__,  ["Context.__str__"],   false]
    - [dc1321sq008, Decimal.__str__.__qualname__.__eq__,  ["Decimal.__repr__"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra1321.Decimal.repr_is_wrapper_descriptor:
  description: "decimal.Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C extension type implemented in _decimal.c"
  category: repr_class
  kind: python_call_eq
  function: Decimal.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra1321.Decimal.repr_qualname_eq:
  description: "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' — Decimal defines its own C-level __repr__ slot"
  category: repr_qualname
  kind: python_call_eq
  function: Decimal.__repr__.__qualname__.__eq__
  args: ["Decimal.__repr__"]
  expected: true

invariant decimal_extra1321.Decimal.repr_qualname_len_16:
  description: "decimal.Decimal.__repr__.__qualname__.__len__() == 16 ('Decimal.__repr__' has 16 characters)"
  category: repr_qualname
  kind: python_call_eq
  function: Decimal.__repr__.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra1321.Context.repr_qualname_eq:
  description: "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' — Context defines its own C-level __repr__ slot"
  category: repr_qualname
  kind: python_call_eq
  function: Context.__repr__.__qualname__.__eq__
  args: ["Context.__repr__"]
  expected: true

invariant decimal_extra1321.Context.repr_qualname_len_16:
  description: "decimal.Context.__repr__.__qualname__.__len__() == 16 ('Context.__repr__' has 16 characters)"
  category: repr_qualname
  kind: python_call_eq
  function: Context.__repr__.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra1321.Decimal.str_qualname_eq:
  description: "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' — Decimal has its own __str__ producing the canonical decimal string representation"
  category: str_qualname
  kind: python_call_eq
  function: Decimal.__str__.__qualname__.__eq__
  args: ["Decimal.__str__"]
  expected: true

invariant decimal_extra1321.Decimal.str_qualname_len_15:
  description: "decimal.Decimal.__str__.__qualname__.__len__() == 15 ('Decimal.__str__' has 15 characters)"
  category: str_qualname
  kind: python_call_eq
  function: Decimal.__str__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra1321.DecimalException.repr_from_BaseException:
  description: "decimal.DecimalException.__repr__.__qualname__ == 'BaseException.__repr__' — DecimalException does not define its own __repr__"
  category: repr_qualname
  kind: python_call_eq
  function: DecimalException.__repr__.__qualname__.__eq__
  args: ["BaseException.__repr__"]
  expected: true
