spec: concurrent_futures_extra26
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra25.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity, exception bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, thread/process submodule __name__, ThreadPoolExecutor/ProcessPoolExecutor/Future __module__.__len__(), ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__.__len__(), as_completed/wait __qualname__, as_completed/wait __module__.__len__()."
    - "This spec covers: ThreadPoolExecutor/ProcessPoolExecutor method __qualname__.__len__(); Future method __qualname__.__len__(); Executor.__module__.__len__(); ThreadPoolExecutor.submit/__qualname__.__len__(); ThreadPoolExecutor.shutdown/__qualname__.__len__(); Executor.map/__qualname__.__len__()."
    - "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — length 25."
    - "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' — length 27."
    - "Executor.map.__qualname__ == 'Executor.map' — length 12 (inherited from base class)."
    - "Future.result.__qualname__ == 'Future.result' — length 13."
    - "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' — length 24."
    - "Future.cancel.__qualname__ == 'Future.cancel' — length 13."
    - "Executor.__module__ == 'concurrent.futures._base' — length 24."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ length table — extra26 namespace
#
# Methods defined directly on ThreadPoolExecutor carry the class name as
# the __qualname__ prefix. submit and shutdown are defined on
# ThreadPoolExecutor itself; map is inherited from the Executor base class
# and therefore has the shorter 'Executor.map' qualname.
#   ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (25)
#   ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (27)
#   ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (12)
# ---------------------------------------------------------------------------

table concurrent_futures_extra26.tpe_method_qualname_lengths:
  description: "ThreadPoolExecutor method __qualname__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tpemqualnamelen26

  columns: [id, function, args, expected]
  rows:
    - [submit,   ThreadPoolExecutor.submit.__qualname__.__len__,   [], 25]
    - [shutdown, ThreadPoolExecutor.shutdown.__qualname__.__len__, [], 27]
    - [map,      ThreadPoolExecutor.map.__qualname__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# Future method __qualname__ length table — extra26 namespace
#
# Methods defined on concurrent.futures.Future carry 'Future.' as their
# __qualname__ prefix. No prior spec measures __qualname__.__len__() for
# Future instance methods.
#   Future.result.__qualname__ == 'Future.result' (13)
#   Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (24)
#   Future.cancel.__qualname__ == 'Future.cancel' (13)
# ---------------------------------------------------------------------------

table concurrent_futures_extra26.future_method_qualname_lengths:
  description: "concurrent.futures.Future method __qualname__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futmqualnamelen26

  columns: [id, function, args, expected]
  rows:
    - [result,            Future.result.__qualname__.__len__,            [], 13]
    - [add_done_callback, Future.add_done_callback.__qualname__.__len__, [], 24]
    - [cancel,            Future.cancel.__qualname__.__len__,            [], 13]

# ---------------------------------------------------------------------------
# Executor.__module__ length — extra26 standalone invariant
#
# concurrent.futures.Executor is the abstract base class defined in
# concurrent.futures._base. Its __module__ == 'concurrent.futures._base'
# (length 24), matching Future, as_completed, and wait. Prior specs
# confirmed __module__.__len__() for Future, as_completed, and wait; this
# invariant adds Executor to that verified set.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra26.Executor.module_len:
  description: "concurrent.futures.Executor.__module__.__len__() == 24 — defined in concurrent.futures._base"
  category: class_modules
  kind: python_call_eq
  function: Executor.__module__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.submit qualname string equality — extra26 standalone
#
# Confirms the full __qualname__ string 'ThreadPoolExecutor.submit' for the
# submit method, complementing the length check in the table above.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra26.tpe_submit_qualname_eq:
  description: "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — method defined on ThreadPoolExecutor"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true
