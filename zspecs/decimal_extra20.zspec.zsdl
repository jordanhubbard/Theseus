spec: decimal_extra20
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra through decimal_extra19."
    - "decimal has no __all__ attribute (verified: hasattr(decimal, '__all__') == False)."
    - "decimal_extra13 covers ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR string equality via __eq__."
    - "decimal_extra17 covers ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR __class__.__name__.__eq__ == 'str'."
    - "No prior spec records __len__ of the rounding-mode string values (e.g. len('ROUND_UP') == 8)."
    - "No prior spec records __qualname__.__len__ for localcontext, getcontext, or setcontext."
    - "No prior spec records __dict__.__class__.__name__.__len__ for Decimal, Context, or DecimalException."
    - "Decimal.__dict__.__class__.__name__ == 'mappingproxy' (len 12); same for Context and DecimalException."
    - "Context.__mro__.__len__() == 2 — Context inherits only from object."
    - "DecimalException.__bases__[0].__name__ == 'ArithmeticError' (len 15)."
    - "InvalidOperation.__bases__[0].__name__ == 'DecimalException' (len 16)."
    - "Overflow.__bases__[0].__name__ == 'Inexact' (len 7) — Overflow is a subclass of Inexact, not DecimalException directly."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Rounding-mode string constant __len__ values
#
# decimal_extra13 confirms each constant equals its own string value.
# decimal_extra17 confirms each constant's __class__.__name__ == 'str'.
# No prior spec records the character length of each rounding-mode string.
# ---------------------------------------------------------------------------

table decimal_extra20.rounding_string_len:
  description: "__len__ for each rounding-mode string constant"
  kind: python_call_eq
  category: constants
  id_prefix: rlen

  columns: [id, function, args, expected, description]
  rows:
    - [round_up,        ROUND_UP.__len__,        [], 8,  "len('ROUND_UP') == 8"]
    - [round_down,      ROUND_DOWN.__len__,      [], 10, "len('ROUND_DOWN') == 10"]
    - [round_half_up,   ROUND_HALF_UP.__len__,   [], 13, "len('ROUND_HALF_UP') == 13"]
    - [round_half_down, ROUND_HALF_DOWN.__len__,  [], 15, "len('ROUND_HALF_DOWN') == 15"]
    - [round_ceiling,   ROUND_CEILING.__len__,   [], 13, "len('ROUND_CEILING') == 13"]
    - [round_floor,     ROUND_FLOOR.__len__,     [], 11, "len('ROUND_FLOOR') == 11"]
    - [round_half_even, ROUND_HALF_EVEN.__len__,  [], 15, "len('ROUND_HALF_EVEN') == 15"]
    - [round_05up,      ROUND_05UP.__len__,      [], 10, "len('ROUND_05UP') == 10"]

# ---------------------------------------------------------------------------
# Context function __qualname__.__len__
#
# decimal_extra14 covers getcontext() via method_chain, checking the returned
# Context object — not the __qualname__ of the function itself.
# No prior spec records __qualname__.__len__ for localcontext, getcontext,
# or setcontext.
# ---------------------------------------------------------------------------

table decimal_extra20.context_fn_qualname_len:
  description: "__qualname__.__len__ for context management functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: ctx_qlen

  columns: [id, function, args, expected, description]
  rows:
    - [localcontext, localcontext.__qualname__.__len__, [], 12, "len('localcontext') == 12"]
    - [getcontext,   getcontext.__qualname__.__len__,   [], 10, "len('getcontext') == 10"]
    - [setcontext,   setcontext.__qualname__.__len__,   [], 10, "len('setcontext') == 10"]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__ — mappingproxy introspection
#
# Class __dict__ returns a mappingproxy, not a plain dict. No prior decimal
# spec records the __dict__.__class__.__name__.__len__ for any class.
# 'mappingproxy' has 12 characters.
# ---------------------------------------------------------------------------

table decimal_extra20.class_dict_type_name_len:
  description: "__dict__.__class__.__name__.__len__ for Decimal, Context, DecimalException"
  kind: python_call_eq
  category: class_metadata
  id_prefix: dict_type_len

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_dict,   Decimal.__dict__.__class__.__name__.__len__,          [], 12, "Decimal.__dict__.__class__.__name__ == 'mappingproxy', len 12"]
    - [context_dict,   Context.__dict__.__class__.__name__.__len__,          [], 12, "Context.__dict__.__class__.__name__ == 'mappingproxy', len 12"]
    - [decexc_dict,    DecimalException.__dict__.__class__.__name__.__len__, [], 12, "DecimalException.__dict__.__class__.__name__ == 'mappingproxy', len 12"]

# ---------------------------------------------------------------------------
# Context.__mro__.__len__ — MRO length for Context class
#
# decimal_extra17 covers Decimal.__mro__.__len__ == 2 and Decimal.__mro__[1].
# No prior spec covers Context.__mro__.__len__. Context also inherits only
# from object, so its MRO has length 2: [Context, object].
# ---------------------------------------------------------------------------

invariant decimal_extra20.Context.mro_len:
  description: "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Exception base class __name__.__len__ — DecimalException, InvalidOperation, Overflow
#
# decimal_extra19 covers __bases__[0].__name__.__eq__ (string equality) for
# Decimal/Context/Clamped/Inexact/Rounded/Subnormal/FloatOperation.
# No prior spec records __bases__[0].__name__.__len__ (character length).
# ---------------------------------------------------------------------------

invariant decimal_extra20.DecimalException.base_name_len:
  description: "decimal.DecimalException.__bases__[0].__name__.__len__() == 15 — 'ArithmeticError' has 15 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__len__"
  args: []
  expected: 15

invariant decimal_extra20.InvalidOperation.base_name_len:
  description: "decimal.InvalidOperation.__bases__[0].__name__.__len__() == 16 — 'DecimalException' has 16 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "InvalidOperation.__bases__[0].__name__.__len__"
  args: []
  expected: 16

invariant decimal_extra20.Overflow.base_name_len:
  description: "decimal.Overflow.__bases__[0].__name__.__len__() == 7 — 'Inexact' has 7 characters; Overflow subclasses Inexact, not DecimalException directly"
  category: class_hierarchy
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__len__"
  args: []
  expected: 7
