spec: inspect_extra133
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers, inspect.isfunction, inspect.isclass, inspect.ismodule, and inspect.isdatadescriptor co_varnames, co_argcount, and __qualname__ attributes (Wave 261)."
    - "inspect.getmembers.__code__.co_varnames == ('object', 'predicate') — getmembers takes 2 arguments. Verified with Python 3.14.3."
    - "len(inspect.getmembers.__code__.co_varnames) == 2. Verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers' (len 10). Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_varnames == ('object',) — isfunction takes 1 argument. Verified with Python 3.14.3."
    - "len(inspect.isfunction.__code__.co_varnames) == 1. Verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction' (len 10). Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_varnames == ('object',) — isclass takes 1 argument. Verified with Python 3.14.3."
    - "len(inspect.isclass.__code__.co_varnames) == 1. Verified with Python 3.14.3."
    - "inspect.isclass.__qualname__ == 'isclass' (len 7). Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_varnames == ('object',) — ismodule takes 1 argument. Verified with Python 3.14.3."
    - "len(inspect.ismodule.__code__.co_varnames) == 1. Verified with Python 3.14.3."
    - "inspect.ismodule.__qualname__ == 'ismodule' (len 8). Verified with Python 3.14.3."
    - "inspect.isdatadescriptor.__code__.co_varnames == ('object', 'tp') — 2 local variables. Verified with Python 3.14.3."
    - "len(inspect.isdatadescriptor.__code__.co_varnames) == 2. Verified with Python 3.14.3."
    - "inspect.isdatadescriptor.__qualname__ == 'isdatadescriptor' (len 16). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers code attributes and qualname
#
# Wave 261 theme: inspect.getmembers co_varnames and __qualname__.
#
# inspect.getmembers.__code__.co_argcount == 2
# len(inspect.getmembers.__code__.co_varnames) == 2
# inspect.getmembers.__code__.co_varnames[0] == 'object'
# inspect.getmembers.__code__.co_varnames[1] == 'predicate'
# inspect.getmembers.__qualname__ == 'getmembers' (len 10)
# inspect.getmembers.__module__ == 'inspect'
#
# getmembers is defined as 'def getmembers(object, predicate=None):' in Lib/inspect.py.
# New to extra133.
# ---------------------------------------------------------------------------

table inspect_extra133.getmembers_code_attrs:
  description: "inspect.getmembers code attributes: co_argcount==2, co_varnames len 2, co_varnames[0]=='object', co_varnames[1]=='predicate', __qualname__ len 10; wave 261; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetmembers133

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers is defined as 'def getmembers(object, predicate=None):' in Lib/inspect.py; it takes 2 positional arguments; co_argcount is 2; int.__eq__(2) returns True; new to extra133"]
    - [getmembers_co_varnames_len_eq_2,
       "getmembers.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getmembers.__code__.co_varnames.__len__() == 2 — getmembers has 2 local variables: object, predicate; len(co_varnames) == 2; new to extra133"]
    - [getmembers_co_varnames_0_eq_object,
       "getmembers.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getmembers.__code__.co_varnames[0].__eq__('object') == True — the first local variable of getmembers is 'object', the first positional argument; str.__eq__('object') returns True; new to extra133"]
    - [getmembers_co_varnames_1_eq_predicate,
       "getmembers.__code__.co_varnames[1].__eq__",
       ["predicate"],
       true,
       "inspect.getmembers.__code__.co_varnames[1].__eq__('predicate') == True — the second local variable of getmembers is 'predicate', the optional filter argument; str.__eq__('predicate') returns True; new to extra133"]
    - [getmembers_qualname_eq,
       "getmembers.__qualname__.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — getmembers is defined at module scope in Lib/inspect.py; its __qualname__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra133"]
    - [getmembers_qualname_len_eq_10,
       "getmembers.__qualname__.__len__",
       [],
       10,
       "inspect.getmembers.__qualname__.__len__() == 10 — __qualname__ is 'getmembers' which has 10 characters; len('getmembers') == 10; new to extra133"]
    - [getmembers_module_eq_inspect,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra133"]

