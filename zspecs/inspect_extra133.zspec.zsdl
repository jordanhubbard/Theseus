# Standalone invariants — extra133
# ---------------------------------------------------------------------------

invariant inspect_extra133.getmembers_co_varnames_len:
  description: "len(inspect.getmembers.__code__.co_varnames) == 2 — getmembers has 2 local variables: object, predicate; wave 261; new to extra133"
  kind: python_call_eq
  function: getmembers.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant inspect_extra133.isfunction_co_varnames_first:
  description: "inspect.isfunction.__code__.co_varnames[0] == 'object' — first local variable of isfunction is 'object'; wave 261; new to extra133"
  kind: python_call_eq
  function: isfunction.__code__.co_varnames[0].__eq__
  args: ["object"]
  expected: true

invariant inspect_extra133.isclass_qualname_len:
  description: "len(inspect.isclass.__qualname__) == 7 — __qualname__ is 'isclass'; wave 261; new to extra133"
  kind: python_call_eq
