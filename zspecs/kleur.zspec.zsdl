spec: kleur
version: ">=4.0.0"
backend: node(kleur)

docs: https://github.com/lukeed/kleur#readme

provenance:
  derived_from:
    - "kleur README — https://github.com/lukeed/kleur#readme"
    - "Test vectors verified with kleur@4.1.5 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "kleur source: index.js"
  notes:
    - "kleur exports an object with color/style methods (red, green, bold, etc.)."
    - "When stdout is not a TTY (subprocess, CI), all methods return the input string unchanged."
    - "The verify harness runs node as a subprocess with piped stdout (not a TTY), so all invariants are in no-color mode."
    - "kleur disables colors automatically when FORCE_COLOR is not set and stdout is not a TTY."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "All methods return the input string unchanged in no-TTY mode. No errors thrown."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table kleur.no_tty:
  kind: node_module_call_eq
  category: no_tty
  id_prefix: kl

  columns: [id, function, args, expected]
  rows:
    - [red,    red,    ["hello"],   "hello"]
    - [green,  green,  ["hi"],      "hi"]
    - [blue,   blue,   ["test"],    "test"]
    - [bold,   bold,   ["strong"],  "strong"]
    - [yellow, yellow, ["warn"],    "warn"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:11:50Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
