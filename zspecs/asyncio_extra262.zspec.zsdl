spec: asyncio_extra262
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "StreamReader.__bases__[0].__name__ == 'object': StreamReader does not inherit from a custom base."
    - "StreamWriter.__bases__[0].__name__ == 'object': StreamWriter does not inherit from a custom base."
    - "Both StreamReader and StreamWriter are defined in asyncio.streams (not asyncio directly)."
    - "open_connection and start_server are coroutine functions; their __class__.__name__ is 'function'."
    - "open_connection.__qualname__ == 'open_connection' (no nesting)."
    - "start_server.__qualname__ == 'start_server' (no nesting)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StreamReader class identity
# ---------------------------------------------------------------------------

invariant asyncio_extra262.stream_reader.name:
  description: "asyncio.StreamReader.__name__ == 'StreamReader'"
  category: identity
  kind: python_call_eq
  function: StreamReader.__name__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra262.stream_reader.module:
  description: "asyncio.StreamReader.__module__ == 'asyncio.streams'"
  category: identity
  kind: python_call_eq
  function: StreamReader.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra262.stream_reader.base:
  description: "asyncio.StreamReader.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: StreamReader.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StreamWriter class identity
# ---------------------------------------------------------------------------

invariant asyncio_extra262.stream_writer.name:
  description: "asyncio.StreamWriter.__name__ == 'StreamWriter'"
  category: identity
  kind: python_call_eq
  function: StreamWriter.__name__.__eq__
  args: ["StreamWriter"]
  expected: true

invariant asyncio_extra262.stream_writer.module:
  description: "asyncio.StreamWriter.__module__ == 'asyncio.streams'"
  category: identity
  kind: python_call_eq
  function: StreamWriter.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra262.stream_writer.base:
  description: "asyncio.StreamWriter.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: StreamWriter.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# open_connection function identity
# ---------------------------------------------------------------------------

invariant asyncio_extra262.open_connection.name:
  description: "asyncio.open_connection.__name__ == 'open_connection'"
  category: identity
  kind: python_call_eq
  function: open_connection.__name__.__eq__
  args: ["open_connection"]
  expected: true

invariant asyncio_extra262.open_connection.qualname:
  description: "asyncio.open_connection.__qualname__ == 'open_connection'"
  category: identity
  kind: python_call_eq
  function: open_connection.__qualname__.__eq__
  args: ["open_connection"]
  expected: true

invariant asyncio_extra262.open_connection.module:
  description: "asyncio.open_connection.__module__ == 'asyncio.streams'"
  category: identity
  kind: python_call_eq
  function: open_connection.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra262.open_connection.class:
  description: "type(asyncio.open_connection).__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: open_connection.__class__.__name__.__eq__
  args: ["function"]
  expected: true

