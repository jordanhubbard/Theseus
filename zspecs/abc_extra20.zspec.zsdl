spec: abc_extra20
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra19.zspec.zsdl — covers combined __qualname__ table for ABCMeta/ABC/abstractmethod/get_cache_token/ABCMeta.register/ABCMeta.__instancecheck__/ABCMeta.__subclasscheck__/abstractmethod.__call__; standalone invariants for ABCMeta.register and abstractmethod.__call__ qualnames."
    - "abc_extra16.zspec.zsdl — covers combined __module__ table for ABCMeta/ABC/abstractmethod; combined __bases__[0].__name__ table for ABCMeta/ABC; abstractmethod.__name__ standalone; get_cache_token.__module__ == '_abc' standalone; ABC.__class__.__name__ standalone."
    - "abc_extra12.zspec.zsdl — covers __qualname__/__module__ for ABC/ABCMeta/abstractmethod/deprecated decorators; get_cache_token.__module__ == '_abc'."
    - "abc_extra10.zspec.zsdl — covers update_abstractmethods __module__/__qualname__/__class__.__name__; ABCMeta.__subclasscheck__.__qualname__; ABC.__subclasshook__.__qualname__."
    - "abc_extra11.zspec.zsdl — covers ABCMeta.__instancecheck__.__qualname__; ABCMeta.__bases__[0].__name__."
  notes:
    - "This spec extends abc_extra19.zspec.zsdl."
    - "Focus: novel combined tables in the extra20 namespace — (1) __module__ values for ABC/ABCMeta/abstractmethod/update_abstractmethods as a group; (2) __bases__[0].__name__ for ABC/ABCMeta in the extra20 namespace; (3) ABCMeta.__subclasshook__.__qualname__ standalone — not previously recorded as a standalone invariant; (4) combined qualname table including update_abstractmethods in the extra20 namespace."
    - "abc.ABC.__module__ == 'abc' — ABC is defined in the abc module."
    - "abc.ABCMeta.__module__ == 'abc' — ABCMeta metaclass is defined in the abc module."
    - "abc.abstractmethod.__module__ == 'abc' — abstractmethod decorator is defined in the abc module."
    - "abc.update_abstractmethods.__module__ == 'abc' — update_abstractmethods is a pure-Python helper defined in abc (Python 3.10+)."
    - "abc.ABC.__bases__[0].__name__ == 'object' — ABC directly inherits from object."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass that inherits from type."
    - "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' — method qualname includes enclosing class; not previously a standalone invariant."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — top-level function (Python 3.10+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ combined table for ABC/ABCMeta/abstractmethod/update_abstractmethods
# (extra20 namespace)
#
# abc_extra16 covers ABC/ABCMeta/abstractmethod as a combined __module__ table.
# This extra20 table adds update_abstractmethods to the same group in the
# extra20 namespace — not previously combined in a single table.
# ---------------------------------------------------------------------------

table abc_extra20.modules:
  description: "__module__.__eq__ for core abc members in the extra20 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [ABC,                    ABC.__module__.__eq__,                    ["abc"],  true]
    - [ABCMeta,                ABCMeta.__module__.__eq__,                ["abc"],  true]
    - [abstractmethod,         abstractmethod.__module__.__eq__,         ["abc"],  true]
    - [update_abstractmethods, update_abstractmethods.__module__.__eq__, ["abc"],  true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ combined table for ABC/ABCMeta (extra20 namespace)
#
# abc_extra16 covers both in a combined table. This anchors them again in the
# extra20 namespace, making the combination available under a fresh ID prefix.
# ---------------------------------------------------------------------------

table abc_extra20.bases:
  description: "__bases__[0].__name__.__eq__ for ABC and ABCMeta in the extra20 namespace"
  kind: python_call_eq
  category: bases
  id_prefix: bases

  columns: [id, function, args, expected]
  rows:
    - [ABC,     "ABC.__bases__[0].__name__.__eq__",     ["object"], true]
    - [ABCMeta, "ABCMeta.__bases__[0].__name__.__eq__", ["type"],   true]

# ---------------------------------------------------------------------------
# Combined __qualname__ table for abc top-level members (extra20 namespace)
#
# Extends the extra19 combined table to add update_abstractmethods in the
# extra20 namespace. update_abstractmethods.__qualname__ is 'update_abstractmethods'.
# All other entries re-anchor prior values under the extra20 ID prefix.
# ---------------------------------------------------------------------------

table abc_extra20.qualnames:
  description: "__qualname__.__eq__ for abc top-level members in the extra20 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABC,                    ABC.__qualname__.__eq__,                    ["ABC"],                    true]
    - [ABCMeta,                ABCMeta.__qualname__.__eq__,                ["ABCMeta"],                true]
    - [abstractmethod,         abstractmethod.__qualname__.__eq__,         ["abstractmethod"],         true]
    - [get_cache_token,        get_cache_token.__qualname__.__eq__,        ["get_cache_token"],        true]
    - [update_abstractmethods, update_abstractmethods.__qualname__.__eq__, ["update_abstractmethods"], true]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__subclasshook__.__qualname__ — standalone invariant
#
# ABCMeta.__subclasshook__ is a classmethod defined on ABCMeta. Its __qualname__
# is 'ABCMeta.__subclasshook__', including the enclosing class. No prior abc spec
# records ABCMeta.__subclasshook__.__qualname__ as a standalone invariant.
# (abc_extra10 covers ABC.__subclasshook__.__qualname__, not ABCMeta's.)
# ---------------------------------------------------------------------------

invariant abc_extra20.ABCMeta.subclasshook.qualname:
  description: "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' — method qualname includes enclosing class"
  category: method_qualnames
  kind: python_call_eq
  function: "ABCMeta.__subclasshook__.__qualname__.__eq__"
  args: ["ABCMeta.__subclasshook__"]
  expected: true

# ---------------------------------------------------------------------------
# abc.update_abstractmethods.__module__ == 'abc' — standalone (extra20 namespace)
#
# update_abstractmethods is a pure-Python helper added in Python 3.10.
# Its __module__ is 'abc'. abc_extra10 covers __module__ and __qualname__ as
# standalone invariants in the extra10 namespace. This re-anchors __module__
# in the extra20 namespace with a distinct ID.
# ---------------------------------------------------------------------------

invariant abc_extra20.update_abstractmethods.module:
  description: "abc.update_abstractmethods.__module__ == 'abc' — pure-Python helper defined in abc (Python 3.10+)"
  category: module_attrs
  kind: python_call_eq
  function: update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABCMeta.__bases__[0].__name__ == 'type' — standalone (extra20 namespace)
#
# ABCMeta is a metaclass that inherits from the built-in type. Its first base
# is therefore 'type'. abc_extra11 covers this as a standalone in extra11.
# Re-anchored here in the extra20 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra20.ABCMeta.bases0.name:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from the built-in type metaclass"
  category: bases
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true
