spec: lodash_size
version: ">=4.0.0"
backend: node(lodash.size)

docs: https://lodash.com/docs/#size

provenance:
  derived_from:
    - "lodash.size README — https://www.npmjs.com/package/lodash.size"
    - "Test vectors verified with lodash.size@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.size exports the _.size function directly as module.exports."
    - "size(collection) returns the number of elements."
    - "For strings, returns character count. For objects, returns own-property count."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer size."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_size.size:
  kind: node_module_call_eq
  function: ~
  category: size
  id_prefix: lsz

  columns: [id, args, expected]
  rows:
    - [array3,    [[1, 2, 3]],           3]
    - [empty_arr, [[]],                  0]
    - [string,    ["hello"],             5]
    - [object,    [{"a": 1, "b": 2}],   2]

