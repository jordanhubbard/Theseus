spec: socket_extra263
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra262.zspec.zsdl — covers socketpair/fromfd function identity; ntohs/htons/ntohl/htonl byte-order function identity; ntohs(256)==1, htons(1)==256."
    - "socket_extra261.zspec.zsdl — covers socket.socket instance attributes family/type/proto/timeout; SHUT_RD/WR/RDWR constant class names and values."
    - "socket_extra259.zspec.zsdl — covers create_connection/create_server/has_dualstack_ipv6 identity and IPPROTO constants."
    - "socket.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; socket/herror/gaierror class names."
  notes:
    - "socket.__name__ == 'socket' — the module __name__ attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__package__ == '' — socket is a top-level stdlib module; __package__ is the empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec' — socket.__spec__ is an importlib.machinery.ModuleSpec. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__spec__.name == 'socket' — the ModuleSpec .name is the fully-qualified module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — the socket module is loaded via SourceFileLoader. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__doc__ is a str that contains 'socket' and 'makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "int(socket.IPPROTO_ICMP) == 1 — ICMP protocol number per RFC 792 and IANA. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "int(socket.IPPROTO_TCP) == 6 — TCP protocol number per RFC 793 and IANA. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "int(socket.IPPROTO_UDP) == 17 — UDP protocol number per RFC 768 and IANA. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "int(socket.IPPROTO_IP) == 0 — IP protocol number (dummy for IP). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "int(socket.IPPROTO_IPV6) == 41 — IPv6 encapsulated in IPv4 (6in4) protocol number. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module identity — __name__, __package__, __spec__, __loader__
# ---------------------------------------------------------------------------

table socket_extra263.module_identity:
  description: "socket module identity attributes: __name__, __package__, __spec__ class and name, __loader__ class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockid263

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,         __name__.__eq__,                        ["socket"],           true, "socket.__name__ == 'socket' — module name attribute"]
    - [package_eq,      __package__.__eq__,                     [""],                 true, "socket.__package__ == '' — top-level module has empty string package"]
    - [spec_class_name, __spec__.__class__.__name__.__eq__,      ["ModuleSpec"],       true, "socket.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,    __spec__.name.__eq__,                   ["socket"],           true, "socket.__spec__.name == 'socket'"]
    - [loader_class,    __loader__.__class__.__name__.__eq__,    ["SourceFileLoader"], true, "socket.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# socket.socket.__doc__ — contains expected keywords
# socket.socket is a subclass of _socket.socket adding makefile(); its __doc__
# mentions 'socket' and 'makefile'.
# ---------------------------------------------------------------------------

invariant socket_extra263.socket_doc_class:
  description: "socket.socket.__doc__.__class__.__name__ == 'str' — __doc__ is a string"
  category: identity
  kind: python_call_eq
  function: socket.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant socket_extra263.socket_doc_contains_makefile:
  description: "socket.socket.__doc__.__contains__('makefile') == True — doc mentions makefile()"
  category: identity
  kind: python_call_eq
  function: socket.__doc__.__contains__
  args: ["makefile"]
  expected: true

# ---------------------------------------------------------------------------
# IPPROTO_* complete set — integer values
# ICMP=1, TCP=6, UDP=17, IP=0, IPV6=41
# These are universally stable IANA-assigned protocol numbers.
# ---------------------------------------------------------------------------

table socket_extra263.IPPROTO_values:
  description: "socket.IPPROTO_* integer values: ICMP==1, TCP==6, UDP==17, IP==0, IPV6==41; universally stable IANA-assigned protocol numbers; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: sockip263

  columns: [id, function, args, expected, description]
  rows:
    - [IPPROTO_ICMP,  IPPROTO_ICMP.__eq__,  [1],  true, "socket.IPPROTO_ICMP == 1 — ICMP protocol number per IANA"]
    - [IPPROTO_TCP,   IPPROTO_TCP.__eq__,   [6],  true, "socket.IPPROTO_TCP == 6 — TCP protocol number per IANA"]
    - [IPPROTO_UDP,   IPPROTO_UDP.__eq__,   [17], true, "socket.IPPROTO_UDP == 17 — UDP protocol number per IANA"]
    - [IPPROTO_IP,    IPPROTO_IP.__eq__,    [0],  true, "socket.IPPROTO_IP == 0 — dummy protocol number for IP"]
    - [IPPROTO_IPV6,  IPPROTO_IPV6.__eq__,  [41], true, "socket.IPPROTO_IPV6 == 41 — IPv6-in-IPv4 encapsulation protocol number"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra263.module_name:
  description: "socket.__name__ == 'socket' — the module's __name__ attribute is the bare module name"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra263.module_package:
  description: "socket.__package__ == '' — socket is a top-level stdlib module; __package__ is the empty string"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant socket_extra263.spec_class_name:
  description: "socket.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant socket_extra263.spec_name:
  description: "socket.__spec__.name == 'socket' — the ModuleSpec .name is the fully-qualified module name"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra263.IPPROTO_ICMP_value:
  description: "socket.IPPROTO_ICMP == 1 — ICMP protocol number per IANA"
  category: constants
  kind: python_call_eq
  function: IPPROTO_ICMP.__eq__
  args: [1]
  expected: true

invariant socket_extra263.IPPROTO_TCP_value:
  description: "socket.IPPROTO_TCP == 6 — TCP protocol number per IANA"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra263.IPPROTO_UDP_value:
  description: "socket.IPPROTO_UDP == 17 — UDP protocol number per IANA"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

invariant socket_extra263.IPPROTO_IP_value:
  description: "socket.IPPROTO_IP == 0 — dummy protocol number for IP"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IP.__eq__
  args: [0]
  expected: true

invariant socket_extra263.IPPROTO_IPV6_value:
  description: "socket.IPPROTO_IPV6 == 41 — IPv6 encapsulation protocol number"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IPV6.__eq__
  args: [41]
  expected: true
