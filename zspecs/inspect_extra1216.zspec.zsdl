provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.Parameter.__bases__.__len__() == 1, inspect.Signature.__bases__.__len__() == 1, inspect.BoundArguments.__bases__.__len__() == 1, inspect.Parameter.__mro__.__len__() == 2, inspect.Signature.__mro__.__len__() == 2, inspect.BoundArguments.__mro__.__len__() == 2, inspect.FullArgSpec.__bases__.__len__() == 1, inspect.FullArgSpec.__mro__.__len__() == 3, inspect.FrameInfo.__bases__.__len__() == 1, inspect.FrameInfo.__mro__.__len__() == 4, inspect.Signature.__module__, inspect.BoundArguments.__module__, inspect.FullArgSpec.__module__, inspect.FrameInfo.__module__ — not covered in _extra1186/_extra1201"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1216.parameter_signature_boundarguments_bases_len:
  description: "inspect.Parameter, Signature, and BoundArguments __bases__.__len__() and __mro__.__len__() identity"
  kind: python_call_eq
  category: parameter_signature_boundarguments_bases_len
  id_prefix: ip1216pb
  columns: [id, function, args, expected]
  rows:
    - [ip1216pb001, inspect.Parameter.__bases__.__len__,                      [],   1]
    - [ip1216pb002, inspect.Parameter.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [ip1216pb003, inspect.Signature.__bases__.__len__,                      [],   1]
    - [ip1216pb004, inspect.Signature.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [ip1216pb005, inspect.BoundArguments.__bases__.__len__,                 [],   1]
    - [ip1216pb006, inspect.BoundArguments.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [ip1216pb007, inspect.Parameter.__mro__.__len__,                        [],   2]
    - [ip1216pb008, inspect.Signature.__mro__.__len__,                        [],   2]

