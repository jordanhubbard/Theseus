spec: concurrent_futures_extra224
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' — startswith('Thread') and endswith('Executor') both True; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — startswith('Process') and endswith('Executor') both True; verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' — startswith('Broken') and endswith('Executor') both True; verified with Python 3.14.3."
    - "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' — endswith('Error') is True; verified with Python 3.14.3."
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError' — endswith('Error') is True; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — startswith('concurrent') is True; verified with Python 3.14.3."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — startswith('concurrent') is True; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor class name startswith/endswith contracts — extra224 namespace
#
# ThreadPoolExecutor, ProcessPoolExecutor, BrokenExecutor name prefix/suffix checks.
# ---------------------------------------------------------------------------

table concurrent_futures_extra224.executor_name_checks:
  description: "concurrent.futures executor class __name__ string comparison contracts in cf224se namespace"
  kind: python_call_eq
  category: string_comparison
  id_prefix: cf224se

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor_sw_Thread,   ThreadPoolExecutor.__name__.__startswith__, ["Thread"],   true, "concurrent.futures.ThreadPoolExecutor.__name__.__startswith__('Thread') == True — verified with Python 3.14.3"]
    - [ProcessPoolExecutor_sw_Process, ProcessPoolExecutor.__name__.__startswith__, ["Process"], true, "concurrent.futures.ProcessPoolExecutor.__name__.__startswith__('Process') == True — verified with Python 3.14.3"]
    - [ThreadPoolExecutor_ew_Executor, ThreadPoolExecutor.__name__.__endswith__, ["Executor"],   true, "concurrent.futures.ThreadPoolExecutor.__name__.__endswith__('Executor') == True — verified with Python 3.14.3"]
    - [ProcessPoolExecutor_ew_Executor, ProcessPoolExecutor.__name__.__endswith__, ["Executor"], true, "concurrent.futures.ProcessPoolExecutor.__name__.__endswith__('Executor') == True — verified with Python 3.14.3"]
    - [BrokenExecutor_ew_Executor,     BrokenExecutor.__name__.__endswith__, ["Executor"],       true, "concurrent.futures.BrokenExecutor.__name__.__endswith__('Executor') == True — verified with Python 3.14.3"]
    - [BrokenExecutor_sw_Broken,       BrokenExecutor.__name__.__startswith__, ["Broken"],       true, "concurrent.futures.BrokenExecutor.__name__.__startswith__('Broken') == True — verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures error class name endswith contracts — extra224 namespace
#
# InvalidStateError and CancelledError both endswith('Error'); verified Python 3.14.3.
# ---------------------------------------------------------------------------

table concurrent_futures_extra224.error_name_checks:
  description: "concurrent.futures error class __name__ endswith contracts in cf224me namespace"
  kind: python_call_eq
  category: string_comparison
  id_prefix: cf224me

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidStateError_ew_Error, InvalidStateError.__name__.__endswith__, ["Error"], true, "concurrent.futures.InvalidStateError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]
    - [CancelledError_ew_Error,    CancelledError.__name__.__endswith__,    ["Error"], true, "concurrent.futures.CancelledError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class __module__ startswith contracts — extra224 namespace
#
# ThreadPoolExecutor lives in concurrent.futures.thread; Future in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra224.module_checks:
  description: "concurrent.futures class __module__ startswith contracts in cf224mod namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf224mod

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor_module_sw_concurrent, ThreadPoolExecutor.__module__.__startswith__, ["concurrent"], true, "concurrent.futures.ThreadPoolExecutor.__module__.__startswith__('concurrent') == True — module is 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [Future_module_sw_concurrent,             Future.__module__.__startswith__,             ["concurrent"], true, "concurrent.futures.Future.__module__.__startswith__('concurrent') == True — module is 'concurrent.futures._base'; verified with Python 3.14.3"]
