spec: theseus_calendar
version: ">=3.9"
backend: python_cleanroom(theseus_calendar)
blocks: calendar

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html"
  notes:
    - "Clean-room calendar utilities. Do NOT import calendar."
    - "isleap(year): True if year is a leap year; isleap(2000)==True, isleap(1900)==False."
    - "monthrange(year, month): (weekday_of_first_day, number_of_days_in_month)."
    - "monthrange(2026, 1) returns (3, 31) — January 2026 starts on Thursday (3), has 31 days."
    - "weekday(year, month, day): day of week 0=Monday..6=Sunday."
    - "Export: isleap(year) -> bool, monthrange(year, month) -> tuple, weekday(year, month, day) -> int."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_calendar.isleap_2000:
  description: "isleap(2000) == True"
  category: isleap
  kind: python_call_eq
  function: calendar_isleap_2000
  args: []
  expected: true

invariant theseus_calendar.isleap_1900:
  description: "isleap(1900) == False"
  category: isleap
  kind: python_call_eq
  function: calendar_isleap_1900
  args: []
  expected: false

invariant theseus_calendar.monthrange:
  description: "monthrange(2026, 1) == (3, 31)"
  category: monthrange
  kind: python_call_eq
  function: calendar_monthrange_jan2026
  args: []
  expected: [3, 31]
