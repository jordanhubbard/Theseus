spec: multiprocessing_extra311
version: ">=3.3"
backend: python_module(multiprocessing.pool)

docs: https://docs.python.org/3/library/multiprocessing.html#module-multiprocessing.pool

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers multiprocessing.pool class identity: __name__, __module__, __bases__[0].__name__."
    - "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'."
    - "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' — Pool is a plain class."
    - "multiprocessing.pool.AsyncResult.__name__ == 'ApplyResult' — the true class name is ApplyResult; AsyncResult is an alias."
    - "multiprocessing.pool.AsyncResult.__module__ == 'multiprocessing.pool'."
    - "multiprocessing.pool.AsyncResult.__bases__[0].__name__ == 'object'."
    - "multiprocessing.pool.MapResult.__name__ == 'MapResult'."
    - "multiprocessing.pool.MapResult.__module__ == 'multiprocessing.pool'."
    - "multiprocessing.pool.MapResult.__bases__[0].__name__ == 'ApplyResult' — MapResult subclasses ApplyResult."
    - "multiprocessing.pool.IMapIterator.__name__ == 'IMapIterator'."
    - "multiprocessing.pool.IMapIterator.__module__ == 'multiprocessing.pool'."
    - "multiprocessing.pool.IMapIterator.__bases__[0].__name__ == 'object'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pool — name, module, and base class
#
# multiprocessing.pool.Pool is a plain class (not a factory function at this
# level — the top-level multiprocessing.Pool is the factory alias). The class
# itself has __module__ == 'multiprocessing.pool' and inherits from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra311.Pool.name:
  description: "multiprocessing.pool.Pool.__name__ == 'Pool'"
  category: pool_class
  kind: python_call_eq
  function: Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra311.Pool.module:
  description: "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'"
  category: pool_class
  kind: python_call_eq
  function: Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra311.Pool.base:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object'"
  category: pool_class
  kind: python_call_eq
  function: Pool.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# AsyncResult — name, module, and base class
#
# multiprocessing.pool.AsyncResult is an alias for the class whose true
# __name__ is 'ApplyResult'. The alias was added for readability, but the
# class object itself still reports __name__ == 'ApplyResult'. It inherits
# directly from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra311.AsyncResult.name:
  description: "multiprocessing.pool.AsyncResult.__name__ == 'ApplyResult' — true class name despite the AsyncResult alias"
  category: result_classes
  kind: python_call_eq
  function: AsyncResult.__name__.__eq__
  args: ["ApplyResult"]
  expected: true

invariant multiprocessing_extra311.AsyncResult.module:
  description: "multiprocessing.pool.AsyncResult.__module__ == 'multiprocessing.pool'"
  category: result_classes
  kind: python_call_eq
  function: AsyncResult.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra311.AsyncResult.base:
  description: "multiprocessing.pool.AsyncResult.__bases__[0].__name__ == 'object'"
  category: result_classes
  kind: python_call_eq
  function: AsyncResult.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# MapResult — name, module, and base class
#
# multiprocessing.pool.MapResult is a subclass of ApplyResult used internally
# by Pool.map(). Its __bases__[0].__name__ is 'ApplyResult', not 'AsyncResult',
# because Python reports the true class name of the base.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra311.MapResult.name:
  description: "multiprocessing.pool.MapResult.__name__ == 'MapResult'"
  category: result_classes
  kind: python_call_eq
  function: MapResult.__name__.__eq__
  args: ["MapResult"]
  expected: true

invariant multiprocessing_extra311.MapResult.module:
  description: "multiprocessing.pool.MapResult.__module__ == 'multiprocessing.pool'"
  category: result_classes
  kind: python_call_eq
  function: MapResult.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra311.MapResult.base:
  description: "multiprocessing.pool.MapResult.__bases__[0].__name__ == 'ApplyResult'"
  category: result_classes
  kind: python_call_eq
  function: MapResult.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ApplyResult"

# ---------------------------------------------------------------------------
# IMapIterator — name, module, and base class
#
# multiprocessing.pool.IMapIterator implements the iterator protocol for
# Pool.imap() and Pool.imap_unordered(). It inherits directly from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra311.IMapIterator.name:
  description: "multiprocessing.pool.IMapIterator.__name__ == 'IMapIterator'"
  category: iterator_classes
  kind: python_call_eq
  function: IMapIterator.__name__.__eq__
  args: ["IMapIterator"]
  expected: true

invariant multiprocessing_extra311.IMapIterator.module:
  description: "multiprocessing.pool.IMapIterator.__module__ == 'multiprocessing.pool'"
  category: iterator_classes
  kind: python_call_eq
  function: IMapIterator.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra311.IMapIterator.base:
  description: "multiprocessing.pool.IMapIterator.__bases__[0].__name__ == 'object'"
  category: iterator_classes
  kind: python_call_eq
  function: IMapIterator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
