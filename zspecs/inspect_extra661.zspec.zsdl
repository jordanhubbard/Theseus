spec: inspect_extra661
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __class__.__name__, __qualname__, __module__, and __doc__.__class__.__name__ for inspect namedtuple result types"
  created_at: "2026-04-12"

table inspect_extra661.fullargspec_identity:
  description: "inspect.FullArgSpec type identity checks"
  kind: python_call_eq
  category: type_identity
  id_prefix: ins661fa
  columns: [id, function, args, expected]
  rows:
    - [ins661fa001, "inspect.FullArgSpec.__class__.__name__.__eq__", ["type"], true]
    - [ins661fa002, "inspect.FullArgSpec.__qualname__.__eq__", ["FullArgSpec"], true]
    - [ins661fa003, "inspect.FullArgSpec.__module__.__eq__", ["inspect"], true]
    - [ins661fa004, "inspect.FullArgSpec.__doc__.__class__.__name__.__eq__", ["str"], true]

table inspect_extra661.argspec_identity:
  description: "inspect.ArgSpec type identity checks"
  kind: python_call_eq
  category: type_identity
  id_prefix: ins661as
  columns: [id, function, args, expected]
  rows:
    - [ins661as001, "inspect.ArgSpec.__class__.__name__.__eq__", ["type"], true]
    - [ins661as002, "inspect.ArgSpec.__qualname__.__eq__", ["ArgSpec"], true]
    - [ins661as003, "inspect.ArgSpec.__module__.__eq__", ["inspect"], true]

table inspect_extra661.arginfo_identity:
  description: "inspect.ArgInfo type identity checks"
  kind: python_call_eq
  category: type_identity
  id_prefix: ins661ai
  columns: [id, function, args, expected]
  rows:
    - [ins661ai001, "inspect.ArgInfo.__class__.__name__.__eq__", ["type"], true]
    - [ins661ai002, "inspect.ArgInfo.__qualname__.__eq__", ["ArgInfo"], true]

table inspect_extra661.namedtuple_types_identity:
  description: "inspect.Arguments and inspect.ClosureVars type identity checks"
  kind: python_call_eq
  category: type_identity
  id_prefix: ins661nt
  columns: [id, function, args, expected]
  rows:
    - [ins661nt001, "inspect.Arguments.__class__.__name__.__eq__", ["type"], true]
    - [ins661nt002, "inspect.Arguments.__qualname__.__eq__", ["Arguments"], true]
    - [ins661nt003, "inspect.ClosureVars.__class__.__name__.__eq__", ["type"], true]
    - [ins661nt004, "inspect.ClosureVars.__qualname__.__eq__", ["ClosureVars"], true]
