spec: struct_extra991
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module error and Struct class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.error and struct.Struct method __qualname__ and descriptor class name attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra991.error_method_qualnames:
  description: "struct.error method __qualname__ identity"
  kind: python_call_eq
  category: error_method_qualnames
  id_prefix: st991em
  columns: [id, function, args, expected]
  rows:
    - [st991em001, struct.error.__init__.__qualname__.__eq__,            ["Exception.__init__"],            true]
    - [st991em002, struct.error.__str__.__qualname__.__eq__,             ["Exception.__str__"],             true]
    - [st991em003, struct.error.__repr__.__qualname__.__eq__,            ["Exception.__repr__"],            true]
    - [st991em004, struct.error.with_traceback.__qualname__.__eq__,      ["BaseException.with_traceback"], true]
    - [st991em005, struct.error.__class__.__name__.__eq__,               ["type"],                          true]
    - [st991em006, struct.error.__module__.__eq__,                       ["builtins"],                      true]

table struct_extra991.error_descriptor_classnames:
  description: "struct.error descriptor attribute class names"
  kind: python_call_eq
  category: error_descriptor_classnames
  id_prefix: st991ed
  columns: [id, function, args, expected]
  rows:
    - [st991ed001, struct.error.args.__class__.__name__.__eq__,          ["getset_descriptor"], true]
    - [st991ed002, struct.error.__doc__.__class__.__name__.__eq__,       ["str"],               true]
    - [st991ed003, struct.error.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]

table struct_extra991.struct_method_qualnames:
  description: "struct.Struct method __qualname__ identity"
  kind: python_call_eq
  category: struct_method_qualnames
  id_prefix: st991sm
  columns: [id, function, args, expected]
  rows:
    - [st991sm001, struct.Struct.__repr__.__qualname__.__eq__,     ["Struct.__repr__"],     true]
    - [st991sm002, struct.Struct.__sizeof__.__qualname__.__eq__,   ["Struct.__sizeof__"],   true]
    - [st991sm003, struct.Struct.__reduce_ex__.__qualname__.__eq__, ["object.__reduce_ex__"], true]
    - [st991sm004, struct.Struct.__class__.__name__.__eq__,        ["type"],                true]
    - [st991sm005, struct.Struct.__module__.__eq__,                ["struct"],              true]
    - [st991sm006, struct.Struct.pack.__qualname__.__eq__,         ["Struct.pack"],         true]
    - [st991sm007, struct.Struct.unpack.__qualname__.__eq__,       ["Struct.unpack"],       true]
