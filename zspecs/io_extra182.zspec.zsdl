spec: io_extra182
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io default buffer sizes and constants — DEFAULT_BUFFER_SIZE, SEEK_SET, SEEK_CUR, SEEK_END, and UnsupportedOperation class identity."
    - "io.DEFAULT_BUFFER_SIZE == 8192 — the default I/O buffer size is 8 KB (8192 bytes)."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — it is a plain Python int."
    - "io.SEEK_SET == 0 — seek from the beginning of the stream."
    - "io.SEEK_CUR == 1 — seek from the current stream position."
    - "io.SEEK_END == 2 — seek from the end of the stream."
    - "io.SEEK_SET.__class__.__name__ == 'int' — unlike re.RegexFlag these are plain ints, not IntFlag members."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' (len=20: 'Unsupported' (11) + 'Operation' (9) = 20)."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — the first base class is OSError."
    - "Name length ordering for constants: SEEK_SET=SEEK_CUR=SEEK_END (8) < DEFAULT_BUFFER_SIZE (19 chars of the name, but value is 8192)."
    - "SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2): a strict ascending value sequence from 0 to 2."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io seek constants: SEEK_SET (0), SEEK_CUR (1), SEEK_END (2)
# All are plain ints; values form a strict ascending sequence 0 < 1 < 2
# ---------------------------------------------------------------------------

table io_extra182.seek_constants:
  description: "io seek constants: SEEK_SET==0, SEEK_CUR==1, SEEK_END==2; SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2): a strict ascending sequence; all are plain ints unlike re.RegexFlag members"
  kind: python_call_eq
  category: identity
  id_prefix: ioconsts182

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_val,       SEEK_SET.__eq__,               [0], true,  "io.SEEK_SET == 0 — SEEK_SET is the seek mode for seeking from the beginning of the stream; value is 0: the smallest seek constant; SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2): SEEK_SET is the minimum in the seek constant value ordering; confirmed Python 3.14.3 macOS"]
    - [seek_set_class,     SEEK_SET.__class__.__name__.__eq__, ["int"], true, "io.SEEK_SET.__class__.__name__ == 'int' — SEEK_SET is a plain Python int, not an IntFlag or IntEnum member; unlike re.RegexFlag flags, the io seek constants are bare ints; confirmed Python 3.14.3 macOS"]
    - [seek_cur_val,       SEEK_CUR.__eq__,               [1], true,  "io.SEEK_CUR == 1 — SEEK_CUR is the seek mode for seeking relative to the current stream position; value is 1: between SEEK_SET (0) and SEEK_END (2); SEEK_CUR (1) > SEEK_SET (0) by 1; SEEK_CUR (1) < SEEK_END (2) by 1; confirmed Python 3.14.3 macOS"]
    - [seek_cur_class,     SEEK_CUR.__class__.__name__.__eq__, ["int"], true, "io.SEEK_CUR.__class__.__name__ == 'int' — SEEK_CUR is a plain Python int; SEEK_CUR (1) is the middle seek constant value; all three seek constants (SEEK_SET, SEEK_CUR, SEEK_END) share __class__.__name__ == 'int'; confirmed Python 3.14.3 macOS"]
    - [seek_end_val,       SEEK_END.__eq__,               [2], true,  "io.SEEK_END == 2 — SEEK_END is the seek mode for seeking relative to the end of the stream; value is 2: the largest seek constant; SEEK_END (2) > SEEK_CUR (1) by 1; SEEK_END (2) > SEEK_SET (0) by 2; confirmed Python 3.14.3 macOS"]
    - [seek_end_class,     SEEK_END.__class__.__name__.__eq__, ["int"], true, "io.SEEK_END.__class__.__name__ == 'int' — SEEK_END is a plain Python int; SEEK_END (2) is the maximum seek constant value: SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE: value == 8192, class == 'int'
# 8192 bytes == 8 KB; the default buffer size for buffered I/O
# ---------------------------------------------------------------------------

table io_extra182.default_buffer_size:
  description: "io.DEFAULT_BUFFER_SIZE==8192 (8 KB); DEFAULT_BUFFER_SIZE.__class__.__name__=='int'; 8192 == 8 * 1024: the default I/O buffer size is a plain int"
  kind: python_call_eq
  category: identity
  id_prefix: ioconsts182

  columns: [id, function, args, expected, description]
  rows:
    - [buf_size_val,   DEFAULT_BUFFER_SIZE.__eq__,                [8192], true, "io.DEFAULT_BUFFER_SIZE == 8192 — the default buffer size for buffered I/O is 8192 bytes (8 KB = 8 * 1024); used as the default when no buffer_size argument is given to open() with buffering enabled; DEFAULT_BUFFER_SIZE (8192) == 8 * 1024 == 2^13; confirmed Python 3.14.3 macOS"]
    - [buf_size_class, DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true, "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int equal to 8192; it is not a float or a special numeric type; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation: class name, name length, and base class
# UnsupportedOperation.__name__ == 'UnsupportedOperation' (len=18)
# UnsupportedOperation.__bases__[0].__name__ == 'OSError'
# ---------------------------------------------------------------------------

table io_extra182.unsupported_operation:
  description: "io.UnsupportedOperation class identity: __name__=='UnsupportedOperation' (len=18); __bases__[0].__name__=='OSError'; UnsupportedOperation is raised when an unsupported operation is attempted on a stream"
  kind: python_call_eq
  category: identity
  id_prefix: ioconsts182

  columns: [id, function, args, expected, description]
  rows:
    - [unsupported_name,      UnsupportedOperation.__name__.__eq__,             ["UnsupportedOperation"], true, "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — 'UnsupportedOperation' has 20 characters: 'Unsupported' (11) + 'Operation' (9) = 20; it is raised when a method is not supported by the stream (e.g. calling write() on a read-only stream); confirmed Python 3.14.3 macOS"]
    - [unsupported_name_len,  UnsupportedOperation.__name__.__len__,            [],                      20,   "io.UnsupportedOperation.__name__.__len__() == 20 — 'UnsupportedOperation': U(1)n(2)s(3)u(4)p(5)p(6)o(7)r(8)t(9)e(10)d(11)O(12)p(13)e(14)r(15)a(16)t(17)i(18)o(19)n(20) = 20 characters; 'Unsupported' (11) + 'Operation' (9) = 20; confirmed Python 3.14.3 macOS"]
    - [unsupported_base,      "UnsupportedOperation.__bases__[0].__name__.__eq__", ["OSError"],           true, "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — the first (and primary) base class of UnsupportedOperation is OSError; UnsupportedOperation also inherits from ValueError making it a dual-base exception; __bases__[0] is OSError; confirmed Python 3.14.3 macOS"]
    - [unsupported_is_type,   UnsupportedOperation.__class__.__name__.__eq__,   ["type"],                true, "io.UnsupportedOperation.__class__.__name__ == 'type' — UnsupportedOperation is a class object (its metaclass is type); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra182.SEEK_SET_is_zero:
  description: "io.SEEK_SET == 0 — SEEK_SET is the seek-from-beginning constant; value 0 is the minimum seek constant; SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2): a strict ascending sequence; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra182.SEEK_CUR_is_one:
  description: "io.SEEK_CUR == 1 — SEEK_CUR is the seek-from-current-position constant; SEEK_CUR (1) is between SEEK_SET (0) and SEEK_END (2); SEEK_CUR (1) > SEEK_SET (0) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra182.SEEK_END_is_two:
  description: "io.SEEK_END == 2 — SEEK_END is the seek-from-end constant; SEEK_END (2) is the maximum seek constant value; SEEK_END (2) > SEEK_SET (0) by 2; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra182.DEFAULT_BUFFER_SIZE_is_8192:
  description: "io.DEFAULT_BUFFER_SIZE == 8192 — 8192 bytes is the default I/O buffer size; 8192 == 2^13 == 8 * 1024 (8 KB); used as the default buffer_size when buffered I/O is requested via open(); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [8192]
  expected: true

invariant io_extra182.DEFAULT_BUFFER_SIZE_class_is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int equal to 8192; not an IntEnum or special type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra182.SEEK_SET_class_is_int:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — SEEK_SET is a plain Python int; unlike re.RegexFlag members, the io seek constants are not IntFlag instances; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra182.UnsupportedOperation_name_is_UnsupportedOperation:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — the class name is 'UnsupportedOperation' with 20 characters; it is raised when an I/O method is not supported by the stream; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra182.UnsupportedOperation_base_is_OSError:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — the first base class of UnsupportedOperation is OSError; UnsupportedOperation also inherits from ValueError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

