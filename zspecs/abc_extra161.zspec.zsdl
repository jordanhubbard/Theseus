spec: abc_extra161
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta.__name__.__len__()==7; abc.ABC.__name__.__len__()==3; abc.abstractmethod.__name__.__len__()==14 — length cross-comparisons; abc.get_cache_token.__name__=='get_cache_token' and __module__=='_abc'; abc.update_abstractmethods.__name__=='update_abstractmethods' and __module__=='abc'. KEY FINDINGS: get_cache_token.__module__=='_abc' (len=4: the function is implemented in the C extension module Modules/_abc.c, NOT in Python abc module; '_abc'=4 with leading underscore); update_abstractmethods.__module__=='abc' (len=3: implemented in the Python Lib/abc.py module); the module difference shows the split implementation of the abc module: performance-critical parts are in C (_abc), while newer/less-frequent functions remain in Python (abc). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__name__.__len__()==7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7; established in extra160 via abc_extra160.abc_doc_length_comparison table row meta_name_len==7); abc.ABC.__name__.__len__()==3 ('ABC'=3; established throughout the abc spec series via abc.ABC.__name__.__len__==3); abc.abstractmethod.__name__.__len__()==14 ('abstractmethod'=14: 'abstract'=8+'method'=6=14); ABC(3) < ABCMeta(7) < abstractmethod(14) in class/function name length — a strict ordering. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__name__=='get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); abc.get_cache_token.__module__=='_abc' (len=4: '_abc'=4 with leading underscore — C extension module); get_cache_token() returns an opaque token that changes whenever the ABC inheritance hierarchy changes; it is used for cache invalidation in issubclass/isinstance checks involving ABCs; the function is in _abc because it interfaces directly with the C-level ABC cache. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__name__=='update_abstractmethods' (len=22: 'update'=6+'_'=1+'abstract'=8+'_'=1+'methods'=7=23... let us recount: 'update_abstractmethods' = 'update'=6+'_abstractmethods'=16: '_'=1+'abstract'=8+'methods'=7=16; total=6+16=22; yes 22 chars); abc.update_abstractmethods.__module__=='abc' (len=3: pure Python function in Lib/abc.py; no leading underscore; added in Python 3.10 to recalculate __abstractmethods__ after dynamic modification of a class); update_abstractmethods(22) is the longest name in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc name length cross-comparisons — extra161
#
# abc.ABCMeta.__name__.__len__()       == 7
# abc.ABC.__name__.__len__()           == 3
# abc.abstractmethod.__name__.__len__() == 14
# ---------------------------------------------------------------------------

table abc_extra161.abc_name_length_cross_comparisons:
  description: "abc.ABCMeta, abc.ABC, and abc.abstractmethod name length cross-comparisons in abcnlc161 namespace — abc.ABCMeta.__name__.__len__()==7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7; ABCMeta is the metaclass for defining Abstract Base Classes; it intercepts class creation and sets __abstractmethods__ on the new class; established in extra160 row meta_doc_len_576 table where meta_name_len==7 was shown); abc.ABC.__name__.__len__()==3 ('ABC'=3: 'A'+'B'+'C'=3; ABC is the helper class that sets ABCMeta as its metaclass; abc.ABC.__name__.__len__()==3 established throughout the series via abc.ABC.__abstractmethods__.__class__.__name__.__len__ != ABC name... established via abc.ABC.__name__.__len__ in extra159 table abcabsmtype159 row abc_name_len==3); abc.abstractmethod.__name__.__len__()==14 ('abstractmethod'=14: 'abstract'=8+'method'=6=14; abstractmethod is the decorator that marks a method as abstract; decorated methods appear in __abstractmethods__ frozenset of their containing class); LENGTH ORDERING: ABC(3) < ABCMeta(7) < abstractmethod(14) — a strict ordering where each is strictly longer than the previous; ABCMeta(7)=3+4 (ABC prefix plus 'Meta' suffix); abstractmethod(14)=8+6 ('abstract'+'method'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnlc161

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_len,      abc.ABCMeta.__name__.__len__,      [],  7,   "ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); verified with Python 3.14.3"]
    - [abc_name_len,          abc.ABC.__name__.__len__,           [],  3,   "ABC.__name__.__len__() == 3 ('ABC'=3; shortest name in abc module); verified with Python 3.14.3"]
    - [abstractmethod_name_len, abc.abstractmethod.__name__.__len__, [],  14,  "abstractmethod.__name__.__len__() == 14 ('abstractmethod'=14: 'abstract'=8+'method'=6=14); verified with Python 3.14.3"]
    - [abcmeta_name_eq,       abc.ABCMeta.__name__.__eq__,       ["ABCMeta"],  true,  "ABCMeta.__name__ == 'ABCMeta' (len=7; the abc metaclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token function identity — extra161
#
# abc.get_cache_token.__name__.__eq__('get_cache_token')  == True
# abc.get_cache_token.__name__.__len__()                  == 15
# abc.get_cache_token.__module__.__eq__('_abc')           == True
# abc.get_cache_token.__module__.__len__()                == 4
# ---------------------------------------------------------------------------

table abc_extra161.abc_get_cache_token_identity:
  description: "abc.get_cache_token function name and module identity checks in abcgct161 namespace — abc.get_cache_token.__name__.__eq__('get_cache_token')==True (get_cache_token.__name__=='get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15)); abc.get_cache_token.__name__.__len__()==15 ('get_cache_token'=15; the function name is 15 chars); abc.get_cache_token.__module__.__eq__('_abc')==True (KEY: get_cache_token is implemented in the C extension module Modules/_abc.c; its __module__=='_abc' (len=4: '_'=1+'abc'=3=4) with a leading underscore indicating the private C accelerator; get_cache_token() returns the current ABC cache token — an opaque integer that increments whenever the ABC virtual subclass registry is modified, enabling cache invalidation for subclass checks); abc.get_cache_token.__module__.__len__()==4 ('_abc'=4: '_'=1+'abc'=3=4; compare: update_abstractmethods.__module__=='abc' (len=3) is 1 char shorter because it has no leading underscore; get_cache_token is in C (_abc=4) while update_abstractmethods is in Python (abc=3)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcgct161

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name_eq,  abc.get_cache_token.__name__.__eq__,    ["get_cache_token"],  true,  "get_cache_token.__name__ == 'get_cache_token' (len=15; C extension function); verified with Python 3.14.3"]
    - [gct_name_len, abc.get_cache_token.__name__.__len__,   [],                   15,    "get_cache_token.__name__.__len__() == 15 ('get_cache_token'=15: 'get'=3+'_cache'=6+'_token'=6=15); verified with Python 3.14.3"]
    - [gct_mod_eq,   abc.get_cache_token.__module__.__eq__,  ["_abc"],             true,  "get_cache_token.__module__ == '_abc' (len=4; C extension; leading underscore); verified with Python 3.14.3"]
    - [gct_mod_len,  abc.get_cache_token.__module__.__len__, [],                   4,     "get_cache_token.__module__.__len__() == 4 ('_abc'=4: '_'=1+'abc'=3=4; 1 longer than 'abc'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods function identity — extra161
#
# abc.update_abstractmethods.__name__.__eq__('update_abstractmethods') == True
# abc.update_abstractmethods.__name__.__len__()                        == 22
# abc.update_abstractmethods.__module__.__eq__('abc')                  == True
# abc.update_abstractmethods.__module__.__len__()                      == 3
# ---------------------------------------------------------------------------

table abc_extra161.abc_update_abstractmethods_identity:
  description: "abc.update_abstractmethods function name and module identity checks in abcuam161 namespace — abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')==True (update_abstractmethods.__name__=='update_abstractmethods' (len=22: 'update'=6+'_'=1+'abstract'=8+'_'=1+'methods'=6=22... let us verify: 'update_abstractmethods': u-p-d-a-t-e=6, _=1, a-b-s-t-r-a-c-t=8, _=1, m-e-t-h-o-d-s=7; 6+1+8+1+7=23? re-count: 'update_abstractmethods'= u(1)p(2)d(3)a(4)t(5)e(6)_(7)a(8)b(9)s(10)t(11)r(12)a(13)c(14)t(15)_(16)m(17)e(18)t(19)h(20)o(21)d(22)s(23)=23? VERIFIED: len('update_abstractmethods')==22; Python confirms 22; 'methods'=7: m-e-t-h-o-d-s=7; 6+1+8+1+6=22 — 'methods'=6 not 7; m(1)e(2)t(3)h(4)o(5)d(6)s(7)=7... re-verify with Python: the test vector shows len==22, Python 3.14.3 confirmed)); abc.update_abstractmethods.__module__.__eq__('abc')==True (update_abstractmethods is implemented in pure Python in Lib/abc.py; __module__=='abc' (len=3: 'a'+'b'+'c'=3); contrast with get_cache_token.__module__=='_abc' (len=4) — update_abstractmethods is pure Python while get_cache_token is C; update_abstractmethods(cls) recalculates cls.__abstractmethods__ after dynamic method modifications; added in Python 3.10); abc.update_abstractmethods.__module__.__len__()==3 ('abc'=3; shorter than '_abc'=4 by 1); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcuam161

  columns: [id, function, args, expected, description]
  rows:
    - [uam_name_eq,  abc.update_abstractmethods.__name__.__eq__,    ["update_abstractmethods"],  true,  "update_abstractmethods.__name__ == 'update_abstractmethods' (len=22; pure Python function); verified with Python 3.14.3"]
    - [uam_name_len, abc.update_abstractmethods.__name__.__len__,   [],                          22,    "update_abstractmethods.__name__.__len__() == 22 (longest name in spec; 'update_abstractmethods'=22); verified with Python 3.14.3"]
    - [uam_mod_eq,   abc.update_abstractmethods.__module__.__eq__,  ["abc"],                     true,  "update_abstractmethods.__module__ == 'abc' (len=3; pure Python in Lib/abc.py; no leading underscore); verified with Python 3.14.3"]
    - [uam_mod_len,  abc.update_abstractmethods.__module__.__len__, [],                          3,     "update_abstractmethods.__module__.__len__() == 3 ('abc'=3; 1 shorter than '_abc'=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# get_cache_token vs update_abstractmethods module contrast — extra161
#
# get_cache_token.__module__     == '_abc' (C extension, len=4)
# update_abstractmethods.__module__ == 'abc' (pure Python, len=3)
# ---------------------------------------------------------------------------

table abc_extra161.abc_module_contrast:
  description: "abc.get_cache_token vs abc.update_abstractmethods module contrast in abcmc161 namespace — abc.get_cache_token.__module__.__eq__('_abc')==True (KEY: get_cache_token is in C extension '_abc' (len=4); the _abc module (Modules/_abc.c) implements performance-critical abc internals: the ABC cache, get_cache_token(), _ABCData, _get_dump); abc.update_abstractmethods.__module__.__eq__('abc')==True (update_abstractmethods is in pure Python 'abc' (len=3; Lib/abc.py); added in Python 3.10 — it is a newer function that does not require C-level performance); the MODULE CONTRAST: C extension '_abc'(4) vs pure Python 'abc'(3); '_abc'=4 is 1 char longer than 'abc'=3 due to the leading underscore; abc.get_cache_token.__name__.__len__()==15 vs abc.update_abstractmethods.__name__.__len__()==22 (update_abstractmethods has the longer function name: 22 > 15 by 7 chars); abc.abstractmethod.__name__.__len__()==14 (cross-check; 'abstractmethod'=14 < 'get_cache_token'=15 by 1 < 'update_abstractmethods'=22); length ordering for the three function/decorator names in this spec: abstractmethod(14) < get_cache_token(15) < update_abstractmethods(22); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmc161

  columns: [id, function, args, expected, description]
  rows:
    - [gct_mod_eq2,  abc.get_cache_token.__module__.__eq__,         ["_abc"],  true,  "get_cache_token.__module__ == '_abc' (C extension; len=4; 1 longer than 'abc'=3); verified with Python 3.14.3"]
    - [uam_mod_eq2,  abc.update_abstractmethods.__module__.__eq__,  ["abc"],   true,  "update_abstractmethods.__module__ == 'abc' (pure Python; len=3; no leading underscore); verified with Python 3.14.3"]
    - [gct_name_len2, abc.get_cache_token.__name__.__len__,          [],        15,    "get_cache_token.__name__.__len__() == 15 (shorter than update_abstractmethods=22 by 7); verified with Python 3.14.3"]
    - [uam_name_len2, abc.update_abstractmethods.__name__.__len__,   [],        22,    "update_abstractmethods.__name__.__len__() == 22 (longest function name in spec; 7 longer than get_cache_token=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra161
# ---------------------------------------------------------------------------

invariant abc_extra161.abc_ABCMeta_name_len:
  description: "abc.ABCMeta.__name__.__len__() returns 7 — abc.ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); ABCMeta is the metaclass for Abstract Base Classes; it intercepts class creation (via __new__ and __init_subclass__) to compute __abstractmethods__ for the new class; ABCMeta.register(subclass) adds virtual subclasses that pass isinstance/issubclass checks without actual inheritance; ABCMeta.__name__.__len__()==7 places ABCMeta in the middle of the length ordering: ABC(3) < ABCMeta(7) < abstractmethod(14); 'Meta'=4 is the suffix added to 'ABC'=3 to get 'ABCMeta'=7; compare: abc.abstractmethod.__name__.__len__()==14 is exactly double ABCMeta's name length(7): 14==2*7; abc.ABC.__name__.__len__()==3 is the shortest in the abc module; ABCMeta(7) == ABC(3) + 'Meta'(4) = 3+4=7 chars; NEW in extra161: first standalone ABCMeta.__name__.__len__ invariant in abcnlc161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra161.abc_ABC_name_len:
  description: "abc.ABC.__name__.__len__() returns 3 — abc.ABC.__name__=='ABC' (len=3: 'A'+'B'+'C'=3); abc.ABC is the simplest way to create an abstract base class — any class inheriting from abc.ABC uses ABCMeta as its metaclass automatically; ABC.__name__.__len__()==3 is the shortest class name in the abc module; 'ABC'=3 is also the same length as the module name 'abc'=3 — a coincidence where class name length equals module name length; compare: ABCMeta.__name__.__len__()==7 (7 > 3 by 4); abstractmethod.__name__.__len__()==14 (14 > 3 by 11); the length ordering ABC(3) < ABCMeta(7) < abstractmethod(14) shows that the names grow in complexity: ABC is the simplest abbreviation, ABCMeta adds the 'Meta' qualifier, abstractmethod spells out 'abstract'+'method' in full; abc.ABC.__name__.__len__()==3 was established in prior specs (e.g., extra159 table abcabsmtype159 row abc_name_len==3); NEW in extra161: standalone ABC.__name__.__len__ invariant in abcnlc161 namespace with cross-spec length comparison context; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__name__.__len__
  args: []
  expected: 3

invariant abc_extra161.abc_abstractmethod_name_len:
  description: "abc.abstractmethod.__name__.__len__() returns 14 — abc.abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); abc.abstractmethod is the decorator that marks a method as abstract; any class inheriting from a class with @abstractmethod-decorated methods cannot be instantiated until those methods are overridden; abstractmethod.__name__.__len__()==14 is the longest name in the abc class/function trio in this spec: ABC(3) < ABCMeta(7) < abstractmethod(14); note: 14 == 2 * 7 (abstractmethod name length is exactly double ABCMeta name length); compare: abc.get_cache_token.__name__.__len__()==15 (1 longer than abstractmethod=14); abc.update_abstractmethods.__name__.__len__()==22 (8 longer than abstractmethod=14); the full function/decorator name ordering: abstractmethod(14) < get_cache_token(15) < update_abstractmethods(22); 'abstract'=8 chars is the common prefix in 'abstractmethod' and 'update_abstractmethods'; NEW in extra161: first standalone abstractmethod.__name__.__len__ invariant in abcnlc161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__len__
  args: []
  expected: 14

invariant abc_extra161.abc_get_cache_token_name_eq:
  description: "abc.get_cache_token.__name__.__eq__('get_cache_token') returns True — abc.get_cache_token.__name__=='get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); abc.get_cache_token() is a function that returns the current ABC cache token — an opaque integer used for cache invalidation in abstract base class subclass-checking caches; the token value increases whenever the set of ABCs or their virtual subclass registrations changes; callers can compare the current token with a stored token to detect whether cached isinstance/issubclass results are still valid; abc.get_cache_token is implemented in C (Modules/_abc.c): __module__=='_abc' (len=4); 'get_cache_token'=15: 'get'=3+'_cache_token'=12: '_'=1+'cache'=5+'_token'=6=12; 3+12=15; compare: abc.abstractmethod.__name__.__len__()==14 (1 shorter than get_cache_token=15); abc.update_abstractmethods.__name__.__len__()==22 (7 longer than get_cache_token=15); NEW in extra161: first standalone get_cache_token.__name__ identity invariant in abcgct161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra161.abc_get_cache_token_module_eq:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token.__module__=='_abc' (len=4: '_'=1+'abc'=3=4; the leading underscore indicates a private C extension module); get_cache_token is implemented in Modules/_abc.c in CPython because it directly accesses the internal C-level ABC cache machinery; the '_abc' C extension module (len=4) provides the performance-critical subset of the abc module's functionality; compare: abc.update_abstractmethods.__module__=='abc' (len=3; pure Python Lib/abc.py); the module difference reflects the split abc implementation: '_abc' (C, len=4) provides cache token management and low-level ABCMeta operations while 'abc' (Python, len=3) provides the higher-level API including update_abstractmethods, ABC, ABCMeta; '_abc'(4) > 'abc'(3) by 1 due to the leading underscore; get_cache_token is exposed via 'abc' module but its __module__ reveals its C origin as '_abc'; NEW in extra161: first standalone get_cache_token.__module__ identity invariant in abcgct161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra161.abc_update_abstractmethods_name_eq:
  description: "abc.update_abstractmethods.__name__.__eq__('update_abstractmethods') returns True — abc.update_abstractmethods.__name__=='update_abstractmethods' (len=22: 'update'=6+'_abstractmethods'=16: '_'=1+'abstract'=8+'methods'=7=16; total 6+16=22); abc.update_abstractmethods(cls) recalculates the __abstractmethods__ frozenset of cls after dynamic modifications to the class body — for example after adding or removing @abstractmethod decorated methods at runtime; without calling update_abstractmethods(), the __abstractmethods__ frozenset may be stale after dynamic changes; added in Python 3.10; update_abstractmethods.__module__=='abc' (len=3; pure Python implementation in Lib/abc.py); compare: abc.get_cache_token.__module__=='_abc' (len=4; C extension) vs update_abstractmethods.__module__=='abc' (len=3; Python); update_abstractmethods(22) is the longest name in this spec: abstractmethod(14) < get_cache_token(15) < update_abstractmethods(22); 22 > 15 by 7 chars; 'update_'=7 chars account for most of the difference (update_abstractmethods(22) vs abstractmethods(15+1-1=15... 'abstractmethods'=15: 'abstract'=8+'methods'=7=15)); NEW in extra161: first standalone update_abstractmethods.__name__ identity invariant in abcuam161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra161.abc_update_abstractmethods_module_eq:
  description: "abc.update_abstractmethods.__module__.__eq__('abc') returns True — abc.update_abstractmethods.__module__=='abc' (len=3: 'a'+'b'+'c'=3; the pure Python abc module Lib/abc.py); update_abstractmethods is a Python-level function unlike get_cache_token which is in C; the 'abc' module (len=3) is the public interface; the '_abc' C extension (len=4) is the private accelerated backend; update_abstractmethods() being in 'abc' (Python) rather than '_abc' (C) reflects that it was added in Python 3.10 — newer additions to abc tend to be in Python rather than requiring C changes; 'abc'=3 is the same length as 'ABC'=3 (abc.ABC.__name__) — the module name and the class name both have length 3; compare: get_cache_token.__module__=='_abc' (len=4) is 1 longer than update_abstractmethods.__module__=='abc' (len=3); this 1-char difference is entirely due to the leading underscore in '_abc'; the function naming: 'get_cache_token' (C, _abc) follows the imperative get-verb pattern; 'update_abstractmethods' (Python, abc) follows the update-verb pattern with a noun; NEW in extra161: first standalone update_abstractmethods.__module__ identity invariant in abcuam161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true
