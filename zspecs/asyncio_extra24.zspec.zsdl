spec: asyncio_extra24
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl and prior extras through asyncio_extra23.zspec.zsdl."
    - "asyncio_extra18 covers: Task.__qualname__=='Task'; Future.__qualname__=='Future' as standalone invariants."
    - "asyncio_extra23 covers: Queue method __qualname__ table (put/get/put_nowait/get_nowait/empty/full/qsize)."
    - "NOT yet covered in any prior spec: asyncio.Task method __qualname__ table (cancel/done/result) in extra24 namespace."
    - "NOT yet covered: asyncio.Future method __qualname__ table (set_result/set_exception) in extra24 namespace."
    - "NOT yet covered: asyncio.Task.__qualname__ length as a standalone extra24 invariant."
    - "NOT yet covered: asyncio.Future.__qualname__ length as a standalone extra24 invariant."
    - "Task.cancel.__qualname__ == 'Task.cancel' — method on asyncio.Task."
    - "Task.done.__qualname__ == 'Task.done' — method on asyncio.Task."
    - "Task.result.__qualname__ == 'Task.result' — method on asyncio.Task."
    - "Future.set_result.__qualname__ == 'Future.set_result' — method on asyncio.Future."
    - "Future.set_exception.__qualname__ == 'Future.set_exception' — method on asyncio.Future."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Task method __qualname__ table — extra24 namespace
#
# asyncio_extra18 checks Task.__qualname__ == 'Task' as a standalone invariant.
# No prior spec provides a table of Task *method* __qualname__ values.
# Each method follows the pattern 'Task.<method>'.
# Lengths: Task.cancel(11), Task.done(9), Task.result(11).
# ---------------------------------------------------------------------------

table asyncio_extra24.task_method_qualnames:
  description: "asyncio.Task method __qualname__ values in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: taskmqn24

  columns: [id, function, args, expected]
  rows:
    - [cancel, Task.cancel.__qualname__.__eq__, ["Task.cancel"], true]
    - [done,   Task.done.__qualname__.__eq__,   ["Task.done"],   true]
    - [result, Task.result.__qualname__.__eq__, ["Task.result"], true]

# ---------------------------------------------------------------------------
# Task method __qualname__ length table — extra24 namespace
#
# Lengths: Task.cancel(11), Task.done(9), Task.result(11).
# ---------------------------------------------------------------------------

table asyncio_extra24.task_method_qualname_lengths:
  description: "asyncio.Task method __qualname__ lengths in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: taskmqnlen24

  columns: [id, function, args, expected]
  rows:
    - [cancel, Task.cancel.__qualname__.__len__, [], 11]
    - [done,   Task.done.__qualname__.__len__,   [], 9]
    - [result, Task.result.__qualname__.__len__, [], 11]

# ---------------------------------------------------------------------------
# Future method __qualname__ table — extra24 namespace
#
# asyncio_extra18 checks Future.__qualname__ == 'Future' as a standalone
# invariant. No prior spec covers Future *method* __qualname__ values.
# Lengths: Future.set_result(17), Future.set_exception(20).
# ---------------------------------------------------------------------------

table asyncio_extra24.future_method_qualnames:
  description: "asyncio.Future method __qualname__ values in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futmqn24

  columns: [id, function, args, expected]
  rows:
    - [set_result,    Future.set_result.__qualname__.__eq__,    ["Future.set_result"],    true]
    - [set_exception, Future.set_exception.__qualname__.__eq__, ["Future.set_exception"], true]

# ---------------------------------------------------------------------------
# Future method __qualname__ length table — extra24 namespace
#
# Lengths: Future.set_result(17), Future.set_exception(20).
# ---------------------------------------------------------------------------

table asyncio_extra24.future_method_qualname_lengths:
  description: "asyncio.Future method __qualname__ lengths in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futmqnlen24

  columns: [id, function, args, expected]
  rows:
    - [set_result,    Future.set_result.__qualname__.__len__,    [], 17]
    - [set_exception, Future.set_exception.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# Task.__qualname__ length — standalone extra24 invariant
#
# asyncio_extra18 checks Task.__qualname__ == 'Task' as a standalone __eq__
# invariant. No prior spec checks the length of 'Task' (4) in extra24
# namespace.
# ---------------------------------------------------------------------------

invariant asyncio_extra24.Task.qualname_len:
  description: "asyncio.Task.__qualname__ length == 4 — 'Task' has 4 characters"
  category: method_names
  kind: python_call_eq
  function: Task.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Future.__qualname__ length — standalone extra24 invariant
#
# asyncio_extra18 checks Future.__qualname__ == 'Future' as a standalone __eq__
# invariant. No prior spec checks the length of 'Future' (6) in extra24
# namespace.
# ---------------------------------------------------------------------------

invariant asyncio_extra24.Future.qualname_len:
  description: "asyncio.Future.__qualname__ length == 6 — 'Future' has 6 characters"
  category: method_names
  kind: python_call_eq
  function: Future.__qualname__.__len__
  args: []
  expected: 6
