spec: functools_extra469
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "WRAPPER_ASSIGNMENTS has 5 items: __module__, __name__, __qualname__, __annotations__, __doc__"
    - "WRAPPER_UPDATES has 1 item: __dict__"
    - "cmp_to_key is a builtin_function_or_method on CPython"
    - "lru_cache and cache are Python-level functions"
    - "partial is a type (class) exported from _functools C extension"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra469.callable_names:
  description: "Name attribute identity for functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: FE469N

  columns: [id, function, args, expected]
  rows:
    - [FE469N001, functools.cmp_to_key.__name__.__eq__, ["cmp_to_key"], true]
    - [FE469N002, functools.reduce.__name__.__eq__, ["reduce"], true]
    - [FE469N003, functools.partial.__name__.__eq__, ["partial"], true]
    - [FE469N004, functools.lru_cache.__name__.__eq__, ["lru_cache"], true]
    - [FE469N005, functools.cache.__name__.__eq__, ["cache"], true]
    - [FE469N006, functools.wraps.__name__.__eq__, ["wraps"], true]
    - [FE469N007, functools.total_ordering.__name__.__eq__, ["total_ordering"], true]

table functools_extra469.callable_modules:
  description: "Module attribute identity for functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: FE469M

  columns: [id, function, args, expected]
  rows:
    - [FE469M001, functools.cmp_to_key.__module__.__eq__, ["functools"], true]
    - [FE469M002, functools.lru_cache.__module__.__eq__, ["functools"], true]
    - [FE469M003, functools.cache.__module__.__eq__, ["functools"], true]
    - [FE469M004, functools.wraps.__module__.__eq__, ["functools"], true]
    - [FE469M005, functools.total_ordering.__module__.__eq__, ["functools"], true]

table functools_extra469.callable_class_names:
  description: "Class name of functools callables (distinguishes builtins from Python functions)"
  kind: python_call_eq
  category: identity
  id_prefix: FE469C

  columns: [id, function, args, expected]
  rows:
    - [FE469C001, functools.reduce.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [FE469C002, functools.lru_cache.__class__.__name__.__eq__, ["function"], true]
    - [FE469C003, functools.cache.__class__.__name__.__eq__, ["function"], true]

table functools_extra469.wrapper_constants:
  description: "Type identity of WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES constants"
  kind: python_call_eq
  category: identity
  id_prefix: FE469W

  columns: [id, function, args, expected]
  rows:
    - [FE469W001, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"], true]
    - [FE469W002, functools.WRAPPER_UPDATES.__class__.__name__.__eq__, ["tuple"], true]
