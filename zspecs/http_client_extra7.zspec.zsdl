spec: http_client_extra7
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "This spec extends http_client.zspec.zsdl through http_client_extra6.zspec.zsdl."
    - "http_client.zspec.zsdl covers: status code integer equality table; HTTP_PORT/HTTPS_PORT; class __name__ table; responses dict 200/201/301/404/500."
    - "http_client_extra4.zspec.zsdl covers: CREATED/NO_CONTENT/MOVED_PERMANENTLY/BAD_REQUEST/UNAUTHORIZED/FORBIDDEN/METHOD_NOT_ALLOWED/BAD_GATEWAY/SERVICE_UNAVAILABLE .value; OK/NOT_FOUND/CREATED/INTERNAL_SERVER_ERROR .name."
    - "http_client_extra5.zspec.zsdl covers: responses dict 204/302/400/403/503; FOUND/NOT_MODIFIED .value and .name; CannotSendRequest/CannotSendHeader base hierarchy."
    - "http_client_extra6.zspec.zsdl covers: responses dict 304/401/405/502; OK/NOT_FOUND/INTERNAL_SERVER_ERROR .phrase; NO_CONTENT/MOVED_PERMANENTLY/UNAUTHORIZED/FORBIDDEN/METHOD_NOT_ALLOWED/BAD_GATEWAY/SERVICE_UNAVAILABLE .name; ImproperConnectionState/IncompleteRead is_type."
    - "Focus: new HTTPStatus enum members and responses dict entries not yet covered."
    - "No prior spec covers: CONTINUE.value == 100; CONTINUE.name == 'CONTINUE'; CONTINUE.phrase == 'Continue'."
    - "No prior spec covers: TEMPORARY_REDIRECT.value == 307; TEMPORARY_REDIRECT.name == 'TEMPORARY_REDIRECT'; TEMPORARY_REDIRECT.phrase == 'Temporary Redirect'."
    - "No prior spec covers: CONFLICT.value == 409; CONFLICT.name == 'CONFLICT'; CONFLICT.phrase == 'Conflict'."
    - "No prior spec covers: TOO_MANY_REQUESTS.value == 429; TOO_MANY_REQUESTS.name == 'TOO_MANY_REQUESTS'."
    - "No prior spec covers: NOT_IMPLEMENTED.value == 501; NOT_IMPLEMENTED.name == 'NOT_IMPLEMENTED'."
    - "No prior spec covers: GATEWAY_TIMEOUT.value == 504; GATEWAY_TIMEOUT.name == 'GATEWAY_TIMEOUT'."
    - "No prior spec covers: responses dict entries 100/202/307/409/501/504."
    - "IncompleteRead MRO: [IncompleteRead, HTTPException, Exception, BaseException, object]."
    - "No prior spec covers: IncompleteRead.__mro__[1].__name__ == 'HTTPException' (MRO depth-1 check)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPStatus.CONTINUE — value, name, and phrase
#
# No prior spec checks CONTINUE. It is a 1xx informational status.
# ---------------------------------------------------------------------------

invariant http_client_extra7.CONTINUE.value:
  description: "http.client.CONTINUE.value == 100"
  category: status_values
  kind: python_call_eq
  function: CONTINUE.value.__eq__
  args: [100]
  expected: true

invariant http_client_extra7.CONTINUE.name:
  description: "http.client.CONTINUE.name == 'CONTINUE'"
  category: status_names
  kind: python_call_eq
  function: CONTINUE.name.__eq__
  args: ["CONTINUE"]
  expected: true

invariant http_client_extra7.CONTINUE.phrase:
  description: "http.client.CONTINUE.phrase == 'Continue'"
  category: status_phrases
  kind: python_call_eq
  function: CONTINUE.phrase.__eq__
  args: ["Continue"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.TEMPORARY_REDIRECT — value, name, and phrase
#
# No prior spec checks TEMPORARY_REDIRECT (307). http_client_extra5 covers
# FOUND (302) and NOT_MODIFIED (304); 307 is new.
# ---------------------------------------------------------------------------

invariant http_client_extra7.TEMPORARY_REDIRECT.value:
  description: "http.client.TEMPORARY_REDIRECT.value == 307"
  category: status_values
  kind: python_call_eq
  function: TEMPORARY_REDIRECT.value.__eq__
  args: [307]
  expected: true

invariant http_client_extra7.TEMPORARY_REDIRECT.name:
  description: "http.client.TEMPORARY_REDIRECT.name == 'TEMPORARY_REDIRECT'"
  category: status_names
  kind: python_call_eq
  function: TEMPORARY_REDIRECT.name.__eq__
  args: ["TEMPORARY_REDIRECT"]
  expected: true

invariant http_client_extra7.TEMPORARY_REDIRECT.phrase:
  description: "http.client.TEMPORARY_REDIRECT.phrase == 'Temporary Redirect'"
  category: status_phrases
  kind: python_call_eq
  function: TEMPORARY_REDIRECT.phrase.__eq__
  args: ["Temporary Redirect"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.CONFLICT and HTTPStatus.TOO_MANY_REQUESTS — value and name
#
# No prior spec checks CONFLICT (409) or TOO_MANY_REQUESTS (429).
# ---------------------------------------------------------------------------

invariant http_client_extra7.CONFLICT.value:
  description: "http.client.CONFLICT.value == 409"
  category: status_values
  kind: python_call_eq
  function: CONFLICT.value.__eq__
  args: [409]
  expected: true

invariant http_client_extra7.CONFLICT.name:
  description: "http.client.CONFLICT.name == 'CONFLICT'"
  category: status_names
  kind: python_call_eq
  function: CONFLICT.name.__eq__
  args: ["CONFLICT"]
  expected: true

invariant http_client_extra7.TOO_MANY_REQUESTS.value:
  description: "http.client.TOO_MANY_REQUESTS.value == 429"
  category: status_values
  kind: python_call_eq
  function: TOO_MANY_REQUESTS.value.__eq__
  args: [429]
  expected: true

invariant http_client_extra7.TOO_MANY_REQUESTS.name:
  description: "http.client.TOO_MANY_REQUESTS.name == 'TOO_MANY_REQUESTS'"
  category: status_names
  kind: python_call_eq
  function: TOO_MANY_REQUESTS.name.__eq__
  args: ["TOO_MANY_REQUESTS"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.NOT_IMPLEMENTED and GATEWAY_TIMEOUT — value and name
#
# No prior spec checks NOT_IMPLEMENTED (501) or GATEWAY_TIMEOUT (504).
# ---------------------------------------------------------------------------

invariant http_client_extra7.NOT_IMPLEMENTED.value:
  description: "http.client.NOT_IMPLEMENTED.value == 501"
  category: status_values
  kind: python_call_eq
  function: NOT_IMPLEMENTED.value.__eq__
  args: [501]
  expected: true

invariant http_client_extra7.NOT_IMPLEMENTED.name:
  description: "http.client.NOT_IMPLEMENTED.name == 'NOT_IMPLEMENTED'"
  category: status_names
  kind: python_call_eq
  function: NOT_IMPLEMENTED.name.__eq__
  args: ["NOT_IMPLEMENTED"]
  expected: true

invariant http_client_extra7.GATEWAY_TIMEOUT.value:
  description: "http.client.GATEWAY_TIMEOUT.value == 504"
  category: status_values
  kind: python_call_eq
  function: GATEWAY_TIMEOUT.value.__eq__
  args: [504]
  expected: true

invariant http_client_extra7.GATEWAY_TIMEOUT.name:
  description: "http.client.GATEWAY_TIMEOUT.name == 'GATEWAY_TIMEOUT'"
  category: status_names
  kind: python_call_eq
  function: GATEWAY_TIMEOUT.name.__eq__
  args: ["GATEWAY_TIMEOUT"]
  expected: true

# ---------------------------------------------------------------------------
# responses dict — additional entries not yet covered
#
# http_client covers 200/201/301/404/500; extra5 covers 204/302/400/403/503;
# extra6 covers 304/401/405/502.
# 100/202/307/409/501/504 are new.
# ---------------------------------------------------------------------------

table http_client_extra7.responses_extended:
  kind: python_call_eq
  category: responses
  id_prefix: resp
  function: responses.__contains__

  columns: [id, args, expected]
  rows:
    - [r100, [100], true]
    - [r202, [202], true]
    - [r307, [307], true]
    - [r409, [409], true]
    - [r501, [501], true]
    - [r504, [504], true]

# ---------------------------------------------------------------------------
# IncompleteRead MRO — depth-1 check
#
# http_client_extra4 covers IncompleteRead.__bases__[0].__name__ == 'HTTPException'.
# No prior spec checks IncompleteRead.__mro__[1].__name__ (a complementary
# invariant dimension: MRO index vs direct bases list).
# IncompleteRead.__mro__: [IncompleteRead, HTTPException, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant http_client_extra7.IncompleteRead.mro_index1:
  description: "http.client.IncompleteRead.__mro__[1].__name__ == 'HTTPException'"
  category: class_hierarchy
  kind: python_call_eq
  function: IncompleteRead.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "HTTPException"
