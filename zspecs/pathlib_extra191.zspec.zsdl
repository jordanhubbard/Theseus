spec: pathlib_extra191
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "pathlib.PosixPath.__name__=='PosixPath' (len=9); __module__=='pathlib'; __qualname__=='PosixPath'."
    - "pathlib.PosixPath.__bases__ == (Path, PurePosixPath) — inherits from Path and PurePosixPath; __bases__[0].__name__=='Path'."
    - "pathlib.WindowsPath.__name__=='WindowsPath' (len=11); __module__=='pathlib'; __qualname__=='WindowsPath'."
    - "pathlib.WindowsPath.__bases__ == (Path, PureWindowsPath) — inherits from Path and PureWindowsPath; __bases__[0].__name__=='Path'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

