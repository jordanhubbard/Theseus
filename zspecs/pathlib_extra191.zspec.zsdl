# ---------------------------------------------------------------------------
# Table 3: cross-class identity distinguishing PosixPath from WindowsPath
# Both concrete path classes share Path as their first base class
# ---------------------------------------------------------------------------

table pathlib_extra191.concretepath_cross_identity:
  description: "PosixPath and WindowsPath are distinct concrete classes sharing Path as their first base — cross-identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibconcrete191

  columns: [id, function, args, expected, description]
  rows:
    - [pp_ne_wp,    PosixPath.__name__.__eq__,    ["WindowsPath"],  false, "pathlib.PosixPath.__name__.__eq__('WindowsPath') == False — PosixPath and WindowsPath are distinct; confirmed Python 3.14.3 macOS"]
    - [wp_ne_pp,    WindowsPath.__name__.__eq__,  ["PosixPath"],    false, "pathlib.WindowsPath.__name__.__eq__('PosixPath') == False — distinct class names; confirmed Python 3.14.3 macOS"]
    - [pp_base_eq,  "PosixPath.__bases__[0].__name__.__eq__",   ["Path"], true, "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — both concrete path variants inherit Path as first base; confirmed Python 3.14.3 macOS"]
    - [wp_base_eq,  "WindowsPath.__bases__[0].__name__.__eq__", ["Path"], true, "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — both concrete path variants inherit Path as first base; confirmed Python 3.14.3 macOS"]
    - [pp_mod_eq,   PosixPath.__module__.__eq__,   ["pathlib"],     true,  "pathlib.PosixPath.__module__ == 'pathlib' — both classes live in the same pathlib module; confirmed Python 3.14.3 macOS"]

