    - [wp_name_len, WindowsPath.__name__.__len__,    [],               11,    "pathlib.WindowsPath.__name__.__len__() == 11 — W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); confirmed Python 3.14.3 macOS"]
    - [wp_module,   WindowsPath.__module__.__eq__,   ["pathlib"],      true,  "pathlib.WindowsPath.__module__ == 'pathlib' — defined in the pathlib standard library module; confirmed Python 3.14.3 macOS"]
    - [wp_qualname, WindowsPath.__qualname__.__eq__, ["WindowsPath"],  true,  "pathlib.WindowsPath.__qualname__ == 'WindowsPath' — simple unqualified class name; confirmed Python 3.14.3 macOS"]
