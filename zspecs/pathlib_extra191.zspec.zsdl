    - [pp_name,     PosixPath.__name__.__eq__,     ["PosixPath"],  true,  "pathlib.PosixPath.__name__ == 'PosixPath' — concrete POSIX filesystem path class; confirmed Python 3.14.3 macOS"]
    - [pp_name_len, PosixPath.__name__.__len__,    [],             9,     "pathlib.PosixPath.__name__.__len__() == 9 — P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); confirmed Python 3.14.3 macOS"]
    - [pp_module,   PosixPath.__module__.__eq__,   ["pathlib"],    true,  "pathlib.PosixPath.__module__ == 'pathlib' — defined in the pathlib standard library module; confirmed Python 3.14.3 macOS"]
    - [pp_qualname, PosixPath.__qualname__.__eq__, ["PosixPath"],  true,  "pathlib.PosixPath.__qualname__ == 'PosixPath' — simple unqualified class name; confirmed Python 3.14.3 macOS"]
    - [pp_base,     "PosixPath.__bases__[0].__name__.__eq__", ["Path"], true, "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — inherits from Path as first base; confirmed Python 3.14.3 macOS"]

