table pathlib_extra191.posixpath_identity:
  description: "pathlib.PosixPath class identity: __name__=='PosixPath' (len=9); __module__=='pathlib'; __qualname__=='PosixPath'; __bases__[0].__name__=='Path'"
  kind: python_call_eq
  category: identity
