  args: ["Queue.put"]
  expected: true

invariant multiprocessing_extra228.Queue.get_name:
  description: "multiprocessing.queues.Queue.get.__name__ == 'get'; new to extra228"
  category: method_names
  kind: python_call_eq
  function: Queue.get.__name__.__eq__
  args: ["get"]
  expected: true

invariant multiprocessing_extra228.Queue.get_qualname:
  description: "multiprocessing.queues.Queue.get.__qualname__ == 'Queue.get' (len=9); new to extra228"
  category: method_qualnames
  kind: python_call_eq
