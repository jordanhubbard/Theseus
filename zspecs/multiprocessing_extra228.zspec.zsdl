  category: method_names
  kind: python_call_eq
  function: Queue.put.__name__.__eq__
  args: ["put"]
  expected: true

invariant multiprocessing_extra228.Queue.put_qualname:
  description: "multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put' (len=9); new to extra228"
  category: method_qualnames
  kind: python_call_eq
