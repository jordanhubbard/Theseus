spec: multiprocessing_extra228
version: ">=3.0"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers multiprocessing.queues.Queue class identity and method contracts."
    - "The top-level multiprocessing.Queue is a bound method on the context object; the actual class lives in multiprocessing.queues."
    - "Queue.__name__ == 'Queue' — 5 characters."
    - "Queue.__module__ == 'multiprocessing.queues' — 22 characters; defined in the queues submodule."
    - "Queue.__bases__[0].__name__ == 'object' — direct base is object in Python 3.14."
    - "Queue.__qualname__ == 'Queue' — top-level class."
    - "put.__qualname__ == 'Queue.put' (len=9); get.__qualname__ == 'Queue.get' (len=9)."
    - "qsize.__qualname__ == 'Queue.qsize'; empty.__qualname__ == 'Queue.empty'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.queues.Queue class identity contracts
#
# Queue.__name__, __module__, __qualname__, and __bases__[0].__name__ confirm
# the class is defined in multiprocessing.queues and inherits from object.
# ---------------------------------------------------------------------------

table multiprocessing_extra228.queue_class_identity:
  description: "multiprocessing.queues.Queue class identity: name, module, qualname, base; new to extra228"
  kind: python_call_eq
  category: class_identity
  id_prefix: mpq228

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name_eq,
       Queue.__name__.__eq__,
       ["Queue"],
       true,
       "multiprocessing.queues.Queue.__name__.__eq__('Queue') == True — 5 characters; new to extra228"]
    - [queue_module_eq,
       Queue.__module__.__eq__,
       ["multiprocessing.queues"],
       true,
       "multiprocessing.queues.Queue.__module__.__eq__('multiprocessing.queues') == True — 22 characters; new to extra228"]
    - [queue_qualname_eq,
       Queue.__qualname__.__eq__,
       ["Queue"],
       true,
       "multiprocessing.queues.Queue.__qualname__.__eq__('Queue') == True — top-level class; new to extra228"]
    - [queue_base_name_eq,
       "Queue.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object') == True — direct base is object in Python 3.14; new to extra228"]
    - [queue_name_len_5,
       Queue.__name__.__len__,
       [],
       5,
       "multiprocessing.queues.Queue.__name__.__len__() == 5 — 'Queue' has exactly 5 characters; new to extra228"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.queues.Queue module length contracts
#
# The module string 'multiprocessing.queues' has 22 characters.
# ---------------------------------------------------------------------------

table multiprocessing_extra228.queue_module_contracts:
  description: "multiprocessing.queues.Queue module length and base class contracts; new to extra228"
  kind: python_call_eq
  category: class_identity
  id_prefix: mpq228

  columns: [id, function, args, expected, description]
  rows:
    - [queue_module_len_22,
       Queue.__module__.__len__,
       [],
       22,
       "multiprocessing.queues.Queue.__module__.__len__() == 22 — 'multiprocessing.queues' has 22 characters; new to extra228"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.queues.Queue method __name__ contracts
#
# Verifies put, get, qsize, empty, and close method __name__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra228.queue_method_names:
  description: "multiprocessing.queues.Queue method __name__ contracts; new to extra228"
  kind: python_call_eq
  category: method_names
  id_prefix: mpq228m

  columns: [id, function, args, expected, description]
  rows:
    - [put_name_eq,
       Queue.put.__name__.__eq__,
       ["put"],
       true,
       "multiprocessing.queues.Queue.put.__name__ == 'put'; new to extra228"]
    - [get_name_eq,
       Queue.get.__name__.__eq__,
       ["get"],
       true,
       "multiprocessing.queues.Queue.get.__name__ == 'get'; new to extra228"]
    - [qsize_name_eq,
       Queue.qsize.__name__.__eq__,
       ["qsize"],
       true,
       "multiprocessing.queues.Queue.qsize.__name__ == 'qsize'; new to extra228"]
    - [empty_name_eq,
       Queue.empty.__name__.__eq__,
       ["empty"],
       true,
       "multiprocessing.queues.Queue.empty.__name__ == 'empty'; new to extra228"]
    - [close_name_eq,
       Queue.close.__name__.__eq__,
       ["close"],
       true,
       "multiprocessing.queues.Queue.close.__name__ == 'close'; new to extra228"]

# ---------------------------------------------------------------------------
# Table 4: multiprocessing.queues.Queue method __qualname__ contracts
#
# For methods defined on Queue, qualname is 'Queue.<method>'.
# ---------------------------------------------------------------------------

table multiprocessing_extra228.queue_method_qualnames:
  description: "multiprocessing.queues.Queue method __qualname__ contracts; new to extra228"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mpq228m

  columns: [id, function, args, expected, description]
  rows:
    - [put_qualname_eq,
       Queue.put.__qualname__.__eq__,
       ["Queue.put"],
       true,
       "multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put' (len=9); new to extra228"]
    - [get_qualname_eq,
       Queue.get.__qualname__.__eq__,
       ["Queue.get"],
       true,
       "multiprocessing.queues.Queue.get.__qualname__ == 'Queue.get' (len=9); new to extra228"]
    - [qsize_qualname_eq,
       Queue.qsize.__qualname__.__eq__,
       ["Queue.qsize"],
       true,
       "multiprocessing.queues.Queue.qsize.__qualname__ == 'Queue.qsize'; new to extra228"]
    - [empty_qualname_eq,
       Queue.empty.__qualname__.__eq__,
       ["Queue.empty"],
       true,
       "multiprocessing.queues.Queue.empty.__qualname__ == 'Queue.empty'; new to extra228"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra228
# ---------------------------------------------------------------------------

invariant multiprocessing_extra228.Queue.name:
  description: "multiprocessing.queues.Queue.__name__ == 'Queue'; new to extra228"
  category: class_identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra228.Queue.module:
  description: "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'; new to extra228"
  category: class_identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra228.Queue.base_name:
  description: "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' — direct base in Python 3.14; new to extra228"
  category: class_identity
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra228.Queue.module_len:
  description: "multiprocessing.queues.Queue.__module__.__len__() == 22; new to extra228"
  category: class_identity
  kind: python_call_eq
  function: Queue.__module__.__len__
  args: []
  expected: 22

