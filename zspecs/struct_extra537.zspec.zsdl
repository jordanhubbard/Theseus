spec: struct_extra537
version: ">=3.9"
backend: python_module(struct)
docs: "Behavioral specs for struct module and Struct class qualname identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table struct_extra537.struct_module_qualnames:
  description: "struct module top-level function and class __qualname__ checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: strmq
  columns: [id, function, args, expected]
  rows:
    - [strmq001, struct.pack.__qualname__.__eq__, ["pack"], true]
    - [strmq002, struct.unpack.__qualname__.__eq__, ["unpack"], true]
    - [strmq003, struct.calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [strmq004, struct.error.__qualname__.__eq__, ["error"], true]
    - [strmq005, struct.Struct.__qualname__.__eq__, ["Struct"], true]

table struct_extra537.struct_class_method_qualnames:
  description: "struct.Struct method __qualname__ checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: strcq
  columns: [id, function, args, expected]
  rows:
    - [strcq001, struct.Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [strcq002, struct.Struct.unpack.__qualname__.__eq__, ["Struct.unpack"], true]
    - [strcq003, struct.Struct.pack_into.__qualname__.__eq__, ["Struct.pack_into"], true]
    - [strcq004, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [strcq005, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]
