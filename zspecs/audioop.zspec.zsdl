spec: audioop
version: ">=3.3,<3.13"
backend: python_module(audioop)

docs: https://docs.python.org/3/library/audioop.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/audioop.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "audioop source: Modules/audioop.c (PSF; source inspection permitted)"
  not_derived_from:
    - "audioop internal DSP and codec implementation details"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "audioop is a C extension module providing audio sample manipulation functions."
    - "The module exposes an exception class 'error' which is a subclass of Exception."
    - "Functions covered: max, avg, rms, bias, reverse."
    - "audioop.error.__module__ is 'audioop' — verified by module round-trip."
    - "All expected values verified by running Python 3.12 audioop module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "audioop.error is raised when arguments are invalid (e.g. wrong fragment size, bad width). It is a direct subclass of Exception."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# error class checks
# ---------------------------------------------------------------------------

invariant audioop.error_name:
  description: "audioop.error.__name__ == 'error'"
  category: classnames
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant audioop.error_module:
  description: "audioop.error.__module__ == 'audioop'"
  category: classnames
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["audioop"]
  expected: true

invariant audioop.error_base:
  description: "audioop.error.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant audioop.max_name:
  description: "audioop.max.__name__ == 'max'"
  category: functions
  kind: python_call_eq
  function: max.__name__.__eq__
  args: ["max"]
  expected: true

invariant audioop.avg_name:
  description: "audioop.avg.__name__ == 'avg'"
  category: functions
  kind: python_call_eq
  function: avg.__name__.__eq__
  args: ["avg"]
  expected: true

invariant audioop.rms_name:
  description: "audioop.rms.__name__ == 'rms'"
  category: functions
  kind: python_call_eq
  function: rms.__name__.__eq__
  args: ["rms"]
  expected: true

invariant audioop.bias_name:
  description: "audioop.bias.__name__ == 'bias'"
  category: functions
  kind: python_call_eq
  function: bias.__name__.__eq__
  args: ["bias"]
  expected: true

invariant audioop.reverse_name:
  description: "audioop.reverse.__name__ == 'reverse'"
  category: functions
  kind: python_call_eq
  function: reverse.__name__.__eq__
  args: ["reverse"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral checks — max() on silent (all-zero) audio fragments
# ---------------------------------------------------------------------------

invariant audioop.max_silent_2byte:
  description: "audioop.max(b'\\x00\\x00', 2) == 0 — max sample in a silent 2-byte fragment (width=2) is 0"
  category: max
  kind: python_call_eq
  function: max
  args: [{type: bytes_hex, value: "0000"}, 2]
  expected: 0

invariant audioop.rms_silent_2byte:
  description: "audioop.rms(b'\\x00\\x00', 2) == 0 — RMS of a silent 2-byte fragment (width=2) is 0"
  category: rms
  kind: python_call_eq
  function: rms
  args: [{type: bytes_hex, value: "0000"}, 2]
  expected: 0

invariant audioop.avg_silent_2byte:
  description: "audioop.avg(b'\\x00\\x00', 2) == 0 — average of a silent 2-byte fragment (width=2) is 0"
  category: avg
  kind: python_call_eq
  function: avg
  args: [{type: bytes_hex, value: "0000"}, 2]
  expected: 0

