spec: time_rust
version: ">=3.9"
backend: rust_module(time_rust)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time documentation"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python time module, exposed via PyO3."
    - "gmtime(secs) returns a struct_time in UTC for the given Unix timestamp."
    - "gmtime(0) is the Unix epoch: 1970-01-01 00:00:00 UTC, Thursday (tm_wday=3)."
    - "gmtime(0).tm_year == 1970, tm_mon == 1, tm_mday == 1."
    - "gmtime(0).tm_hour == 0, tm_min == 0, tm_sec == 0."
    - "gmtime(0).tm_wday == 3 (Monday=0, ..., Thursday=3, ..., Sunday=6)."
    - "gmtime(0).tm_yday == 1 (day of year, January 1 = 1)."
    - "gmtime(0).tm_isdst == 0 (no DST in UTC)."
    - "gmtime(3600).tm_hour == 1 (one hour after epoch)."
    - "gmtime(86400).tm_mday == 2 (one day after epoch: Jan 2)."
    - "struct_time fields are properties (not callable methods)."
    - "All test vectors verified against Python 3.14.3 time module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# gmtime(0) — Unix epoch field-by-field
invariant time_rust.gmtime.epoch_year:
  description: "gmtime(0).tm_year == 1970"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_year
  expected: 1970

invariant time_rust.gmtime.epoch_mon:
  description: "gmtime(0).tm_mon == 1 (January)"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_mon
  expected: 1

invariant time_rust.gmtime.epoch_mday:
  description: "gmtime(0).tm_mday == 1"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_mday
  expected: 1

invariant time_rust.gmtime.epoch_hour:
  description: "gmtime(0).tm_hour == 0"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_hour
  expected: 0

invariant time_rust.gmtime.epoch_min:
  description: "gmtime(0).tm_min == 0"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_min
  expected: 0

invariant time_rust.gmtime.epoch_sec:
  description: "gmtime(0).tm_sec == 0"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_sec
  expected: 0

invariant time_rust.gmtime.epoch_wday:
  description: "gmtime(0).tm_wday == 3 (Thursday; Monday=0)"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_wday
  expected: 3

invariant time_rust.gmtime.epoch_yday:
  description: "gmtime(0).tm_yday == 1 (Jan 1 = day 1)"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_yday
  expected: 1

invariant time_rust.gmtime.epoch_isdst:
  description: "gmtime(0).tm_isdst == 0 (UTC has no DST)"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [0]
  method: tm_isdst
  expected: 0

# gmtime(3600) — one hour after epoch
invariant time_rust.gmtime.hour_year:
  description: "gmtime(3600).tm_year == 1970"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [3600]
  method: tm_year
  expected: 1970

invariant time_rust.gmtime.hour_hour:
  description: "gmtime(3600).tm_hour == 1"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [3600]
  method: tm_hour
  expected: 1

invariant time_rust.gmtime.hour_min:
  description: "gmtime(3600).tm_min == 0"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [3600]
  method: tm_min
  expected: 0

# gmtime(86400) — one full day later (Jan 2, 1970)
invariant time_rust.gmtime.day_mday:
  description: "gmtime(86400).tm_mday == 2"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [86400]
  method: tm_mday
  expected: 2

invariant time_rust.gmtime.day_yday:
  description: "gmtime(86400).tm_yday == 2 (Jan 2 = day 2)"
  category: gmtime
  kind: python_call_eq
  function: gmtime
  args: [86400]
  method: tm_yday
  expected: 2

