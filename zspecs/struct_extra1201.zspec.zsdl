spec: struct_extra1201
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct.size and struct.Struct.format getset_descriptor __name__/__qualname__ string values, struct.Struct and struct.error __name__/__qualname__/__module__ string identity, and struct.pack and struct.unpack __qualname__/__module__ attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1201.struct_size_format_name_qualname:
  description: "struct.Struct.size and struct.Struct.format getset_descriptor __name__ and __qualname__ string values"
  kind: python_call_eq
  category: struct_size_format_name_qualname
  id_prefix: st1201sf
  columns: [id, function, args, expected]
  rows:
    - [st1201sf001, struct.Struct.size.__name__.__eq__,                          ["size"],         true]
    - [st1201sf002, struct.Struct.size.__qualname__.__eq__,                      ["Struct.size"],  true]
    - [st1201sf003, struct.Struct.format.__name__.__eq__,                        ["format"],       true]
    - [st1201sf004, struct.Struct.format.__qualname__.__eq__,                    ["Struct.format"], true]
    - [st1201sf005, struct.Struct.size.__name__.__class__.__name__.__eq__,       ["str"],          true]
    - [st1201sf006, struct.Struct.size.__qualname__.__class__.__name__.__eq__,   ["str"],          true]
    - [st1201sf007, struct.Struct.format.__name__.__class__.__name__.__eq__,     ["str"],          true]
    - [st1201sf008, struct.Struct.format.__qualname__.__class__.__name__.__eq__, ["str"],          true]
    - [st1201sf009, struct.Struct.size.__class__.__name__.__eq__,                ["getset_descriptor"], true]
    - [st1201sf010, struct.Struct.format.__class__.__name__.__eq__,              ["getset_descriptor"], true]

table struct_extra1201.struct_class_name_qualname_module:
  description: "struct.Struct and struct.error __name__/__qualname__/__module__ string identity"
  kind: python_call_eq
  category: struct_class_name_qualname_module
  id_prefix: st1201nm
  columns: [id, function, args, expected]
  rows:
    - [st1201nm001, struct.Struct.__name__.__eq__,                               ["Struct"],   true]
    - [st1201nm002, struct.Struct.__qualname__.__eq__,                           ["Struct"],   true]
    - [st1201nm003, struct.Struct.__module__.__eq__,                             ["_struct"],  true]
    - [st1201nm004, struct.error.__name__.__eq__,                                ["error"],    true]
    - [st1201nm005, struct.error.__qualname__.__eq__,                            ["error"],    true]
    - [st1201nm006, struct.error.__module__.__eq__,                              ["struct"],   true]
    - [st1201nm007, struct.Struct.__name__.__class__.__name__.__eq__,            ["str"],      true]
    - [st1201nm008, struct.Struct.__qualname__.__class__.__name__.__eq__,        ["str"],      true]
    - [st1201nm009, struct.Struct.__module__.__class__.__name__.__eq__,          ["str"],      true]
    - [st1201nm010, struct.error.__name__.__class__.__name__.__eq__,             ["str"],      true]
    - [st1201nm011, struct.error.__module__.__class__.__name__.__eq__,           ["str"],      true]

table struct_extra1201.pack_unpack_qualname_module:
  description: "struct.pack and struct.unpack __qualname__ and __module__ attrs"
  kind: python_call_eq
  category: pack_unpack_qualname_module
  id_prefix: st1201pu
  columns: [id, function, args, expected]
  rows:
    - [st1201pu001, struct.pack.__qualname__.__eq__,                             ["pack"],     true]
    - [st1201pu002, struct.pack.__module__.__eq__,                               ["_struct"],  true]
    - [st1201pu003, struct.unpack.__qualname__.__eq__,                           ["unpack"],   true]
    - [st1201pu004, struct.unpack.__module__.__eq__,                             ["_struct"],  true]
    - [st1201pu005, struct.pack.__qualname__.__class__.__name__.__eq__,          ["str"],      true]
    - [st1201pu006, struct.pack.__module__.__class__.__name__.__eq__,            ["str"],      true]
    - [st1201pu007, struct.unpack.__qualname__.__class__.__name__.__eq__,        ["str"],      true]
    - [st1201pu008, struct.unpack.__module__.__class__.__name__.__eq__,          ["str"],      true]
