spec: itertools_extra13
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra12.zspec.zsdl."
    - "itertools_extra12 covers: accumulate second element and initial keyword; batched class name and first/second chunk; compress second element and list first element; pairwise second pair; starmap second element."
    - "No prior itertools spec covers __qualname__ for chain, cycle, repeat, count, zip_longest, product, permutations, combinations, combinations_with_replacement, groupby, or islice."
    - "itertools.chain.__qualname__ == 'chain' — C-level type at module scope."
    - "itertools.cycle.__qualname__ == 'cycle' — C-level type at module scope."
    - "itertools.repeat.__qualname__ == 'repeat' — C-level type at module scope."
    - "itertools.count.__qualname__ == 'count' — C-level type at module scope."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' — C-level type at module scope."
    - "itertools.product.__qualname__ == 'product' — C-level type at module scope."
    - "itertools.permutations.__qualname__ == 'permutations' — C-level type at module scope."
    - "itertools.combinations.__qualname__ == 'combinations' — C-level type at module scope."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' — C-level type."
    - "itertools.groupby.__qualname__ == 'groupby' — C-level type at module scope."
    - "itertools.islice.__qualname__ == 'islice' — C-level type at module scope."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools C-level type __qualname__ attributes
#
# No prior itertools spec covers __qualname__ for any of these types.
# All itertools iterator types are implemented in C (itertoolsmodule.c).
# For C-level types defined at module scope, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant itertools_extra13.chain.qualname:
  description: "itertools.chain.__qualname__ == 'chain' — C-level type at module scope"
  category: qualnames
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra13.cycle.qualname:
  description: "itertools.cycle.__qualname__ == 'cycle' — C-level type at module scope"
  category: qualnames
  kind: python_call_eq
  function: cycle.__qualname__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra13.repeat.qualname:
  description: "itertools.repeat.__qualname__ == 'repeat' — C-level type at module scope"
  category: qualnames
  kind: python_call_eq
  function: repeat.__qualname__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra13.count.qualname:
  description: "itertools.count.__qualname__ == 'count' — C-level type at module scope"
  category: qualnames
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

