invariant itertools_extra13.combinations_with_replacement.qualname:
  description: "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'"
  category: qualnames
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra13.groupby.qualname:
  description: "itertools.groupby.__qualname__ == 'groupby' — C-level type at module scope"
