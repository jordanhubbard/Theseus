  expected: true

# ---------------------------------------------------------------------------
# qualname length cross-checks — two representative types
#
# These complement the equality invariants above with a second behavioral axis.
# combinations_with_replacement is the longest name (len == 27).
# chain is the shortest (len == 5).
# ---------------------------------------------------------------------------

invariant itertools_extra13.combinations_with_replacement.qualname_len:
  description: "itertools.combinations_with_replacement.__qualname__.__len__() == 27"
  category: qualname_lengths
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__len__
  args: []
  expected: 27

invariant itertools_extra13.chain.qualname_len:
  description: "itertools.chain.__qualname__.__len__() == 5 — len('chain')"
  category: qualname_lengths
  kind: python_call_eq
  function: chain.__qualname__.__len__
  args: []
  expected: 5
