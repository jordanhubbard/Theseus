spec: struct_extra2356
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct is a C extension type; Struct.__init__.__class__.__name__ == 'wrapper_descriptor'."
    - "struct.Struct.__new__.__class__.__name__ == 'builtin_function_or_method' (C-level allocation)."
    - "struct.error is a Python exception subclass; error.__init__.__class__.__name__ == 'wrapper_descriptor' (inherits BaseException C __init__)."
    - "struct.error.__new__.__class__.__name__ == 'builtin_function_or_method' (inherits object.__new__)."
    - "struct.pack, struct.unpack, struct.pack_into, struct.unpack_from, struct.iter_unpack, struct.calcsize are all C builtins: __class__.__name__ == 'builtin_function_or_method'."
    - "struct.Struct.pack and struct.Struct.unpack are method_descriptor (C method on a C type)."
    - "struct.Struct.size is a getset_descriptor (C-level computed property)."
    - "wrapper_descriptor is the type of __init__ for C extension types (both struct.Struct and struct.error use it)."
    - "The difference between struct.Struct and struct.error: Struct is a C type for packing, error is a Python exception aliasing ValueError."
  created_at: "2026-04-12"

table struct_extra2356.struct_init_type:
  description: "struct.Struct is a C extension type — __init__ is wrapper_descriptor, __new__ is builtin_function_or_method"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: st2356
  columns: [id, function, args, expected]
  rows:
    - ["st2356001", "struct.Struct.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2356002", "struct.Struct.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table struct_extra2356.struct_error_init_type:
  description: "struct.error is a Python exception subclass — __init__ is wrapper_descriptor (inherited from BaseException), __new__ is builtin_function_or_method"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: st2356
  columns: [id, function, args, expected]
  rows:
    - ["st2356003", "struct.error.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2356004", "struct.error.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table struct_extra2356.module_functions_class:
  description: "Module-level struct functions are all builtin_function_or_method (C-backed)"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: st2356
  columns: [id, function, args, expected]
  rows:
    - ["st2356005", "struct.pack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2356006", "struct.unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2356007", "struct.pack_into.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2356008", "struct.unpack_from.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2356009", "struct.iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2356010", "struct.calcsize.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table struct_extra2356.struct_method_descriptors:
  description: "struct.Struct bound methods on the class are method_descriptor; size is getset_descriptor"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: st2356
  columns: [id, function, args, expected]
  rows:
    - ["st2356011", "struct.Struct.pack.__class__.__name__.__eq__", ["method_descriptor"], true]
    - ["st2356012", "struct.Struct.unpack.__class__.__name__.__eq__", ["method_descriptor"], true]
    - ["st2356013", "struct.Struct.size.__class__.__name__.__eq__", ["getset_descriptor"], true]

table struct_extra2356.init_type_contrast:
  description: "Contrast: struct.Struct and struct.error both use wrapper_descriptor for __init__; module functions are not wrapper_descriptor"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: st2356
  columns: [id, function, args, expected]
  rows:
    - ["st2356014", "struct.Struct.__init__.__class__.__name__.__eq__", ["function"], false]
    - ["st2356015", "struct.Struct.__init__.__class__.__name__.__eq__", ["builtin_function_or_method"], false]
    - ["st2356016", "struct.error.__init__.__class__.__name__.__eq__", ["function"], false]
    - ["st2356017", "struct.error.__init__.__class__.__name__.__eq__", ["builtin_function_or_method"], false]
    - ["st2356018", "struct.pack.__class__.__name__.__eq__", ["function"], false]
    - ["st2356019", "struct.pack.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["st2356020", "struct.Struct.__new__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["st2356021", "struct.error.__new__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
