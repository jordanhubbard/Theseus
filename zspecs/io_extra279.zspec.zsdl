spec: io_extra279
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "io.BytesIO.__module__ == '_io' — BytesIO is defined in the C extension _io, not the io wrapper."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits directly from the C-level _BufferedIOBase."
    - "io.StringIO.__module__ == '_io' — StringIO is also defined in the C extension."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO inherits directly from the C-level _TextIOBase."
    - "io.IOBase.__module__ == 'io' — the abstract base class is re-exported by the Python wrapper."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase inherits from the C-level _IOBase."
    - "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase is an abstract class registered via ABCMeta."
    - "io.BytesIO.__class__.__name__ == 'type' — BytesIO is a plain C type, not wrapped in ABCMeta."
    - "io.StringIO.__class__.__name__ == 'type' — StringIO is also a plain C type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: io.BytesIO class identity
# ---------------------------------------------------------------------------

table io_extra279.bytesio_class_identity:
  description: "io.BytesIO __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: bio

  columns: [id, function, args, expected, description]
  rows:
    - [name,       BytesIO.__name__.__eq__,                   ["BytesIO"],          true, "io.BytesIO.__name__ == 'BytesIO'"]
    - [module,     BytesIO.__module__.__eq__,                 ["_io"],              true, "io.BytesIO.__module__ == '_io' — defined in C extension"]
    - [base_name,  "BytesIO.__bases__[0].__name__.__eq__",    ["_BufferedIOBase"],  true, "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase'"]
    - [metaclass,  BytesIO.__class__.__name__.__eq__,         ["type"],             true, "io.BytesIO.__class__.__name__ == 'type' — plain C type"]

# ---------------------------------------------------------------------------
# Table: io.StringIO class identity
# ---------------------------------------------------------------------------

table io_extra279.stringio_class_identity:
  description: "io.StringIO __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: sio

  columns: [id, function, args, expected, description]
  rows:
    - [name,       StringIO.__name__.__eq__,                  ["StringIO"],      true, "io.StringIO.__name__ == 'StringIO'"]
    - [module,     StringIO.__module__.__eq__,                ["_io"],           true, "io.StringIO.__module__ == '_io' — defined in C extension"]
    - [base_name,  "StringIO.__bases__[0].__name__.__eq__",   ["_TextIOBase"],   true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase'"]
    - [metaclass,  StringIO.__class__.__name__.__eq__,        ["type"],          true, "io.StringIO.__class__.__name__ == 'type' — plain C type"]

# ---------------------------------------------------------------------------
# Standalone invariants: io.IOBase abstract base class identity
# ---------------------------------------------------------------------------

invariant io_extra279.IOBase.name:
  description: "io.IOBase.__name__ == 'IOBase'"
  category: identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra279.IOBase.module:
  description: "io.IOBase.__module__ == 'io' — IOBase is re-exported by the Python wrapper"
  category: identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra279.IOBase.base_name:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' — inherits from C-level _IOBase"
  category: identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra279.IOBase.metaclass:
  description: "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase is an abstract class"
  category: identity
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra279.RawIOBase.name:
  description: "io.RawIOBase.__name__ == 'RawIOBase'"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra279.RawIOBase.module:
  description: "io.RawIOBase.__module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra279.BufferedIOBase.name:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase'"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra279.BufferedIOBase.module:
  description: "io.BufferedIOBase.__module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra279.TextIOBase.name:
  description: "io.TextIOBase.__name__ == 'TextIOBase'"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true

invariant io_extra279.TextIOBase.module:
  description: "io.TextIOBase.__module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["io"]
  expected: true
