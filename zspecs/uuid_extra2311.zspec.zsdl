spec: uuid_extra2311
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ absence checks and additional dict-presence."
    - "uuid.UUID is a pure-Python class with no abstract methods."
    - "uuid.SafeUUID is an IntEnum subclass with no abstract methods."
    - "__abstractmethods__ is absent from both class dicts; accessing it raises AttributeError."
    - "Additional dict-presence checks confirm that common sequence/numeric protocol dunders are not defined directly on uuid.UUID or uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — uuid.UUID and uuid.SafeUUID
#
# Neither uuid.UUID nor uuid.SafeUUID is abstract. __abstractmethods__ is
# absent from both class dicts. All expected false.
# ---------------------------------------------------------------------------

table uuid_extra2311.uuid_abstract:
  description: "uuid.UUID and uuid.SafeUUID __abstractmethods__ absence — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2311
  columns: [id, function, args, expected]
  rows:
    - ["uu2311001", "uuid.UUID.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["uu2311002", "uuid.SafeUUID.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ direct attribute access raises AttributeError
#
# Since __abstractmethods__ is absent and not inherited, accessing it on
# uuid.UUID or uuid.SafeUUID raises AttributeError.
# ---------------------------------------------------------------------------

table uuid_extra2311.uuid_abstract_attr_error:
  description: "uuid types raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: uu2311
  columns: [id, function, args, expected]
  rows:
    - ["uu2311003", "uuid.UUID.__abstractmethods__.__len__", [], "AttributeError"]
    - ["uu2311004", "uuid.SafeUUID.__abstractmethods__.__len__", [], "AttributeError"]
    - ["uu2311005", "uuid.UUID.__abstractmethods__.__contains__", ["int"], "AttributeError"]
    - ["uu2311006", "uuid.SafeUUID.__abstractmethods__.__contains__", ["value"], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID dict-presence for sequence/format/numeric dunders
#
# uuid.UUID does not implement sequence, buffer, or numeric protocols.
# None of these dunders appear in uuid.UUID.__dict__ directly.
# All expected false.
# ---------------------------------------------------------------------------

table uuid_extra2311.uuid_dict_contains:
  description: "uuid.UUID dict-presence checks for unimplemented protocol dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2311
  columns: [id, function, args, expected]
  rows:
    - ["uu2311007", "uuid.UUID.__dict__.__contains__", ["__format__"], false]
    - ["uu2311008", "uuid.UUID.__dict__.__contains__", ["__bytes__"], false]
    - ["uu2311009", "uuid.UUID.__dict__.__contains__", ["__len__"], false]
    - ["uu2311010", "uuid.UUID.__dict__.__contains__", ["__contains__"], false]
    - ["uu2311011", "uuid.UUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu2311012", "uuid.UUID.__dict__.__contains__", ["__reversed__"], false]
    - ["uu2311013", "uuid.UUID.__dict__.__contains__", ["__add__"], false]
    - ["uu2311014", "uuid.UUID.__dict__.__contains__", ["__sub__"], false]
    - ["uu2311015", "uuid.UUID.__dict__.__contains__", ["__mul__"], false]
    - ["uu2311016", "uuid.UUID.__dict__.__contains__", ["__truediv__"], false]

# ---------------------------------------------------------------------------
# Table 4: uuid.SafeUUID dict-presence for sequence/format/numeric dunders
#
# uuid.SafeUUID is an IntEnum subclass. While IntEnum inherits numeric
# operators from int via its MRO, none of these dunders are defined directly
# on the uuid.SafeUUID class dict itself. All expected false.
# ---------------------------------------------------------------------------

table uuid_extra2311.safeuuid_dict_contains:
  description: "uuid.SafeUUID dict-presence checks for protocol dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2311
  columns: [id, function, args, expected]
  rows:
    - ["uu2311017", "uuid.SafeUUID.__dict__.__contains__", ["__format__"], false]
    - ["uu2311018", "uuid.SafeUUID.__dict__.__contains__", ["__bytes__"], false]
    - ["uu2311019", "uuid.SafeUUID.__dict__.__contains__", ["__len__"], false]
    - ["uu2311020", "uuid.SafeUUID.__dict__.__contains__", ["__contains__"], false]
    - ["uu2311021", "uuid.SafeUUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu2311022", "uuid.SafeUUID.__dict__.__contains__", ["__reversed__"], false]
    - ["uu2311023", "uuid.SafeUUID.__dict__.__contains__", ["__add__"], false]
    - ["uu2311024", "uuid.SafeUUID.__dict__.__contains__", ["__sub__"], false]
    - ["uu2311025", "uuid.SafeUUID.__dict__.__contains__", ["__mul__"], false]
    - ["uu2311026", "uuid.SafeUUID.__dict__.__contains__", ["__truediv__"], false]
