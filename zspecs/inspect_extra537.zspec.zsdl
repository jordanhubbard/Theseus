spec: inspect_extra537
version: ">=3.9"
backend: python_module(inspect)
docs: "Cover inspect module predicate functions __doc__ class identity and getmodule name/module"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: exception_is_failure

table inspect_extra537.doc_class_checks:
  description: "inspect predicate and utility function __doc__ class name checks"
  kind: python_call_eq
  category: identity
  id_prefix: ind

  columns: [id, function, args, expected]
  rows:
    - [ind001, inspect.isfunction.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind002, inspect.isclass.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind003, inspect.ismethod.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind004, inspect.ismodule.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind005, inspect.isbuiltin.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind006, inspect.getmembers.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind007, inspect.signature.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind008, inspect.getsource.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind009, inspect.getfile.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ind010, inspect.getdoc.__doc__.__class__.__name__.__eq__, ["str"], true]

table inspect_extra537.getmodule_identity:
  description: "inspect.getmodule name and module identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: ing

  columns: [id, function, args, expected]
  rows:
    - [ing001, inspect.getmodule.__name__.__eq__, ["getmodule"], true]
    - [ing002, inspect.getmodule.__module__.__eq__, ["inspect"], true]
