  rows:
    - [ip1141gf001, inspect.getsource.__qualname__.__eq__,                           ["getsource"],                    true]
    - [ip1141gf002, inspect.getsource.__module__.__eq__,                             ["inspect"],                      true]
    - [ip1141gf003, inspect.getsource.__class__.__name__.__eq__,                     ["function"],                     true]
