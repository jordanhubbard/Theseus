spec: inspect_extra1141
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks isbuiltin/__qualname__, isgeneratorfunction/__qualname__, isasyncgenfunction/__qualname__, iscoroutinefunction/__qualname__, getsource/__qualname__, getfile/__qualname__, isroutine/__class__.__name__ — not covered in _extra1111/_extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1141.isbuiltin_isgeneratorfunction_qualnames:
  description: "inspect.isbuiltin and isgeneratorfunction qualname, module, and class identity"
  kind: python_call_eq
  category: isbuiltin_isgeneratorfunction_qualnames
  id_prefix: ip1141bg
  columns: [id, function, args, expected]
  rows:
    - [ip1141bg001, inspect.isbuiltin.__qualname__.__eq__,                           ["isbuiltin"],                    true]
    - [ip1141bg002, inspect.isbuiltin.__module__.__eq__,                             ["inspect"],                      true]
    - [ip1141bg003, inspect.isbuiltin.__class__.__name__.__eq__,                     ["function"],                     true]
    - [ip1141bg004, inspect.isbuiltin.__doc__.__class__.__name__.__eq__,             ["str"],                          true]
    - [ip1141bg005, inspect.isgeneratorfunction.__qualname__.__eq__,                 ["isgeneratorfunction"],           true]
    - [ip1141bg006, inspect.isgeneratorfunction.__module__.__eq__,                   ["inspect"],                      true]
    - [ip1141bg007, inspect.isgeneratorfunction.__class__.__name__.__eq__,           ["function"],                     true]
    - [ip1141bg008, inspect.isgeneratorfunction.__doc__.__class__.__name__.__eq__,   ["str"],                          true]

