    - [ip1141ac005, inspect.iscoroutinefunction.__qualname__.__eq__,                 ["iscoroutinefunction"],           true]
    - [ip1141ac006, inspect.iscoroutinefunction.__module__.__eq__,                   ["inspect"],                      true]
