spec: wrap_text
version: ">=1.0.10"
backend: node(wrap-text)

docs: https://www.npmjs.com/package/wrap-text

provenance:
  derived_from:
    - "wrap-text README — https://www.npmjs.com/package/wrap-text"
    - "Test vectors verified with wrap-text via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "wrap-text source"
  notes:
    - "wrap-text is an npm package. Install: npm install wrap-text"
    - "Wraps text at word boundaries to fit within a given column width."
    - "Lines are joined with newlines in the output."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string with newlines."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table wrap_text.wrap:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: wrtxt

  columns: [id, args, expected]
  rows:
    - [wraps,  ["hello world", 7],  "hello\nworld"]
    - [fits,   ["hi", 100],         "hi"]
    - [multi,  ["a b c d", 3],      "a b\nc d"]
