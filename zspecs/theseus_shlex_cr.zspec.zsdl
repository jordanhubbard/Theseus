spec: theseus_shlex_cr
version: ">=3.8"
backend: python_cleanroom(theseus_shlex_cr)
blocks: shlex

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shlex.html"
  not_derived_from:
    - "CPython source: Lib/shlex.py (internal implementation)"
  notes:
    - "Clean-room shlex module. Do NOT import shlex."
    - "split(s): split a shell-like string into tokens."
    - "quote(s): return a shell-escaped version of s."
    - "join(tokens): join tokens back into a string."

error_model: python_exceptions

invariant theseus_shlex_cr.shlex2_split:
  description: "split('echo hello world') returns 3 tokens"
  category: split
  kind: python_call_eq
  function: shlex2_split
  args: []
  expected: 3

invariant theseus_shlex_cr.shlex2_quoted:
  description: "split respects quoted strings as single token"
  category: split
  kind: python_call_eq
  function: shlex2_quoted
  args: []
  expected: true

invariant theseus_shlex_cr.shlex2_quote:
  description: "quote wraps strings with spaces in single quotes"
  category: quote
  kind: python_call_eq
  function: shlex2_quote
  args: []
  expected: true
