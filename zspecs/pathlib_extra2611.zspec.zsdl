spec: pathlib_extra2611
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2596.zspec.zsdl — covers __get__/__set__/__delete__ dict-presence"
  notes:
    - "Wave 621 (pathlib_extra2611) theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "None of the pathlib classes define __init_subclass__, __subclasshook__, or __class_getitem__ in their own __dict__."
    - "pathlib.Path and pathlib.PurePath are filesystem path objects; they are not generic aliases and do not override subclassing hooks."
    - "pathlib.Path.__class_getitem__ was NOT added in Python 3.12 — the class does not define it in its own __dict__; generic path subscripting is provided through other means."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath are pure-syntax subclasses; neither overrides __init_subclass__ or __subclasshook__."
    - "pathlib.PosixPath is the concrete POSIX path class; it also lacks all three dunders in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2611.no_init_subclass_in_pathlib_classes:
  description: "__init_subclass__ is absent from all pathlib class __dict__s — path objects do not override __init_subclass__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2611

  columns: [id, function, args, expected]
  rows:
    - ["pp2611001", "pathlib.PurePath.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["pp2611002", "pathlib.Path.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["pp2611003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__init_subclass__"], false]
    - ["pp2611004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__init_subclass__"], false]
    - ["pp2611005", "pathlib.PosixPath.__dict__.__contains__",       ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __subclasshook__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2611.no_subclasshook_in_pathlib_classes:
  description: "__subclasshook__ is absent from all pathlib class __dict__s — path classes do not customise ABC virtual subclass registration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2611

  columns: [id, function, args, expected]
  rows:
    - ["pp2611006", "pathlib.PurePath.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["pp2611007", "pathlib.Path.__dict__.__contains__",            ["__subclasshook__"], false]
    - ["pp2611008", "pathlib.PurePosixPath.__dict__.__contains__",   ["__subclasshook__"], false]
    - ["pp2611009", "pathlib.PureWindowsPath.__dict__.__contains__", ["__subclasshook__"], false]
    - ["pp2611010", "pathlib.PosixPath.__dict__.__contains__",       ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2611.no_class_getitem_in_pathlib_classes:
  description: "__class_getitem__ is absent from all pathlib class __dict__s — pathlib classes are not generic aliases"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2611

  columns: [id, function, args, expected]
  rows:
    - ["pp2611011", "pathlib.PurePath.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["pp2611012", "pathlib.Path.__dict__.__contains__",            ["__class_getitem__"], false]
    - ["pp2611013", "pathlib.PurePosixPath.__dict__.__contains__",   ["__class_getitem__"], false]
    - ["pp2611014", "pathlib.PureWindowsPath.__dict__.__contains__", ["__class_getitem__"], false]
    - ["pp2611015", "pathlib.PosixPath.__dict__.__contains__",       ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes HAVE path-manipulation methods but NOT subclassing protocol methods
# Confirms that path objects are domain-specific types, not subclassing customizers
# ---------------------------------------------------------------------------

table pathlib_extra2611.pathlib_has_path_methods_not_subclass_hooks:
  description: "pathlib classes define path methods (__str__, parts, name, stat, exists) but NOT __init_subclass__/__subclasshook__/__class_getitem__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2611

  columns: [id, function, args, expected]
  rows:
    - ["pp2611016", "pathlib.PurePath.__dict__.__contains__", ["__str__"],           true]
    - ["pp2611017", "pathlib.PurePath.__dict__.__contains__", ["parts"],             true]
    - ["pp2611018", "pathlib.PurePath.__dict__.__contains__", ["name"],              true]
    - ["pp2611019", "pathlib.PurePath.__dict__.__contains__", ["parent"],            true]
    - ["pp2611020", "pathlib.PurePath.__dict__.__contains__", ["__init_subclass__"], false]
    - ["pp2611021", "pathlib.PurePath.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["pp2611022", "pathlib.PurePath.__dict__.__contains__", ["__class_getitem__"], false]
    - ["pp2611023", "pathlib.Path.__dict__.__contains__",     ["stat"],              true]
    - ["pp2611024", "pathlib.Path.__dict__.__contains__",     ["exists"],            true]
    - ["pp2611025", "pathlib.Path.__dict__.__contains__",     ["open"],              true]
    - ["pp2611026", "pathlib.Path.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["pp2611027", "pathlib.Path.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["pp2611028", "pathlib.Path.__dict__.__contains__",     ["__class_getitem__"], false]
