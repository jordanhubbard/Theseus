spec: pluralise
version: ">=1.0.1"
backend: node(pluralise)

docs: https://www.npmjs.com/package/pluralise

provenance:
  derived_from:
    - "pluralise README — https://www.npmjs.com/package/pluralise"
    - "Test vectors verified with pluralise via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "pluralise source"
  notes:
    - "pluralise is an npm package. Install: npm install pluralise"
    - "Signature: pluralise(count, singular, optionalPlural)"
    - "Returns the singular or plural form of a word based on count. Does not include the count in the output."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pluralise.pluralise:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: plurls

  columns: [id, args, expected]
  rows:
    - [plural_cat,     [2, "cat"],             "cats"]
    - [singular_cat,   [1, "cat"],             "cat"]
    - [zero_cat,       [0, "cat"],             "cats"]
    - [plural_irreg,   [2, "person", "people"], "people"]
    - [singular_irreg, [1, "person", "people"], "person"]
