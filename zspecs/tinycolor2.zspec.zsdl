spec: tinycolor2
version: ">=1.0.0"
backend: node(tinycolor2)

docs: https://www.npmjs.com/package/tinycolor2

provenance:
  derived_from:
    - "tinycolor2 README — https://www.npmjs.com/package/tinycolor2"
    - "Test vectors verified with tinycolor2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "tinycolor2 source"
  notes:
    - "tinycolor2 is an npm package. Install: npm install tinycolor2"
    - "tinycolor2(color) parses a color and returns an object with utility methods."
    - "toHexString() returns the hex representation."
    - "isDark()/isLight() check perceived brightness."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns color utility object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table tinycolor2.toHexString:
  kind: node_factory_call_eq
  factory: ~
  method: toHexString
  id_prefix: tchex

  columns: [id, factory_args, expected]
  rows:
    - [red,    ["red"],               "#ff0000"]
    - [blue,   ["#0000ff"],           "#0000ff"]
    - [hsl,    ["hsl(120,100%,50%)"], "#00ff00"]

table tinycolor2.isDark:
  kind: node_factory_call_eq
  factory: ~
  method: isDark
  id_prefix: tcdark

  columns: [id, factory_args, expected]
  rows:
    - [black_dark,  ["black"], true]
    - [white_light, ["white"], false]
    - [red_dark,    ["red"],   true]

table tinycolor2.isLight:
  kind: node_factory_call_eq
  factory: ~
  method: isLight
  id_prefix: tclight

  columns: [id, factory_args, expected]
  rows:
    - [white_light, ["white"], true]
    - [black_dark,  ["black"], false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:38:59Z
  iterations: 2
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 2 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
