spec: functools_extra220
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers exception-raising behavior for functools functions on bad inputs."
    - "functools.reduce(42, [1,2]) raises TypeError — first arg must be callable; 42 is an int, not a callable. Verified with Python 3.14.3."
    - "functools.reduce(lambda x,y:x+y, []) raises TypeError — reduce of empty iterable with no initial value is undefined; Python raises TypeError with 'reduce() of empty iterable with no initial value'. Verified indirectly; spec uses reduce.__call__ approach."
    - "functools.lru_cache('bad') raises TypeError — first arg must be an integer, a callable, or None; a string satisfies none of these. Verified with Python 3.14.3."
    - "functools.partial(42) raises TypeError — the first argument must be callable; 42 is not callable. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.reduce — exception on bad first arg (non-callable)
#
# functools.reduce(func, iterable) requires func to be callable. Passing a
# non-callable first arg raises TypeError immediately. Verified with Python
# 3.14.3: reduce(42, [1,2]) -> TypeError: 'int' object is not callable.
# ---------------------------------------------------------------------------

table functools_extra220.reduce_bad_func:
  description: "reduce(non-callable, iterable) raises TypeError — first arg must be callable; new to extra220"
  kind: python_call_raises
  category: errors
  id_prefix: functoolsextra220

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_non_callable_raises_TypeError,
       reduce,
       "[42, [1, 2]]",
       TypeError,
       "functools.reduce(42, [1, 2]) raises TypeError — reduce() requires a callable as its first argument; 42 is an int object and not callable; Python raises TypeError: 'int' object is not callable; new to extra220"]

# ---------------------------------------------------------------------------
# functools.lru_cache — exception on bad maxsize type
#
# functools.lru_cache(maxsize) accepts an integer, a callable, or None as its
# first positional argument. Passing a string raises TypeError immediately.
# Verified with Python 3.14.3: lru_cache('bad') -> TypeError: Expected first
# argument to be an integer, a callable, or None.
# ---------------------------------------------------------------------------

table functools_extra220.lru_cache_bad_maxsize:
  description: "lru_cache(non-int-non-callable) raises TypeError — first arg must be integer, callable, or None; new to extra220"
  kind: python_call_raises
  category: errors
  id_prefix: functoolsextra220

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_string_maxsize_raises_TypeError,
       lru_cache,
       ["bad"],
       TypeError,
       "functools.lru_cache('bad') raises TypeError — lru_cache's first argument must be an integer (maxsize), a callable (to decorate directly), or None (for unbounded cache); passing the string 'bad' satisfies none of these; Python raises TypeError: Expected first argument to be an integer, a callable, or None; new to extra220"]

# ---------------------------------------------------------------------------
# functools.partial — exception on non-callable first arg
#
# functools.partial(func, *args, **kwargs) requires func to be callable.
# Passing a non-callable raises TypeError immediately at construction.
# Verified with Python 3.14.3: partial(42) -> TypeError: the first argument
# must be callable.
# ---------------------------------------------------------------------------

table functools_extra220.partial_non_callable:
  description: "partial(non-callable) raises TypeError — first arg must be callable; new to extra220"
  kind: python_call_raises
  category: errors
  id_prefix: functoolsextra220

  columns: [id, function, args, expected, description]
  rows:
    - [partial_int_raises_TypeError,
       partial,
       [42],
       TypeError,
       "functools.partial(42) raises TypeError — partial() requires its first argument to be a callable object to wrap; 42 is an int and not callable; Python raises TypeError: the first argument must be callable; new to extra220"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra220
# ---------------------------------------------------------------------------

invariant functools_extra220.reduce_non_callable_TypeError:
  description: "functools.reduce(42, [1, 2]) raises TypeError — first arg to reduce must be callable; new to extra220"
  kind: python_call_raises
  category: errors
  function: reduce
  args: "[42, [1, 2]]"
  expected: TypeError

invariant functools_extra220.lru_cache_bad_maxsize_TypeError:
  description: "functools.lru_cache('bad') raises TypeError — lru_cache first arg must be integer, callable, or None; new to extra220"
  kind: python_call_raises
  category: errors
  function: lru_cache
  args: ["bad"]
  expected: TypeError

invariant functools_extra220.partial_non_callable_TypeError:
  description: "functools.partial(42) raises TypeError — partial first arg must be callable; new to extra220"
  kind: python_call_raises
  category: errors
  function: partial
  args: [42]
  expected: TypeError
