spec: socket_extra20
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra8.zspec.zsdl — covers __qualname__ for socket/error/timeout/gaierror/herror/create_server/setdefaulttimeout and gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection via table."
    - "socket_extra10.zspec.zsdl — covers __qualname__ for inet_aton/inet_ntoa/htonl/ntohl/htons/ntohs."
    - "socket_extra12.zspec.zsdl — covers AddressFamily/__qualname__; SocketKind/__qualname__."
    - "socket_extra19.zspec.zsdl — covers gaierror/herror __name__.__len__(); timeout/__name__.__len__(); error/__name__.__len__(); timeout/__name__.__eq__ and gaierror/__name__.__eq__ table."
  notes:
    - "This spec extends socket_extra19; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__len__() checks for socket module functions not yet measured — socket/create_connection/create_server/setdefaulttimeout/gethostname/gethostbyname/getaddrinfo. socket_extra8 verifies these qualnames via __eq__ but never checks lengths."
    - "socket.socket.__qualname__.__len__() == 6: len('socket') == 6. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.create_connection.__qualname__.__len__() == 17: len('create_connection') == 17. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.create_server.__qualname__.__len__() == 13: len('create_server') == 13. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__qualname__.__len__() == 17: len('setdefaulttimeout') == 17. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__.__len__() == 11: len('gethostname') == 11. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__qualname__.__len__() == 13: len('gethostbyname') == 13. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__.__len__() == 11: len('getaddrinfo') == 11. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class — __qualname__ standalone invariant (extra20 namespace)
#
# socket_extra8 covers socket.__qualname__ == 'socket' via table row.
# This invariant anchors the same property from the extra20 namespace as a
# standalone __eq__ call, providing an independent regression checkpoint.
# ---------------------------------------------------------------------------

invariant socket_extra20.socket_class.qualname:
  description: "socket.socket.__qualname__ == 'socket' — C extension socket class"
  category: class_qualnames
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket function __qualname__.__len__() table
#
# socket_extra8 covers these qualnames via __eq__ in a table, but no prior
# spec verifies __qualname__.__len__() for any of these functions.
# socket.socket (the class) has __qualname__ == 'socket' (len 6).
# create_connection and setdefaulttimeout both have qualnames of length 17.
# ---------------------------------------------------------------------------

table socket_extra20.function_qualname_lengths:
  description: "Length of __qualname__ strings for socket module functions and the socket class"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sockqlen20

  columns: [id, function, args, expected]
  rows:
    - [socket_class,      socket.__qualname__.__len__,            [],  6]
    - [create_connection, create_connection.__qualname__.__len__, [], 17]
    - [create_server,     create_server.__qualname__.__len__,     [], 13]
    - [setdefaulttimeout, setdefaulttimeout.__qualname__.__len__, [], 17]
    - [gethostname,       gethostname.__qualname__.__len__,       [], 11]
    - [gethostbyname,     gethostbyname.__qualname__.__len__,     [], 13]
    - [getaddrinfo,       getaddrinfo.__qualname__.__len__,       [], 11]

# ---------------------------------------------------------------------------
# socket.create_connection — __qualname__.__eq__ standalone invariant
#
# socket_extra8 covers create_connection.__qualname__ in a table (gethostname,
# gethostbyname, getaddrinfo, getfqdn, create_connection).
# This standalone invariant anchors create_connection from the extra20 namespace
# using the direct __eq__ path, independent of the table row in extra8.
# ---------------------------------------------------------------------------

invariant socket_extra20.create_connection.qualname:
  description: "socket.create_connection.__qualname__ == 'create_connection' — module-level convenience function"
  category: function_qualnames
  kind: python_call_eq
  function: create_connection.__qualname__.__eq__
  args: ["create_connection"]
  expected: true

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout — __qualname__.__eq__ standalone invariant
#
# socket_extra8 covers setdefaulttimeout.__qualname__ == 'setdefaulttimeout'
# as a table row. This standalone invariant anchors the same from the extra20
# namespace via an independent __eq__ call.
# ---------------------------------------------------------------------------

invariant socket_extra20.setdefaulttimeout.qualname:
  description: "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout' — module-level timeout setter"
  category: function_qualnames
  kind: python_call_eq
  function: setdefaulttimeout.__qualname__.__eq__
  args: ["setdefaulttimeout"]
  expected: true
