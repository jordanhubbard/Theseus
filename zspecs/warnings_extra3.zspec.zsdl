spec: warnings_extra3
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl, warnings_extra.zspec.zsdl, and warnings_extra2.zspec.zsdl."
    - "Focus: __module__ for filterwarnings, simplefilter, resetwarnings (not yet covered); __qualname__ for showwarning, formatwarning, warn_explicit; __module__ for DeprecationWarning and UserWarning."
    - "filterwarnings, simplefilter, resetwarnings are pure-Python functions defined in Lib/warnings.py; their __module__ is 'warnings'."
    - "showwarning and formatwarning are defined in warnings.py; their __qualname__ equals their unqualified function name."
    - "warn_explicit is a C-level function re-exported from _warnings; its __qualname__ == 'warn_explicit'."
    - "DeprecationWarning and UserWarning are built-in exception classes; their __module__ == 'builtins'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — filterwarnings, simplefilter, resetwarnings
# Not covered in any prior warnings spec.
# ---------------------------------------------------------------------------

table warnings_extra3.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [filterwarnings, filterwarnings.__module__.__eq__, ["warnings"], true]
    - [simplefilter,   simplefilter.__module__.__eq__,   ["warnings"], true]
    - [resetwarnings,  resetwarnings.__module__.__eq__,  ["warnings"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — showwarning, formatwarning, warn_explicit
# warnings_extra5 covers warn, warn_explicit, filterwarnings, simplefilter,
# resetwarnings, catch_warnings, WarningMessage qualnames.
# showwarning and formatwarning qualnames are not yet covered.
# ---------------------------------------------------------------------------

table warnings_extra3.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [showwarning,   showwarning.__qualname__.__eq__,   ["showwarning"],   true]
    - [formatwarning, formatwarning.__qualname__.__eq__, ["formatwarning"], true]

# ---------------------------------------------------------------------------
# warn_explicit.__qualname__ — separate invariant (C extension function)
# ---------------------------------------------------------------------------

invariant warnings_extra3.warn_explicit.qualname:
  description: "warnings.warn_explicit.__qualname__ == 'warn_explicit'"
  category: qualnames
  kind: python_call_eq
  function: warn_explicit.__qualname__.__eq__
  args: ["warn_explicit"]
  expected: true

# ---------------------------------------------------------------------------
# DeprecationWarning and UserWarning __module__ — both are built-in classes
# defined in CPython's bltinmodule.c; their __module__ == 'builtins'.
# ---------------------------------------------------------------------------

invariant warnings_extra3.DeprecationWarning.module:
  description: "warnings.DeprecationWarning.__module__ == 'builtins'"
  category: warning_categories
  kind: python_call_eq
  function: DeprecationWarning.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant warnings_extra3.UserWarning.module:
  description: "warnings.UserWarning.__module__ == 'builtins'"
  category: warning_categories
  kind: python_call_eq
  function: UserWarning.__module__.__eq__
  args: ["builtins"]
  expected: true
