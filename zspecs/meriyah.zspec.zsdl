spec: meriyah
version: ">=4.0.0"
backend: node(meriyah)

docs: https://github.com/meriyah/meriyah#readme

provenance:
  derived_from:
    - "Meriyah README — https://github.com/meriyah/meriyah#readme"
    - "ESTree specification — https://github.com/estree/estree"
    - "Test vectors verified with meriyah via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "meriyah source"
  notes:
    - "Meriyah is a fast ECMAScript parser — alternative to acorn, drop-in compatible AST."
    - "Install: npm install meriyah"
    - "parse(code) — auto-detects script vs module. Use parseScript or parseModule explicitly when needed."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws on syntax errors; pure parser otherwise."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes: {}

invariant meriyah.parse_program_type:
  description: "parse('1+2') returns Program"
  category: program
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["1 + 2"]
  chain:
    - {get: type}
  expected: "Program"

invariant meriyah.binary_expression_operator:
  description: "BinaryExpression operator preserved"
  category: expressions
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["a * b"]
  chain:
    - {get: body}
    - {method: at, args: [0]}
    - {get: expression}
    - {get: operator}
  expected: "*"

invariant meriyah.identifier_name:
  description: "Identifier 'x' at expression statement preserves its name"
  category: identifiers
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["x"]
  chain:
    - {get: body}
    - {method: at, args: [0]}
    - {get: expression}
    - {get: name}
  expected: "x"

invariant meriyah.var_decl_kind:
  description: "'var x = 1' has VariableDeclaration kind 'var'"
  category: declarations
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["var x = 1"]
  chain:
    - {get: body}
    - {method: at, args: [0]}
    - {get: kind}
  expected: "var"

invariant meriyah.let_decl_kind:
  description: "'let x = 1' has VariableDeclaration kind 'let'"
  category: declarations
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["let x = 1"]
  chain:
    - {get: body}
    - {method: at, args: [0]}
    - {get: kind}
  expected: "let"

invariant meriyah.parse_module_module_type:
  description: "parseModule sets sourceType to 'module' on the Program"
  category: module
  kind: node_chain_eq
  entry: named
  function: parseModule
  entry_args: ["import x from 'y'"]
  chain:
    - {get: sourceType}
  expected: "module"

invariant meriyah.parse_script_script_type:
  description: "parseScript sets sourceType to 'script'"
  category: module
  kind: node_chain_eq
  entry: named
  function: parseScript
  entry_args: ["1 + 2"]
  chain:
    - {get: sourceType}
  expected: "script"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:13:11Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
