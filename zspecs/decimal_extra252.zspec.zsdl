spec: decimal_extra252
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal.Decimal method identity for from_float, as_tuple, as_integer_ratio, to_integral, to_integral_value, to_integral_exact, fma, conjugate."
    - "decimal.Decimal.from_float.__class__.__name__ == 'builtin_function_or_method' — from_float is a classmethod implemented as a C-level builtin."
    - "decimal.Decimal.from_float.__qualname__ == 'Decimal.from_float' — qualified name confirms class ownership."
    - "decimal.Decimal.as_tuple.__class__.__name__ == 'method_descriptor' — as_tuple is a C-level instance method."
    - "decimal.Decimal.as_integer_ratio.__class__.__name__ == 'method_descriptor' — returns (numerator, denominator) with denominator a power of 10."
    - "decimal.Decimal.to_integral.__name__ == 'to_integral' — rounds to the nearest integer."
    - "decimal.Decimal.to_integral_value.__name__ == 'to_integral_value' — rounds to nearest integer, preferred over to_integral."
    - "decimal.Decimal.to_integral_exact.__name__ == 'to_integral_exact' — like to_integral_value but also signals Inexact/Rounded."
    - "decimal.Decimal.fma.__name__ == 'fma' — fused multiply-add: (self * other) + third with no intermediate rounding."
    - "decimal.Decimal.conjugate.__name__ == 'conjugate' — returns self (Decimal has no imaginary part; exists for numeric tower compatibility)."
    - "All method_descriptor methods are implemented in the C extension _decimal."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal classmethod and conversion method identity
#
# from_float is a classmethod (builtin_function_or_method at class level).
# as_tuple, as_integer_ratio are instance methods (method_descriptor).
# Their __name__, __qualname__, and __class__.__name__ are verified.
# ---------------------------------------------------------------------------

table decimal_extra252.decimal_conversion_method_identity:
  description: "decimal.Decimal from_float, as_tuple, as_integer_ratio method identity — __name__, __qualname__, class kind; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: decxcmi252

  columns: [id, function, args, expected, description]
  rows:
    - [from_float_name,
       "Decimal.from_float.__name__.__eq__",
       ["from_float"],
       true,
       "decimal.Decimal.from_float.__name__.__eq__('from_float') == True — from_float is a classmethod that creates a Decimal from a float without rounding to the string representation; its __name__ is 'from_float'; str.__eq__('from_float') returns True; new to extra252"]
    - [from_float_qualname,
       "Decimal.from_float.__qualname__.__eq__",
       ["Decimal.from_float"],
       true,
       "decimal.Decimal.from_float.__qualname__.__eq__('Decimal.from_float') == True — the qualified name is 'Decimal.from_float', confirming it is defined in the Decimal class; str.__eq__('Decimal.from_float') returns True; new to extra252"]
    - [from_float_class,
       "Decimal.from_float.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "decimal.Decimal.from_float.__class__.__name__.__eq__('builtin_function_or_method') == True — from_float is a C-level classmethod; at class access it appears as a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra252"]
    - [as_tuple_name,
       "Decimal.as_tuple.__name__.__eq__",
       ["as_tuple"],
       true,
       "decimal.Decimal.as_tuple.__name__.__eq__('as_tuple') == True — as_tuple returns a DecimalTuple named tuple (sign, digits, exponent) representing the number; its __name__ is 'as_tuple'; str.__eq__('as_tuple') returns True; new to extra252"]
    - [as_tuple_qualname,
       "Decimal.as_tuple.__qualname__.__eq__",
       ["Decimal.as_tuple"],
       true,
       "decimal.Decimal.as_tuple.__qualname__.__eq__('Decimal.as_tuple') == True — the qualified name is 'Decimal.as_tuple'; str.__eq__('Decimal.as_tuple') returns True; new to extra252"]
    - [as_tuple_class,
       "Decimal.as_tuple.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.as_tuple.__class__.__name__.__eq__('method_descriptor') == True — as_tuple is a C-level method_descriptor in the _decimal extension; str.__eq__('method_descriptor') returns True; new to extra252"]
    - [as_integer_ratio_name,
       "Decimal.as_integer_ratio.__name__.__eq__",
       ["as_integer_ratio"],
       true,
       "decimal.Decimal.as_integer_ratio.__name__.__eq__('as_integer_ratio') == True — as_integer_ratio returns (numerator, denominator) such that numerator/denominator == self exactly, with denominator a power of 10; its __name__ is 'as_integer_ratio'; str.__eq__('as_integer_ratio') returns True; new to extra252"]
    - [as_integer_ratio_qualname,
       "Decimal.as_integer_ratio.__qualname__.__eq__",
       ["Decimal.as_integer_ratio"],
       true,
       "decimal.Decimal.as_integer_ratio.__qualname__.__eq__('Decimal.as_integer_ratio') == True — the qualified name is 'Decimal.as_integer_ratio'; str.__eq__('Decimal.as_integer_ratio') returns True; new to extra252"]
    - [as_integer_ratio_class,
       "Decimal.as_integer_ratio.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.as_integer_ratio.__class__.__name__.__eq__('method_descriptor') == True — as_integer_ratio is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra252"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal to_integral family and fma/conjugate identity
#
# to_integral, to_integral_value, and to_integral_exact round to integer;
# fma performs fused multiply-add with a single rounding;
# conjugate returns self (numeric tower compatibility method).
# All are C-level method_descriptor objects.
# ---------------------------------------------------------------------------

table decimal_extra252.decimal_integral_arithmetic_identity:
  description: "decimal.Decimal to_integral, to_integral_value, to_integral_exact, fma, conjugate method identity; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: decxiai252

  columns: [id, function, args, expected, description]
  rows:
    - [to_integral_name,
       "Decimal.to_integral.__name__.__eq__",
       ["to_integral"],
       true,
       "decimal.Decimal.to_integral.__name__.__eq__('to_integral') == True — to_integral rounds the Decimal to the nearest integer using the current context's rounding; its __name__ is 'to_integral'; str.__eq__('to_integral') returns True; new to extra252"]
    - [to_integral_qualname,
       "Decimal.to_integral.__qualname__.__eq__",
       ["Decimal.to_integral"],
       true,
       "decimal.Decimal.to_integral.__qualname__.__eq__('Decimal.to_integral') == True — the qualified name is 'Decimal.to_integral'; str.__eq__('Decimal.to_integral') returns True; new to extra252"]
    - [to_integral_class,
       "Decimal.to_integral.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.to_integral.__class__.__name__.__eq__('method_descriptor') == True — to_integral is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra252"]
    - [to_integral_value_name,
       "Decimal.to_integral_value.__name__.__eq__",
       ["to_integral_value"],
       true,
       "decimal.Decimal.to_integral_value.__name__.__eq__('to_integral_value') == True — to_integral_value rounds to the nearest integer; it is the preferred name over to_integral; its __name__ is 'to_integral_value'; str.__eq__('to_integral_value') returns True; new to extra252"]
    - [to_integral_value_qualname,
       "Decimal.to_integral_value.__qualname__.__eq__",
       ["Decimal.to_integral_value"],
       true,
       "decimal.Decimal.to_integral_value.__qualname__.__eq__('Decimal.to_integral_value') == True — the qualified name is 'Decimal.to_integral_value'; str.__eq__('Decimal.to_integral_value') returns True; new to extra252"]
    - [to_integral_exact_name,
       "Decimal.to_integral_exact.__name__.__eq__",
       ["to_integral_exact"],
       true,
       "decimal.Decimal.to_integral_exact.__name__.__eq__('to_integral_exact') == True — to_integral_exact rounds to integer like to_integral_value but additionally raises Inexact and/or Rounded signals if digits were discarded; its __name__ is 'to_integral_exact'; str.__eq__('to_integral_exact') returns True; new to extra252"]
    - [to_integral_exact_qualname,
       "Decimal.to_integral_exact.__qualname__.__eq__",
       ["Decimal.to_integral_exact"],
       true,
       "decimal.Decimal.to_integral_exact.__qualname__.__eq__('Decimal.to_integral_exact') == True — the qualified name is 'Decimal.to_integral_exact'; str.__eq__('Decimal.to_integral_exact') returns True; new to extra252"]
    - [fma_name,
       "Decimal.fma.__name__.__eq__",
       ["fma"],
       true,
       "decimal.Decimal.fma.__name__.__eq__('fma') == True — fma performs a fused multiply-add: returns (self * other) + third with a single final rounding, no intermediate rounding between the multiply and add; its __name__ is 'fma'; str.__eq__('fma') returns True; new to extra252"]
    - [fma_qualname,
       "Decimal.fma.__qualname__.__eq__",
       ["Decimal.fma"],
       true,
       "decimal.Decimal.fma.__qualname__.__eq__('Decimal.fma') == True — the qualified name is 'Decimal.fma'; str.__eq__('Decimal.fma') returns True; new to extra252"]
    - [fma_class,
       "Decimal.fma.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.fma.__class__.__name__.__eq__('method_descriptor') == True — fma is a C-level method_descriptor in the _decimal extension; str.__eq__('method_descriptor') returns True; new to extra252"]
    - [conjugate_name,
       "Decimal.conjugate.__name__.__eq__",
       ["conjugate"],
       true,
       "decimal.Decimal.conjugate.__name__.__eq__('conjugate') == True — conjugate returns self unchanged (Decimal has no imaginary part); it exists to satisfy the numeric tower's complex interface; its __name__ is 'conjugate'; str.__eq__('conjugate') returns True; new to extra252"]
    - [conjugate_qualname,
       "Decimal.conjugate.__qualname__.__eq__",
       ["Decimal.conjugate"],
       true,
       "decimal.Decimal.conjugate.__qualname__.__eq__('Decimal.conjugate') == True — the qualified name is 'Decimal.conjugate'; str.__eq__('Decimal.conjugate') returns True; new to extra252"]
    - [conjugate_class,
       "Decimal.conjugate.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.conjugate.__class__.__name__.__eq__('method_descriptor') == True — conjugate is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra252"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra252
# ---------------------------------------------------------------------------

invariant decimal_extra252.from_float_name:
  description: "decimal.Decimal.from_float.__name__ == 'from_float' — classmethod converting float to exact Decimal; new to extra252"
  kind: python_call_eq
  function: Decimal.from_float.__name__.__eq__
  args: ["from_float"]
  expected: true

invariant decimal_extra252.from_float_qualname:
  description: "decimal.Decimal.from_float.__qualname__ == 'Decimal.from_float' — qualified name includes the class; new to extra252"
  kind: python_call_eq
  function: Decimal.from_float.__qualname__.__eq__
  args: ["Decimal.from_float"]
  expected: true

invariant decimal_extra252.from_float_is_builtin:
  description: "decimal.Decimal.from_float.__class__.__name__ == 'builtin_function_or_method' — from_float is a C-level classmethod; new to extra252"
  kind: python_call_eq
  function: Decimal.from_float.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra252.as_tuple_name:
  description: "decimal.Decimal.as_tuple.__name__ == 'as_tuple' — returns (sign, digits, exponent) named tuple; new to extra252"
  kind: python_call_eq
  function: Decimal.as_tuple.__name__.__eq__
  args: ["as_tuple"]
  expected: true

invariant decimal_extra252.as_tuple_is_method_descriptor:
  description: "decimal.Decimal.as_tuple.__class__.__name__ == 'method_descriptor' — as_tuple is a C-level method_descriptor; new to extra252"
  kind: python_call_eq
  function: Decimal.as_tuple.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra252.as_integer_ratio_name:
  description: "decimal.Decimal.as_integer_ratio.__name__ == 'as_integer_ratio' — returns exact (numerator, denominator) pair; new to extra252"
  kind: python_call_eq
  function: Decimal.as_integer_ratio.__name__.__eq__
  args: ["as_integer_ratio"]
  expected: true

invariant decimal_extra252.to_integral_name:
  description: "decimal.Decimal.to_integral.__name__ == 'to_integral' — rounds to nearest integer; new to extra252"
  kind: python_call_eq
  function: Decimal.to_integral.__name__.__eq__
  args: ["to_integral"]
  expected: true

invariant decimal_extra252.to_integral_value_name:
  description: "decimal.Decimal.to_integral_value.__name__ == 'to_integral_value' — preferred integer-rounding method; new to extra252"
  kind: python_call_eq
  function: Decimal.to_integral_value.__name__.__eq__
  args: ["to_integral_value"]
  expected: true

invariant decimal_extra252.to_integral_exact_name:
  description: "decimal.Decimal.to_integral_exact.__name__ == 'to_integral_exact' — rounds to integer and signals Inexact/Rounded if applicable; new to extra252"
  kind: python_call_eq
  function: Decimal.to_integral_exact.__name__.__eq__
  args: ["to_integral_exact"]
  expected: true

invariant decimal_extra252.fma_name:
  description: "decimal.Decimal.fma.__name__ == 'fma' — fused multiply-add with a single rounding; new to extra252"
  kind: python_call_eq
  function: Decimal.fma.__name__.__eq__
  args: ["fma"]
  expected: true

invariant decimal_extra252.fma_qualname:
  description: "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' — qualified name includes the class; new to extra252"
  kind: python_call_eq
  function: Decimal.fma.__qualname__.__eq__
  args: ["Decimal.fma"]
  expected: true

invariant decimal_extra252.fma_is_method_descriptor:
  description: "decimal.Decimal.fma.__class__.__name__ == 'method_descriptor' — fma is a C-level method_descriptor; new to extra252"
  kind: python_call_eq
  function: Decimal.fma.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra252.conjugate_name:
  description: "decimal.Decimal.conjugate.__name__ == 'conjugate' — returns self; numeric tower compatibility method; new to extra252"
  kind: python_call_eq
  function: Decimal.conjugate.__name__.__eq__
  args: ["conjugate"]
  expected: true

invariant decimal_extra252.conjugate_qualname:
  description: "decimal.Decimal.conjugate.__qualname__ == 'Decimal.conjugate' — qualified name includes the class; new to extra252"
  kind: python_call_eq
  function: Decimal.conjugate.__qualname__.__eq__
  args: ["Decimal.conjugate"]
  expected: true
