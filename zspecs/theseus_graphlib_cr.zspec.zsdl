spec: theseus_graphlib_cr
version: ">=3.9"
backend: python_cleanroom(theseus_graphlib_cr)
blocks: graphlib

docs: https://docs.python.org/3/library/graphlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/graphlib.html"
  not_derived_from:
    - "CPython source: Lib/graphlib.py"
  notes:
    - "Clean-room graphlib module. Do NOT import graphlib."

error_model: python_exceptions

invariant theseus_graphlib_cr.graphlib2_topo:
  description: "TopologicalSorter produces correct topological order"
  category: behavior
  kind: python_call_eq
  function: graphlib2_topo
  args: []
  expected: true

invariant theseus_graphlib_cr.graphlib2_cycle:
  description: "TopologicalSorter raises CycleError on cycles"
  category: behavior
  kind: python_call_eq
  function: graphlib2_cycle
  args: []
  expected: true

invariant theseus_graphlib_cr.graphlib2_static_order:
  description: "static_order() yields nodes in dependency order"
  category: behavior
  kind: python_call_eq
  function: graphlib2_static_order
  args: []
  expected: true
