    - [mp1336hq002, multiprocessing.synchronize.Semaphore.__hash__.__qualname__.__eq__,      ["object.__hash__"], true]
    - [mp1336hq003, multiprocessing.synchronize.Event.__hash__.__qualname__.__eq__,          ["object.__hash__"], true]
    - [mp1336hq004, multiprocessing.synchronize.Barrier.__hash__.__qualname__.__eq__,        ["object.__hash__"], true]
    - [mp1336hq005, multiprocessing.synchronize.Lock.__hash__.__qualname__.__eq__,           ["object.__hash__"], true]
    - [mp1336hq006, multiprocessing.pool.Pool.__hash__.__qualname__.__eq__,                  ["object.__hash__"], true]

table multiprocessing_extra1336.eq_qualnames:
  description: "multiprocessing classes: __eq__ qualname and class checks — all inherit object.__eq__ with no custom equality"
