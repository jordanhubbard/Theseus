spec: multiprocessing_extra1336
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method checks for multiprocessing classes."
    - "multiprocessing.Process.__hash__.__class__.__name__ == 'wrapper_descriptor' — inherits object.__hash__, hashable by identity."
    - "multiprocessing.Process.__hash__.__qualname__ == 'object.__hash__' — no custom __hash__ defined."
    - "multiprocessing.Process.__eq__.__class__.__name__ == 'wrapper_descriptor' — inherits object.__eq__."
    - "multiprocessing.Process.__eq__.__qualname__ == 'object.__eq__' — no custom equality defined."
    - "multiprocessing.synchronize.Semaphore.__hash__.__class__.__name__ == 'wrapper_descriptor' — hashable by identity."
    - "multiprocessing.synchronize.Event.__hash__.__class__.__name__ == 'wrapper_descriptor' — hashable by identity."
    - "multiprocessing.synchronize.Barrier.__hash__.__class__.__name__ == 'wrapper_descriptor' — hashable by identity."
    - "All multiprocessing sync primitives inherit __eq__ from object — qualname is 'object.__eq__'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1336.hash_class_names:
  description: "multiprocessing classes: __hash__ method class checks — all inherit wrapper_descriptor from object.__hash__"
  kind: python_call_eq
  category: identity
  id_prefix: mp1336hc
  columns: [id, function, args, expected]
  rows:
    - [mp1336hc001, multiprocessing.Process.__hash__.__class__.__name__.__eq__,                    ["wrapper_descriptor"], true]
    - [mp1336hc002, multiprocessing.synchronize.Semaphore.__hash__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true]
    - [mp1336hc003, multiprocessing.synchronize.Event.__hash__.__class__.__name__.__eq__,          ["wrapper_descriptor"], true]
    - [mp1336hc004, multiprocessing.synchronize.Barrier.__hash__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true]
    - [mp1336hc005, multiprocessing.synchronize.Lock.__hash__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]
    - [mp1336hc006, multiprocessing.pool.Pool.__hash__.__class__.__name__.__eq__,                  ["wrapper_descriptor"], true]

