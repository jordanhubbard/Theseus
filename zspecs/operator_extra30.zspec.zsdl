spec: operator_extra30
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra29.zspec.zsdl."
    - "Prior specs covered: add/sub/mul/truediv/floordiv/mod/pow/neg/pos/abs/eq/ne/lt/le/gt/ge/and_/or_/xor/not_/lshift/rshift/getitem/setitem/delitem/length_hint/index/contains/__name__/__module__, attrgetter/itemgetter/methodcaller __name__/__module__/__qualname__/__init__.__name__, iadd/isub/imul/itruediv __name__, operator.__name__/__package__, attrgetter/itemgetter/methodcaller __bases__[0].__name__, __name__.__len__() for eq/lt/add/sub/mul/truediv/attrgetter/itemgetter/methodcaller, __module__.__len__() for attrgetter/add/iadd."
    - "This spec covers: __name__.__len__() for ne/gt/ge/le/floordiv/mod/neg/pos/lshift/rshift; __module__.__len__() for itemgetter/methodcaller/sub/mul/neg; __qualname__.__len__() for add/sub/mul/attrgetter/itemgetter/methodcaller."
    - "Key findings: ne/gt/ge/le are all 2 chars; floordiv=8, lshift/rshift=6, neg/pos/mod=3; itemgetter/methodcaller __module__ is 'operator' (len 8), sub/mul/neg __module__ is '_operator' (len 9)."
    - "For all plain operator functions, __qualname__ == __name__ (module-level builtins); for callable classes, __qualname__ == __name__ (also module-level)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — comparison and bitshift operator name lengths
#
# operator.ne, gt, ge, and le all have 2-character names (like eq and lt from
# extra29). operator.lshift and rshift have 6-character names. operator.floordiv
# has an 8-character name. operator.neg, pos, and mod share the 3-character
# length with add, sub, and mul. No prior operator spec records these ten
# __name__.__len__() values together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table operator_extra30.comparison_bitshift_name_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra30.comparison_bitshift_name_lengths.ne,
       ne.__name__.__len__,
       [],
       2,
       "len(operator.ne.__name__) == 2"]
    - [operator_extra30.comparison_bitshift_name_lengths.gt,
       gt.__name__.__len__,
       [],
       2,
       "len(operator.gt.__name__) == 2"]
    - [operator_extra30.comparison_bitshift_name_lengths.ge,
       ge.__name__.__len__,
       [],
       2,
       "len(operator.ge.__name__) == 2"]
    - [operator_extra30.comparison_bitshift_name_lengths.le,
       le.__name__.__len__,
       [],
       2,
       "len(operator.le.__name__) == 2"]
    - [operator_extra30.comparison_bitshift_name_lengths.neg,
       neg.__name__.__len__,
       [],
       3,
       "len(operator.neg.__name__) == 3"]
    - [operator_extra30.comparison_bitshift_name_lengths.mod,
       mod.__name__.__len__,
       [],
       3,
       "len(operator.mod.__name__) == 3"]
    - [operator_extra30.comparison_bitshift_name_lengths.lshift,
       lshift.__name__.__len__,
       [],
       6,
       "len(operator.lshift.__name__) == 6"]
    - [operator_extra30.comparison_bitshift_name_lengths.rshift,
       rshift.__name__.__len__,
       [],
       6,
       "len(operator.rshift.__name__) == 6"]
    - [operator_extra30.comparison_bitshift_name_lengths.floordiv,
       floordiv.__name__.__len__,
       [],
       8,
       "len(operator.floordiv.__name__) == 8"]

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string lengths: callable classes and functions
#
# operator.itemgetter and operator.methodcaller have __module__ == 'operator'
# (len 8), consistent with attrgetter (recorded in extra29). operator.sub,
# mul, and neg have __module__ == '_operator' (len 9), consistent with add
# and iadd (recorded in extra29). This table extends both categories with
# new members to reinforce the public-vs-C-extension module naming pattern.
# No prior operator spec records these five __module__.__len__() values together
# in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table operator_extra30.module_str_lengths_extended:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra30.module_str_lengths_extended.itemgetter,
       itemgetter.__module__.__len__,
       [],
       8,
       "len(operator.itemgetter.__module__) == 8 — 'operator'"]
    - [operator_extra30.module_str_lengths_extended.methodcaller,
       methodcaller.__module__.__len__,
       [],
       8,
       "len(operator.methodcaller.__module__) == 8 — 'operator'"]
    - [operator_extra30.module_str_lengths_extended.sub,
       sub.__module__.__len__,
       [],
       9,
       "len(operator.sub.__module__) == 9 — '_operator'"]
    - [operator_extra30.module_str_lengths_extended.mul,
       mul.__module__.__len__,
       [],
       9,
       "len(operator.mul.__module__) == 9 — '_operator'"]
    - [operator_extra30.module_str_lengths_extended.neg,
       neg.__module__.__len__,
       [],
       9,
       "len(operator.neg.__module__) == 9 — '_operator'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — qualname string lengths: arithmetic and callable classes
#
# For all operator objects, __qualname__ == __name__ (all are module-level).
# add.__qualname__ is 'add' (len 3); sub.__qualname__ is 'sub' (len 3);
# mul.__qualname__ is 'mul' (len 3); attrgetter.__qualname__ is 'attrgetter'
# (len 10); itemgetter.__qualname__ is 'itemgetter' (len 10); methodcaller.__qualname__
# is 'methodcaller' (len 12). This table confirms __qualname__.__len__() for
# six representative operator objects spanning both arithmetic functions and
# callable classes. No prior operator spec records these six __qualname__.__len__()
# values together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table operator_extra30.qualname_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra30.qualname_str_lengths.add,
       add.__qualname__.__len__,
       [],
       3,
       "len(operator.add.__qualname__) == 3"]
    - [operator_extra30.qualname_str_lengths.sub,
       sub.__qualname__.__len__,
       [],
       3,
       "len(operator.sub.__qualname__) == 3"]
    - [operator_extra30.qualname_str_lengths.mul,
       mul.__qualname__.__len__,
       [],
       3,
       "len(operator.mul.__qualname__) == 3"]
    - [operator_extra30.qualname_str_lengths.attrgetter,
       attrgetter.__qualname__.__len__,
       [],
       10,
       "len(operator.attrgetter.__qualname__) == 10"]
    - [operator_extra30.qualname_str_lengths.itemgetter,
       itemgetter.__qualname__.__len__,
       [],
       10,
       "len(operator.itemgetter.__qualname__) == 10"]
    - [operator_extra30.qualname_str_lengths.methodcaller,
       methodcaller.__qualname__.__len__,
       [],
       12,
       "len(operator.methodcaller.__qualname__) == 12"]

# ---------------------------------------------------------------------------
# floordiv.__name__.__len__() — standalone name string length
#
# operator.floordiv.__name__ is 'floordiv', an 8-character string. floordiv
# implements the // operator and is the longest single-word arithmetic operator
# name in the module (truediv has 7; floordiv has 8). The 'floor' prefix
# reflects that integer division rounds toward negative infinity. No prior
# operator spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra30.floordiv.name_len:
  description: "len(operator.floordiv.__name__) == 8"
  category: string_properties
  kind: python_call_eq
  function: floordiv.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# itemgetter.__module__.__len__() — standalone module string length
#
# operator.itemgetter.__module__ is 'operator', an 8-character string. Like
# attrgetter and methodcaller, itemgetter is a C-level callable class attributed
# to the public 'operator' namespace rather than the private '_operator' C
# extension used for plain functions. itemgetter creates a callable that retrieves
# one or more items from its operand using __getitem__. No prior operator spec
# records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra30.itemgetter.module_len:
  description: "len(operator.itemgetter.__module__) == 8 — 'operator' is 8 chars"
  category: string_properties
  kind: python_call_eq
  function: itemgetter.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# methodcaller.__qualname__.__len__() — standalone qualname string length
#
# operator.methodcaller.__qualname__ is 'methodcaller', a 12-character string.
# methodcaller is a C-level callable class; as a module-level object its
# __qualname__ equals its __name__. At 12 characters it has the longest
# __qualname__ among the three callable classes in the operator module
# (attrgetter and itemgetter are each 10). No prior operator spec records this
# standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra30.methodcaller.qualname_len:
  description: "len(operator.methodcaller.__qualname__) == 12"
  category: string_properties
  kind: python_call_eq
  function: methodcaller.__qualname__.__len__
  args: []
  expected: 12
