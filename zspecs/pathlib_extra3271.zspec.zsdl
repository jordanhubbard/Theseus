spec: pp3271
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (pp3271): __rand__, __ror__, __rxor__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __rand__, __ror__, __rxor__ dict-presence (reflected bitwise logical)."
    - "No pathlib class defines __rand__ in its own __dict__: path objects represent filesystem paths, not integer types, and do not implement reflected bitwise AND."
    - "No pathlib class defines __ror__ in its own __dict__: path objects do not implement reflected bitwise OR; bitwise logical operations are not part of the path protocol."
    - "No pathlib class defines __rxor__ in its own __dict__: path objects do not implement reflected bitwise XOR."
    - "pathlib defines __truediv__ (wave 659) for path joining but defines no reflected bitwise logical operators on any class."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rand__ dict-presence — operator.contains(Cls.__dict__, '__rand__')
#
# No pathlib class defines __rand__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths, not integer operands.
# ---------------------------------------------------------------------------

table pp3271.rand:
  description: "pathlib types __rand__ dict-presence checks; wave 665"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3271

  columns: [id, function, args, expected]
