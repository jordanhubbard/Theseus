    - ["pp3271001", operator.contains, [pathlib.PurePath.__dict__,         "__rand__"], false]
    - ["pp3271002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__rand__"], false]
    - ["pp3271003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__rand__"], false]
    - ["pp3271004", operator.contains, [pathlib.Path.__dict__,             "__rand__"], false]
    - ["pp3271005", operator.contains, [pathlib.PosixPath.__dict__,        "__rand__"], false]

