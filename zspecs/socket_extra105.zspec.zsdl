spec: socket_extra105
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types (method_descriptor) / socket.socket method qualname lengths / socket.socket Python-level method types (function) and class identity (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop __class__.__name__ and qualname lengths / htons/htonl/ntohs/ntohl class names and qualname lengths / herror/gaierror __mro__.__len__()==5 / AddressFamily/SocketKind __mro__.__len__()==6 (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket/__qualname__/__name__/__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method qualname lengths (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket Python method class/module / send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra104; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: AF_* and SOCK_* constants as IntEnum instances — class module/qualname/mro/int superclass / AddressFamily and SocketKind class identity (name/module/qualname/bases/metaclass)."
    - "socket.AF_INET.__class__.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__qualname__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__qualname__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__mro__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__mro__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.AF_INET) == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.AF_INET6) == 30 (macOS). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SOCK_STREAM) == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SOCK_DGRAM) == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__name__ == 'AddressFamily' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__ == 'SocketKind' (len 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__class__.__name__ == 'EnumType'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__mro__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.value == 2. socket.SOCK_STREAM.value == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: AF_INET6 value is 30 on macOS/Darwin (unlike Linux where it is typically 10). This spec targets macOS/Darwin 25.4.0."
    - "Note: socket_extra96 anchors AF_*/SOCK_* __class__.__name__ equality and AddressFamily/SocketKind __bases__[0].__name__=='IntEnum'; this spec anchors __class__.__module__, __class__.__qualname__, __class__.__mro__.__len__(), and AddressFamily/SocketKind class identity attributes."
    - "Note: The MRO of AF_INET is (AddressFamily, IntEnum, int, ReprEnum, Enum, object) — depth 6. This is the same for all AddressFamily and SocketKind members."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__module__.__eq__('socket')
# socket.SOCK_STREAM.__class__.__module__.__eq__('socket')
# socket.AF_INET.__class__.__qualname__.__eq__('AddressFamily')
# socket.SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind')
# socket.AF_INET.__class__.__mro__.__len__()==6
#
# Wave 267 theme: AF_* and SOCK_* constant class module/qualname/mro depth.
#
# AF_INET and AF_INET6 are AddressFamily IntEnum members; SOCK_STREAM and
# SOCK_DGRAM are SocketKind IntEnum members. Their __class__.__module__ is
# 'socket', __class__.__qualname__ reflects the enum class name, and
# __class__.__mro__.__len__() is 6: (AddressFamily, IntEnum, int, ReprEnum,
# Enum, object). socket_extra96 anchors __class__.__name__ and __bases__;
# no prior socket spec anchors __class__.__module__ or __class__.__qualname__
# or __class__.__mro__.__len__() as a group under sockconst105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra105.AF_SOCK_class_module_qualname_mro:
  description: "AF_INET.__class__.__module__.__eq__('socket')==True / SOCK_STREAM.__class__.__module__.__eq__('socket')==True / AF_INET.__class__.__qualname__.__eq__('AddressFamily')==True / SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind')==True / AF_INET.__class__.__mro__.__len__()==6 — all AF_*/SOCK_* constants have __class__.__module__=='socket' and __class__.__qualname__ matches enum class name; MRO depth 6: (AddressFamily, IntEnum, int, ReprEnum, Enum, object); extra96 anchors __class__.__name__; first sockconst105 anchor for module/qualname/mro"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockconst105

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class_module,   "AF_INET.__class__.__module__.__eq__",    ["socket"],        true, "AF_INET.__class__.__module__ is 'socket' (AddressFamily defined in Lib/socket.py)"]
    - [sock_stream_class_mod,  "SOCK_STREAM.__class__.__module__.__eq__", ["socket"],        true, "SOCK_STREAM.__class__.__module__ is 'socket' (SocketKind defined in Lib/socket.py)"]
    - [af_inet_class_qualname, "AF_INET.__class__.__qualname__.__eq__",  ["AddressFamily"], true, "AF_INET.__class__.__qualname__ is 'AddressFamily' (the enum class name)"]
    - [sock_stream_qualname,   "SOCK_STREAM.__class__.__qualname__.__eq__", ["SocketKind"], true, "SOCK_STREAM.__class__.__qualname__ is 'SocketKind' (the enum class name)"]
    - [af_inet_class_mro_len,  "AF_INET.__class__.__mro__.__len__",      [],               6,    "AF_INET.__class__ MRO depth is 6: (AddressFamily, IntEnum, int, ReprEnum, Enum, object)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__bases__[0].__name__.__eq__('IntEnum')
# socket.SOCK_STREAM.__class__.__bases__[0].__name__.__eq__('IntEnum')
# socket.SOCK_STREAM.__class__.__mro__.__len__()==6
# int(socket.AF_INET).__eq__(2)
# int(socket.SOCK_STREAM).__eq__(1)
#
# Wave 267 theme: AF_*/SOCK_* IntEnum superclass and integer values.
#
# AF_INET and SOCK_STREAM are IntEnum values — their classes directly inherit
# from IntEnum. int(AF_INET)==2, int(SOCK_STREAM)==1. The IntEnum base means
# they can be used directly as integers in socket system calls.
# socket_extra96 anchors AddressFamily.__bases__[0].__name__=='IntEnum' at
# the class level; no prior socket spec anchors __class__.__bases__[0].__name__
# at the *member* level or the int() conversion values as a group under sockconst105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra105.AF_SOCK_intEnum_base_and_values:
  description: "AF_INET.__class__.__bases__[0].__name__.__eq__('IntEnum')==True / SOCK_STREAM.__class__.__bases__[0].__name__.__eq__('IntEnum')==True / SOCK_STREAM.__class__.__mro__.__len__()==6 / int(AF_INET).__eq__(2)==True / int(SOCK_STREAM).__eq__(1)==True — AF_*/SOCK_* members directly inherit IntEnum; IntEnum base allows use as raw int in syscalls; int(AF_INET)==2 and int(SOCK_STREAM)==1; extra96 anchors IntEnum base at class level; first sockconst105 anchor for member-level base and integer values"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockconst105

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_base_intenum,   "AF_INET.__class__.__bases__[0].__name__.__eq__",    ["IntEnum"], true, "AF_INET.__class__ directly inherits from IntEnum (not just Enum)"]
    - [sock_base_intenum,      "SOCK_STREAM.__class__.__bases__[0].__name__.__eq__", ["IntEnum"], true, "SOCK_STREAM.__class__ directly inherits from IntEnum"]
    - [sock_stream_mro_len,    "SOCK_STREAM.__class__.__mro__.__len__",             [],          6,    "SOCK_STREAM.__class__ MRO depth is 6: (SocketKind, IntEnum, int, ReprEnum, Enum, object)"]
    - [af_inet_int_val,        "AF_INET.__int__",                                   [],          2,    "int(AF_INET) == 2 (macOS/Darwin POSIX value for AF_INET)"]
    - [sock_stream_int_val,    "SOCK_STREAM.__int__",                               [],          1,    "int(SOCK_STREAM) == 1 (POSIX value for SOCK_STREAM)"]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__eq__('AddressFamily')
# socket.AddressFamily.__module__.__eq__('socket')
# socket.AddressFamily.__class__.__name__.__eq__('EnumType')
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum')
# socket.SocketKind.__name__.__eq__('SocketKind')
#
# Wave 267 theme: AddressFamily and SocketKind class identity.
#
# socket.AddressFamily is an IntEnum class defined in Lib/socket.py.
# Its __name__ is 'AddressFamily' (13 chars), __module__ is 'socket',
# and its metaclass (__class__) is 'EnumType' (the Enum metaclass).
# SocketKind.__name__ is 'SocketKind' (10 chars). Both inherit from IntEnum.
# socket_extra103 anchors AddressFamily/SocketKind __mro__.__len__()==6;
# socket_extra102 anchors their qualname lengths and module; no prior spec
# groups name equality / module equality / metaclass equality together under
# sockconst105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra105.AddressFamily_SocketKind_identity:
  description: "AddressFamily.__name__.__eq__('AddressFamily')==True / AddressFamily.__module__.__eq__('socket')==True / AddressFamily.__class__.__name__.__eq__('EnumType')==True / AddressFamily.__bases__[0].__name__.__eq__('IntEnum')==True / SocketKind.__name__.__eq__('SocketKind')==True — AddressFamily is an IntEnum class defined in Lib/socket.py; metaclass is 'EnumType' (the Enum metaclass); SocketKind.__name__ is 'SocketKind' (10 chars); extra103 anchors __mro__.__len__()==6; first sockconst105 anchor grouping these five identity attributes"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockconst105

  columns: [id, function, args, expected, description]
  rows:
    - [af_class_name_eq,      "AddressFamily.__name__.__eq__",              ["AddressFamily"], true, "AddressFamily.__name__ is 'AddressFamily' (13 chars; IntEnum class)"]
    - [af_module_eq,          "AddressFamily.__module__.__eq__",            ["socket"],        true, "AddressFamily.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [af_metaclass_enumtype, "AddressFamily.__class__.__name__.__eq__",    ["EnumType"],      true, "AddressFamily.__class__.__name__ is 'EnumType' (the Enum metaclass, not 'type')"]
    - [af_base_intenum,       "AddressFamily.__bases__[0].__name__.__eq__", ["IntEnum"],       true, "AddressFamily.__bases__[0].__name__ is 'IntEnum' (direct base class)"]
    - [sk_name_eq,            "SocketKind.__name__.__eq__",                 ["SocketKind"],    true, "SocketKind.__name__ is 'SocketKind' (10 chars; IntEnum class for SOCK_* constants)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__module__.__eq__('socket') — standalone
#
# socket.AF_INET.__class__.__module__ is 'socket'. The AddressFamily enum
# class is defined in Lib/socket.py, not in the C _socket module. AF_INET is
# a member of AddressFamily, so its class's __module__ reflects where the
# AddressFamily enum was defined. socket_extra96 anchors AF_INET.__class__.__name__
# == 'AddressFamily'; no prior socket spec anchors AF_INET.__class__.__module__
# as a standalone under sockconst105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra105.AF_INET_class_module_eq:
  description: "socket.AF_INET.__class__.__module__.__eq__('socket') == True — AddressFamily (AF_INET's class) is defined in Lib/socket.py; __module__=='socket' (not '_socket' C module); extra96 anchors __class__.__name__=='AddressFamily'; first standalone for AF_INET.__class__.__module__ under sockconst105"
  category: type_identity
  kind: python_call_eq
  function: "AF_INET.__class__.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__class__.__name__.__eq__('EnumType') — standalone
#
# socket.AddressFamily.__class__.__name__ is 'EnumType'. AddressFamily is an
# IntEnum class, and the metaclass of all Enum classes in Python is 'EnumType'
# (also accessible as enum.EnumType). This contrasts with regular Python
# classes whose metaclass is 'type'. socket.SocketKind.__class__.__name__ is
# also 'EnumType'. socket_extra96 anchors AddressFamily.__bases__[0].__name__
# == 'IntEnum'; no prior socket spec anchors AddressFamily.__class__.__name__
# == 'EnumType' as a standalone under sockconst105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra105.AddressFamily_metaclass_EnumType:
  description: "socket.AddressFamily.__class__.__name__.__eq__('EnumType') == True — AddressFamily is an IntEnum class whose metaclass is 'EnumType' (the Enum metaclass); contrasts with socket.socket.__class__.__name__=='type' (regular metaclass); extra96 anchors IntEnum base; first standalone for AddressFamily metaclass under sockconst105"
  category: type_identity
  kind: python_call_eq
  function: "AddressFamily.__class__.__name__.__eq__"
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__mro__.__len__()==6 — standalone
#
# socket.AF_INET.__class__.__mro__.__len__() is 6. The MRO of AddressFamily is
# (AddressFamily, IntEnum, int, ReprEnum, Enum, object). The depth 6 reflects
# the inheritance chain of IntEnum through the enum machinery: IntEnum -> int
# (for integer behavior) and IntEnum -> ReprEnum -> Enum -> object (for enum
# behavior). socket_extra103 anchors AddressFamily.__mro__.__len__()==6 at
# class level; no prior socket spec anchors AF_INET.__class__.__mro__.__len__()
# at the *member* level as a standalone under sockconst105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra105.AF_INET_class_mro_len_6:
  description: "socket.AF_INET.__class__.__mro__.__len__() == 6 — AddressFamily MRO is (AddressFamily, IntEnum, int, ReprEnum, Enum, object) depth 6; IntEnum inherits from both int and Enum creating the 6-step chain; extra103 anchors AddressFamily.__mro__.__len__()==6 at class level; first standalone for AF_INET member-level class mro depth under sockconst105"
  category: type_identity
  kind: python_call_eq
  function: "AF_INET.__class__.__mro__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__eq__('AddressFamily') — standalone
#
# socket.AddressFamily.__name__ is 'AddressFamily' (13 chars). AddressFamily
# is the IntEnum class that wraps all AF_* constants in Python's socket module.
# Its long name (13 chars) reflects its descriptive nature: it categorizes
# the address family (protocol domain) for socket creation. socket_extra102
# anchors AddressFamily.__qualname__.__len__()==13 at table level; no prior
# socket spec anchors AddressFamily.__name__.__eq__('AddressFamily') as a
# standalone under sockconst105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra105.AddressFamily_name_eq:
  description: "socket.AddressFamily.__name__.__eq__('AddressFamily') == True — AddressFamily is 13 chars; the IntEnum class wrapping all AF_* constants; descriptive name reflecting its role as address family (protocol domain) categorizer; extra102 anchors __qualname__.__len__()==13; first standalone for AddressFamily.__name__ equality under sockconst105"
  category: type_identity
  kind: python_call_eq
  function: "AddressFamily.__name__.__eq__"
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum') — standalone
#
# socket.SocketKind.__bases__[0].__name__ is 'IntEnum'. SocketKind is an
# IntEnum class wrapping SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, and other
# socket type constants. Like AddressFamily, it directly inherits from
# IntEnum, giving it both integer behavior (for use in syscalls) and enum
# behavior (named members). socket_extra96 anchors SocketKind.__bases__[0]
# .__name__ == 'IntEnum' at table level; no prior socket spec anchors it
# as a standalone under sockconst105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra105.SocketKind_base_IntEnum:
  description: "socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum') == True — SocketKind directly inherits from IntEnum; wraps SOCK_STREAM/SOCK_DGRAM/SOCK_RAW and other socket type constants; IntEnum base gives integer behavior for syscalls and enum membership; extra96 anchors at table level; first standalone for SocketKind.__bases__[0] equality under sockconst105"
  category: type_identity
  kind: python_call_eq
  function: "SocketKind.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

