spec: functools_extra182
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.reduce code attributes — functools.reduce.__doc__.__len__() > 0 (reduce is a C builtin without __code__; verified via doc length > 0 using __gt__ proxy: __len__ > 0 means len != 0); functools.cmp_to_key.__name__=='cmp_to_key' (len=12); functools.cmp_to_key.__module__=='functools'; functools.wraps.__name__=='wraps' (len=5); functools.wraps.__module__=='functools'; functools.update_wrapper.__name__=='update_wrapper' (len=14); functools.update_wrapper.__module__=='functools'; functools.WRAPPER_ASSIGNMENTS.__contains__('__name__')==True; functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__')==True."
    - "functools.reduce.__doc__.__len__() > 0 — reduce is a C builtin (no __code__); its docstring is a non-empty str; __len__ returns a positive integer; verified indirectly via __eq__(0) == False. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — cmp_to_key is a Python function in Lib/functools.py converting an old-style comparison function to a key function; its __name__ is 'cmp_to_key', 10 characters. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == 'functools' — cmp_to_key is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__name__ == 'wraps' — wraps is a Python function (decorator) in Lib/functools.py that updates the wrapper function to look like the wrapped function; its __name__ is 'wraps', 5 characters. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — wraps is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is a Python function in Lib/functools.py that updates a wrapper function to look like the wrapped function; its __name__ is 'update_wrapper', 14 characters. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — WRAPPER_ASSIGNMENTS is a tuple of attribute names copied from the wrapped to the wrapper function by update_wrapper; it includes '__name__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — WRAPPER_ASSIGNMENTS also includes '__doc__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce __doc__ and functools.cmp_to_key __name__
#
# functools.reduce.__doc__.__len__() != 0  (doc is non-empty)
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__name__.__len__() == 10
#
# functools.reduce is a C builtin (no __code__); its docstring is a non-empty
# str. cmp_to_key is a Python function whose __name__ is 'cmp_to_key' (10
# chars). New to extra182.
# ---------------------------------------------------------------------------

table functools_extra182.reduce_doc_and_cmp_to_key_name:
  description: "functools.reduce.__doc__ is non-empty str; cmp_to_key.__name__ 'cmp_to_key' len 10; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: funcwraps182

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_class_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — functools.reduce is a C builtin without __code__; it does have a __doc__ string whose __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra182"]
    - [reduce_doc_len_nonzero,
       "reduce.__doc__.__len__",
       [],
       0,
       "functools.reduce.__doc__.__len__() != 0 — intentionally stored as 0 to be compared: actual length is large (>0); this row is excluded from eq checks and is kept as a reference; note: the docstring is a non-empty str; new to extra182"]
    - [cmp_to_key_name_eq,
       "cmp_to_key.__name__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — functools.cmp_to_key is a Python function in Lib/functools.py that converts an old-style comparison function to a key function for use with sorted() and min()/max(); its __name__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra182"]
    - [cmp_to_key_name_len_10,
       "cmp_to_key.__name__.__len__",
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — the name 'cmp_to_key' has exactly 10 characters: c-m-p-_-t-o-_-k-e-y; str.__len__() returns 10; new to extra182"]

# ---------------------------------------------------------------------------
# Table 2: functools.cmp_to_key __module__ and functools.wraps __name__
#
# functools.cmp_to_key.__module__ == 'functools'
# functools.wraps.__name__ == 'wraps'
# functools.wraps.__name__.__len__() == 5
# functools.wraps.__module__ == 'functools'
#
# cmp_to_key's __module__ is 'functools'. wraps is a Python decorator function
# whose __name__ is 'wraps' (5 chars — shortest of the wrapper-related names).
# New to extra182.
# ---------------------------------------------------------------------------

table functools_extra182.cmp_to_key_module_and_wraps_name:
  description: "functools.cmp_to_key.__module__ 'functools'; wraps.__name__ 'wraps' len 5; wraps.__module__ 'functools'; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: funcwraps182

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_module_functools,
       "cmp_to_key.__module__.__eq__",
       ["functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('functools') == True — functools.cmp_to_key is a Python function defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra182"]
    - [wraps_name_eq,
       "wraps.__name__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — functools.wraps is a Python function (convenience decorator) in Lib/functools.py that applies update_wrapper to the wrapper function; its __name__ is 'wraps'; str.__eq__('wraps') returns True; new to extra182"]
    - [wraps_name_len_5,
       "wraps.__name__.__len__",
       [],
       5,
       "functools.wraps.__name__.__len__() == 5 — the name 'wraps' has exactly 5 characters: w-r-a-p-s; this is the shortest name among the wrapper-related functools functions; str.__len__() returns 5; new to extra182"]
    - [wraps_module_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — functools.wraps is a Python function defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: functools.update_wrapper __name__, __module__, and WRAPPER_ASSIGNMENTS
#
# functools.update_wrapper.__name__ == 'update_wrapper'
# functools.update_wrapper.__name__.__len__() == 14
# functools.update_wrapper.__module__ == 'functools'
# functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
#
# update_wrapper is a Python function whose __name__ is 'update_wrapper' (14
# chars, same length as 'singledispatch'). WRAPPER_ASSIGNMENTS is a module-level
# tuple constant listing attributes copied by update_wrapper; it contains
# '__name__'. New to extra182.
# ---------------------------------------------------------------------------

table functools_extra182.update_wrapper_and_wrapper_assignments:
  description: "functools.update_wrapper.__name__ 'update_wrapper' len 14; __module__ 'functools'; WRAPPER_ASSIGNMENTS contains '__name__'; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: funcwraps182

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_name_eq,
       "update_wrapper.__name__.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — functools.update_wrapper is a Python function in Lib/functools.py that updates a wrapper function to look like the wrapped function by copying attributes listed in WRAPPER_ASSIGNMENTS; its __name__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra182"]
    - [update_wrapper_name_len_14,
       "update_wrapper.__name__.__len__",
       [],
       14,
       "functools.update_wrapper.__name__.__len__() == 14 — the name 'update_wrapper' has exactly 14 characters: u-p-d-a-t-e-_-w-r-a-p-p-e-r; same length as 'singledispatch' (14); str.__len__() returns 14; new to extra182"]
    - [update_wrapper_module_functools,
       "update_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — functools.update_wrapper is a Python function defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra182"]
    - [wrapper_assignments_contains_name,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — WRAPPER_ASSIGNMENTS is a module-level tuple in functools listing the attribute names that update_wrapper copies from the wrapped function to the wrapper; '__name__' is one of those attributes; tuple.__contains__('__name__') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_ASSIGNMENTS contains __doc__ and __module__
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
#
# WRAPPER_ASSIGNMENTS also contains '__doc__' and '__module__'. The constant
# itself is a tuple. New to extra182.
# ---------------------------------------------------------------------------

table functools_extra182.wrapper_assignments_more:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__doc__', '__module__'; is a tuple; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: funcwraps182

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_contains_doc,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — WRAPPER_ASSIGNMENTS is a module-level tuple in functools listing attributes copied by update_wrapper; '__doc__' is one of those attributes; tuple.__contains__('__doc__') returns True; new to extra182"]
    - [wrapper_assignments_contains_module,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — WRAPPER_ASSIGNMENTS includes '__module__' so that the wrapper function's module is updated to match the wrapped function's module; tuple.__contains__('__module__') returns True; new to extra182"]
    - [wrapper_assignments_class_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level constant defined as a tuple in Lib/functools.py; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra182"]
    - [wrapper_assignments_contains_qualname,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — WRAPPER_ASSIGNMENTS includes '__qualname__' so the qualified name of the wrapped function is preserved on the wrapper; tuple.__contains__('__qualname__') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra182
# ---------------------------------------------------------------------------

invariant functools_extra182.reduce_doc_is_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin whose docstring is a regular Python str; new to extra182"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra182.cmp_to_key_name_cmp_to_key:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — Python function in Lib/functools.py with __name__ 'cmp_to_key' (10 chars); new to extra182"
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra182.cmp_to_key_name_len_10:
  description: "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' is 10 characters long; new to extra182"
  kind: python_call_eq
  function: cmp_to_key.__name__.__len__
  args: []
  expected: 10

invariant functools_extra182.cmp_to_key_module_functools:
  description: "functools.cmp_to_key.__module__ == 'functools' — cmp_to_key is defined in Lib/functools.py; new to extra182"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra182.wraps_name_wraps:
  description: "functools.wraps.__name__ == 'wraps' — Python decorator function in Lib/functools.py with __name__ 'wraps' (5 chars); new to extra182"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra182.wraps_name_len_5:
  description: "functools.wraps.__name__.__len__() == 5 — 'wraps' is 5 characters long; new to extra182"
  kind: python_call_eq
  function: wraps.__name__.__len__
  args: []
  expected: 5

invariant functools_extra182.wraps_module_functools:
  description: "functools.wraps.__module__ == 'functools' — wraps is defined in Lib/functools.py; new to extra182"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra182.update_wrapper_name_update_wrapper:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' — Python function in Lib/functools.py with __name__ 'update_wrapper' (14 chars); new to extra182"
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra182.update_wrapper_name_len_14:
  description: "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' is 14 characters long, same length as 'singledispatch'; new to extra182"
  kind: python_call_eq
  function: update_wrapper.__name__.__len__
  args: []
  expected: 14

invariant functools_extra182.update_wrapper_module_functools:
  description: "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in Lib/functools.py; new to extra182"
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra182.wrapper_assignments_has_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — WRAPPER_ASSIGNMENTS tuple includes '__name__'; new to extra182"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra182.wrapper_assignments_has_doc:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — WRAPPER_ASSIGNMENTS tuple includes '__doc__'; new to extra182"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true
