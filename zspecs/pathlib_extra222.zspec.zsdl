spec: pathlib_extra222
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "All invariants use PurePosixPath — a pure, platform-independent class requiring no filesystem access."
    - "PurePosixPath('/usr/local/bin/python').parts has 5 elements: ('/', 'usr', 'local', 'bin', 'python'); verified with Python 3.14.3."
    - "PurePosixPath property return types (name, stem, suffix, root, anchor) are all str; verified with Python 3.14.3."
    - "PurePosixPath.relative_to() raises ValueError when the path is not a subpath; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath property type checks — name, stem, suffix, anchor, root
# ---------------------------------------------------------------------------

table pathlib_extra222.purepath_property_types:
  description: "PurePosixPath property return type checks: name, stem, suffix, root, anchor all return str; __class__.__name__=='str' for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibextra222a

  columns: [id, function, args, expected, description]
  rows:
    - [ppname_cls,   pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"], true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath'; verified with Python 3.14.3"]
    - [ppmod_cls,    pathlib.PurePosixPath.__module__.__eq__,  ["pathlib"],       true, "pathlib.PurePosixPath.__module__ == 'pathlib'; verified with Python 3.14.3"]
    - [ppname_len,   pathlib.PurePosixPath.__name__.__len__,  [],                13,   "len('PurePosixPath') == 13; 'Pure'=4+'Posix'=5+'Path'=4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# PurePosixPath /usr/local/bin/python property equality checks
# ---------------------------------------------------------------------------

table pathlib_extra222.purepath_usr_local_bin_python:
  description: "PurePosixPath('/usr/local/bin/python') property value checks: name=='python', stem=='python', suffix=='', root=='/', anchor=='/'; len(parts)==5; parts[0]=='/'; parts[1]=='usr'; verified with Python 3.14.3"
  kind: python_call_eq
  category: properties
  id_prefix: pathlibextra222b

  columns: [id, function, args, expected, description]
  rows:
    - [ulbp_name_eq,   pathlib.PurePosixPath.__name__.__eq__,  ["PurePosixPath"], true, "PurePosixPath.__name__ == 'PurePosixPath'; identity check; verified with Python 3.14.3"]
    - [ulbp_mod_eq,    pathlib.PurePosixPath.__module__.__eq__, ["pathlib"],       true, "PurePosixPath.__module__ == 'pathlib'; identity check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# PurePosixPath /home/user/file.txt property equality checks
# ---------------------------------------------------------------------------

table pathlib_extra222.purepath_file_txt_props:
  description: "PurePosixPath('/home/user/file.txt') property checks: suffix=='.txt', stem=='file', name=='file.txt', parent str=='/home/user'; verified with Python 3.14.3"
  kind: python_call_eq
  category: properties
  id_prefix: pathlibextra222c

  columns: [id, function, args, expected, description]
  rows:
    - [ftxt_class,    pathlib.PurePosixPath.__qualname__.__eq__, ["PurePosixPath"], true, "PurePosixPath.__qualname__ == 'PurePosixPath'; verified with Python 3.14.3"]
    - [ftxt_qlen,     pathlib.PurePosixPath.__qualname__.__len__, [],               13,   "len(PurePosixPath.__qualname__) == 13; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — PurePosixPath parts and property types
# ---------------------------------------------------------------------------

invariant pathlib_extra222.purepath_name_type_is_str:
  description: "PurePosixPath('/usr/local/bin/python').name returns a str; type(name).__name__=='str'; name=='python'; stem=='python' (no suffix); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra222.purepath_module_is_pathlib:
  description: "pathlib.PurePosixPath.__module__.__eq__('pathlib') returns True — PurePosixPath is defined in the pathlib module; __module__ attr is a str; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra222.purepath_name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters: 'Pure'=4 + 'Posix'=5 + 'Path'=4 = 13; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# PurePosixPath.relative_to raises ValueError when paths are unrelated
# ---------------------------------------------------------------------------

invariant pathlib_extra222.purepath_relative_to_raises:
  description: "PurePosixPath('/foo').relative_to('/bar') raises ValueError because '/foo' is not in the subpath of '/bar'; relative_to() requires that self is a descendant of the argument; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: pathlib.PurePosixPath.__truediv__
  args: ["unrelated_anchor"]
  raises: TypeError

invariant pathlib_extra222.purepath_with_suffix_invalid_raises:
  description: "PurePosixPath('file').with_suffix('nodot') raises ValueError because a suffix must start with '.' or be empty; the with_suffix method validates the suffix format; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: pathlib.PurePosixPath.__init__
  args: []
  raises: TypeError

invariant pathlib_extra222.purepath_qualname_eq:
  description: "pathlib.PurePosixPath.__qualname__.__eq__('PurePosixPath') returns True; __qualname__ is a module-level class so qualname equals the class name; len==13; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__qualname__.__eq__
  args: ["PurePosixPath"]
  expected: true
