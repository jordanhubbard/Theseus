spec: pathlib_extra266
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib_extra265.zspec.zsdl — covers Path.exists/is_file/is_dir/stat/chmod/unlink and PurePath.with_name/with_suffix/with_stem qualnames"
  notes:
    - "Path.mkdir, rmdir, touch, resolve, absolute, expanduser qualnames all use 'Path.' prefix — defined on Path."
    - "Path.mkdir.__class__.__name__ == 'function' — pathlib methods are plain Python functions."
    - "PurePath.__str__.__qualname__ == 'PurePath.__str__', __class__.__name__ == 'function'."
    - "PurePath.__repr__.__qualname__ == 'PurePath.__repr__', __class__.__name__ == 'function'."
    - "PurePath.__bytes__ exists and __qualname__ == 'PurePath.__bytes__', __class__.__name__ == 'function'."
    - "PurePath.__hash__.__qualname__ == 'PurePath.__hash__', __class__.__name__ == 'function'."
    - "PurePath.__lt__.__qualname__ == 'PurePath.__lt__', __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path filesystem-mutation methods — qualnames
# ---------------------------------------------------------------------------

table pathlib_extra266.Path.mutation_method_qualnames:
  description: "Path filesystem-mutation methods report correct __qualname__ attributes using 'Path.' prefix"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [mkdir,      Path.mkdir.__qualname__.__eq__,      ["Path.mkdir"],      true]
    - [rmdir,      Path.rmdir.__qualname__.__eq__,      ["Path.rmdir"],      true]
    - [touch,      Path.touch.__qualname__.__eq__,      ["Path.touch"],      true]
    - [resolve,    Path.resolve.__qualname__.__eq__,    ["Path.resolve"],    true]
    - [absolute,   Path.absolute.__qualname__.__eq__,   ["Path.absolute"],   true]
    - [expanduser, Path.expanduser.__qualname__.__eq__, ["Path.expanduser"], true]

# ---------------------------------------------------------------------------
# Path.mkdir — descriptor/class type
# ---------------------------------------------------------------------------

invariant pathlib_extra266.Path.mkdir.class_name:
  description: "Path.mkdir.__class__.__name__ == 'function' — pathlib methods are plain Python functions"
  category: method_identity
  kind: python_call_eq
  function: Path.mkdir.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# PurePath string/repr/bytes/hash/lt dunders — qualnames
# ---------------------------------------------------------------------------

table pathlib_extra266.PurePath.dunder_qualnames:
  description: "PurePath string-conversion and comparison dunders report correct __qualname__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [str,   PurePath.__str__.__qualname__.__eq__,   ["PurePath.__str__"],   true]
    - [repr,  PurePath.__repr__.__qualname__.__eq__,  ["PurePath.__repr__"],  true]
    - [bytes, PurePath.__bytes__.__qualname__.__eq__, ["PurePath.__bytes__"], true]
    - [hash,  PurePath.__hash__.__qualname__.__eq__,  ["PurePath.__hash__"],  true]
    - [lt,    PurePath.__lt__.__qualname__.__eq__,    ["PurePath.__lt__"],    true]

# ---------------------------------------------------------------------------
# PurePath.__str__ — descriptor/class type
# ---------------------------------------------------------------------------

invariant pathlib_extra266.PurePath.str.class_name:
  description: "PurePath.__str__.__class__.__name__ == 'function' — PurePath dunders are plain Python functions"
  category: method_identity
  kind: python_call_eq
  function: PurePath.__str__.__class__.__name__.__eq__
  args: ["function"]
  expected: true
