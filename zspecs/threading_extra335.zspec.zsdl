spec: threading_extra335
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Barrier(2).__class__.__name__ == 'Barrier' — Barrier is a Python class."
    - "threading.Barrier(2).parties == 2 — the number of parties required to trip the barrier."
    - "threading.Barrier(2).n_waiting == 0 — no threads waiting at construction time."
    - "threading.Barrier(2).broken == False — not broken at construction time."
    - "threading.Barrier.__module__ == 'threading' — defined in the threading module."
    - "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError'."
    - "threading.BrokenBarrierError.__module__ == 'threading'."
    - "threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError' — inherits from RuntimeError."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Barrier class — name and module (class-level, not instance-level)
# ---------------------------------------------------------------------------

invariant threading_extra335.Barrier.class_name:
  description: "threading.Barrier.__name__ == 'Barrier'"
  category: Barrier
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra335.Barrier.module:
  description: "threading.Barrier.__module__ == 'threading'"
  category: Barrier
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# Barrier instance — class name, parties, n_waiting, broken
#
# Each invariant constructs a fresh Barrier(2) instance and reads an attribute.
# ---------------------------------------------------------------------------

invariant threading_extra335.Barrier.instance_class_name:
  description: "threading.Barrier(2).__class__.__name__ == 'Barrier'"
  category: Barrier_instance
  kind: python_call_eq
  function: Barrier
  args: [2]
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["Barrier"]
  expected: true

invariant threading_extra335.Barrier.parties:
  description: "threading.Barrier(2).parties == 2"
  category: Barrier_instance
  kind: python_call_eq
  function: Barrier
  args: [2]
  method: parties.__eq__
  method_args: [2]
  expected: true

invariant threading_extra335.Barrier.n_waiting:
  description: "threading.Barrier(2).n_waiting == 0"
  category: Barrier_instance
  kind: python_call_eq
  function: Barrier
  args: [2]
  method: n_waiting.__eq__
  method_args: [0]
  expected: true

invariant threading_extra335.Barrier.broken:
  description: "threading.Barrier(2).broken == False"
  category: Barrier_instance
  kind: python_call_eq
  function: Barrier
  args: [2]
  method: broken.__eq__
  method_args: [false]
  expected: true

# ---------------------------------------------------------------------------
# BrokenBarrierError — name, module, and base class
# ---------------------------------------------------------------------------

invariant threading_extra335.BrokenBarrierError.name:
  description: "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError'"
  category: BrokenBarrierError
  kind: python_call_eq
  function: BrokenBarrierError.__name__.__eq__
  args: ["BrokenBarrierError"]
  expected: true

invariant threading_extra335.BrokenBarrierError.module:
  description: "threading.BrokenBarrierError.__module__ == 'threading'"
  category: BrokenBarrierError
  kind: python_call_eq
  function: BrokenBarrierError.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra335.BrokenBarrierError.base_class_name:
  description: "threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError'"
  category: BrokenBarrierError
  kind: python_call_eq
  function: "BrokenBarrierError.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true
