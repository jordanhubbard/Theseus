spec: io_extra2446
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl"
    - "io_extra2.zspec.zsdl"
    - "_io_extra.zspec.zsdl"
  notes:
    - "Wave 2446, theme: __enter__/__exit__ context manager protocol dict-presence."
    - "io.IOBase IS a context manager (hasattr confirms __enter__ and __exit__ are reachable), but its own __dict__ does NOT define them."
    - "In Python 3.14, io.IOBase is a thin ABC wrapper; the context manager protocol lives in _io._IOBase (the C base), not in io.IOBase.__dict__."
    - "io.IOBase.__dict__ contains only _abc_impl and __doc__ — no protocol methods at all."
    - "All subclasses (RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, TextIOWrapper) also lack __enter__/__exit__ in their own __dict__."
    - "io.BytesIO.__dict__ contains read, write, getvalue, read1 — but not __enter__ or __exit__."
    - "io.FileIO.__dict__ contains read, write, mode — but not __enter__ or __exit__."
    - "io.TextIOWrapper.__dict__ contains encoding — but not __enter__ or __exit__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# io.IOBase — context manager protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table io_extra2446.iobase_cm_protocol:
  description: "io.IOBase.__dict__ does not define __enter__ or __exit__ directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2446

  columns: [id, function, args, expected]
  rows:
    - ["io2446001", "io.IOBase.__dict__.__contains__", ["__enter__"], false]
    - ["io2446002", "io.IOBase.__dict__.__contains__", ["__exit__"], false]

# ---------------------------------------------------------------------------
# io abstract base classes — context manager protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table io_extra2446.abstract_bases_cm_protocol:
  description: "io.RawIOBase, BufferedIOBase, TextIOBase do not define __enter__/__exit__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2446

  columns: [id, function, args, expected]
  rows:
    - ["io2446003", "io.RawIOBase.__dict__.__contains__",      ["__enter__"], false]
    - ["io2446004", "io.RawIOBase.__dict__.__contains__",      ["__exit__"],  false]
    - ["io2446005", "io.BufferedIOBase.__dict__.__contains__", ["__enter__"], false]
    - ["io2446006", "io.BufferedIOBase.__dict__.__contains__", ["__exit__"],  false]
    - ["io2446007", "io.TextIOBase.__dict__.__contains__",     ["__enter__"], false]
    - ["io2446008", "io.TextIOBase.__dict__.__contains__",     ["__exit__"],  false]

# ---------------------------------------------------------------------------
# io concrete classes — context manager protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table io_extra2446.concrete_classes_cm_protocol:
  description: "io.BytesIO, StringIO, FileIO, BufferedReader, TextIOWrapper do not define __enter__/__exit__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2446

  columns: [id, function, args, expected]
  rows:
    - ["io2446009", "io.BytesIO.__dict__.__contains__",        ["__enter__"], false]
    - ["io2446010", "io.BytesIO.__dict__.__contains__",        ["__exit__"],  false]
    - ["io2446011", "io.StringIO.__dict__.__contains__",       ["__enter__"], false]
    - ["io2446012", "io.StringIO.__dict__.__contains__",       ["__exit__"],  false]
    - ["io2446013", "io.FileIO.__dict__.__contains__",         ["__enter__"], false]
    - ["io2446014", "io.FileIO.__dict__.__contains__",         ["__exit__"],  false]
    - ["io2446015", "io.BufferedReader.__dict__.__contains__", ["__enter__"], false]
    - ["io2446016", "io.BufferedReader.__dict__.__contains__", ["__exit__"],  false]
    - ["io2446017", "io.TextIOWrapper.__dict__.__contains__",  ["__enter__"], false]
    - ["io2446018", "io.TextIOWrapper.__dict__.__contains__",  ["__exit__"],  false]

# ---------------------------------------------------------------------------
# Complementary: methods that ARE in concrete class __dict__
# ---------------------------------------------------------------------------

table io_extra2446.concrete_class_own_methods:
  description: "Own methods that ARE present in concrete io class __dict__ (not inherited from base)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2446

  columns: [id, function, args, expected]
  rows:
    - ["io2446019", "io.BytesIO.__dict__.__contains__",       ["read"],     true]
    - ["io2446020", "io.BytesIO.__dict__.__contains__",       ["write"],    true]
    - ["io2446021", "io.BytesIO.__dict__.__contains__",       ["getvalue"], true]
    - ["io2446022", "io.FileIO.__dict__.__contains__",        ["read"],     true]
    - ["io2446023", "io.FileIO.__dict__.__contains__",        ["write"],    true]
    - ["io2446024", "io.FileIO.__dict__.__contains__",        ["mode"],     true]
    - ["io2446025", "io.TextIOWrapper.__dict__.__contains__", ["encoding"], true]
