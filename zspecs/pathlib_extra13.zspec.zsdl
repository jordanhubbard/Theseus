spec: pathlib_extra13
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra12.zspec.zsdl."
    - "pathlib_extra12 covers parts.__len__, parts[0], parents.__len__, with_suffix strip/add, joinpath single/multi, match wildcard true/false, suffixes.__len__, suffixes[0]."
    - "pathlib_extra11 covers PosixPath/WindowsPath __name__/__module__, PurePath.__module__, Path/__bases__ hierarchy, PurePosixPath/PureWindowsPath __bases__.__len__."
    - "pathlib_extra10 covers with_stem, is_relative_to, __str__/as_posix on /usr/local/bin, with_name behavioral vector."
    - "NOT yet covered: PurePosixPath.stem on a path without suffix."
    - "NOT yet covered: PurePosixPath.drive on a POSIX path (always empty string)."
    - "NOT yet covered: PurePosixPath.anchor on a relative path (empty string)."
    - "NOT yet covered: PurePosixPath.parts.__len__ for a relative path."
    - "NOT yet covered: PurePosixPath.joinpath with an absolute component (resets to that component)."
    - "NOT yet covered: PurePosixPath.relative_to on a two-level ancestor."
    - "NOT yet covered: PurePosixPath.name on a path with no directory."
    - "NOT yet covered: PurePosixPath.__truediv__ (the / operator) as a value test."
    - "PurePosixPath('plain').stem == 'plain' — bare filename without suffix."
    - "PurePosixPath('/a/b').drive == '' — POSIX paths have no drive letter."
    - "PurePosixPath('a/b').anchor == '' — relative paths have no anchor."
    - "PurePosixPath('a/b/c').parts.__len__() == 3 — ('a', 'b', 'c')."
    - "PurePosixPath('/a/b').joinpath('/c').__str__() == '/c' — absolute arg resets path."
    - "PurePosixPath('/a/b/c/d').relative_to('/a/b').__str__() == 'c/d'."
    - "PurePosixPath('hello.py').name == 'hello.py' — bare filename."
    - "str(PurePosixPath('/a/b') / 'c') == '/a/b/c' — __truediv__ joins path."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath.stem — bare filename without extension
#
# pathlib.zspec.zsdl covers .stem for 'archive.tar.gz' == 'archive.tar'.
# This adds a bare filename without any suffix: 'plain'.stem == 'plain'.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.stem_no_suffix:
  description: "pathlib.PurePosixPath('plain').stem == 'plain' — bare filename without extension"
  category: stem
  kind: python_call_eq
  function: PurePosixPath
  args: ["plain"]
  method: stem
  expected: "plain"

# ---------------------------------------------------------------------------
# PurePosixPath.drive — always empty string on POSIX
#
# On POSIX systems, paths have no drive letter. drive is always ''.
# pathlib_extra9 covers .drive for /a/b/c and /a/b/c.txt but only as part
# of a broader attributes table — no standalone invariant for drive == ''.
# This adds a drive-focused standalone invariant.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.drive_empty:
  description: "pathlib.PurePosixPath('/a/b').drive == '' — POSIX paths have no drive letter"
  category: drive
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: drive
  expected: ""

# ---------------------------------------------------------------------------
# PurePosixPath.anchor — empty string for relative paths
#
# The anchor is the drive + root combined. For relative paths both are empty.
# pathlib_extra9 covers anchor for absolute paths ('/a/b/c').
# This adds a relative path where anchor is ''.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.anchor_relative:
  description: "pathlib.PurePosixPath('a/b').anchor == '' — relative path has no anchor"
  category: anchor
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b"]
  method: anchor
  expected: ""

# ---------------------------------------------------------------------------
# PurePosixPath.parts — length of a relative (no-root) path
#
# pathlib_extra12 covers parts.__len__ for '/a/b/c' == 4 (root counts as part).
# A relative path 'a/b/c' has 3 parts and no root component.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.parts_relative_len:
  description: "pathlib.PurePosixPath('a/b/c').parts.__len__() == 3 — relative path, no root component"
  category: parts
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b/c"]
  method: parts.__len__
  expected: 3

# ---------------------------------------------------------------------------
# PurePosixPath.joinpath — absolute component resets path
#
# pathlib_extra12 covers joinpath with relative components.
# When joinpath receives an absolute component, the result is reset to that
# component alone — exactly mirroring os.path.join behaviour.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.joinpath_absolute_reset:
  description: "str(pathlib.PurePosixPath('/a/b').joinpath('/c')) == '/c' — absolute arg resets the path"
  category: joinpath
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: joinpath
  method_args: ["/c"]
  expected: "/c"

# ---------------------------------------------------------------------------
# PurePosixPath.relative_to — two-level ancestor
#
# pathlib.zspec.zsdl covers relative_to('/etc') for '/etc/passwd' == 'passwd'.
# This adds a deeper path: '/a/b/c/d'.relative_to('/a/b') == 'c/d'.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.relative_to_two_levels:
  description: "str(pathlib.PurePosixPath('/a/b/c/d').relative_to('/a/b')) == 'c/d'"
  category: relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c/d"]
  method: relative_to
  method_args: ["/a/b"]
  expected: "c/d"

# ---------------------------------------------------------------------------
# PurePosixPath.name — bare filename (no directory component)
#
# pathlib.zspec.zsdl covers .name for '/etc/passwd' == 'passwd'.
# This adds a path with no directory component: 'hello.py'.name == 'hello.py'.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.name_bare_file:
  description: "pathlib.PurePosixPath('hello.py').name == 'hello.py' — path with no directory component"
  category: name
  kind: python_call_eq
  function: PurePosixPath
  args: ["hello.py"]
  method: name
  expected: "hello.py"

# ---------------------------------------------------------------------------
# PurePosixPath.__truediv__ — the / operator as a value vector
#
# pathlib.zspec.zsdl covers __truediv__ for '/usr' / 'bin/python' == '/usr/bin/python'
# via method_chain: __str__. This spec adds a standalone value vector without
# method_chain, comparing the str() of the result directly via method: __str__.
# ---------------------------------------------------------------------------

invariant pathlib_extra13.PurePosixPath.truediv_simple:
  description: "str(pathlib.PurePosixPath('/a/b') / 'c') == '/a/b/c'"
  category: truediv
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: __truediv__
  method_args: ["c"]
  expected: "/a/b/c"

# ---------------------------------------------------------------------------
# Table: PurePosixPath suffix access on varied path inputs
#
# pathlib_extra12 covers suffixes.__len__ and suffixes[0] for 'c.tar.gz'.
# This table adds suffix access for a single-extension file and a dotfile.
# ---------------------------------------------------------------------------

table pathlib_extra13.suffix_access:
  kind: python_call_eq
  category: suffix
  id_prefix: suffix
  function: PurePosixPath

  columns: [id, args, method, expected]
  rows:
    - [single_ext,  ["/a/b/c.py"],   suffix,  ".py"]
    - [no_ext,      ["/a/b/c"],      suffix,  ""]
    - [dotfile,     [".hidden"],     suffix,  ""]
