spec: abc_extra211
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "A class with two @abc.abstractmethod methods has len(__abstractmethods__) == 2."
    - "__abstractmethods__ is a frozenset; __class__.__name__ == 'frozenset'."
    - "abc.ABC.__abstractmethods__ == frozenset() — ABC itself has no abstract methods."
    - "isinstance(abc.ABC, abc.ABCMeta) is True — ABC's metaclass is ABCMeta."
    - "abc.ABCMeta.register.__name__ == 'register'; __qualname__ == 'ABCMeta.register'."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty all exist (deprecated)."
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods'; __module__ == 'abc'."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.register identity — extra211 namespace
#
# ABCMeta.register is the class registration method; its __name__ is
# 'register' and its __qualname__ is 'ABCMeta.register'.
# ---------------------------------------------------------------------------

table abc_extra211.ABCMeta_register_identity:
  description: "abc.ABCMeta.register __name__ and __qualname__ checks in extra211 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc211regident

  columns: [id, function, args, expected, description]
  rows:
    - [register_name,     ABCMeta.register.__name__.__eq__,     ["register"],          true,  "abc.ABCMeta.register.__name__ == 'register'"]
    - [register_qualname, ABCMeta.register.__qualname__.__eq__,  ["ABCMeta.register"],  true,  "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'"]

# ---------------------------------------------------------------------------
# abc deprecated decorator names — extra211 namespace
#
# abstractclassmethod, abstractstaticmethod, and abstractproperty are
# deprecated but still present; their __name__ attributes equal the class name.
# ---------------------------------------------------------------------------

table abc_extra211.deprecated_decorator_names:
  description: "abc deprecated decorator __name__ checks in extra211 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc211depname

  columns: [id, function, args, expected, description]
  rows:
    - [abstractclassmethod_name,  abstractclassmethod.__name__.__eq__,  ["abstractclassmethod"],  true,  "abc.abstractclassmethod.__name__ == 'abstractclassmethod'"]
    - [abstractstaticmethod_name, abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true,  "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod'"]
    - [abstractproperty_name,     abstractproperty.__name__.__eq__,     ["abstractproperty"],     true,  "abc.abstractproperty.__name__ == 'abstractproperty'"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods identity — extra211 namespace
#
# update_abstractmethods is a top-level function added in Python 3.10.
# Its __name__, __qualname__, and __module__ are all straightforward.
# ---------------------------------------------------------------------------

table abc_extra211.update_abstractmethods_identity:
  description: "abc.update_abstractmethods __name__, __qualname__, __module__ checks in extra211 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc211updabc

  columns: [id, function, args, expected, description]
  rows:
    - [updabc_name,     update_abstractmethods.__name__.__eq__,     ["update_abstractmethods"],  true,  "abc.update_abstractmethods.__name__ == 'update_abstractmethods'"]
    - [updabc_qualname, update_abstractmethods.__qualname__.__eq__,  ["update_abstractmethods"],  true,  "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'"]
    - [updabc_module,   update_abstractmethods.__module__.__eq__,    ["abc"],                     true,  "abc.update_abstractmethods.__module__ == 'abc'"]

# ---------------------------------------------------------------------------
# abc.ABC metaclass and abstractmethods — extra211 namespace
#
# abc.ABC uses ABCMeta as its metaclass, so isinstance(abc.ABC, abc.ABCMeta)
# is True. abc.ABC itself defines no abstract methods, so __abstractmethods__
# is an empty frozenset.
# ---------------------------------------------------------------------------

table abc_extra211.ABC_metaclass:
  description: "abc.ABC metaclass and abstractmethods attribute checks in extra211 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc211abcmeta

  columns: [id, function, args, expected, description]
  rows:
    - [abc_class_name,    ABC.__class__.__name__.__eq__,               ["ABCMeta"],   true,  "abc.ABC.__class__.__name__ == 'ABCMeta' — metaclass is ABCMeta"]
    - [abc_absmethods_class, ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'"]
    - [abc_absmethods_len, ABC.__abstractmethods__.__len__,             [],            0,     "len(abc.ABC.__abstractmethods__) == 0 — ABC has no abstract methods"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra211 namespace
# ---------------------------------------------------------------------------

invariant abc_extra211.ABCMeta_register_name:
  description: "abc.ABCMeta.register.__name__ == 'register'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__name__.__eq__
  args: ["register"]
  expected: true

invariant abc_extra211.ABCMeta_register_qualname:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra211.update_abstractmethods_module:
  description: "abc.update_abstractmethods.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra211.ABC_abstractmethods_empty:
  description: "abc.ABC.__abstractmethods__.__len__() == 0 — ABC defines no abstract methods"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__abstractmethods__.__len__
  args: []
  expected: 0

invariant abc_extra211.abstractproperty_name:
  description: "abc.abstractproperty.__name__ == 'abstractproperty'"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__name__.__eq__
  args: ["abstractproperty"]
  expected: true

