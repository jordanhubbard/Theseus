spec: sqlite3_extra3
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified by running Python 3.12 sqlite3 module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sqlite/"
    - "SQLite source: sqlite3.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl, sqlite3_extra.zspec.zsdl, and sqlite3_extra2.zspec.zsdl."
    - "sqlite3.zspec.zsdl covers: complete_statement(), roundtrip SQL tests, error on non-string."
    - "sqlite3_extra.zspec.zsdl covers: Connection/__name__/__module__, Cursor/__name__, Row/__name__, Error/__name__, DatabaseError/__name__, OperationalError/__name__, IntegrityError/__name__, ProgrammingError/__name__, DataError/__name__, DatabaseError->Error hierarchy, OperationalError->DatabaseError hierarchy, sqlite_version/__class__/__name__ == 'str', version/__class__/__name__ == 'str', threadsafety/__class__/__name__ == 'int'."
    - "sqlite3_extra2.zspec.zsdl covers: Connection/__name__, Cursor/__name__, Row/__name__, Error/__name__, DatabaseError/__name__, OperationalError/__name__, Error.__bases__[0].__name__ == 'Exception', sqlite_version class, threadsafety class."
    - "This spec adds: __module__ for Cursor, Row, Error, DatabaseError, OperationalError, IntegrityError, ProgrammingError, InterfaceError; InterfaceError/__name__, NotSupportedError/__name__; sqlite_version_info type check; apilevel value and type; paramstyle value and type; threadsafety value bounds; IntegrityError and ProgrammingError hierarchy."
    - "sqlite3.apilevel == '2.0' — DB-API 2.0 compliant."
    - "sqlite3.paramstyle == 'qmark' — uses ? placeholders."
    - "sqlite3.threadsafety is in {0, 1, 2, 3}; the standard CPython value is 1."
    - "sqlite3.sqlite_version_info is a tuple of three ints."
    - "sqlite3.InterfaceError is a subclass of sqlite3.Error."
    - "sqlite3.NotSupportedError is a subclass of sqlite3.DatabaseError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for classes not yet covered by sqlite3_extra or sqlite3_extra2
# sqlite3_extra covers Connection.__module__; this spec covers the rest.
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.Cursor.module:
  description: "sqlite3.Cursor.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: Cursor.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.Row.module:
  description: "sqlite3.Row.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: Row.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.Error.module:
  description: "sqlite3.Error.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.DatabaseError.module:
  description: "sqlite3.DatabaseError.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: DatabaseError.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.OperationalError.module:
  description: "sqlite3.OperationalError.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: OperationalError.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.IntegrityError.module:
  description: "sqlite3.IntegrityError.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: IntegrityError.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.ProgrammingError.module:
  description: "sqlite3.ProgrammingError.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: ProgrammingError.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# InterfaceError and NotSupportedError — class names not in previous specs
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.InterfaceError.name:
  description: "sqlite3.InterfaceError.__name__ == 'InterfaceError'"
  category: class_names
  kind: python_call_eq
  function: InterfaceError.__name__.__eq__
  args: ["InterfaceError"]
  expected: true

invariant sqlite3_extra3.InterfaceError.module:
  description: "sqlite3.InterfaceError.__module__ == 'sqlite3'"
  category: class_modules
  kind: python_call_eq
  function: InterfaceError.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra3.NotSupportedError.name:
  description: "sqlite3.NotSupportedError.__name__ == 'NotSupportedError'"
  category: class_names
  kind: python_call_eq
  function: NotSupportedError.__name__.__eq__
  args: ["NotSupportedError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — IntegrityError, ProgrammingError, InterfaceError,
# NotSupportedError base classes (not yet covered by previous specs)
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.IntegrityError.base_is_DatabaseError:
  description: "sqlite3.IntegrityError.__bases__[0].__name__ == 'DatabaseError'"
  category: class_hierarchy
  kind: python_call_eq
  function: IntegrityError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DatabaseError"

invariant sqlite3_extra3.ProgrammingError.base_is_DatabaseError:
  description: "sqlite3.ProgrammingError.__bases__[0].__name__ == 'DatabaseError'"
  category: class_hierarchy
  kind: python_call_eq
  function: ProgrammingError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DatabaseError"

invariant sqlite3_extra3.InterfaceError.base_is_Error:
  description: "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error'"
  category: class_hierarchy
  kind: python_call_eq
  function: InterfaceError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant sqlite3_extra3.NotSupportedError.base_is_DatabaseError:
  description: "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError'"
  category: class_hierarchy
  kind: python_call_eq
  function: NotSupportedError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DatabaseError"

# ---------------------------------------------------------------------------
# sqlite_version_info — tuple of three ints
# (sqlite3_extra checks sqlite_version str type; this checks the _info tuple)
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.sqlite_version_info.class_is_tuple:
  description: "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: sqlite_version_info.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# apilevel — DB-API 2.0 constant
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.apilevel.value:
  description: "sqlite3.apilevel == '2.0' — DB-API 2.0 compliance string"
  category: constants
  kind: python_call_eq
  function: apilevel.__eq__
  args: ["2.0"]
  expected: true

invariant sqlite3_extra3.apilevel.class_is_str:
  description: "sqlite3.apilevel.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: apilevel.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# paramstyle — DB-API 2.0 parameter style constant
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.paramstyle.value:
  description: "sqlite3.paramstyle == 'qmark' — uses ? placeholders"
  category: constants
  kind: python_call_eq
  function: paramstyle.__eq__
  args: ["qmark"]
  expected: true

invariant sqlite3_extra3.paramstyle.class_is_str:
  description: "sqlite3.paramstyle.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: paramstyle.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# threadsafety — value bound check (must be >= 0)
# (sqlite3_extra already checks __class__.__name__ == 'int'; this adds value check)
# ---------------------------------------------------------------------------

invariant sqlite3_extra3.threadsafety.gte_zero:
  description: "sqlite3.threadsafety >= 0 — valid DB-API 2.0 thread safety level"
  category: constants
  kind: python_call_eq
  function: threadsafety.__ge__
  args: [0]
  expected: true

invariant sqlite3_extra3.threadsafety.lte_three:
  description: "sqlite3.threadsafety <= 3 — valid DB-API 2.0 thread safety level (max is 3)"
  category: constants
  kind: python_call_eq
  function: threadsafety.__le__
  args: [3]
  expected: true
