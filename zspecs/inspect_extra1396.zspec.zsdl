spec: inspect_extra1396
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence for inspect classes."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments do NOT define __class_getitem__ in their __dict__."
    - "None of these classes have generic alias support via __class_getitem__; they are not designed to be used as generic types."
    - "No inspect class defines __init_subclass__ in its __dict__; all inherit it from object as a builtin_function_or_method."
    - "All class __dict__ attributes are mappingproxy instances for these pure Python inspect classes."
    - "The absence of __class_getitem__ distinguishes inspect classes from classes like functools.partial that support generic syntax."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1396.class_getitem_not_in_dict:
  description: "inspect.Parameter, Signature, and BoundArguments do not define __class_getitem__ in their __dict__; these classes have no generic alias support"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: in1396cg
  columns: [id, function, args, expected]
  rows:
    - [in1396cg001, inspect.Parameter.__dict__.__contains__,      ["__class_getitem__"], false]
    - [in1396cg002, inspect.Signature.__dict__.__contains__,      ["__class_getitem__"], false]
    - [in1396cg003, inspect.BoundArguments.__dict__.__contains__, ["__class_getitem__"], false]
    - [in1396cg004, inspect.Parameter.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [in1396cg005, inspect.Signature.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [in1396cg006, inspect.BoundArguments.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table inspect_extra1396.init_subclass_not_in_dict:
  description: "inspect.Parameter, Signature, and BoundArguments do not define __init_subclass__ in their __dict__; all inherit it from object and it resolves to builtin_function_or_method"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: in1396is
  columns: [id, function, args, expected]
  rows:
    - [in1396is001, inspect.Parameter.__dict__.__contains__,      ["__init_subclass__"], false]
    - [in1396is002, inspect.Signature.__dict__.__contains__,      ["__init_subclass__"], false]
    - [in1396is003, inspect.BoundArguments.__dict__.__contains__, ["__init_subclass__"], false]
    - [in1396is004, inspect.Parameter.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [in1396is005, inspect.Signature.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [in1396is006, inspect.BoundArguments.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table inspect_extra1396.class_getitem_init_subclass_cross_check:
  description: "Cross-check: neither __class_getitem__ nor __init_subclass__ appears in any of the three inspect classes' __dict__; mappingproxy confirmed for all"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: in1396xc
  columns: [id, function, args, expected]
  rows:
    - [in1396xc001, inspect.Parameter.__dict__.__contains__,      ["__class_getitem__"], false]
    - [in1396xc002, inspect.Parameter.__dict__.__contains__,      ["__init_subclass__"], false]
    - [in1396xc003, inspect.Signature.__dict__.__contains__,      ["__class_getitem__"], false]
    - [in1396xc004, inspect.Signature.__dict__.__contains__,      ["__init_subclass__"], false]
    - [in1396xc005, inspect.BoundArguments.__dict__.__contains__, ["__class_getitem__"], false]
    - [in1396xc006, inspect.BoundArguments.__dict__.__contains__, ["__init_subclass__"], false]
    - [in1396xc007, inspect.Parameter.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [in1396xc008, inspect.BoundArguments.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
