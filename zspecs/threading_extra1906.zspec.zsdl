spec: threading_extra1906
version: ">=3.9"
backend: python_module(threading)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 574: __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "threading.Thread is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "threading.Event is a Python class; its __dict__ does not contain __reversed__ or __match_args__."
    - "threading.Condition is a Python class; its __dict__ does not contain __reversed__ or __match_args__."
    - "threading.Semaphore is a Python class; its __dict__ does not contain __reversed__ or __match_args__."
    - "threading.Barrier is a Python class; its __dict__ does not contain __reversed__ or __match_args__."
    - "threading.local is a C-level type; its __dict__ does not contain __reversed__ or __match_args__."
    - "threading.Timer is a Python class (subclass of Thread); its __dict__ does not contain __reversed__ or __match_args__."
    - "threading.BoundedSemaphore is a Python class (subclass of Semaphore); its __dict__ does not contain __match_args__."
    - "threading.Thread.__qualname__ == 'Thread' — top-level Python class."
    - "threading.Event.__qualname__ == 'Event' — top-level Python class."
    - "threading.Condition.__qualname__ == 'Condition' — top-level Python class."
    - "threading.Semaphore.__qualname__ == 'Semaphore' — top-level Python class."
    - "threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level Python class."
    - "threading.Timer.__qualname__ == 'Timer' — top-level Python class."
    - "threading.Barrier.__qualname__ == 'Barrier' — top-level Python class."
    - "threading.local.__qualname__ == 'local' — C-level type."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

