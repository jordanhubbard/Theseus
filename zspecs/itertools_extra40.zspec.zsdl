spec: itertools_extra40
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra39.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all; __dict__.__class__.__name__.__len__()==12 for all; chain.from_iterable.__name__.__len__()==13; __doc__ lengths for all major types; list(repeat(7, 3))==[7,7,7]; next(dropwhile(...)) behavioral; groupby.__name__/'groupby'; groupby.__qualname__/'groupby'; compress.__name__/'compress'; compress.__qualname__/'compress'; dropwhile.__name__/'dropwhile'; takewhile.__name__/'takewhile'; starmap.__name__/'starmap'; filterfalse.__name__/'filterfalse'; __name__.__len__() for groupby(7)/compress(8)/dropwhile(9)/takewhile(9)/starmap(7)/filterfalse(11)."
    - "This spec covers: chain.__name__ == 'chain'; chain.__qualname__ == 'chain'; chain.from_iterable.__qualname__ == 'chain.from_iterable'; chain.from_iterable.__qualname__.__len__() == 19; zip_longest.__name__ == 'zip_longest'; zip_longest.__qualname__ == 'zip_longest'; islice.__name__ == 'islice'; islice.__qualname__ == 'islice'; accumulate.__name__ == 'accumulate'; accumulate.__qualname__ == 'accumulate'."
    - "Key findings: itertools.chain.__name__ is 'chain' (5 chars) and itertools.chain.__qualname__ is 'chain' (5 chars) — for all itertools C-extension types, __qualname__ == __name__ because they are top-level type definitions. itertools.chain.from_iterable.__qualname__ is 'chain.from_iterable' (19 chars) — the only itertools attribute with a dotted __qualname__ because from_iterable is a classmethod descriptor nested inside chain. itertools.zip_longest.__name__ and __qualname__ are both 'zip_longest' (11 chars). itertools.islice.__name__ and __qualname__ are both 'islice' (6 chars). itertools.accumulate.__name__ and __qualname__ are both 'accumulate' (10 chars). In all cases __qualname__ == __name__ for these top-level C types. Prior specs recorded __qualname__.__len__() for all of these, but not the string equality invariants for __name__ or __qualname__, nor the string equality for chain.from_iterable.__qualname__. No prior itertools spec records these equality invariants in the extra40 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain identity metadata — extra40 namespace
#
# itertools.chain.__name__ is 'chain' (5 chars) and itertools.chain.__qualname__
# is 'chain' (5 chars). As a top-level C-extension type in itertoolsmodule.c,
# __qualname__ equals __name__ because there is no enclosing class scope.
# Prior specs recorded chain.__qualname__.__len__() values but not the string
# equality invariants for __name__ or __qualname__. These two equality invariants
# are new to the extra40 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra40.chain_name:
  description: "itertools.chain.__name__ == 'chain' — C-extension type; 5-char name; the only itertools type that exposes a classmethod (from_iterable) as a direct attribute"
  category: identity
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra40.chain_qualname:
  description: "itertools.chain.__qualname__ == 'chain' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 5 chars"
  category: identity
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

# ---------------------------------------------------------------------------
# itertools.chain.from_iterable __qualname__ — extra40 namespace
#
# itertools.chain.from_iterable.__qualname__ is 'chain.from_iterable' (19 chars).
# This is the only itertools attribute with a dotted __qualname__ because
# from_iterable is a classmethod descriptor defined inside the chain C type.
# The qualname reflects the enclosing type: 'chain.' (6 chars) + 'from_iterable'
# (13 chars) = 19 chars total. Prior specs recorded chain.from_iterable.__name__
# .__len__()==13 but not the full __qualname__ string equality or its __len__().
# These two invariants are new to the extra40 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra40.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — classmethod nested inside chain C type; dotted qualname; 19 chars (6+'.'(1)+13)"
  category: identity
  kind: python_call_eq
  function: "chain.from_iterable.__qualname__.__eq__"
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra40.chain_from_iterable_qualname_len:
  description: "len(itertools.chain.from_iterable.__qualname__) == 19 — 'chain.from_iterable'; 6-char 'chain' + '.' + 13-char 'from_iterable'; the only dotted __qualname__ in itertools"
  category: string_properties
  kind: python_call_eq
  function: "chain.from_iterable.__qualname__.__len__"
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# itertools type __name__ and __qualname__ string equality — extra40 namespace
#
# itertools.zip_longest.__name__ and __qualname__ are both 'zip_longest' (11
# chars). itertools.islice.__name__ and __qualname__ are both 'islice' (6 chars).
# itertools.accumulate.__name__ and __qualname__ are both 'accumulate' (10 chars).
# For all itertools C-extension types, __qualname__ == __name__ because they are
# top-level type definitions with no enclosing class scope. Prior specs recorded
# __qualname__.__len__() for all three, but not the string equality invariants.
# These six equality invariants (two per type) are new to the extra40 namespace.
# ---------------------------------------------------------------------------

table itertools_extra40.type_name_qualname_equality:
  description: "itertools C-type __name__ and __qualname__ string equality: zip_longest, islice, accumulate — all have __qualname__ == __name__"
  kind: python_call_eq
  category: identity
  id_prefix: tnqeq40

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_name,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__ == 'zip_longest' — C-extension type; 11-char name; same as filterfalse.__len__()-0; handles unequal-length iterables with a fillvalue"]
    - [zip_longest_qualname,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__ == 'zip_longest' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 11 chars"]
    - [islice_name,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__ == 'islice' — C-extension type; 6-char name; iterator equivalent of sequence slicing"]
    - [islice_qualname,
       islice.__qualname__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__qualname__ == 'islice' — top-level C type; __qualname__ == __name__; 6 chars; same length as chain.__name__"]
    - [accumulate_name,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__ == 'accumulate' — C-extension type; 10-char name; running totals / prefix sums"]
    - [accumulate_qualname,
       accumulate.__qualname__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__ == 'accumulate' — top-level C type; __qualname__ == __name__; 10 chars"]
