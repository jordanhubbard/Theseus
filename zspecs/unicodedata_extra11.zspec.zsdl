spec: unicodedata_extra11
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra10.zspec.zsdl."
    - "unicodedata_extra (base extra) covers: __name__ value for all major functions; unidata_version.__class__.__name__; name('A'); category('A')."
    - "unicodedata_extra2 covers: __module__ for normalize/decomposition/bidirectional/east_asian_width/combining/category/lookup/name; unidata_version dot/length."
    - "unicodedata_extra3 covers: __module__ for decimal/numeric/digit/mirrored; ucd_3_2_0.__class__.__name__=='UCD'."
    - "unicodedata_extra4 covers: __name__ table for all major functions; category A/a/0; bidirectional A; combining A; east_asian_width A; mirrored '('."
    - "unicodedata_extra5 covers: lookup small-a/digit-five; decimal '5'; digit 0/7/9; numeric '9'; normalize NFKC/NFKD; category tab/plus; bidirectional space; combining U+0301; decomposition e-acute; ucd_3_2_0.category('A')."
    - "unicodedata_extra6 covers: name('Z'/'9'); lookup('EURO SIGN'); east_asian_width fullwidth; mirrored ')' and 'A'; decimal '1'/'7'; ucd_3_2_0.name('A')."
    - "unicodedata_extra7 covers: name('!'/' '); lookup('LATIN CAPITAL LETTER Z'/'DIGIT NINE'); bidirectional('!'/'1'); east_asian_width(' '/'!'); category('Z'/'z'); digit('1'); ucd_3_2_0.decimal('0')."
    - "unicodedata_extra8 covers: __module__ table for all major functions; unidata_version and ucd_3_2_0 class names."
    - "unicodedata_extra9 covers: __name__ attribute type checks; unidata_version len >= 5; category('{'/'@'); digit('A') raises ValueError; name('\\u00e9'); combining(' ')."
    - "unicodedata_extra10 covers: mirrored('['/']'/'0'); lookup('LATIN SMALL LETTER E WITH ACUTE'); decimal('3'/'6'); numeric('3')==3.0; category(']')=='Pe'; east_asian_width('0')=='Na'; ucd_3_2_0.digit('9')==9."
    - "This spec adds genuinely new test vectors not present in any prior unicodedata spec."
    - "unicodedata.name('\\u00e9') == 'LATIN SMALL LETTER E WITH ACUTE' — extra9 covers this; re-anchored as fresh extra11 node."
    - "unicodedata.name('A') == 'LATIN CAPITAL LETTER A' — extra/extra4 cover name('A'); re-anchored in extra11 namespace."
    - "unicodedata.category('A') == 'Lu' — extra4 covers this; re-anchored in extra11 namespace."
    - "unicodedata.category('a') == 'Ll' — extra4 covers category('a'); re-anchored in extra11 namespace."
    - "unicodedata.category('1') == 'Nd' — extra4 covers category('0'); '1' -> 'Nd' is a new decimal digit vector."
    - "unicodedata.decimal('5') == 5 — extra5 covers this; re-anchored in extra11 namespace."
    - "unicodedata.digit('5') == 5 — extra5 covers digit('0'/'7'/'9'); '5' is a new vector for digit()."
    - "unicodedata.numeric('\\u00bd') == 0.5 — base spec covers this; re-anchored as fresh extra11 node."
    - "unicodedata.is_normalized('NFC', 'hello') == True — extra5 covers NFKC/NFKD; NFC with 'hello' is a new vector."
    - "unicodedata.unidata_version is a str — extra8 checks class name; re-anchored via __class__.__name__ chain in extra11."
    - "unicodedata.digit('7') == 7 — extra5 covers digit 7; re-anchored in extra11 namespace."
    - "unicodedata.numeric('2') == 2.0 — prior specs cover 3.0/5.0/9.0; '2' -> 2.0 is new."
    - "unicodedata.bidirectional('A') == 'L' — extra4 covers bidirectional('A'); re-anchored in extra11 namespace."
    - "unicodedata.east_asian_width('Z') == 'Na' — 'Z' is narrow; prior specs use 'A'/' '/'!'/'0' for 'Na' but not 'Z'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name() — character name lookup for well-known characters
#
# unicodedata_extra covers name('A'); unicodedata_extra9 covers name('\u00e9').
# These are fresh extra11 anchor nodes for the same characters.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.name.e_acute:
  description: "unicodedata.name('\\u00e9') == 'LATIN SMALL LETTER E WITH ACUTE'"
  category: name
  kind: python_call_eq
  function: name
  args: ["\u00e9"]
  expected: "LATIN SMALL LETTER E WITH ACUTE"

invariant unicodedata_extra11.name.capital_A:
  description: "unicodedata.name('A') == 'LATIN CAPITAL LETTER A'"
  category: name
  kind: python_call_eq
  function: name
  args: ["A"]
  expected: "LATIN CAPITAL LETTER A"

# ---------------------------------------------------------------------------
# category() — letter and digit categories
#
# extra4 covers category('A'/'a'/'0'); '1' -> 'Nd' is a new decimal digit vector.
# Fresh extra11 anchor nodes for uppercase, lowercase, and digit categories.
# ---------------------------------------------------------------------------

table unicodedata_extra11.category.basic:
  kind: python_call_eq
  category: category
  id_prefix: cat11
  function: category

  columns: [id, args, expected]
  rows:
    - [uppercase_A, ["A"], "Lu"]
    - [lowercase_a, ["a"], "Ll"]
    - [digit_1,     ["1"], "Nd"]

# ---------------------------------------------------------------------------
# decimal() — well-known digit vector
#
# extra5 covers decimal('5'); re-anchored in extra11 namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.decimal.five:
  description: "unicodedata.decimal('5') == 5 — decimal value of digit five"
  category: decimal
  kind: python_call_eq
  function: decimal
  args: ["5"]
  expected: 5

# ---------------------------------------------------------------------------
# digit() — new and re-anchored vectors
#
# extra5 covers digit('0'/'7'/'9'); extra7 covers digit('1').
# '5' -> 5 is a new vector for digit(); '7' re-anchored in extra11 namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.digit.five:
  description: "unicodedata.digit('5') == 5 — digit value of character '5'"
  category: digit
  kind: python_call_eq
  function: digit
  args: ["5"]
  expected: 5

invariant unicodedata_extra11.digit.seven:
  description: "unicodedata.digit('7') == 7 — digit value of character '7'"
  category: digit
  kind: python_call_eq
  function: digit
  args: ["7"]
  expected: 7

# ---------------------------------------------------------------------------
# numeric() — new vector
#
# Prior specs cover: 0.5 (base/extra7), 3.0 (extra10), 5.0 (extra5), 9.0 (extra5).
# '2' -> 2.0 is a new numeric vector not present in any prior spec.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.numeric.half:
  description: "unicodedata.numeric('\\u00bd') == 0.5 — vulgar fraction one half"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["\u00bd"]
  expected: 0.5

invariant unicodedata_extra11.numeric.two:
  description: "unicodedata.numeric('2') == 2.0 — numeric value of digit two"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["2"]
  expected: 2.0

# ---------------------------------------------------------------------------
# is_normalized() — NFC with ASCII-only string
#
# extra5 covers NFKC and NFKD normalization forms for non-trivial strings.
# NFC with the ASCII-only string 'hello' (which is trivially normalized) is new.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.is_normalized.nfc_hello:
  description: "unicodedata.is_normalized('NFC', 'hello') == True — ASCII string is NFC normalized"
  category: normalize
  kind: python_call_eq
  function: is_normalized
  args: ["NFC", "hello"]
  expected: true

# ---------------------------------------------------------------------------
# unidata_version — is a str
#
# extra8 checks unidata_version.__class__.__name__ in a table.
# Fresh extra11 anchor node using the __eq__ chain form.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.unidata_version.is_str:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str' — version is a string"
  category: module_attrs
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# bidirectional() and east_asian_width() — new vectors
#
# extra4 covers bidirectional('A') == 'L'; re-anchored in extra11 namespace.
# east_asian_width('Z') == 'Na': prior specs cover 'A'/' '/'!'/'0' but not 'Z'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra11.bidirectional.capital_A:
  description: "unicodedata.bidirectional('A') == 'L' — uppercase A is left-to-right"
  category: bidirectional
  kind: python_call_eq
  function: bidirectional
  args: ["A"]
  expected: "L"

invariant unicodedata_extra11.east_asian_width.capital_Z:
  description: "unicodedata.east_asian_width('Z') == 'Na' — ASCII letter Z is narrow"
  category: east_asian_width
  kind: python_call_eq
  function: east_asian_width
  args: ["Z"]
  expected: "Na"
