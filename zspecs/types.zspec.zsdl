spec: types
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "Python types documentation — https://docs.python.org/3/library/types.html"
    - "Test vectors verified by running Python 3.14.3 types module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "types.SimpleNamespace allows attribute assignment and access as a simple object."
    - "types.MappingProxyType is a read-only proxy of a mapping; item assignment raises TypeError."
    - "types.NoneType is the type of None (Python 3.10+)."
    - "types.LambdaType is an alias for types.FunctionType — both have __name__ == 'function'."
    - "types.UnionType.__name__ == 'Union' (the runtime type created by X | Y syntax, Python 3.10+)."
    - "types.CoroutineType.__name__ == 'coroutine'."
    - "types.AsyncGeneratorType.__name__ == 'async_generator'."
    - "SimpleNamespace stores attributes in __dict__; keyword args at construction become attributes."
    - "MappingProxyType wraps any mapping and provides read-only __getitem__, __len__, __contains__."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — __name__ attributes of built-in type objects
# ---------------------------------------------------------------------------

invariant types.functiontype.name:
  description: "types.FunctionType.__name__ == 'function'"
  category: class_names
  kind: python_call_eq
  function: FunctionType.__name__.__eq__
  args: ["function"]
  expected: true

invariant types.methodtype.name:
  description: "types.MethodType.__name__ == 'method'"
  category: class_names
  kind: python_call_eq
  function: MethodType.__name__.__eq__
  args: ["method"]
  expected: true

invariant types.moduletype.name:
  description: "types.ModuleType.__name__ == 'module'"
  category: class_names
  kind: python_call_eq
  function: ModuleType.__name__.__eq__
  args: ["module"]
  expected: true

invariant types.nonetype.name:
  description: "types.NoneType.__name__ == 'NoneType'"
  category: class_names
  kind: python_call_eq
  function: NoneType.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant types.generatortype.name:
  description: "types.GeneratorType.__name__ == 'generator'"
  category: class_names
  kind: python_call_eq
  function: GeneratorType.__name__.__eq__
  args: ["generator"]
  expected: true

invariant types.mappingproxytype.name:
  description: "types.MappingProxyType.__name__ == 'mappingproxy'"
  category: class_names
  kind: python_call_eq
  function: MappingProxyType.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant types.simplenamespace.class_name:
  description: "types.SimpleNamespace.__name__ == 'SimpleNamespace'"
  category: class_names
  kind: python_call_eq
  function: SimpleNamespace.__name__.__eq__
  args: ["SimpleNamespace"]
  expected: true

invariant types.lambdatype.name:
  description: "types.LambdaType.__name__ == 'function' (alias for FunctionType)"
  category: class_names
  kind: python_call_eq
  function: LambdaType.__name__.__eq__
  args: ["function"]
  expected: true

invariant types.coroutinetype.name:
  description: "types.CoroutineType.__name__ == 'coroutine'"
  category: class_names
  kind: python_call_eq
  function: CoroutineType.__name__.__eq__
  args: ["coroutine"]
  expected: true

invariant types.asyncgeneratortype.name:
  description: "types.AsyncGeneratorType.__name__ == 'async_generator'"
  category: class_names
  kind: python_call_eq
  function: AsyncGeneratorType.__name__.__eq__
  args: ["async_generator"]
  expected: true

invariant types.uniontype.name:
  description: "types.UnionType.__name__ == 'Union' (Python 3.10+)"
  category: class_names
  kind: python_call_eq
  function: UnionType.__name__.__eq__
  args: ["Union"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleNamespace — attribute access via keyword construction
#
# SimpleNamespace(**kwargs) stores kwargs as instance attributes.
# Attribute access is via __getattribute__; the harness uses method: attr_name
# to read instance attributes just like method calls that return a value.
# ---------------------------------------------------------------------------

invariant types.simplenamespace.int_attr:
  description: "types.SimpleNamespace(x=1).x == 1"
  category: simplenamespace
  kind: python_call_eq
  function: SimpleNamespace
  kwargs: {x: 1}
  method: x
  expected: 1

invariant types.simplenamespace.str_attr:
  description: "types.SimpleNamespace(y='hello').y == 'hello'"
  category: simplenamespace
  kind: python_call_eq
  function: SimpleNamespace
  kwargs: {y: "hello"}
  method: y
  expected: "hello"

invariant types.simplenamespace.bool_attr:
  description: "types.SimpleNamespace(flag=True).flag == True"
  category: simplenamespace
  kind: python_call_eq
  function: SimpleNamespace
  kwargs: {flag: true}
  method: flag
  expected: true

invariant types.simplenamespace.multi_attr_a:
  description: "types.SimpleNamespace(a=42, b=True).a == 42"
  category: simplenamespace
  kind: python_call_eq
  function: SimpleNamespace
  kwargs: {a: 42, b: true}
  method: a
  expected: 42

invariant types.simplenamespace.multi_attr_b:
  description: "types.SimpleNamespace(a=42, b=True).b == True"
  category: simplenamespace
  kind: python_call_eq
  function: SimpleNamespace
  kwargs: {a: 42, b: true}
  method: b
  expected: true

# ---------------------------------------------------------------------------
# MappingProxyType — read-only dict proxy
#
# MappingProxyType(mapping) wraps a dict in a read-only view.
# __getitem__, __len__, and __contains__ are all supported.
# Item assignment raises TypeError.
# ---------------------------------------------------------------------------

invariant types.mappingproxy.getitem_a:
  description: "types.MappingProxyType({'a':1,'b':2})['a'] == 1"
  category: mappingproxy
  kind: python_call_eq
  function: MappingProxyType
  args: [{"a": 1, "b": 2}]
  method: __getitem__
  method_args: ["a"]
  expected: 1

invariant types.mappingproxy.getitem_b:
  description: "types.MappingProxyType({'a':1,'b':2})['b'] == 2"
  category: mappingproxy
  kind: python_call_eq
  function: MappingProxyType
  args: [{"a": 1, "b": 2}]
  method: __getitem__
  method_args: ["b"]
  expected: 2

invariant types.mappingproxy.len:
  description: "len(types.MappingProxyType({'a':1,'b':2,'c':3})) == 3"
  category: mappingproxy
  kind: python_call_eq
  function: MappingProxyType
  args: [{"a": 1, "b": 2, "c": 3}]
  method: __len__
  expected: 3

invariant types.mappingproxy.contains_true:
  description: "types.MappingProxyType({'a':1}).__contains__('a') == True"
  category: mappingproxy
  kind: python_call_eq
  function: MappingProxyType
  args: [{"a": 1}]
  method: __contains__
  method_args: ["a"]
  expected: true

invariant types.mappingproxy.contains_false:
  description: "types.MappingProxyType({'a':1}).__contains__('z') == False"
  category: mappingproxy
  kind: python_call_eq
  function: MappingProxyType
  args: [{"a": 1}]
  method: __contains__
  method_args: ["z"]
  expected: false

invariant types.mappingproxy.len_empty:
  description: "len(types.MappingProxyType({})) == 0"
  category: mappingproxy
  kind: python_call_eq
  function: MappingProxyType
  args: [{}]
  method: __len__
  expected: 0
