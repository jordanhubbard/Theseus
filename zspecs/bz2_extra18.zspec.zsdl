spec: bz2_extra18
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra17.zspec.zsdl — covers BZ2File.__mro__[2]/__mro__[3]; BZ2Compressor/BZ2Decompressor/BZ2File __dict__ membership; BZ2Decompressor.__qualname__.__class__.__name__."
    - "bz2_extra16.zspec.zsdl — covers BZ2File.__init__/readable/writable/seekable __qualname__ (extra16); BZ2Compressor.compress/flush __qualname__ (extra16); BZ2Decompressor.decompress __qualname__ (extra16)."
    - "bz2_extra15.zspec.zsdl — covers BZ2File.read/write/seek/close __qualname__ (extra15); BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra15); open/compress/decompress __qualname__ (extra15 anchor)."
    - "bz2_extra11.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __module__ table (cmod11); compress/decompress __name__ standalone (extra11); class __qualname__ standalone (extra11)."
    - "bz2_extra8.zspec.zsdl — covers BZ2File.__mro__[1].__name__ == 'BaseStream' (method_chain form)."
    - "bz2_extra7.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __module__ and open/compress/decompress __module__ standalone; BZ2File.__bases__[0].__name__ == 'BaseStream' (string-return form)."
    - "bz2_extra6.zspec.zsdl — covers BZ2Compressor/__bases__[0].__name__ == 'object'; BZ2Decompressor/__bases__[0].__name__ == 'object'."
    - "bz2_extra5.zspec.zsdl — covers BZ2File.__bases__[0].__name__ == 'BaseStream' (bool form)."
    - "bz2_extra2.zspec.zsdl — covers BZ2File.read/__name__, BZ2File.write/__name__, BZ2File.close/__name__ in a method names table."
  notes:
    - "This spec extends bz2 through bz2_extra17; it does NOT duplicate invariants present in those files."
    - "Focus: BZ2File.tell/peek/readline/read1/readinto __qualname__ (novel method qualnames not covered by extra15 or extra16); BZ2File.__mro__[4]/__mro__[5] (novel MRO invariants beyond extra17's mro[2]/mro[3]); BZ2Decompressor.__dict__ property membership for eof/needs_input/unused_data (novel __dict__ checks not covered by extra17); bz2.__loader__.__class__.__name__ and bz2.__spec__.__class__.__name__ (novel loader/spec type invariants)."
    - "BZ2File.tell.__qualname__ == 'BZ2File.tell': tell is defined directly on BZ2File. No prior bz2 spec checks this qualname. Verified 2026-04-09."
    - "BZ2File.peek.__qualname__ == 'BZ2File.peek': peek is defined directly on BZ2File. No prior bz2 spec checks this qualname. Verified 2026-04-09."
    - "BZ2File.readline.__qualname__ == 'BZ2File.readline': readline is defined directly on BZ2File. No prior bz2 spec checks this qualname. Verified 2026-04-09."
    - "BZ2File.read1.__qualname__ == 'BZ2File.read1': read1 is defined directly on BZ2File. No prior bz2 spec checks this qualname. Verified 2026-04-09."
    - "BZ2File.readinto.__qualname__ == 'BZ2File.readinto': readinto is defined directly on BZ2File. No prior bz2 spec checks this qualname. Verified 2026-04-09."
    - "BZ2File.__mro__[4].__name__ == 'IOBase': extra17 covers mro[2] and mro[3]; mro[4] is IOBase. No prior bz2 spec checks mro[4]. Verified 2026-04-09."
    - "BZ2File.__mro__[5].__name__ == '_IOBase': fifth entry in MRO is the C-level _IOBase. No prior bz2 spec checks mro[5]. Verified 2026-04-09."
    - "'eof' in BZ2Decompressor.__dict__: BZ2Decompressor exposes eof as a member_descriptor in its own __dict__. extra17 covers compress/flush/decompress/read/write dict membership; eof is novel. Verified 2026-04-09."
    - "'needs_input' in BZ2Decompressor.__dict__: BZ2Decompressor exposes needs_input in its __dict__. Novel relative to extra17. Verified 2026-04-09."
    - "'unused_data' in BZ2Decompressor.__dict__: BZ2Decompressor exposes unused_data in its __dict__. Novel relative to extra17. Verified 2026-04-09."
    - "bz2.__loader__.__class__.__name__ == 'SourceFileLoader': bz2 is a pure-Python module. No prior bz2 spec checks this. Verified 2026-04-09."
    - "bz2.__spec__.__class__.__name__ == 'ModuleSpec': import system attaches a ModuleSpec to every module. No prior bz2 spec checks this. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.tell __qualname__ — novel, extra18 anchor
#
# No prior bz2 spec checks BZ2File.tell.__qualname__. tell is defined directly
# on BZ2File in Lib/bz2.py. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.tell.qualname:
  description: "bz2.BZ2File.tell.__qualname__ == 'BZ2File.tell' — method qualname encodes class context (extra18)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.tell.__qualname__.__eq__
  args: ["BZ2File.tell"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.peek __qualname__ — novel, extra18 anchor
#
# No prior bz2 spec checks BZ2File.peek.__qualname__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.peek.qualname:
  description: "bz2.BZ2File.peek.__qualname__ == 'BZ2File.peek' — method qualname encodes class context (extra18)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.peek.__qualname__.__eq__
  args: ["BZ2File.peek"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.readline __qualname__ — novel, extra18 anchor
#
# No prior bz2 spec checks BZ2File.readline.__qualname__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.readline.qualname:
  description: "bz2.BZ2File.readline.__qualname__ == 'BZ2File.readline' — method qualname encodes class context (extra18)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.readline.__qualname__.__eq__
  args: ["BZ2File.readline"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.read1 __qualname__ — novel, extra18 anchor
#
# No prior bz2 spec checks BZ2File.read1.__qualname__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.read1.qualname:
  description: "bz2.BZ2File.read1.__qualname__ == 'BZ2File.read1' — method qualname encodes class context (extra18)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.read1.__qualname__.__eq__
  args: ["BZ2File.read1"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.readinto __qualname__ — novel, extra18 anchor
#
# No prior bz2 spec checks BZ2File.readinto.__qualname__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.readinto.qualname:
  description: "bz2.BZ2File.readinto.__qualname__ == 'BZ2File.readinto' — method qualname encodes class context (extra18)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.readinto.__qualname__.__eq__
  args: ["BZ2File.readinto"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.__mro__[4].__name__ == 'IOBase' — novel, extra18 anchor
#
# bz2_extra17 covers mro[2] == 'BufferedIOBase' and mro[3] == '_BufferedIOBase'.
# No prior bz2 spec checks mro[4]. BZ2File MRO: BZ2File -> BaseStream ->
# BufferedIOBase -> _BufferedIOBase -> IOBase -> _IOBase -> object.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.mro4_name:
  description: "bz2.BZ2File.__mro__[4].__name__ == 'IOBase' — fifth MRO entry is IOBase (extra18)"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__mro__.__getitem__
  args: [4]
  method: __name__.__eq__
  method_args: ["IOBase"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.__mro__[5].__name__ == '_IOBase' — novel, extra18 anchor
#
# No prior bz2 spec checks mro[5]. _IOBase is the C-level base for IOBase.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2File.mro5_name:
  description: "bz2.BZ2File.__mro__[5].__name__ == '_IOBase' — sixth MRO entry is the C-level _IOBase (extra18)"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__mro__.__getitem__
  args: [5]
  method: __name__.__eq__
  method_args: ["_IOBase"]
  expected: true

# ---------------------------------------------------------------------------
# 'eof' in BZ2Decompressor.__dict__ — novel, extra18 anchor
#
# bz2_extra17 covers 'decompress' in BZ2Decompressor.__dict__. The eof,
# needs_input, and unused_data properties are also in the C extension type's
# own __dict__. No prior bz2 spec checks these. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2Decompressor.dict_has_eof:
  description: "bz2.BZ2Decompressor.__dict__.__contains__('eof') == True — eof is defined directly on BZ2Decompressor (extra18)"
  category: class_structure
  kind: python_call_eq
  function: BZ2Decompressor.__dict__.__contains__
  args: ["eof"]
  expected: true

# ---------------------------------------------------------------------------
# 'needs_input' in BZ2Decompressor.__dict__ — novel, extra18 anchor
#
# No prior bz2 spec checks 'needs_input' in BZ2Decompressor.__dict__.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2Decompressor.dict_has_needs_input:
  description: "bz2.BZ2Decompressor.__dict__.__contains__('needs_input') == True — needs_input is defined directly on BZ2Decompressor (extra18)"
  category: class_structure
  kind: python_call_eq
  function: BZ2Decompressor.__dict__.__contains__
  args: ["needs_input"]
  expected: true

# ---------------------------------------------------------------------------
# 'unused_data' in BZ2Decompressor.__dict__ — novel, extra18 anchor
#
# No prior bz2 spec checks 'unused_data' in BZ2Decompressor.__dict__.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.BZ2Decompressor.dict_has_unused_data:
  description: "bz2.BZ2Decompressor.__dict__.__contains__('unused_data') == True — unused_data is defined directly on BZ2Decompressor (extra18)"
  category: class_structure
  kind: python_call_eq
  function: BZ2Decompressor.__dict__.__contains__
  args: ["unused_data"]
  expected: true

# ---------------------------------------------------------------------------
# bz2.__loader__.__class__.__name__ == 'SourceFileLoader' — novel, extra18 anchor
#
# No prior bz2 spec checks the loader class name. bz2 is a pure-Python
# stdlib module loaded by importlib's SourceFileLoader. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.loader.class_name:
  description: "bz2.__loader__.__class__.__name__ == 'SourceFileLoader' — module is loaded by SourceFileLoader (extra18)"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# bz2.__spec__.__class__.__name__ == 'ModuleSpec' — novel, extra18 anchor
#
# No prior bz2 spec checks the spec object's class name. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra18.spec.class_name:
  description: "bz2.__spec__.__class__.__name__ == 'ModuleSpec' — module's __spec__ is a ModuleSpec instance (extra18)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — BZ2File.tell/peek/readline/read1/readinto (extra18)
#
# No prior bz2 spec presents these five method qualnames in any table.
# This table anchors all five from the extra18 namespace.
# ---------------------------------------------------------------------------

table bz2_extra18.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn18

  columns: [id, function, args, expected]
  rows:
    - [BZ2File.tell,     BZ2File.tell.__qualname__.__eq__,     ["BZ2File.tell"],     true]
    - [BZ2File.peek,     BZ2File.peek.__qualname__.__eq__,     ["BZ2File.peek"],     true]
    - [BZ2File.readline, BZ2File.readline.__qualname__.__eq__, ["BZ2File.readline"], true]
    - [BZ2File.read1,    BZ2File.read1.__qualname__.__eq__,    ["BZ2File.read1"],    true]
    - [BZ2File.readinto, BZ2File.readinto.__qualname__.__eq__, ["BZ2File.readinto"], true]

# ---------------------------------------------------------------------------
# __dict__ membership table — BZ2Decompressor properties (extra18)
#
# No prior bz2 spec checks eof/needs_input/unused_data dict membership.
# This table anchors all three from the extra18 namespace.
# ---------------------------------------------------------------------------

table bz2_extra18.decompressor_dict_properties:
  kind: python_call_eq
  category: class_structure
  id_prefix: dict18

  columns: [id, function, args, expected]
  rows:
    - [BZ2Decompressor_eof,         BZ2Decompressor.__dict__.__contains__, ["eof"],         true]
    - [BZ2Decompressor_needs_input, BZ2Decompressor.__dict__.__contains__, ["needs_input"], true]
    - [BZ2Decompressor_unused_data, BZ2Decompressor.__dict__.__contains__, ["unused_data"], true]
