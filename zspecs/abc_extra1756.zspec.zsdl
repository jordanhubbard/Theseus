spec: abc_extra1756
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "Theme: which abc stdlib types define __add__, __sub__, __mul__, __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__."
    - "abc.ABCMeta: metaclass for abstract base classes; controls class creation and virtual-subclass registration — not a numeric type, no arithmetic operators in __dict__ -> all False."
    - "abc.ABC: simple helper base class using ABCMeta as its metaclass — not a numeric type, no arithmetic operators in __dict__ -> all False."
    - "abc.abstractmethod: decorator for marking abstract methods — not a numeric type, no arithmetic operators in __dict__ -> all False."
    - "Rationale: abc types model the abstract-class protocol (metaclass machinery, virtual subclassing, abstract method enforcement), not numeric quantities."
    - "Complementary checks: abc.get_cache_token.__class__.__name__ -> 'builtin_function_or_method'; abc.ABCMeta.__dict__.__contains__('__abstractmethods__') -> False (abstractmethods live on instances/classes using ABCMeta, not on ABCMeta itself)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for abc types
#
# Wave 564 theme: which abc types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# abc.ABCMeta: a metaclass (subclass of type) that adds abstract-base-class
#   machinery — register(), __instancecheck__(), __subclasscheck__() — to
#   classes that use it. It is not a numeric type and does not define any
#   arithmetic dunders in its own __dict__.
# abc.ABC: a convenience class whose metaclass is ABCMeta. It provides a
#   minimal base for user-defined ABCs without explicitly specifying the
#   metaclass. Not numeric; no arithmetic operators in __dict__.
# abc.abstractmethod: a decorator (actually a class) that marks a method as
#   abstract. It stores the wrapped callable and sets __isabstractmethod__ = True.
#   It is not a numeric type; no arithmetic operators in __dict__.
# ---------------------------------------------------------------------------

table abc_extra1756.arithmetic_operators:
  description: "abc types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1756

  columns: [id, function, args, expected]
  rows:
    - ["ab1756001", "abc.ABCMeta.__dict__.__contains__",        ["__add__"],      false]
    - ["ab1756002", "abc.ABCMeta.__dict__.__contains__",        ["__sub__"],      false]
    - ["ab1756003", "abc.ABCMeta.__dict__.__contains__",        ["__mul__"],      false]
    - ["ab1756004", "abc.ABCMeta.__dict__.__contains__",        ["__truediv__"],  false]
    - ["ab1756005", "abc.ABCMeta.__dict__.__contains__",        ["__floordiv__"], false]
    - ["ab1756006", "abc.ABCMeta.__dict__.__contains__",        ["__pow__"],      false]
    - ["ab1756007", "abc.ABCMeta.__dict__.__contains__",        ["__neg__"],      false]
    - ["ab1756008", "abc.ABCMeta.__dict__.__contains__",        ["__pos__"],      false]
    - ["ab1756009", "abc.ABC.__dict__.__contains__",            ["__add__"],      false]
    - ["ab1756010", "abc.ABC.__dict__.__contains__",            ["__sub__"],      false]
    - ["ab1756011", "abc.ABC.__dict__.__contains__",            ["__mul__"],      false]
    - ["ab1756012", "abc.ABC.__dict__.__contains__",            ["__neg__"],      false]
    - ["ab1756013", "abstractmethod.__dict__.__contains__",     ["__add__"],      false]
    - ["ab1756014", "abstractmethod.__dict__.__contains__",     ["__sub__"],      false]
    - ["ab1756015", "abstractmethod.__dict__.__contains__",     ["__mul__"],      false]
    - ["ab1756016", "abstractmethod.__dict__.__contains__",     ["__truediv__"],  false]
    - ["ab1756017", "abstractmethod.__dict__.__contains__",     ["__floordiv__"], false]
    - ["ab1756018", "abstractmethod.__dict__.__contains__",     ["__neg__"],      false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for abc module-level attributes
#
# The arithmetic theme is all-False for all abc types. These complementary
# checks confirm genuine abc-specific attributes and structural properties:
# - abc.get_cache_token is a C-level builtin function (implemented in
#   Modules/_abc.c); its class name is 'builtin_function_or_method'.
# - abc.ABCMeta.__dict__.__contains__('__abstractmethods__') -> False:
#   ABCMeta itself does not carry a __abstractmethods__ attribute in its own
#   __dict__. The __abstractmethods__ frozenset lives on each class whose
#   metaclass is ABCMeta, not on ABCMeta itself.
# - abc.ABC.__dict__.__contains__('__pow__') -> False (cross-check).
# - abc.abstractmethod.__dict__.__contains__('__pow__') -> False (cross-check).
# - abc.ABCMeta.__dict__.__contains__('register') -> True (the register()
#   method for adding virtual subclasses lives in ABCMeta's own __dict__).
# - abc.ABCMeta.__dict__.__contains__('__instancecheck__') -> True.
# - abc.abstractmethod.__dict__.__contains__('__get__') -> True (abstractmethod
#   IS a descriptor; confirmed here as a genuine positive cross-check distinct
#   from the all-False arithmetic rows).
# ---------------------------------------------------------------------------

table abc_extra1756.complementary_checks:
  description: "abc module-level function class name and dict-presence complementary checks — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1756

  columns: [id, function, args, expected]
  rows:
    - ["ab1756019", "abc.get_cache_token.__class__.__name__.__eq__",   ["builtin_function_or_method"], true]
    - ["ab1756020", "abc.ABCMeta.__dict__.__contains__",               ["__abstractmethods__"],        false]
    - ["ab1756021", "abc.ABC.__dict__.__contains__",                   ["__pow__"],                    false]
    - ["ab1756022", "abstractmethod.__dict__.__contains__",            ["__pow__"],                    false]
    - ["ab1756023", "abc.ABCMeta.__dict__.__contains__",               ["register"],                   true]
    - ["ab1756024", "abc.ABCMeta.__dict__.__contains__",               ["__instancecheck__"],          true]
    - ["ab1756025", "abstractmethod.__dict__.__contains__",            ["__get__"],                    true]
