spec: weakref_extra2
version: ">=3.4"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/weakref.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/weakref.py"
    - "weakref.zspec.zsdl — covers class names, function names, empty containers, getweakrefs"
    - "weakref_extra.zspec.zsdl — covers module checks for WeakValueDictionary/WeakKeyDictionary/finalize, proxy.__name__, ReferenceType.__name__, base class chains"
    - "_weakref.zspec.zsdl — covers the C-level _weakref extension type names and modules"
  notes:
    - "weakref.ref.__module__ == 'weakref' — the Python-level alias is considered part of the weakref module."
    - "weakref.ReferenceType.__module__ == 'weakref' — same object as ref, same module."
    - "weakref.ProxyType.__module__ == 'weakref' — the proxy type is registered to the weakref module."
    - "weakref.CallableProxyType.__module__ == 'weakref' — callable proxy also maps to weakref module."
    - "weakref.proxy.__module__ == '_weakref' — proxy() is a C builtin from the _weakref extension."
    - "weakref.WeakSet.__module__ == '_weakrefset' — WeakSet is defined in _weakrefset, not weakref."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for reference types
# ---------------------------------------------------------------------------

invariant weakref_extra2.ref.module:
  description: "weakref.ref.__module__ == 'weakref'"
  category: modules
  kind: python_call_eq
  function: ref.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra2.ReferenceType.module:
  description: "weakref.ReferenceType.__module__ == 'weakref'"
  category: modules
  kind: python_call_eq
  function: ReferenceType.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra2.ProxyType.module:
  description: "weakref.ProxyType.__module__ == 'weakref'"
  category: modules
  kind: python_call_eq
  function: ProxyType.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra2.CallableProxyType.module:
  description: "weakref.CallableProxyType.__module__ == 'weakref'"
  category: modules
  kind: python_call_eq
  function: CallableProxyType.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra2.proxy.module:
  description: "weakref.proxy.__module__ == '_weakref' — proxy() is a C builtin from the _weakref extension"
  category: modules
  kind: python_call_eq
  function: proxy.__module__.__eq__
  args: ["_weakref"]
  expected: true

invariant weakref_extra2.WeakSet.module:
  description: "weakref.WeakSet.__module__ == '_weakrefset' — WeakSet is defined in the _weakrefset helper module"
  category: modules
  kind: python_call_eq
  function: WeakSet.__module__.__eq__
  args: ["_weakrefset"]
  expected: true

# ---------------------------------------------------------------------------
# CallableProxyType class name check
# ---------------------------------------------------------------------------

invariant weakref_extra2.CallableProxyType.name:
  description: "weakref.CallableProxyType.__name__ == 'CallableProxyType'"
  category: class_names
  kind: python_call_eq
  function: CallableProxyType.__name__.__eq__
  args: ["CallableProxyType"]
  expected: true

# ---------------------------------------------------------------------------
# ReferenceType is ref — identity via __name__ cross-check
# ---------------------------------------------------------------------------

invariant weakref_extra2.ref.name_is_ReferenceType:
  description: "weakref.ref.__name__ == 'ReferenceType' — ref is an alias for the C ReferenceType"
  category: class_names
  kind: python_call_eq
  function: ref.__name__.__eq__
  args: ["ReferenceType"]
  expected: true
