spec: pathlib_extra166
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __qualname__ values for open, read_text, write_text, touch, mkdir."
    - "All five Path method qualnames follow the 'Path.<method>' pattern using the public class name 'Path' (5 characters)."
    - "The 'Path.' prefix is 5 characters ('Path' (4) + '.' (1) = 5)."
    - "pathlib.Path.open.__qualname__ == 'Path.open' (len=9; 'Path.' (5) + 'open' (4) = 9; the shortest of the five methods in this spec)."
    - "pathlib.Path.touch.__qualname__ == 'Path.touch' (len=10; 'Path.' (5) + 'touch' (5) = 10; tied with mkdir at 10)."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (len=10; 'Path.' (5) + 'mkdir' (5) = 10; tied with touch at 10)."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (len=14; 'Path.' (5) + 'read_text' (9) = 14; tied with write_text at 14)."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (len=15; 'Path.' (5) + 'write_text' (10) = 15; the longest of the five methods in this spec)."
    - "Two-way tie at 10: touch and mkdir — both 5-character method names."
    - "read_text stands alone at 14 (9-character method name)."
    - "write_text stands alone at 15 (10-character method name) — the longest in this spec."
    - "Length ranking: open=9, touch=mkdir=10, read_text=14, write_text=15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path file-operation method __qualname__ values (group 1)
# open, touch, mkdir — short method names (4-5 characters).
# open=9, touch=10, mkdir=10 (touch and mkdir tied at 10).
# All use 'Path.' prefix (5 characters).
# ---------------------------------------------------------------------------

table pathlib_extra166.Path_file_op_method_qualnames_group1:
  description: "pathlib.Path file-operation method __qualname__ values: open='Path.open' (len=9), touch=mkdir='Path.touch'/'Path.mkdir' (len=10); open is the shortest; touch and mkdir tied at 10"
  kind: python_call_eq
  category: qualname
  id_prefix: pathfileq166

  columns: [id, function, args, expected, description]
  rows:
    - [open_qeq,  Path.open.__qualname__.__eq__,  ["Path.open"],  true, "pathlib.Path.open.__qualname__ == 'Path.open' (Path.open() opens the file pointed to by the path, like the built-in open() function; returns a file object; accepts mode, buffering, encoding, errors, newline arguments; 'Path.open' has 9 characters: 'Path.' (5) + 'open' (4) = 9; the shortest of all five Path method qualnames in this spec; open() is the foundational method for file access — all file reading and writing ultimately flows through it or its text/bytes convenience wrappers; qualname length 9 is the minimum for any 'Path.' method covering a 4-character method name)"]
    - [touch_qeq, Path.touch.__qualname__.__eq__,  ["Path.touch"],  true, "pathlib.Path.touch.__qualname__ == 'Path.touch' (Path.touch() creates the file at the path if it does not exist, or updates its modification time if it does; analogous to the POSIX touch(1) command; 'Path.touch' has 10 characters: 'Path.' (5) + 'touch' (5) = 10; tied with 'Path.mkdir' (also 10) — both touch and mkdir have 5-character method names; Path.touch() is the pathlib analog of os.utime(path, None); one character longer than 'Path.open' (9) because 'touch' (5) is one character longer than 'open' (4))"]
    - [mkdir_qeq, Path.mkdir.__qualname__.__eq__,  ["Path.mkdir"],  true, "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (Path.mkdir() creates a new directory at the path; accepts parents=True to create intermediate-level directories and exist_ok=True to suppress FileExistsError; 'Path.mkdir' has 10 characters: 'Path.' (5) + 'mkdir' (5) = 10; tied with 'Path.touch' (also 10); mkdir stands for 'make directory'; Path.mkdir() is the pathlib equivalent of os.makedirs() when parents=True; both touch (creates file) and mkdir (creates directory) are creation methods at length 10)"]
    - [open_qlen,  Path.open.__qualname__.__len__,  [],              9,    "pathlib.Path.open.__qualname__.__len__() == 9 ('Path.open' has 9 characters: 'Path.' (5) + 'open' (4) = 9; the shortest of all five Path method qualnames in this spec; the length ranking from shortest to longest is: open=9, touch=mkdir=10, read_text=14, write_text=15; note that Path.stat.__qualname__ also has length 9 (established in pathlib_extra165) — open and stat are tied as the shortest Path method qualnames seen across these pathlib_extra16x specs)"]

# ---------------------------------------------------------------------------
# pathlib.Path text-I/O method __qualname__ values (group 2)
# read_text, write_text — the text I/O convenience methods.
# read_text=14, write_text=15.
# write_text is the longest of all five Path methods in this spec.
# ---------------------------------------------------------------------------

table pathlib_extra166.Path_text_io_method_qualnames_group2:
  description: "pathlib.Path text-I/O method __qualname__ values: read_text='Path.read_text' (len=14), write_text='Path.write_text' (len=15); write_text is the longest of all five methods in this spec"
  kind: python_call_eq
  category: qualname
  id_prefix: pathfileq166

  columns: [id, function, args, expected, description]
  rows:
    - [read_text_qeq,  Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true, "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (Path.read_text() reads the file contents as a decoded string; accepts encoding and errors arguments; it is the convenience wrapper around Path.open(mode='r').read() that automatically opens and closes the file; 'Path.read_text' has 14 characters: 'Path.' (5) + 'read_text' (9) = 14; the underscore in 'read_text' makes it the longest non-write method name in this spec; read_text stands alone at 14 — one character shorter than write_text (15) and four longer than touch/mkdir (10))"]
    - [write_text_qeq, Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true, "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (Path.write_text() writes the given string to the file, overwriting any existing content; accepts encoding and errors arguments; it is the convenience wrapper around Path.open(mode='w').write() that automatically opens and closes the file; 'Path.write_text' has 15 characters: 'Path.' (5) + 'write_text' (10) = 15; the longest of all five Path method qualnames in this spec; 'write_text' (10 chars) is one character longer than 'read_text' (9 chars) because 'write' (5) > 'read' (4) by one character)"]
    - [read_text_qlen, Path.read_text.__qualname__.__len__,  [],                   14,   "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' has 14 characters: 'Path.' (5) + 'read_text' (9) = 14; 'read_text' (9 chars) is the second-longest method name in this spec after 'write_text' (10 chars); read_text sits between mkdir/touch (10) and write_text (15) in the length ranking; the underscore in 'read_text' contributes to its length — without it, 'readtext' would be 8 chars like 'getvalue' or 'readline'; all five Path method qualnames in this spec: open=9, touch=mkdir=10, read_text=14, write_text=15)"]
    - [write_text_qlen, Path.write_text.__qualname__.__len__, [],                   15,   "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 characters: 'Path.' (5) + 'write_text' (10) = 15; the longest Path method qualname in this spec; 'write_text' (10 chars) is the longest method name in this spec; complete length ranking: open=9, touch=mkdir=10, read_text=14, write_text=15; 'Path.write_text' (15) matches 'Decimal.__str__' (15) established in decimal_extra154 — both are 15-character identifiers; Path.write_text is one character longer than Path.read_text because 'write' (5) exceeds 'read' (4) by one character)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra166.Path_open_is_shortest_at_9:
  description: "pathlib.Path.open.__qualname__.__len__() == 9 — 'Path.open' is the shortest of all five Path method qualnames in this spec with only 9 characters: 'Path.' (5) + 'open' (4) = 9; 'open' (4 chars) is the shortest method name of the five; the complete ascending length order is: open=9, touch=mkdir=10, read_text=14, write_text=15; Path.open() is the foundational file-access method from which read_text and write_text are derived; qualname length 9 is shared with Path.stat (established in pathlib_extra165); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.open.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra166.Path_touch_mkdir_tied_at_10:
  description: "pathlib.Path.touch.__qualname__.__len__() == 10 — 'Path.touch' has 10 characters: 'Path.' (5) + 'touch' (5) = 10; tied with 'Path.mkdir' (also 10: 'Path.' (5) + 'mkdir' (5) = 10); touch and mkdir are the only two Path methods in this spec with 5-character method names, producing the same qualname length of 10; touch creates a file and mkdir creates a directory — both are filesystem-creation methods; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.touch.__qualname__.__len__
  args: []
  expected: 10

invariant pathlib_extra166.Path_write_text_is_longest_at_15:
  description: "pathlib.Path.write_text.__qualname__.__len__() == 15 — 'Path.write_text' is the longest of all five Path method qualnames in this spec at 15 characters: 'Path.' (5) + 'write_text' (10) = 15; 'write_text' (10 chars) is the longest method name of the five; the length progression from shortest to longest is open (9), touch=mkdir (10), read_text (14), write_text (15); write_text is the text-writing convenience method that opens, writes, and closes the file in one call; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra166.Path_mkdir_qualname_eq:
  description: "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' — mkdir() uses the public class name 'Path' in its qualname, consistent with all other Path methods; 'Path.mkdir' has 10 characters, tied with 'Path.touch' (both 5-character method names); Path.mkdir() creates directories with optional parents=True and exist_ok=True support; 'mkdir' stands for 'make directory' and is a POSIX command name incorporated directly into pathlib; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.mkdir.__qualname__.__eq__
  args: ["Path.mkdir"]
  expected: true
