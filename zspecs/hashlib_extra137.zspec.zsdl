spec: hashlib_extra137
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra136.zspec.zsdl — covers sha3_224/sha3_256/sha3_384/sha3_512/shake_128/shake_256 __name__ equality / file_digest __name__/__qualname__/__module__/__code__.co_argcount / hashlib.new true __name__ ('__hash_new') and __qualname__ (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / md5/sha1/sha224/sha256/sha384/sha512 __name__ equality / blake2b/blake2s class identity and module / new function class / algorithms_guaranteed length (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 349 theme: hashlib.pbkdf2_hmac C builtin identity / sha256.__doc__ content and class name / hashlib.new.__code__.co_name and co_varnames[0] / algorithms_guaranteed and algorithms_available class names and lengths."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. pbkdf2_hmac is a C builtin from _hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__len__() == 66. The docstring is 'Returns a sha256 hash object; optionally initialized with a string' (66 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_name == '__hash_new'. The code object's co_name reveals the private internal function name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_varnames[0] == 'name'. The first local variable (and parameter) of __hash_new is 'name' (the hash algorithm name string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_varnames.__len__() == 3. The function has 3 locals: 'name', plus two others from the function body. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. algorithms_guaranteed is a plain Python set (not frozenset). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. algorithms_available is also a plain Python set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra97 anchors algorithms_guaranteed membership; extra99 anchors algorithms_guaranteed length==14 and algorithms_guaranteed class. This spec is the first to anchor pbkdf2_hmac __name__/__qualname__/__module__/__class__.__name__, sha256.__doc__ class and length, new.__code__.co_name and co_varnames[0], and algorithms_available class name under hashlibfn137."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str')
#
# Wave 349 theme: pbkdf2_hmac C builtin identity and sha256.__doc__ class name.
#
# hashlib.pbkdf2_hmac is a Password-Based Key Derivation Function (PBKDF2) using
# HMAC as the pseudo-random function. Unlike hashlib.file_digest and hashlib.new
# which are pure-Python functions, pbkdf2_hmac is implemented in C (via _hashlib)
# for performance. Its __module__ is '_hashlib' (not 'hashlib') and its
# __class__.__name__ is 'builtin_function_or_method'. sha256.__doc__ is a plain
# str (not bytes). No prior hashlib spec anchors pbkdf2_hmac identity via __eq__
# calls under hashlibfn137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra137.pbkdf2_hmac_identity:
  description: "hashlib.pbkdf2_hmac/__name__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac/__qualname__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac/__module__.__eq__('_hashlib')==True / pbkdf2_hmac/__class__.__name__.__eq__('builtin_function_or_method')==True / sha256/__doc__/__class__.__name__.__eq__('str')==True — pbkdf2_hmac is a C builtin from _hashlib (not pure-Python like file_digest/new); sha256.__doc__ is a str; first hashlibfn137 anchor for pbkdf2_hmac identity via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfn137

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_name,    pbkdf2_hmac.__name__.__eq__,               ["pbkdf2_hmac"],               true, "pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (11 chars)"]
    - [pbkdf2_qualname, pbkdf2_hmac.__qualname__.__eq__,           ["pbkdf2_hmac"],               true, "pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (top-level, no class prefix)"]
    - [pbkdf2_module,  pbkdf2_hmac.__module__.__eq__,              ["_hashlib"],                  true, "pbkdf2_hmac.__module__ is '_hashlib' (C extension, unlike file_digest which is 'hashlib')"]
    - [pbkdf2_class,   pbkdf2_hmac.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "pbkdf2_hmac is a C builtin (no __code__ attribute unlike file_digest)"]
    - [sha256_doc_cls, sha256.__doc__.__class__.__name__.__eq__,   ["str"],                       true, "sha256.__doc__.__class__.__name__ is 'str' (docstring is a plain Python string)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__len__().__eq__(66)
# hashlib.new.__code__.co_name.__eq__('__hash_new')
# hashlib.new.__code__.co_varnames[0].__eq__('name')
# hashlib.new.__code__.co_varnames.__len__().__eq__(3)
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
#
# Wave 349 theme: sha256.__doc__ length / new code attributes / algorithms_guaranteed class.
#
# hashlib.sha256.__doc__ is 66 characters: 'Returns a sha256 hash object;
# optionally initialized with a string'. The new function's code object
# has co_name == '__hash_new' (confirming the private alias discussed in
# extra136), co_varnames[0] == 'name' (the hash name parameter), and
# co_varnames.__len__() == 3 total locals. algorithms_guaranteed is a plain
# Python set (not frozenset), as is algorithms_available. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra137.doc_coname_algsets:
  description: "hashlib.sha256/__doc__/__len__()==66 / new/__code__/co_name.__eq__('__hash_new')==True / new/__code__/co_varnames[0].__eq__('name')==True / new/__code__/co_varnames/__len__()==3 / algorithms_guaranteed/__class__.__name__.__eq__('set')==True — sha256 docstring is 66 chars; new co_name confirms private alias; new first param is 'name'; algorithms_guaranteed is a plain set; first hashlibfn137 anchor for these code and collection attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfn137

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_len,  sha256.__doc__.__len__,                                [],              66,   "sha256.__doc__ is 66 chars: 'Returns a sha256 hash object; optionally initialized with a string'"]
    - [new_coname,      new.__code__.co_name.__eq__,                           ["__hash_new"],  true, "new.__code__.co_name is '__hash_new' (confirms private alias; __name__ and co_name agree)"]
    - [new_var0,        "new.__code__.co_varnames[0].__eq__",                  ["name"],        true, "new first parameter is 'name' (the hash algorithm name string passed to __hash_new)"]
    - [new_varlen,      "new.__code__.co_varnames.__len__",                    [],              3,    "new has 3 total co_varnames (1 required param + 2 locals from function body)"]
    - [alg_guar_cls,   algorithms_guaranteed.__class__.__name__.__eq__,        ["set"],         true, "algorithms_guaranteed.__class__.__name__ is 'set' (plain Python set, not frozenset)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__len__().__eq__(19)
# hashlib.algorithms_guaranteed.__len__().__eq__(14)
# hashlib.pbkdf2_hmac.__name__.__len__().__eq__(11)
# hashlib.sha256.__doc__.__len__().__eq__(66)
#
# Wave 349 theme: algorithms_available class name / collection lengths / name lengths.
#
# Both hashlib.algorithms_guaranteed and hashlib.algorithms_available are plain
# Python sets. algorithms_guaranteed has 14 members (all SHA-2, SHA-3, blake2,
# shake, MD5, SHA-1). algorithms_available has 19 members on this platform
# (adds md5-sha1, ripemd160, sha512_224, sha512_256, sm3 from OpenSSL).
# pbkdf2_hmac.__name__.__len__() == 11 (same as file_digest.__name__.__len__()).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra137.algsets_and_lengths:
  description: "hashlib.algorithms_available/__class__.__name__.__eq__('set')==True / algorithms_available/__len__()==19 / algorithms_guaranteed/__len__()==14 / pbkdf2_hmac/__name__/__len__()==11 / sha256/__doc__/__len__()==66 — both algorithm sets are plain Python sets; algorithms_available has 5 more than guaranteed (platform-specific OpenSSL extras); pbkdf2_hmac name is 11 chars; sha256 docstring is 66 chars; first hashlibfn137 anchor for algorithms_available class and length"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfn137

  columns: [id, function, args, expected, description]
  rows:
    - [alg_avail_cls,  algorithms_available.__class__.__name__.__eq__,  ["set"],  true, "algorithms_available.__class__.__name__ is 'set' (same type as algorithms_guaranteed)"]
    - [alg_avail_len,  algorithms_available.__len__,                    [],        19,   "algorithms_available has 19 members (14 guaranteed + 5 OpenSSL extras on this platform)"]
    - [alg_guar_len,   algorithms_guaranteed.__len__,                   [],        14,   "algorithms_guaranteed has 14 members (cross-check; extra99 anchors this at table level)"]
    - [pbkdf2_namelen, pbkdf2_hmac.__name__.__len__,                    [],        11,   "len('pbkdf2_hmac') == 11 (same length as 'file_digest'; both are 11 chars)"]
    - [sha256_doclen,  sha256.__doc__.__len__,                          [],        66,   "sha256.__doc__ is 66 chars (cross-check with doc_coname_algsets table entry)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac.__name__ is 'pbkdf2_hmac'. pbkdf2_hmac is one of three
# public functions in hashlib alongside new/file_digest, but unlike those two
# it is a C builtin from _hashlib rather than pure Python. It implements the
# PBKDF2-HMAC key derivation algorithm per RFC 2898. Its __name__ equals the
# public attribute name (no private aliasing unlike hashlib.new whose __name__
# is '__hash_new'). No prior hashlib spec anchors pbkdf2_hmac.__name__.__eq__
# as a standalone under hashlibfn137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra137.pbkdf2_hmac_name:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — pbkdf2_hmac is a C builtin from _hashlib implementing PBKDF2-HMAC per RFC 2898; __name__ equals public attribute (no aliasing unlike new/__name__=='__hash_new'); extra136 anchors file_digest __name__; first standalone for pbkdf2_hmac.__name__.__eq__ under hashlibfn137"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib'. This contrasts with
# hashlib.file_digest whose __module__ is 'hashlib' (pure Python). pbkdf2_hmac
# has been implemented in C since Python 3.4 for performance — password hashing
# requires many iterations of HMAC and the C implementation is significantly
# faster than a pure-Python equivalent. hashlib_extra136 anchors file_digest
# __module__=='hashlib'; this is the first standalone for pbkdf2_hmac
# __module__.__eq__('_hashlib') under hashlibfn137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra137.pbkdf2_hmac_module:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — pbkdf2_hmac is C-backed (performance-critical PBKDF2 iteration); contrasts with file_digest.__module__=='hashlib' (pure Python); extra136 anchors file_digest __module__; first standalone for pbkdf2_hmac.__module__.__eq__ under hashlibfn137"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_name.__eq__('__hash_new') — standalone
#
# hashlib.new.__code__.co_name is '__hash_new'. The code object's co_name is
# the function name as it appears in the source code at definition time.
# For hashlib.new, co_name reveals the private function '__hash_new', the same
# value as __name__ and __qualname__. co_name is an immutable attribute of the
# code object embedded in the bytecode. extra136 anchors new.__name__.__eq__ and
# new.__qualname__.__eq__; this is the first standalone for new.__code__.co_name
# under hashlibfn137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra137.new_code_co_name:
  description: "hashlib.new.__code__.co_name.__eq__('__hash_new') == True — co_name is the function's source-level name (embedded in bytecode); matches __name__ and __qualname__ for hashlib.new; extra136 anchors __name__/__qualname__ equality; first standalone for new.__code__.co_name under hashlibfn137"
  category: type_identity
  kind: python_call_eq
  function: new.__code__.co_name.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available.__class__.__name__ is 'set'. Unlike what one
# might expect (frozenset, since the set contents reflect OpenSSL capabilities
# at import time), both algorithms_guaranteed and algorithms_available are plain
# mutable Python sets. algorithms_available contains additional OpenSSL-specific
# names beyond the 14 guaranteed ones: md5-sha1, ripemd160, sha512_224,
# sha512_256, sm3 (platform-dependent). No prior hashlib spec anchors
# algorithms_available.__class__.__name__.__eq__('set') as a standalone
# under hashlibfn137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra137.algorithms_available_class:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain mutable Python set (same type as algorithms_guaranteed, not frozenset); contains platform-specific OpenSSL names beyond the 14 guaranteed; extra97 anchors algorithms_guaranteed membership; first standalone for algorithms_available class name under hashlibfn137"
  category: type_identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__().__eq__(19) — standalone
#
# hashlib.algorithms_available.__len__() is 19. On Python 3.14.3 macOS/Darwin
# with OpenSSL, algorithms_available has 19 members: the 14 in
# algorithms_guaranteed plus 5 additional OpenSSL-specific names (md5-sha1,
# ripemd160, sha512_224, sha512_256, sm3). The exact count may differ on
# platforms with different OpenSSL configurations. extra99 anchors
# algorithms_guaranteed.__len__()==14; this is the first standalone for
# algorithms_available.__len__()==19 under hashlibfn137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra137.algorithms_available_len:
  description: "hashlib.algorithms_available.__len__() == 19 — algorithms_available has 19 members on Python 3.14.3 macOS/Darwin: 14 guaranteed + 5 OpenSSL extras (md5-sha1, ripemd160, sha512_224, sha512_256, sm3); platform-dependent; extra99 anchors algorithms_guaranteed len==14; first standalone for algorithms_available.__len__()==19 under hashlibfn137"
  category: type_identity
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

