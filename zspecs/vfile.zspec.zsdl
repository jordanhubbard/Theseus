spec: vfile
version: ">=6.0.0"
backend: node(vfile)

docs: https://github.com/vfile/vfile#readme

provenance:
  derived_from:
    - "vfile README — https://github.com/vfile/vfile#readme"
    - "Test vectors verified with vfile via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "vfile source"
  notes:
    - "Virtual file objects used by the unified ecosystem (remark/rehype) for streaming text+metadata."
    - "Install: npm install vfile"
    - "Pattern: const {VFile} = require('vfile'); new VFile({path, value})"
    - "Path utilities (.basename, .extname, .stem, .dirname) mirror Node's path module."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor; throws on invalid path types only."
  stderr: "null"
  stickiness: "N/A — each VFile is independent."
  codes: {}

invariant vfile.path_preserved:
  description: "VFile({path}).path returns the path"
  category: properties
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "foo.md", value: "# hello"}]
  chain:
    - {get: path}
  expected: "foo.md"

invariant vfile.value_preserved:
  description: "VFile({value}).value returns the content"
  category: properties
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "foo.md", value: "# hello"}]
  chain:
    - {get: value}
  expected: "# hello"

invariant vfile.basename:
  description: ".basename strips the directory"
  category: path_helpers
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "/dir/foo.md", value: ""}]
  chain:
    - {get: basename}
  expected: "foo.md"

invariant vfile.extname:
  description: ".extname returns the extension with leading dot"
  category: path_helpers
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "foo.md", value: ""}]
  chain:
    - {get: extname}
  expected: ".md"

invariant vfile.stem:
  description: ".stem returns basename without extension"
  category: path_helpers
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "foo.md", value: ""}]
  chain:
    - {get: stem}
  expected: "foo"

invariant vfile.dirname:
  description: ".dirname returns the directory portion"
  category: path_helpers
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "/dir/foo.md", value: ""}]
  chain:
    - {get: dirname}
  expected: "/dir"

invariant vfile.toString_returns_value:
  description: ".toString() returns the .value content"
  category: serialization
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{path: "foo.md", value: "body"}]
  chain:
    - {method: toString, args: []}
  expected: "body"

invariant vfile.no_path_value_only:
  description: "VFile constructed with only value has undefined path"
  category: edge
  kind: node_chain_eq
  entry: constructor
  class: VFile
  entry_args: [{value: "raw"}]
  chain:
    - {get: path}
  expected: ~
