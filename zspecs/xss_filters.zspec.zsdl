spec: xss_filters
version: ">=0.1.0"
backend: node(xss-filters)

docs: https://www.npmjs.com/package/xss-filters

provenance:
  derived_from:
    - "xss-filters README — https://www.npmjs.com/package/xss-filters"
    - "Test vectors verified with xss-filters via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "xss-filters source"
  notes:
    - "xss-filters is an npm package. Install: npm install xss-filters"
    - "inHTMLData(str) escapes < to &lt; but does NOT encode & in plain HTML data context."
    - "uriInHTMLData(str) is for URI values in HTML data context."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns escaped string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table xss_filters.inHTMLData:
  kind: node_module_call_eq
  function: inHTMLData
  category: inHTMLData
  id_prefix: xssihd

  columns: [id, args, expected]
  rows:
    - [script_tag,   ["<script>"],      "&lt;script>"]
    - [ampersand,    ["Tom & Jerry"],   "Tom & Jerry"]
    - [plain,        ["hello world"],   "hello world"]
    - [lt_gt,        ["a < b > c"],     "a &lt; b > c"]

table xss_filters.uriInHTMLData:
  kind: node_module_call_eq
  function: uriInHTMLData
  category: uriInHTMLData
  id_prefix: xssuihd

  columns: [id, args, expected]
  rows:
    - [plain_url,    ["https://example.com"], "https://example.com"]
    - [js_proto,     ["javascript:alert(1)"], "javascript:alert(1)"]
