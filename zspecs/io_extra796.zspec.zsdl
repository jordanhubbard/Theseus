spec: io_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - io module CPython source
    - Python standard library documentation
  not_derived_from:
    - any third-party io libraries
  notes:
    - Covers BufferedReader, BufferedWriter, BufferedRandom, and FileIO method qualnames
    - All qualname checks confirm canonical method identity within the io module
  created_at: "2026-04-12"

table io_extra796.name:
  description: Verify __qualname__ attributes for io buffered I/O class methods
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: io796xx
  columns: [id, function, args, expected]
  rows:
    - [io796xx001, io.BufferedReader.__init__.__qualname__.__eq__, ["BufferedReader.__init__"], true]
    - [io796xx002, io.BufferedReader.read.__qualname__.__eq__, ["BufferedReader.read"], true]
    - [io796xx003, io.BufferedReader.read1.__qualname__.__eq__, ["BufferedReader.read1"], true]
    - [io796xx004, io.BufferedReader.readline.__qualname__.__eq__, ["BufferedReader.readline"], true]
    - [io796xx005, io.BufferedReader.peek.__qualname__.__eq__, ["BufferedReader.peek"], true]
    - [io796xx006, io.BufferedWriter.__init__.__qualname__.__eq__, ["BufferedWriter.__init__"], true]
    - [io796xx007, io.BufferedWriter.write.__qualname__.__eq__, ["BufferedWriter.write"], true]
    - [io796xx008, io.BufferedWriter.flush.__qualname__.__eq__, ["BufferedWriter.flush"], true]
    - [io796xx009, io.BufferedRandom.__init__.__qualname__.__eq__, ["BufferedRandom.__init__"], true]
    - [io796xx010, io.BufferedRandom.read.__qualname__.__eq__, ["BufferedRandom.read"], true]
    - [io796xx011, io.BufferedRandom.write.__qualname__.__eq__, ["BufferedRandom.write"], true]
    - [io796xx012, io.FileIO.__init__.__qualname__.__eq__, ["FileIO.__init__"], true]
