spec: re_extra81
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra80."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern.match/__doc__.__class__.__name__; Pattern.search/__doc__.__class__.__name__."
    - "This spec covers: Pattern.findall/__doc__.__class__.__name__; Pattern.finditer/__doc__.__class__.__name__; Pattern.sub/__doc__.__class__.__name__; Pattern.subn/__doc__.__class__.__name__; Pattern.split/__doc__.__class__.__name__; Pattern.fullmatch/__doc__.__class__.__name__; Match.group/__qualname__ value and __len__(); Match.groups/__qualname__.__len__(); Match.groupdict/__qualname__.__len__(); Match.start/__qualname__.__len__(); Match.end/__qualname__.__len__(); Match.span/__qualname__.__len__()."
    - "re.Pattern.findall.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Pattern.finditer.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Pattern.sub.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Pattern.subn.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Pattern.split.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Pattern.fullmatch.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Match.group.__qualname__ == 'Match.group' — length 11."
    - "re.Match.groups.__qualname__.__len__() == 12 — 'Match.groups'."
    - "re.Match.groupdict.__qualname__.__len__() == 15 — 'Match.groupdict'."
    - "re.Match.start.__qualname__.__len__() == 11 — 'Match.start'."
    - "re.Match.end.__qualname__.__len__() == 9 — 'Match.end'."
    - "re.Match.span.__qualname__.__len__() == 10 — 'Match.span'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern.findall, Pattern.finditer, Pattern.sub __doc__.__class__.__name__
# These are C method_descriptors; their __doc__ is a plain Python str.
# __doc__.__class__.__name__ == 'str'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra81.Pattern_findall_finditer_sub_doc_class:
  description: "Pattern.findall, Pattern.finditer, Pattern.sub __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra81

  columns: [id, function, args, expected]
  rows:
    - [findall_doc_cls,  Pattern.findall.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [finditer_doc_cls, Pattern.finditer.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sub_doc_cls,      Pattern.sub.__doc__.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# Pattern.subn, Pattern.split, Pattern.fullmatch __doc__.__class__.__name__
# All are C method_descriptors; their __doc__ is a plain Python str.
# __doc__.__class__.__name__ == 'str'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra81.Pattern_subn_split_fullmatch_doc_class:
  description: "Pattern.subn, Pattern.split, Pattern.fullmatch __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra81

  columns: [id, function, args, expected]
  rows:
    - [subn_doc_cls,      Pattern.subn.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [split_doc_cls,     Pattern.split.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [fullmatch_doc_cls, Pattern.fullmatch.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Match.group __qualname__ value and length
# Match.group.__qualname__ == 'Match.group' — length 11.
# Match.groups.__qualname__.__len__() == 12 — 'Match.groups'.
# Match.groupdict.__qualname__.__len__() == 15 — 'Match.groupdict'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra81.Match_group_qualname:
  description: "Match.group, Match.groups, Match.groupdict __qualname__ value and length"
  kind: python_call_eq
  category: qualname
  id_prefix: reextra81

  columns: [id, function, args, expected]
  rows:
    - [group_qualname,      Match.group.__qualname__.__eq__,          ["Match.group"], true]
    - [group_qualname_len,  Match.group.__qualname__.__len__,         [],              11]
    - [groups_qualname_len, Match.groups.__qualname__.__len__,        [],              12]
    - [gdict_qualname_len,  Match.groupdict.__qualname__.__len__,     [],              15]

# ---------------------------------------------------------------------------
# Match.start, Match.end, Match.span __qualname__ lengths
# Match.start.__qualname__.__len__() == 11 — 'Match.start'.
# Match.end.__qualname__.__len__() == 9 — 'Match.end'.
# Match.span.__qualname__.__len__() == 10 — 'Match.span'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra81.Match_start_end_span_qualname_len:
  description: "Match.start, Match.end, Match.span __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: reextra81

  columns: [id, function, args, expected]
  rows:
    - [start_qualname_len, Match.start.__qualname__.__len__, [], 11]
    - [end_qualname_len,   Match.end.__qualname__.__len__,   [], 9]
    - [span_qualname_len,  Match.span.__qualname__.__len__,  [], 10]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra81.Pattern_findall_doc.class_name:
  description: "re.Pattern.findall.__doc__.__class__.__name__ == 'str'"
  category: class_identity
  kind: python_call_eq
  function: Pattern.findall.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra81.Pattern_sub_doc.class_name:
  description: "re.Pattern.sub.__doc__.__class__.__name__ == 'str'"
  category: class_identity
  kind: python_call_eq
  function: Pattern.sub.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra81.Match_group.qualname:
  description: "re.Match.group.__qualname__ == 'Match.group' (length 11)"
  category: qualname
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra81.Match_groupdict.qualname_len:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict')"
  category: qualname
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__len__
  args: []
  expected: 15

invariant re_extra81.Match_span.qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 ('Match.span')"
  category: qualname
  kind: python_call_eq
  function: Match.span.__qualname__.__len__
  args: []
  expected: 10
