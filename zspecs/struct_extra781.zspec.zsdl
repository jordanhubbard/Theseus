spec: struct_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - struct module documentation
    - CPython standard library source
  not_derived_from:
    - any third-party struct wrapper
  notes:
    - Covers struct module attributes and Struct docstrings
    - struct.error is a subclass of Exception defined in the struct module
    - pack/unpack/calcsize/iter_unpack are top-level callables
  created_at: "2026-04-12"

table struct_extra781.name:
  description: struct module attributes and Struct docstrings
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: st781xx
  columns: [id, function, args, expected]
  rows:
    - [st781xx001, struct.__name__.__eq__, ["struct"], true]
    - [st781xx002, struct.__package__.__eq__, ["struct"], true]
    - [st781xx003, struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - [st781xx004, struct.Struct.__module__.__eq__, ["struct"], true]
    - [st781xx005, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st781xx006, struct.error.__qualname__.__eq__, ["error"], true]
    - [st781xx007, struct.error.__module__.__eq__, ["struct"], true]
    - [st781xx008, struct.error.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st781xx009, struct.pack.__qualname__.__eq__, ["pack"], true]
    - [st781xx010, struct.unpack.__qualname__.__eq__, ["unpack"], true]
    - [st781xx011, struct.calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [st781xx012, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
