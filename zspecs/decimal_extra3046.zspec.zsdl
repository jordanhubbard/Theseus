spec: dc3046
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (dc3046): __enter__, __exit__, __aenter__ dict-presence for decimal types."
    - "decimal.Context defines __enter__ and __exit__ at runtime to support with-statement usage, but those methods live in the C-level implementation and are not present in decimal.Context.__dict__ at the Python level."
    - "decimal.Decimal and all decimal exception types are numeric/exception types; none define __enter__, __exit__, or __aenter__ in their own __dict__."
    - "None of the decimal types define __aenter__ in their own __dict__; async context manager support is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# decimal types do not define __enter__ in their own Python-level __dict__;
# all false.
# ---------------------------------------------------------------------------

table dc3046.enter:
  description: "decimal types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc3046
  columns: [id, function, args, expected]
  rows:
    - ["dc3046001", operator.contains, [decimal.Decimal.__dict__,          "__enter__"], false]
    - ["dc3046002", operator.contains, [decimal.Context.__dict__,          "__enter__"], false]
    - ["dc3046003", operator.contains, [decimal.DecimalException.__dict__, "__enter__"], false]
    - ["dc3046004", operator.contains, [decimal.InvalidOperation.__dict__, "__enter__"], false]
    - ["dc3046005", operator.contains, [decimal.Overflow.__dict__,         "__enter__"], false]
    - ["dc3046006", operator.contains, [decimal.Underflow.__dict__,        "__enter__"], false]

