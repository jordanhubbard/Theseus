# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# decimal types do not implement the async context manager protocol;
# none define __aenter__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table dc3046.aenter:
  description: "decimal types __aenter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc3046
  columns: [id, function, args, expected]
  rows:
    - ["dc3046013", operator.contains, [decimal.Decimal.__dict__,          "__aenter__"], false]
    - ["dc3046014", operator.contains, [decimal.Context.__dict__,          "__aenter__"], false]
    - ["dc3046015", operator.contains, [decimal.DecimalException.__dict__, "__aenter__"], false]
    - ["dc3046016", operator.contains, [decimal.InvalidOperation.__dict__, "__aenter__"], false]
    - ["dc3046017", operator.contains, [decimal.Overflow.__dict__,         "__aenter__"], false]
    - ["dc3046018", operator.contains, [decimal.Underflow.__dict__,        "__aenter__"], false]

# ---------------------------------------------------------------------------
# combined — all three dunder checks across the full set of decimal types
#
# 6 types x 3 operators = 18 core rows; padded to 24 with additional coverage.
# All values are false: none of the decimal types define any of these hooks
# in their own __dict__.
# ---------------------------------------------------------------------------

