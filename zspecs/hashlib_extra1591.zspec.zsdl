spec: hashlib_extra1591
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — descriptor protocol checks via __dict__.__contains__ for hashlib hash object types"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "hashlib hash objects are C extension types; they do not implement the descriptor protocol (__get__, __set__, __delete__)."
    - "Hash object types expose protocol methods: update, digest, hexdigest, copy, block_size, digest_size, name."
    - "hashlib.algorithms_guaranteed and hashlib.algorithms_available are frozensets of algorithm name strings."
  created_at: "2026-04-12"
error_model: python_exceptions

table hashlib_extra1591.hash_type_no_descriptor:
  description: "hashlib hash object types do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1591nd

  columns: [id, function, args, expected]
  rows:
    - ["hl1591nd001", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__get__"],    false]
    - ["hl1591nd002", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__set__"],    false]
    - ["hl1591nd003", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__delete__"], false]
    - ["hl1591nd004", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__get__"],    false]
    - ["hl1591nd005", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__set__"],    false]
    - ["hl1591nd006", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__delete__"], false]
    - ["hl1591nd007", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__get__"],    false]
    - ["hl1591nd008", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__set__"],    false]
    - ["hl1591nd009", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__delete__"], false]
    - ["hl1591nd010", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__get__"],    false]
    - ["hl1591nd011", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__set__"],    false]
    - ["hl1591nd012", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__delete__"], false]
    - ["hl1591nd013", "type(hashlib.sha224(b'')).__dict__.__contains__", ["__get__"],    false]
    - ["hl1591nd014", "type(hashlib.sha224(b'')).__dict__.__contains__", ["__set__"],    false]
    - ["hl1591nd015", "type(hashlib.sha224(b'')).__dict__.__contains__", ["__delete__"], false]
    - ["hl1591nd016", "type(hashlib.sha384(b'')).__dict__.__contains__", ["__get__"],    false]
    - ["hl1591nd017", "type(hashlib.sha384(b'')).__dict__.__contains__", ["__set__"],    false]
    - ["hl1591nd018", "type(hashlib.sha384(b'')).__dict__.__contains__", ["__delete__"], false]
    - ["hl1591nd019", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__set_name__"], false]
    - ["hl1591nd020", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__set_name__"], false]
    - ["hl1591nd021", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__set_name__"], false]

table hashlib_extra1591.hash_protocol_present:
  description: "hashlib hash object types define the standard hash protocol methods in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1591pp

  columns: [id, function, args, expected]
  rows:
    - ["hl1591pp001", "type(hashlib.md5(b'')).__dict__.__contains__",    ["update"],     true]
    - ["hl1591pp002", "type(hashlib.md5(b'')).__dict__.__contains__",    ["digest"],     true]
    - ["hl1591pp003", "type(hashlib.md5(b'')).__dict__.__contains__",    ["hexdigest"],  true]
    - ["hl1591pp004", "type(hashlib.md5(b'')).__dict__.__contains__",    ["copy"],       true]
    - ["hl1591pp005", "type(hashlib.md5(b'')).__dict__.__contains__",    ["digest_size"], true]
    - ["hl1591pp006", "type(hashlib.md5(b'')).__dict__.__contains__",    ["block_size"], true]
    - ["hl1591pp007", "type(hashlib.md5(b'')).__dict__.__contains__",    ["name"],       true]
    - ["hl1591pp008", "type(hashlib.sha256(b'')).__dict__.__contains__", ["update"],     true]
    - ["hl1591pp009", "type(hashlib.sha256(b'')).__dict__.__contains__", ["digest"],     true]
    - ["hl1591pp010", "type(hashlib.sha256(b'')).__dict__.__contains__", ["hexdigest"],  true]
    - ["hl1591pp011", "type(hashlib.sha256(b'')).__dict__.__contains__", ["copy"],       true]
    - ["hl1591pp012", "type(hashlib.sha256(b'')).__dict__.__contains__", ["digest_size"], true]
    - ["hl1591pp013", "type(hashlib.sha256(b'')).__dict__.__contains__", ["block_size"], true]
    - ["hl1591pp014", "type(hashlib.sha256(b'')).__dict__.__contains__", ["name"],       true]
    - ["hl1591pp015", "type(hashlib.sha512(b'')).__dict__.__contains__", ["update"],     true]
    - ["hl1591pp016", "type(hashlib.sha512(b'')).__dict__.__contains__", ["digest"],     true]
    - ["hl1591pp017", "type(hashlib.sha512(b'')).__dict__.__contains__", ["hexdigest"],  true]
    - ["hl1591pp018", "type(hashlib.sha512(b'')).__dict__.__contains__", ["copy"],       true]
    - ["hl1591pp019", "type(hashlib.sha512(b'')).__dict__.__contains__", ["digest_size"], true]
    - ["hl1591pp020", "type(hashlib.sha512(b'')).__dict__.__contains__", ["block_size"], true]
    - ["hl1591pp021", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["update"],     true]
    - ["hl1591pp022", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["digest"],     true]
    - ["hl1591pp023", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["hexdigest"],  true]
    - ["hl1591pp024", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["copy"],       true]

table hashlib_extra1591.algorithms_set_membership:
  description: "hashlib.algorithms_guaranteed and algorithms_available are frozensets containing expected algorithm names"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1591as

  columns: [id, function, args, expected]
  rows:
    - ["hl1591as001", "isinstance(hashlib.algorithms_guaranteed, frozenset).__eq__", [true],  true]
    - ["hl1591as002", "isinstance(hashlib.algorithms_available, frozenset).__eq__",  [true],  true]
    - ["hl1591as003", "hashlib.algorithms_guaranteed.__contains__", ["md5"],    true]
    - ["hl1591as004", "hashlib.algorithms_guaranteed.__contains__", ["sha1"],   true]
    - ["hl1591as005", "hashlib.algorithms_guaranteed.__contains__", ["sha256"], true]
    - ["hl1591as006", "hashlib.algorithms_guaranteed.__contains__", ["sha512"], true]
    - ["hl1591as007", "hashlib.algorithms_guaranteed.__contains__", ["sha224"], true]
    - ["hl1591as008", "hashlib.algorithms_guaranteed.__contains__", ["sha384"], true]
    - ["hl1591as009", "hashlib.algorithms_available.__contains__",  ["md5"],    true]
    - ["hl1591as010", "hashlib.algorithms_available.__contains__",  ["sha256"], true]
    - ["hl1591as011", "hashlib.algorithms_available.__contains__",  ["sha512"], true]
    - ["hl1591as012", "hashlib.algorithms_guaranteed.__contains__", ["notanalgorithm"], false]
    - ["hl1591as013", "hashlib.algorithms_guaranteed.__contains__", ["MD5"],    false]
    - ["hl1591as014", "hashlib.algorithms_guaranteed.__contains__", ["SHA256"], false]
    - ["hl1591as015", "hashlib.algorithms_guaranteed.__class__.__name__.__eq__", ["frozenset"], true]
    - ["hl1591as016", "hashlib.algorithms_available.__class__.__name__.__eq__",  ["frozenset"], true]
    - ["hl1591as017", "hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available).__eq__", [true], true]
    - ["hl1591as018", "isinstance(hashlib.algorithms_guaranteed, set).__eq__",  [false], true]
    - ["hl1591as019", "isinstance(hashlib.algorithms_available, set).__eq__",   [false], true]
    - ["hl1591as020", "hashlib.algorithms_guaranteed.__contains__", ["sha3_256"], true]
    - ["hl1591as021", "hashlib.algorithms_guaranteed.__contains__", ["sha3_512"], true]
    - ["hl1591as022", "hashlib.algorithms_guaranteed.__contains__", ["blake2b"], true]
    - ["hl1591as023", "hashlib.algorithms_guaranteed.__contains__", ["blake2s"], true]
