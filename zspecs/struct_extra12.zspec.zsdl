spec: struct_extra12
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__; pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__; pack(>I,65536)/(<I,65536)/(>i,-256); calcsize(>i/<i/>I)."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
    - "struct_extra8.zspec.zsdl — function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct_extra9.zspec.zsdl — calcsize('c'/'P'); Struct method descriptor __qualname__ table; Struct method descriptor __name__ table."
    - "struct_extra10.zspec.zsdl — pack/unpack('>BB',0,255); pack/unpack('<I',1); calcsize('<f'/'<d'); Struct('>BB') format/size; pack('>i',0/-1)."
    - "struct_extra11.zspec.zsdl — pack('>I',305419896); pack('<H',256); pack('!f',1.0) length; unpack('>I',12345678); calcsize('!BHI'/'3s'); Struct __name__/__module__; error.__module__; pack/unpack('>H',1000); pack('>B',127)."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior struct spec."
    - "struct.pack('<H', 1) == b'\\x01\\x00' — little-endian uint16 value 1; prior specs pack '<H' with 256 (extra11) but not 1."
    - "struct.pack('<H', 256) already covered in extra11; this spec adds '<H' with 1 and 65535 for completeness."
    - "struct.pack('>b', 127) already covered in extra6; this spec anchors it in extra12 namespace as a table row."
    - "struct.pack('>b', -128) already covered in extra6; re-anchored as table row in extra12 namespace."
    - "struct.unpack('<H', b'\\x01\\x00') == (1,) — little-endian uint16 decode of value 1; not in any prior spec."
    - "struct.unpack('<H', b'\\xff\\xff') == (65535,) — little-endian uint16 max value decode; not in any prior spec."
    - "struct.unpack('>i', b'\\xff\\xff\\xff\\xff') == (-1,) — big-endian signed int -1; extra10 packs '>i' with -1 but no prior spec unpacks '>i' from FFFFFFFF."
    - "struct.calcsize('<H') == 2 — little-endian unsigned short is 2 bytes; prior calcsize specs use '>H' but not '<H' standalone."
    - "struct.calcsize('<I') == 4 — little-endian unsigned int is 4 bytes; prior specs use '<I' for pack/unpack but not standalone calcsize."
    - "struct.calcsize('>i') == 4 — big-endian signed int is 4 bytes; prior specs use '>i' for pack/unpack but not standalone calcsize."
    - "struct.calcsize('>b') == 1 — big-endian signed byte is 1 byte; no prior spec checks calcsize for '>b' standalone."
    - "struct.calcsize('!H') == 2 — network byte order unsigned short is 2 bytes; prior calcsize specs use '!BHI'/'!5s'/'!3p' but not bare '!H'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pack — byte-order variants not yet covered together
#
# Table collects little-endian and signed-format pack vectors.
# '<H' with value 1 is new; '>b' boundary values anchor in extra12 namespace.
# ---------------------------------------------------------------------------

table struct_extra12.pack_variants:
  kind: python_call_eq
  category: pack_values
  id_prefix: pack12

  columns: [id, function, args, expected]
  rows:
    - [le_uint16_one,     pack, ["<H", 1],    !hex 0100]
    - [le_uint16_max,     pack, ["<H", 65535], !hex FFFF]
    - [be_int8_max,       pack, [">b", 127],   !hex 7F]
    - [be_int8_min,       pack, [">b", -128],  !hex 80]
    - [le_uint32_two,     pack, ["<I", 2],     !hex 02000000]

# ---------------------------------------------------------------------------
# unpack — little-endian and signed variants
#
# unpack('<H', \x01\x00) == (1,) and unpack('<H', \xff\xff) == (65535,) are new.
# unpack('>i', \xff\xff\xff\xff) == (-1,) is new (extra10 packs but does not unpack).
# Results are YAML sequences (lists) as ZSDL maps tuples to lists.
# ---------------------------------------------------------------------------

table struct_extra12.unpack_variants:
  kind: python_call_eq
  category: unpack_values
  id_prefix: unpack12

  columns: [id, function, args, expected]
  rows:
    - [le_uint16_one,      unpack, ["<H", !hex 0100],     [1]]
    - [le_uint16_max,      unpack, ["<H", !hex FFFF],     [65535]]
    - [be_int32_minus_one, unpack, [">i", !hex FFFFFFFF], [-1]]

# ---------------------------------------------------------------------------
# calcsize — byte-order prefix variants not yet covered standalone
#
# '<H', '<I', '>i', '>b' have not appeared as standalone calcsize invariants.
# '!H' (network byte order) gives 2, the same as '>H' — a separate format string.
# ---------------------------------------------------------------------------

table struct_extra12.calcsize_variants:
  kind: python_call_eq
  category: calcsize
  id_prefix: calcsize12

  columns: [id, function, args, expected]
  rows:
    - [le_uint16,     calcsize, ["<H"],  2]
    - [le_uint32,     calcsize, ["<I"],  4]
    - [be_int32,      calcsize, [">i"],  4]
    - [be_int8,       calcsize, [">b"],  1]
    - [net_uint16,    calcsize, ["!H"],  2]

# ---------------------------------------------------------------------------
# pack('<H', 256) — round-trip with calcsize sanity check
#
# struct_extra11 covers pack('<H', 256) as a standalone invariant.
# This invariant confirms the packed output length via method: __len__,
# a new axis combining '<H' + value 256 + length check — not in extra11.
# ---------------------------------------------------------------------------

invariant struct_extra12.pack.le_uint16_256_length:
  description: "len(struct.pack('<H', 256)) == 2 — little-endian uint16 always occupies 2 bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["<H", 256]
  method: __len__
  method_args: []
  expected: 2

# ---------------------------------------------------------------------------
# pack('>b', 0) — signed byte zero
#
# Boundary values 127 and -128 for '>b' are covered by extra6 and re-anchored
# in this spec's table. The zero value for '>b' is a new mid-point vector.
# ---------------------------------------------------------------------------

invariant struct_extra12.pack.be_int8_zero:
  description: "struct.pack('>b', 0) == b'\\x00' — big-endian signed byte zero"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">b", 0]
  expected: !hex 00
