spec: itertools_extra262
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers classnames and first_element for chain, islice, count, cycle, repeat, accumulate, compress, product, combinations, permutations, dropwhile, takewhile, zip_longest"
    - "itertools_extra.zspec.zsdl — covers filterfalse, chain length_hint, bounded repeat, islice length_hint"
    - "itertools_extra261.zspec.zsdl — covers repeat, cycle, groupby class identity and __new__.__qualname__"
  notes:
    - "itertools.chain is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "itertools.islice is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "itertools.takewhile is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "itertools.dropwhile is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "itertools.compress is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "list(chain([1,2],[3,4])) == [1,2,3,4]; list(chain.from_iterable([[1,2],[3,4]])) == [1,2,3,4]."
    - "list(islice(count(0), 3)) == [0,1,2]; list(islice(repeat(7), 3)) == [7,7,7]."
    - "list(takewhile(lambda x: x<3, [1,2,3,4])) == [1,2]; list(dropwhile(lambda x: x<3, [1,2,3,4])) == [3,4]."
    - "list(compress('ABCDE', [1,0,1,0,1])) == ['A','C','E']."
    - "chain.__new__.__qualname__ == 'chain.__new__'; islice.__new__.__qualname__ == 'islice.__new__'."
    - "takewhile.__new__.__qualname__ == 'takewhile.__new__'; dropwhile.__new__.__qualname__ == 'dropwhile.__new__'."
    - "compress.__new__.__qualname__ == 'compress.__new__'."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain — class identity and __new__.__qualname__
# ---------------------------------------------------------------------------

invariant itertools_extra262.chain.name:
  description: "itertools.chain.__name__ == 'chain'"
  category: identity
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra262.chain.module:
  description: "itertools.chain.__module__ == 'itertools'"
  category: identity
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra262.chain.base_name:
  description: "itertools.chain.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: chain.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant itertools_extra262.chain.new_qualname:
  description: "itertools.chain.__new__.__qualname__ == 'chain.__new__'"
  category: identity
  kind: python_call_eq
  function: chain.__new__.__qualname__.__eq__
  args: ["chain.__new__"]
  expected: true

