# ---------------------------------------------------------------------------
# class_types table — chain, islice, takewhile, dropwhile, compress are all type objects
# ---------------------------------------------------------------------------

table itertools_extra262.class_types:
  description: "chain, islice, takewhile, dropwhile, compress are all C-level type objects"
  kind: python_call_eq
  category: identity
  id_prefix: ctype

  columns: [id, function, args, expected]
  rows:
    - [chain,     chain.__class__.__name__.__eq__,     ["type"], true]
    - [islice,    islice.__class__.__name__.__eq__,    ["type"], true]
    - [takewhile, takewhile.__class__.__name__.__eq__, ["type"], true]
    - [dropwhile, dropwhile.__class__.__name__.__eq__, ["type"], true]
    - [compress,  compress.__class__.__name__.__eq__,  ["type"], true]
