spec: pathlib_extra185
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers: pathlib.PurePath and pathlib.Path dunder method names — __fspath__, __str__, __repr__, __hash__, __eq__, __lt__, __truediv__, __rtruediv__."
    - "pathlib.Path.__fspath__.__name__ == '__fspath__' (len=10); pathlib.PurePath.__str__.__name__ == '__str__' (len=7)."
    - "pathlib.PurePath.__repr__.__name__ == '__repr__' (len=8); pathlib.PurePath.__hash__.__name__ == '__hash__' (len=8)."
    - "__repr__ (8) == __hash__ (8): a 2-way tie at length 8."
    - "pathlib.PurePath.__eq__.__name__ == '__eq__' (len=6); pathlib.PurePath.__lt__.__name__ == '__lt__' (len=6)."
    - "__eq__ (6) == __lt__ (6): a 2-way tie at length 6."
    - "pathlib.PurePath.__truediv__.__name__ == '__truediv__' (len=11); pathlib.PurePath.__rtruediv__.__name__ == '__rtruediv__' (len=12)."
    - "__truediv__ (11) < __rtruediv__ (12): __rtruediv__ is 1 character longer due to the 'r' prefix."
    - "Length ordering: __eq__==__lt__ (6) < __str__ (7) < __repr__==__hash__ (8) < __fspath__ (10) < __truediv__ (11) < __rtruediv__ (12)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath short dunder names (__eq__, __lt__, __str__)
# __eq__==__lt__ (6): a 2-way tie; __str__ (7) > them by 1
# ---------------------------------------------------------------------------

table pathlib_extra185.short_dunder_names:
  description: "pathlib.PurePath short dunder names: __eq__.__name__=='__eq__' (len=6); __lt__.__name__=='__lt__' (len=6); __str__.__name__=='__str__' (len=7); __eq__==__lt__ (6) < __str__ (7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdunders185

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name,      "PurePath.__eq__.__name__.__eq__",       ["__eq__"],  true, "pathlib.PurePath.__eq__.__name__ == '__eq__' — __eq__ implements path equality comparison (case-sensitive on POSIX, case-insensitive on Windows); '__eq__' has 6 characters: _(1)_(2)e(3)q(4)_(5)_(6); __eq__ (6) == __lt__ (6): a 2-way tie at length 6; __eq__ (6) < __str__ (7); confirmed Python 3.14.3 macOS"]
    - [eq_name_len,  "PurePath.__eq__.__name__.__len__",      [],          6,    "pathlib.PurePath.__eq__.__name__.__len__() == 6 — '__eq__' has 6 characters; __eq__ (6) == __lt__ (6): a 2-way tie; __eq__==__lt__ (6) < __str__ (7) < __repr__==__hash__ (8) < __fspath__ (9) < __truediv__ (11) < __rtruediv__ (12): the full length ordering; confirmed Python 3.14.3 macOS"]
    - [lt_name,      "PurePath.__lt__.__name__.__eq__",       ["__lt__"],  true, "pathlib.PurePath.__lt__.__name__ == '__lt__' — __lt__ implements the < ordering for paths (used for sorting path objects); '__lt__' has 6 characters: _(1)_(2)l(3)t(4)_(5)_(6); __lt__ (6) == __eq__ (6): both comparison dunders share length 6; confirmed Python 3.14.3 macOS"]
    - [lt_name_len,  "PurePath.__lt__.__name__.__len__",      [],          6,    "pathlib.PurePath.__lt__.__name__.__len__() == 6 — '__lt__' has 6 characters; __lt__ (6) == __eq__ (6): both share length 6; __eq__==__lt__ (6) < __str__ (7): the comparison dunders are shorter than __str__; confirmed Python 3.14.3 macOS"]
    - [str_name,     PurePath.__str__.__name__.__eq__,        ["__str__"], true, "pathlib.PurePath.__str__.__name__ == '__str__' — __str__ returns the path as a string (e.g., '/usr/bin'); '__str__' has 7 characters: _(1)_(2)s(3)t(4)r(5)_(6)_(7); __str__ (7) > __eq__==__lt__ (6) by 1; __str__ (7) < __repr__==__hash__ (8) by 1; confirmed Python 3.14.3 macOS"]
    - [str_name_len, PurePath.__str__.__name__.__len__,       [],          7,    "pathlib.PurePath.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; __eq__==__lt__ (6) < __str__ (7) < __repr__==__hash__ (8): __str__ is strictly between the two flanking groups; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PurePath medium dunder names (__repr__, __hash__, __fspath__)
# __repr__==__hash__ (8): a 2-way tie; __fspath__ (9) > them by 1
# ---------------------------------------------------------------------------

table pathlib_extra185.medium_dunder_names:
  description: "pathlib.PurePath/__fspath__ medium dunder names: __repr__.__name__=='__repr__' (len=8); __hash__.__name__=='__hash__' (len=8); Path.__fspath__.__name__=='__fspath__' (len=9); __repr__==__hash__ (8) < __fspath__ (9)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdunders185

  columns: [id, function, args, expected, description]
  rows:
    - [repr_name,      PurePath.__repr__.__name__.__eq__,     ["__repr__"],  true, "pathlib.PurePath.__repr__.__name__ == '__repr__' — __repr__ returns a string like PurePosixPath('/usr/bin'); '__repr__' has 8 characters: _(1)_(2)r(3)e(4)p(5)r(6)_(7)_(8); __repr__ (8) == __hash__ (8): a 2-way tie at length 8; __str__ (7) < __repr__==__hash__ (8) < __fspath__ (9); confirmed Python 3.14.3 macOS"]
    - [repr_name_len,  PurePath.__repr__.__name__.__len__,    [],            8,    "pathlib.PurePath.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters; __repr__ (8) == __hash__ (8): both share length 8; __str__ (7) < __repr__==__hash__ (8) < __fspath__ (9): __repr__ and __hash__ are in the middle length tier; confirmed Python 3.14.3 macOS"]
    - [hash_name,      PurePath.__hash__.__name__.__eq__,     ["__hash__"],  true, "pathlib.PurePath.__hash__.__name__ == '__hash__' — __hash__ enables path objects to be used as dictionary keys and in sets; '__hash__' has 8 characters: _(1)_(2)h(3)a(4)s(5)h(6)_(7)_(8); __hash__ (8) == __repr__ (8): both share length 8; confirmed Python 3.14.3 macOS"]
    - [hash_name_len,  PurePath.__hash__.__name__.__len__,    [],            8,    "pathlib.PurePath.__hash__.__name__.__len__() == 8 — '__hash__' has 8 characters; __hash__ (8) == __repr__ (8): a 2-way tie; __str__ (7) < __repr__==__hash__ (8) < __fspath__ (9): the 2-way tie at 8 is flanked by 7 and 9; confirmed Python 3.14.3 macOS"]
    - [fspath_name,    Path.__fspath__.__name__.__eq__,       ["__fspath__"], true, "pathlib.Path.__fspath__.__name__ == '__fspath__' — __fspath__ implements the os.fspath() protocol, returning the path as a string; '__fspath__' has 10 characters: _(1)_(2)f(3)s(4)p(5)a(6)t(7)h(8)_(9)_(10); __repr__==__hash__ (8) < __fspath__ (10) < __truediv__ (11): __fspath__ is between the 8-character group and __truediv__; confirmed Python 3.14.3 macOS"]
    - [fspath_name_len, Path.__fspath__.__name__.__len__,     [],            10,   "pathlib.Path.__fspath__.__name__.__len__() == 10 — '__fspath__' has 10 characters: _(1)_(2)f(3)s(4)p(5)a(6)t(7)h(8)_(9)_(10); __repr__==__hash__ (8) < __fspath__ (10) < __truediv__ (11): __fspath__ is between the 8-character group and __truediv__; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePath division dunder names (__truediv__, __rtruediv__)
# __truediv__ (11) < __rtruediv__ (12): the / and r/ path-join operators
# ---------------------------------------------------------------------------

table pathlib_extra185.division_dunder_names:
  description: "pathlib.PurePath division operator dunder names: __truediv__.__name__=='__truediv__' (len=11); __rtruediv__.__name__=='__rtruediv__' (len=12); __truediv__ (11) < __rtruediv__ (12) by 1; these are the longest covered dunder names"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdunders185

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_name,      "PurePath.__truediv__.__name__.__eq__",   ["__truediv__"],  true, "pathlib.PurePath.__truediv__.__name__ == '__truediv__' — __truediv__ implements the / operator for path joining (e.g., Path('/usr') / 'bin' == Path('/usr/bin')); '__truediv__' has 11 characters: _(1)_(2)t(3)r(4)u(5)e(6)d(7)i(8)v(9)_(10)_(11); __truediv__ (11) < __rtruediv__ (12) by 1; confirmed Python 3.14.3 macOS"]
    - [truediv_name_len,  "PurePath.__truediv__.__name__.__len__",  [],               11,   "pathlib.PurePath.__truediv__.__name__.__len__() == 11 — '__truediv__' has 11 characters; __fspath__ (10) < __truediv__ (11) < __rtruediv__ (12): __truediv__ is in the upper tier of the length ordering; confirmed Python 3.14.3 macOS"]
    - [rtruediv_name,     "PurePath.__rtruediv__.__name__.__eq__",  ["__rtruediv__"], true, "pathlib.PurePath.__rtruediv__.__name__ == '__rtruediv__' — __rtruediv__ implements the reflected / operator for path joining (e.g., 'base' / path_obj); '__rtruediv__' has 12 characters: _(1)_(2)r(3)t(4)r(5)u(6)e(7)d(8)i(9)v(10)_(11)_(12); __rtruediv__ (12) > __truediv__ (11) by 1: the 'r' prefix adds one character; __rtruediv__ (12) is the longest covered dunder name; confirmed Python 3.14.3 macOS"]
    - [rtruediv_name_len, "PurePath.__rtruediv__.__name__.__len__", [],               12,   "pathlib.PurePath.__rtruediv__.__name__.__len__() == 12 — '__rtruediv__' has 12 characters; __rtruediv__ (12) > __truediv__ (11) by 1; __rtruediv__ (12) is the maximum length in the full ordering: __eq__==__lt__ (6) < __str__ (7) < __repr__==__hash__ (8) < __fspath__ (10) < __truediv__ (11) < __rtruediv__ (12); confirmed Python 3.14.3 macOS"]
    - [truediv_class,     "PurePath.__truediv__.__class__.__name__.__eq__",  ["function"], true, "pathlib.PurePath.__truediv__.__class__.__name__ == 'function' — __truediv__ is a Python function (pathlib is a pure-Python module); all PurePath dunders covered are Python functions; confirmed Python 3.14.3 macOS"]
    - [rtruediv_class,    "PurePath.__rtruediv__.__class__.__name__.__eq__", ["function"], true, "pathlib.PurePath.__rtruediv__.__class__.__name__ == 'function' — __rtruediv__ is a Python function; __rtruediv__ (12) > __truediv__ (11): both are Python functions but __rtruediv__ has the longer name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra185.fspath_name_is_dunder_fspath:
  description: "pathlib.Path.__fspath__.__name__ == '__fspath__' — __fspath__ implements the os.fspath() protocol; len=10 ('__fspath__' = 10 chars); __repr__==__hash__ (8) < __fspath__ (10) < __truediv__ (11); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.__fspath__.__name__.__eq__
  args: ["__fspath__"]
  expected: true

invariant pathlib_extra185.str_name_is_dunder_str:
  description: "pathlib.PurePath.__str__.__name__ == '__str__' — __str__ returns the path string; len=7; __eq__==__lt__ (6) < __str__ (7) < __repr__==__hash__ (8): __str__ is strictly between the two flanking groups; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

invariant pathlib_extra185.repr_name_len_is_8:
  description: "pathlib.PurePath.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters; __repr__ (8) == __hash__ (8): a 2-way tie at length 8; __str__ (7) < __repr__==__hash__ (8) < __fspath__ (10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__repr__.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra185.hash_name_len_is_8:
  description: "pathlib.PurePath.__hash__.__name__.__len__() == 8 — '__hash__' has 8 characters; __hash__ (8) == __repr__ (8): a 2-way tie; __repr__==__hash__ (8) is flanked by __str__ (7) on the left and __fspath__ (10) on the right; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__hash__.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra185.eq_name_len_is_6:
  description: "pathlib.PurePath.__eq__.__name__.__len__() == 6 — '__eq__' has 6 characters; __eq__ (6) == __lt__ (6): a 2-way tie at length 6; __eq__==__lt__ (6) is the minimum length group in the full ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__eq__.__name__.__len__"
  args: []
  expected: 6

invariant pathlib_extra185.lt_name_is_dunder_lt:
  description: "pathlib.PurePath.__lt__.__name__ == '__lt__' — __lt__ enables sorting of path objects; len=6; __lt__ (6) == __eq__ (6): both comparison dunders share length 6 — a 2-way tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__lt__.__name__.__eq__"
  args: ["__lt__"]
  expected: true

invariant pathlib_extra185.truediv_name_is_dunder_truediv:
  description: "pathlib.PurePath.__truediv__.__name__ == '__truediv__' — __truediv__ is the / path-join operator; len=11; __fspath__ (10) < __truediv__ (11) < __rtruediv__ (12): __truediv__ is strictly between __fspath__ and __rtruediv__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__truediv__.__name__.__eq__"
  args: ["__truediv__"]
  expected: true

invariant pathlib_extra185.rtruediv_name_len_is_12:
  description: "pathlib.PurePath.__rtruediv__.__name__.__len__() == 12 — '__rtruediv__' has 12 characters; __rtruediv__ (12) is the longest covered dunder name; __truediv__ (11) < __rtruediv__ (12): the 'r' prefix adds 1 character; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__rtruediv__.__name__.__len__"
  args: []
  expected: 12

