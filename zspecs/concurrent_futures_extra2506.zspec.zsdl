spec: concurrent_futures_extra2506
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence checks."
    - "concurrent.futures.Future and concurrent.futures.Executor define no arithmetic operators."
    - "__dict__.__contains__ returns False for __add__, __sub__, __mul__ on both classes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — arithmetic operator dict-presence
# ---------------------------------------------------------------------------

table concurrent_futures_extra2506.future_arith_ops:
  description: "concurrent.futures.Future.__dict__ contains no arithmetic operators (__add__, __sub__, __mul__); all __dict__.__contains__ calls return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2506

  columns: [id, function, args, expected]
  rows:
    - ["cf2506001", concurrent.futures.Future.__dict__.__contains__, ["__add__"], false]
    - ["cf2506002", concurrent.futures.Future.__dict__.__contains__, ["__sub__"], false]
    - ["cf2506003", concurrent.futures.Future.__dict__.__contains__, ["__mul__"], false]

