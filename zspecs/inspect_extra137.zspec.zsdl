spec: inspect_extra137
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.isbuiltin, inspect.isroutine, inspect.isabstract, inspect.ismethoddescriptor, inspect.isasyncgenfunction, inspect.isasyncgen — qualname, co_argcount, co_varnames (Wave 265)."
    - "inspect.isbuiltin.__qualname__ == 'isbuiltin' (len 9) — defined at module scope in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1 — takes object. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_varnames == ('object',) — len 1. Verified with Python 3.14.3."
    - "inspect.isroutine.__qualname__ == 'isroutine' (len 9). Verified with Python 3.14.3."
    - "inspect.isroutine.__code__.co_argcount == 1 — takes object. Verified with Python 3.14.3."
    - "inspect.isroutine.__code__.co_varnames == ('object',) — len 1. Verified with Python 3.14.3."
    - "inspect.isabstract.__qualname__ == 'isabstract' (len 10). Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_argcount == 1 — takes object. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_varnames len 4 — object, name, value, base. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__qualname__ == 'ismethoddescriptor' (len 18). Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__code__.co_argcount == 1 — takes object. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__code__.co_varnames len 2 — object, tp. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__qualname__ == 'isasyncgenfunction' (len 18). Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_argcount == 1 — takes obj. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_varnames == ('obj',) — len 1. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__qualname__ == 'isasyncgen' (len 10). Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_argcount == 1 — takes object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isbuiltin and inspect.isroutine — qualname and code attrs
#
# Wave 265 theme: inspect predicate functions for C builtins and routines.
#
# inspect.isbuiltin.__qualname__ == 'isbuiltin' (len 9)
# inspect.isbuiltin.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_varnames == ('object',) len 1
# inspect.isroutine.__qualname__ == 'isroutine' (len 9)
# inspect.isroutine.__code__.co_argcount == 1
# inspect.isroutine.__code__.co_varnames == ('object',) len 1
#
# Both are Python functions defined at module scope in Lib/inspect.py.
# New to extra137.
# ---------------------------------------------------------------------------

table inspect_extra137.isbuiltin_isroutine_identity:
  description: "inspect.isbuiltin and isroutine: qualnames len 9, co_argcount==1, co_varnames len 1; wave 265; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectisbuiltin137

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_qualname_eq,
       "isbuiltin.__qualname__.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — isbuiltin is defined at module scope in Lib/inspect.py; its __qualname__ is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra137"]
    - [isbuiltin_qualname_len_eq_9,
       "isbuiltin.__qualname__.__len__",
       [],
       9,
       "inspect.isbuiltin.__qualname__.__len__() == 9 — __qualname__ is 'isbuiltin' which has 9 characters; len('isbuiltin') == 9; new to extra137"]
    - [isbuiltin_co_argcount_eq_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra137"]
    - [isbuiltin_co_varnames_len_eq_1,
       "isbuiltin.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isbuiltin.__code__.co_varnames.__len__() == 1 — co_varnames has 1 entry: 'object'; len() == 1; new to extra137"]
    - [isbuiltin_co_varnames_0_eq_object,
       "isbuiltin.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.isbuiltin.__code__.co_varnames[0].__eq__('object') == True — the only local variable of isbuiltin is 'object', the object being tested; str.__eq__('object') returns True; new to extra137"]
    - [isroutine_qualname_eq,
       "isroutine.__qualname__.__eq__",
       ["isroutine"],
       true,
       "inspect.isroutine.__qualname__.__eq__('isroutine') == True — isroutine is defined at module scope in Lib/inspect.py; its __qualname__ is 'isroutine'; str.__eq__('isroutine') returns True; new to extra137"]
    - [isroutine_qualname_len_eq_9,
       "isroutine.__qualname__.__len__",
       [],
       9,
       "inspect.isroutine.__qualname__.__len__() == 9 — __qualname__ is 'isroutine' which has 9 characters; len('isroutine') == 9; new to extra137"]
    - [isroutine_co_argcount_eq_1,
       "isroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isroutine.__code__.co_argcount.__eq__(1) == True — isroutine takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra137"]
    - [isroutine_co_varnames_len_eq_1,
       "isroutine.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isroutine.__code__.co_varnames.__len__() == 1 — co_varnames has 1 entry: 'object'; len() == 1; new to extra137"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isabstract and inspect.ismethoddescriptor — qualname and code attrs
#
# Wave 265 theme: inspect predicates for abstract and method-descriptor checks.
#
# inspect.isabstract.__qualname__ == 'isabstract' (len 10)
# inspect.isabstract.__code__.co_argcount == 1
# len(inspect.isabstract.__code__.co_varnames) == 4 — object, name, value, base
# inspect.ismethoddescriptor.__qualname__ == 'ismethoddescriptor' (len 18)
# inspect.ismethoddescriptor.__code__.co_argcount == 1
# len(inspect.ismethoddescriptor.__code__.co_varnames) == 2 — object, tp
#
# Both are Python functions defined at module scope in Lib/inspect.py.
# New to extra137.
# ---------------------------------------------------------------------------

table inspect_extra137.isabstract_ismethoddescriptor_identity:
  description: "inspect.isabstract and ismethoddescriptor: qualnames, co_argcount==1, co_varnames lengths; wave 265; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectisabstract137

  columns: [id, function, args, expected, description]
  rows:
    - [isabstract_qualname_eq,
       "isabstract.__qualname__.__eq__",
       ["isabstract"],
       true,
       "inspect.isabstract.__qualname__.__eq__('isabstract') == True — isabstract is defined at module scope in Lib/inspect.py; its __qualname__ is 'isabstract'; str.__eq__('isabstract') returns True; new to extra137"]
    - [isabstract_qualname_len_eq_10,
       "isabstract.__qualname__.__len__",
       [],
       10,
       "inspect.isabstract.__qualname__.__len__() == 10 — __qualname__ is 'isabstract' which has 10 characters; len('isabstract') == 10; new to extra137"]
    - [isabstract_co_argcount_eq_1,
       "isabstract.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isabstract.__code__.co_argcount.__eq__(1) == True — isabstract takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra137"]
    - [isabstract_co_varnames_len_eq_4,
       "isabstract.__code__.co_varnames.__len__",
       [],
       4,
       "inspect.isabstract.__code__.co_varnames.__len__() == 4 — co_varnames has 4 entries: object, name, value, base; len() == 4; new to extra137"]
    - [ismethoddescriptor_qualname_eq,
       "ismethoddescriptor.__qualname__.__eq__",
       ["ismethoddescriptor"],
       true,
       "inspect.ismethoddescriptor.__qualname__.__eq__('ismethoddescriptor') == True — ismethoddescriptor is defined at module scope in Lib/inspect.py; its __qualname__ is 'ismethoddescriptor'; str.__eq__('ismethoddescriptor') returns True; new to extra137"]
    - [ismethoddescriptor_qualname_len_eq_18,
       "ismethoddescriptor.__qualname__.__len__",
       [],
       18,
       "inspect.ismethoddescriptor.__qualname__.__len__() == 18 — __qualname__ is 'ismethoddescriptor' which has 18 characters; len('ismethoddescriptor') == 18; new to extra137"]
    - [ismethoddescriptor_co_argcount_eq_1,
       "ismethoddescriptor.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismethoddescriptor.__code__.co_argcount.__eq__(1) == True — ismethoddescriptor takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra137"]
    - [ismethoddescriptor_co_varnames_len_eq_2,
       "ismethoddescriptor.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.ismethoddescriptor.__code__.co_varnames.__len__() == 2 — co_varnames has 2 entries: object, tp; len() == 2; new to extra137"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isasyncgenfunction and inspect.isasyncgen — qualname and code attrs
#
# Wave 265 theme: inspect predicates for async generator introspection.
#
# inspect.isasyncgenfunction.__qualname__ == 'isasyncgenfunction' (len 18)
# inspect.isasyncgenfunction.__code__.co_argcount == 1
# inspect.isasyncgenfunction.__code__.co_varnames == ('obj',) len 1
# inspect.isasyncgen.__qualname__ == 'isasyncgen' (len 10)
# inspect.isasyncgen.__code__.co_argcount == 1
# inspect.isasyncgen.__code__.co_varnames == ('object',) len 1
#
# Both are Python functions defined at module scope in Lib/inspect.py.
# Note isasyncgenfunction uses 'obj' while isasyncgen uses 'object'. New to extra137.
# ---------------------------------------------------------------------------

table inspect_extra137.asyncgen_predicates_identity:
  description: "inspect.isasyncgenfunction and isasyncgen: qualnames, co_argcount==1, co_varnames; wave 265; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectasyncgen137

  columns: [id, function, args, expected, description]
  rows:
    - [isasyncgenfunction_qualname_eq,
       "isasyncgenfunction.__qualname__.__eq__",
       ["isasyncgenfunction"],
       true,
       "inspect.isasyncgenfunction.__qualname__.__eq__('isasyncgenfunction') == True — isasyncgenfunction is defined at module scope in Lib/inspect.py; its __qualname__ is 'isasyncgenfunction'; str.__eq__('isasyncgenfunction') returns True; new to extra137"]
    - [isasyncgenfunction_qualname_len_eq_18,
       "isasyncgenfunction.__qualname__.__len__",
       [],
       18,
       "inspect.isasyncgenfunction.__qualname__.__len__() == 18 — __qualname__ is 'isasyncgenfunction' which has 18 characters; len('isasyncgenfunction') == 18; new to extra137"]
    - [isasyncgenfunction_co_argcount_eq_1,
       "isasyncgenfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgenfunction.__code__.co_argcount.__eq__(1) == True — isasyncgenfunction takes 1 positional-or-keyword argument: obj; co_argcount is 1; int.__eq__(1) returns True; new to extra137"]
    - [isasyncgenfunction_co_varnames_len_eq_1,
       "isasyncgenfunction.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isasyncgenfunction.__code__.co_varnames.__len__() == 1 — co_varnames has 1 entry: 'obj'; len() == 1; new to extra137"]
    - [isasyncgenfunction_co_varnames_0_eq_obj,
       "isasyncgenfunction.__code__.co_varnames[0].__eq__",
       ["obj"],
       true,
       "inspect.isasyncgenfunction.__code__.co_varnames[0].__eq__('obj') == True — the only local variable of isasyncgenfunction is 'obj' (note: differs from other predicates that use 'object'); str.__eq__('obj') returns True; new to extra137"]
    - [isasyncgen_qualname_eq,
       "isasyncgen.__qualname__.__eq__",
       ["isasyncgen"],
       true,
       "inspect.isasyncgen.__qualname__.__eq__('isasyncgen') == True — isasyncgen is defined at module scope in Lib/inspect.py; its __qualname__ is 'isasyncgen'; str.__eq__('isasyncgen') returns True; new to extra137"]
    - [isasyncgen_qualname_len_eq_10,
       "isasyncgen.__qualname__.__len__",
       [],
       10,
       "inspect.isasyncgen.__qualname__.__len__() == 10 — __qualname__ is 'isasyncgen' which has 10 characters; len('isasyncgen') == 10; new to extra137"]
    - [isasyncgen_co_argcount_eq_1,
       "isasyncgen.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgen.__code__.co_argcount.__eq__(1) == True — isasyncgen takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra137"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra137
# ---------------------------------------------------------------------------

invariant inspect_extra137.isbuiltin_qualname_len:
  description: "len(inspect.isbuiltin.__qualname__) == 9 — __qualname__ is 'isbuiltin'; wave 265; new to extra137"
  kind: python_call_eq
  function: isbuiltin.__qualname__.__len__
  args: []
  expected: 9

invariant inspect_extra137.isroutine_co_argcount:
  description: "inspect.isroutine.__code__.co_argcount == 1 — takes object; wave 265; new to extra137"
  kind: python_call_eq
  function: isroutine.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra137.isabstract_co_varnames_len:
  description: "len(inspect.isabstract.__code__.co_varnames) == 4 — object, name, value, base; wave 265; new to extra137"
  kind: python_call_eq
  function: isabstract.__code__.co_varnames.__len__
  args: []
  expected: 4

invariant inspect_extra137.ismethoddescriptor_qualname_len:
  description: "len(inspect.ismethoddescriptor.__qualname__) == 18 — __qualname__ is 'ismethoddescriptor'; wave 265; new to extra137"
  kind: python_call_eq
  function: ismethoddescriptor.__qualname__.__len__
  args: []
  expected: 18

invariant inspect_extra137.isasyncgenfunction_co_varnames_0:
  description: "inspect.isasyncgenfunction.__code__.co_varnames[0] == 'obj' — uses 'obj' not 'object' unlike other predicates; wave 265; new to extra137"
  kind: python_call_eq
  function: "isasyncgenfunction.__code__.co_varnames[0].__eq__"
  args: ["obj"]
  expected: true
