invariant asyncio.boundedsemaphore.base_name:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — inherits from Semaphore"
  category: boundedsemaphore
  kind: python_call_eq
  function: BoundedSemaphore.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Semaphore"

