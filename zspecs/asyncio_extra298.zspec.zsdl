spec: asyncio_extra298
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.Lock and asyncio.Semaphore both inherit from _ContextManagerMixin (bases[0]) and _LoopBoundMixin (bases[1])."
    - "asyncio.Event and asyncio.Queue inherit only from _LoopBoundMixin (bases[0])."
    - "asyncio.BoundedSemaphore inherits from asyncio.locks.Semaphore (single base)."
    - "asyncio.LifoQueue and asyncio.PriorityQueue inherit from asyncio.queues.Queue (single base)."
    - "asyncio.Queue.__module__ == 'asyncio.queues' (the submodule, not the top-level asyncio package)."
    - "All expected values verified by running Python 3.14.3 asyncio module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Lock — class identity
# ---------------------------------------------------------------------------

invariant asyncio.lock.name:
  description: "asyncio.Lock.__name__ == 'Lock'"
  category: lock
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio.lock.module:
  description: "asyncio.Lock.__module__ == 'asyncio.locks'"
  category: lock
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio.lock.base_name:
  description: "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'"
  category: lock
  kind: python_call_eq
  function: Lock.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_ContextManagerMixin"

