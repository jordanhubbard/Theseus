spec: logging_extra33
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra32.zspec.zsdl — covers Logger method __qualname__.__len__() (critical/exception/addHandler/setLevel/removeHandler/hasHandlers); Handler method __qualname__.__len__() (format/setFormatter/handle/setLevel); module-level fn __qualname__.__len__() (warning/error/info/debug/critical/exception/log); StreamHandler/NullHandler/FileHandler __mro__/__bases__[0].__name__; Logger/Handler/Formatter/Filter/LogRecord __qualname__.__len__()."
    - "logging_extra31.zspec.zsdl — covers __all__.__len__()==45; level constant values and class name lengths; Logger/Handler/Formatter/Filter/LogRecord __dict__.__class__.__name__.__len__()==12; getLevelName/getLogger/makeLogRecord/basicConfig __qualname__.__len__()."
    - "logging_extra30.zspec.zsdl — covers Logger/Handler/Formatter/LogRecord __mro__.__len__() and __bases__[0].__name__.__len__(); Logger.debug(12)/info(11)/warning(14)/error(12)/emit(12) and Formatter.format(16) __qualname__.__len__()."
  notes:
    - "This spec extends logging_extra32.zspec.zsdl."
    - "Prior specs covered: Logger/Handler/Formatter/LogRecord __mro__/__bases__; all Logger/Handler method qualnames (debug/info/warning/error/emit/critical/exception/addHandler/setLevel/removeHandler/hasHandlers/format/setFormatter/handle); module-level fn qualnames; StreamHandler/NullHandler/FileHandler hierarchy; core class __qualname__ lengths."
    - "This spec covers NEW angles: Filter.__mro__.__len__()==2 and Filter.__bases__[0].__name__.__len__()==6; Filterer.__mro__.__len__()==2/.__bases__[0].__name__.__len__()==6; Filterer.__qualname__.__len__()==8; Filterer.__dict__.__class__.__name__.__len__()==12; NOTSET.__class__.__name__.__len__()==3; Logger.findCaller(17)/makeRecord(17)/handle(13)/callHandlers(19)/getEffectiveLevel(24)/isEnabledFor(19) __qualname__.__len__(); Handler.acquire(15)/release(15)/close(13)/addFilter(18) __qualname__.__len__(); Formatter.formatTime(20)/formatException(25) __qualname__.__len__(); Filter.filter(13) __qualname__.__len__(); disable(7)/addLevelName(12)/captureWarnings(15)/shutdown(8) __qualname__.__len__()."
    - "logging.Filter.__mro__ == [Filter, object] (len 2). logging.Filterer.__mro__ == [Filterer, object] (len 2). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Filterer.__qualname__ == 'Filterer' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Filterer.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.NOTSET == 0, __class__.__name__ == 'int' (len 3). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.findCaller.__qualname__ == 'Logger.findCaller' (len 17). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.makeRecord.__qualname__ == 'Logger.makeRecord' (len 17). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.handle.__qualname__ == 'Logger.handle' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.callHandlers.__qualname__ == 'Logger.callHandlers' (len 19). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.getEffectiveLevel.__qualname__ == 'Logger.getEffectiveLevel' (len 24). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.isEnabledFor.__qualname__ == 'Logger.isEnabledFor' (len 19). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.acquire.__qualname__ == 'Handler.acquire' (len 15). logging.Handler.release.__qualname__ == 'Handler.release' (len 15). logging.Handler.close.__qualname__ == 'Handler.close' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.addFilter.__qualname__ == 'Filterer.addFilter' (len 18) — inherited from Filterer. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Formatter.formatTime.__qualname__ == 'Formatter.formatTime' (len 20). logging.Formatter.formatException.__qualname__ == 'Formatter.formatException' (len 25). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Filter.filter.__qualname__ == 'Filter.filter' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.disable.__qualname__ == 'disable' (len 7). logging.addLevelName.__qualname__ == 'addLevelName' (len 12). logging.captureWarnings.__qualname__ == 'captureWarnings' (len 15). logging.shutdown.__qualname__ == 'shutdown' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Filter and Filterer __mro__.__len__() and __bases__[0].__name__.__len__()
#
# extra30 covered Logger/Handler/Formatter/LogRecord but NOT Filter or Filterer.
# Filter.__mro__ == [Filter, object] — len 2; base 'object' (len 6).
# Filterer.__mro__ == [Filterer, object] — len 2; base 'object' (len 6).
# ---------------------------------------------------------------------------

invariant logging_extra33.Filter.mro_len:
  description: "logging.Filter.__mro__.__len__() == 2 — MRO: [Filter, object]"
  category: class_introspection
  kind: python_call_eq
  function: Filter.__mro__.__len__
  args: []
  expected: 2

invariant logging_extra33.Filter.bases_name_len:
  description: "logging.Filter.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_introspection
  kind: python_call_eq
  function: "Filter.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant logging_extra33.Filterer.mro_len:
  description: "logging.Filterer.__mro__.__len__() == 2 — MRO: [Filterer, object]"
  category: class_introspection
  kind: python_call_eq
  function: Filterer.__mro__.__len__
  args: []
  expected: 2

invariant logging_extra33.Filterer.bases_name_len:
  description: "logging.Filterer.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_introspection
  kind: python_call_eq
  function: "Filterer.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Filterer class identity: __qualname__ and __dict__ type name
#
# No prior spec checks __qualname__.__len__() or __dict__.__class__.__name__.__len__()
# for Filterer. Filterer.__qualname__ == 'Filterer' (len 8).
# Filterer.__dict__.__class__.__name__ == 'mappingproxy' (len 12).
# ---------------------------------------------------------------------------

invariant logging_extra33.Filterer.qualname.len:
  description: "logging.Filterer.__qualname__.__len__() == 8 — 'Filterer' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Filterer.__qualname__.__len__
  args: []
  expected: 8

invariant logging_extra33.Filterer.dict.class.name.len:
  description: "logging.Filterer.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: Filterer.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# logging.NOTSET.__class__.__name__.__len__()
#
# NOTSET == 0 and is an int. No prior spec checks NOTSET.__class__.__name__.__len__().
# 'int' has length 3.
# ---------------------------------------------------------------------------

invariant logging_extra33.NOTSET.class.name.len:
  description: "logging.NOTSET.__class__.__name__.__len__() == 3 — NOTSET is an 'int'"
  category: module_constants
  kind: python_call_eq
  function: NOTSET.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Table: Logger method __qualname__.__len__() — findCaller, makeRecord, handle,
# callHandlers, getEffectiveLevel, isEnabledFor
#
# Prior specs covered debug/info/warning/error (extra30) and
# critical/exception/addHandler/setLevel/removeHandler/hasHandlers (extra32).
# This table adds the remaining Logger methods:
#   Logger.findCaller        -> 17
#   Logger.makeRecord        -> 17
#   Logger.handle            -> 13
#   Logger.callHandlers      -> 19
#   Logger.getEffectiveLevel -> 24
#   Logger.isEnabledFor      -> 19
# ---------------------------------------------------------------------------

table logging_extra33.Logger_remaining_method_qualnames:
  description: "logging.Logger remaining method __qualname__ lengths — findCaller (17), makeRecord (17), handle (13), callHandlers (19), getEffectiveLevel (24), isEnabledFor (19)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: llr33

  columns: [id, function, args, expected]
  rows:
    - [findCaller,        Logger.findCaller.__qualname__.__len__,        [], 17]
    - [makeRecord,        Logger.makeRecord.__qualname__.__len__,        [], 17]
    - [handle,            Logger.handle.__qualname__.__len__,            [], 13]
    - [callHandlers,      Logger.callHandlers.__qualname__.__len__,      [], 19]
    - [getEffectiveLevel, Logger.getEffectiveLevel.__qualname__.__len__, [], 24]
    - [isEnabledFor,      Logger.isEnabledFor.__qualname__.__len__,      [], 19]

# ---------------------------------------------------------------------------
# Table: Handler method __qualname__.__len__() — acquire, release, close,
# addFilter
#
# Prior specs covered emit (extra30), format/setFormatter/handle/setLevel (extra32).
# This table adds: acquire(15), release(15), close(13).
# Handler.addFilter is inherited from Filterer — qualname is 'Filterer.addFilter' (18).
# ---------------------------------------------------------------------------

table logging_extra33.Handler_remaining_method_qualnames:
  description: "logging.Handler remaining method __qualname__ lengths — acquire (15), release (15), close (13), addFilter (18, inherited from Filterer)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: lhr33

  columns: [id, function, args, expected]
  rows:
    - [acquire,   Handler.acquire.__qualname__.__len__,   [], 15]
    - [release,   Handler.release.__qualname__.__len__,   [], 15]
    - [close,     Handler.close.__qualname__.__len__,     [], 13]
    - [addFilter, Handler.addFilter.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# Table: Formatter and Filter method __qualname__.__len__()
#
# Prior spec (extra30) covered Formatter.format(16). New here:
#   Formatter.formatTime      -> 20
#   Formatter.formatException -> 25
#   Filter.filter             -> 13
# ---------------------------------------------------------------------------

table logging_extra33.Formatter_Filter_method_qualnames:
  description: "logging.Formatter/Filter method __qualname__ lengths — formatTime (20), formatException (25), Filter.filter (13)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: lff33

  columns: [id, function, args, expected]
  rows:
    - [formatTime,      Formatter.formatTime.__qualname__.__len__,      [], 20]
    - [formatException, Formatter.formatException.__qualname__.__len__, [], 25]
    - [filter_filter,   Filter.filter.__qualname__.__len__,             [], 13]

# ---------------------------------------------------------------------------
# Table: additional module-level function __qualname__.__len__()
#
# Prior specs covered getLevelName/getLogger/makeLogRecord/basicConfig (extra31)
# and warning/error/info/debug/critical/exception/log (extra32).
# New here: disable(7), addLevelName(12), captureWarnings(15), shutdown(8).
# ---------------------------------------------------------------------------

table logging_extra33.additional_module_fn_qualnames:
  description: "logging additional module-level function __qualname__ lengths — disable (7), addLevelName (12), captureWarnings (15), shutdown (8)"
  kind: python_call_eq
  category: function_identity
  id_prefix: lam33

  columns: [id, function, args, expected]
  rows:
    - [disable_ql,         disable.__qualname__.__len__,         [], 7]
    - [addLevelName_ql,    addLevelName.__qualname__.__len__,    [], 12]
    - [captureWarnings_ql, captureWarnings.__qualname__.__len__, [], 15]
    - [shutdown_ql,        shutdown.__qualname__.__len__,        [], 8]
