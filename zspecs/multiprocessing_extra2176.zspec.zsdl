spec: multiprocessing_extra2176
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Theme: iterator/sequence protocol dict-presence — checks for __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__ in class __dict__."
    - "multiprocessing.Process does not define any iterator/sequence protocol methods in its own __dict__."
    - "multiprocessing.synchronize.Lock does not define any iterator/sequence protocol methods in its own __dict__."
    - "multiprocessing.synchronize.RLock does not define any iterator/sequence protocol methods in its own __dict__."
    - "multiprocessing.synchronize.Semaphore does not define any iterator/sequence protocol methods in its own __dict__."
    - "multiprocessing.synchronize.Event does not define any iterator/sequence protocol methods in its own __dict__."
    - "multiprocessing.queues.Queue does not define any iterator/sequence protocol methods in its own __dict__."
    - "These multiprocessing primitives wrap OS-level IPC and synchronization but do not implement iterator, async iterator, awaitable, or sequence protocols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — iterator/sequence protocol dict-presence
# ---------------------------------------------------------------------------

table multiprocessing_extra2176.Process_iterator_presence:
  kind: python_call_eq
  category: iterator_presence
  columns: [id, function, args, expected]
  rows:
    - ["mp2176001", "multiprocessing.Process.__dict__.__contains__", ["__iter__"], false]
    - ["mp2176002", "multiprocessing.Process.__dict__.__contains__", ["__next__"], false]
    - ["mp2176003", "multiprocessing.Process.__dict__.__contains__", ["__aiter__"], false]
