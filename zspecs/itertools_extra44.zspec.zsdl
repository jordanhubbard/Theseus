spec: itertools_extra44
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra43.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all; chain/__name__/__qualname__=='chain'; chain.from_iterable/__qualname__=='chain.from_iterable'; zip_longest/__name__/__qualname__=='zip_longest'; islice/__name__/__qualname__=='islice'; accumulate/__name__/__qualname__=='accumulate'; groupby/__name__/__qualname__; compress/__name__/__qualname__; dropwhile/__name__/__qualname__; takewhile/__name__/__qualname__; starmap/__name__/__qualname__; filterfalse/__name__/__qualname__; pairwise/__name__/__qualname__=='pairwise'; batched/__name__/__qualname__=='batched'; count/__name__/__qualname__=='count'; product/__name__/__qualname__=='product'; permutations/__name__/__qualname__=='permutations'; combinations/__name__/__qualname__=='combinations'; combinations_with_replacement/__name__/__qualname__=='combinations_with_replacement'; cycle/__name__/__qualname__=='cycle'; repeat/__name__/__qualname__=='repeat'; chain.__bases__[0].__name__=='object'; count.__bases__[0].__name__=='object'; product.__bases__[0].__name__=='object'; permutations.__bases__[0].__name__=='object'; combinations.__bases__[0].__name__=='object'; combinations_with_replacement.__bases__[0].__name__=='object'; groupby.__bases__[0].__name__=='object'; islice.__bases__[0].__name__=='object'; zip_longest.__bases__[0].__name__=='object'; accumulate.__bases__[0].__name__=='object'."
    - "This spec covers: itertools.compress.__bases__[0].__name__ == 'object'; itertools.dropwhile.__bases__[0].__name__ == 'object'; itertools.takewhile.__bases__[0].__name__ == 'object'; itertools.filterfalse.__bases__[0].__name__ == 'object'; itertools.starmap.__bases__[0].__name__ == 'object'; itertools.pairwise.__bases__[0].__name__ == 'object'; itertools.batched.__bases__[0].__name__ == 'object'; itertools.repeat.__bases__[0].__name__ == 'object'; itertools.cycle.__bases__[0].__name__ == 'object'."
    - "Key findings: All nine itertools C-extension types (compress, dropwhile, takewhile, filterfalse, starmap, pairwise, batched, repeat, cycle) have __bases__[0].__name__ == 'object'. This extends the __bases__[0].__name__ string equality coverage from extra43 (which covered product/permutations/combinations/combinations_with_replacement/groupby/islice/zip_longest/accumulate) and extra42 (which covered chain and count). Prior specs recorded __bases__[0].__name__.__len__()==6 for all itertools types (confirming they are all 'object') but not the string equality invariants for these nine types. pairwise was added in Python 3.10 and batched in Python 3.12; both are C-extension types in itertoolsmodule.c and follow the same universal pattern of inheriting directly from object."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools filtering types __bases__[0].__name__ — extra44 namespace
#
# itertools.compress, dropwhile, takewhile, filterfalse, and starmap all have
# __bases__[0].__name__ == 'object'. These five are C-extension types in
# Modules/itertoolsmodule.c that filter or map over iterables. Prior specs
# recorded __bases__[0].__name__.__len__()==6 for all itertools types and
# string equality for chain, count, product, permutations, combinations,
# combinations_with_replacement, groupby, islice, zip_longest, and accumulate
# (extra42 and extra43), but not for these five types. All five are new here.
# ---------------------------------------------------------------------------

table itertools_extra44.filtering_types_bases:
  description: "itertools compress/dropwhile/takewhile/filterfalse/starmap __bases__[0].__name__ == 'object' — C-extension filtering/mapping types inheriting directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ftbases44

  columns: [id, function, args, expected, description]
  rows:
    - [compress_bases_name,
       "compress.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.compress.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; filters elements of an iterable by a corresponding boolean selector iterable"]
    - [dropwhile_bases_name,
       "dropwhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.dropwhile.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; drops elements while a predicate is true then yields the rest"]
    - [takewhile_bases_name,
       "takewhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.takewhile.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; yields elements while a predicate is true then stops"]
    - [filterfalse_bases_name,
       "filterfalse.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; yields elements for which the predicate is false (complement of filter)"]
    - [starmap_bases_name,
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; maps a function using arguments from each tuple in an iterable"]

# ---------------------------------------------------------------------------
# itertools newer and infinite types __bases__[0].__name__ — extra44 namespace
#
# itertools.pairwise (added 3.10), itertools.batched (added 3.12),
# itertools.repeat, and itertools.cycle all have __bases__[0].__name__ == 'object'.
# pairwise and batched are newer additions defined in itertoolsmodule.c alongside
# the other C-extension types. repeat and cycle are the infinite iterator types.
# Prior specs recorded __bases__[0].__name__.__len__()==6 for all types (confirming
# the 6-char 'object' length) but not string equality for these four. New here.
# ---------------------------------------------------------------------------

table itertools_extra44.newer_infinite_types_bases:
  description: "itertools pairwise/batched/repeat/cycle __bases__[0].__name__ == 'object' — C-extension types including Python 3.10/3.12 additions; all inherit directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: nibase44

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_bases_name,
       "pairwise.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.pairwise.__bases__[0].__name__ == 'object' — C-extension type added in Python 3.10; inherits directly from object; yields overlapping consecutive pairs from an iterable"]
    - [batched_bases_name,
       "batched.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.batched.__bases__[0].__name__ == 'object' — C-extension type added in Python 3.12; inherits directly from object; batches an iterable into tuples of length n"]
    - [repeat_bases_name,
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; infinite (or bounded) iterator that yields the same object repeatedly"]
    - [cycle_bases_name,
       "cycle.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; cycles through an iterable indefinitely, saving a copy internally"]
