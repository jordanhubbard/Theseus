spec: is_null
version: ">=1.0.1"
backend: node(is-null)

docs: https://www.npmjs.com/package/is-null

provenance:
  derived_from:
    - "is-null README — https://www.npmjs.com/package/is-null"
    - "Test vectors verified with is-null via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-null source"
  notes:
    - "is-null is an npm package. Install: npm install is-null"
    - "Returns true if the value is exactly null."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_null.check:
  kind: node_module_call_eq
  function: ~
  category: validation
  id_prefix: isnull

  columns: [id, args, expected]
  rows:
    - [null_val,  [null],   true]
    - [zero,      [0],      false]
    - [empty_obj, [{}],     false]
