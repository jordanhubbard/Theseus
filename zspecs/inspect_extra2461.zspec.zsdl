spec: inspect_extra2461
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether inspect classes define the length protocol in their class __dict__."
    - "inspect.Parameter.__dict__.__contains__('__len__') == False — Parameter describes a single function parameter; it is not a container. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('__length_hint__') == False — Parameter is not an iterator. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('__len__') == False — Signature holds an ordered mapping of Parameters but does not define __len__ in its own class dict. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('__len__') == False — BoundArguments holds bound call arguments but does not define __len__. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__dict__.__contains__('__len__') == False — FrameInfo is a named-tuple subclass; __len__ is inherited from tuple, not defined in FrameInfo.__dict__ itself. Verified with Python 3.14.3."
    - "inspect.Traceback.__dict__.__contains__('__len__') == False — Traceback is a named-tuple subclass; __len__ is inherited from tuple, not in Traceback.__dict__. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__dict__.__contains__('__len__') == False — ArgInfo is a namedtuple; __len__ is inherited from tuple. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__dict__.__contains__('__len__') == False — FullArgSpec is a namedtuple; __len__ is inherited from tuple. Verified with Python 3.14.3."
    - "No inspect class defines __length_hint__ in its class __dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __len__ dict-presence for inspect classes
#
# Theme: which inspect classes define __len__ in their class __dict__?
#
# inspect.Parameter.__dict__.__contains__('__len__') == False
# inspect.Signature.__dict__.__contains__('__len__') == False
# inspect.BoundArguments.__dict__.__contains__('__len__') == False
# inspect.FrameInfo.__dict__.__contains__('__len__') == False
# inspect.Traceback.__dict__.__contains__('__len__') == False
# inspect.ArgInfo.__dict__.__contains__('__len__') == False
# inspect.FullArgSpec.__dict__.__contains__('__len__') == False
# inspect.Arguments.__dict__.__contains__('__len__') == False
#
# No inspect class defines __len__ in its own class dict. Named-tuple
# subclasses (FrameInfo, Traceback, ArgInfo, FullArgSpec, Arguments)
# inherit __len__ from tuple, but tuple.__len__ is not copied into
# their individual class dicts. Container-like classes (Signature,
# BoundArguments) do not define __len__ either.
# ---------------------------------------------------------------------------

table inspect_extra2461.len_dict_presence:
  description: "__len__ in class __dict__ for inspect types; none define it directly"
  kind: python_call_eq
  category: identity
  id_prefix: in2461

  columns: [id, function, args, expected]
  rows:
    - ["in2461001", Parameter.__dict__.__contains__, ["__len__"], false]
    - ["in2461002", Signature.__dict__.__contains__, ["__len__"], false]
    - ["in2461003", BoundArguments.__dict__.__contains__, ["__len__"], false]
    - ["in2461004", FrameInfo.__dict__.__contains__, ["__len__"], false]
    - ["in2461005", Traceback.__dict__.__contains__, ["__len__"], false]
    - ["in2461006", ArgInfo.__dict__.__contains__, ["__len__"], false]
    - ["in2461007", FullArgSpec.__dict__.__contains__, ["__len__"], false]
    - ["in2461008", Arguments.__dict__.__contains__, ["__len__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence for inspect classes
#
# Theme: which inspect classes define __length_hint__ in their class __dict__?
#
# inspect.Parameter.__dict__.__contains__('__length_hint__') == False
# inspect.Signature.__dict__.__contains__('__length_hint__') == False
# inspect.BoundArguments.__dict__.__contains__('__length_hint__') == False
# inspect.FrameInfo.__dict__.__contains__('__length_hint__') == False
# inspect.Traceback.__dict__.__contains__('__length_hint__') == False
# inspect.ArgInfo.__dict__.__contains__('__length_hint__') == False
# inspect.FullArgSpec.__dict__.__contains__('__length_hint__') == False
# inspect.Arguments.__dict__.__contains__('__length_hint__') == False
#
# No inspect class defines __length_hint__. The inspect module provides
# introspection tools; its classes are not iterators and have no need to
# estimate remaining items in an iteration.
# ---------------------------------------------------------------------------

table inspect_extra2461.length_hint_dict_presence:
  description: "__length_hint__ in class __dict__ for inspect types; none define it"
  kind: python_call_eq
  category: identity
  id_prefix: in2461

  columns: [id, function, args, expected]
  rows:
    - ["in2461009", Parameter.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461010", Signature.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461011", BoundArguments.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461012", FrameInfo.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461013", Traceback.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461014", ArgInfo.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461015", FullArgSpec.__dict__.__contains__, ["__length_hint__"], false]
    - ["in2461016", Arguments.__dict__.__contains__, ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: cross-checks — domain attributes present vs length protocol absent
#
# inspect.Parameter.__dict__.__contains__('kind') == True
# inspect.Parameter.__dict__.__contains__('__len__') == False
# inspect.Signature.__dict__.__contains__('parameters') == True
# inspect.Signature.__dict__.__contains__('__len__') == False
# inspect.BoundArguments.__dict__.__contains__('arguments') == True
# inspect.BoundArguments.__dict__.__contains__('__len__') == False
# inspect.ArgInfo.__dict__.__contains__('args') == True
# inspect.FullArgSpec.__dict__.__contains__('args') == True
#
# These cross-checks confirm that inspect classes define their domain-specific
# attributes in their class dict, but consistently omit the length protocol.
# The contrast between 'kind' (present) and '__len__' (absent) in Parameter,
# for example, clarifies that the class dict is not empty — it just has no
# length protocol support.
# ---------------------------------------------------------------------------

table inspect_extra2461.domain_attrs_vs_length_protocol:
  description: "inspect classes define domain attrs but not __len__; cross-checks"
  kind: python_call_eq
  category: identity
  id_prefix: in2461

  columns: [id, function, args, expected]
  rows:
    - ["in2461017", Parameter.__dict__.__contains__, ["kind"], true]
    - ["in2461018", Parameter.__dict__.__contains__, ["__len__"], false]
    - ["in2461019", Signature.__dict__.__contains__, ["parameters"], true]
    - ["in2461020", Signature.__dict__.__contains__, ["__len__"], false]
    - ["in2461021", BoundArguments.__dict__.__contains__, ["arguments"], true]
    - ["in2461022", BoundArguments.__dict__.__contains__, ["__len__"], false]
    - ["in2461023", ArgInfo.__dict__.__contains__, ["args"], true]
    - ["in2461024", FullArgSpec.__dict__.__contains__, ["args"], true]
