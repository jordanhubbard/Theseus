spec: struct_extra2476
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — membership test and item access protocol checks in class __dict__."
    - "struct.Struct does NOT define __contains__ or __getitem__ in its own __dict__; compiled struct objects are not mappings or sequences."
    - "struct.Struct instances are compiled binary format descriptors; they expose pack/unpack/iter_unpack/pack_into/unpack_from methods and format/size attributes, not a container protocol."
    - "struct.Struct.__setattr__ and struct.Struct.__delattr__ ARE defined in __dict__ (to enforce immutability of format and size after construction)."
    - "struct.Struct.__getattribute__ IS defined in __dict__ (C-level attribute access override)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: struct.Struct — __contains__ and __getitem__ absent
#
# struct.Struct is a compiled binary format descriptor. It does NOT define
# __contains__ or __getitem__ in its class __dict__. Struct instances are not
# mappings, sets, or sequences; membership testing and subscript access are
# both unsupported on Struct objects.
# ---------------------------------------------------------------------------

table struct_extra2476.struct_contains_getitem_absent:
  description: "struct.Struct.__dict__: __contains__ and __getitem__ absent — Struct is not a mapping or sequence; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2476

  columns: [id, function, args, expected]
  rows:
    - ["st2476-001", "struct.Struct.__dict__.__contains__", ["__contains__"], false]
    - ["st2476-002", "struct.Struct.__dict__.__contains__", ["__getitem__"],  false]
    - ["st2476-003", "struct.Struct.__dict__.__contains__", ["__setitem__"],  false]
    - ["st2476-004", "struct.Struct.__dict__.__contains__", ["__delitem__"],  false]
    - ["st2476-005", "struct.Struct.__dict__.__contains__", ["__iter__"],     false]
    - ["st2476-006", "struct.Struct.__dict__.__contains__", ["__len__"],      false]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct — pack/unpack API present in __dict__
#
# struct.Struct defines its binary format API directly in its class __dict__.
# These own attributes confirm the Struct interface; their presence contrasts
# with the absent container protocol above: Struct converts between Python
# values and C-layout binary data, it does not act as a container.
# ---------------------------------------------------------------------------

table struct_extra2476.struct_api_present:
  description: "struct.Struct.__dict__: pack/unpack API methods and format/size attrs present; contrasts with absent __contains__/__getitem__; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2476

  columns: [id, function, args, expected]
  rows:
    - ["st2476-007", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st2476-008", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st2476-009", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st2476-010", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2476-011", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2476-012", "struct.Struct.__dict__.__contains__", ["format"],      true]
    - ["st2476-013", "struct.Struct.__dict__.__contains__", ["size"],        true]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct — attribute access control methods present
#
# struct.Struct IS immutable after construction. The C implementation enforces
# this by defining __setattr__ and __delattr__ in __dict__ (they raise
# AttributeError). __getattribute__ is also defined at the C level. None of
# these relate to mapping or sequence container protocols.
# ---------------------------------------------------------------------------

table struct_extra2476.struct_attr_control_present:
  description: "struct.Struct.__dict__: __setattr__, __delattr__, __getattribute__ present (immutability enforcement); new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2476

  columns: [id, function, args, expected]
  rows:
    - ["st2476-014", "struct.Struct.__dict__.__contains__", ["__setattr__"],     true]
    - ["st2476-015", "struct.Struct.__dict__.__contains__", ["__delattr__"],     true]
    - ["st2476-016", "struct.Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st2476-017", "struct.Struct.__dict__.__contains__", ["__getattr__"],     false]
