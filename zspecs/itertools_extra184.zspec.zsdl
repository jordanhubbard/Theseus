spec: itertools_extra184
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/itertools.py"
  notes:
    - "This spec covers: itertools.chain class identity and chain.from_iterable classmethod — itertools.chain.__name__=='chain' (len=5); itertools.chain.__module__=='itertools'; itertools.chain.__qualname__=='chain'; itertools.chain.__class__.__name__=='type' (chain is a C type/class); itertools.chain.from_iterable.__name__=='from_iterable' (len=13); itertools.chain.from_iterable.__qualname__=='chain.from_iterable' (len=19); itertools.chain.from_iterable.__class__.__name__=='builtin_function_or_method'; itertools.count.__name__=='count' (len=5); itertools.count.__module__=='itertools'; itertools.islice.__name__=='islice' (len=6)."
    - "itertools.chain.__name__ == 'chain' — chain is implemented as a C type in the itertools C extension; its __name__ is 'chain', 5 characters. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — chain is exposed as part of the itertools module; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__qualname__ == 'chain' — as a module-level C type, __qualname__ equals __name__ 'chain'. Verified with Python 3.14.3."
    - "itertools.chain.__class__.__name__ == 'type' — chain is a C type (class), so type(chain).__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' — from_iterable is a classmethod of chain implemented as a C builtin; its __name__ is 'from_iterable', 13 characters. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — the qualname includes the owning class 'chain.' prefix making it 'chain.from_iterable', 19 characters. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — from_iterable is a C builtin classmethod, so type(from_iterable).__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.count.__name__ == 'count' — count is a C type in itertools; its __name__ is 'count', 5 chars. Verified with Python 3.14.3."
    - "itertools.islice.__name__ == 'islice' — islice is a C type in itertools; its __name__ is 'islice', 6 chars. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain __name__, __module__, __qualname__
#
# itertools.chain.__name__ == 'chain'
# itertools.chain.__name__.__len__() == 5
# itertools.chain.__module__ == 'itertools'
# itertools.chain.__qualname__ == 'chain'
#
# chain is implemented as a C type in the itertools C extension. It chains
# multiple iterables together into a single lazy iterator. Its __name__ is
# 'chain' (5 chars) and __module__ is 'itertools'.
# New to extra184.
# ---------------------------------------------------------------------------

table itertools_extra184.chain_identity:
  description: "itertools.chain.__name__=='chain' len 5; __module__=='itertools'; __qualname__=='chain'; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain184

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C type in the itertools extension that chains multiple iterables into a single lazy iterator; its __name__ is 'chain'; str.__eq__('chain') returns True; new to extra184"]
    - [chain_name_len_5,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — the name 'chain' has exactly 5 characters: c-h-a-i-n; str.__len__() returns 5; new to extra184"]
    - [chain_module_eq,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is exposed as part of the itertools module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra184"]
    - [chain_qualname_eq,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — as a module-level C type, __qualname__ equals __name__ 'chain' (5 chars); str.__eq__('chain') returns True; new to extra184"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain __class__ and chain.from_iterable identity
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.chain.from_iterable.__name__ == 'from_iterable'
# itertools.chain.from_iterable.__name__.__len__() == 13
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
#
# chain is a C type so its __class__.__name__ is 'type'. from_iterable is a
# classmethod implemented as a C builtin; its __name__ is 'from_iterable'
# (13 chars) and its __qualname__ is 'chain.from_iterable' (19 chars) because
# it belongs to the chain class. New to extra184.
# ---------------------------------------------------------------------------

table itertools_extra184.chain_class_and_from_iterable:
  description: "itertools.chain.__class__.__name__=='type'; chain.from_iterable.__name__=='from_iterable' len 13; __qualname__=='chain.from_iterable' len 19; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain184

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_eq,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C type (class), so type(chain).__name__ is 'type'; str.__eq__('type') returns True; new to extra184"]
    - [fromiter_name_eq,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — from_iterable is a classmethod of chain implemented as a C builtin that builds a chain from a single iterable of iterables; its __name__ is 'from_iterable'; str.__eq__('from_iterable') returns True; new to extra184"]
    - [fromiter_name_len_13,
       "chain.from_iterable.__name__.__len__",
       [],
       13,
       "itertools.chain.from_iterable.__name__.__len__() == 13 — the name 'from_iterable' has exactly 13 characters: f-r-o-m-_-i-t-e-r-a-b-l-e; str.__len__() returns 13; new to extra184"]
    - [fromiter_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — the qualname includes the owning class 'chain.' prefix making it 'chain.from_iterable' (19 chars); str.__eq__('chain.from_iterable') returns True; new to extra184"]

# ---------------------------------------------------------------------------
# Table 3: itertools.count and itertools.islice identity
#
# itertools.count.__name__ == 'count'
# itertools.count.__name__.__len__() == 5
# itertools.count.__module__ == 'itertools'
# itertools.islice.__name__ == 'islice'
# itertools.islice.__name__.__len__() == 6
# itertools.islice.__module__ == 'itertools'
#
# count and islice are both C types in the itertools extension. count generates
# an infinite arithmetic sequence. islice returns selected elements from an
# iterable like slice notation. New to extra184.
# ---------------------------------------------------------------------------

table itertools_extra184.count_and_islice_identity:
  description: "itertools.count.__name__=='count' len 5; __module__=='itertools'; itertools.islice.__name__=='islice' len 6; __module__=='itertools'; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain184

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_eq,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C type in itertools that generates an infinite arithmetic sequence starting at start with step step; its __name__ is 'count'; str.__eq__('count') returns True; new to extra184"]
    - [count_name_len_5,
       count.__name__.__len__,
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — the name 'count' has exactly 5 characters: c-o-u-n-t; str.__len__() returns 5; new to extra184"]
    - [count_module_eq,
       count.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is a C type exposed as part of the itertools module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra184"]
    - [islice_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C type in itertools that returns selected elements from an iterable using slice-like notation; its __name__ is 'islice'; str.__eq__('islice') returns True; new to extra184"]
    - [islice_name_len_6,
       islice.__name__.__len__,
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — the name 'islice' has exactly 6 characters: i-s-l-i-c-e; str.__len__() returns 6; new to extra184"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra184
# ---------------------------------------------------------------------------

invariant itertools_extra184.chain_name_is_chain:
  description: "itertools.chain.__name__ == 'chain' — C type in the itertools extension that chains multiple iterables into a single lazy iterator; __name__ is 'chain' (5 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra184.chain_module_is_itertools:
  description: "itertools.chain.__module__ == 'itertools' — chain is exposed as part of the itertools module; its __module__ is 'itertools'; new to extra184"
  category: identity
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra184.chain_qualname_equals_name:
  description: "itertools.chain.__qualname__ == 'chain' — module-level C type has __qualname__ == __name__ == 'chain' (5 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra184.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C type (class), so type(chain).__name__ == 'type'; new to extra184"
  category: identity
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra184.from_iterable_name_is_from_iterable:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' — C builtin classmethod of chain that builds a chain from a single iterable of iterables; __name__ is 'from_iterable' (13 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: "chain.from_iterable.__name__.__eq__"
  args: ["from_iterable"]
  expected: true

invariant itertools_extra184.from_iterable_qualname_includes_class:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — qualname includes the owning class prefix 'chain.' making it 'chain.from_iterable' (19 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: "chain.from_iterable.__qualname__.__eq__"
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra184.count_name_is_count:
  description: "itertools.count.__name__ == 'count' — C type in itertools that generates an infinite arithmetic sequence; __name__ is 'count' (5 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra184.islice_name_is_islice:
  description: "itertools.islice.__name__ == 'islice' — C type in itertools that returns selected elements using slice-like notation; __name__ is 'islice' (6 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true
