  notes:
    - "inspect.getmembers.__doc__.__contains__('sorted') == True — getmembers docstring says 'as (name, value) pairs sorted by name'. Verified with Python 3.14.3."
    - "inspect.getmembers.__doc__.__contains__('predicate') == True — getmembers docstring says 'Optionally, only return members that satisfy a given predicate'. Verified with Python 3.14.3."
    - "inspect.isfunction.__doc__.__contains__('user-defined') == True — isfunction docstring says 'Return true if the object is a user-defined function'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__doc__.__contains__('built-in') == True — isbuiltin docstring says 'Return true if the object is a built-in function or method'. Verified with Python 3.14.3."
    - "inspect.ismethod.__doc__.__contains__('instance') == True — ismethod docstring says 'Return true if the object is an instance method'. Verified with Python 3.14.3."
    - "inspect.getfile.__doc__.__contains__('compiled') == True — getfile docstring says 'Work out which source or compiled file an object was defined in'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__doc__.__contains__('coroutine') == True — iscoroutine docstring says 'Return true if the object is a coroutine'. Verified with Python 3.14.3."
    - "inspect.getcallargs.__doc__.__contains__('mapping') == True — getcallargs docstring says 'Get the mapping of arguments to values'. Verified with Python 3.14.3."
    - "inspect.getdoc.__doc__.__contains__('tabs') == True — getdoc docstring says 'All tabs are expanded to spaces'. Verified with Python 3.14.3."
    - "inspect.getmembers.__doc__.__len__() == 134 — getmembers docstring has exactly 134 characters. Verified with Python 3.14.3."
    - "inspect.getsource.__doc__.__len__() == 250 — getsource docstring has exactly 250 characters. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__doc__.__len__() == 284 — isbuiltin docstring has exactly 284 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

