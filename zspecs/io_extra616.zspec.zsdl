spec: io_extra616
version: ">=3.9"
backend: python_module(io)
docs: "Behavioral specs for io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, and io.IncrementalNewlineDecoder method and class qualnames."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python I/O module buffered I/O classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ attributes of buffered I/O classes and selected method qualnames"
  created_at: "2026-04-12T00:00:00Z"

table io_extra616.class_qualnames:
  description: "Class __qualname__ attributes for buffered I/O classes"
  kind: python_call_eq
  category: class_metadata
  id_prefix: io616bq
  columns: [id, function, args, expected]
  rows:
    - [io616bq001, io.BufferedReader.__qualname__.__eq__, ["BufferedReader"], true]
    - [io616bq002, io.BufferedWriter.__qualname__.__eq__, ["BufferedWriter"], true]
    - [io616bq003, io.BufferedRandom.__qualname__.__eq__, ["BufferedRandom"], true]
    - [io616bq004, io.IncrementalNewlineDecoder.__qualname__.__eq__, ["IncrementalNewlineDecoder"], true]

table io_extra616.class_modules:
  description: "Class __module__ attributes for buffered I/O classes"
  kind: python_call_eq
  category: class_metadata
  id_prefix: io616sq
  columns: [id, function, args, expected]
  rows:
    - [io616sq001, io.BufferedReader.__module__.__eq__, ["io"], true]
    - [io616sq002, io.BufferedWriter.__module__.__eq__, ["io"], true]
    - [io616sq003, io.BufferedRandom.__module__.__eq__, ["io"], true]

table io_extra616.method_qualnames:
