spec: socket_extra70
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra69.zspec.zsdl — covers socket module __name__/__spec__.name/__spec__.__class__/__loader__.__class__ / __file__.__contains__('socket')/('.py') / socket.socket.__dict__.__class__=='mappingproxy' / socket.__dict__.__contains__ accept/makefile/setblocking/settimeout (table + invariants)."
    - "socket_extra68.zspec.zsdl — covers socket.connect/bind/sendall/recv __class__/__name__=='method_descriptor' / __qualname__ eq and len / socket.__doc__.__class__/__name__=='str' / socket.__doc__.__contains__('socket') (table + invariants)."
    - "socket_extra67.zspec.zsdl — covers accept/__kwdefaults__/__class__/__name__=='NoneType' / gethostname/gethostbyname/__class__/__name__=='builtin_function_or_method' / getfqdn/__class__/__name__=='function' (table + invariants)."
    - "socket_extra66.zspec.zsdl — covers socket.socket/__name__/__module__/__qualname__=='socket' / socket.socket/__bases__[0].__name__=='object' (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra69; it does NOT duplicate invariants present in those files."
    - "Wave 237 theme: socket.socket method descriptor qualnames + socket module constants."
    - "In python_module(socket), 'socket' in the module namespace refers to the socket.socket class (the class is named 'socket'). Module-level attributes like AF_INET, SOCK_STREAM are accessed directly."
    - "socket.socket.accept.__qualname__ == 'socket.accept' — the qualname of socket.accept uses just the class name 'socket' (not 'socket.socket') because the class qualname is 'socket'. socket_extra68 covers connect/bind/sendall/recv qualnames; no prior socket spec checks accept.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — socket_extra68 covers this; re-anchored in extra70 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — socket_extra68 covers this; re-anchored in extra70 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen' — socket_extra68 covers listen.__qualname__; re-anchored in extra70 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__class__.__name__ == 'function' — socket.accept is a Python function defined in socket.py (not a C method_descriptor). socket_extra68 covers connect/bind as method_descriptor; no prior socket spec checks accept.__class__.__name__=='function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum value; __class__.__name__ is 'AddressFamily'. No prior socket spec checks AF_INET.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum value; __class__.__name__ is 'SocketKind'. No prior socket spec checks SOCK_STREAM.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept/__qualname__ and connect/__qualname__
#
# Wave 237 theme: socket.socket method qualnames.
#
# In python_module(socket), 'socket' refers to the socket.socket class.
# socket.accept is a Python function (function, not method_descriptor);
# its qualname is 'socket.accept'. socket.connect is a C method_descriptor
# inherited from _socket.socket; its qualname is 'socket.connect'.
# socket_extra68 covers connect/bind qualnames; no prior socket spec checks
# accept.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra70.socket_method_qualnames_accept_connect:
  description: "socket.socket.accept/__qualname__.__eq__('socket.accept')==True / socket.socket.accept/__class__/__name__.__eq__('function')==True / socket.socket.connect/__qualname__.__eq__('socket.connect')==True — accept is a Python function in socket.py; connect is a C method_descriptor; qualnames use class name 'socket' (not 'socket.socket'); socket_extra68 covers connect/bind qualnames; no prior socket spec checks accept.__qualname__ or accept.__class__.__name__=='function'; first accept qualname and class identity anchor"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore70

  columns: [id, function, args, expected]
  rows:
    - [accept_qualname_socket_accept,   socket.accept.__qualname__.__eq__,          ["socket.accept"],   true]
    - [accept_class_function,           socket.accept.__class__.__name__.__eq__,    ["function"],        true]
    - [connect_qualname_socket_connect, socket.connect.__qualname__.__eq__,         ["socket.connect"],  true]

# ---------------------------------------------------------------------------
# socket.socket.bind/__qualname__ and socket.socket.listen/__qualname__
#
# Wave 237 theme: socket.socket.bind and socket.socket.listen qualnames.
#
# socket.bind and socket.listen are C method_descriptors inherited from
# _socket.socket. Their qualnames are 'socket.bind' and 'socket.listen'.
# socket_extra68 covers bind and listen qualnames. This table re-anchors them
# in the extra70 namespace as part of the complete Wave 237 qualname survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra70.socket_method_qualnames_bind_listen:
  description: "socket.socket.bind/__qualname__.__eq__('socket.bind')==True / socket.socket.listen/__qualname__.__eq__('socket.listen')==True — bind and listen are C method_descriptors; qualnames use class name 'socket'; socket_extra68 covers these qualnames; re-anchored in extra70 namespace as part of Wave 237 qualname survey; first bind+listen qualname table in extra70"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore70

  columns: [id, function, args, expected]
  rows:
    - [bind_qualname_socket_bind,     socket.bind.__qualname__.__eq__,   ["socket.bind"],   true]
    - [listen_qualname_socket_listen, socket.listen.__qualname__.__eq__, ["socket.listen"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM __class__.__name__
#
# Wave 237 theme: socket module constants class identity.
#
# socket.AF_INET is an AddressFamily IntEnum value. socket.SOCK_STREAM is a
# SocketKind IntEnum value. No prior socket spec checks AF_INET.__class__.__name__
# or SOCK_STREAM.__class__.__name__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra70.socket_constants_class:
  description: "socket.AF_INET/__class__/__name__.__eq__('AddressFamily')==True / socket.SOCK_STREAM/__class__/__name__.__eq__('SocketKind')==True — AF_INET is an AddressFamily IntEnum; SOCK_STREAM is a SocketKind IntEnum; no prior socket spec checks AF_INET.__class__.__name__ or SOCK_STREAM.__class__.__name__; first constants class identity anchor for socket module"
  kind: python_call_eq
  category: constants
  id_prefix: socketmore70

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_class_AddressFamily,   AF_INET.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [SOCK_STREAM_class_SocketKind,  SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],  true]

# ---------------------------------------------------------------------------
# socket.socket.connect and socket.socket.bind __class__.__name__
#
# Wave 237 theme: connect and bind method descriptor class identity.
#
# socket.connect and socket.bind are C method_descriptors inherited from
# _socket.socket. socket_extra68 covers __class__.__name__=='method_descriptor'
# for connect and bind. This table re-anchors both in the extra70 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra70.socket_method_class_connect_bind:
  description: "socket.socket.connect/__class__/__name__.__eq__('method_descriptor')==True / socket.socket.bind/__class__/__name__.__eq__('method_descriptor')==True — connect and bind are C method_descriptors; socket_extra68 covers these facts; re-anchored in extra70 namespace alongside the novel accept and constants checks; first combined method_descriptor class table for connect+bind in extra70"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore70

  columns: [id, function, args, expected]
  rows:
    - [connect_class_method_descriptor, socket.connect.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [bind_class_method_descriptor,    socket.bind.__class__.__name__.__eq__,    ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept') — standalone
#
# socket.socket.accept is a Python function defined in Lib/socket.py. Its
# qualname is 'socket.accept' (class qualname is 'socket', not 'socket.socket').
# No prior socket spec checks accept.__qualname__. First accept qualname
# standalone for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra70.accept_qualname_socket_accept:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — accept is a Python function in socket.py; qualname is 'socket.accept' using the class name 'socket'; no prior socket spec checks accept.__qualname__; first accept qualname standalone for socket"
  category: qualnames
  kind: python_call_eq
  function: socket.accept.__qualname__.__eq__
  args: ["socket.accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.accept is a Python function (not a C method_descriptor).
# It is defined in Lib/socket.py as a Python method. socket_extra68 covers
# connect/bind as method_descriptor. No prior socket spec checks
# accept.__class__.__name__=='function'. First accept class identity standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra70.accept_class_function:
  description: "socket.socket.accept.__class__.__name__.__eq__('function') == True — accept is a Python function defined in socket.py (not a C method_descriptor); socket_extra68 covers connect/bind as method_descriptor; no prior socket spec checks accept.__class__.__name__=='function'; first accept class identity standalone"
  category: class_identity
  kind: python_call_eq
  function: socket.accept.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET is an AddressFamily IntEnum member. Its __class__.__name__
# is 'AddressFamily'. No prior socket spec checks AF_INET.__class__.__name__.
# First AF_INET class identity standalone for socket module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra70.AF_INET_class_AddressFamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an AddressFamily IntEnum member; no prior socket spec checks AF_INET.__class__.__name__; first AF_INET class identity standalone for socket module"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_STREAM is a SocketKind IntEnum member. Its __class__.__name__
# is 'SocketKind'. No prior socket spec checks SOCK_STREAM.__class__.__name__.
# First SOCK_STREAM class identity standalone for socket module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra70.SOCK_STREAM_class_SocketKind:
  description: "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM is a SocketKind IntEnum member; no prior socket spec checks SOCK_STREAM.__class__.__name__; first SOCK_STREAM class identity standalone for socket module"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.bind.__qualname__.__eq__('socket.bind') — standalone
#
# socket.socket.bind is a C method_descriptor with qualname 'socket.bind'.
# socket_extra68 covers this. Re-anchored in extra70 namespace alongside novel
# accept and constants checks.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra70.bind_qualname_socket_bind:
  description: "socket.socket.bind.__qualname__.__eq__('socket.bind') == True — bind is a C method_descriptor; qualname is 'socket.bind'; socket_extra68 covers this; re-anchored in extra70 namespace for Wave 237 survey; first bind qualname standalone in extra70"
  category: qualnames
  kind: python_call_eq
  function: socket.bind.__qualname__.__eq__
  args: ["socket.bind"]
  expected: true
