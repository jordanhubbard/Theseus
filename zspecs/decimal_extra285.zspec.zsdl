spec: decimal_extra285
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module reference and Context class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c, Lib/_pydecimal.py"
  notes:
    - "decimal does NOT have __all__ (hasattr returns False on Python 3.14)"
    - "getcontext, setcontext, localcontext __module__ is '_decimal' (C accelerator)"
    - "decimal.Context.prec and decimal.Context.rounding are both getset_descriptor"
    - "decimal.Context has no .traps or .flags as class-level descriptors"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra285.function_identity:
  description: "decimal module function __name__ and __module__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: dce285

  columns: [id, function, args, expected, description]
  rows:
    - [dce285001, decimal.getcontext.__name__,    [], "getcontext",  "getcontext __name__"]
    - [dce285002, decimal.getcontext.__module__,  [], "_decimal",    "getcontext __module__"]
    - [dce285003, decimal.setcontext.__name__,    [], "setcontext",  "setcontext __name__"]
    - [dce285004, decimal.setcontext.__module__,  [], "_decimal",    "setcontext __module__"]
    - [dce285005, decimal.localcontext.__name__,  [], "localcontext", "localcontext __name__"]
    - [dce285006, decimal.localcontext.__module__, [], "_decimal",   "localcontext __module__"]

table decimal_extra285.context_attr_descriptors:
  description: "decimal.Context attribute descriptor class names"
  kind: python_call_eq
  category: identity
  id_prefix: dce285d

  columns: [id, function, args, expected, description]
  rows:
    - [dce285d001, decimal.Context.prec.__class__.__name__,     [], "getset_descriptor", "prec descriptor class"]
    - [dce285d002, decimal.Context.rounding.__class__.__name__, [], "getset_descriptor", "rounding descriptor class"]
    - [dce285d003, decimal.Context.Emin.__class__.__name__,     [], "getset_descriptor", "Emin descriptor class"]
    - [dce285d004, decimal.Context.Emax.__class__.__name__,     [], "getset_descriptor", "Emax descriptor class"]
    - [dce285d005, decimal.Context.capitals.__class__.__name__, [], "getset_descriptor", "capitals descriptor class"]
    - [dce285d006, decimal.Context.clamp.__class__.__name__,    [], "getset_descriptor", "clamp descriptor class"]

invariant decimal_extra285.getcontext_name:
  description: "decimal.getcontext __name__ confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.getcontext.__name__
  args: []
  expected: "getcontext"

invariant decimal_extra285.setcontext_name:
  description: "decimal.setcontext __name__ confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.setcontext.__name__
  args: []
  expected: "setcontext"

invariant decimal_extra285.localcontext_name:
  description: "decimal.localcontext __name__ confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.localcontext.__name__
  args: []
  expected: "localcontext"

invariant decimal_extra285.context_prec_descriptor:
  description: "decimal.Context.prec is a getset_descriptor"
  category: identity
  kind: python_call_eq
  function: decimal.Context.prec.__class__.__name__
  args: []
  expected: "getset_descriptor"
