spec: traceback_extra8
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra7.zspec.zsdl."
    - "Prior specs cover: function __name__ (traceback + traceback_extra4), class __name__/__module__ (traceback_extra4), function __module__ (traceback_extra3 + traceback_extra7), class __qualname__ (traceback_extra5), function __qualname__ for all public functions (traceback_extra5 + traceback_extra6), class __bases__ for StackSummary/FrameSummary/TracebackException (traceback_extra2/traceback_extra4/traceback_extra6), StackSummary.from_list.__func__.__qualname__, traceback.__spec__.name, traceback.__file__.__class__.__name__."
    - "NEW in this spec: class __name__ identity checks via __eq__ predicate (expected: true form) for TracebackException, StackSummary, FrameSummary; class __module__ identity checks via __eq__ predicate for TracebackException, StackSummary, FrameSummary; function __name__ identity checks via __eq__ predicate for print_exc, print_tb, print_stack, format_exc, format_tb, format_stack, clear_frames."
    - "traceback.TracebackException.__module__ == 'traceback' — defined in Lib/traceback.py."
    - "traceback.StackSummary.__module__ == 'traceback' — defined in Lib/traceback.py."
    - "traceback.FrameSummary.__module__ == 'traceback' — defined in Lib/traceback.py."
    - "All function __name__ checks use the __eq__ predicate form (expected: true) as a distinct structural form not previously used for this set."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ identity checks — __eq__ predicate form
#
# Prior specs confirm these __name__ values via direct expected strings in
# table rows.  These invariants use __eq__ with expected: true — a distinct
# structural form not previously used for this predicate on these classes.
# ---------------------------------------------------------------------------

invariant traceback_extra8.TracebackException.name_eq:
  description: "traceback.TracebackException.__name__.__eq__('TracebackException') == True"
  category: class_names
  kind: python_call_eq
  function: TracebackException.__name__.__eq__
  args: ["TracebackException"]
  expected: true

invariant traceback_extra8.StackSummary.name_eq:
  description: "traceback.StackSummary.__name__.__eq__('StackSummary') == True"
  category: class_names
  kind: python_call_eq
  function: StackSummary.__name__.__eq__
  args: ["StackSummary"]
  expected: true

invariant traceback_extra8.FrameSummary.name_eq:
  description: "traceback.FrameSummary.__name__.__eq__('FrameSummary') == True"
  category: class_names
  kind: python_call_eq
  function: FrameSummary.__name__.__eq__
  args: ["FrameSummary"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ identity checks — __eq__ predicate form
#
# Prior specs confirm these __module__ values via table rows with direct
# expected strings (traceback_extra4).  These invariants use __eq__ with
# expected: true — a distinct structural form not previously used for this
# predicate on these three classes.
# ---------------------------------------------------------------------------

invariant traceback_extra8.TracebackException.module_eq:
  description: "traceback.TracebackException.__module__.__eq__('traceback') == True"
  category: class_modules
  kind: python_call_eq
  function: TracebackException.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra8.StackSummary.module_eq:
  description: "traceback.StackSummary.__module__.__eq__('traceback') == True"
  category: class_modules
  kind: python_call_eq
  function: StackSummary.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra8.FrameSummary.module_eq:
  description: "traceback.FrameSummary.__module__.__eq__('traceback') == True"
  category: class_modules
  kind: python_call_eq
  function: FrameSummary.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ identity checks — __eq__ predicate form
#
# Prior specs confirm these __name__ values via table rows (traceback base
# spec and traceback_extra4).  These invariants use the __eq__ predicate
# form with expected: true — a distinct structural form for this set.
# ---------------------------------------------------------------------------

invariant traceback_extra8.print_exc.name_eq:
  description: "traceback.print_exc.__name__.__eq__('print_exc') == True"
  category: function_names
  kind: python_call_eq
  function: print_exc.__name__.__eq__
  args: ["print_exc"]
  expected: true

invariant traceback_extra8.print_tb.name_eq:
  description: "traceback.print_tb.__name__.__eq__('print_tb') == True"
  category: function_names
  kind: python_call_eq
  function: print_tb.__name__.__eq__
  args: ["print_tb"]
  expected: true

invariant traceback_extra8.print_stack.name_eq:
  description: "traceback.print_stack.__name__.__eq__('print_stack') == True"
  category: function_names
  kind: python_call_eq
  function: print_stack.__name__.__eq__
  args: ["print_stack"]
  expected: true

invariant traceback_extra8.format_exc.name_eq:
  description: "traceback.format_exc.__name__.__eq__('format_exc') == True"
  category: function_names
  kind: python_call_eq
  function: format_exc.__name__.__eq__
  args: ["format_exc"]
  expected: true

invariant traceback_extra8.format_tb.name_eq:
  description: "traceback.format_tb.__name__.__eq__('format_tb') == True"
  category: function_names
  kind: python_call_eq
  function: format_tb.__name__.__eq__
  args: ["format_tb"]
  expected: true

invariant traceback_extra8.format_stack.name_eq:
  description: "traceback.format_stack.__name__.__eq__('format_stack') == True"
  category: function_names
  kind: python_call_eq
  function: format_stack.__name__.__eq__
  args: ["format_stack"]
  expected: true

invariant traceback_extra8.clear_frames.name_eq:
  description: "traceback.clear_frames.__name__.__eq__('clear_frames') == True"
  category: function_names
  kind: python_call_eq
  function: clear_frames.__name__.__eq__
  args: ["clear_frames"]
  expected: true
