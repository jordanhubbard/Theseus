spec: decimal_extra202
version: ">=3.9"
backend: python_module(_pydecimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/ — C extension implementation"
  notes:
    - "This spec covers: __defaults__ attributes of decimal module classes via the pure-Python _pydecimal module. decimal.Decimal and decimal.Context are C extensions (_decimal module) with wrapper_descriptor __init__ methods that have no __defaults__ attribute."
    - "_pydecimal.Decimal uses __new__ (not __init__) for construction: Decimal.__new__(cls, value='0', context=None). __new__.__defaults__ == ('0', None). __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 2."
    - "_pydecimal.Decimal.__init__.__defaults__ has no __defaults__ attribute (wrapper_descriptor) — Decimal uses __new__ for value initialization."
    - "_pydecimal.Context.__init__.__defaults__ == (None, None, None, None, None, None, None, None, None) — nine defaults for: prec, rounding, Emin, Emax, capitals, clamp, flags, traps, _ignored_flags, all defaulting to None. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 9."
    - "_pydecimal.getcontext.__defaults__ == None — getcontext() takes no arguments. __defaults__.__class__.__name__ == 'NoneType'."
    - "_pydecimal.localcontext.__defaults__ == (None,) — one default: ctx=None. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _pydecimal.Decimal.__new__.__defaults__ — class name and length
#
# _pydecimal.Decimal uses __new__ for instantiation:
#   def __new__(cls, value="0", context=None):
# __defaults__ == ('0', None)  — length 2
# __defaults__.__class__.__name__ == 'tuple'
# Note: Decimal.__init__ is a wrapper_descriptor (from object) with no __defaults__.
# ---------------------------------------------------------------------------

table decimal_extra202.Decimal_new_defaults:
  description: "_pydecimal.Decimal.__new__.__defaults__ class name and length — defaults ('0', None) for value and context params; __class__.__name__=='tuple'; __len__()==2; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: decimaldefaults202

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_new_defs_cls,     Decimal.__new__.__defaults__.__class__.__name__.__eq__, ["tuple"],    true,  "_pydecimal.Decimal.__new__.__defaults__.__class__.__name__ == 'tuple' — two defaults: value='0' and context=None; Decimal uses __new__ not __init__; verified Python 3.14.3"]
    - [decimal_new_defs_len,     Decimal.__new__.__defaults__.__len__,                   [],           2,     "_pydecimal.Decimal.__new__.__defaults__.__len__() == 2 — defaults for value='0' and context=None; verified Python 3.14.3"]
    - [decimal_new_not_nonetype, Decimal.__new__.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "_pydecimal.Decimal.__new__.__defaults__.__class__.__name__ != 'NoneType' — Decimal.__new__ has two defaults; verified Python 3.14.3"]
    - [decimal_new_not_len_1,    Decimal.__new__.__defaults__.__len__,                   [],           2,     "_pydecimal.Decimal.__new__.__defaults__.__len__() == 2 (not 1 or 9); two defaults: value and context; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pydecimal.Context.__init__.__defaults__ — class name and length
#
# _pydecimal.Context.__init__ takes nine optional parameters:
#   def __init__(self, prec=None, rounding=None, Emin=None, Emax=None,
#                capitals=None, clamp=None, flags=None, traps=None,
#                _ignored_flags=None):
# __defaults__ == (None, None, None, None, None, None, None, None, None)  — length 9
# __defaults__.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table decimal_extra202.Context_init_defaults:
  description: "_pydecimal.Context.__init__.__defaults__ class name and length — nine None defaults for prec/rounding/Emin/Emax/capitals/clamp/flags/traps/_ignored_flags; __class__.__name__=='tuple'; __len__()==9; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: decimaldefaults202

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_defs_cls,      Context.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"],    true,  "_pydecimal.Context.__init__.__defaults__.__class__.__name__ == 'tuple' — nine None defaults for all Context parameters; verified Python 3.14.3"]
    - [ctx_defs_len,      Context.__init__.__defaults__.__len__,                   [],           9,     "_pydecimal.Context.__init__.__defaults__.__len__() == 9 — nine defaults: prec, rounding, Emin, Emax, capitals, clamp, flags, traps, _ignored_flags; verified Python 3.14.3"]
    - [ctx_not_nonetype,  Context.__init__.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "_pydecimal.Context.__init__.__defaults__.__class__.__name__ != 'NoneType' — Context has nine defaults; verified Python 3.14.3"]
    - [ctx_not_len_2,     Context.__init__.__defaults__.__len__,                   [],           9,     "_pydecimal.Context.__init__.__defaults__.__len__() == 9 (not 2 like Decimal.__new__); Context has the most defaults in the decimal module; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pydecimal.getcontext and localcontext __defaults__
#
# _pydecimal.getcontext()  — no arguments
#   __defaults__ == None  →  __class__.__name__ == 'NoneType'
# _pydecimal.localcontext(ctx=None)  — one optional argument
#   __defaults__ == (None,)  →  __class__.__name__ == 'tuple', __len__() == 1
# ---------------------------------------------------------------------------

table decimal_extra202.getcontext_localcontext_defaults:
  description: "_pydecimal.getcontext and localcontext __defaults__: getcontext has NoneType (no args); localcontext has tuple len=1 (ctx=None); verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: decimaldefaults202

  columns: [id, function, args, expected, description]
  rows:
    - [getctx_defs_cls,       getcontext.__defaults__.__class__.__name__.__eq__,   ["NoneType"], true,  "_pydecimal.getcontext.__defaults__.__class__.__name__ == 'NoneType' — getcontext() takes no arguments; __defaults__ is None; verified Python 3.14.3"]
    - [getctx_not_tuple,      getcontext.__defaults__.__class__.__name__.__eq__,   ["tuple"],    false, "_pydecimal.getcontext.__defaults__.__class__.__name__ != 'tuple' — getcontext has no defaults; verified Python 3.14.3"]
    - [localctx_defs_cls,     localcontext.__defaults__.__class__.__name__.__eq__, ["tuple"],    true,  "_pydecimal.localcontext.__defaults__.__class__.__name__ == 'tuple' — one default: ctx=None; localcontext(ctx=None) is a context manager; verified Python 3.14.3"]
    - [localctx_defs_len,     localcontext.__defaults__.__len__,                   [],           1,     "_pydecimal.localcontext.__defaults__.__len__() == 1 — single default: ctx=None; verified Python 3.14.3"]
    - [localctx_not_nonetype, localcontext.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "_pydecimal.localcontext.__defaults__.__class__.__name__ != 'NoneType' — localcontext has one default (ctx=None); contrast with getcontext; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra202
# ---------------------------------------------------------------------------

invariant decimal_extra202.Decimal_new_defaults_class_name:
  description: "_pydecimal.Decimal.__new__.__defaults__.__class__.__name__ == 'tuple' — Decimal uses __new__ (not __init__) for instantiation; __new__(cls, value='0', context=None) has two defaults; __defaults__ == ('0', None); __defaults__.__class__.__name__ == 'tuple'; decimal.Decimal is a C extension with no inspectable __defaults__ on __init__; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Decimal.__new__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant decimal_extra202.Decimal_new_defaults_len_2:
  description: "_pydecimal.Decimal.__new__.__defaults__.__len__() == 2 — two positional defaults: value='0' and context=None; Decimal() with no args creates a zero Decimal; Decimal(value) creates from string/int/tuple; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Decimal.__new__.__defaults__.__len__
  args: []
  expected: 2

invariant decimal_extra202.Context_init_defaults_class_name:
  description: "_pydecimal.Context.__init__.__defaults__.__class__.__name__ == 'tuple' — Context.__init__ has nine parameters all defaulting to None; __defaults__ is a tuple of nine Nones; this allows creating a Context() with all defaults (which inherits from DefaultContext); verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Context.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant decimal_extra202.Context_init_defaults_len_9:
  description: "_pydecimal.Context.__init__.__defaults__.__len__() == 9 — nine defaults: prec, rounding, Emin, Emax, capitals, clamp, flags, traps, _ignored_flags (all None); Context has the largest __defaults__ tuple in the decimal module; Decimal.__new__ has 2, localcontext has 1; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Context.__init__.__defaults__.__len__
  args: []
  expected: 9

invariant decimal_extra202.getcontext_defaults_NoneType:
  description: "_pydecimal.getcontext.__defaults__.__class__.__name__ == 'NoneType' — getcontext() takes no arguments; Python sets __defaults__ to None when a function has no default values; None.__class__.__name__ == 'NoneType'; contrast with localcontext which has ctx=None default; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: getcontext.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant decimal_extra202.localcontext_defaults_class_name:
  description: "_pydecimal.localcontext.__defaults__.__class__.__name__ == 'tuple' — localcontext(ctx=None) is a context manager; one default: ctx=None (use current context when ctx not specified); __defaults__ == (None,); __defaults__.__class__.__name__ == 'tuple'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: localcontext.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant decimal_extra202.localcontext_defaults_len_1:
  description: "_pydecimal.localcontext.__defaults__.__len__() == 1 — single default: ctx=None; localcontext is used as 'with localcontext() as ctx:' or 'with localcontext(myctx) as ctx:'; __len__() == 1; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: localcontext.__defaults__.__len__
  args: []
  expected: 1

invariant decimal_extra202.Context_defaults_greater_than_Decimal:
  description: "_pydecimal.Context.__init__.__defaults__.__len__() > _pydecimal.Decimal.__new__.__defaults__.__len__() — Context has 9 defaults vs Decimal's 2; Context.__init__.__defaults__.__len__()==9 and Decimal.__new__.__defaults__.__len__()==2; the Context class has more configurable parameters than Decimal's constructor; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Context.__init__.__defaults__.__len__
  args: []
  expected: 9
