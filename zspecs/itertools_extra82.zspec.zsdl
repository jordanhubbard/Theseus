spec: itertools_extra82
version: ">=3.10"
backend: python_module(itertools)
extends: itertools_extra81

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra81.zspec.zsdl."
    - "This spec covers: itertools C type __mro__.__len__() for all 16 types (Wave 246)."
    - "All 16 itertools C types inherit directly from object so __mro__ has exactly 2 entries. Verified with Python 3.14.3."
    - "count.__mro__.__len__() == 2 — MRO is (count, object). Verified with Python 3.14.3."
    - "cycle.__mro__.__len__() == 2 — MRO is (cycle, object). Verified with Python 3.14.3."
    - "repeat.__mro__.__len__() == 2 — MRO is (repeat, object). Verified with Python 3.14.3."
    - "accumulate.__mro__.__len__() == 2 — MRO is (accumulate, object). Verified with Python 3.14.3."
    - "chain.__mro__.__len__() == 2 — MRO is (chain, object). Verified with Python 3.14.3."
    - "compress.__mro__.__len__() == 2 — MRO is (compress, object). Verified with Python 3.14.3."
    - "dropwhile.__mro__.__len__() == 2 — MRO is (dropwhile, object). Verified with Python 3.14.3."
    - "filterfalse.__mro__.__len__() == 2 — MRO is (filterfalse, object). Verified with Python 3.14.3."
    - "groupby.__mro__.__len__() == 2 — MRO is (groupby, object). Verified with Python 3.14.3."
    - "islice.__mro__.__len__() == 2 — MRO is (islice, object). Verified with Python 3.14.3."
    - "pairwise.__mro__.__len__() == 2 — MRO is (pairwise, object). Verified with Python 3.14.3."
    - "permutations.__mro__.__len__() == 2 — MRO is (permutations, object). Verified with Python 3.14.3."
    - "product.__mro__.__len__() == 2 — MRO is (product, object). Verified with Python 3.14.3."
    - "starmap.__mro__.__len__() == 2 — MRO is (starmap, object). Verified with Python 3.14.3."
    - "takewhile.__mro__.__len__() == 2 — MRO is (takewhile, object). Verified with Python 3.14.3."
    - "zip_longest.__mro__.__len__() == 2 — MRO is (zip_longest, object). Verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# count/cycle/repeat/accumulate __mro__.__len__() == 2 — extra82
#
# Wave 246 theme: all itertools C types have __mro__.__len__()==2.
#
# itertools.count.__mro__.__len__()       == 2
# itertools.cycle.__mro__.__len__()       == 2
# itertools.repeat.__mro__.__len__()      == 2
# itertools.accumulate.__mro__.__len__()  == 2
#
# No prior itertools spec checks count/cycle/repeat/accumulate __mro__.__len__() via itrtoolsextra82. New to extra82.
# ---------------------------------------------------------------------------

table itertools_extra82.mro_len_group1:
  description: "count/cycle/repeat/accumulate __mro__.__len__()==2; wave 246 itertools C type __mro__ length; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra82

  columns: [id, function, args, expected, description]
  rows:
    - [count_mro_len_eq_2,
       "count.__mro__.__len__",
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — count is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object so its MRO is (count, object) — exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks count.__mro__.__len__() via itrtoolsextra82; new to extra82"]
    - [cycle_mro_len_eq_2,
       "cycle.__mro__.__len__",
       [],
       2,
       "itertools.cycle.__mro__.__len__() == 2 — cycle is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object so its MRO is (cycle, object) — exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks cycle.__mro__.__len__() via itrtoolsextra82; new to extra82"]
    - [repeat_mro_len_eq_2,
       "repeat.__mro__.__len__",
       [],
       2,
       "itertools.repeat.__mro__.__len__() == 2 — repeat is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object so its MRO is (repeat, object) — exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks repeat.__mro__.__len__() via itrtoolsextra82; new to extra82"]
    - [accumulate_mro_len_eq_2,
       "accumulate.__mro__.__len__",
       [],
       2,
       "itertools.accumulate.__mro__.__len__() == 2 — accumulate is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object so its MRO is (accumulate, object) — exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks accumulate.__mro__.__len__() via itrtoolsextra82; new to extra82"]

