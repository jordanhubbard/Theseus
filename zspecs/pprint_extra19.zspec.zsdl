spec: pprint_extra19
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra18.zspec.zsdl."
    - "pprint_extra14 covers: PrettyPrinter.__bases__[0].__name__=='object'; pformat/pprint/isreadable/isrecursive/saferepr __qualname__ standalones; pformat.__module__ standalone."
    - "pprint_extra16 covers: PrettyPrinter.pprint/pformat/isreadable/isrecursive __qualname__ as standalone invariants."
    - "pprint_extra17 covers: PrettyPrinter.__repr__.__qualname__; PrettyPrinter._pprint_dict/_pprint_list/_pprint_tuple/_pprint_set/_format __qualname__ standalones."
    - "pprint_extra18 covers: PrettyPrinter._pprint_ordered_dict/_pprint_dataclass/_format_dict_items/_format_items qualnames."
    - "No prior spec verifies PrettyPrinter.__init__.__qualname__ as a standalone invariant."
    - "No prior spec verifies PrettyPrinter.pprint.__qualname__ in a table row (only as standalone in extra16)."
    - "No prior spec verifies PrettyPrinter.pformat.__qualname__ in a table row (only as standalone in extra14/16)."
    - "No prior spec verifies PrettyPrinter.isrecursive.__qualname__ or PrettyPrinter.isreadable.__qualname__ in a table row."
    - "No prior spec verifies pprint.__all__.__class__.__name__ == 'list' as a standalone invariant."
    - "No prior spec verifies len(pprint.__all__) == 7 as a standalone invariant."
    - "pprint.PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__' — verified at runtime."
    - "pprint.PrettyPrinter.pprint.__qualname__ == 'PrettyPrinter.pprint' — verified at runtime."
    - "pprint.PrettyPrinter.pformat.__qualname__ == 'PrettyPrinter.pformat' — verified at runtime."
    - "pprint.PrettyPrinter.isrecursive.__qualname__ == 'PrettyPrinter.isrecursive' — verified at runtime."
    - "pprint.PrettyPrinter.isreadable.__qualname__ == 'PrettyPrinter.isreadable' — verified at runtime."
    - "pprint.PrettyPrinter.__repr__.__qualname__ == 'object.__repr__' — PrettyPrinter does not override __repr__; the method resolves to object. Verified at runtime."
    - "pprint.__all__.__class__.__name__ == 'list' — the __all__ export list is a plain Python list. Verified at runtime."
    - "len(pprint.__all__) == 7 — pprint exports exactly 7 names: ['PrettyPrinter','isreadable','isrecursive','pformat','pp','pprint','saferepr']. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter.__init__.__qualname__
#
# pprint_extra14/16/17/18 cover various public and private method qualnames
# but none verifies PrettyPrinter.__init__.__qualname__ as a standalone.
# The constructor's qualname is 'PrettyPrinter.__init__'. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra19.PrettyPrinter.__init__qualname:
  description: "pprint.PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__' — constructor qualname"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__init__.__qualname__.__eq__
  args: ["PrettyPrinter.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter.__repr__.__qualname__
#
# PrettyPrinter does not define its own __repr__; the attribute resolves to
# object.__repr__. Hence __qualname__ == 'object.__repr__', not
# 'PrettyPrinter.__repr__'. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra19.PrettyPrinter.__repr__qualname:
  description: "pprint.PrettyPrinter.__repr__.__qualname__ == 'object.__repr__' — PrettyPrinter inherits __repr__ from object"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__repr__.__qualname__.__eq__
  args: ["object.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# pprint.__all__ type and length
#
# No prior spec verifies the type of pprint.__all__ (a plain list) or its
# length (7 entries) as standalone invariants.
# Verified: __all__ == ['PrettyPrinter','isreadable','isrecursive','pformat','pp','pprint','saferepr'].
# ---------------------------------------------------------------------------

invariant pprint_extra19.__all__.class_name:
  description: "pprint.__all__.__class__.__name__ == 'list' — the __all__ export list is a plain Python list"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pprint_extra19.__all__.length:
  description: "len(pprint.__all__) == 7 — pprint exports exactly 7 public names"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Table: PrettyPrinter public method __qualname__ attributes
#
# Groups __init__, pprint, pformat, isrecursive, and isreadable qualname
# checks in one indexed table. No prior table covers __init__ qualname or
# assembles all five public method qualnames together.
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra19.PrettyPrinter_public_method_qualnames:
  description: "pprint.PrettyPrinter public method __qualname__ attributes — __init__, pprint, pformat, isrecursive, isreadable"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp19pmq

  columns: [id, function, args, expected]
  rows:
    - [__init__,    PrettyPrinter.__init__.__qualname__.__eq__,    ["PrettyPrinter.__init__"],    true]
    - [pprint,      PrettyPrinter.pprint.__qualname__.__eq__,      ["PrettyPrinter.pprint"],      true]
    - [pformat,     PrettyPrinter.pformat.__qualname__.__eq__,     ["PrettyPrinter.pformat"],     true]
    - [isrecursive, PrettyPrinter.isrecursive.__qualname__.__eq__, ["PrettyPrinter.isrecursive"], true]
    - [isreadable,  PrettyPrinter.isreadable.__qualname__.__eq__,  ["PrettyPrinter.isreadable"],  true]

# ---------------------------------------------------------------------------
# Table: pprint.__all__ structure checks
#
# Groups the type and length checks for pprint.__all__ in one indexed table.
# No prior table covers __all__.__class__.__name__ or __all__.__len__.
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra19.__all__structure:
  description: "pprint.__all__ structural checks — class name and length"
  kind: python_call_eq
  category: module_structure
  id_prefix: pp19as

  columns: [id, function, args, expected]
  rows:
    - [class_name, __all__.__class__.__name__.__eq__, ["list"], true]
    - [length,     __all__.__len__,                   [],        7   ]
