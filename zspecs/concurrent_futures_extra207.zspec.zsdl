spec: concurrent_futures_extra207
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.__dict__.__contains__('set_result') returns True — Future.set_result() is defined directly on the class; it sets the result of the future and notifies all callbacks."
    - "concurrent.futures.Future.__dict__.__contains__('set_exception') returns True — Future.set_exception() is defined directly on the class; it sets an exception result and notifies callbacks."
    - "concurrent.futures.Future.__dict__.__contains__('running') returns True — Future.running() is defined directly on the class; it returns True if the future is currently executing."
    - "concurrent.futures.Future.__dict__.__contains__('exception') returns True — Future.exception() is defined directly on the class; it returns the exception raised by the call or None."
    - "concurrent.futures.BrokenExecutor.__dict__.__contains__('__init__') returns False — BrokenExecutor does not define __init__ in its own class body; it inherits from RuntimeError and relies on RuntimeError.__init__."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor's sole base class is RuntimeError; this confirms the exception hierarchy."
    - "concurrent.futures.Future.__dict__ has 21 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, _invoke_callbacks, __repr__, cancel, cancelled, running, done, _Future__get_result, add_done_callback, result, exception, set_running_or_notify_cancel, set_result, set_exception, __class_getitem__, __static_attributes__, __dict__, __weakref__."
    - "concurrent.futures.BrokenExecutor.__dict__ has 5 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __static_attributes__, __weakref__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

