invariant concurrent_futures_extra207.future_dict_contains_set_result:
  description: "concurrent.futures.Future.__dict__.__contains__('set_result') returns True — concurrent.futures.Future defines set_result() directly in its class body in Lib/concurrent/futures/_base.py; Future.set_result(result) sets the result of the future to result; it also calls any added done callbacks; 'set_result' is in Future.__dict__ (not inherited from a base class); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["set_result"]
  expected: true

invariant concurrent_futures_extra207.future_dict_contains_set_exception:
  description: "concurrent.futures.Future.__dict__.__contains__('set_exception') returns True — concurrent.futures.Future defines set_exception() directly in its class body; Future.set_exception(exception) sets the exception associated with the future; done callbacks are called; 'set_exception' is in Future.__dict__ (not inherited); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["set_exception"]
  expected: true

invariant concurrent_futures_extra207.future_dict_contains_running:
  description: "concurrent.futures.Future.__dict__.__contains__('running') returns True — concurrent.futures.Future defines running() directly in its class body; Future.running() returns True if the future is currently executing and cannot be cancelled; 'running' is in Future.__dict__ (not inherited); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["running"]
  expected: true

invariant concurrent_futures_extra207.future_dict_contains_exception:
  description: "concurrent.futures.Future.__dict__.__contains__('exception') returns True — concurrent.futures.Future defines exception() directly in its class body; Future.exception() returns the exception raised by the call or None if no exception was raised; 'exception' is in Future.__dict__ (not inherited); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["exception"]
  expected: true

invariant concurrent_futures_extra207.broken_executor_no_init:
  description: "concurrent.futures.BrokenExecutor.__dict__.__contains__('__init__') returns False — concurrent.futures.BrokenExecutor does not define __init__ in its own class body; BrokenExecutor inherits directly from RuntimeError and relies on RuntimeError.__init__ for initialization; '__init__' is NOT in BrokenExecutor.__dict__; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__dict__.__contains__
  args: ["__init__"]
  expected: false

invariant concurrent_futures_extra207.broken_executor_base_is_runtime_error:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor's sole base class is RuntimeError; BrokenExecutor.__bases__ is the tuple (<class 'RuntimeError'>,); __bases__[0].__name__ is 'RuntimeError'; this confirms BrokenExecutor is a RuntimeError subclass and should be caught with except RuntimeError; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra207.future_dict_len:
  description: "concurrent.futures.Future.__dict__.__len__() returns 21 — concurrent.futures.Future's class dict has 21 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, _invoke_callbacks, __repr__, cancel, cancelled, running, done, _Future__get_result, add_done_callback, result, exception, set_running_or_notify_cancel, set_result, set_exception, __class_getitem__, __static_attributes__, __dict__, __weakref__; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__len__
  args: []
  expected: 21

invariant concurrent_futures_extra207.broken_executor_dict_len:
  description: "concurrent.futures.BrokenExecutor.__dict__.__len__() returns 5 — concurrent.futures.BrokenExecutor's class dict has 5 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __static_attributes__, __weakref__; BrokenExecutor is a thin exception subclass with no additional methods; its small dict confirms it delegates all behavior to RuntimeError; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__dict__.__len__
