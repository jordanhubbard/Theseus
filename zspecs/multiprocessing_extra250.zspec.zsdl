spec: multiprocessing_extra250
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.get_start_method, set_start_method, and get_context are bound methods of a DefaultContext instance."
    - "multiprocessing.get_logger and log_to_stderr are bound methods of BaseContext (parent of DefaultContext)."
    - "All five functions have __class__.__name__ == 'method' — they are bound instance methods, not plain functions."
    - "All five functions report __module__ == 'multiprocessing.context'."
    - "get_start_method.__qualname__ == 'DefaultContext.get_start_method'."
    - "get_logger.__qualname__ == 'BaseContext.get_logger'; log_to_stderr.__qualname__ == 'BaseContext.log_to_stderr'."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.get_start_method — identity
# ---------------------------------------------------------------------------

invariant multiprocessing_extra250.get_start_method.__name__:
  description: "multiprocessing.get_start_method.__name__ == 'get_start_method'"
  category: identity
  kind: python_call_eq
  function: get_start_method.__name__.__eq__
  args: ["get_start_method"]
  expected: true

invariant multiprocessing_extra250.get_start_method.__qualname__:
  description: "multiprocessing.get_start_method.__qualname__ == 'DefaultContext.get_start_method'"
  category: identity
  kind: python_call_eq
  function: get_start_method.__qualname__.__eq__
  args: ["DefaultContext.get_start_method"]
  expected: true

invariant multiprocessing_extra250.get_start_method.__module__:
  description: "multiprocessing.get_start_method.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: get_start_method.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra250.get_start_method.__class__.__name__:
  description: "multiprocessing.get_start_method.__class__.__name__ == 'method' — bound instance method"
  category: identity
  kind: python_call_eq
  function: get_start_method.__class__.__name__.__eq__
  args: ["method"]
  expected: true

