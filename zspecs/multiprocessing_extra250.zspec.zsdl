# ---------------------------------------------------------------------------
# Cross-function table: __name__ for all five functions
# ---------------------------------------------------------------------------

table multiprocessing_extra250.function_names:
  description: "All five multiprocessing context functions report expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected, description]
  rows:
    - [get_start_method, get_start_method.__name__.__eq__, ["get_start_method"], true, "multiprocessing.get_start_method.__name__"]
    - [set_start_method, set_start_method.__name__.__eq__, ["set_start_method"], true, "multiprocessing.set_start_method.__name__"]
    - [get_context,      get_context.__name__.__eq__,      ["get_context"],      true, "multiprocessing.get_context.__name__"]
    - [get_logger,       get_logger.__name__.__eq__,       ["get_logger"],       true, "multiprocessing.get_logger.__name__"]
    - [log_to_stderr,    log_to_stderr.__name__.__eq__,    ["log_to_stderr"],    true, "multiprocessing.log_to_stderr.__name__"]

# ---------------------------------------------------------------------------
# Cross-function table: __qualname__ showing DefaultContext vs BaseContext
# ---------------------------------------------------------------------------

table multiprocessing_extra250.function_qualnames:
  description: "DefaultContext methods vs BaseContext methods as reflected in __qualname__"
  kind: python_call_eq
  category: identity
  id_prefix: fqname

  columns: [id, function, args, expected, description]
  rows:
    - [get_start_method, get_start_method.__qualname__.__eq__, ["DefaultContext.get_start_method"], true, "get_start_method defined on DefaultContext"]
    - [set_start_method, set_start_method.__qualname__.__eq__, ["DefaultContext.set_start_method"], true, "set_start_method defined on DefaultContext"]
    - [get_context,      get_context.__qualname__.__eq__,      ["DefaultContext.get_context"],      true, "get_context defined on DefaultContext"]
    - [get_logger,       get_logger.__qualname__.__eq__,       ["BaseContext.get_logger"],          true, "get_logger defined on BaseContext"]
    - [log_to_stderr,    log_to_stderr.__qualname__.__eq__,    ["BaseContext.log_to_stderr"],       true, "log_to_stderr defined on BaseContext"]

# ---------------------------------------------------------------------------
# Cross-function table: all five are bound methods
# ---------------------------------------------------------------------------

table multiprocessing_extra250.function_classes:
  description: "All five multiprocessing top-level functions are bound methods (class: method)"
  kind: python_call_eq
  category: identity
  id_prefix: fcls

  columns: [id, function, args, expected, description]
  rows:
    - [get_start_method, get_start_method.__class__.__name__.__eq__, ["method"], true, "get_start_method is a bound method"]
    - [set_start_method, set_start_method.__class__.__name__.__eq__, ["method"], true, "set_start_method is a bound method"]
    - [get_context,      get_context.__class__.__name__.__eq__,      ["method"], true, "get_context is a bound method"]
    - [get_logger,       get_logger.__class__.__name__.__eq__,       ["method"], true, "get_logger is a bound method"]
    - [log_to_stderr,    log_to_stderr.__class__.__name__.__eq__,    ["method"], true, "log_to_stderr is a bound method"]
