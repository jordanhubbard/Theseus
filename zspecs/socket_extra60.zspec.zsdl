spec: socket_extra60
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra59.zspec.zsdl — covers socket.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "socket_extra58.zspec.zsdl — covers socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "socket_extra50.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values."
    - "socket_extra44.zspec.zsdl — covers socket.socket recvfrom/sendto/connect_ex/recv_into/recvfrom_into __name__.__eq__ string values (__name__ axis, NOT __qualname__.__eq__)."
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra36.zspec.zsdl — covers socket.socket.dup/get_inheritable/set_inheritable __qualname__.__len__() (length axis only; does NOT check __qualname__.__eq__ string values)."
    - "socket_extra22.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/close/recv/send __qualname__.__eq__ string values."
    - "socket_extra8.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection __qualname__.__eq__ string values (module-level functions)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra59; it does NOT duplicate invariants present in those files."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "socket.socket is a C extension class named 'socket'. Its method descriptors use 'socket.' (the class name) as the prefix in __qualname__ — e.g., socket.socket.recv_into.__qualname__ == 'socket.recv_into'. This is distinct from the module name; the class is named 'socket', not 'socket.socket'."
    - "socket_extra50/extra22 cover connect/bind/listen/accept/send/recv/close __qualname__.__eq__. socket_extra42 covers shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__. socket_extra36 covers get_inheritable/set_inheritable __qualname__.__len__()==22 (length axis only). No prior socket spec checks __qualname__.__eq__ string values for recv_into, recvfrom_into, getblocking, get_inheritable, or set_inheritable. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv_into.__qualname__ == 'socket.recv_into' (len 16). socket_extra44 covers recv_into.__name__.__eq__('recv_into') (__name__ axis); no prior spec checks recv_into.__qualname__.__eq__('socket.recv_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom_into.__qualname__ == 'socket.recvfrom_into' (len 20). socket_extra32 covers recvfrom_into.__qualname__.__len__()==20 (length axis); socket_extra44 covers __name__.__eq__; no prior spec checks recvfrom_into.__qualname__.__eq__('socket.recvfrom_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getblocking.__qualname__ == 'socket.getblocking' (len 18). No prior socket spec checks getblocking.__qualname__.__eq__ or __qualname__.__len__() in any form. This is the first qualname anchor for getblocking. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.get_inheritable.__qualname__ == 'socket.get_inheritable' (len 22). socket_extra36 covers get_inheritable.__qualname__.__len__()==22 (length axis only); no prior spec checks get_inheritable.__qualname__.__eq__('socket.get_inheritable'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.set_inheritable.__qualname__ == 'socket.set_inheritable' (len 22). socket_extra36 covers set_inheritable.__qualname__.__len__()==22 (length axis only); no prior spec checks set_inheritable.__qualname__.__eq__('socket.set_inheritable'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __qualname__.__eq__ string values — novel methods
#
# Wave 227 theme: Class method __qualname__ string equality checks for methods
# not yet covered.
#
# Prior __qualname__.__eq__ coverage:
#   extra22/extra50: connect/bind/listen/accept/send/recv/close
#   extra42:         shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach
#   extra36:         get_inheritable/set_inheritable __qualname__.__len__ (length only)
#   extra44:         recv_into/recvfrom_into __name__.__eq__ (different axis)
#
# Novel for this spec: recv_into, recvfrom_into, getblocking, get_inheritable,
# set_inheritable — all have __qualname__.__eq__ uncovered.
# The socket.socket class is named 'socket' so qualnames are 'socket.<method>'.
# ---------------------------------------------------------------------------

table socket_extra60.socket_novel_method_qualname_eq:
  description: "socket.socket recv_into/recvfrom_into/getblocking/get_inheritable/set_inheritable __qualname__.__eq__ string values — socket class named 'socket' so qualnames use 'socket.' prefix; extra22/42 cover connect/bind/etc; extra36 covers get_inheritable/set_inheritable __len__ only; extra44 covers recv_into/recvfrom_into __name__.__eq__ only; no prior spec checks __qualname__.__eq__ for any of these five methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: socketqual60

  columns: [id, function, args, expected]
  rows:
    - [recv_into_qualname_eq,     socket.recv_into.__qualname__.__eq__,     ["socket.recv_into"],     true]
    - [recvfrom_into_qualname_eq, socket.recvfrom_into.__qualname__.__eq__, ["socket.recvfrom_into"], true]
    - [getblocking_qualname_eq,   socket.getblocking.__qualname__.__eq__,   ["socket.getblocking"],   true]
    - [get_inheritable_qualname_eq, socket.get_inheritable.__qualname__.__eq__, ["socket.get_inheritable"], true]
    - [set_inheritable_qualname_eq, socket.set_inheritable.__qualname__.__eq__, ["socket.set_inheritable"], true]

# ---------------------------------------------------------------------------
# socket.socket.recv_into.__qualname__.__eq__('socket.recv_into') — standalone
#
# socket_extra44 covers socket.socket.recv_into.__name__.__eq__('recv_into')
# (the __name__ axis; bare method name without class prefix). The complementary
# __qualname__.__eq__ axis — confirming the class-prefixed qualname string
# 'socket.recv_into' — is entirely novel. No prior socket spec checks
# recv_into.__qualname__.__eq__. The qualname uses 'socket.' (the class name)
# not 'socket.socket.' (the module + class path).
# ---------------------------------------------------------------------------

invariant socket_extra60.socket_recv_into_qualname_str:
  description: "socket.socket.recv_into.__qualname__.__eq__('socket.recv_into') == True — socket class named 'socket' so method qualnames use 'socket.' prefix; socket_extra44 covers recv_into.__name__.__eq__('recv_into') (__name__ axis); no prior spec checks recv_into.__qualname__.__eq__; first qualname string equality anchor for recv_into"
  category: method_qualnames
  kind: python_call_eq
  function: socket.recv_into.__qualname__.__eq__
  args: ["socket.recv_into"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getblocking.__qualname__.__eq__('socket.getblocking') — standalone
#
# getblocking() returns True if the socket is in blocking mode. No prior socket
# spec checks getblocking in any qualname context (__eq__ or __len__). This is
# the first qualname anchor for getblocking. The qualname 'socket.getblocking'
# (18 chars) follows the standard 'socket.<method>' pattern for socket.socket
# method descriptors.
# ---------------------------------------------------------------------------

invariant socket_extra60.socket_getblocking_qualname_str:
  description: "socket.socket.getblocking.__qualname__.__eq__('socket.getblocking') == True — getblocking() returns True if socket is blocking; no prior socket spec checks getblocking.__qualname__ in any form (__eq__ or __len__); first qualname anchor for getblocking; follows 'socket.<method>' pattern"
  category: method_qualnames
  kind: python_call_eq
  function: socket.getblocking.__qualname__.__eq__
  args: ["socket.getblocking"]
  expected: true
