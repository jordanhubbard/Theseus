spec: ospath_extra_rust
version: ">=3.9"
backend: rust_module(ospath_extra_rust)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — os.path"
  notes:
    - "os.path provides path manipulation utilities."
    - "os.path.join('a', 'b') == 'a/b'."
    - "os.path.exists('/') is True."
    - "os.path.basename('/foo/bar.txt') == 'bar.txt'."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant ospath_extra_rust.join_ab:
  description: "os.path.join('a','b') == 'a/b'"
  category: join
  kind: python_call_eq
  function: ospath_extra_join_ab
  args: []
  expected: "a/b"

invariant ospath_extra_rust.exists_root:
  description: "os.path.exists('/') is True"
  category: exists
  kind: python_call_eq
  function: ospath_extra_exists_root
  args: []
  expected: true

invariant ospath_extra_rust.basename_txt:
  description: "os.path.basename('/foo/bar.txt') == 'bar.txt'"
  category: basename
  kind: python_call_eq
  function: ospath_extra_basename_txt
  args: []
  expected: "bar.txt"

