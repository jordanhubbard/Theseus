spec: imaplib_extra
version: ">=3.9"
backend: python_module(imaplib)

docs: https://docs.python.org/3/library/imaplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imaplib.html — Python imaplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imaplib.py"
  notes:
    - "Extends imaplib.zspec.zsdl with nested exception class names, module checks, hierarchy, and method name invariants."
    - "imaplib.IMAP4.__name__ == 'IMAP4' — core IMAP4 client class."
    - "imaplib.IMAP4.__module__ == 'imaplib' — defined in the imaplib module."
    - "imaplib.IMAP4_SSL.__name__ == 'IMAP4_SSL' — TLS-enabled subclass of IMAP4."
    - "imaplib.IMAP4_SSL.__bases__[0].__name__ == 'IMAP4' — IMAP4_SSL inherits directly from IMAP4."
    - "imaplib.IMAP4.error is a nested exception class; its __name__ == 'error'."
    - "imaplib.IMAP4.error.__bases__[0].__name__ == 'Exception' — error inherits directly from Exception."
    - "imaplib.IMAP4.abort is a nested exception class; __bases__[0].__name__ == 'error'."
    - "imaplib.IMAP4.readonly is a nested exception class; __bases__[0].__name__ == 'abort'."
    - "The exception hierarchy is: abort -> error -> Exception; readonly -> abort -> error -> Exception."
    - "imaplib.IMAP4.debug is an instance attribute (set to the module-level Debug variable in __init__), not a class attribute."
    - "IMAP4 methods include login, logout, select, search, fetch, append, close, expunge, store, copy."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IMAP4 — class name and module
# ---------------------------------------------------------------------------

invariant imaplib_extra.IMAP4.name:
  description: "imaplib.IMAP4.__name__ == 'IMAP4'"
  category: class_names
  kind: python_call_eq
  function: IMAP4.__name__.__eq__
  args: ["IMAP4"]
  expected: true

invariant imaplib_extra.IMAP4.module:
  description: "imaplib.IMAP4.__module__ == 'imaplib'"
  category: class_modules
  kind: python_call_eq
  function: IMAP4.__module__.__eq__
  args: ["imaplib"]
  expected: true

# ---------------------------------------------------------------------------
# IMAP4_SSL — class name and base class
# ---------------------------------------------------------------------------

invariant imaplib_extra.IMAP4_SSL.name:
  description: "imaplib.IMAP4_SSL.__name__ == 'IMAP4_SSL'"
  category: class_names
  kind: python_call_eq
  function: IMAP4_SSL.__name__.__eq__
  args: ["IMAP4_SSL"]
  expected: true

invariant imaplib_extra.IMAP4_SSL.base_class:
  description: "imaplib.IMAP4_SSL.__bases__[0].__name__ == 'IMAP4' — IMAP4_SSL inherits directly from IMAP4"
  category: class_hierarchy
  kind: python_call_eq
  function: IMAP4_SSL.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "IMAP4"

# ---------------------------------------------------------------------------
# Nested exception classes — names
# ---------------------------------------------------------------------------

invariant imaplib_extra.IMAP4.error.name:
  description: "imaplib.IMAP4.error.__name__ == 'error' — nested exception class on IMAP4"
  category: class_names
  kind: python_call_eq
  function: IMAP4.error.__name__.__eq__
  args: ["error"]
  expected: true

invariant imaplib_extra.IMAP4.abort.name:
  description: "imaplib.IMAP4.abort.__name__ == 'abort' — nested exception class on IMAP4"
  category: class_names
  kind: python_call_eq
  function: IMAP4.abort.__name__.__eq__
  args: ["abort"]
  expected: true

invariant imaplib_extra.IMAP4.readonly.name:
  description: "imaplib.IMAP4.readonly.__name__ == 'readonly' — nested exception class on IMAP4"
  category: class_names
  kind: python_call_eq
  function: IMAP4.readonly.__name__.__eq__
  args: ["readonly"]
  expected: true

# ---------------------------------------------------------------------------
# Nested exception hierarchy
# ---------------------------------------------------------------------------

invariant imaplib_extra.IMAP4.error.base_class:
  description: "imaplib.IMAP4.error.__bases__[0].__name__ == 'Exception' — error inherits directly from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: IMAP4.error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant imaplib_extra.IMAP4.abort.base_class:
  description: "imaplib.IMAP4.abort.__bases__[0].__name__ == 'error' — abort inherits directly from IMAP4.error"
  category: class_hierarchy
  kind: python_call_eq
  function: IMAP4.abort.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "error"

invariant imaplib_extra.IMAP4.readonly.base_class:
  description: "imaplib.IMAP4.readonly.__bases__[0].__name__ == 'abort' — readonly inherits directly from IMAP4.abort"
  category: class_hierarchy
  kind: python_call_eq
  function: IMAP4.readonly.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "abort"

# ---------------------------------------------------------------------------
# IMAP4 method names
# ---------------------------------------------------------------------------

table imaplib_extra.IMAP4.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: method_name

  columns: [id, function, args, expected]
  rows:
    - [login,    IMAP4.login.__name__.__eq__,    ["login"],    true]
    - [logout,   IMAP4.logout.__name__.__eq__,   ["logout"],   true]
    - [select,   IMAP4.select.__name__.__eq__,   ["select"],   true]
    - [search,   IMAP4.search.__name__.__eq__,   ["search"],   true]
    - [fetch,    IMAP4.fetch.__name__.__eq__,    ["fetch"],    true]
    - [append,   IMAP4.append.__name__.__eq__,   ["append"],   true]
    - [close,    IMAP4.close.__name__.__eq__,    ["close"],    true]
    - [expunge,  IMAP4.expunge.__name__.__eq__,  ["expunge"],  true]
    - [store,    IMAP4.store.__name__.__eq__,    ["store"],    true]
    - [copy,     IMAP4.copy.__name__.__eq__,     ["copy"],     true]
