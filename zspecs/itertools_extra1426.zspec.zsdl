spec: itertools_extra1426
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for itertools classes."
    - "All itertools types are C extension types (itertoolsmodule.c); __format__ and __dir__ are inherited from object."
    - "itertools.chain.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.count.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.cycle.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.repeat.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.accumulate.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.combinations.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.product.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "itertools.islice.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "None of the itertools classes define '__format__' or '__dir__' in their own __dict__. Verified Python 3.14.3."
    - "All itertools classes have __format__.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __format__ method type checks
#
# Wave 542 theme: __format__.__class__.__name__ checks for itertools C types.
# All eight classes — chain, count, cycle, repeat, accumulate, combinations,
# product, islice — inherit __format__ from object as 'method_descriptor'.
# ---------------------------------------------------------------------------

table itertools_extra1426.format_class_name:
  description: "itertools classes: __format__.__class__.__name__ == 'method_descriptor' for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_class_name
  id_prefix: it1426fc

  columns: [id, function, args, expected, description]
  rows:
    - [it1426fc001,
       "itertools.chain.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.chain.__format__.__class__.__name__.__eq__('method_descriptor') == True — chain is a C extension type; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [it1426fc002,
