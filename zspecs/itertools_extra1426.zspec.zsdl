       true,
       "itertools.repeat.__format__.__class__.__name__.__eq__('method_descriptor') == True — repeat is a C extension type; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [it1426fc005,
       "itertools.accumulate.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.accumulate.__format__.__class__.__name__.__eq__('method_descriptor') == True — accumulate is a C extension type; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [it1426fc006,
       "itertools.combinations.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.combinations.__format__.__class__.__name__.__eq__('method_descriptor') == True — combinations is a C extension type; __format__ inherited from object as method_descriptor; new to extra1426"]
