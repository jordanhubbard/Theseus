# ---------------------------------------------------------------------------
# Table 2: itertools class __format__ and __dir__ absence from own __dict__
#
# Wave 542 theme: '__format__' and '__dir__' not in own __dict__ for itertools
# classes. All eight classes are pure C types; neither method is overridden.
# ---------------------------------------------------------------------------

table itertools_extra1426.format_dir_dict_membership:
  description: "itertools classes: '__format__' and '__dir__' not in own __dict__ for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_dir_dict_membership
  id_prefix: it1426dm

  columns: [id, function, args, expected, description]
  rows:
    - [it1426dm001,
       "itertools.chain.__dict__.__contains__",
       ["__format__"],
       false,
       "itertools.chain.__dict__.__contains__('__format__') == False — chain does not define __format__ in its own __dict__; inherited from object; new to extra1426"]
    - [it1426dm002,
       "itertools.count.__dict__.__contains__",
       ["__format__"],
       false,
       "itertools.count.__dict__.__contains__('__format__') == False — count does not define __format__ in its own __dict__; inherited from object; new to extra1426"]
