# ---------------------------------------------------------------------------
# Standalone invariants — extra1426
# ---------------------------------------------------------------------------

invariant itertools_extra1426.chain_format_is_method_descriptor:
  description: "itertools.chain.__format__.__class__.__name__ == 'method_descriptor' — __format__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: itertools.chain.__format__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant itertools_extra1426.chain_format_not_in_dict:
  description: "'__format__' not in itertools.chain.__dict__ — chain does not override __format__; wave 542; new to extra1426"
  kind: python_call_eq
  function: itertools.chain.__dict__.__contains__
  args: ["__format__"]
  expected: false

invariant itertools_extra1426.chain_dir_is_method_descriptor:
  description: "itertools.chain.__dir__.__class__.__name__ == 'method_descriptor' — __dir__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: itertools.chain.__dir__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant itertools_extra1426.chain_dir_not_in_dict:
  description: "'__dir__' not in itertools.chain.__dict__ — chain does not override __dir__; wave 542; new to extra1426"
