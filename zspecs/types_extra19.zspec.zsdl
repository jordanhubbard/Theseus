spec: types_extra19
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types_extra18.zspec.zsdl — covers __name__.__eq__ table for FunctionType/LambdaType/MethodType/BuiltinFunctionType/ModuleType/GeneratorType/CoroutineType/NoneType; __name__.__len__ table for NoneType/CoroutineType/ModuleType/GeneratorType/BuiltinFunctionType"
    - "types_extra17.zspec.zsdl — covers __qualname__ table for FunctionType/LambdaType/CodeType/MappingProxyType/SimpleNamespace/GeneratorType/CoroutineType; __module__ table"
    - "types_extra16.zspec.zsdl — covers __mro__[1].__name__ for FunctionType/MethodType/CodeType/CoroutineType; standalone __qualname__.__eq__ for FunctionType/ModuleType/MethodType"
    - "types_extra9.zspec.zsdl — covers __name__.__eq__ for FunctionType/LambdaType/GeneratorType/CoroutineType/CodeType/MethodType/BuiltinFunctionType/ModuleType/NoneType etc."
  notes:
    - "This spec extends types.zspec.zsdl through types_extra18.zspec.zsdl."
    - "Focus: __bases__[0].__name__ and __bases__.__len__() for core types module type objects."
    - "All types.FunctionType/LambdaType/GeneratorType/ModuleType/CodeType/MethodType/__bases__[0].__name__ are 'object' — these C builtin types all directly subclass object."
    - "types.FunctionType is types.LambdaType — they are the same object; __bases__ is identical."
    - "All six core types have exactly one direct base class (object)."
    - "types.FunctionType.__qualname__ == 'function' — the internal C-level type name."
    - "types.GeneratorType.__qualname__ == 'generator' — internal C type name."
    - "types.CodeType.__qualname__ == 'code' — internal C type name (len 4)."
    - "types.MethodType.__qualname__ == 'method' — internal C type name (len 6)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for core types — table
#
# No prior types spec checks __bases__[0].__name__ for FunctionType, GeneratorType,
# ModuleType, CodeType, MethodType, or BuiltinFunctionType in a combined table.
# All of these C builtin types directly subclass object, so __bases__[0].__name__
# is 'object' for each.
# ---------------------------------------------------------------------------

table types_extra19.type_bases:
  description: "__bases__[0].__name__ for core types module type objects"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base0

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,        "FunctionType.__bases__.__getitem__(0).__name__.__eq__",        ["object"], true]
    - [GeneratorType,       "GeneratorType.__bases__.__getitem__(0).__name__.__eq__",       ["object"], true]
    - [ModuleType,          "ModuleType.__bases__.__getitem__(0).__name__.__eq__",          ["object"], true]
    - [CodeType,            "CodeType.__bases__.__getitem__(0).__name__.__eq__",            ["object"], true]
    - [MethodType,          "MethodType.__bases__.__getitem__(0).__name__.__eq__",          ["object"], true]
    - [BuiltinFunctionType, "BuiltinFunctionType.__bases__.__getitem__(0).__name__.__eq__", ["object"], true]

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for core types — standalone invariants
#
# Each of these C builtin types has exactly one direct base class (object).
# No prior types spec covers __bases__.__len__() for any of these types.
# ---------------------------------------------------------------------------

invariant types_extra19.FunctionType.bases_len:
  description: "types.FunctionType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: FunctionType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra19.GeneratorType.bases_len:
  description: "types.GeneratorType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: GeneratorType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra19.ModuleType.bases_len:
  description: "types.ModuleType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: ModuleType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra19.CodeType.bases_len:
  description: "types.CodeType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: CodeType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra19.MethodType.bases_len:
  description: "types.MethodType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: MethodType.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# __qualname__.__len__() for core types — standalone invariants
#
# types_extra17 covers __qualname__.__eq__ for FunctionType/LambdaType/CodeType/
# MappingProxyType/SimpleNamespace/GeneratorType/CoroutineType. No prior spec
# covers __qualname__.__len__() for CodeType or MethodType as standalone
# invariants in the extra19 namespace.
# types.CodeType.__qualname__ == 'code' (len 4).
# types.MethodType.__qualname__ == 'method' (len 6).
# ---------------------------------------------------------------------------

invariant types_extra19.CodeType.qualname_len:
  description: "types.CodeType.__qualname__.__len__() == 4 — qualname 'code' has 4 characters"
  category: type_name_lengths
  kind: python_call_eq
  function: CodeType.__qualname__.__len__
  args: []
  expected: 4

invariant types_extra19.MethodType.qualname_len:
  description: "types.MethodType.__qualname__.__len__() == 6 — qualname 'method' has 6 characters"
  category: type_name_lengths
  kind: python_call_eq
  function: MethodType.__qualname__.__len__
  args: []
  expected: 6
