spec: collections_extra32
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra31.zspec.zsdl."
    - "Prior specs covered: OrderedDict/defaultdict/Counter/deque/ChainMap/UserDict/UserList/UserString __name__/__module__/__qualname__/__bases__, namedtuple, __module__.__len__() for all eight classes (all 11), __name__.__len__() for OrderedDict/defaultdict/Counter/deque."
    - "This spec covers: __name__.__len__() for ChainMap/UserDict/UserList/UserString/namedtuple; __qualname__.__len__() for OrderedDict/ChainMap/Counter/deque/UserDict/UserList/UserString/namedtuple."
    - "collections.ChainMap.__name__.__len__() == 8 — 'ChainMap' has length 8."
    - "collections.UserDict.__name__.__len__() == 8 — 'UserDict' has length 8."
    - "collections.UserList.__name__.__len__() == 8 — 'UserList' has length 8."
    - "collections.UserString.__name__.__len__() == 10 — 'UserString' has length 10."
    - "collections.namedtuple.__name__.__len__() == 10 — 'namedtuple' has length 10."
    - "All __qualname__.__len__() values match __name__.__len__() for these top-level symbols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — name string lengths for ChainMap/UserDict/UserList/
# UserString/namedtuple (extra32 namespace)
#
# collections_extra31 covered OrderedDict (11), defaultdict (11), Counter (7),
# and deque (5). This table extends that coverage to the remaining five
# top-level symbols:
#   ChainMap -> 8, UserDict -> 8, UserList -> 8, UserString -> 10,
#   namedtuple -> 10.
# No prior collections spec records __name__.__len__() for these five together
# in the extra32 namespace.
# ---------------------------------------------------------------------------

table collections_extra32.name_str_lengths:
  description: "__name__.__len__() for ChainMap/UserDict/UserList/UserString/namedtuple"
  kind: python_call_eq
  category: string_properties
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [ChainMap,   ChainMap.__name__.__len__,   [], 8]
    - [UserDict,   UserDict.__name__.__len__,   [], 8]
    - [UserList,   UserList.__name__.__len__,   [], 8]
    - [UserString, UserString.__name__.__len__, [], 10]
    - [namedtuple, namedtuple.__name__.__len__, [], 10]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — qualname string lengths for all eight core
# collection classes plus namedtuple (extra32 namespace)
#
# All nine symbols are defined at module scope, so __qualname__ == __name__
# for each. Consequently __qualname__.__len__() matches __name__.__len__().
# This table assembles the full qualname-length picture for all nine symbols
# together for the first time in the extra32 namespace:
#   OrderedDict -> 11, defaultdict -> 11, Counter -> 7, deque -> 5,
#   ChainMap -> 8, UserDict -> 8, UserList -> 8, UserString -> 10,
#   namedtuple -> 10.
# ---------------------------------------------------------------------------

table collections_extra32.qualname_str_lengths:
  description: "__qualname__.__len__() for core collection classes — matches __name__.__len__() for top-level symbols"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [OrderedDict, OrderedDict.__qualname__.__len__, [], 11]
    - [defaultdict, defaultdict.__qualname__.__len__, [], 11]
    - [Counter,     Counter.__qualname__.__len__,     [], 7]
    - [deque,       deque.__qualname__.__len__,       [], 5]
    - [ChainMap,    ChainMap.__qualname__.__len__,    [], 8]
    - [UserDict,    UserDict.__qualname__.__len__,    [], 8]
    - [UserList,    UserList.__qualname__.__len__,    [], 8]
    - [UserString,  UserString.__qualname__.__len__,  [], 10]
    - [namedtuple,  namedtuple.__qualname__.__len__,  [], 10]

# ---------------------------------------------------------------------------
# UserString.__name__.__len__() == 10 — standalone (extra32 namespace)
#
# 'UserString' has 10 characters. Among the User* wrappers, UserDict and
# UserList share length 8, while UserString is 2 characters longer. UserString
# wraps str objects and provides a mutable string-like interface. No prior
# collections spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra32.UserString.name_len:
  description: "len(collections.UserString.__name__) == 10 — 'UserString' is longer than UserDict/UserList (both 8)"
  category: string_properties
  kind: python_call_eq
  function: UserString.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# namedtuple.__qualname__.__len__() == 10 — standalone (extra32 namespace)
#
# 'namedtuple' is a module-level factory function, so its __qualname__ equals
# its __name__. Both have length 10. This confirms that the qualname for
# a module-level function is identical to its plain name. No prior collections
# spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra32.namedtuple.qualname_len:
  description: "len(collections.namedtuple.__qualname__) == 10 — top-level function so qualname equals name"
  category: string_properties
  kind: python_call_eq
  function: namedtuple.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# OrderedDict.__qualname__.__len__() == 11 — standalone (extra32 namespace)
#
# 'OrderedDict' has 11 characters. As a top-level class its __qualname__ equals
# its __name__, both length 11. This is the maximum qualname length among all
# core collection classes covered in this spec. No prior collections spec
# records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra32.OrderedDict.qualname_len:
  description: "len(collections.OrderedDict.__qualname__) == 11 — longest qualname among core collection classes"
  category: string_properties
  kind: python_call_eq
  function: OrderedDict.__qualname__.__len__
  args: []
  expected: 11
