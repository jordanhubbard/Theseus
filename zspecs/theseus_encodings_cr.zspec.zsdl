spec: theseus_encodings_cr
version: ">=3.0"
backend: python_cleanroom(theseus_encodings_cr)
blocks: encodings

docs: https://docs.python.org/3/library/codecs.html#encodings-and-unicode

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/codecs.html"
  not_derived_from:
    - "CPython source: Lib/encodings/__init__.py"
  notes:
    - "Clean-room encodings module. Do NOT import encodings."

error_model: python_exceptions

invariant theseus_encodings_cr.enc2_normalize:
  description: "normalize_encoding() normalizes codec names"
  category: behavior
  kind: python_call_eq
  function: enc2_normalize
  args: []
  expected: true

invariant theseus_encodings_cr.enc2_search:
  description: "search_function() finds codecs via codecs module"
  category: behavior
  kind: python_call_eq
  function: enc2_search
  args: []
  expected: true

invariant theseus_encodings_cr.enc2_error_class:
  description: "CodecRegistryError exception class exists"
  category: behavior
  kind: python_call_eq
  function: enc2_error_class
  args: []
  expected: true
