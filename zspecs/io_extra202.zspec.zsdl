spec: io_extra202
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers io.TextIOWrapper class identity attributes not covered by prior io_extra specs."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=13); TextIOWrapper is the buffered text stream wrapper class; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__module__ == '_io' (len=3); TextIOWrapper is implemented in the C extension module _io; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (len=11); TextIOWrapper's direct base class is _TextIOBase; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__class__.__name__ == 'type' (len=4); TextIOWrapper is a class object using the plain type metaclass; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__init__.__qualname__ == 'TextIOWrapper.__init__' (len=22); qualified name confirms __init__ belongs to TextIOWrapper; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read' (len=18); qualified name of the read method; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write' (len=19); qualified name of the write method; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.encoding.__class__.__name__ == 'member_descriptor' (len=17); encoding is a C-level member descriptor, not a plain property; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

