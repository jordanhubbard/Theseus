spec: pathlib_extra155
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path.__dict__.__contains__ membership for key filesystem operation methods (open, read_text, write_text, mkdir, exists, stat, is_dir, is_file, glob, unlink, rename, iterdir, cwd, home, absolute, touch, rmdir). Also covers pathlib.PurePath.__dict__.__contains__ for path manipulation attributes (parts, parent, parents, name, suffix, suffixes, stem, drive, root, anchor, joinpath, with_name, with_suffix, is_absolute, as_posix, as_uri, match, relative_to)."
    - "All checked Path methods are in Path.__dict__ (not inherited from PurePath) — stat, exists, is_dir, is_file, open, read_text, write_text, mkdir, rmdir, unlink, rename, iterdir, glob, touch, cwd, home, absolute are all Path-only filesystem methods."
    - "All checked PurePath attributes are in PurePath.__dict__ — parts, parent, parents, name, suffix, suffixes, stem, drive, root, anchor, joinpath, with_name, with_suffix, is_absolute, as_posix, as_uri, match, relative_to are defined on PurePath."
    - "pathlib.Path.__module__ == 'pathlib' (len=7); pathlib.PurePath.__module__ == 'pathlib' (len=7)."
    - "pathlib.Path.__name__ == 'Path' (len=4); pathlib.PurePath.__name__ == 'PurePath' (len=8)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__contains__ — filesystem operation methods
# All of these are defined directly in Path.__dict__, not inherited from PurePath.
# stat, exists, is_dir, is_file, open, read_text, write_text, mkdir, rmdir,
# unlink, rename, iterdir, glob, touch, cwd, home, absolute.
# ---------------------------------------------------------------------------

table pathlib_extra155.Path_dict_contains_io_methods:
  description: "pathlib.Path.__dict__.__contains__: open/read_text/write_text/mkdir/exists/stat/is_dir/is_file all True (filesystem I/O methods defined directly in Path)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath155

  columns: [id, function, args, expected, description]
  rows:
    - [has_open,       Path.__dict__.__contains__, ["open"],       true, "pathlib.Path.__dict__.__contains__('open') == True (open is defined directly in Path.__dict__; returns a file object for reading/writing the path; the pathlib equivalent of the built-in open() function)"]
    - [has_read_text,  Path.__dict__.__contains__, ["read_text"],  true, "pathlib.Path.__dict__.__contains__('read_text') == True (read_text reads and returns the file contents as a string using the given encoding)"]
    - [has_write_text, Path.__dict__.__contains__, ["write_text"], true, "pathlib.Path.__dict__.__contains__('write_text') == True (write_text writes data (str) to the path; creates or truncates the file)"]
    - [has_mkdir,      Path.__dict__.__contains__, ["mkdir"],      true, "pathlib.Path.__dict__.__contains__('mkdir') == True (mkdir creates the directory at this path; accepts parents=True and exist_ok=True keyword arguments)"]
    - [has_exists,     Path.__dict__.__contains__, ["exists"],     true, "pathlib.Path.__dict__.__contains__('exists') == True (exists returns True if the path points to an existing file or directory)"]
    - [has_stat,       Path.__dict__.__contains__, ["stat"],       true, "pathlib.Path.__dict__.__contains__('stat') == True (stat returns a os.stat_result object with file metadata including size, mtime, permissions)"]
    - [has_is_dir,     Path.__dict__.__contains__, ["is_dir"],     true, "pathlib.Path.__dict__.__contains__('is_dir') == True (is_dir returns True if the path points to a directory, following symlinks)"]
    - [has_is_file,    Path.__dict__.__contains__, ["is_file"],    true, "pathlib.Path.__dict__.__contains__('is_file') == True (is_file returns True if the path points to a regular file, following symlinks)"]

table pathlib_extra155.Path_dict_contains_nav_methods:
  description: "pathlib.Path.__dict__.__contains__: glob/unlink/rename/iterdir/cwd/home/absolute/touch/rmdir all True (navigation and manipulation methods defined directly in Path)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath155

  columns: [id, function, args, expected, description]
  rows:
    - [has_glob,      Path.__dict__.__contains__, ["glob"],     true, "pathlib.Path.__dict__.__contains__('glob') == True (glob returns an iterator of paths matching the given glob pattern relative to this path)"]
    - [has_unlink,    Path.__dict__.__contains__, ["unlink"],   true, "pathlib.Path.__dict__.__contains__('unlink') == True (unlink removes the file or symlink at this path)"]
    - [has_rename,    Path.__dict__.__contains__, ["rename"],   true, "pathlib.Path.__dict__.__contains__('rename') == True (rename renames the path to target, returning the new Path)"]
    - [has_iterdir,   Path.__dict__.__contains__, ["iterdir"],  true, "pathlib.Path.__dict__.__contains__('iterdir') == True (iterdir yields Path objects for all files and directories in this directory)"]
    - [has_cwd,       Path.__dict__.__contains__, ["cwd"],      true, "pathlib.Path.__dict__.__contains__('cwd') == True (cwd is a classmethod returning the current working directory as a Path object)"]
    - [has_home,      Path.__dict__.__contains__, ["home"],     true, "pathlib.Path.__dict__.__contains__('home') == True (home is a classmethod returning the home directory of the current user as a Path)"]
    - [has_absolute,  Path.__dict__.__contains__, ["absolute"], true, "pathlib.Path.__dict__.__contains__('absolute') == True (absolute makes the path absolute without resolving symlinks, unlike resolve())"]
    - [has_touch,     Path.__dict__.__contains__, ["touch"],    true, "pathlib.Path.__dict__.__contains__('touch') == True (touch creates the file if it does not exist, updating mtime if it does; analogous to the Unix touch command)"]
    - [has_rmdir,     Path.__dict__.__contains__, ["rmdir"],    true, "pathlib.Path.__dict__.__contains__('rmdir') == True (rmdir removes the directory at this path; it must be empty)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ — path manipulation attributes
# All of these are defined directly in PurePath.__dict__.
# parts, parent, parents, name, suffix, suffixes, stem, drive, root, anchor,
# joinpath, with_name, with_suffix, is_absolute, as_posix, as_uri, match,
# relative_to.
# ---------------------------------------------------------------------------

table pathlib_extra155.PurePath_dict_contains_properties:
  description: "pathlib.PurePath.__dict__.__contains__: parts/parent/parents/name/suffix/suffixes/stem/drive/root/anchor all True (path component properties in PurePath)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath155

  columns: [id, function, args, expected, description]
  rows:
    - [has_parts,    PurePath.__dict__.__contains__, ["parts"],    true, "pathlib.PurePath.__dict__.__contains__('parts') == True (parts is a property returning a tuple of the path's components: drive, root, and all path segments)"]
    - [has_parent,   PurePath.__dict__.__contains__, ["parent"],   true, "pathlib.PurePath.__dict__.__contains__('parent') == True (parent is a property returning the logical parent directory of the path)"]
    - [has_parents,  PurePath.__dict__.__contains__, ["parents"],  true, "pathlib.PurePath.__dict__.__contains__('parents') == True (parents is a property returning an immutable sequence of the path's logical ancestors)"]
    - [has_name,     PurePath.__dict__.__contains__, ["name"],     true, "pathlib.PurePath.__dict__.__contains__('name') == True (name is a property returning the final path component, without the directory part)"]
    - [has_suffix,   PurePath.__dict__.__contains__, ["suffix"],   true, "pathlib.PurePath.__dict__.__contains__('suffix') == True (suffix is a property returning the file extension of the final path component)"]
    - [has_suffixes, PurePath.__dict__.__contains__, ["suffixes"], true, "pathlib.PurePath.__dict__.__contains__('suffixes') == True (suffixes is a property returning a list of the path's file extensions, e.g. ['.tar', '.gz'] for 'archive.tar.gz')"]
    - [has_stem,     PurePath.__dict__.__contains__, ["stem"],     true, "pathlib.PurePath.__dict__.__contains__('stem') == True (stem is a property returning the final path component without its suffix)"]
    - [has_drive,    PurePath.__dict__.__contains__, ["drive"],    true, "pathlib.PurePath.__dict__.__contains__('drive') == True (drive is a property returning the drive letter or name, if any, e.g. 'C:' on Windows)"]
    - [has_root,     PurePath.__dict__.__contains__, ["root"],     true, "pathlib.PurePath.__dict__.__contains__('root') == True (root is a property returning the root of the path, e.g. '/' on POSIX or '\\\\' for UNC paths on Windows)"]
    - [has_anchor,   PurePath.__dict__.__contains__, ["anchor"],   true, "pathlib.PurePath.__dict__.__contains__('anchor') == True (anchor is a property returning the concatenation of drive and root)"]

table pathlib_extra155.PurePath_dict_contains_methods:
  description: "pathlib.PurePath.__dict__.__contains__: joinpath/with_name/with_suffix/is_absolute/as_posix/as_uri/match/relative_to all True (path manipulation methods in PurePath)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath155

  columns: [id, function, args, expected, description]
  rows:
    - [has_joinpath,    PurePath.__dict__.__contains__, ["joinpath"],    true, "pathlib.PurePath.__dict__.__contains__('joinpath') == True (joinpath combines the path with each of its arguments, equivalent to the / operator)"]
    - [has_with_name,   PurePath.__dict__.__contains__, ["with_name"],   true, "pathlib.PurePath.__dict__.__contains__('with_name') == True (with_name returns a new path with the final component changed to name)"]
    - [has_with_suffix, PurePath.__dict__.__contains__, ["with_suffix"], true, "pathlib.PurePath.__dict__.__contains__('with_suffix') == True (with_suffix returns a new path with the suffix changed)"]
    - [has_is_absolute, PurePath.__dict__.__contains__, ["is_absolute"], true, "pathlib.PurePath.__dict__.__contains__('is_absolute') == True (is_absolute returns True if the path is absolute, i.e. has root and optionally drive)"]
    - [has_as_posix,    PurePath.__dict__.__contains__, ["as_posix"],    true, "pathlib.PurePath.__dict__.__contains__('as_posix') == True (as_posix returns a string representation of the path with forward slashes)"]
    - [has_as_uri,      PurePath.__dict__.__contains__, ["as_uri"],      true, "pathlib.PurePath.__dict__.__contains__('as_uri') == True (as_uri represents the path as a file URI, e.g. 'file:///etc/passwd'; requires an absolute path)"]
    - [has_match,       PurePath.__dict__.__contains__, ["match"],       true, "pathlib.PurePath.__dict__.__contains__('match') == True (match tests whether the path matches the given glob-style pattern; case-insensitive on Windows)"]
    - [has_relative_to, PurePath.__dict__.__contains__, ["relative_to"], true, "pathlib.PurePath.__dict__.__contains__('relative_to') == True (relative_to returns a version of this path relative to the other path; raises ValueError if impossible)"]

# ---------------------------------------------------------------------------
# pathlib.Path and PurePath class identity
# pathlib.Path.__name__ == 'Path' (len=4); pathlib.PurePath.__name__ == 'PurePath' (len=8).
# pathlib.Path.__module__ == 'pathlib' (len=7); pathlib.PurePath.__module__ == 'pathlib' (len=7).
# ---------------------------------------------------------------------------

table pathlib_extra155.Path_PurePath_class_identity:
  description: "pathlib.Path and PurePath class identity: __name__ and __module__ values"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath155

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_eq,     Path.__name__.__eq__,         ["Path"],     true, "pathlib.Path.__name__ == 'Path' (len=4; the main concrete filesystem path class)"]
    - [path_name_len,    Path.__name__.__len__,         [],           4,    "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters; the shortest class name in pathlib.__all__)"]
    - [purepath_name_eq, PurePath.__name__.__eq__,      ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath' (len=8; the abstract pure path base class)"]
    - [purepath_name_len,PurePath.__name__.__len__,     [],           8,    "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [path_module_eq,   Path.__module__.__eq__,        ["pathlib"],  true, "pathlib.Path.__module__ == 'pathlib' (len=7; Path is defined in the pathlib package)"]
    - [purepath_mod_eq,  PurePath.__module__.__eq__,    ["pathlib"],  true, "pathlib.PurePath.__module__ == 'pathlib' (len=7; PurePath is also defined in the pathlib package)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra155.Path.dict_has_open:
  description: "pathlib.Path.__dict__.__contains__('open') == True — open() is defined directly in Path.__dict__ (not inherited from PurePath); it opens the path and returns a file object; it accepts the same arguments as the built-in open() function; this is one of the core filesystem I/O methods that distinguishes Path from PurePath"
  category: identity
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["open"]
  expected: true

invariant pathlib_extra155.Path.dict_has_read_text:
  description: "pathlib.Path.__dict__.__contains__('read_text') == True — read_text() is defined directly in Path.__dict__; it opens and reads the file at this path as text, using the given encoding (defaults to locale encoding); it is a convenience method equivalent to Path.open().read(); there is no read_text in PurePath.__dict__ (PurePath has no filesystem access)"
  category: identity
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["read_text"]
  expected: true

invariant pathlib_extra155.Path.dict_has_mkdir:
  description: "pathlib.Path.__dict__.__contains__('mkdir') == True — mkdir() is defined directly in Path.__dict__; it creates the directory at this path; it accepts mode (default 0o777), parents (create intermediate directories), and exist_ok (suppress FileExistsError) keyword arguments; not available in PurePath"
  category: identity
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["mkdir"]
  expected: true

invariant pathlib_extra155.PurePath.dict_has_parts:
  description: "pathlib.PurePath.__dict__.__contains__('parts') == True — parts is defined directly in PurePath.__dict__; it is a property returning a tuple of the path's string components: ('/', 'usr', 'local', 'bin') for '/usr/local/bin'; the first element is the root or drive+root for absolute paths; the parts property is available on all PurePath and Path objects"
  category: identity
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["parts"]
  expected: true

invariant pathlib_extra155.PurePath.dict_has_joinpath:
  description: "pathlib.PurePath.__dict__.__contains__('joinpath') == True — joinpath is defined directly in PurePath.__dict__; it combines the path with each of its arguments sequentially; PurePath('a').joinpath('b', 'c') == PurePath('a/b/c'); the / operator on paths is syntactic sugar for joinpath with a single argument"
  category: identity
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["joinpath"]
  expected: true

invariant pathlib_extra155.Path.name_len_4:
  description: "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters; the shortest class name in pathlib.__all__ — shorter than PurePath (8), PosixPath (9), WindowsPath (11), PurePosixPath (13), PureWindowsPath (15), and UnsupportedOperation (20))"
  category: identity
  kind: python_call_eq
  function: Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra155.PurePath.dict_has_as_uri:
  description: "pathlib.PurePath.__dict__.__contains__('as_uri') == True — as_uri is defined directly in PurePath.__dict__; it represents the path as a file URI string (e.g. 'file:///etc/hosts'); it raises ValueError if the path is not absolute; as_uri is the only method in PurePath that produces a URI, making it important for interoperability with URI-based APIs"
  category: identity
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["as_uri"]
  expected: true

