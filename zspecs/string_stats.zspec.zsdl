spec: string_stats
version: ">=0.0.5"
backend: node(string-stats)

docs: https://www.npmjs.com/package/string-stats

provenance:
  derived_from:
    - "string-stats README — https://www.npmjs.com/package/string-stats"
    - "Test vectors verified with string-stats via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "string-stats source"
  notes:
    - "string-stats is an npm package. Install: npm install string-stats"
    - "Exports wordCount, characterCount, and containsAlphanumericCharacter named functions."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number or boolean depending on the function."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_stats.word_count:
  kind: node_module_call_eq
  function: wordCount
  category: strings
  id_prefix: sswc

  columns: [id, args, expected]
  rows:
    - [two_words,   ["hello world"],   2]
    - [three_words, ["one two three"], 3]

table string_stats.character_count:
  kind: node_module_call_eq
  function: characterCount
  category: strings
  id_prefix: sscc

  columns: [id, args, expected]
  rows:
    - [hello,       ["hello"],       5]
    - [hello_world, ["hello world"], 11]

table string_stats.contains_alphanumeric:
  kind: node_module_call_eq
  function: containsAlphanumericCharacter
  category: strings
  id_prefix: ssalpha

  columns: [id, args, expected]
  rows:
    - [letters,  ["hello"], true]
    - [symbols,  ["!@#"],   false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:15:36Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
