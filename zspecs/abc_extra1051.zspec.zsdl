spec: abc_extra1051
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta and abstractmethod documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta and abc.ABC __init_subclass__ and __class_getitem__ qualnames, abc.abstractmethod __init__ qualname and descriptor identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1051.abcmeta_subclass_qualnames:
  description: "abc.ABCMeta __init_subclass__ and __class_getitem__ qualname identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1051ms
  columns: [id, function, args, expected]
  rows:
    - [ab1051ms001, abc.ABCMeta.__init_subclass__.__qualname__.__eq__,   ["type.__init_subclass__"],   true]
    - [ab1051ms002, abc.ABCMeta.__class_getitem__.__qualname__.__eq__,   ["type.__class_getitem__"],   true]
    - [ab1051ms003, abc.ABCMeta.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1051ms004, abc.ABCMeta.__class_getitem__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1051ms005, abc.ABCMeta.__module__.__eq__,                        ["abc"],                     true]

table abc_extra1051.abc_class_qualnames:
  description: "abc.ABC __init_subclass__ func qualname identity via __func__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1051ac
  columns: [id, function, args, expected]
  rows:
    - [ab1051ac001, abc.ABC.__init_subclass__.__func__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [ab1051ac002, abc.ABC.__module__.__eq__,                              ["abc"],                      true]
    - [ab1051ac003, abc.ABC.__qualname__.__eq__,                            ["ABC"],                      true]
    - [ab1051ac004, abc.ABC.__class__.__name__.__eq__,                      ["ABCMeta"],                  true]
    - [ab1051ac005, abc.ABC.__doc__.__class__.__name__.__eq__,              ["str"],                      true]

table abc_extra1051.abstractmethod_qualnames:
  description: "abc.abstractmethod __init__ and __init_subclass__ qualname identity"
  kind: python_call_eq
  category: abstractmethod_qualnames
  id_prefix: ab1051am
  columns: [id, function, args, expected]
  rows:
    - [ab1051am001, abc.abstractmethod.__init__.__qualname__.__eq__,          ["abstractmethod.__init__"],    true]
    - [ab1051am002, abc.abstractmethod.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"],   true]
    - [ab1051am003, abc.abstractmethod.__class_getitem__.__qualname__.__eq__, ["object.__class_getitem__"],   true]
    - [ab1051am004, abc.abstractmethod.__module__.__eq__,                     ["abc"],                        true]
    - [ab1051am005, abc.abstractmethod.__qualname__.__eq__,                   ["abstractmethod"],             true]
    - [ab1051am006, abc.abstractmethod.__class__.__name__.__eq__,             ["type"],                       true]
