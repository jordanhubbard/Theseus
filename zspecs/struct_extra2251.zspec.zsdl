spec: struct_extra2251
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "any prior struct zspec files"
  notes:
    - "Wave 597 (_extra2251): callable protocol and function-attribute dict-presence checks for struct types."
    - "struct.Struct is a C extension type; __call__ is absent from its __dict__ (type metaclass provides __call__ for construction)."
    - "struct.Struct defines __init__ and __new__ in its __dict__ (both True)."
    - "struct.Struct defines pack, unpack, pack_into, unpack_from, iter_unpack, format, size in its __dict__."
    - "struct.Struct also defines __repr__, __sizeof__, __getattribute__, __setattr__, __delattr__ in its __dict__."
    - "Function-object attributes (__code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__) are absent from struct.Struct and struct.error __dict__s."
    - "struct.pack, struct.unpack, struct.pack_into, struct.unpack_from, struct.iter_unpack, struct.calcsize are all builtin_function_or_method (C extension builtins), not Python functions; they have no __code__ or __globals__."
    - "struct.error is a simple exception subclass with only __doc__, __module__, __weakref__ in its __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2251.struct_class_call_protocol:
  description: "struct.Struct callable protocol and function-attribute dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2251
  columns: [id, function, args, expected]
  rows:
    - ["st2251001", "struct.Struct.__dict__.__contains__", ["__call__"],        false]
    - ["st2251002", "struct.Struct.__dict__.__contains__", ["__code__"],        false]
    - ["st2251003", "struct.Struct.__dict__.__contains__", ["__globals__"],     false]
    - ["st2251004", "struct.Struct.__dict__.__contains__", ["__defaults__"],    false]
    - ["st2251005", "struct.Struct.__dict__.__contains__", ["__kwdefaults__"],  false]
    - ["st2251006", "struct.Struct.__dict__.__contains__", ["__annotations__"], false]
    - ["st2251007", "struct.Struct.__dict__.__contains__", ["__builtins__"],    false]

table struct_extra2251.struct_class_positive_anchors:
  description: "struct.Struct dict members that ARE present: construction, pack/unpack methods, format, size"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2251
  columns: [id, function, args, expected]
  rows:
    - ["st2251008", "struct.Struct.__dict__.__contains__", ["__init__"],     true]
    - ["st2251009", "struct.Struct.__dict__.__contains__", ["__new__"],      true]
    - ["st2251010", "struct.Struct.__dict__.__contains__", ["__doc__"],      true]
    - ["st2251011", "struct.Struct.__dict__.__contains__", ["pack"],         true]
    - ["st2251012", "struct.Struct.__dict__.__contains__", ["unpack"],       true]
    - ["st2251013", "struct.Struct.__dict__.__contains__", ["pack_into"],    true]
    - ["st2251014", "struct.Struct.__dict__.__contains__", ["unpack_from"],  true]
    - ["st2251015", "struct.Struct.__dict__.__contains__", ["iter_unpack"],  true]
    - ["st2251016", "struct.Struct.__dict__.__contains__", ["format"],       true]
    - ["st2251017", "struct.Struct.__dict__.__contains__", ["size"],         true]
    - ["st2251018", "struct.Struct.__dict__.__contains__", ["__repr__"],     true]
    - ["st2251019", "struct.Struct.__dict__.__contains__", ["__sizeof__"],   true]

table struct_extra2251.struct_error_call_protocol:
  description: "struct.error exception subclass callable protocol and function-attribute dict-presence (all false)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2251
  columns: [id, function, args, expected]
  rows:
    - ["st2251020", "struct.error.__dict__.__contains__", ["__call__"],        false]
    - ["st2251021", "struct.error.__dict__.__contains__", ["__code__"],        false]
    - ["st2251022", "struct.error.__dict__.__contains__", ["__globals__"],     false]
    - ["st2251023", "struct.error.__dict__.__contains__", ["__defaults__"],    false]
    - ["st2251024", "struct.error.__dict__.__contains__", ["__kwdefaults__"],  false]
    - ["st2251025", "struct.error.__dict__.__contains__", ["__annotations__"], false]
    - ["st2251026", "struct.error.__dict__.__contains__", ["__builtins__"],    false]
    - ["st2251027", "struct.error.__dict__.__contains__", ["__doc__"],         true]
    - ["st2251028", "struct.error.__dict__.__contains__", ["__module__"],      true]
    - ["st2251029", "struct.error.__dict__.__contains__", ["__weakref__"],     true]

table struct_extra2251.module_builtins_no_code:
  description: "struct module-level builtins (pack, unpack, calcsize, etc.) have no __code__ — they are C extension builtins, not Python functions"
  kind: python_call_eq
  category: builtin_no_code
  id_prefix: st2251
  columns: [id, function, args, expected]
  rows:
    - ["st2251030", "struct.pack.__class__.__name__.__eq__",        ["builtin_function_or_method"], true]
    - ["st2251031", "struct.unpack.__class__.__name__.__eq__",      ["builtin_function_or_method"], true]
    - ["st2251032", "struct.pack_into.__class__.__name__.__eq__",   ["builtin_function_or_method"], true]
    - ["st2251033", "struct.unpack_from.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2251034", "struct.iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2251035", "struct.calcsize.__class__.__name__.__eq__",    ["builtin_function_or_method"], true]
