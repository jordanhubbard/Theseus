spec: uuid_extra221
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.getnode.__name__ == 'getnode' — function name is 'getnode' (7 characters)."
    - "uuid.getnode.__module__ == 'uuid' — getnode is defined in the uuid module."
    - "uuid.getnode.__qualname__ == 'getnode' — top-level function; qualname equals name."
    - "uuid.getnode().__class__.__name__ == 'int' — getnode returns a plain Python int."
    - "uuid.getnode() returns the hardware MAC address as a 48-bit positive integer."
    - "uuid.uuid4.__name__ == 'uuid4' — random UUID generator function name (5 characters)."
    - "uuid.uuid1.__name__ == 'uuid1' — time-based UUID generator function name (5 characters)."
    - "uuid.uuid4.__module__ == 'uuid' — uuid4 is defined in uuid module."
    - "uuid.uuid1.__module__ == 'uuid' — uuid1 is defined in uuid module."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.getnode function identity contracts
#
# uuid.getnode.__name__    == 'getnode'
# uuid.getnode.__module__  == 'uuid'
# uuid.getnode.__qualname__ == 'getnode'
# uuid.getnode.__name__.__len__() == 7
#
# uuid.getnode() returns the hardware MAC address as a 48-bit positive integer.
# It is a top-level function defined in uuid.py. The function name 'getnode'
# is 7 characters. It is used internally by uuid.uuid1() to obtain the node
# component of time-based UUIDs.
# ---------------------------------------------------------------------------

table uuid_extra221.getnode_function_identity:
  description: "getnode.__name__=='getnode'; getnode.__module__=='uuid'; getnode.__qualname__=='getnode'; getnode.__name__.__len__()==7; function identity contracts; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: uuid221

  columns: [id, function, args, expected, description]
  rows:
    - [getnode_name_eq_getnode,
       "getnode.__name__.__eq__",
       ["getnode"],
       true,
       "uuid.getnode.__name__.__eq__('getnode') == True — getnode function name is 'getnode' (7 characters); returns the hardware MAC address as a 48-bit positive integer; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [getnode_module_eq_uuid,
       "getnode.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.getnode.__module__.__eq__('uuid') == True — getnode is defined in the uuid module (Lib/uuid.py); __module__ is 'uuid'; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [getnode_qualname_eq_getnode,
       "getnode.__qualname__.__eq__",
       ["getnode"],
       true,
       "uuid.getnode.__qualname__.__eq__('getnode') == True — getnode is a top-level function so __qualname__ equals __name__; no outer class scope; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [getnode_name_len_7,
       "getnode.__name__.__len__",
       [],
       7,
       "uuid.getnode.__name__.__len__() == 7 — the string 'getnode' has 7 characters; portable length anchor for function name; new anchor in extra221 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.getnode() return type contracts
#
# uuid.getnode().__class__.__name__ == 'int'
# uuid.getnode().__gt__(0) == True
#
# getnode() returns the hardware MAC address as a plain Python int. The
# address is a 48-bit non-negative integer; on any real host it is positive.
# The return type is always int regardless of how the MAC address is obtained.
# ---------------------------------------------------------------------------

table uuid_extra221.getnode_return_type:
  description: "getnode().__class__.__name__=='int'; getnode().__gt__(0)==True; return type and value range; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: uuid221a

  columns: [id, function, args, expected, description]
  rows:
    - [getnode_class_is_int,
       "getnode().__class__.__name__.__eq__",
       ["int"],
       true,
       "uuid.getnode().__class__.__name__.__eq__('int') == True — getnode() returns a plain Python int; the hardware MAC address encoded as a 48-bit positive integer; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [getnode_result_gt_0,
       "getnode().__gt__",
       [0],
       true,
       "uuid.getnode().__gt__(0) == True — getnode() returns a positive integer representing the 48-bit MAC address; on any real host the MAC address is non-zero and positive; new anchor in extra221 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid4 and uuid.uuid1 function identity contracts
#
# uuid.uuid4.__name__    == 'uuid4'
# uuid.uuid1.__name__    == 'uuid1'
# uuid.uuid4.__module__  == 'uuid'
# uuid.uuid1.__module__  == 'uuid'
# uuid.uuid4.__qualname__ == 'uuid4'
# uuid.uuid1.__qualname__ == 'uuid1'
#
# uuid4() generates a random UUID (RFC 4122 §4.4).
# uuid1() generates a time-based UUID using the MAC address (RFC 4122 §4.1.4).
# Both are top-level functions in uuid.py with name length 5.
# ---------------------------------------------------------------------------

table uuid_extra221.uuid4_uuid1_function_identity:
  description: "uuid4.__name__=='uuid4'; uuid1.__name__=='uuid1'; uuid4.__module__=='uuid'; uuid1.__module__=='uuid'; uuid4.__qualname__=='uuid4'; uuid1.__qualname__=='uuid1'; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: uuid221b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name_eq_uuid4,
       "uuid4.__name__.__eq__",
       ["uuid4"],
       true,
       "uuid.uuid4.__name__.__eq__('uuid4') == True — uuid4 generates random UUIDs per RFC 4122 Section 4.4; __name__ is 'uuid4' (5 characters); new anchor in extra221 namespace; verified Python 3.14.3"]
    - [uuid1_name_eq_uuid1,
       "uuid1.__name__.__eq__",
       ["uuid1"],
       true,
       "uuid.uuid1.__name__.__eq__('uuid1') == True — uuid1 generates time-based UUIDs using the MAC address per RFC 4122 Section 4.1.4; __name__ is 'uuid1' (5 characters); new anchor in extra221 namespace; verified Python 3.14.3"]
    - [uuid4_module_eq_uuid,
       "uuid4.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.uuid4.__module__.__eq__('uuid') == True — uuid4 is a Python function defined in uuid.py; __module__ is 'uuid'; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [uuid1_module_eq_uuid,
       "uuid1.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.uuid1.__module__.__eq__('uuid') == True — uuid1 is a Python function defined in uuid.py; __module__ is 'uuid'; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [uuid4_qualname_eq_uuid4,
       "uuid4.__qualname__.__eq__",
       ["uuid4"],
       true,
       "uuid.uuid4.__qualname__.__eq__('uuid4') == True — uuid4 is a top-level function so __qualname__ equals __name__; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [uuid1_qualname_eq_uuid1,
       "uuid1.__qualname__.__eq__",
       ["uuid1"],
       true,
       "uuid.uuid1.__qualname__.__eq__('uuid1') == True — uuid1 is a top-level function so __qualname__ equals __name__; new anchor in extra221 namespace; verified Python 3.14.3"]
    - [uuid4_name_len_5,
       "uuid4.__name__.__len__",
       [],
       5,
       "uuid.uuid4.__name__.__len__() == 5 — the string 'uuid4' has 5 characters; same length as uuid1/uuid3/uuid5; portable length anchor; new anchor in extra221 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra221.getnode_name_eq_getnode:
  description: "uuid.getnode.__name__.__eq__('getnode') == True — getnode is a top-level function in uuid.py that returns the hardware MAC address as a 48-bit positive integer; it is used internally by uuid.uuid1() to provide the node component of time-based UUIDs; the __name__ attribute is 'getnode' (7 characters); prior specs anchor uuid1/uuid3/uuid4/uuid5 names but extra221 is the first namespace to anchor getnode.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "getnode.__name__.__eq__"
  args: ["getnode"]
  expected: true

invariant uuid_extra221.getnode_class_is_int:
  description: "uuid.getnode().__class__.__name__.__eq__('int') == True — getnode() returns the hardware MAC address as a plain Python int; the MAC address is a 48-bit non-negative integer (at most 2^48 - 1 = 281474976710655); Python represents it as a plain int; the class name is 'int'; prior specs anchor UUID return types but extra221 is the first namespace to anchor getnode return type as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "getnode().__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant uuid_extra221.uuid4_name_eq_uuid4:
  description: "uuid.uuid4.__name__.__eq__('uuid4') == True — uuid4 is a Python function in uuid.py that generates a random UUID per RFC 4122 Section 4.4; it uses os.urandom() or equivalent for randomness; the __name__ attribute is 'uuid4' (5 characters); same length as uuid1/uuid3/uuid5 names; prior extra220 anchors uuid3/uuid5 names; extra221 is the first namespace to anchor uuid4.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "uuid4.__name__.__eq__"
  args: ["uuid4"]
  expected: true
