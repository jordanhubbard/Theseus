spec: heapq_extra19
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
    - "heapq_extra18.zspec.zsdl — covers __module__.__len__() for all 8 heapq callables; __name__.__len__() and __package__.__len__() at module level."
    - "heapq_extra17.zspec.zsdl — covers unified __qualname__.__eq__ table for all 8 callables."
    - "heapq_extra16.zspec.zsdl — covers __package__ and __qualname__.__len__() for all functions."
    - "heapq_extra15.zspec.zsdl — covers __module__.__eq__ for merge/nlargest/nsmallest."
  notes:
    - "This spec extends heapq.zspec.zsdl through heapq_extra18.zspec.zsdl."
    - "Prior specs cover: __qualname__.__eq__ and __qualname__.__len__() for all 8 callables; __module__.__eq__ and __module__.__len__() for all 8; __package__; __name__."
    - "NOT yet covered: heapq.__spec__.name attribute; heapq.__spec__.__class__.__name__; heapq.__doc__.__class__.__name__; standalone __module__.__eq__ invariants for heappush (C builtin) and nlargest (pure-Python) in extra19 namespace."
    - "Focus: heapq.__spec__.name; heapq.__spec__.__class__.__name__; heapq.__doc__.__class__.__name__; standalone __module__.__eq__ anchors in extra19 namespace."
    - "heapq.__spec__.name == 'heapq' — ModuleSpec.name attribute. Verified Python 3.12 macOS."
    - "heapq.__spec__.__class__.__name__ == 'ModuleSpec' — heapq's spec is a ModuleSpec instance. Verified."
    - "heapq.__doc__.__class__.__name__ == 'str' — the module docstring is a str. Verified."
    - "heapq.heappush.__module__ == '_heapq' — C builtin; comes from the _heapq C extension. Verified."
    - "heapq.nlargest.__module__ == 'heapq' — pure-Python; defined in Lib/heapq.py. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# heapq.__spec__.name — ModuleSpec.name attribute
#
# No prior heapq spec accesses heapq.__spec__.name (the .name attribute of
# the ModuleSpec object). This is distinct from heapq.__name__ (covered in
# extra4/extra18). ModuleSpec.name equals the fully-qualified module name.
# heapq.__spec__.name == 'heapq'. Verified Python 3.12 macOS.
# ---------------------------------------------------------------------------

invariant heapq_extra19.spec.name:
  description: "heapq.__spec__.name == 'heapq' — ModuleSpec.name attribute equals module name"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.name.__eq__"
  args: ["heapq"]
  expected: true

invariant heapq_extra19.spec.name_len:
  description: "heapq.__spec__.name.__len__() == 5 — len('heapq') == 5"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.name.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# heapq.__spec__.__class__.__name__ — module spec type identity
#
# No prior heapq spec checks heapq.__spec__.__class__.__name__. The module's
# __spec__ is a ModuleSpec instance from importlib.machinery. Its
# __class__.__name__ is 'ModuleSpec'. Under python_module(heapq), the function
# chain accesses the attribute on the heapq module object.
# ---------------------------------------------------------------------------

invariant heapq_extra19.spec.class_name:
  description: "heapq.__spec__.__class__.__name__ == 'ModuleSpec' — spec is a ModuleSpec instance"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant heapq_extra19.spec.class_name_len:
  description: "heapq.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec') == 10"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# heapq.__doc__.__class__.__name__ — docstring type identity
#
# No prior heapq spec checks the type of heapq.__doc__. The module docstring
# is a Python str object. heapq.__doc__.__class__.__name__ == 'str'. This
# invariant confirms the docstring exists and is a string (not None or other).
# Under python_module(heapq), __doc__.__class__.__name__.__eq__ accesses the
# docstring's class name on the heapq module object.
# ---------------------------------------------------------------------------

invariant heapq_extra19.doc.class_name:
  description: "heapq.__doc__.__class__.__name__ == 'str' — module docstring is a str object"
  category: module_identity
  kind: python_call_eq
  function: "__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone __module__.__eq__ anchors in extra19 namespace
#
# heapq_extra15 covers __module__.__eq__ for nlargest/nsmallest/merge.
# No prior heapq spec covers standalone __module__.__eq__ for heappush
# (the representative C builtin) or nlargest (the representative pure-Python
# function) in the extra19 namespace. These standalone invariants provide
# independent anchors confirming the C-vs-Python module distinction.
# heapq.heappush.__module__ == '_heapq' (C extension).
# heapq.nlargest.__module__ == 'heapq' (pure-Python, Lib/heapq.py).
# ---------------------------------------------------------------------------

invariant heapq_extra19.heappush.module:
  description: "heapq.heappush.__module__ == '_heapq' — C builtin from the _heapq extension (extra19 anchor)"
  category: function_module
  kind: python_call_eq
  function: heappush.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra19.nlargest.module:
  description: "heapq.nlargest.__module__ == 'heapq' — pure-Python function defined in Lib/heapq.py (extra19 anchor)"
  category: function_module
  kind: python_call_eq
  function: nlargest.__module__.__eq__
  args: ["heapq"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — spec.name, spec class name, doc class name (extra19)
#
# Groups the module-level metadata invariants from this spec in a single table
# for the extra19 namespace. id_prefix hqmeta19 does not conflict with any
# prior heapq spec.
# ---------------------------------------------------------------------------

table heapq_extra19.module_metadata:
  description: "Module-level metadata: __spec__.name, __spec__.__class__.__name__, __doc__.__class__.__name__"
  kind: python_call_eq
  category: module_identity
  id_prefix: hqmeta19

  columns: [id, function, args, expected]
  rows:
    - [spec_name,       __spec__.name.__eq__,                  ["heapq"],      true]
    - [spec_class_name, __spec__.__class__.__name__.__eq__,    ["ModuleSpec"], true]
    - [doc_class_name,  __doc__.__class__.__name__.__eq__,     ["str"],        true]
