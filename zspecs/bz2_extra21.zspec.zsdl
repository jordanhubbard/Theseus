spec: bz2_extra21
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2_extra20.zspec.zsdl."
    - "Prior specs covered: BZ2File/__name__/__module__/__qualname__, BZ2Compressor/__name__/__module__, BZ2Decompressor/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, BZ2File/__bases__[0].__name__, BZ2Compressor/__bases__[0].__name__, BZ2Decompressor/__bases__[0].__name__, various __qualname__ checks, BZ2File/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, module/__len__() for all identifiers, __name__.__len__() for all identifiers."
    - "This spec covers: bz2.BZ2File.__mro__.__len__(), bz2.BZ2Compressor.__mro__.__len__(), bz2.BZ2Decompressor.__mro__.__len__(), bz2.BZ2File.__bases__[0].__name__.__len__(), bz2.BZ2Compressor.__bases__[0].__name__.__len__(), bz2.BZ2Decompressor.__bases__[0].__name__.__len__(), bz2.BZ2File.__init__.__qualname__.__len__(), bz2.BZ2File.read.__qualname__.__len__(), bz2.BZ2File.write.__qualname__.__len__(), bz2.BZ2File.peek.__qualname__.__len__(), bz2.BZ2File.close.__qualname__.__len__()."
    - "bz2.BZ2File.__mro__.__len__() == 7: MRO is [BZ2File, BaseStream, BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]. Verified 2026-04-10."
    - "bz2.BZ2Compressor.__mro__.__len__() == 2: MRO is [BZ2Compressor, object] — C extension type with no intermediate bases. Verified 2026-04-10."
    - "bz2.BZ2Decompressor.__mro__.__len__() == 2: MRO is [BZ2Decompressor, object] — C extension type with no intermediate bases. Verified 2026-04-10."
    - "bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' (len 10): BZ2File directly inherits from the internal BaseStream mixin. Verified 2026-04-10."
    - "bz2.BZ2Compressor.__bases__[0].__name__ == 'object' (len 6): C extension type bases directly from object. Verified 2026-04-10."
    - "bz2.BZ2Decompressor.__bases__[0].__name__ == 'object' (len 6): C extension type bases directly from object. Verified 2026-04-10."
    - "bz2.BZ2File.__init__.__qualname__ == 'BZ2File.__init__' (len 16). Verified 2026-04-10."
    - "bz2.BZ2File.read.__qualname__ == 'BZ2File.read' (len 12). Verified 2026-04-10."
    - "bz2.BZ2File.write.__qualname__ == 'BZ2File.write' (len 13). Verified 2026-04-10."
    - "bz2.BZ2File.peek.__qualname__ == 'BZ2File.peek' (len 12). Verified 2026-04-10."
    - "bz2.BZ2File.close.__qualname__ == 'BZ2File.close' (len 13). Verified 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.__mro__.__len__() == 7 — novel, extra21 anchor
#
# bz2.BZ2File.__mro__ is [BZ2File, BaseStream, BufferedIOBase,
# _BufferedIOBase, IOBase, _IOBase, object] — seven entries. No prior bz2
# spec checks __mro__.__len__() for BZ2File. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.mro_len:
  description: "bz2.BZ2File.__mro__.__len__() == 7 — BZ2File MRO has seven entries (extra21)"
  category: class_hierarchy
  kind: python_call_eq
  function: BZ2File.__mro__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# BZ2Compressor.__mro__.__len__() == 2 — novel, extra21 anchor
#
# bz2.BZ2Compressor.__mro__ is [BZ2Compressor, object] — two entries.
# BZ2Compressor is a C extension type that bases directly from object.
# No prior bz2 spec checks __mro__.__len__() for BZ2Compressor.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2Compressor.mro_len:
  description: "bz2.BZ2Compressor.__mro__.__len__() == 2 — BZ2Compressor MRO has two entries (extra21)"
  category: class_hierarchy
  kind: python_call_eq
  function: BZ2Compressor.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# BZ2Decompressor.__mro__.__len__() == 2 — novel, extra21 anchor
#
# bz2.BZ2Decompressor.__mro__ is [BZ2Decompressor, object] — two entries.
# BZ2Decompressor is a C extension type that bases directly from object.
# No prior bz2 spec checks __mro__.__len__() for BZ2Decompressor.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2Decompressor.mro_len:
  description: "bz2.BZ2Decompressor.__mro__.__len__() == 2 — BZ2Decompressor MRO has two entries (extra21)"
  category: class_hierarchy
  kind: python_call_eq
  function: BZ2Decompressor.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# BZ2File.__bases__[0].__name__.__len__() == 10 — novel, extra21 anchor
#
# bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' which has 10
# characters. BZ2File inherits directly from the internal BaseStream mixin.
# No prior bz2 spec checks __bases__[0].__name__.__len__(). Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.bases0_name_len:
  description: "bz2.BZ2File.__bases__[0].__name__.__len__() == 10 — 'BaseStream' has ten characters (extra21)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BZ2File.__bases__[0].__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# BZ2Compressor.__bases__[0].__name__.__len__() == 6 — novel, extra21 anchor
#
# bz2.BZ2Compressor.__bases__[0].__name__ == 'object' which has 6
# characters. C extension type bases directly from object. No prior bz2 spec
# checks __bases__[0].__name__.__len__() for BZ2Compressor. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2Compressor.bases0_name_len:
  description: "bz2.BZ2Compressor.__bases__[0].__name__.__len__() == 6 — 'object' has six characters (extra21)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BZ2Compressor.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# BZ2Decompressor.__bases__[0].__name__.__len__() == 6 — novel, extra21 anchor
#
# bz2.BZ2Decompressor.__bases__[0].__name__ == 'object' which has 6
# characters. C extension type bases directly from object. No prior bz2 spec
# checks __bases__[0].__name__.__len__() for BZ2Decompressor.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2Decompressor.bases0_name_len:
  description: "bz2.BZ2Decompressor.__bases__[0].__name__.__len__() == 6 — 'object' has six characters (extra21)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BZ2Decompressor.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# BZ2File.__init__.__qualname__.__len__() == 16 — novel, extra21 anchor
#
# bz2.BZ2File.__init__.__qualname__ == 'BZ2File.__init__' which has 16
# characters. No prior bz2 spec checks __qualname__.__len__() for
# BZ2File.__init__. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.init_qualname_len:
  description: "bz2.BZ2File.__init__.__qualname__.__len__() == 16 — 'BZ2File.__init__' has sixteen characters (extra21)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2File.__init__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# BZ2File.read.__qualname__.__len__() == 12 — novel, extra21 anchor
#
# bz2.BZ2File.read.__qualname__ == 'BZ2File.read' which has 12 characters.
# No prior bz2 spec checks __qualname__.__len__() for BZ2File.read.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.read_qualname_len:
  description: "bz2.BZ2File.read.__qualname__.__len__() == 12 — 'BZ2File.read' has twelve characters (extra21)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2File.read.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# BZ2File.write.__qualname__.__len__() == 13 — novel, extra21 anchor
#
# bz2.BZ2File.write.__qualname__ == 'BZ2File.write' which has 13 characters.
# No prior bz2 spec checks __qualname__.__len__() for BZ2File.write.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.write_qualname_len:
  description: "bz2.BZ2File.write.__qualname__.__len__() == 13 — 'BZ2File.write' has thirteen characters (extra21)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2File.write.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# BZ2File.peek.__qualname__.__len__() == 12 — novel, extra21 anchor
#
# bz2.BZ2File.peek.__qualname__ == 'BZ2File.peek' which has 12 characters.
# No prior bz2 spec checks __qualname__.__len__() for BZ2File.peek.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.peek_qualname_len:
  description: "bz2.BZ2File.peek.__qualname__.__len__() == 12 — 'BZ2File.peek' has twelve characters (extra21)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2File.peek.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# BZ2File.close.__qualname__.__len__() == 13 — novel, extra21 anchor
#
# bz2.BZ2File.close.__qualname__ == 'BZ2File.close' which has 13 characters.
# No prior bz2 spec checks __qualname__.__len__() for BZ2File.close.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant bz2_extra21.BZ2File.close_qualname_len:
  description: "bz2.BZ2File.close.__qualname__.__len__() == 13 — 'BZ2File.close' has thirteen characters (extra21)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2File.close.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# __mro__.__len__() table — BZ2File, BZ2Compressor, BZ2Decompressor (extra21)
#
# BZ2File has a 7-entry MRO (inherits through BaseStream into the io
# hierarchy); BZ2Compressor and BZ2Decompressor each have 2 entries (C
# extension types directly from object). This table anchors all three MRO
# depths from the extra21 namespace.
# ---------------------------------------------------------------------------

table bz2_extra21.mro_depths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mrodepth21

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__mro__.__len__,         [], 7]
    - [BZ2Compressor,   BZ2Compressor.__mro__.__len__,   [], 2]
    - [BZ2Decompressor, BZ2Decompressor.__mro__.__len__, [], 2]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() table — BZ2File, BZ2Compressor,
#                                         BZ2Decompressor (extra21)
#
# BZ2File.__bases__[0].__name__ == 'BaseStream' (len 10);
# BZ2Compressor.__bases__[0].__name__ == 'object' (len 6);
# BZ2Decompressor.__bases__[0].__name__ == 'object' (len 6).
# This table anchors all three direct-base name lengths from extra21.
# ---------------------------------------------------------------------------

table bz2_extra21.bases0_name_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases0nlen21

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         "BZ2File.__bases__[0].__name__.__len__",         [], 10]
    - [BZ2Compressor,   "BZ2Compressor.__bases__[0].__name__.__len__",   [], 6]
    - [BZ2Decompressor, "BZ2Decompressor.__bases__[0].__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# BZ2File method __qualname__.__len__() table — __init__, read, write,
#                                               peek, close (extra21)
#
# No prior bz2 spec presents method __qualname__.__len__() checks in a table.
# __init__=16, read=12, write=13, peek=12, close=13. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table bz2_extra21.BZ2File_method_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: methqnlen21

  columns: [id, function, args, expected]
  rows:
    - [init,  BZ2File.__init__.__qualname__.__len__,  [], 16]
    - [read,  BZ2File.read.__qualname__.__len__,      [], 12]
    - [write, BZ2File.write.__qualname__.__len__,     [], 13]
    - [peek,  BZ2File.peek.__qualname__.__len__,      [], 12]
    - [close, BZ2File.close.__qualname__.__len__,     [], 13]
