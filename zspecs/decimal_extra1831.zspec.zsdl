spec: decimal_extra1831
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__delete__/__set_name__); __call__ callable protocol; decimal module attribute presence."
    - "decimal.Decimal is a C type and uses __new__ for construction rather than __init__."
    - "decimal.Context is a Python class and defines __init__ but not __new__."
    - "decimal.DecimalException is a Python exception base class; __init__ is inherited, not in own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra1831.descriptor_protocol:
  description: "decimal types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1831

  columns: [id, function, args, expected]
  rows:
    - ["dc1831001", "decimal.Decimal.__dict__.__contains__", ["__get__"], false]
    - ["dc1831002", "decimal.Decimal.__dict__.__contains__", ["__set__"], false]
    - ["dc1831003", "decimal.Context.__dict__.__contains__", ["__get__"], false]
    - ["dc1831004", "decimal.Context.__dict__.__contains__", ["__set__"], false]
    - ["dc1831005", "decimal.Decimal.__dict__.__contains__", ["__set_name__"], false]
    - ["dc1831006", "decimal.Context.__dict__.__contains__", ["__set_name__"], false]
    - ["dc1831007", "decimal.DecimalException.__dict__.__contains__", ["__get__"], false]
    - ["dc1831008", "decimal.DecimalException.__dict__.__contains__", ["__set_name__"], false]

table decimal_extra1831.callable_protocol:
  description: "decimal types __call__ and construction protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1831

  columns: [id, function, args, expected]
  rows:
    - ["dc1831101", "decimal.Decimal.__dict__.__contains__", ["__call__"], false]
    - ["dc1831102", "decimal.Context.__dict__.__contains__", ["__call__"], false]
    - ["dc1831103", "decimal.DecimalException.__dict__.__contains__", ["__call__"], false]
    - ["dc1831104", "decimal.Decimal.__dict__.__contains__", ["__init__"], false]
    - ["dc1831105", "decimal.Decimal.__dict__.__contains__", ["__new__"], true]
    - ["dc1831106", "decimal.Context.__dict__.__contains__", ["__init__"], true]
    - ["dc1831107", "decimal.Context.__dict__.__contains__", ["__new__"], false]
    - ["dc1831108", "decimal.DecimalException.__dict__.__contains__", ["__init__"], false]

table decimal_extra1831.decimal_module_attrs:
  description: "decimal module-level attribute dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1831

  columns: [id, function, args, expected]
  rows:
    - ["dc1831201", "decimal.__dict__.__contains__", ["Decimal"], true]
    - ["dc1831202", "decimal.__dict__.__contains__", ["Context"], true]
    - ["dc1831203", "decimal.__dict__.__contains__", ["DefaultContext"], true]
    - ["dc1831204", "decimal.__dict__.__contains__", ["BasicContext"], true]
    - ["dc1831205", "decimal.__dict__.__contains__", ["ExtendedContext"], true]
    - ["dc1831206", "decimal.__dict__.__contains__", ["DecimalException"], true]
    - ["dc1831207", "decimal.__dict__.__contains__", ["Overflow"], true]
    - ["dc1831208", "decimal.__dict__.__contains__", ["Underflow"], true]
    - ["dc1831209", "decimal.__dict__.__contains__", ["InvalidOperation"], true]
    - ["dc1831210", "decimal.__dict__.__contains__", ["getcontext"], true]
