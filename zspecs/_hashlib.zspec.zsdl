spec: _hashlib
version: ">=3.6"
backend: python_module(_hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "OpenSSL source: crypto/sha/sha256.c"
  notes:
    - "_hashlib is the C extension backing the Python hashlib module; it is loaded directly here."
    - "openssl_md5, openssl_sha1, openssl_sha256, openssl_sha512 are the low-level C-level constructor functions."
    - "Each constructor returns a HASH object with digest_size, block_size, name, digest(), and hexdigest() attributes."
    - "openssl_md5(b'').digest_size == 16 (128-bit output, FIPS 180-4 / RFC 1321)."
    - "openssl_sha1(b'').digest_size == 20 (160-bit output, FIPS 180-4)."
    - "openssl_sha256(b'').digest_size == 32 (256-bit output, FIPS 180-4)."
    - "openssl_sha512(b'').digest_size == 64 (512-bit output, FIPS 180-4)."
    - "All MD5 and SHA variants share block_size == 64 bytes for the basic (non-SHA-512) family."
    - "openssl_sha512 has block_size == 128 bytes."
    - "The HASH class name is 'HASH' as exposed by the C extension."
    - "All expected values verified by running Python 3.12 _hashlib on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH class name — accessed via an instance's __class__.__name__
# ---------------------------------------------------------------------------

invariant _hashlib.openssl_md5.class_name:
  description: "openssl_md5(b'').__class__.__name__ == 'HASH' — the C-level hash type is named HASH"
  category: classnames
  kind: python_call_eq
  function: openssl_md5
  args: [{type: bytes_ascii, value: ""}]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks — each openssl_* symbol exposes __name__
# ---------------------------------------------------------------------------

invariant _hashlib.openssl_md5.func_name:
  description: "openssl_md5.__name__ == 'openssl_md5'"
  category: functions
  kind: python_call_eq
  function: openssl_md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant _hashlib.openssl_sha1.func_name:
  description: "openssl_sha1.__name__ == 'openssl_sha1'"
  category: functions
  kind: python_call_eq
  function: openssl_sha1.__name__.__eq__
  args: ["openssl_sha1"]
  expected: true

invariant _hashlib.openssl_sha256.func_name:
  description: "openssl_sha256.__name__ == 'openssl_sha256'"
  category: functions
  kind: python_call_eq
  function: openssl_sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant _hashlib.openssl_sha512.func_name:
  description: "openssl_sha512.__name__ == 'openssl_sha512'"
  category: functions
  kind: python_call_eq
  function: openssl_sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

# ---------------------------------------------------------------------------
# digest_size — number of bytes in the raw digest output
# ---------------------------------------------------------------------------

invariant _hashlib.openssl_md5.digest_size:
  description: "openssl_md5(b'').digest_size == 16 — MD5 produces 128-bit (16-byte) digests"
  category: properties
  kind: python_call_eq
  function: openssl_md5
  args: [{type: bytes_ascii, value: ""}]
  method: digest_size
  expected: 16

invariant _hashlib.openssl_sha1.digest_size:
  description: "openssl_sha1(b'').digest_size == 20 — SHA-1 produces 160-bit (20-byte) digests"
  category: properties
  kind: python_call_eq
  function: openssl_sha1
  args: [{type: bytes_ascii, value: ""}]
  method: digest_size
  expected: 20

invariant _hashlib.openssl_sha256.digest_size:
  description: "openssl_sha256(b'').digest_size == 32 — SHA-256 produces 256-bit (32-byte) digests"
  category: properties
  kind: python_call_eq
  function: openssl_sha256
  args: [{type: bytes_ascii, value: ""}]
  method: digest_size
  expected: 32

invariant _hashlib.openssl_sha512.digest_size:
  description: "openssl_sha512(b'').digest_size == 64 — SHA-512 produces 512-bit (64-byte) digests"
  category: properties
  kind: python_call_eq
  function: openssl_sha512
  args: [{type: bytes_ascii, value: ""}]
  method: digest_size
  expected: 64

# ---------------------------------------------------------------------------
# block_size — internal compression block size in bytes
# ---------------------------------------------------------------------------

invariant _hashlib.openssl_md5.block_size:
  description: "openssl_md5(b'').block_size == 64 — MD5 uses a 512-bit (64-byte) block size"
  category: properties
  kind: python_call_eq
  function: openssl_md5
  args: [{type: bytes_ascii, value: ""}]
  method: block_size
  expected: 64

invariant _hashlib.openssl_sha256.block_size:
  description: "openssl_sha256(b'').block_size == 64 — SHA-256 uses a 512-bit (64-byte) block size"
  category: properties
  kind: python_call_eq
  function: openssl_sha256
  args: [{type: bytes_ascii, value: ""}]
  method: block_size
  expected: 64

invariant _hashlib.openssl_sha512.block_size:
  description: "openssl_sha512(b'').block_size == 128 — SHA-512 uses a 1024-bit (128-byte) block size"
  category: properties
  kind: python_call_eq
  function: openssl_sha512
  args: [{type: bytes_ascii, value: ""}]
  method: block_size
  expected: 128

# ---------------------------------------------------------------------------
# name attribute — human-readable algorithm name on the HASH object
# ---------------------------------------------------------------------------

invariant _hashlib.openssl_md5.name:
  description: "openssl_md5(b'').name == 'md5'"
  category: properties
  kind: python_call_eq
  function: openssl_md5
  args: [{type: bytes_ascii, value: ""}]
  method: name
  expected: "md5"

invariant _hashlib.openssl_sha256.name:
  description: "openssl_sha256(b'').name == 'sha256'"
  category: properties
  kind: python_call_eq
  function: openssl_sha256
  args: [{type: bytes_ascii, value: ""}]
  method: name
  expected: "sha256"
