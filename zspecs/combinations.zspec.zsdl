spec: combinations
version: ">=1.0.0"
backend: node(combinations)

docs: https://www.npmjs.com/package/combinations

provenance:
  derived_from:
    - "combinations README — https://www.npmjs.com/package/combinations"
    - "Test vectors verified with combinations via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "combinations source"
  notes:
    - "combinations is an npm package. Install: npm install combinations"
    - "Returns all combinations of elements from an array up to length k."
    - "combinations([1,2,3], 2) returns all subsets of length <= 2."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table combinations.combinations:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: comb

  columns: [id, args, expected]
  rows:
    - [k2,  [[1, 2, 3], 2],  [[1, 2], [1, 3], [2, 3], [1, 2, 3]]]
    - [k1,  [[1, 2], 1],     [[1], [2], [1, 2]]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:32:38Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
