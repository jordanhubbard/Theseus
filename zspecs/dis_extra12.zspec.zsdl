spec: dis_extra12
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__"
    - "dis_extra8.zspec.zsdl — covers standalone __module__ for all major dis public names"
    - "dis_extra11.zspec.zsdl — covers Instruction/Bytecode __qualname__ as standalone invariants; Instruction.__bases__.__len__; opmap.__len__; opcode list lengths; haslocal/hasname/hasjrel class checks"
  notes:
    - "This spec extends dis_extra11.zspec.zsdl."
    - "dis.pretty_flags — __qualname__/__name__/__module__ not verified in any prior dis spec."
    - "dis.Positions — a NamedTuple class added in Python 3.11; __qualname__/__name__/__module__ not verified in any prior dis spec."
    - "dis.ArgResolver — a class added in Python 3.12; __qualname__/__name__/__module__ not verified in any prior dis spec."
    - "dis.cmp_op — a tuple of comparison operator strings; class and first element not verified in any prior dis spec."
    - "dis.hasjump — list of jump opcodes (relative and absolute); class and length not verified in any prior dis spec."
    - "dis.deoptmap — a dict mapping specialized to base opnames; class not verified in any prior dis spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pretty_flags — __qualname__, __name__, __module__
#
# dis.pretty_flags converts code flag bitmasks to human-readable strings.
# It appears in no prior dis spec. It is a plain Python function defined in
# the dis module.
# ---------------------------------------------------------------------------

invariant dis_extra12.pretty_flags.qualname:
  description: "dis.pretty_flags.__qualname__ == 'pretty_flags' — module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: pretty_flags.__qualname__.__eq__
  args: ["pretty_flags"]
  expected: true

invariant dis_extra12.pretty_flags.name:
  description: "dis.pretty_flags.__name__ == 'pretty_flags' — function name check"
  category: function_names
  kind: python_call_eq
  function: pretty_flags.__name__.__eq__
  args: ["pretty_flags"]
  expected: true

invariant dis_extra12.pretty_flags.module:
  description: "dis.pretty_flags.__module__ == 'dis' — defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: pretty_flags.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# Positions — __qualname__, __name__, __module__
#
# dis.Positions is a NamedTuple class added in Python 3.11 for source position
# information. No prior dis spec verifies any attribute of Positions.
# ---------------------------------------------------------------------------

invariant dis_extra12.Positions.qualname:
  description: "dis.Positions.__qualname__ == 'Positions' — NamedTuple class for source positions"
  category: class_qualnames
  kind: python_call_eq
  function: Positions.__qualname__.__eq__
  args: ["Positions"]
  expected: true

invariant dis_extra12.Positions.name:
  description: "dis.Positions.__name__ == 'Positions' — class name check"
  category: class_names
  kind: python_call_eq
  function: Positions.__name__.__eq__
  args: ["Positions"]
  expected: true

invariant dis_extra12.Positions.module:
  description: "dis.Positions.__module__ == 'dis' — Positions is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: Positions.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# ArgResolver — __qualname__, __name__, __module__
#
# dis.ArgResolver is a class added in Python 3.12 for resolving opcode
# arguments. No prior dis spec verifies any attribute of ArgResolver.
# ---------------------------------------------------------------------------

invariant dis_extra12.ArgResolver.qualname:
  description: "dis.ArgResolver.__qualname__ == 'ArgResolver' — opcode argument resolver class"
  category: class_qualnames
  kind: python_call_eq
  function: ArgResolver.__qualname__.__eq__
  args: ["ArgResolver"]
  expected: true

invariant dis_extra12.ArgResolver.name:
  description: "dis.ArgResolver.__name__ == 'ArgResolver' — class name check"
  category: class_names
  kind: python_call_eq
  function: ArgResolver.__name__.__eq__
  args: ["ArgResolver"]
  expected: true

invariant dis_extra12.ArgResolver.module:
  description: "dis.ArgResolver.__module__ == 'dis' — ArgResolver is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: ArgResolver.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# cmp_op — class check and first element
#
# dis.cmp_op is a tuple of comparison operator strings used by COMPARE_OP.
# No prior dis spec verifies its class or content.
# ---------------------------------------------------------------------------

invariant dis_extra12.cmp_op.class:
  description: "dis.cmp_op.__class__.__name__ == 'tuple' — cmp_op is a tuple"
  category: cmp_op
  kind: python_call_eq
  function: cmp_op.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant dis_extra12.cmp_op.first_element:
  description: "dis.cmp_op[0] == '<' — first comparison operator string"
  category: cmp_op
  kind: python_call_eq
  function: cmp_op.__getitem__(0).__eq__
  args: ["<"]
  expected: true

# ---------------------------------------------------------------------------
# hasjump — class check and length
#
# dis.hasjump is the combined list of relative and absolute jump opcodes.
# No prior dis spec verifies its class or length. On Python 3.12 hasjump
# has 16 entries (same count as hasjrel on that version).
# ---------------------------------------------------------------------------

invariant dis_extra12.hasjump.class:
  description: "dis.hasjump.__class__.__name__ == 'list' — hasjump is a list"
  category: opcode_lists
  kind: python_call_eq
  function: hasjump.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra12.hasjump.len:
  description: "dis.hasjump.__len__() == 16 — number of jump opcodes on Python 3.12"
  category: opcode_lists
  kind: python_call_eq
  function: hasjump.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# deoptmap — class check
#
# dis.deoptmap is a dict mapping specialized opcode names back to their base
# (non-specialized) names. No prior dis spec verifies its class.
# ---------------------------------------------------------------------------

invariant dis_extra12.deoptmap.class:
  description: "dis.deoptmap.__class__.__name__ == 'dict' — deoptmap is a dict"
  category: opcode_maps
  kind: python_call_eq
  function: deoptmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
