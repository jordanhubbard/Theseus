  category: method_descriptor
  id_prefix: iostrio140

  columns: [id, function, args, expected]
  rows:
    - [init_cls_eq,      StringIO.__init__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [init_cls_not_md,  StringIO.__init__.__class__.__name__.__eq__,     ["method_descriptor"],  false]
    - [getval_cls_eq,    StringIO.getvalue.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [read_cls_eq,      StringIO.read.__class__.__name__.__eq__,         ["method_descriptor"],  true]
    - [write_cls_eq,     StringIO.write.__class__.__name__.__eq__,        ["method_descriptor"],  true]
    - [seek_cls_eq,      StringIO.seek.__class__.__name__.__eq__,         ["method_descriptor"],  true]
    - [readline_cls_eq,  StringIO.readline.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [tell_cls_eq,      StringIO.tell.__class__.__name__.__eq__,         ["method_descriptor"],  true]
    - [truncate_cls_eq,  StringIO.truncate.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [close_cls_eq,     StringIO.close.__class__.__name__.__eq__,        ["method_descriptor"],  true]

