spec: io_extra140
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/stringio.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.StringIO and io.BytesIO class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()) and method descriptor identity (__class__.__name__ and __qualname__) for __init__, getvalue, read, write, seek, readline, tell, truncate, close."
    - "io.StringIO.__name__ == 'StringIO' (length 8)."
    - "io.StringIO.__module__ == '_io' — StringIO is a C extension type from the _io internal module, not the pure Python io wrapper."
    - "io.StringIO.__qualname__ == 'StringIO' — qualname equals __name__ for module-level C types."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (length 11) — StringIO directly extends the private C base _TextIOBase."
    - "io.StringIO.__mro__.__len__() == 4 — MRO is [StringIO, _TextIOBase, _IOBase, object]."
    - "io.StringIO.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ is a slot wrapper, not a method_descriptor."
    - "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (length 17)."
    - "io.StringIO.getvalue.__class__.__name__ == 'method_descriptor' — getvalue is a C method descriptor."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (length 17)."
    - "io.StringIO.read.__qualname__ == 'StringIO.read' (length 13)."
    - "io.StringIO.write.__qualname__ == 'StringIO.write' (length 14)."
    - "io.StringIO.seek.__qualname__ == 'StringIO.seek' (length 13)."
    - "io.StringIO.readline.__qualname__ == 'StringIO.readline' (length 17)."
    - "io.StringIO.tell.__qualname__ == 'StringIO.tell' (length 13)."
    - "io.StringIO.truncate.__qualname__ == 'StringIO.truncate' (length 17)."
    - "io.StringIO.close.__qualname__ == 'StringIO.close' (length 14)."
    - "io.BytesIO.__name__ == 'BytesIO' (length 7), __module__ == '_io'."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (length 15)."
    - "io.BytesIO.__mro__.__len__() == 4 — MRO is [BytesIO, _BufferedIOBase, _IOBase, object]."
    - "io.BytesIO.__init__.__class__.__name__ == 'wrapper_descriptor'."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (length 16)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO class identity
# StringIO is a C extension type from _io. __name__ == 'StringIO' (8),
# __module__ == '_io' (3), __qualname__ == 'StringIO' (8).
# __bases__[0].__name__ == '_TextIOBase' (11). MRO length == 4.
# ---------------------------------------------------------------------------

table io_extra140.StringIO_class_identity:
  description: "io.StringIO class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: iostrio140

  columns: [id, function, args, expected]
  rows:
    - [sio_name_eq,      StringIO.__name__.__eq__,                ["StringIO"],    true]
    - [sio_name_len,     StringIO.__name__.__len__,               [],              8]
    - [sio_module_eq,    StringIO.__module__.__eq__,              ["_io"],         true]
    - [sio_module_not,   StringIO.__module__.__eq__,              ["io"],          false]
    - [sio_module_len,   StringIO.__module__.__len__,             [],              3]
    - [sio_qualname_eq,  StringIO.__qualname__.__eq__,            ["StringIO"],    true]
    - [sio_qualname_len, StringIO.__qualname__.__len__,           [],              8]
    - [sio_base_eq,      "StringIO.__bases__[0].__name__.__eq__", ["_TextIOBase"], true]
    - [sio_base_len,     "StringIO.__bases__[0].__name__.__len__", [],             11]
    - [sio_mro_len,      StringIO.__mro__.__len__,                [],              4]

# ---------------------------------------------------------------------------
# io.StringIO method descriptor __class__.__name__
# __init__ is a wrapper_descriptor; getvalue, read, write, seek, readline,
# tell, truncate, close are all method_descriptor instances.
# ---------------------------------------------------------------------------

table io_extra140.StringIO_method_descriptor_classes:
  description: "io.StringIO method descriptor __class__.__name__: __init__='wrapper_descriptor', getvalue/read/write/seek/readline/tell/truncate/close='method_descriptor'"
