# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra140.StringIO.name_is_StringIO:
  description: "io.StringIO.__name__ == 'StringIO' (length 8; the class name as defined in the _io C extension)"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra140.StringIO.module_is_underscore_io:
  description: "io.StringIO.__module__ == '_io' (length 3; StringIO is a C extension type from the _io internal module, not the pure Python io wrapper)"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra140.StringIO.mro_len_4:
  description: "io.StringIO.__mro__.__len__() == 4 (MRO is [StringIO, _TextIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra140.StringIO.init_is_wrapper_descriptor:
  description: "io.StringIO.__init__.__class__.__name__ == 'wrapper_descriptor' (__init__ is a slot wrapper, distinct from the method_descriptor used by read, write, getvalue, etc.)"
  category: method_descriptor
  kind: python_call_eq
  function: StringIO.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra140.StringIO.getvalue_qualname_len_17:
  description: "io.StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.getvalue' is 17 chars: 'StringIO' (8) + '.' (1) + 'getvalue' (8))"
  category: method_descriptor
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__len__
  args: []
  expected: 17

