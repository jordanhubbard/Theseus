spec: hashlib_extra200
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2module.c"
  notes:
    - "hashlib.md5.__qualname__ == 'openssl_md5' (len=11) — OpenSSL-backed md5 on macOS/Darwin; qualname equals __name__."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1' (len=12) — OpenSSL-backed sha1 on macOS/Darwin."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256' (len=14) — OpenSSL-backed sha256 on macOS/Darwin."
    - "hashlib.sha512.__qualname__ == 'openssl_sha512' (len=14) — OpenSSL-backed sha512 on macOS/Darwin."
    - "hashlib.blake2b.__qualname__ == 'blake2b' (len=7) — backed by _blake2 C extension, not OpenSSL; shorter qualname."
    - "hashlib.blake2s.__qualname__ == 'blake2s' (len=7) — backed by _blake2 C extension; same length as blake2b qualname."
    - "hashlib.md5.__module__ == '_hashlib' (len=8) — OpenSSL-backed constructors report _hashlib as their module."
    - "hashlib.blake2b.__module__ == '_blake2' (len=7) — BLAKE2 constructors report _blake2, distinct from _hashlib."
    - "Qualname length ordering: blake2b==blake2s(7) < md5(11) < sha1(12) < sha256==sha512(14)."
    - "blake2b and blake2s are the only hashlib constructors whose qualname does not carry the 'openssl_' prefix."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib constructor __qualname__ values — openssl family
# md5(11), sha1(12), sha256/sha512(14) — all carry 'openssl_' prefix
# ---------------------------------------------------------------------------

table hashlibqualnames200.openssl_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: hashlibqualnames200

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qualname,    md5.__qualname__.__eq__,    ["openssl_md5"],    true, "hashlib.md5.__qualname__ == 'openssl_md5' (OpenSSL-backed md5 constructor on macOS/Darwin)"]
    - [sha1_qualname,   sha1.__qualname__.__eq__,   ["openssl_sha1"],   true, "hashlib.sha1.__qualname__ == 'openssl_sha1' (OpenSSL-backed sha1 constructor on macOS/Darwin)"]
    - [sha256_qualname, sha256.__qualname__.__eq__, ["openssl_sha256"], true, "hashlib.sha256.__qualname__ == 'openssl_sha256' (OpenSSL-backed sha256 constructor on macOS/Darwin)"]

# ---------------------------------------------------------------------------
# hashlib constructor __qualname__ values — sha512 and BLAKE2 family
# sha512 has 'openssl_' prefix; blake2b/blake2s do not
# ---------------------------------------------------------------------------

table hashlibqualnames200.blake2_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: hashlibqualnames200

  columns: [id, function, args, expected, description]
  rows:
    - [sha512_qualname,  sha512.__qualname__.__eq__,  ["openssl_sha512"], true, "hashlib.sha512.__qualname__ == 'openssl_sha512' (OpenSSL-backed sha512 constructor on macOS/Darwin)"]
    - [blake2b_qualname, blake2b.__qualname__.__eq__,  ["blake2b"],        true, "hashlib.blake2b.__qualname__ == 'blake2b' (backed by _blake2 extension, no 'openssl_' prefix)"]
    - [blake2s_qualname, blake2s.__qualname__.__eq__,  ["blake2s"],        true, "hashlib.blake2s.__qualname__ == 'blake2s' (backed by _blake2 extension, same length as blake2b)"]

# ---------------------------------------------------------------------------
# hashlib constructor __module__ values — _hashlib vs _blake2
# md5 reports _hashlib; blake2b reports _blake2
# ---------------------------------------------------------------------------

table hashlibqualnames200.modules:
  kind: python_call_eq
  category: modules
  id_prefix: hashlibqualnames200

  columns: [id, function, args, expected, description]
  rows:
    - [md5_module,      md5.__module__.__eq__,     ["_hashlib"], true, "hashlib.md5.__module__ == '_hashlib' (OpenSSL-backed constructors report _hashlib)"]
    - [blake2b_module,  blake2b.__module__.__eq__,  ["_blake2"],  true, "hashlib.blake2b.__module__ == '_blake2' (BLAKE2 constructors report _blake2, not _hashlib)"]
    - [blake2b_qualname_len, blake2b.__qualname__.__len__, [], 7, "len(hashlib.blake2b.__qualname__) == 7 ('blake2b' has 7 characters — shortest qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlibqualnames200.md5.qualname:
  description: "hashlib.md5.__qualname__ == 'openssl_md5' (OpenSSL-backed md5 constructor on macOS/Darwin; qualname equals __name__)"
  category: qualnames
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlibqualnames200.sha256.qualname:
  description: "hashlib.sha256.__qualname__ == 'openssl_sha256' (OpenSSL-backed sha256; len=14)"
  category: qualnames
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlibqualnames200.sha512.qualname:
  description: "hashlib.sha512.__qualname__ == 'openssl_sha512' (OpenSSL-backed sha512; same length as sha256 qualname)"
  category: qualnames
  kind: python_call_eq
  function: sha512.__qualname__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlibqualnames200.sha1.qualname:
  description: "hashlib.sha1.__qualname__ == 'openssl_sha1' (len=12 — between md5(11) and sha256/sha512(14))"
  category: qualnames
  kind: python_call_eq
  function: sha1.__qualname__.__eq__
  args: ["openssl_sha1"]
  expected: true

invariant hashlibqualnames200.blake2b.qualname:
  description: "hashlib.blake2b.__qualname__ == 'blake2b' (len=7 — backed by _blake2; no 'openssl_' prefix)"
  category: qualnames
  kind: python_call_eq
  function: blake2b.__qualname__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlibqualnames200.blake2s.qualname:
  description: "hashlib.blake2s.__qualname__ == 'blake2s' (len=7 — same length as blake2b qualname)"
  category: qualnames
  kind: python_call_eq
  function: blake2s.__qualname__.__eq__
  args: ["blake2s"]
  expected: true

invariant hashlibqualnames200.md5.module:
  description: "hashlib.md5.__module__ == '_hashlib' (len=8 — OpenSSL-backed constructors report _hashlib as their module)"
  category: modules
  kind: python_call_eq
  function: md5.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlibqualnames200.blake2b.module:
  description: "hashlib.blake2b.__module__ == '_blake2' (len=7 — BLAKE2 constructors use _blake2, distinct from _hashlib)"
  category: modules
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

