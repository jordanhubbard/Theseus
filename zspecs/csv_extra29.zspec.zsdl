spec: csv_extra29
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
    - "csv_extra25.zspec.zsdl — covers __module__.__len__() for DictReader/DictWriter/Dialect/Error/reader/writer/register_dialect/field_size_limit; __name__.__len__() for DictReader/DictWriter/Dialect/Error"
    - "csv_extra26.zspec.zsdl — covers __qualname__.__len__() for Dialect/excel/excel_tab/unix_dialect/DictReader/DictWriter; DictReader.__init__/DictReader.__next__/DictWriter.writerow/DictWriter.writerows/DictWriter.writeheader __qualname__.__len__()"
    - "csv_extra27.zspec.zsdl — covers __mro__.__len__() for DictReader/DictWriter/Dialect/excel/excel_tab; __bases__[0].__name__ for DictReader/DictWriter/Dialect; DictWriter.__init__/Dialect.__init__ __qualname__.__len__()"
    - "csv_extra28.zspec.zsdl — covers csv.__all__.__len__()==21; csv.__all__.__class__.__name__.__len__()==4; csv.__version__ value and len; QUOTE_* constants; Sniffer/__mro__.__len__()==2; Error/__mro__.__len__()==4; unix_dialect/__mro__.__len__()==3; Sniffer/__dict__.__class__.__name__.__len__()==12; Error/__dict__.__class__.__name__.__len__()==12; Sniffer.__init__/__qualname__.__len__()==16; Sniffer.sniff/__qualname__.__len__()==13; Error.__reduce__.__qualname__.__len__()==24"
  notes:
    - "This spec extends csv_extra28.zspec.zsdl."
    - "Prior specs covered: reader/writer/DictReader/DictWriter/Dialect/Error/Sniffer/unix_dialect __name__/__module__/__qualname__, __mro__.__len__(), __bases__[0].__name__, __dict__.__class__.__name__.__len__(), key method qualname lengths, QUOTE_* constants, __all__, __version__."
    - "This spec covers: csv.Dialect.__dict__.__class__.__name__.__len__()==12; csv.Dialect.__mro__.__len__()==2; csv.Dialect.__bases__[0].__name__.__len__()==6; csv.Error.__bases__[0].__name__.__len__()==9; csv.reader.__class__.__name__.__len__()==26; csv.writer.__class__.__name__.__len__()==26; csv.DictReader.__dict__.__class__.__name__.__len__()==12; csv.DictWriter.__dict__.__class__.__name__.__len__()==12; csv.DictReader.__bases__[0].__name__.__len__()==6; csv.DictReader.__mro__.__len__()==2; csv.register_dialect.__qualname__.__len__()==16; csv.unregister_dialect.__qualname__.__len__()==18; csv.get_dialect.__qualname__.__len__()==11; csv.list_dialects.__qualname__.__len__()==13."
    - "csv.Dialect.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12."
    - "csv.Dialect.__mro__ == [Dialect, object] — len 2. Verified Python 3.12."
    - "csv.Dialect.__bases__[0].__name__ == 'object' — len 6. Verified Python 3.12."
    - "csv.Error.__bases__[0].__name__ == 'Exception' — len 9. Verified Python 3.12."
    - "csv.reader.__class__.__name__ == 'builtin_function_or_method' — len 26. csv.reader is a C builtin, not a class. Verified Python 3.12."
    - "csv.writer.__class__.__name__ == 'builtin_function_or_method' — len 26. Same as csv.reader. Verified Python 3.12."
    - "csv.DictReader.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12."
    - "csv.DictWriter.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12."
    - "csv.DictReader.__bases__[0].__name__ == 'object' — len 6. Verified Python 3.12."
    - "csv.DictReader.__mro__ == [DictReader, object] — len 2. Verified Python 3.12."
    - "csv.register_dialect.__qualname__ == 'register_dialect' — len 16. Verified Python 3.12."
    - "csv.unregister_dialect.__qualname__ == 'unregister_dialect' — len 18. Verified Python 3.12."
    - "csv.get_dialect.__qualname__ == 'get_dialect' — len 11. Verified Python 3.12."
    - "csv.list_dialects.__qualname__ == 'list_dialects' — len 13. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# csv.Dialect introspection
#
# Dialect is the base class for all dialect subclasses (excel, excel_tab,
# unix_dialect). Its class namespace is a mappingproxy (len 12), it has a
# simple two-level MRO [Dialect, object] (len 2), and its single base is
# 'object' (len 6).
# csv_extra27 covered DictReader/DictWriter/excel/excel_tab __mro__ and bases.
# csv_extra28 covered Sniffer/Error __mro__.
# No prior csv spec checks Dialect.__dict__.__class__.__name__.__len__() alone.
# ---------------------------------------------------------------------------

invariant csv_extra29.Dialect.dict_class_name_len:
  description: "csv.Dialect.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is a 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: Dialect.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant csv_extra29.Dialect.mro_len:
  description: "csv.Dialect.__mro__.__len__() == 2 — MRO is [Dialect, object]; Dialect has no intermediate bases"
  category: class_hierarchy
  kind: python_call_eq
  function: Dialect.__mro__.__len__
  args: []
  expected: 2

invariant csv_extra29.Dialect.base_name_len:
  description: "csv.Dialect.__bases__[0].__name__.__len__() == 6 — direct base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Dialect.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# csv.Error base class name
#
# csv.Error inherits from Exception. Error.__bases__[0].__name__ == 'Exception'
# (len 9). csv_extra28 covered Error.__mro__.__len__() == 4 and
# Error.__dict__.__class__.__name__.__len__() == 12 but did not check the
# length of the base class name string.
# ---------------------------------------------------------------------------

invariant csv_extra29.Error.base_name_len:
  description: "csv.Error.__bases__[0].__name__.__len__() == 9 — direct base is 'Exception' (9 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Error.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# csv.reader and csv.writer __class__.__name__.__len__()
#
# csv.reader and csv.writer are C builtins exposed as instances of
# 'builtin_function_or_method' (len 26), NOT Python classes.
# No prior csv spec checks the class name of csv.reader or csv.writer.
# ---------------------------------------------------------------------------

table csv_extra29.reader_writer_class_name_len:
  description: "csv.reader and csv.writer __class__.__name__.__len__() == 26 — both are 'builtin_function_or_method' (26 chars); they are C-level callables"
  kind: python_call_eq
  category: class_introspection
  id_prefix: rwcn29

  columns: [id, function, args, expected]
  rows:
    - [reader, reader.__class__.__name__.__len__, [], 26]
    - [writer, writer.__class__.__name__.__len__, [], 26]

# ---------------------------------------------------------------------------
# csv.DictReader and csv.DictWriter __dict__.__class__.__name__.__len__()
# and DictReader __bases__[0].__name__.__len__() and __mro__.__len__()
#
# DictReader and DictWriter are pure-Python classes; their class namespace
# is a mappingproxy (len 12). Both have a single base 'object' (len 6) and
# a two-level MRO (len 2).
# csv_extra27 covered DictReader/DictWriter __mro__.__len__() and
# __bases__[0].__name__ but NOT __dict__.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

table csv_extra29.dictclass_dict_proxy_len:
  description: "csv.DictReader and csv.DictWriter __dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ddp29

  columns: [id, function, args, expected]
  rows:
    - [DictReader, DictReader.__dict__.__class__.__name__.__len__, [], 12]
    - [DictWriter, DictWriter.__dict__.__class__.__name__.__len__, [], 12]

invariant csv_extra29.DictReader.base_name_len:
  description: "csv.DictReader.__bases__[0].__name__.__len__() == 6 — direct base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "DictReader.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant csv_extra29.DictReader.mro_len:
  description: "csv.DictReader.__mro__.__len__() == 2 — MRO is [DictReader, object]; no intermediate bases"
  category: class_hierarchy
  kind: python_call_eq
  function: DictReader.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# csv module-level function qualname lengths
#
# These four functions are the dialect registry API. Their qualnames are simple
# top-level names (not class-scoped), so qualname == __name__. No prior csv
# spec checks qualname lengths for register_dialect, unregister_dialect,
# get_dialect, or list_dialects.
#
#   register_dialect   -> 'register_dialect'   -> 16 chars
#   unregister_dialect -> 'unregister_dialect' -> 18 chars
#   get_dialect        -> 'get_dialect'         -> 11 chars
#   list_dialects      -> 'list_dialects'       -> 13 chars
# ---------------------------------------------------------------------------

table csv_extra29.dialect_registry_qualname_lens:
  description: "csv dialect registry function __qualname__.__len__(): register_dialect (16), unregister_dialect (18), get_dialect (11), list_dialects (13)"
  kind: python_call_eq
  category: function_identity
  id_prefix: drq29

  columns: [id, function, args, expected]
  rows:
    - [register_dialect,   register_dialect.__qualname__.__len__,   [], 16]
    - [unregister_dialect, unregister_dialect.__qualname__.__len__, [], 18]
    - [get_dialect,        get_dialect.__qualname__.__len__,        [], 11]
    - [list_dialects,      list_dialects.__qualname__.__len__,      [], 13]
