spec: itertools_extra166
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain.__name__ 'chain'; itertools.chain.__module__ 'itertools'; itertools.cycle.__name__ 'cycle' (cross-check, already in extra164); itertools.repeat.__name__ 'repeat' (cross-check); itertools.product.__name__ 'product'; itertools.product.__module__ 'itertools'; itertools.permutations.__name__ 'permutations'; itertools.permutations.__module__ 'itertools'; itertools.combinations.__name__ 'combinations'; itertools.combinations.__module__ 'itertools' (Wave 295)."
    - "itertools.chain.__name__ == 'chain' — itertools.chain is a C extension type in itertoolsmodule.c that chains multiple iterables end-to-end into a single iterator; its type __name__ is 'chain'. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — chain is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product' — itertools.product is a C extension type in itertoolsmodule.c that produces the Cartesian product of input iterables; its type __name__ is 'product'. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — product is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' — itertools.permutations is a C extension type in itertoolsmodule.c that emits successive permutations of elements from an iterable; its type __name__ is 'permutations'. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools' — permutations is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' — itertools.combinations is a C extension type in itertoolsmodule.c that emits r-length subsequences of elements from an iterable; its type __name__ is 'combinations'. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools' — combinations is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain identity — __name__ and __module__
#
# Wave 295 theme: itertools.chain C extension type identity — __name__,
# __module__, and __bases__.
#
# itertools.chain.__name__ == 'chain'
# itertools.chain.__module__ == 'itertools'
# itertools.chain.__bases__[0].__name__ == 'object'
# itertools.chain.__class__.__name__ == 'type'
#
# itertools.chain(*iterables) makes an iterator that returns elements from
# the first iterable until it is exhausted, then proceeds to the next, until
# all of the iterables are exhausted. Used for treating consecutive sequences
# as a single sequence. It is a C extension type in itertoolsmodule.c that
# inherits directly from object. New to extra166.
# ---------------------------------------------------------------------------

table itertools_extra166.chain_identity:
  description: "itertools.chain: __name__ 'chain', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolschi166

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq_chain,
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C extension type in itertoolsmodule.c that returns elements from consecutive iterables as if they were a single sequence; its type __name__ attribute is 'chain'; str.__eq__('chain') returns True; new to extra166"]
    - [chain_module_eq_itertools,
       "chain.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra166"]
    - ["chain_bases_0_object",
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain is a C extension type in itertoolsmodule.c that chains consecutive iterables; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra166"]
    - [chain_class_name_type,
       "chain.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra166"]

# ---------------------------------------------------------------------------
# Table 2: itertools.product identity — __name__ and __module__
#
# Wave 295 theme: itertools.product C extension type identity — __name__,
# __module__, and __bases__.
#
# itertools.product.__name__ == 'product'
# itertools.product.__module__ == 'itertools'
# itertools.product.__bases__[0].__name__ == 'object'
#
# itertools.product(*iterables, repeat=1) computes the Cartesian product of
# input iterables, equivalent to nested for-loops. For example,
# product(A, B) returns the same as ((x, y) for x in A for y in B). It is
# a C extension type in itertoolsmodule.c that inherits directly from object.
# New to extra166.
# ---------------------------------------------------------------------------

table itertools_extra166.product_identity:
  description: "itertools.product: __name__ 'product', __module__ 'itertools', __bases__[0].__name__ 'object'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolspid166

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_eq_product,
       "product.__name__.__eq__",
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C extension type in itertoolsmodule.c that computes the Cartesian product of input iterables; its type __name__ attribute is 'product'; str.__eq__('product') returns True; new to extra166"]
    - [product_module_eq_itertools,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra166"]
    - ["product_bases_0_object",
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product is a C extension type that computes Cartesian products; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra166"]
    - [product_name_ne_chain,
       "product.__name__.__eq__",
       ["chain"],
       false,
       "itertools.product.__name__.__eq__('chain') == False — product.__name__ is 'product', not 'chain'; these are two distinct C extension iterator types in itertoolsmodule.c; str.__eq__('chain') returns False; new to extra166"]

# ---------------------------------------------------------------------------
# Table 3: itertools.permutations and itertools.combinations identity
#
# Wave 295 theme: itertools.permutations and itertools.combinations C extension
# type identity — __name__, __module__, and __bases__.
#
# itertools.permutations.__name__ == 'permutations'
# itertools.permutations.__module__ == 'itertools'
# itertools.permutations.__bases__[0].__name__ == 'object'
# itertools.combinations.__name__ == 'combinations'
# itertools.combinations.__module__ == 'itertools'
#
# itertools.permutations(iterable, r=None) emits successive r-length
# permutations of elements in the iterable in lexicographic ordering. If r
# is not specified it defaults to the iterable's length. It is a C extension
# type in itertoolsmodule.c inheriting from object.
# itertools.combinations(iterable, r) emits r-length subsequences of elements
# from the iterable in sorted order (combinations do not include repeated
# elements). Also a C extension type inheriting from object. New to extra166.
# ---------------------------------------------------------------------------

table itertools_extra166.permutations_and_combinations_identity:
  description: "itertools: permutations.__name__ 'permutations', permutations.__module__ 'itertools', permutations.__bases__[0].__name__ 'object', combinations.__name__ 'combinations', combinations.__module__ 'itertools'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolspci166

  columns: [id, function, args, expected, description]
  rows:
    - [perms_name_eq_permutations,
       "permutations.__name__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C extension type in itertoolsmodule.c that emits successive r-length permutations of elements in an iterable; its type __name__ attribute is 'permutations'; str.__eq__('permutations') returns True; new to extra166"]
    - [perms_module_eq_itertools,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra166"]
    - ["perms_bases_0_object",
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations is a C extension type; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra166"]
    - [combs_name_eq_combinations,
       "combinations.__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C extension type in itertoolsmodule.c that emits r-length subsequences of elements in sorted order; its type __name__ attribute is 'combinations'; str.__eq__('combinations') returns True; new to extra166"]
    - [combs_module_eq_itertools,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra166"]

# ---------------------------------------------------------------------------
# Table 4: itertools.combinations __bases__ and cross-checks
#
# Wave 295 theme: itertools.combinations base class and cross-checks between
# the new C extension types introduced in this spec.
#
# itertools.combinations.__bases__[0].__name__ == 'object'
# itertools.permutations.__name__ != 'combinations'
# itertools.combinations.__name__ != 'permutations'
# itertools.chain.__name__ != 'product'
#
# All six types (chain, cycle, repeat, product, permutations, combinations)
# are C extension types in itertoolsmodule.c that inherit directly from object.
# Their __name__ values are distinct. New to extra166.
# ---------------------------------------------------------------------------

table itertools_extra166.combinations_bases_and_cross_checks:
  description: "itertools: combinations.__bases__[0].__name__ 'object'; permutations.__name__ != 'combinations'; combinations.__name__ != 'permutations'; chain.__name__ != 'product'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscbcc166

  columns: [id, function, args, expected, description]
  rows:
    - ["combs_bases_0_object",
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations is a C extension type that emits r-length subsequences; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra166"]
    - [perms_name_ne_combinations,
       "permutations.__name__.__eq__",
       ["combinations"],
       false,
       "itertools.permutations.__name__.__eq__('combinations') == False — permutations.__name__ is 'permutations' not 'combinations'; these are two distinct C extension types; str.__eq__('combinations') returns False; new to extra166"]
    - [combs_name_ne_permutations,
       "combinations.__name__.__eq__",
       ["permutations"],
       false,
       "itertools.combinations.__name__.__eq__('permutations') == False — combinations.__name__ is 'combinations' not 'permutations'; these are two distinct C extension types; str.__eq__('permutations') returns False; new to extra166"]
    - [chain_name_ne_product,
       "chain.__name__.__eq__",
       ["product"],
       false,
       "itertools.chain.__name__.__eq__('product') == False — chain.__name__ is 'chain' not 'product'; these are two distinct C extension types in itertoolsmodule.c; str.__eq__('product') returns False; new to extra166"]

