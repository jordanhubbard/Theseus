spec: _bisect_extra
version: ">=3.9"
backend: python_module(_bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl, bisect_extra.zspec.zsdl, and bisect_extra2.zspec.zsdl."
    - "The _bisect module is the C accelerator for the bisect stdlib module."
    - "_bisect.bisect is an alias for bisect_right; _bisect.bisect.__name__ == 'bisect_right'."
    - "_bisect.insort is an alias for insort_right; _bisect.insort.__name__ == 'insort_right'."
    - "_bisect functions report __module__ == '_bisect' on CPython (verified on 3.12)."
    - "insort_left and insort_right mutate the list in-place and return None."
    - "bisect_left([1,2,3,4,5], 3) == 2 — left insertion point for value that exists."
    - "bisect_right([1,2,3,4,5], 3) == 3 — right insertion point for value that exists."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — public and aliased API functions of _bisect
# ---------------------------------------------------------------------------

invariant _bisect_extra.bisect.__name__:
  description: "_bisect.bisect.__name__ == 'bisect_right' — bisect is an alias for bisect_right"
  category: identity
  kind: python_call_eq
  function: bisect.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant _bisect_extra.bisect_left.__name__:
  description: "_bisect.bisect_left.__name__ == 'bisect_left'"
  category: identity
  kind: python_call_eq
  function: bisect_left.__name__.__eq__
  args: ["bisect_left"]
  expected: true

invariant _bisect_extra.bisect_right.__name__:
  description: "_bisect.bisect_right.__name__ == 'bisect_right'"
  category: identity
  kind: python_call_eq
  function: bisect_right.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant _bisect_extra.insort.__name__:
  description: "_bisect.insort.__name__ == 'insort_right' — insort is an alias for insort_right"
  category: identity
  kind: python_call_eq
  function: insort.__name__.__eq__
  args: ["insort_right"]
  expected: true

invariant _bisect_extra.insort_left.__name__:
  description: "_bisect.insort_left.__name__ == 'insort_left'"
  category: identity
  kind: python_call_eq
  function: insort_left.__name__.__eq__
  args: ["insort_left"]
  expected: true

invariant _bisect_extra.insort_right.__name__:
  description: "_bisect.insort_right.__name__ == 'insort_right'"
  category: identity
  kind: python_call_eq
  function: insort_right.__name__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — all functions report __module__ == '_bisect'
# ---------------------------------------------------------------------------

table _bisect_extra.function_modules:
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [bisect,       bisect.__module__.__eq__,       ["_bisect"], true]
    - [bisect_left,  bisect_left.__module__.__eq__,  ["_bisect"], true]
    - [bisect_right, bisect_right.__module__.__eq__, ["_bisect"], true]
    - [insort,       insort.__module__.__eq__,       ["_bisect"], true]
    - [insort_left,  insort_left.__module__.__eq__,  ["_bisect"], true]
    - [insort_right, insort_right.__module__.__eq__, ["_bisect"], true]

# ---------------------------------------------------------------------------
# Behavioral — bisect_left and bisect_right correctness via _bisect directly
# ---------------------------------------------------------------------------

invariant _bisect_extra.bisect_left.existing_value:
  description: "_bisect.bisect_left([1,2,3,4,5], 3) == 2 — left insertion point for existing value"
  category: behavioral
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 4, 5], 3]
  expected: 2

invariant _bisect_extra.bisect_right.existing_value:
  description: "_bisect.bisect_right([1,2,3,4,5], 3) == 3 — right insertion point after existing value"
  category: behavioral
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 4, 5], 3]
  expected: 3

invariant _bisect_extra.bisect_left.empty_list:
  description: "_bisect.bisect_left([], 5) == 0 — empty list returns 0"
  category: behavioral
  kind: python_call_eq
  function: bisect_left
  args: [[], 5]
  expected: 0

invariant _bisect_extra.bisect_right.empty_list:
  description: "_bisect.bisect_right([], 5) == 0 — empty list returns 0"
  category: behavioral
  kind: python_call_eq
  function: bisect_right
  args: [[], 5]
  expected: 0

# ---------------------------------------------------------------------------
# insort_left and insort_right — return None (in-place mutation)
# ---------------------------------------------------------------------------

invariant _bisect_extra.insort_left.returns_none:
  description: "_bisect.insort_left([1,3,5], 2) returns None — in-place insert, no return value"
  category: behavioral
  kind: python_call_eq
  function: insort_left
  args: [[1, 3, 5], 2]
  expected: ~

invariant _bisect_extra.insort_right.returns_none:
  description: "_bisect.insort_right([1,3,5], 4) returns None — in-place insert, no return value"
  category: behavioral
  kind: python_call_eq
  function: insort_right
  args: [[1, 3, 5], 4]
  expected: ~
