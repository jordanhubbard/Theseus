spec: functools_extra1261
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 531: checks functools.__all__ membership (contains true/false), __all__ class identity, and __all__ length class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1261.all_contains_true:
  description: "functools.__all__.__contains__ returns true for names that are in __all__"
  kind: python_call_eq
  category: all_membership_true
  id_prefix: fu1261at
  columns: [id, function, args, expected]
  rows:
    - [fu1261at001, functools.__all__.__contains__, ["reduce"],               true]
    - [fu1261at002, functools.__all__.__contains__, ["partial"],              true]
    - [fu1261at003, functools.__all__.__contains__, ["lru_cache"],            true]
    - [fu1261at004, functools.__all__.__contains__, ["cache"],                true]
    - [fu1261at005, functools.__all__.__contains__, ["cached_property"],      true]
    - [fu1261at006, functools.__all__.__contains__, ["wraps"],                true]
    - [fu1261at007, functools.__all__.__contains__, ["total_ordering"],       true]
    - [fu1261at008, functools.__all__.__contains__, ["singledispatch"],       true]
    - [fu1261at009, functools.__all__.__contains__, ["update_wrapper"],       true]
    - [fu1261at010, functools.__all__.__contains__, ["cmp_to_key"],           true]
    - [fu1261at011, functools.__all__.__contains__, ["singledispatchmethod"], true]
    - [fu1261at012, functools.__all__.__contains__, ["partialmethod"],        true]
    - [fu1261at013, functools.__all__.__contains__, ["WRAPPER_ASSIGNMENTS"],  true]
    - [fu1261at014, functools.__all__.__contains__, ["WRAPPER_UPDATES"],      true]
    - [fu1261at015, functools.__all__.__contains__, ["Placeholder"],          true]

table functools_extra1261.all_contains_false:
  description: "functools.__all__.__contains__ returns false for private names and imported symbols not in __all__"
  kind: python_call_eq
  category: all_membership_false
  id_prefix: fu1261af
  columns: [id, function, args, expected]
  rows:
    - [fu1261af001, functools.__all__.__contains__, ["_lru_cache_wrapper"], false]
    - [fu1261af002, functools.__all__.__contains__, ["_CacheInfo"],         false]
    - [fu1261af003, functools.__all__.__contains__, ["_NOT_FOUND"],         false]
    - [fu1261af004, functools.__all__.__contains__, ["GenericAlias"],       false]
    - [fu1261af005, functools.__all__.__contains__, ["MappingProxyType"],   false]
    - [fu1261af006, functools.__all__.__contains__, ["RLock"],              false]
    - [fu1261af007, functools.__all__.__contains__, ["sys"],                false]
    - [fu1261af008, functools.__all__.__contains__, ["types"],              false]
    - [fu1261af009, functools.__all__.__contains__, ["_c3_merge"],          false]
    - [fu1261af010, functools.__all__.__contains__, ["_c3_mro"],            false]
    - [fu1261af011, functools.__all__.__contains__, ["MethodType"],         false]
    - [fu1261af012, functools.__all__.__contains__, ["UnionType"],          false]

table functools_extra1261.all_class_and_type_checks:
  description: "functools.__all__ is a list and its class name identity checks"
  kind: python_call_eq
  category: all_class_checks
  id_prefix: fu1261ac
  columns: [id, function, args, expected]
  rows:
    - [fu1261ac001, functools.__all__.__class__.__name__.__eq__,           ["list"],      true]
    - [fu1261ac002, functools.__all__.__class__.__name__.__eq__,           ["tuple"],     false]
    - [fu1261ac003, functools.__all__.__class__.__name__.__eq__,           ["set"],       false]
    - [fu1261ac004, functools.__all__.__class__.__name__.__eq__,           ["frozenset"], false]
    - [fu1261ac005, functools.__all__.__class__.__name__.__eq__,           ["dict"],      false]
    - [fu1261ac006, functools.__all__.__class__.__qualname__.__eq__,       ["list"],      true]
    - [fu1261ac007, functools.__all__.__class__.__module__.__eq__,         ["builtins"],  true]
    - [fu1261ac008, functools.__name__.__eq__,                             ["functools"], true]
    - [fu1261ac009, functools.__spec__.name.__eq__,                        ["functools"], true]
    - [fu1261ac010, functools.__all__.__len__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
