spec: inspect_extra266
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "All inspect members in this spec are plain Python functions: __class__.__name__ == 'function' for all."
    - "All inspect functions have __module__ == 'inspect' (len=7)."
    - "getdoc.__name__ (6) is shortest; isfunction.__name__ (10) == getmembers.__name__ (10) tied longest."
    - "isfunction.__name__ (10) > signature.__name__ (9) > ismodule.__name__ (8) == ismethod.__name__ (8) > isclass.__name__ (7) > getdoc.__name__ (6)."
    - "All functions have __qualname__ == __name__ (module-level, no nesting)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect predicate functions identity: isfunction, isclass, ismodule, ismethod
#
# All are plain Python functions defined in inspect.
# isfunction.__name__ (len=10) tied longest with getmembers.
# isclass.__name__ (len=7) tied with module name 'inspect' (len=7).
# ismodule.__name__ (len=8) == ismethod.__name__ (len=8) — tied.
# ---------------------------------------------------------------------------

table inspect_extra266.predicate_functions_identity:
  description: "inspect.isfunction(10), isclass(7), ismodule(8), ismethod(8) identity — all plain Python functions in inspect(7); isfunction(10) is longest in table; isclass(7) equals module name length; ismodule and ismethod names(8) are tied; all qualnames equal names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex266p

  columns: [id, function, args, expected, description]
  rows:
    - [if_name_eq,       isfunction.__name__.__eq__,                 ["isfunction"],                 true, "inspect.isfunction.__name__ == 'isfunction'; verified with Python 3.14.3"]
    - [if_name_len,      isfunction.__name__.__len__,                [],                             10,   "inspect.isfunction.__name__.__len__() == 10 — tied longest with getmembers; verified with Python 3.14.3"]
    - [if_qn_eq,         isfunction.__qualname__.__eq__,             ["isfunction"],                 true, "inspect.isfunction.__qualname__ == 'isfunction' — qualname equals name; verified with Python 3.14.3"]
    - [if_mod_eq,        isfunction.__module__.__eq__,               ["inspect"],                    true, "inspect.isfunction.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [if_mod_len,       isfunction.__module__.__len__,              [],                             7,    "inspect.isfunction.__module__.__len__() == 7; verified with Python 3.14.3"]
    - [if_cls_eq,        isfunction.__class__.__name__.__eq__,       ["function"],                   true, "inspect.isfunction.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ic_name_eq,       isclass.__name__.__eq__,                    ["isclass"],                    true, "inspect.isclass.__name__ == 'isclass'; verified with Python 3.14.3"]
    - [ic_name_len,      isclass.__name__.__len__,                   [],                             7,    "inspect.isclass.__name__.__len__() == 7 — equals module name 'inspect' length; verified with Python 3.14.3"]
    - [ic_qn_eq,         isclass.__qualname__.__eq__,                ["isclass"],                    true, "inspect.isclass.__qualname__ == 'isclass' — qualname equals name; verified with Python 3.14.3"]
    - [ic_mod_eq,        isclass.__module__.__eq__,                  ["inspect"],                    true, "inspect.isclass.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ic_cls_eq,        isclass.__class__.__name__.__eq__,          ["function"],                   true, "inspect.isclass.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [im_name_eq,       ismodule.__name__.__eq__,                   ["ismodule"],                   true, "inspect.ismodule.__name__ == 'ismodule'; verified with Python 3.14.3"]
    - [im_name_len,      ismodule.__name__.__len__,                  [],                             8,    "inspect.ismodule.__name__.__len__() == 8 — tied with ismethod; verified with Python 3.14.3"]
    - [im_mod_eq,        ismodule.__module__.__eq__,                 ["inspect"],                    true, "inspect.ismodule.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [im_cls_eq,        ismodule.__class__.__name__.__eq__,         ["function"],                   true, "inspect.ismodule.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ith_name_eq,      ismethod.__name__.__eq__,                   ["ismethod"],                   true, "inspect.ismethod.__name__ == 'ismethod'; verified with Python 3.14.3"]
    - [ith_name_len,     ismethod.__name__.__len__,                  [],                             8,    "inspect.ismethod.__name__.__len__() == 8 — tied with ismodule; verified with Python 3.14.3"]
    - [ith_mod_eq,       ismethod.__module__.__eq__,                 ["inspect"],                    true, "inspect.ismethod.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ith_cls_eq,       ismethod.__class__.__name__.__eq__,         ["function"],                   true, "inspect.ismethod.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect utility functions identity: getmembers, signature, getdoc
#
# getmembers.__name__ (len=10) tied longest with isfunction.
# signature.__name__ (len=9).
# getdoc.__name__ (len=6) is shortest in spec.
# All are plain Python functions in inspect.
# ---------------------------------------------------------------------------

table inspect_extra266.utility_functions_identity:
  description: "inspect.getmembers(10), signature(9), getdoc(6) identity — all plain Python functions in inspect(7); getmembers(10) tied longest with isfunction; getdoc(6) is shortest in spec; signature(9) between them; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex266u

  columns: [id, function, args, expected, description]
  rows:
    - [gm_name_eq,       getmembers.__name__.__eq__,                 ["getmembers"],                 true, "inspect.getmembers.__name__ == 'getmembers'; verified with Python 3.14.3"]
    - [gm_name_len,      getmembers.__name__.__len__,                [],                             10,   "inspect.getmembers.__name__.__len__() == 10 — tied longest with isfunction; verified with Python 3.14.3"]
    - [gm_qn_eq,         getmembers.__qualname__.__eq__,             ["getmembers"],                 true, "inspect.getmembers.__qualname__ == 'getmembers' — qualname equals name; verified with Python 3.14.3"]
    - [gm_mod_eq,        getmembers.__module__.__eq__,               ["inspect"],                    true, "inspect.getmembers.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gm_cls_eq,        getmembers.__class__.__name__.__eq__,       ["function"],                   true, "inspect.getmembers.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [sg_name_eq,       signature.__name__.__eq__,                  ["signature"],                  true, "inspect.signature.__name__ == 'signature'; verified with Python 3.14.3"]
    - [sg_name_len,      signature.__name__.__len__,                 [],                             9,    "inspect.signature.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [sg_qn_eq,         signature.__qualname__.__eq__,              ["signature"],                  true, "inspect.signature.__qualname__ == 'signature' — qualname equals name; verified with Python 3.14.3"]
    - [sg_mod_eq,        signature.__module__.__eq__,                ["inspect"],                    true, "inspect.signature.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [sg_cls_eq,        signature.__class__.__name__.__eq__,        ["function"],                   true, "inspect.signature.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [gd_name_eq,       getdoc.__name__.__eq__,                     ["getdoc"],                     true, "inspect.getdoc.__name__ == 'getdoc'; verified with Python 3.14.3"]
    - [gd_name_len,      getdoc.__name__.__len__,                    [],                             6,    "inspect.getdoc.__name__.__len__() == 6 — shortest name in spec; verified with Python 3.14.3"]
    - [gd_qn_eq,         getdoc.__qualname__.__eq__,                 ["getdoc"],                     true, "inspect.getdoc.__qualname__ == 'getdoc' — qualname equals name; verified with Python 3.14.3"]
    - [gd_mod_eq,        getdoc.__module__.__eq__,                   ["inspect"],                    true, "inspect.getdoc.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gd_cls_eq,        getdoc.__class__.__name__.__eq__,           ["function"],                   true, "inspect.getdoc.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra266
# ---------------------------------------------------------------------------

invariant inspect_extra266.all_functions_share_module:
  description: "inspect.isfunction.__module__ == 'inspect' — all inspect functions in this spec share __module__ == 'inspect' (len=7); module name length (7) equals isclass name length (7)"
  category: identity
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra266.getmembers_name_len_equals_isfunction:
  description: "inspect.getmembers.__name__.__len__() == 10 — tied longest with isfunction.__name__.__len__() == 10; both are length 10"
  category: identity
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra266.getdoc_is_shortest_name:
  description: "inspect.getdoc.__name__.__len__() == 6 — shortest name in spec; shorter than isclass(7), ismodule(8), signature(9), isfunction(10)"
  category: identity
  kind: python_call_eq
  function: getdoc.__name__.__len__
  args: []
  expected: 6

invariant inspect_extra266.ismodule_name_len_equals_ismethod:
  description: "inspect.ismodule.__name__.__len__() == 8 == inspect.ismethod.__name__.__len__() — ismodule and ismethod names are both length 8"
  category: identity
  kind: python_call_eq
  function: ismodule.__name__.__len__
  args: []
  expected: 8

invariant inspect_extra266.signature_class_is_function:
  description: "inspect.signature.__class__.__name__ == 'function' — signature is a plain Python function, not a class; all inspect helpers in this spec are plain Python functions"
  category: identity
  kind: python_call_eq
  function: signature.__class__.__name__.__eq__
  args: ["function"]
  expected: true
