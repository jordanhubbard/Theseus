spec: hashlib_extra1711
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "Theme: __init__ protocol — which stdlib types define __init__ in their own __dict__."
    - "Wave 561, suffix _extra1711. Cross-checks __init__ vs __new__ (contrast with wave _extra1666 which covered __new__)."
    - "hashlib._hashlib.HASH and hashlib._hashlib.HASHXOF are C extension types."
    - "'__init__' in hashlib._hashlib.HASH.__dict__ — True: HASH defines C-level tp_init accepting name and data parameters."
    - "'__init__' in hashlib._hashlib.HASHXOF.__dict__ — True: HASHXOF also defines C-level tp_init."
    - "hashlib.md5, hashlib.sha256, etc. are module-level callable objects (builtin_function_or_method), not bare classes."
    - "Hash constructors accept optional initial data: hashlib.md5(b'hello') is equivalent to md5(); obj.update(b'hello')."
    - "hashlib.md5(b'hello world').hexdigest() == '3e25960a79dbc69b674cd4ec67a72c62' — widely cited reference vector."
    - "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb924…' — FIPS 180-4 empty-string vector."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names. Hash construction with valid algorithms never raises."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; module-level callables are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Table 1: hash_type_init_dict
# Probe whether the C extension HASH and HASHXOF types expose __init__ and __new__
# in their Python-visible __dict__.  Contrast with wave _extra1666 (__new__ theme).
# ---------------------------------------------------------------------------

table hashlib_extra1711.hash_type_init_dict:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: "hl1711"

  columns: [id, function, args, expected]
  rows:
    - ["hl1711_HASH_has_init",         _hashlib.HASH.__dict__.__contains__,    ["__init__"],  true]
    - ["hl1711_HASH_has_new",          _hashlib.HASH.__dict__.__contains__,    ["__new__"],   false]
    - ["hl1711_HASHXOF_has_init",      _hashlib.HASHXOF.__dict__.__contains__, ["__init__"],  true]
    - ["hl1711_HASHXOF_has_new",       _hashlib.HASHXOF.__dict__.__contains__, ["__new__"],   false]
    - ["hl1711_HASH_class_name",       _hashlib.HASH.__name__.__eq__,          ["HASH"],      true]
    - ["hl1711_HASHXOF_class_name",    _hashlib.HASHXOF.__name__.__eq__,       ["HASHXOF"],   true]
    - ["hl1711_HASH_module",           _hashlib.HASH.__module__.__eq__,        ["_hashlib"],  true]
    - ["hl1711_HASHXOF_module",        _hashlib.HASHXOF.__module__.__eq__,     ["_hashlib"],  true]
    - ["hl1711_HASH_has_hexdigest",    _hashlib.HASH.__dict__.__contains__,    ["hexdigest"], true]
    - ["hl1711_HASH_has_digest",       _hashlib.HASH.__dict__.__contains__,    ["digest"],    true]
    - ["hl1711_HASH_has_update",       _hashlib.HASH.__dict__.__contains__,    ["update"],    true]
    - ["hl1711_HASH_has_copy",         _hashlib.HASH.__dict__.__contains__,    ["copy"],      true]
    - ["hl1711_HASHXOF_has_hexdigest", _hashlib.HASHXOF.__dict__.__contains__, ["hexdigest"], true]
    - ["hl1711_HASH_bases_0",          _hashlib.HASH.__bases__.__getitem__,    [0],           "object"]

# ---------------------------------------------------------------------------
# Table 2: hash_constructor_callable_checks
# Verify that module-level hash constructors are callable builtin functions.
# These are not classes, so their __dict__ is not the relevant scope for __init__.
# ---------------------------------------------------------------------------

table hashlib_extra1711.hash_constructor_callable_checks:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: "hl1711"

  columns: [id, function, args, expected]
  rows:
    - ["hl1711_md5_callable_type",    md5.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - ["hl1711_sha256_callable_type", sha256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - ["hl1711_sha1_callable_type",   sha1.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - ["hl1711_sha512_callable_type", sha512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - ["hl1711_new_callable_type",    new.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - ["hl1711_md5_name_is_str",      md5.__name__.__class__.__name__.__eq__,    ["str"], true]
    - ["hl1711_sha256_name_is_str",   sha256.__name__.__class__.__name__.__eq__, ["str"], true]
    - ["hl1711_sha1_name_is_str",     sha1.__name__.__class__.__name__.__eq__,   ["str"], true]
    - ["hl1711_sha512_name_is_str",   sha512.__name__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Table 3: known_digests
# Invariant hexdigest values and digest_size checks.
# All values verified against Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table hashlib_extra1711.known_digests:
  kind: python_call_eq
  category: known_vector
  id_prefix: "hl1711"

  columns: [id, function, args, method, method_args, expected]
  rows:
    - ["hl1711_md5_helloworld",   md5,    ["hello world"], hexdigest, [], "3e25960a79dbc69b674cd4ec67a72c62"]
    - ["hl1711_md5_empty",        md5,    [""],             hexdigest, [], "d41d8cd98f00b204e9800998ecf8427e"]
    - ["hl1711_md5_hexlen",       md5,    [""],             hexdigest.__len__, [], 32]
    - ["hl1711_sha256_empty",     sha256, [""],             hexdigest, [], "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
    - ["hl1711_sha256_hexlen",    sha256, [""],             hexdigest.__len__, [], 64]
    - ["hl1711_sha1_empty",       sha1,   [""],             hexdigest, [], "da39a3ee5e6b4b0d3255bfef95601890afd80709"]
    - ["hl1711_sha1_hexlen",      sha1,   [""],             hexdigest.__len__, [], 40]
    - ["hl1711_sha512_hexlen",    sha512, [""],             hexdigest.__len__, [], 128]
    - ["hl1711_md5_name_obj",     md5,    [""],             name.__eq__, ["md5"],    true]
    - ["hl1711_sha256_name_obj",  sha256, [""],             name.__eq__, ["sha256"], true]
    - ["hl1711_sha1_name_obj",    sha1,   [""],             name.__eq__, ["sha1"],   true]
    - ["hl1711_sha512_name_obj",  sha512, [""],             name.__eq__, ["sha512"], true]
    - ["hl1711_md5_digest_size",  md5,    [""],             digest_size.__eq__, [16], true]
    - ["hl1711_sha256_dsz",       sha256, [""],             digest_size.__eq__, [32], true]
    - ["hl1711_sha1_dsz",         sha1,   [""],             digest_size.__eq__, [20], true]
    - ["hl1711_sha512_dsz",       sha512, [""],             digest_size.__eq__, [64], true]
    - ["hl1711_md5_obj_class",    md5,    [""],             __class__.__name__.__eq__, ["HASH"], true]
    - ["hl1711_sha256_obj_class", sha256, [""],             __class__.__name__.__eq__, ["HASH"], true]
    - ["hl1711_sha1_obj_class",   sha1,   [""],             __class__.__name__.__eq__, ["HASH"], true]
    - ["hl1711_sha512_obj_class", sha512, [""],             __class__.__name__.__eq__, ["HASH"], true]
