spec: concurrent_futures_extra1441
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__ and __instancecheck__ checks for concurrent.futures classes."
    - "concurrent.futures.Future, Executor, ThreadPoolExecutor, and ProcessPoolExecutor all use plain 'type' as metaclass (not ABCMeta)."
    - "Therefore __subclasshook__ is inherited; its __class__.__name__ is 'builtin_function_or_method'."
    - "__instancecheck__ is inherited from 'type'; its __class__.__name__ is 'builtin_function_or_method'."
    - "None of the concurrent.futures classes define __subclasshook__ or __instancecheck__ in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1441.subclasshook_class_name:
  description: "concurrent.futures class __subclasshook__.__class__.__name__ identity — all classes use plain 'type' as metaclass so __subclasshook__ is inherited and has __class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: cf1441sh
  columns: [id, function, args, expected]
  rows:
    - [cf1441sh001, concurrent.futures.Future.__subclasshook__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [cf1441sh002, concurrent.futures.Executor.__subclasshook__.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - [cf1441sh003, concurrent.futures.ThreadPoolExecutor.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [cf1441sh004, concurrent.futures.ProcessPoolExecutor.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [cf1441sh005, concurrent.futures.Future.__subclasshook__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [cf1441sh006, concurrent.futures.Executor.__subclasshook__.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]

table concurrent_futures_extra1441.subclasshook_not_in_dict:
  description: "concurrent.futures class __subclasshook__ absence from own __dict__ — none define it in their own __dict__; all inherit it; __dict__.__contains__('__subclasshook__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: subclasshook_dict_membership
  id_prefix: cf1441sd
  columns: [id, function, args, expected]
  rows:
    - [cf1441sd001, concurrent.futures.Future.__dict__.__contains__,             ["__subclasshook__"], false]
    - [cf1441sd002, concurrent.futures.Executor.__dict__.__contains__,           ["__subclasshook__"], false]
    - [cf1441sd003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__subclasshook__"], false]
    - [cf1441sd004, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__subclasshook__"], false]
    - [cf1441sd005, concurrent.futures.Future.__dict__.__contains__,             ["__instancecheck__"], false]
    - [cf1441sd006, concurrent.futures.Executor.__dict__.__contains__,           ["__instancecheck__"], false]

