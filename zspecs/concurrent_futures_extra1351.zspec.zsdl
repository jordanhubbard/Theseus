spec: concurrent_futures_extra1351
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Launching parallel tasks"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "concurrent.futures.Future defines __weakref__ and __dict__ in its own __dict__ (it is a top-level class)."
    - "concurrent.futures.Executor defines __weakref__ and __dict__ in its own __dict__ (abstract base class)."
    - "ThreadPoolExecutor and ProcessPoolExecutor do not define __slots__, __weakref__, or __dict__ directly (subclasses of Executor)."
    - "BrokenExecutor defines __weakref__ in its own __dict__ but not __dict__ itself (it is a subclass of RuntimeError)."
    - "None of the concurrent.futures classes define __slots__: all use standard instance dict memory layout."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1351.Future_slots_weakref_dict:
  description: "concurrent.futures.Future __slots__, __weakref__, and __dict__ checks: Future defines __weakref__ and __dict__ as a top-level class"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: cf1351fu
  columns: [id, function, args, expected]
  rows:
    - [cf1351fu001, concurrent.futures.Future.__dict__.__contains__, ["__slots__"],   false]
    - [cf1351fu002, concurrent.futures.Future.__dict__.__contains__, ["__weakref__"], true]
    - [cf1351fu003, concurrent.futures.Future.__dict__.__contains__, ["__dict__"],    true]
    - [cf1351fu004, concurrent.futures.Executor.__dict__.__contains__, ["__slots__"],   false]
    - [cf1351fu005, concurrent.futures.Executor.__dict__.__contains__, ["__weakref__"], true]
    - [cf1351fu006, concurrent.futures.Executor.__dict__.__contains__, ["__dict__"],    true]

table concurrent_futures_extra1351.ThreadPool_ProcessPool_slots_weakref_dict:
  description: "ThreadPoolExecutor and ProcessPoolExecutor do not define __slots__, __weakref__, or __dict__ (subclasses of Executor)"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: cf1351tp
  columns: [id, function, args, expected]
  rows:
    - [cf1351tp001, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__slots__"],   false]
    - [cf1351tp002, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__weakref__"], false]
    - [cf1351tp003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__dict__"],    false]
    - [cf1351tp004, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__slots__"],   false]
    - [cf1351tp005, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__weakref__"], false]
    - [cf1351tp006, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__dict__"],    false]

table concurrent_futures_extra1351.BrokenExecutor_slots_weakref_dict:
  description: "concurrent.futures.BrokenExecutor defines __weakref__ but not __slots__ or __dict__; InvalidStateError defines none of these"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: cf1351be
  columns: [id, function, args, expected]
  rows:
    - [cf1351be001, concurrent.futures.BrokenExecutor.__dict__.__contains__,    ["__slots__"],   false]
    - [cf1351be002, concurrent.futures.BrokenExecutor.__dict__.__contains__,    ["__weakref__"], true]
    - [cf1351be003, concurrent.futures.BrokenExecutor.__dict__.__contains__,    ["__dict__"],    false]
    - [cf1351be004, concurrent.futures.InvalidStateError.__dict__.__contains__,  ["__slots__"],   false]
    - [cf1351be005, concurrent.futures.InvalidStateError.__dict__.__contains__,  ["__weakref__"], false]
    - [cf1351be006, concurrent.futures.InvalidStateError.__dict__.__contains__,  ["__dict__"],    false]
