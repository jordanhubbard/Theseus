spec: io3496
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (io3496): __aenter__, __aexit__, __await__ dict-presence checks for io/pathlib/re/decimal types."
    - "All values False — these types are synchronous and do not implement the async context manager or awaitable protocols."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "No io class defines __aenter__ in its own __dict__: io stream classes are synchronous I/O abstractions and do not implement the async context manager protocol."
    - "No io class defines __aexit__ in its own __dict__: io stream classes do not implement the async context manager exit protocol."
    - "No io class defines __await__ in its own __dict__: io stream classes are not awaitable objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No io subclass defines __aenter__ in its own __dict__; all false.
# io stream classes are synchronous I/O abstractions and do not implement
# the async context manager protocol.
# ---------------------------------------------------------------------------

table io3496.aenter:
  description: "io types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
