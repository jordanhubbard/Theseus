spec: csv_extra2
version: ">=3.2"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "Python csv documentation — https://docs.python.org/3/library/csv.html"
    - "Test vectors verified by running Python 3.12 csv module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "csv.zspec.zsdl — covers reader parsing, QUOTE_* constant values, excel dialect properties, field_size_limit, and Dialect/excel/excel_tab __name__"
    - "csv_extra.zspec.zsdl — covers DictReader, DictWriter, unix_dialect name/properties, excel_tab lineterminator/quoting, excel/__excel_tab __bases__"
    - "_csv.zspec.zsdl — covers _csv C-extension Dialect/__name__, Error, reader/writer names and module membership, QUOTE_* constants"
  notes:
    - "This spec covers __name__ and __module__ for reader, writer, DictReader, DictWriter, Dialect, Sniffer, Error."
    - "csv.Dialect.__module__ == '_csv' — the abstract Dialect class is defined in the C extension _csv, not in the csv Python module."
    - "csv.list_dialects() returns a list of registered dialect name strings."
    - "The 'excel' dialect is always registered; it appears in list_dialects()."
    - "csv.register_dialect.__name__ == 'register_dialect' — it is a C extension function."
    - "csv.list_dialects.__name__ == 'list_dialects' — it is a C extension function."
    - "csv.reader.__module__ == '_csv' — reader type is implemented in the C extension."
    - "csv.writer.__module__ == '_csv' — writer type is implemented in the C extension."
    - "csv.Error.__name__ == 'Error' — the exception class for csv-related errors."
    - "csv.Error.__module__ == '_csv' — Error is also in the C extension."
    - "csv.Sniffer.__module__ == 'csv' — Sniffer is a pure-Python class defined in csv.py."
    - "QUOTE_MINIMAL==0, QUOTE_ALL==1, QUOTE_NONNUMERIC==2, QUOTE_NONE==3 (pinned integer values)."
    - "All expected values verified by running Python 3.12 csv module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# csv.Dialect — class name and module membership (defined in the C extension _csv)
# ---------------------------------------------------------------------------

invariant csv_extra2.Dialect.class_name:
  description: "csv.Dialect.__name__ == 'Dialect'"
  category: classnames
  kind: python_call_eq
  function: Dialect.__name__.__eq__
  args: ["Dialect"]
  expected: true

invariant csv_extra2.Dialect.module:
  description: "csv.Dialect.__module__ == '_csv' — Dialect is defined in the C extension"
  category: classnames
  kind: python_call_eq
  function: Dialect.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Error — class name and module
# ---------------------------------------------------------------------------

invariant csv_extra2.Error.class_name:
  description: "csv.Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant csv_extra2.Error.module:
  description: "csv.Error.__module__ == '_csv' — Error is defined in the C extension"
  category: classnames
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Sniffer — class name and module
# ---------------------------------------------------------------------------

invariant csv_extra2.Sniffer.class_name:
  description: "csv.Sniffer.__name__ == 'Sniffer'"
  category: classnames
  kind: python_call_eq
  function: Sniffer.__name__.__eq__
  args: ["Sniffer"]
  expected: true

invariant csv_extra2.Sniffer.module:
  description: "csv.Sniffer.__module__ == 'csv' — Sniffer is a pure-Python class defined in csv.py"
  category: classnames
  kind: python_call_eq
  function: Sniffer.__module__.__eq__
  args: ["csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.reader / csv.writer — __module__ checks
# ---------------------------------------------------------------------------

invariant csv_extra2.reader.module:
  description: "csv.reader.__module__ == '_csv' — reader is implemented in the C extension"
  category: classnames
  kind: python_call_eq
  function: reader.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra2.writer.module:
  description: "csv.writer.__module__ == '_csv' — writer is implemented in the C extension"
  category: classnames
  kind: python_call_eq
  function: writer.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.DictReader and csv.DictWriter — __module__ checks
# ---------------------------------------------------------------------------

invariant csv_extra2.DictReader.module:
  description: "csv.DictReader.__module__ == 'csv'"
  category: classnames
  kind: python_call_eq
  function: DictReader.__module__.__eq__
  args: ["csv"]
  expected: true

invariant csv_extra2.DictWriter.module:
  description: "csv.DictWriter.__module__ == 'csv'"
  category: classnames
  kind: python_call_eq
  function: DictWriter.__module__.__eq__
  args: ["csv"]
  expected: true

# ---------------------------------------------------------------------------
# register_dialect and list_dialects — __name__ checks
# ---------------------------------------------------------------------------

invariant csv_extra2.register_dialect.function_name:
  description: "csv.register_dialect.__name__ == 'register_dialect'"
  category: function_names
  kind: python_call_eq
  function: register_dialect.__name__.__eq__
  args: ["register_dialect"]
  expected: true

invariant csv_extra2.list_dialects.function_name:
  description: "csv.list_dialects.__name__ == 'list_dialects'"
  category: function_names
  kind: python_call_eq
  function: list_dialects.__name__.__eq__
  args: ["list_dialects"]
  expected: true

# ---------------------------------------------------------------------------
# list_dialects() — returns a list; 'excel' is always registered
# ---------------------------------------------------------------------------

invariant csv_extra2.list_dialects.returns_list:
  description: "csv.list_dialects().__class__.__name__ == 'list'"
  category: list_dialects
  kind: python_call_eq
  function: list_dialects
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant csv_extra2.list_dialects.contains_excel:
  description: "'excel' in csv.list_dialects() — excel dialect is always registered"
  category: list_dialects
  kind: python_call_eq
  function: list_dialects
  args: []
  method: __contains__
  method_args: ["excel"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_* constants — pin exact integer values
# ---------------------------------------------------------------------------

table csv_extra2.quote_values:
  kind: python_call_eq
  category: constants
  id_prefix: qval

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_MINIMAL,    QUOTE_MINIMAL.__eq__,    [0], true]
    - [QUOTE_ALL,        QUOTE_ALL.__eq__,        [1], true]
    - [QUOTE_NONNUMERIC, QUOTE_NONNUMERIC.__eq__,  [2], true]
    - [QUOTE_NONE,       QUOTE_NONE.__eq__,       [3], true]

# ---------------------------------------------------------------------------
# QUOTE_* constants — class type is int
# ---------------------------------------------------------------------------

table csv_extra2.quote_class_types:
  kind: python_call_eq
  category: constants
  id_prefix: qtype

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_ALL_type,         QUOTE_ALL.__class__.__name__.__eq__,         ["int"], true]
    - [QUOTE_MINIMAL_type,     QUOTE_MINIMAL.__class__.__name__.__eq__,     ["int"], true]
    - [QUOTE_NONNUMERIC_type,  QUOTE_NONNUMERIC.__class__.__name__.__eq__,  ["int"], true]
    - [QUOTE_NONE_type,        QUOTE_NONE.__class__.__name__.__eq__,        ["int"], true]
