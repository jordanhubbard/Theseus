spec: theseus_cprofile_cr
version: ">=3.0"
backend: python_cleanroom(theseus_cprofile_cr)
blocks: cProfile

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
  not_derived_from:
    - "CPython source: Lib/cProfile.py"
  notes:
    - "Clean-room cProfile module. Do NOT import cProfile."

error_model: python_exceptions

invariant theseus_cprofile_cr.cprofile2_profile:
  description: "Profile class can be instantiated"
  category: behavior
  kind: python_call_eq
  function: cprofile2_profile
  args: []
  expected: true

invariant theseus_cprofile_cr.cprofile2_run:
  description: "run() function executes a statement and profiles it"
  category: behavior
  kind: python_call_eq
  function: cprofile2_run
  args: []
  expected: true

invariant theseus_cprofile_cr.cprofile2_runctx:
  description: "runctx() function profiles code in a given context"
  category: behavior
  kind: python_call_eq
  function: cprofile2_runctx
  args: []
  expected: true
