spec: theseus_pstats_cr
version: ">=3.9"
backend: python_cleanroom(theseus_pstats_cr)
blocks: pstats

docs: https://docs.python.org/3/library/profile.html#the-stats-class

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
  not_derived_from:
    - "CPython source: Lib/pstats.py"
  notes:
    - "Clean-room pstats module. Do NOT import pstats."

error_model: python_exceptions

invariant theseus_pstats_cr.pstats2_sortkey:
  description: "SortKey enum exists with CALLS member"
  category: behavior
  kind: python_call_eq
  function: pstats2_sortkey
  args: []
  expected: true

invariant theseus_pstats_cr.pstats2_stats_class:
  description: "Stats class is present"
  category: behavior
  kind: python_call_eq
  function: pstats2_stats_class
  args: []
  expected: true

invariant theseus_pstats_cr.pstats2_functionprofile:
  description: "FunctionProfile and StatsProfile dataclasses exist"
  category: behavior
  kind: python_call_eq
  function: pstats2_functionprofile
  args: []
  expected: true
