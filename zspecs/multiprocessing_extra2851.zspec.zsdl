spec: mp2851
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [multiprocessing source, Python docs, https://docs.python.org/3/library/multiprocessing.html]
  not_derived_from: [any external dataset]
  notes: [Wave 637 theme — __rlshift__/__rrshift__/__rpow__ dict-presence checks for multiprocessing types. Process/Pool/AsyncResult (ApplyResult in 3.14)/MapResult/SyncManager and proxy types for Queue/Value/Array/Lock/RLock/Event/Semaphore are process-management primitives not numeric types — none define reflected shift or power operator dunders. multiprocessing.pool.AsyncResult.__name__ is ApplyResult on Python 3.14. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table mp2851.rlshift:
