spec: array_without
version: ">=0.0.2"
backend: node(array-without)

docs: https://www.npmjs.com/package/array-without

provenance:
  derived_from:
    - "array-without README — https://www.npmjs.com/package/array-without"
    - "Test vectors verified with array-without via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-without source"
  notes:
    - "array-without is an npm package. Install: npm install array-without"
    - "Returns a new array with specified values removed."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array with the specified values excluded."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_without.without:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: awout

  columns: [id, args, expected]
  rows:
    - [basic,   [[1, 2, 3, 4], 2, 4],   [1, 3]]
    - [single,  [[5, 6, 7], 6],          [5, 7]]
    - [none,    [[1, 2, 3], 9],          [1, 2, 3]]
