spec: symtable
version: ">=3.0"
backend: python_module(symtable)

docs: https://docs.python.org/3/library/symtable.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/symtable.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from: []
  notes:
    - "symtable.symtable(code, filename, compile_type) wraps the CPython compiler's symbol-table pass."
    - "Calling symtable('x = 1', '<string>', 'exec') returns a SymbolTable whose concrete class is named 'Module'."
    - "Function and Class are subclasses of SymbolTable; Symbol is a separate class for individual name entries."
    - "Method names are checked via unbound method objects on the class."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Raises SyntaxError for invalid source; raises TypeError for wrong argument types."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Module-level function name
# ---------------------------------------------------------------------------

invariant symtable.symtable.function_name:
  description: "symtable.symtable.__name__ == 'symtable'"
  category: functions
  kind: python_call_eq
  function: symtable.__name__.__eq__
  args: ["symtable"]
  expected: true

# ---------------------------------------------------------------------------
# Class identity
# ---------------------------------------------------------------------------

invariant symtable.SymbolTable.class_name:
  description: "symtable.SymbolTable.__name__ == 'SymbolTable'"
  category: classes
  kind: python_call_eq
  function: SymbolTable.__name__.__eq__
  args: ["SymbolTable"]
  expected: true

invariant symtable.SymbolTable.class_module:
  description: "symtable.SymbolTable.__module__ == 'symtable'"
  category: classes
  kind: python_call_eq
  function: SymbolTable.__module__.__eq__
  args: ["symtable"]
  expected: true

invariant symtable.Function.class_name:
  description: "symtable.Function.__name__ == 'Function'"
  category: classes
  kind: python_call_eq
  function: Function.__name__.__eq__
  args: ["Function"]
  expected: true

invariant symtable.Class.class_name:
  description: "symtable.Class.__name__ == 'Class'"
  category: classes
  kind: python_call_eq
  function: Class.__name__.__eq__
  args: ["Class"]
  expected: true

invariant symtable.Symbol.class_name:
  description: "symtable.Symbol.__name__ == 'Symbol'"
  category: classes
  kind: python_call_eq
  function: Symbol.__name__.__eq__
  args: ["Symbol"]
  expected: true

# ---------------------------------------------------------------------------
# SymbolTable method names
# ---------------------------------------------------------------------------

invariant symtable.SymbolTable.get_type.method_name:
  description: "symtable.SymbolTable.get_type.__name__ == 'get_type'"
  category: methods
  kind: python_call_eq
  function: SymbolTable.get_type.__name__.__eq__
  args: ["get_type"]
  expected: true

invariant symtable.SymbolTable.get_id.method_name:
  description: "symtable.SymbolTable.get_id.__name__ == 'get_id'"
  category: methods
  kind: python_call_eq
  function: SymbolTable.get_id.__name__.__eq__
  args: ["get_id"]
  expected: true

invariant symtable.SymbolTable.get_name.method_name:
  description: "symtable.SymbolTable.get_name.__name__ == 'get_name'"
  category: methods
  kind: python_call_eq
  function: SymbolTable.get_name.__name__.__eq__
  args: ["get_name"]
  expected: true

invariant symtable.SymbolTable.get_children.method_name:
  description: "symtable.SymbolTable.get_children.__name__ == 'get_children'"
  category: methods
  kind: python_call_eq
  function: SymbolTable.get_children.__name__.__eq__
  args: ["get_children"]
  expected: true

invariant symtable.SymbolTable.get_symbols.method_name:
  description: "symtable.SymbolTable.get_symbols.__name__ == 'get_symbols'"
  category: methods
  kind: python_call_eq
  function: SymbolTable.get_symbols.__name__.__eq__
  args: ["get_symbols"]
  expected: true

invariant symtable.Symbol.get_name.method_name:
  description: "symtable.Symbol.get_name.__name__ == 'get_name'"
  category: methods
  kind: python_call_eq
  function: Symbol.get_name.__name__.__eq__
  args: ["get_name"]
  expected: true

invariant symtable.Symbol.is_global.method_name:
  description: "symtable.Symbol.is_global.__name__ == 'is_global'"
  category: methods
  kind: python_call_eq
  function: Symbol.is_global.__name__.__eq__
  args: ["is_global"]
  expected: true

invariant symtable.Symbol.is_local.method_name:
  description: "symtable.Symbol.is_local.__name__ == 'is_local'"
  category: methods
  kind: python_call_eq
  function: Symbol.is_local.__name__.__eq__
  args: ["is_local"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: symtable('x = 1', '<string>', 'exec') returns a Module table
# ---------------------------------------------------------------------------

invariant symtable.symtable.exec_returns_module:
  description: "symtable('x = 1', '<string>', 'exec').__class__.__name__ == 'Module'"
  category: behavior
  kind: python_call_eq
  function: symtable
  args: ["x = 1", "<string>", "exec"]
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "Module"

