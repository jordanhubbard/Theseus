spec: hashlru
version: ">=2.3.0"
backend: node(hashlru)

docs: https://github.com/dominictarr/hashlru#readme

provenance:
  derived_from:
    - "hashlru README — https://github.com/dominictarr/hashlru#readme"
    - "Test vectors verified with hashlru via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "hashlru source"
  notes:
    - "Tiny ~30 LOC LRU cache — uses two-table eviction (active + warming) for amortized O(1)."
    - "Install: npm install hashlru"
    - "v2 CJS; module export IS the factory hashlru(maxSize) → cache. Cache exposes get / set / has / remove / clear."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory + cache; never throws on string keys."
  stderr: "null"
  stickiness: "Each cache instance owns its tables; eviction is automatic at 2*maxSize total inserts."
  codes: {}

invariant hashlru.module_is_function:
  description: "Module export is a function (factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant hashlru.module_arity:
  description: "Factory takes 1 arg (maxSize)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant hashlru.factory_returns_get:
  description: "hashlru(N).get is a function"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [10]
  chain:
    - {get: "get.constructor.name"}
  expected: "Function"

invariant hashlru.factory_returns_set:
  description: "hashlru(N).set is a function"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [10]
  chain:
    - {get: "set.constructor.name"}
  expected: "Function"

invariant hashlru.factory_returns_has:
  description: "hashlru(N).has is a function"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [10]
  chain:
    - {get: "has.constructor.name"}
  expected: "Function"

invariant hashlru.factory_returns_remove:
  description: "hashlru(N).remove is a function"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [10]
  chain:
    - {get: "remove.constructor.name"}
  expected: "Function"

invariant hashlru.factory_returns_clear:
  description: "hashlru(N).clear is a function"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [10]
  chain:
    - {get: "clear.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:51:12Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
