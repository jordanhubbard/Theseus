spec: fast_content_type_parse
version: ">=2.0.0"
backend: node(fast-content-type-parse)

docs: https://github.com/fastify/fast-content-type-parse#readme

provenance:
  derived_from:
    - "fast-content-type-parse README — https://github.com/fastify/fast-content-type-parse#readme"
    - "RFC 7231 §3.1.1.5 — Content-Type header grammar"
    - "Test vectors verified with fast-content-type-parse via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "fast-content-type-parse source"
  notes:
    - "Faster Content-Type header parser — used by Fastify."
    - "Install: npm install fast-content-type-parse"
    - "v2 CJS; named exports parse / safeParse / defaultContentType."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "parse() throws TypeError on malformed input; safeParse() returns defaultContentType."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant fast_content_type_parse.parse_simple:
  description: "parse('text/html').type is 'text/html'"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["text/html"]
  chain:
    - {get: type}
  expected: "text/html"

invariant fast_content_type_parse.parse_with_charset:
  description: "parse('text/html; charset=utf-8').parameters.charset is 'utf-8'"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["text/html; charset=utf-8"]
  chain:
    - {get: "parameters.charset"}
  expected: "utf-8"

invariant fast_content_type_parse.parse_application_json:
  description: "parse('application/json').type"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["application/json"]
  chain:
    - {get: type}
  expected: "application/json"

invariant fast_content_type_parse.parse_returns_parameters_object:
  description: "Returned object always has a .parameters key"
  category: shape
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["text/plain"]
  chain:
    - {method: hasOwnProperty, args: ["parameters"]}
  expected: true

invariant fast_content_type_parse.safeParse_returns_empty_on_invalid:
  description: "safeParse on invalid input returns the defaultContentType (type='' sentinel)"
  category: safeParse
  kind: node_chain_eq
  entry: named
  function: safeParse
  entry_args: ["not a content type !!!"]
  chain:
    - {get: type}
  expected: ""

invariant fast_content_type_parse.defaultContentType_empty_type:
  description: "defaultContentType.type is '' (sentinel for 'no successful parse')"
  category: defaults
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "defaultContentType.type"}
  expected: ""

invariant fast_content_type_parse.parse_multiple_params:
  description: "Multiple parameters parsed into the parameters object"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["multipart/form-data; boundary=----WebKitFormBoundary; charset=utf-8"]
  chain:
    - {get: "parameters.boundary"}
  expected: "----WebKitFormBoundary"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:47:52Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
