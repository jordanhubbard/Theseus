spec: statistics_extra25
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra24.zspec.zsdl."
    - "Prior specs covered: mean/median/mode/stdev/variance/pstdev/pvariance, StatisticsError.__name__/__module__/__bases__[0].__name__, NormalDist.__name__/__module__/__qualname__/__bases__[0].__name__, NormalDist.__init__.__name__, NormalDist(0,1) mean/stdev/variance, fmean/geometric_mean/harmonic_mean/median_low/median_high/median_grouped/__name__, statistics.__all__ type/length."
    - "This spec covers: statistics.mean/__qualname__, statistics.median/__qualname__, statistics.mode/__qualname__, statistics.stdev/__qualname__, statistics.variance/__qualname__, statistics.fmean/__qualname__, statistics.geometric_mean/__qualname__, statistics.harmonic_mean/__qualname__, statistics.mean/__module__.__len__(), statistics.median/__module__.__len__(), statistics.stdev/__module__.__len__(), statistics.NormalDist/__module__.__len__()."
    - "All eight module-level functions are top-level; their __qualname__ equals their __name__."
    - "All module-level functions and NormalDist have __module__ == 'statistics' (10 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__ values
#
# No prior spec records __qualname__ for mean, median, mode, stdev, variance,
# fmean, geometric_mean, or harmonic_mean.
# All are top-level functions; their __qualname__ equals their __name__.
# ---------------------------------------------------------------------------

table statistics_extra25.function_qualnames:
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [mean,          mean.__qualname__.__eq__,          ["mean"],          true, "statistics.mean.__qualname__ == 'mean'"]
    - [median,        median.__qualname__.__eq__,        ["median"],        true, "statistics.median.__qualname__ == 'median'"]
    - [mode,          mode.__qualname__.__eq__,          ["mode"],          true, "statistics.mode.__qualname__ == 'mode'"]
    - [stdev,         stdev.__qualname__.__eq__,         ["stdev"],         true, "statistics.stdev.__qualname__ == 'stdev'"]
    - [variance,      variance.__qualname__.__eq__,      ["variance"],      true, "statistics.variance.__qualname__ == 'variance'"]
    - [fmean,         fmean.__qualname__.__eq__,         ["fmean"],         true, "statistics.fmean.__qualname__ == 'fmean'"]
    - [geometric_mean, geometric_mean.__qualname__.__eq__, ["geometric_mean"], true, "statistics.geometric_mean.__qualname__ == 'geometric_mean'"]
    - [harmonic_mean, harmonic_mean.__qualname__.__eq__, ["harmonic_mean"], true, "statistics.harmonic_mean.__qualname__ == 'harmonic_mean'"]

# ---------------------------------------------------------------------------
# Function __qualname__ length invariants
#
# Each qualname equals the function name string; lengths follow directly.
# ---------------------------------------------------------------------------

invariant statistics_extra25.mean.qualname_len:
  description: "len(statistics.mean.__qualname__) == 4 — 'mean' is 4 chars"
  category: function_identity
  kind: python_call_eq
  function: mean.__qualname__.__len__
  args: []
  expected: 4

invariant statistics_extra25.median.qualname_len:
  description: "len(statistics.median.__qualname__) == 6 — 'median' is 6 chars"
  category: function_identity
  kind: python_call_eq
  function: median.__qualname__.__len__
  args: []
  expected: 6

invariant statistics_extra25.mode.qualname_len:
  description: "len(statistics.mode.__qualname__) == 4 — 'mode' is 4 chars"
  category: function_identity
  kind: python_call_eq
  function: mode.__qualname__.__len__
  args: []
  expected: 4

invariant statistics_extra25.stdev.qualname_len:
  description: "len(statistics.stdev.__qualname__) == 5 — 'stdev' is 5 chars"
  category: function_identity
  kind: python_call_eq
  function: stdev.__qualname__.__len__
  args: []
  expected: 5

invariant statistics_extra25.variance.qualname_len:
  description: "len(statistics.variance.__qualname__) == 8 — 'variance' is 8 chars"
  category: function_identity
  kind: python_call_eq
  function: variance.__qualname__.__len__
  args: []
  expected: 8

invariant statistics_extra25.fmean.qualname_len:
  description: "len(statistics.fmean.__qualname__) == 5 — 'fmean' is 5 chars"
  category: function_identity
  kind: python_call_eq
  function: fmean.__qualname__.__len__
  args: []
  expected: 5

invariant statistics_extra25.geometric_mean.qualname_len:
  description: "len(statistics.geometric_mean.__qualname__) == 14 — 'geometric_mean' is 14 chars"
  category: function_identity
  kind: python_call_eq
  function: geometric_mean.__qualname__.__len__
  args: []
  expected: 14

invariant statistics_extra25.harmonic_mean.qualname_len:
  description: "len(statistics.harmonic_mean.__qualname__) == 13 — 'harmonic_mean' is 13 chars"
  category: function_identity
  kind: python_call_eq
  function: harmonic_mean.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Function __module__.__len__() for mean, median, stdev
#
# No prior spec records __module__.__len__() for any of these functions.
# All module-level statistics functions have __module__ == 'statistics' (10 chars).
# ---------------------------------------------------------------------------

invariant statistics_extra25.mean.module_len:
  description: "len(statistics.mean.__module__) == 10 — 'statistics' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: mean.__module__.__len__
  args: []
  expected: 10

invariant statistics_extra25.median.module_len:
  description: "len(statistics.median.__module__) == 10 — 'statistics' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: median.__module__.__len__
  args: []
  expected: 10

invariant statistics_extra25.stdev.module_len:
  description: "len(statistics.stdev.__module__) == 10 — 'statistics' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: stdev.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# statistics.NormalDist.__module__.__len__()
#
# No prior spec records NormalDist.__module__.__len__().
# NormalDist.__module__ == 'statistics' (10 chars), the same as all
# module-level functions — NormalDist is defined in the statistics module.
# ---------------------------------------------------------------------------

invariant statistics_extra25.NormalDist.module_len:
  description: "len(statistics.NormalDist.__module__) == 10 — 'statistics' is 10 chars"
  category: class_identity
  kind: python_call_eq
  function: NormalDist.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for all measured functions + NormalDist
#
# Consolidates the module length checks in tabular form.
# ---------------------------------------------------------------------------

table statistics_extra25.module_lengths:
  kind: python_call_eq
  category: function_identity
  id_prefix: module_len

  columns: [id, function, args, expected, description]
  rows:
    - [mean,       mean.__module__.__len__,       [], 10, "statistics.mean.__module__ has length 10"]
    - [median,     median.__module__.__len__,     [], 10, "statistics.median.__module__ has length 10"]
    - [stdev,      stdev.__module__.__len__,      [], 10, "statistics.stdev.__module__ has length 10"]
    - [NormalDist, NormalDist.__module__.__len__, [], 10, "statistics.NormalDist.__module__ has length 10"]
