spec: threading_extra44
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra43.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__.__len__()==6; Thread method __qualname__.__len__() for start/run/join/is_alive/__init__/__repr__/getName/setName; Event method __qualname__.__len__(); Condition method __qualname__.__len__(); Semaphore/__name__/__qualname__.__len__()==9; Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; local/__name__/__qualname__.__len__()==6; Lock/__name__.__len__()==4; RLock/__dict__.__class__.__name__.__len__()==12; current_thread/__name__/main_thread/__name__; threading.__all__.__len__()==28; TIMEOUT_MAX; active_count/enumerate/settrace/setprofile/stack_size __name__ lengths; Thread property __class__.__name__.__len__() for daemon/name/ident/native_id; pure-Python class __module__.__len__()==9; Barrier/__name__/__module__=='Barrier'/'threading'; Condition/__name__/__module__=='Condition'/'threading'; Semaphore/__name__/__module__=='Semaphore'/'threading'; RLock/__name__/__module__=='RLock'/'threading'; Timer/__name__/__module__=='Timer'/'threading'; Timer/__bases__[0].__name__=='Thread'; BoundedSemaphore/__name__/__module__=='BoundedSemaphore'/'threading'; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; local/__name__=='_local'; TIMEOUT_MAX==9223372036.0; excepthook/__name__=='_excepthook'; Thread/__bases__[0].__name__=='object'; Thread/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__mro__.__len__()==2; Lock/__name__=='lock'; RLock/__qualname__=='RLock'; main_thread/__name__=='main_thread'; current_thread/__name__=='current_thread'; active_count/__name__=='active_count'."
    - "This spec covers: threading.main_thread.__module__ == 'threading'; threading.current_thread.__module__ == 'threading'; threading.active_count.__module__ == 'threading'; threading.enumerate.__name__ == 'enumerate'; threading.enumerate.__module__ == 'threading'; threading.settrace.__name__ == 'settrace'; threading.setprofile.__name__ == 'setprofile'; threading.stack_size.__name__ == 'stack_size'; threading.Thread.__qualname__ == 'Thread'."
    - "Key findings: threading.main_thread.__module__, threading.current_thread.__module__, and threading.active_count.__module__ are all 'threading' (9 chars) — all three are pure-Python functions defined in Lib/threading.py; prior spec extra43 recorded their __name__ string equality but not __module__ string equality. threading.enumerate.__name__ is 'enumerate' (9 chars) and __module__ is 'threading' — note that threading.enumerate shadows the built-in enumerate; the threading module attribute is a pure-Python function that returns all live Thread objects; prior specs recorded __name__.__len__()==9 but not string equality. threading.settrace.__name__ is 'settrace' (8 chars) and threading.setprofile.__name__ is 'setprofile' (10 chars) — both are pure-Python functions in Lib/threading.py; prior specs recorded __len__() values but not string equality. threading.stack_size.__name__ is 'stack_size' (10 chars) — pure-Python wrapper in Lib/threading.py; prior specs recorded __len__()==10 but not string equality. threading.Thread.__qualname__ is 'Thread' — pure-Python class defined at module level; __qualname__ == __name__ for top-level classes; prior specs recorded Thread/__name__.__len__()==6 and __qualname__.__len__()==6 but not the string equality invariant for __qualname__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading utility function __module__ — extra44 namespace
#
# threading.main_thread.__module__, threading.current_thread.__module__, and
# threading.active_count.__module__ are all 'threading' (9 chars). All three
# are pure-Python functions defined in Lib/threading.py. Prior spec extra43
# recorded their __name__ string equality invariants (main_thread, current_thread,
# active_count) but not their __module__ string equality. These three invariants
# are new to extra44.
# ---------------------------------------------------------------------------

table threading_extra44.utility_function_modules:
  description: "threading.main_thread, current_thread, and active_count __module__ == 'threading' — all pure-Python functions in Lib/threading.py"
  kind: python_call_eq
  category: module_metadata
  id_prefix: ufmod44

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_module,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__ == 'threading' — pure-Python function in Lib/threading.py; 9-char module name; returns the MainThread singleton object"]
    - [current_thread_module,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__ == 'threading' — pure-Python function in Lib/threading.py; 9-char module name; returns the currently executing Thread object"]
    - [active_count_module,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__ == 'threading' — pure-Python function in Lib/threading.py; 9-char module name; returns count of currently alive Thread objects"]

# ---------------------------------------------------------------------------
# threading.enumerate identity — extra44 namespace
#
# threading.enumerate.__name__ is 'enumerate' (9 chars) and
# threading.enumerate.__module__ is 'threading' (9 chars). threading.enumerate
# shadows the built-in enumerate; it is a pure-Python function defined in
# Lib/threading.py that returns a list of all currently alive Thread objects.
# Prior specs recorded enumerate.__name__.__len__()==9 but not the string
# equality invariants for __name__ or __module__. Both are new to extra44.
# ---------------------------------------------------------------------------

table threading_extra44.enumerate_identity:
  description: "threading.enumerate __name__ and __module__ string equality — pure-Python function that returns all live Thread objects; shadows built-in enumerate"
  kind: python_call_eq
  category: identity
  id_prefix: enumid44

  columns: [id, function, args, expected, description]
  rows:
    - [enumerate_name,
       enumerate.__name__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__name__ == 'enumerate' — pure-Python function; 9-char name; shadows the built-in enumerate; returns list of all currently alive Thread objects"]
    - [enumerate_module,
       enumerate.__module__.__eq__,
       ["threading"],
       true,
       "threading.enumerate.__module__ == 'threading' — pure-Python function in Lib/threading.py; 9-char module name; same length as __name__ 'enumerate'"]

# ---------------------------------------------------------------------------
# threading.settrace and setprofile __name__ — extra44 namespace
#
# threading.settrace.__name__ is 'settrace' (8 chars) and
# threading.setprofile.__name__ is 'setprofile' (10 chars). Both are
# pure-Python functions in Lib/threading.py that install trace/profile hooks
# for all new threads. Prior specs recorded settrace.__name__.__len__()==8 and
# setprofile.__name__.__len__()==10 but not the string equality invariants.
# These two invariants are new to extra44.
# ---------------------------------------------------------------------------

table threading_extra44.settrace_setprofile_names:
  description: "threading.settrace and setprofile __name__ string equality — pure-Python thread hook installation functions in Lib/threading.py"
  kind: python_call_eq
  category: identity
  id_prefix: tpname44

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_name,
       settrace.__name__.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__name__ == 'settrace' — pure-Python function; 8-char name; installs a trace function for all new threads created after the call"]
    - [setprofile_name,
       setprofile.__name__.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__name__ == 'setprofile' — pure-Python function; 10-char name; installs a profile function for all new threads created after the call"]

# ---------------------------------------------------------------------------
# threading.stack_size __name__ — extra44 namespace
#
# threading.stack_size.__name__ is 'stack_size' (10 chars). stack_size is a
# pure-Python wrapper function in Lib/threading.py around the underlying
# _thread.stack_size C function. It gets or sets the thread stack size used
# when creating new threads. Prior specs recorded stack_size.__name__.__len__()==10
# but not the string equality invariant. This invariant is new to extra44.
# ---------------------------------------------------------------------------

invariant threading_extra44.stack_size_name:
  description: "threading.stack_size.__name__ == 'stack_size' — pure-Python wrapper in Lib/threading.py; 10-char name; same length as setprofile.__name__; gets or sets the thread stack size"
  category: identity
  kind: python_call_eq
  function: stack_size.__name__.__eq__
  args: ["stack_size"]
  expected: true

# ---------------------------------------------------------------------------
# threading.Thread __qualname__ — extra44 namespace
#
# threading.Thread.__qualname__ is 'Thread' (6 chars). Thread is the main
# pure-Python threading class defined at module level in Lib/threading.py.
# As a top-level class __qualname__ == __name__. Prior specs recorded
# Thread/__name__.__len__()==6 and Thread/__qualname__.__len__()==6 in length
# tables, and Thread/__name__=='Thread' was implicit in various notes, but no
# spec recorded the explicit string equality invariant for Thread.__qualname__
# in a standalone invariant block. This invariant is new to extra44.
# ---------------------------------------------------------------------------

invariant threading_extra44.Thread_qualname:
  description: "threading.Thread.__qualname__ == 'Thread' — pure-Python class defined at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing class scope); 6 chars"
  category: identity
  kind: python_call_eq
  function: Thread.__qualname__.__eq__
  args: ["Thread"]
  expected: true
