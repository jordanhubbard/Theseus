spec: dc3151
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (dc3151): __setitem__, __delitem__, __contains__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "No decimal class defines __setitem__ in its own __dict__: Decimal and Context expose attribute-based mutation, not item assignment."
    - "No decimal class defines __delitem__ in its own __dict__: decimal types do not support item deletion."
    - "No decimal class defines __contains__ in its own __dict__: decimal types do not implement membership testing."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# No decimal class defines __setitem__ in its own __dict__; all false.
# Decimal is an immutable numeric type; Context uses attribute setters, not item
# assignment; exception subclasses are standard exception types.
# ---------------------------------------------------------------------------

table dc3151.setitem:
  description: "decimal types __setitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3151

  columns: [id, function, args, expected]
  rows:
    - ["dc3151001", operator.contains, [decimal.Decimal.__dict__,          "__setitem__"], false]
    - ["dc3151002", operator.contains, [decimal.Context.__dict__,           "__setitem__"], false]
    - ["dc3151003", operator.contains, [decimal.DecimalException.__dict__,  "__setitem__"], false]
    - ["dc3151004", operator.contains, [decimal.InvalidOperation.__dict__,  "__setitem__"], false]
    - ["dc3151005", operator.contains, [decimal.Overflow.__dict__,          "__setitem__"], false]
    - ["dc3151006", operator.contains, [decimal.Underflow.__dict__,         "__setitem__"], false]

