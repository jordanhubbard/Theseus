spec: threading_extra155
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Condition class identity (__name__ 'Condition', __module__ 'threading', __bases__[0].__name__ 'object'); threading.Timer class identity (__name__ 'Timer', __module__ 'threading', __bases__[0].__name__ 'Thread' — Timer inherits from Thread not object); threading.Barrier class identity (__name__ 'Barrier', __module__ 'threading') (Wave 283)."
    - "threading.Condition.__name__ == 'Condition' — Condition is a Python class in Lib/threading.py; its __name__ is 'Condition'. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' — Condition is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer' — Timer is a Python class in Lib/threading.py; its __name__ is 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread (not object); it is a Thread subclass that calls a function after a delay. __bases__[0].__name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' — Barrier is a Python class in Lib/threading.py; its __name__ is 'Barrier'. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition class identity
#
# Wave 283 theme: threading.Condition and threading.Timer class identity.
#
# threading.Condition.__name__ == 'Condition'
# threading.Condition.__module__ == 'threading'
# threading.Condition.__bases__[0].__name__ == 'object'
#
# Condition is a Python class in Lib/threading.py implementing a monitor-style
# synchronization primitive. It wraps a Lock or RLock and allows threads to
# wait for a condition to become true. It inherits directly from object.
# New to extra155.
# ---------------------------------------------------------------------------

table threading_extra155.condition_class_identity:
  description: "threading.Condition: __name__ 'Condition', __module__ 'threading', __bases__[0] 'object'; monitor synchronization class identity; wave 283; new to extra155"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcondid155

  columns: [id, function, args, expected, description]
  rows:
    - [condition_name_eq,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a Python class in Lib/threading.py implementing monitor-style synchronization; threads wait for a condition to become true; its __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra155"]
    - [condition_module_eq_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra155"]
    - ["condition_bases_0_name_eq_object",
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition inherits directly from object; __bases__ is (object,) so __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra155"]
    - [condition_qualname_eq,
       "Condition.__qualname__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — Condition is defined at module scope in Lib/threading.py; its __qualname__ equals its __name__ 'Condition'; str.__eq__('Condition') returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer class identity
#
# Wave 283 theme: threading.Timer inherits from Thread, not object.
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__bases__[0].__name__ == 'Thread'
#
# Timer is a Thread subclass in Lib/threading.py that calls a function after
# a specified interval. Because it inherits from Thread (not object), its
# __bases__[0].__name__ is 'Thread' — distinguishing it from other threading
# primitives (Event, Condition, Semaphore) that inherit from object.
# New to extra155.
# ---------------------------------------------------------------------------

table threading_extra155.timer_class_identity:
  description: "threading.Timer: __name__ 'Timer', __module__ 'threading', __bases__[0] 'Thread' (Timer inherits from Thread not object); wave 283; new to extra155"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimerid155

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a Python class in Lib/threading.py that calls a function after a specified delay; it is a Thread subclass; its __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra155"]
    - [timer_module_eq_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra155"]
    - ["timer_bases_0_name_eq_Thread",
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits from Thread (not object); it is a Thread subclass that delays function execution; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra155"]
    - [timer_qualname_eq,
       "Timer.__qualname__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is defined at module scope in Lib/threading.py; its __qualname__ equals its __name__ 'Timer'; str.__eq__('Timer') returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier class identity
#
# Wave 283 theme: threading.Barrier class identity.
#
# threading.Barrier.__name__ == 'Barrier'
# threading.Barrier.__module__ == 'threading'
# threading.Barrier.__qualname__ == 'Barrier'
#
# Barrier is a Python class in Lib/threading.py implementing a reusable
# barrier synchronization primitive. Threads wait at the barrier until a
# specified number have arrived, then all proceed simultaneously.
# New to extra155.
# ---------------------------------------------------------------------------

table threading_extra155.barrier_class_identity:
  description: "threading.Barrier: __name__ 'Barrier', __module__ 'threading', __qualname__ 'Barrier'; reusable barrier sync primitive; wave 283; new to extra155"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbarririd155

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a Python class in Lib/threading.py implementing a reusable barrier; threads wait until the specified number arrive then all proceed; its __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra155"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra155"]
    - [barrier_qualname_eq,
       "Barrier.__qualname__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — Barrier is defined at module scope in Lib/threading.py; its __qualname__ equals its __name__ 'Barrier'; str.__eq__('Barrier') returns True; new to extra155"]
    - [barrier_class_eq_type,
       "Barrier.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — Barrier is a Python class; its metaclass is type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra155"]

