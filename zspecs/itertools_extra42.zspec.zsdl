spec: itertools_extra42
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra41.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all; chain/__name__/__qualname__=='chain'; chain.from_iterable/__qualname__=='chain.from_iterable'; zip_longest/__name__/__qualname__=='zip_longest'; islice/__name__/__qualname__=='islice'; accumulate/__name__/__qualname__=='accumulate'; groupby/__name__/__qualname__; compress/__name__/__qualname__; dropwhile/__name__/__qualname__; takewhile/__name__/__qualname__; starmap/__name__/__qualname__; filterfalse/__name__/__qualname__; pairwise/__name__/__qualname__=='pairwise'; batched/__name__/__qualname__=='batched'; count/__name__/__qualname__=='count'; product/__name__/__qualname__=='product'; permutations/__name__/__qualname__=='permutations'; combinations/__name__/__qualname__=='combinations'."
    - "This spec covers: itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'; itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (same as __name__); itertools.combinations_with_replacement.__name__.__len__() == 29; itertools.cycle.__name__ == 'cycle'; itertools.cycle.__qualname__ == 'cycle'; itertools.repeat.__name__ == 'repeat'; itertools.repeat.__qualname__ == 'repeat'; itertools.chain.__bases__[0].__name__ == 'object'; itertools.count.__bases__[0].__name__ == 'object'."
    - "Key findings: itertools.combinations_with_replacement.__name__ and __qualname__ are both 'combinations_with_replacement' (29 chars) — this is the longest __name__ among all itertools types by a wide margin; as a top-level C-extension type __qualname__ == __name__. itertools.cycle.__name__ and __qualname__ are both 'cycle' (5 chars) — same length as count.__name__; top-level C type. itertools.repeat.__name__ and __qualname__ are both 'repeat' (6 chars) — same length as chain.__name__ and the base class name 'object'; top-level C type. Prior specs recorded __qualname__.__len__() for combinations_with_replacement (29), cycle (5), and repeat (6) but not the string equality invariants; the __bases__[0].__name__ invariants are entirely new. itertools.chain.__bases__[0].__name__ == 'object' and itertools.count.__bases__[0].__name__ == 'object' — all itertools C-extension types inherit directly from object."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.combinations_with_replacement identity metadata — extra42 namespace
#
# itertools.combinations_with_replacement.__name__ is
# 'combinations_with_replacement' (29 chars) and __qualname__ is the same.
# This is the longest __name__ among all itertools types. As a top-level
# C-extension type in itertoolsmodule.c, __qualname__ == __name__. Prior
# specs recorded __qualname__.__len__()==29 but not the string equality
# invariants for __name__, __qualname__, or __name__.__len__(). These three
# invariants are new to the extra42 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra42.combinations_with_replacement_name:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — C-extension type; 29-char name; longest __name__ among all itertools types; r-length subsequences with repeated elements"
  category: identity
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra42.combinations_with_replacement_qualname:
  description: "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 29 chars; same as __name__"
  category: identity
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra42.combinations_with_replacement_name_len:
  description: "len(itertools.combinations_with_replacement.__name__) == 29 — 'combinations_with_replacement'; longest __name__ among all itertools types; 17 chars longer than permutations/combinations (12)"
  category: string_properties
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

# ---------------------------------------------------------------------------
# itertools.cycle and itertools.repeat identity metadata — extra42 namespace
#
# itertools.cycle.__name__ and __qualname__ are both 'cycle' (5 chars) —
# same length as count.__name__. itertools.repeat.__name__ and __qualname__
# are both 'repeat' (6 chars) — same length as chain.__name__ and 'object'.
# Both are top-level C-extension types in itertoolsmodule.c. Prior specs
# recorded __qualname__.__len__() for both (5 and 6 respectively) but not
# the string equality invariants. These four equality invariants are new.
# ---------------------------------------------------------------------------

table itertools_extra42.cycle_repeat_names:
  description: "itertools.cycle and itertools.repeat __name__ and __qualname__ string equality — both top-level C types with __qualname__ == __name__"
  kind: python_call_eq
  category: identity
  id_prefix: crname42

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_name,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__ == 'cycle' — C-extension type; 5-char name; same length as count.__name__; infinite cycle through an iterable"]
    - [cycle_qualname,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__ == 'cycle' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 5 chars; same as count.__qualname__"]
    - [repeat_name,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__ == 'repeat' — C-extension type; 6-char name; same length as chain.__name__ and 'object'; repeats a value n times or infinitely"]
    - [repeat_qualname,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__ == 'repeat' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 6 chars; same as chain.__qualname__"]

# ---------------------------------------------------------------------------
# itertools.chain and itertools.count __bases__[0].__name__ — extra42 namespace
#
# itertools.chain.__bases__[0].__name__ is 'object' (6 chars) and
# itertools.count.__bases__[0].__name__ is 'object' (6 chars). All itertools
# C-extension types inherit directly from object — their __bases__ tuple
# contains exactly one element, the built-in object type. Prior specs recorded
# __bases__[0].__name__.__len__()==6 for all itertools types (confirmed the
# length is 'object') but not the string equality invariants. These two
# equality invariants are new to the extra42 namespace.
# ---------------------------------------------------------------------------

table itertools_extra42.chain_count_bases:
  description: "itertools.chain and itertools.count __bases__[0].__name__ == 'object' — all itertools C types inherit directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ccbases42

  columns: [id, function, args, expected, description]
  rows:
    - [chain_bases_name,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; single base class; 6-char base name same length as chain.__name__"]
    - [count_bases_name,
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; single base class; same base as all itertools types"]
