spec: decimal_extra2341
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "_decimal_extra.zspec.zsdl — covers Decimal/Context class names and operations"
    - "decimal_extra1876.zspec.zsdl — covers attr_access_protocol and introspection_protocol"
  notes:
    - "Theme: __slots__ contents. decimal.Decimal and decimal.Context are C extension types."
    - "C extension types do not expose Python-level __slots__ in their __dict__."
    - "decimal.DecimalException and all its subclasses are pure Python exception classes."
    - "None of the decimal exception classes define __slots__; they rely on __dict__ per instance."
    - "DecimalException.__dict__ contains: __module__, __weakref__, __doc__."
    - "InvalidOperation, DivisionByZero, Overflow, Underflow, etc. each contain only __module__ and __doc__."
    - "All expected values verified by running Python 3.14 decimal module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# decimal C types — Decimal and Context have no Python __slots__
# ---------------------------------------------------------------------------

table decimal_extra2341.c_type_no_slots:
  kind: python_call_eq
  category: slots
  id_prefix: dc2341

  columns: [id, function, args, expected]
  rows:
    - ["dc2341001", Decimal.__dict__.__contains__, ["__slots__"], false]
    - ["dc2341002", Context.__dict__.__contains__, ["__slots__"], false]

# ---------------------------------------------------------------------------
# decimal exception hierarchy — no __slots__ in any class
# ---------------------------------------------------------------------------

table decimal_extra2341.exception_no_slots:
  kind: python_call_eq
  category: slots
  id_prefix: dc2341

  columns: [id, function, args, expected]
  rows:
    - ["dc2341003", DecimalException.__dict__.__contains__,  ["__slots__"], false]
    - ["dc2341004", InvalidOperation.__dict__.__contains__,  ["__slots__"], false]
    - ["dc2341005", DivisionByZero.__dict__.__contains__,    ["__slots__"], false]
    - ["dc2341006", Overflow.__dict__.__contains__,          ["__slots__"], false]
    - ["dc2341007", Underflow.__dict__.__contains__,         ["__slots__"], false]
    - ["dc2341008", Inexact.__dict__.__contains__,           ["__slots__"], false]
    - ["dc2341009", Rounded.__dict__.__contains__,           ["__slots__"], false]
    - ["dc2341010", Subnormal.__dict__.__contains__,         ["__slots__"], false]
    - ["dc2341011", FloatOperation.__dict__.__contains__,    ["__slots__"], false]
    - ["dc2341012", Clamped.__dict__.__contains__,           ["__slots__"], false]

# ---------------------------------------------------------------------------
# Spot-check: exception classes carry __module__ and __doc__ but not __slots__
# DecimalException also holds __weakref__ (top of the hierarchy)
# ---------------------------------------------------------------------------

table decimal_extra2341.exception_dict_members:
  kind: python_call_eq
  category: slots
  id_prefix: dc2341

  columns: [id, function, args, expected]
  rows:
    - ["dc2341013", DecimalException.__dict__.__contains__,  ["__module__"],   true]
    - ["dc2341014", DecimalException.__dict__.__contains__,  ["__weakref__"],  true]
    - ["dc2341015", DecimalException.__dict__.__contains__,  ["__doc__"],      true]
    - ["dc2341016", InvalidOperation.__dict__.__contains__,  ["__module__"],   true]
    - ["dc2341017", InvalidOperation.__dict__.__contains__,  ["__doc__"],      true]
    - ["dc2341018", DivisionByZero.__dict__.__contains__,    ["__module__"],   true]
    - ["dc2341019", DivisionByZero.__dict__.__contains__,    ["__doc__"],      true]
    - ["dc2341020", Overflow.__dict__.__contains__,          ["__module__"],   true]
    - ["dc2341021", Overflow.__dict__.__contains__,          ["__doc__"],      true]
    - ["dc2341022", Clamped.__dict__.__contains__,           ["__module__"],   true]
