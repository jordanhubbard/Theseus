spec: abc_extra35
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra34.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain __class__/__name__.__len__() tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod' (extra34), get_cache_token/__module__=='_abc' (extra34), ABC/__name__=='ABC' (extra34), ABC/__bases__[0].__name__=='object' (extra34)."
    - "This spec covers: ABCMeta.__name__=='ABCMeta'; ABCMeta.__module__=='abc'; ABCMeta.__bases__[0].__name__=='type'; ABCMeta.register.__qualname__.__len__()==16 ('ABCMeta.register'); ABCMeta.__mro__.__len__()==3; ABC.__mro__.__len__()==2; ABC.__mro__[1].__name__=='object'."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type'. ABCMeta is itself a metaclass — it is a subclass of 'type' (the root metaclass). ABCMeta.__mro__ == [ABCMeta, type, object], giving __mro__.__len__() == 3. The MRO depth of 3 (ABCMeta -> type -> object) reflects ABCMeta's position as a single-level extension of the type metaclass."
    - "abc.ABC.__mro__.__len__() == 2. ABC.__mro__ == [ABC, object], giving a depth of 2. ABC is a simple helper class that inherits directly from object with ABCMeta as its metaclass. The MRO contains only two entries: ABC itself and object."
    - "abc.ABC.__mro__[1].__name__ == 'object'. The second entry (index 1) in ABC's MRO is object — confirming ABC's single-level inheritance. ABC.__bases__[0].__name__ == 'object' was already captured in extra34; the MRO index form abc.ABC.__mro__[1].__name__ provides an equivalent but novel formulation using MRO indexing in extra35."
    - "ABCMeta.register.__qualname__ == 'ABCMeta.register' (16 chars: 'ABCMeta'(7) + '.'(1) + 'register'(8) = 16). This confirms register is defined directly on ABCMeta. Prior specs measured ABCMeta.register qualname lengths in other namespaces; extra35 establishes the integer value in this namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta identity — extra35 namespace
#
# ABCMeta is the metaclass for all abstract base classes:
#   ABCMeta.__name__   == 'ABCMeta' (7 chars)
#   ABCMeta.__module__ == 'abc'     (3 chars)
# ABCMeta is defined directly in the 'abc' module (pure Python). Its __name__ and
# __module__ are the canonical identifiers. Prior specs measured __len__() values
# for these attributes; extra35 captures the string equality checks freshly.
# ---------------------------------------------------------------------------

table abc_extra35.ABCMeta_identity:
  description: "abc.ABCMeta identity string equality in extra35 namespace — __name__ and __module__"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabcmetaid35

  columns: [id, function, args, expected, description]
  rows:
    - [name,   ABCMeta.__name__.__eq__,   ["ABCMeta"], true, "ABCMeta.__name__ == 'ABCMeta' (7 chars)"]
    - [module, ABCMeta.__module__.__eq__,  ["abc"],     true, "ABCMeta.__module__ == 'abc' (3 chars)"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class hierarchy — extra35 namespace
#
# ABCMeta's position in the Python type system:
#   ABCMeta.__bases__[0].__name__ == 'type'    (4 chars)
#   ABCMeta.__mro__.__len__()     == 3
# ABCMeta is a metaclass that extends 'type' (the root metaclass in Python).
# MRO: [ABCMeta, type, object] — three entries, as ABCMeta adds one level
# above type. ABC.__mro__.__len__() == 2 (MRO: [ABC, object]) confirms ABC
# is a simple one-level helper class. ABC.__mro__[1].__name__ == 'object'
# confirms the second (and final) MRO entry is 'object'.
# ---------------------------------------------------------------------------

table abc_extra35.class_mro_depths:
  description: "abc class MRO depths in extra35 namespace — ABCMeta(3) and ABC(2)"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmrolen35

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_mro_len, ABCMeta.__mro__.__len__, [], 3, "ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]"]
    - [ABC_mro_len,     ABC.__mro__.__len__,     [], 2, "ABC.__mro__.__len__() == 2 — MRO is [ABC, object]"]

# ---------------------------------------------------------------------------
# abc.ABCMeta base class and register method — extra35 namespace
#
# ABCMeta extends 'type' (the root metaclass):
#   ABCMeta.__bases__[0].__name__      == 'type'             (4 chars)
#   ABCMeta.register.__qualname__      == 'ABCMeta.register' (16 chars)
# ABCMeta.register.__qualname__ == 'ABCMeta.register' confirms register is
# defined directly on ABCMeta (not inherited). 16 chars = 'ABCMeta'(7) + '.'(1)
# + 'register'(8).
# ---------------------------------------------------------------------------

invariant abc_extra35.ABCMeta_bases0_name_eq:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass that directly extends 'type', the root Python metaclass"
  category: class_names
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra35.ABCMeta_register_qualname_len:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' has 16 characters: 'ABCMeta'(7) + '.'(1) + 'register'(8)"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra35.ABCMeta_mro_len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; ABCMeta adds exactly one level above the 'type' metaclass"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra35.ABC_mro_len:
  description: "abc.ABC.__mro__.__len__() == 2 — MRO is [ABC, object]; ABC is a simple one-level helper class with no intermediate base classes"
  category: class_names
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra35.ABC_mro1_name_eq:
  description: "abc.ABC.__mro__[1].__name__ == 'object' — the second MRO entry (index 1) for ABC is 'object'; ABC inherits directly from object with no intermediate classes"
  category: class_names
  kind: python_call_eq
  function: "ABC.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra35.ABCMeta_name_eq:
  description: "abc.ABCMeta.__name__ == 'ABCMeta' — the canonical name for the metaclass that enables abstract base class functionality (7 chars)"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra35.ABCMeta_module_eq:
  description: "abc.ABCMeta.__module__ == 'abc' — ABCMeta is defined in the pure-Python abc module (3 chars), in contrast to get_cache_token which lives in '_abc' (C extension)"
  category: module_names
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true
