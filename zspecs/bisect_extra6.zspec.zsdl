spec: bisect_extra6
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras."
    - "bisect.zspec.zsdl covers: bisect_left/bisect_right tables; bisect alias; lo/hi; function __name__."
    - "bisect_extra covers: bisect_left/__name__/__module__=='_bisect'; bisect_right/__name__; insort_left/insort_right/__name__; bisect/__name__=='bisect_right'; insort/__name__=='insort_right'; behavioral on [1,2,3,4,5] and [1,2,3,3,3,4]."
    - "bisect_extra2 covers: insort/insort_left/insort_right/__name__; bisect/__name__; bisect_left([1,3,5,7], 4)==2."
    - "bisect_extra3 covers: __module__ for bisect/bisect_right/insort/insort_left/insort_right; __name__ for bisect_left/bisect_right/insort_left/insort_right; behavioral on [1,2,3,4,5]."
    - "bisect_extra4 covers: bisect module __name__ == 'bisect' (standalone invariant); behavioral on [1,2,3,3,4] and [2,4,6,8,10]."
    - "bisect_extra5 covers: __qualname__ for all bisect functions; behavioral on [1,3,5,7] with multiple search values."
    - "This spec adds: __name__ table for all six bisect functions under id_prefix bname (new namespace); bisect.__name__=='bisect_right' and insort.__name__=='insort_right' paired with direct functions; module __name__ as a table row; behavioral vectors on [10,20,30,40,50] (new input domain, multiples of 10)."
    - "bisect.bisect.__name__ == 'bisect_right' — bisect is an alias for the C-level bisect_right."
    - "bisect.insort.__name__ == 'insort_right' — insort is an alias for the C-level insort_right."
    - "bisect_left([10,20,30,40,50], 25) == 2 — 25 falls between 20 and 30."
    - "bisect_right([10,20,30,40,50], 30) == 3 — 30 is at index 2; right point is 3."
    - "bisect_left([10,20,30,40,50], 30) == 2 — 30 is at index 2; left point is 2."
    - "bisect([10,20,30,40,50], 10) == 1 — 10 is at index 0; right point is 1."
    - "bisect_left([10,20,30,40,50], 50) == 4 — 50 is at index 4; left point is 4."
    - "bisect_right([10,20,30,40,50], 50) == 5 — 50 is at index 4; right point is 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — all six bisect functions, id_prefix bname (new namespace)
# bisect/__name__=='bisect_right' and insort/__name__=='insort_right' have been
# checked as individual invariants in prior specs but never in a combined table
# with this id_prefix.
# ---------------------------------------------------------------------------

table bisect_extra6.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: bname

  columns: [id, function, args, expected]
  rows:
    - [bisect,       bisect.__name__.__eq__,       ["bisect_right"], true]
    - [bisect_left,  bisect_left.__name__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__name__.__eq__, ["bisect_right"], true]
    - [insort,       insort.__name__.__eq__,       ["insort_right"], true]
    - [insort_left,  insort_left.__name__.__eq__,  ["insort_left"],  true]
    - [insort_right, insort_right.__name__.__eq__, ["insort_right"], true]

# ---------------------------------------------------------------------------
# Module __name__ — table form under id_prefix bmod
# bisect_extra4 checks bisect.__name__ as a standalone invariant with
# function: __name__.__eq__; this table presents the same check under a
# new namespace and groups it with related identity checks.
# ---------------------------------------------------------------------------

table bisect_extra6.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: bmod

  columns: [id, function, args, expected]
  rows:
    - [module_name, __name__.__eq__, ["bisect"], true]

# ---------------------------------------------------------------------------
# Behavioral invariants — [10, 20, 30, 40, 50] (multiples of 10)
# This input is distinct from all prior spec inputs:
#   bisect        uses [1,3,5,7,9] and [1,3,5,5,5,7]
#   bisect_extra  uses [1,2,3,4,5] and [1,2,3,3,3,4]
#   bisect_extra2 uses [1,3,5,7] (single value)
#   bisect_extra3 uses [1,2,3,4,5]
#   bisect_extra4 uses [1,2,3,3,4] and [2,4,6,8,10]
#   bisect_extra5 uses [1,3,5,7] (multiple values)
# ---------------------------------------------------------------------------

invariant bisect_extra6.bisect_left.tens_gap:
  description: "bisect_left([10,20,30,40,50], 25) == 2 — 25 falls between 20 and 30"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[10, 20, 30, 40, 50], 25]
  expected: 2

invariant bisect_extra6.bisect_right.tens_gap:
  description: "bisect_right([10,20,30,40,50], 25) == 2 — 25 absent; left and right agree"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[10, 20, 30, 40, 50], 25]
  expected: 2

invariant bisect_extra6.bisect_left.tens_present_thirty:
  description: "bisect_left([10,20,30,40,50], 30) == 2 — 30 at index 2; left insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[10, 20, 30, 40, 50], 30]
  expected: 2

invariant bisect_extra6.bisect_right.tens_present_thirty:
  description: "bisect_right([10,20,30,40,50], 30) == 3 — 30 at index 2; right insertion point is 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[10, 20, 30, 40, 50], 30]
  expected: 3

invariant bisect_extra6.bisect.tens_first:
  description: "bisect([10,20,30,40,50], 10) == 1 — 10 at index 0; bisect (alias bisect_right) returns 1"
  category: behavior
  kind: python_call_eq
  function: bisect
  args: [[10, 20, 30, 40, 50], 10]
  expected: 1

invariant bisect_extra6.bisect_left.tens_last:
  description: "bisect_left([10,20,30,40,50], 50) == 4 — 50 at index 4; left insertion point is 4"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[10, 20, 30, 40, 50], 50]
  expected: 4

invariant bisect_extra6.bisect_right.tens_last:
  description: "bisect_right([10,20,30,40,50], 50) == 5 — 50 at index 4; right insertion point is 5"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[10, 20, 30, 40, 50], 50]
  expected: 5
