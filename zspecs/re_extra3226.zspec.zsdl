spec: re3226
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (re3226): __radd__, __rsub__, __rmul__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic)."
    - "No re class defines __radd__ in its own __dict__: re.Pattern and re.Match are read-only match result objects; re.RegexFlag is an IntFlag subclass but reflected arithmetic is not part of the IntFlag protocol."
    - "No re class defines __rsub__ in its own __dict__: re.Pattern and re.Match do not implement reflected subtraction; re.RegexFlag is an IntFlag subclass but __rsub__ is an integer arithmetic operation not relevant to flag values."
    - "No re class defines __rmul__ in its own __dict__: same reasoning — reflected multiplication is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the reflected arithmetic methods __radd__, __rsub__, __rmul__ are not defined on IntFlag either; these are not bitwise flag operations."
    - "operator.contains(re.RegexFlag.__dict__, '__radd__') = False: not present in the class-own dict."
    - "Key finding: decimal.Decimal defines all 3 reflected operators (complete numeric type supporting right-hand arithmetic); all other classes in this wave are False."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __radd__ dict-presence — operator.contains(Cls.__dict__, '__radd__')
#
# No re class defines __radd__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but reflected arithmetic is not part of the flag protocol.
# ---------------------------------------------------------------------------

table re3226.radd:
  description: "re types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3226

  columns: [id, function, args, expected]
  rows:
    - ["re3226001", operator.contains, [re.Pattern.__dict__,   "__radd__"], false]
    - ["re3226002", operator.contains, [re.Match.__dict__,     "__radd__"], false]
    - ["re3226003", operator.contains, [re.RegexFlag.__dict__, "__radd__"], false]

# ---------------------------------------------------------------------------
