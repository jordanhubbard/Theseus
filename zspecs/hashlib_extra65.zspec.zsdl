spec: hashlib_extra65
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra64.zspec.zsdl — covers hashlib.new and file_digest __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / new.__globals__.__class__.__name__.__eq__('dict') / new.__globals__.__contains__('new') / blake2b.__doc__.__contains__('BLAKE2b') (table + invariants)."
    - "hashlib_extra63.zspec.zsdl — covers blake2b/blake2s method descriptor __qualname__.__eq__ string values for update/digest/hexdigest/copy (blake2b) and update/digest/hexdigest (blake2s)."
    - "hashlib_extra62.zspec.zsdl — covers hashlib.__spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "hashlib_extra61.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__.__eq__('str'); sha256/new/module __doc__.__class__.__qualname__.__eq__('str')."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra64; it does NOT duplicate invariants present in those files."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks."
    - "hashlib.new is a pure Python function in Lib/hashlib.py with signature new(name, *args, **kwargs). It has NO positional-default arguments — __defaults__ is None (NoneType). Despite the documentation showing data=b'' as a keyword, in Python 3.14.3 the actual function signature uses *args/**kwargs and __defaults__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest is also a pure Python function in Lib/hashlib.py with signature file_digest(fileobj, digest). It takes two required arguments and has no defaults — __defaults__ is None (NoneType). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__defaults__.__class__.__name__ == 'NoneType' — __defaults__ is None, and None.__class__.__name__ == 'NoneType'. No prior hashlib spec checks new.__defaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__ is a code object (type 'code') — the bytecode object for the pure Python function. No prior hashlib spec checks new.__code__.__class__.__name__.__eq__('code'). The code object class name is 'code'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__ == 'Return a new BLAKE2b hash object.' The string does NOT contain 'digest' (the word 'digest' does not appear in this short C extension type docstring). The docstring contains 'BLAKE2b' (already covered in hashlib_extra64), 'hash', 'new', and 'Return'. hashlib_extra64 checks blake2b.__doc__.__contains__('BLAKE2b'). This spec checks the __doc__ class identity of blake2b.__doc__ via __class__.__name__.__eq__ (wave 229 doc-content focus on a new keyword). The docstring is too short for 'digest' — use 'hash' as the content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __defaults__ class identity
#
# Wave 229 theme: __defaults__ checks for Python functions.
#
# hashlib.new(name, *args, **kwargs) and hashlib.file_digest(fileobj, digest)
# are pure Python functions in Lib/hashlib.py. Neither has positional-default
# arguments — both have __defaults__ == None (NoneType).
#
# No prior hashlib spec checks new.__defaults__.__class__.__name__ or
# file_digest.__defaults__.__class__.__name__ in any form. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra65.python_func_defaults_class_name:
  description: "hashlib.new and file_digest __defaults__.__class__.__name__.__eq__('NoneType') — both are pure Python functions with no positional-default arguments; __defaults__ is None so __class__.__name__ is 'NoneType'; no prior hashlib spec checks __defaults__.__class__.__name__ for any hashlib function; first __defaults__ class identity anchor for hashlib"
  kind: python_call_eq
  category: defaults
  id_prefix: hashlibcode65

  columns: [id, function, args, expected]
  rows:
    - [new_defaults_class_name_eq,         new.__defaults__.__class__.__name__.__eq__,         ["NoneType"], true]
    - [file_digest_defaults_class_name_eq, file_digest.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__ class identity
#
# Wave 229 theme: __code__ checks for Python functions.
#
# hashlib.new and hashlib.file_digest are pure Python functions. Both have a
# __code__ attribute that is a Python code object (type name 'code'). C
# extension builtins like pbkdf2_hmac do NOT have __code__. No prior hashlib
# spec checks new.__code__.__class__.__name__.__eq__('code') or
# file_digest.__code__.__class__.__name__.__eq__('code'). Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra65.python_func_code_class_name:
  description: "hashlib.new and file_digest __code__.__class__.__name__.__eq__('code') — both are pure Python functions with a code object; pbkdf2_hmac is a C builtin and excluded; no prior hashlib spec checks __code__.__class__.__name__.__eq__('code') for any hashlib function; first __code__ class identity anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode65

  columns: [id, function, args, expected]
  rows:
    - [new_code_class_name_eq,         new.__code__.__class__.__name__.__eq__,         ["code"], true]
    - [file_digest_code_class_name_eq, file_digest.__code__.__class__.__name__.__eq__, ["code"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b __doc__ content check — 'hash'
#
# Wave 229 theme: __doc__ content checks.
#
# hashlib.blake2b.__doc__ == 'Return a new BLAKE2b hash object.' The string
# 'hash' appears in the docstring (as part of 'hash object'). hashlib_extra64
# checks blake2b.__doc__.__contains__('BLAKE2b') (wave 228). This spec adds
# the complementary check for the word 'hash', which also appears in the
# docstring and was not checked in any prior hashlib spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra65.blake2b_doc_contains_hash:
  description: "hashlib.blake2b.__doc__.__contains__('hash') — C extension type docstring is 'Return a new BLAKE2b hash object.'; 'hash' appears as part of 'hash object'; hashlib_extra64 checks __contains__('BLAKE2b') (wave 228); no prior hashlib spec checks blake2b.__doc__.__contains__('hash'); complementary doc content check for blake2b"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibcode65

  columns: [id, function, args, expected]
  rows:
    - [blake2b_doc_contains_hash, blake2b.__doc__.__contains__, ["hash"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__defaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# hashlib.new is the primary Python wrapper for creating new hash objects in
# Lib/hashlib.py. Its signature is new(name, *args, **kwargs) — no positional
# defaults. __defaults__ is None (NoneType). The chain
# __defaults__.__class__.__name__.__eq__('NoneType') confirms the None type
# identity of the defaults object. No prior hashlib spec checks
# new.__defaults__ in any form. First __defaults__ anchor for any hashlib
# function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra65.new_defaults_class_name_nonetype:
  description: "hashlib.new.__defaults__.__class__.__name__.__eq__('NoneType') == True — hashlib.new has signature new(name, *args, **kwargs) with no positional defaults; __defaults__ is None so __class__.__name__ is 'NoneType'; no prior hashlib spec checks new.__defaults__.__class__.__name__; first __defaults__ class identity anchor for any hashlib function"
  category: defaults
  kind: python_call_eq
  function: new.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.__class__.__name__.__eq__('code') — standalone
#
# hashlib.new is a pure Python function; its __code__ attribute is a Python
# code object. The code object class name is 'code'. C extension functions like
# pbkdf2_hmac do not have __code__. No prior hashlib spec checks
# new.__code__.__class__.__name__.__eq__('code') in any form. First __code__
# class identity anchor for any hashlib function. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra65.new_code_class_name_code:
  description: "hashlib.new.__code__.__class__.__name__.__eq__('code') == True — hashlib.new is a pure Python function in Lib/hashlib.py; __code__ is a Python code object with class name 'code'; pbkdf2_hmac is a C builtin without __code__; no prior hashlib spec checks new.__code__.__class__.__name__.__eq__('code'); first __code__ class identity anchor for any hashlib function"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true
