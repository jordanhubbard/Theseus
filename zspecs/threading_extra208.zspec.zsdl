invariant threading_extra208.main_thread_co_stacksize_1:
  description: "threading.main_thread.__code__.co_stacksize == 1 — main_thread is a simple lookup function requiring only stack depth 1; the smallest co_stacksize of the threading functions checked in this spec; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: main_thread.__code__.co_stacksize.__eq__
  args: [1]
  expected: true

invariant threading_extra208.thread_init_co_flags_201326595:
  description: "threading.Thread.__init__.__code__.co_flags == 201326595 — Thread.__init__ has a distinct co_flags value from module-level functions (67108867) due to method flags (keyword-only args etc.); new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_flags.__eq__
  args: [201326595]
  expected: true

invariant threading_extra208.active_count_co_stacksize_7:
  description: "threading.active_count.__code__.co_stacksize == 7 — active_count requires maximum stack depth of 7, the largest co_stacksize of the module-level threading functions checked in this spec; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
