spec: threading_extra208
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "Python threading documentation — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.current_thread, threading.main_thread, and threading.active_count are Python-level functions defined in threading.py. They have __code__ attributes."
    - "threading.Thread.__init__ is a Python-level method. Its co_flags value is 201326595 — different from the module-level functions (which are all 67108867). The different value reflects that __init__ uses keyword-only arguments and other flags not present in simple module-level functions."
    - "threading.current_thread.__code__.co_flags.__class__.__name__ == 'int' — co_flags==67108867. Verified with Python 3.14.3."
    - "threading.main_thread.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize==1. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to threading.py. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags==201326595. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize==4. Verified with Python 3.14.3."
    - "co_stacksize values: main_thread=1, current_thread=4, active_count=7, Thread.__init__=4. All verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: co_flags.__class__.__name__ == 'int' for threading functions
#
# threading.current_thread, main_thread, active_count are module-level
# Python functions with co_flags==67108867.
# threading.Thread.__init__ is a method with co_flags==201326595.
# All co_flags values are int.
# ---------------------------------------------------------------------------

table threading_extra208.co_flags_class_name:
  description: "__code__.co_flags.__class__.__name__ == 'int' for threading functions and Thread.__init__; module-level functions have co_flags==67108867; Thread.__init__ has co_flags==201326595 (method with additional flags); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: threadcoflags208

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_flags_class,
       "current_thread.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.current_thread.__code__.co_flags.__class__.__name__ == 'int' — current_thread is a module-level Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra208"]
    - [main_thread_flags_class,
       "main_thread.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.main_thread.__code__.co_flags.__class__.__name__ == 'int' — main_thread is a module-level Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra208"]
    - [active_count_flags_class,
       "active_count.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.active_count.__code__.co_flags.__class__.__name__ == 'int' — active_count is a module-level Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra208"]
    - [thread_init_flags_class,
       "Thread.__init__.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.Thread.__init__.__code__.co_flags.__class__.__name__ == 'int' — Thread.__init__ is a Python method; co_flags==201326595 is an int bitmask (different from module-level functions); str.__eq__('int') returns True; new to extra208"]

# ---------------------------------------------------------------------------
# Table 2: co_stacksize.__class__.__name__ and values for threading
#
# co_stacksize values: main_thread=1, current_thread=4, active_count=7,
# Thread.__init__=4. All are int.
# ---------------------------------------------------------------------------

table threading_extra208.co_stacksize_class_and_values:
  description: "__code__.co_stacksize.__class__.__name__ == 'int' and exact values for threading functions; main_thread=1, current_thread=4, active_count=7, Thread.__init__=4; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: threadcoflags208

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_stacksize_class,
       "main_thread.__code__.co_stacksize.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.main_thread.__code__.co_stacksize.__class__.__name__ == 'int' — main_thread co_stacksize==1; type is int; str.__eq__('int') returns True; new to extra208"]
    - [main_thread_stacksize_value,
       "main_thread.__code__.co_stacksize.__eq__",
       [1],
       true,
       "threading.main_thread.__code__.co_stacksize == 1 — main_thread is a simple lookup function requiring only stack depth 1; int.__eq__(1) returns True; new to extra208"]
    - [current_thread_stacksize_value,
       "current_thread.__code__.co_stacksize.__eq__",
       [4],
       true,
       "threading.current_thread.__code__.co_stacksize == 4 — current_thread requires maximum stack depth of 4; int.__eq__(4) returns True; new to extra208"]
    - [active_count_stacksize_value,
       "active_count.__code__.co_stacksize.__eq__",
       [7],
       true,
       "threading.active_count.__code__.co_stacksize == 7 — active_count requires maximum stack depth of 7, the largest of the module-level functions checked here; int.__eq__(7) returns True; new to extra208"]
    - [thread_init_stacksize_class,
       "Thread.__init__.__code__.co_stacksize.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.Thread.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — Thread.__init__ co_stacksize==4; type is int; str.__eq__('int') returns True; new to extra208"]
    - [thread_init_stacksize_value,
       "Thread.__init__.__code__.co_stacksize.__eq__",
       [4],
       true,
       "threading.Thread.__init__.__code__.co_stacksize == 4 — Thread.__init__ requires maximum stack depth of 4; int.__eq__(4) returns True; new to extra208"]

# ---------------------------------------------------------------------------
# Table 3: co_filename.__class__.__name__ and co_flags exact values
#
# co_filename is always str (path to threading.py).
# Thread.__init__ co_flags == 201326595 (distinct from module-level functions).
# Module-level function co_flags == 67108867.
# ---------------------------------------------------------------------------

table threading_extra208.co_filename_class_and_flags_values:
  description: "co_filename.__class__.__name__ == 'str' and exact co_flags values for threading functions; Thread.__init__ co_flags==201326595 (method flags differ from module-level function co_flags==67108867); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: threadcoflags208

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_filename_class,
       "active_count.__code__.co_filename.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.active_count.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to threading.py; type is str; str.__eq__('str') returns True; new to extra208"]
    - [current_thread_filename_class,
       "current_thread.__code__.co_filename.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.current_thread.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to threading.py; type is str; str.__eq__('str') returns True; new to extra208"]
    - [current_thread_flags_value,
       "current_thread.__code__.co_flags.__eq__",
       [67108867],
       true,
       "threading.current_thread.__code__.co_flags == 67108867 — module-level function bitmask; int.__eq__(67108867) returns True; new to extra208"]
    - [thread_init_flags_value,
       "Thread.__init__.__code__.co_flags.__eq__",
       [201326595],
       true,
       "threading.Thread.__init__.__code__.co_flags == 201326595 — Thread.__init__ is a method with additional flags (keyword-only args and other attributes); distinct from module-level function co_flags (67108867); int.__eq__(201326595) returns True; new to extra208"]
    - [thread_init_flags_not_module_flags,
       "Thread.__init__.__code__.co_flags.__eq__",
       [67108867],
       false,
       "threading.Thread.__init__.__code__.co_flags != 67108867 — Thread.__init__ co_flags is 201326595, not the module-level function value 67108867; int.__eq__(67108867) returns False; new to extra208"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra208
# ---------------------------------------------------------------------------

invariant threading_extra208.current_thread_co_flags_class_int:
  description: "threading.current_thread.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask; current_thread is a Python-level function; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: current_thread.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant threading_extra208.main_thread_co_stacksize_class_int:
  description: "threading.main_thread.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an integer; main_thread co_stacksize==1; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: main_thread.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant threading_extra208.active_count_co_filename_class_str:
  description: "threading.active_count.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to threading.py; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: active_count.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra208.thread_init_co_flags_class_int:
  description: "threading.Thread.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask; Thread.__init__ is a Python method; co_flags==201326595; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
