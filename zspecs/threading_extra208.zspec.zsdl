invariant threading_extra208.thread_init_co_stacksize_class_int:
  description: "threading.Thread.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an integer; Thread.__init__ co_stacksize==4; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_stacksize.__class__.__name__.__eq__
