spec: hashlib_extra263
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, and hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "hashlib.zspec.zsdl covers: sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors; digest_size/block_size attrs; algorithms_guaranteed core sets; digest_consistency, copy_independence, api_equivalence."
    - "hashlib_extra.zspec.zsdl covers: blake2b/blake2s name and digest_size variants; sha3_224/sha3_384 attrs; algorithms_guaranteed extended membership; algorithms_available type and sha256 membership; pbkdf2_hmac function name and return lengths."
    - "hashlib_extra2.zspec.zsdl covers: md5/sha1/sha256 empty hexdigest; md5(hello) hexdigest; sha256/sha512 digest_size_eq; algorithms_guaranteed type_is_set; new() returns hash object."
    - "sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — FIPS 180-4 reference vector."
    - "md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — RFC 1321 Appendix A.5 reference vector."
    - "sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — FIPS 180-4 reference vector."
    - "sha256(b'hello').hexdigest() == '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824' — widely cited reference vector."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha256(b'') — digest byte length and hexdigest equality
# hexdigest() string tested in hashlib_extra2; here we add digest().__len__
# and an __eq__ form of the same hexdigest invariant for orthogonal coverage.
# ---------------------------------------------------------------------------

invariant hashlib_extra263.sha256.empty_digest_len:
  description: "len(hashlib.sha256(b'').digest()) == 32 (256 bits = 32 bytes)"
  category: known_vector
  kind: python_call_eq
  function: sha256
  args: [""]
  method: digest.__len__
  method_args: []
  expected: 32

invariant hashlib_extra263.sha256.empty_hexdigest_eq:
  description: "hashlib.sha256(b'').hexdigest().__eq__('e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855') (FIPS 180-4)"
  category: known_vector
  kind: python_call_eq
  function: sha256
  args: [""]
  method: hexdigest.__eq__
  method_args: ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
  expected: true

# ---------------------------------------------------------------------------
# md5(b'') — digest byte length and hexdigest equality (RFC 1321 A.5)
# ---------------------------------------------------------------------------

invariant hashlib_extra263.md5.empty_digest_len:
  description: "len(hashlib.md5(b'').digest()) == 16 (128 bits = 16 bytes)"
  category: known_vector
  kind: python_call_eq
  function: md5
  args: [""]
  method: digest.__len__
  method_args: []
  expected: 16

invariant hashlib_extra263.md5.empty_hexdigest_eq:
  description: "hashlib.md5(b'').hexdigest().__eq__('d41d8cd98f00b204e9800998ecf8427e') (RFC 1321 A.5)"
  category: known_vector
  kind: python_call_eq
  function: md5
  args: [""]
  method: hexdigest.__eq__
  method_args: ["d41d8cd98f00b204e9800998ecf8427e"]
  expected: true

# ---------------------------------------------------------------------------
# sha1(b'') — digest byte length and hexdigest equality (FIPS 180-4)
# ---------------------------------------------------------------------------

invariant hashlib_extra263.sha1.empty_digest_len:
  description: "len(hashlib.sha1(b'').digest()) == 20 (160 bits = 20 bytes)"
  category: known_vector
  kind: python_call_eq
  function: sha1
  args: [""]
  method: digest.__len__
  method_args: []
  expected: 20

invariant hashlib_extra263.sha1.empty_hexdigest_eq:
  description: "hashlib.sha1(b'').hexdigest().__eq__('da39a3ee5e6b4b0d3255bfef95601890afd80709') (FIPS 180-4)"
  category: known_vector
  kind: python_call_eq
  function: sha1
  args: [""]
  method: hexdigest.__eq__
  method_args: ["da39a3ee5e6b4b0d3255bfef95601890afd80709"]
  expected: true

# ---------------------------------------------------------------------------
# sha256(b'hello') — hexdigest equality, widely cited reference vector
# ---------------------------------------------------------------------------

invariant hashlib_extra263.sha256.hello_hexdigest_eq:
  description: "hashlib.sha256(b'hello').hexdigest() == '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824'"
  category: known_vector
  kind: python_call_eq
  function: sha256
  args: [!ascii "hello"]
  method: hexdigest.__eq__
  method_args: ["2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"]
  expected: true

# ---------------------------------------------------------------------------
# hexdigest() length — output is always 2 * digest_size hex characters
# ---------------------------------------------------------------------------

invariant hashlib_extra263.sha256.hexdigest_len:
  description: "len(hashlib.sha256(b'').hexdigest()) == 64 (2 * 32 bytes)"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [""]
  method: hexdigest.__len__
  method_args: []
  expected: 64

invariant hashlib_extra263.md5.hexdigest_len:
  description: "len(hashlib.md5(b'').hexdigest()) == 32 (2 * 16 bytes)"
  category: properties
  kind: python_call_eq
  function: md5
  args: [""]
  method: hexdigest.__len__
  method_args: []
  expected: 32

invariant hashlib_extra263.sha1.hexdigest_len:
  description: "len(hashlib.sha1(b'').hexdigest()) == 40 (2 * 20 bytes)"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [""]
  method: hexdigest.__len__
  method_args: []
  expected: 40
