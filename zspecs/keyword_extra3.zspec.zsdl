spec: keyword_extra3
version: ">=3.9"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html — Python keyword module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/keyword.py"
  notes:
    - "This spec extends keyword.zspec.zsdl, keyword_extra.zspec.zsdl, and keyword_extra2.zspec.zsdl."
    - "keyword (base) covers: iskeyword true/false cases (for/while/if/def/class/return/import/lambda/True/False/None/and/or/not/in/is; hello/foo/print/len/match/case), issoftkeyword true/false cases."
    - "keyword_extra covers: kwlist.__class__.__name__=='list', kwlist.__len__()>=35, iskeyword.__name__, iskeyword('else'/'elif'/'try'/'except'/'with'/'yield'), iskeyword('hello')==False, issoftkeyword.__name__."
    - "keyword_extra2 covers: iskeyword.__name__, iskeyword.__module__, issoftkeyword.__name__, kwlist.__class__.__name__, kwlist.__len__()>=30, kwlist.__contains__('if'/'for'/'while'/'class'/'def'), softkwlist.__class__.__name__, softkwlist.__len__()==4, softkwlist.__contains__('_'/'case'/'match'/'type')."
    - "This spec adds: iskeyword.__qualname__ == 'iskeyword' (not in any prior spec), issoftkeyword.__qualname__ == 'issoftkeyword' (not in any prior spec), kwlist.__contains__('hello') == False (not in any prior spec — extra2 only checks for presence of keywords, not absence)."
    - "iskeyword and issoftkeyword are module-level functions so __qualname__ == __name__."
    - "kwlist.__contains__('hello') == False confirms that a plain English word is not in the keyword list."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# iskeyword.__qualname__ — not covered in keyword, keyword_extra, or keyword_extra2
# ---------------------------------------------------------------------------

invariant keyword_extra3.iskeyword.qualname:
  description: "iskeyword.__qualname__ == 'iskeyword'"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword.__qualname__.__eq__
  args: ["iskeyword"]
  expected: true

# ---------------------------------------------------------------------------
# issoftkeyword.__qualname__ — not covered in keyword, keyword_extra, or keyword_extra2
# issoftkeyword was added in Python 3.9 and is a module-level function.
# ---------------------------------------------------------------------------

invariant keyword_extra3.issoftkeyword.qualname:
  description: "issoftkeyword.__qualname__ == 'issoftkeyword' (Python >= 3.9)"
  category: issoftkeyword
  kind: python_call_eq
  function: issoftkeyword.__qualname__.__eq__
  args: ["issoftkeyword"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist.__contains__('hello') == False
# keyword_extra2 only checks __contains__ for words that ARE keywords.
# This adds a negative membership check: 'hello' is not in kwlist.
# keyword_extra checks iskeyword('hello') == False but not kwlist.__contains__.
# ---------------------------------------------------------------------------

invariant keyword_extra3.kwlist.not_contains_hello:
  description: "kwlist.__contains__('hello') == False — 'hello' is not a Python keyword"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__contains__
  args: ["hello"]
  expected: false
