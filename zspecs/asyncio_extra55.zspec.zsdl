spec: asyncio_extra55
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks and coroutines documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra54.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54)."
    - "This spec covers: asyncio class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition — every asyncio class has metaclass 'type' from builtins, so __class__.__module__ == 'builtins'; no prior asyncio spec has captured __class__.__module__ string equality. Also: gather/sleep/wait __class__.__module__.__eq__('builtins') — module-level coroutine functions have __class__ == 'function' from builtins. Also: Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') — Python class __init__ methods are plain functions; no prior asyncio spec has captured __init__.__class__ at all."
    - "asyncio.Queue.__class__.__module__ == 'builtins'. Queue is a standard Python class defined in Lib/asyncio/queues.py; its metaclass is the built-in 'type', which is defined in the builtins module. Therefore Queue.__class__.__module__ == 'builtins' (8 chars). No prior asyncio spec has captured __class__.__module__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__class__.__module__ == 'builtins'. Lock is defined in Lib/asyncio/locks.py with metaclass 'type' from builtins; __class__.__module__ == 'builtins'. No prior asyncio spec has captured __class__.__module__ for Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__class__.__module__ == 'builtins'. Event is defined in Lib/asyncio/locks.py alongside Lock; metaclass 'type' from builtins; __class__.__module__ == 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__class__.__module__ == 'builtins'. Semaphore is defined in Lib/asyncio/locks.py; metaclass 'type' from builtins; __class__.__module__ == 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__class__.__module__ == 'builtins'. Condition is defined in Lib/asyncio/locks.py; metaclass 'type' from builtins; __class__.__module__ == 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__class__.__module__ == 'builtins'. gather is a module-level coroutine function (a plain Python function object) defined in Lib/asyncio/tasks.py; its __class__ is the built-in 'function' type, whose __module__ is 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__class__.__module__ == 'builtins'. sleep is a module-level coroutine function; __class__ is the built-in 'function' type from builtins; __class__.__module__ == 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait.__class__.__module__ == 'builtins'. wait is a module-level coroutine function; __class__ is the built-in 'function' type from builtins; __class__.__module__ == 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__class__.__name__ == 'function'. Python class __init__ methods defined in pure Python are plain function objects; the 'function' type has __class__.__name__ == 'function'. Queue.__init__ is defined in Lib/asyncio/queues.py. No prior asyncio spec has captured any __init__.__class__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__class__.__name__ == 'function'. Lock.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'. Novel __init__.__class__.__name__ check for Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__init__.__class__.__name__ == 'function'. Event.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'. Novel __init__.__class__.__name__ check for Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__init__.__class__.__name__ == 'function'. Semaphore.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'. Novel __init__.__class__.__name__ check for Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__init__.__class__.__name__ == 'function'. Condition.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'. Novel __init__.__class__.__name__ check for Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __class__.__module__ string equality — extra55
#
# Every asyncio lock/queue class (Queue, Lock, Event, Semaphore, Condition)
# is a standard Python class whose metaclass is the built-in 'type'. The
# 'type' metaclass is defined in the builtins module, so:
#   Queue.__class__.__module__ == 'builtins'  (8 chars)
#   Lock.__class__.__module__  == 'builtins'  (8 chars)
#   ...
#
# No prior asyncio spec has captured __class__.__module__ for any asyncio
# class or function. Extra55 introduces this dimension in the asynciomod55
# namespace.
# ---------------------------------------------------------------------------

table asyncio_extra55.class_module_eq:
  description: "asyncio class __class__.__module__ string equality in asynciomod55 namespace — Queue/Lock/Event/Semaphore/Condition metaclass is 'type' from builtins; no prior asyncio spec captured __class__.__module__"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciomod55clsmodule

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__class__.__module__.__eq__,     ["builtins"], true, "Queue.__class__.__module__ == 'builtins' — Queue metaclass is built-in 'type' from builtins (8 chars); first asyncio __class__.__module__ check in any asyncio spec"]
    - [Lock,      Lock.__class__.__module__.__eq__,      ["builtins"], true, "Lock.__class__.__module__ == 'builtins' — Lock metaclass is built-in 'type' from builtins; defined in Lib/asyncio/locks.py"]
    - [Event,     Event.__class__.__module__.__eq__,     ["builtins"], true, "Event.__class__.__module__ == 'builtins' — Event metaclass is built-in 'type' from builtins; defined in Lib/asyncio/locks.py"]
    - [Semaphore, Semaphore.__class__.__module__.__eq__, ["builtins"], true, "Semaphore.__class__.__module__ == 'builtins' — Semaphore metaclass is built-in 'type' from builtins; defined in Lib/asyncio/locks.py"]
    - [Condition, Condition.__class__.__module__.__eq__, ["builtins"], true, "Condition.__class__.__module__ == 'builtins' — Condition metaclass is built-in 'type' from builtins; defined in Lib/asyncio/locks.py"]

# ---------------------------------------------------------------------------
# asyncio coroutine function __class__.__module__ string equality — extra55
#
# The module-level coroutine functions gather, sleep, and wait are plain
# Python function objects (type 'function'). The 'function' type is a
# built-in type defined in the builtins module, so:
#   gather.__class__.__module__ == 'builtins'  (8 chars)
#   sleep.__class__.__module__  == 'builtins'  (8 chars)
#   wait.__class__.__module__   == 'builtins'  (8 chars)
#
# No prior asyncio spec has captured __class__.__module__ for any asyncio
# function. Extra55 covers the three major coroutine functions.
# ---------------------------------------------------------------------------

table asyncio_extra55.function_module_eq:
  description: "asyncio coroutine function __class__.__module__ string equality in asynciomod55 namespace — gather/sleep/wait are 'function' type objects from builtins"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciomod55fnmodule

  columns: [id, function, args, expected, description]
  rows:
    - [gather, gather.__class__.__module__.__eq__, ["builtins"], true, "gather.__class__.__module__ == 'builtins' — gather is a module-level coroutine function; its __class__ is the built-in 'function' type, whose __module__ is 'builtins' (8 chars)"]
    - [sleep,  sleep.__class__.__module__.__eq__,  ["builtins"], true, "sleep.__class__.__module__ == 'builtins' — sleep is a module-level coroutine function; its __class__ is the built-in 'function' type from builtins"]
    - [wait,   wait.__class__.__module__.__eq__,   ["builtins"], true, "wait.__class__.__module__ == 'builtins' — wait is a module-level coroutine function; its __class__ is the built-in 'function' type from builtins"]

# ---------------------------------------------------------------------------
# asyncio class __init__.__class__.__name__ string equality — extra55
#
# Python class __init__ methods defined in pure Python source are plain
# function objects. The built-in 'function' type has __name__ == 'function'.
# Therefore for any asyncio class whose __init__ is defined in Python:
#   Queue.__init__.__class__.__name__     == 'function'
#   Lock.__init__.__class__.__name__      == 'function'
#   Event.__init__.__class__.__name__     == 'function'
#   Semaphore.__init__.__class__.__name__ == 'function'
#   Condition.__init__.__class__.__name__ == 'function'
#
# No prior asyncio spec has captured any __init__.__class__ attribute.
# Extra55 introduces this new access path in the asynciomod55 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra55.init_class_name_eq:
  description: "asyncio class __init__.__class__.__name__ string equality in asynciomod55 namespace — Python-defined __init__ methods are 'function' type objects; first __init__.__class__ check in any asyncio spec"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciomod55initclsname

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__init__.__class__.__name__.__eq__,     ["function"], true, "Queue.__init__.__class__.__name__ == 'function' — Queue.__init__ is a plain Python function defined in Lib/asyncio/queues.py; the 'function' type is a built-in type; novel __init__.__class__.__name__ check not in any prior asyncio spec"]
    - [Lock,      Lock.__init__.__class__.__name__.__eq__,      ["function"], true, "Lock.__init__.__class__.__name__ == 'function' — Lock.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'"]
    - [Event,     Event.__init__.__class__.__name__.__eq__,     ["function"], true, "Event.__init__.__class__.__name__ == 'function' — Event.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'"]
    - [Semaphore, Semaphore.__init__.__class__.__name__.__eq__, ["function"], true, "Semaphore.__init__.__class__.__name__ == 'function' — Semaphore.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'"]
    - [Condition, Condition.__init__.__class__.__name__.__eq__, ["function"], true, "Condition.__init__.__class__.__name__ == 'function' — Condition.__init__ is a plain Python function defined in Lib/asyncio/locks.py; its __class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra55
# ---------------------------------------------------------------------------

invariant asyncio_extra55.Queue_class_module_eq:
  description: "asyncio.Queue.__class__.__module__ == 'builtins' — Queue is a standard Python class with metaclass 'type'; the built-in 'type' is defined in builtins; __class__.__module__ == 'builtins' (8 chars); first __class__.__module__ check in any asyncio spec"
  category: class_names
  kind: python_call_eq
  function: Queue.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra55.Lock_class_module_eq:
  description: "asyncio.Lock.__class__.__module__ == 'builtins' — Lock is a standard Python class with metaclass 'type' from builtins; __class__.__module__ == 'builtins'; novel __class__.__module__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra55.gather_class_module_eq:
  description: "asyncio.gather.__class__.__module__ == 'builtins' — gather is a module-level coroutine function; the built-in 'function' type is defined in builtins; __class__.__module__ == 'builtins'; first __class__.__module__ check for any asyncio function"
  category: module_identity
  kind: python_call_eq
  function: gather.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra55.Queue_init_class_name_eq:
  description: "asyncio.Queue.__init__.__class__.__name__ == 'function' — Queue.__init__ is a plain Python function defined in Lib/asyncio/queues.py; the 'function' type is a built-in type with __name__ == 'function'; no prior asyncio spec has captured any __init__.__class__ attribute"
  category: class_names
  kind: python_call_eq
  function: Queue.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra55.Lock_init_class_name_eq:
  description: "asyncio.Lock.__init__.__class__.__name__ == 'function' — Lock.__init__ is a plain Python function defined in Lib/asyncio/locks.py; the 'function' type has __name__ == 'function'; novel __init__.__class__.__name__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra55.Semaphore_init_class_name_eq:
  description: "asyncio.Semaphore.__init__.__class__.__name__ == 'function' — Semaphore.__init__ is a plain Python function; the 'function' type has __name__ == 'function'; novel __init__.__class__.__name__ check for Semaphore"
  category: class_names
  kind: python_call_eq
  function: Semaphore.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true
