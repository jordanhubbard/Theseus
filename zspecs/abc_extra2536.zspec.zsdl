spec: abc_extra2536
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence — checking whether abc classes define custom formatting, bytes conversion, and filesystem path protocol in their class __dict__."
    - "abc.ABC is a convenience base class created with ABCMeta as its metaclass; it provides no custom string formatting, bytes conversion, or path protocol in its class __dict__. Verified with Python 3.14."
    - "abc.ABCMeta is the metaclass for abstract base classes; it controls abstract method registration and virtual subclass checks — not formatting, serialization, or path operations. Verified with Python 3.14."
    - "Neither abc.ABC nor abc.ABCMeta has any reason to define __format__, __bytes__, or __fspath__: they are structural/metaclass primitives, not data-holding or path-like objects. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC — __format__/__bytes__/__fspath__ absence
#
# Theme: custom formatting, bytes conversion, and path protocol absent from
# abc.ABC __dict__.
# ABC is a convenience base class; its only role is to carry ABCMeta as its
# metaclass. It defines no string-format override, bytes conversion, or path
# protocol in its own class __dict__.
# ---------------------------------------------------------------------------

table abc_extra2536.abc_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from abc.ABC __dict__; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2536

  columns: [id, function, args, expected]
  rows:
    - ["ab2536-001", abc.ABC.__dict__.__contains__, ["__format__"], false]
    - ["ab2536-002", abc.ABC.__dict__.__contains__, ["__bytes__"],  false]
    - ["ab2536-003", abc.ABC.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta — __format__/__bytes__/__fspath__ absence
#
# Theme: custom formatting, bytes conversion, and path protocol absent from
# abc.ABCMeta __dict__.
# ABCMeta is a metaclass that controls abstract method registration via
# __abstractmethods__; it carries no custom formatting, bytes, or path protocol.
# ---------------------------------------------------------------------------

table abc_extra2536.abcmeta_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from abc.ABCMeta __dict__; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2536

  columns: [id, function, args, expected]
  rows:
    - ["ab2536-004", abc.ABCMeta.__dict__.__contains__, ["__format__"], false]
    - ["ab2536-005", abc.ABCMeta.__dict__.__contains__, ["__bytes__"],  false]
    - ["ab2536-006", abc.ABCMeta.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 3: cross-check — ABC and ABCMeta both absent for all three protocols
#
# Symmetric cross-check: both ABC and ABCMeta lack all three protocols.
# This confirms the full absence of the formatting/bytes/path axis across
# the entire public abc class surface.
# ---------------------------------------------------------------------------

table abc_extra2536.cross_check_abc_abcmeta_all_absent:
  description: "__format__, __bytes__, __fspath__ absent from both abc.ABC and abc.ABCMeta; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2536

  columns: [id, function, args, expected]
  rows:
    - ["ab2536-007", abc.ABC.__dict__.__contains__,    ["__format__"], false]
    - ["ab2536-008", abc.ABC.__dict__.__contains__,    ["__bytes__"],  false]
    - ["ab2536-009", abc.ABC.__dict__.__contains__,    ["__fspath__"], false]
    - ["ab2536-010", abc.ABCMeta.__dict__.__contains__, ["__format__"], false]
    - ["ab2536-011", abc.ABCMeta.__dict__.__contains__, ["__bytes__"],  false]
    - ["ab2536-012", abc.ABCMeta.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 4: abc.ABC and abc.ABCMeta — __fspath__ absence with parity note
#
# __fspath__ implements the os.PathLike protocol. Neither ABC nor ABCMeta
# is a filesystem object. Neither defines __fspath__ at any level of its
# class hierarchy that would appear in its own __dict__.
# Re-checked as a standalone table to document the os.PathLike non-conformance
# as an explicit design property of both abc classes.
# ---------------------------------------------------------------------------

table abc_extra2536.fspath_parity:
  description: "__fspath__ absent from abc.ABC and abc.ABCMeta; neither implements os.PathLike; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2536

  columns: [id, function, args, expected]
  rows:
    - ["ab2536-013", abc.ABC.__dict__.__contains__,    ["__fspath__"], false]
    - ["ab2536-014", abc.ABCMeta.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 5: abc.ABC and abc.ABCMeta — __bytes__ absence with parity note
#
# __bytes__ provides a bytes representation of an object. Neither ABC nor
# ABCMeta is a data-carrying or byte-serializable object. Neither defines
# __bytes__ in its class __dict__. Documented as a standalone table to make
# the bytes-protocol non-conformance explicit alongside the fspath check above.
# ---------------------------------------------------------------------------

table abc_extra2536.bytes_parity:
  description: "__bytes__ absent from abc.ABC and abc.ABCMeta; neither defines a bytes conversion protocol; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2536

  columns: [id, function, args, expected]
  rows:
    - ["ab2536-015", abc.ABC.__dict__.__contains__,    ["__bytes__"], false]
    - ["ab2536-016", abc.ABCMeta.__dict__.__contains__, ["__bytes__"], false]
