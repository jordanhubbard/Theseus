spec: functools_extra292
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module identity: lru_cache, cached_property, partial, partialmethod, cmp_to_key, reduce, total_ordering"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "cmp_to_key is implemented in C and has __module__ == '_functools'"
    - "cached_property and partialmethod are pure Python with __module__ == 'functools'"
    - "partial.__bases__[0].__name__ == 'object' (C type inherits from object)"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra292.name_module_identity:
  description: "__name__ and __module__ identity for cached_property, partialmethod, cmp_to_key"
  kind: python_call_eq
  category: identity
  id_prefix: fex292

  columns: [id, function, args, expected, description]
  rows:
    - [fex292_001, functools.cached_property.__name__.__eq__, ["cached_property"], true, "cached_property __name__"]
    - [fex292_002, functools.cached_property.__module__.__eq__, ["functools"], true, "cached_property __module__"]
    - [fex292_003, functools.partialmethod.__name__.__eq__, ["partialmethod"], true, "partialmethod __name__"]
    - [fex292_004, functools.partialmethod.__module__.__eq__, ["functools"], true, "partialmethod __module__"]
    - [fex292_005, functools.cmp_to_key.__name__.__eq__, ["cmp_to_key"], true, "cmp_to_key __name__"]
    - [fex292_006, functools.cmp_to_key.__module__.__eq__, ["_functools"], true, "cmp_to_key __module__ is C extension"]

table functools_extra292.doc_class_identity:
  description: "__doc__.__class__.__name__ == 'str' for cached_property, partialmethod, reduce, total_ordering, cmp_to_key"
  kind: python_call_eq
  category: identity
  id_prefix: fex292d

  columns: [id, function, args, expected, description]
  rows:
    - [fex292d_001, functools.cached_property.__doc__.__class__.__name__.__eq__, ["str"], true, "cached_property __doc__ is str"]
    - [fex292d_002, functools.partialmethod.__doc__.__class__.__name__.__eq__, ["str"], true, "partialmethod __doc__ is str"]
    - [fex292d_003, functools.reduce.__doc__.__class__.__name__.__eq__, ["str"], true, "reduce __doc__ is str"]
    - [fex292d_004, functools.total_ordering.__doc__.__class__.__name__.__eq__, ["str"], true, "total_ordering __doc__ is str"]
    - [fex292d_005, functools.cmp_to_key.__doc__.__class__.__name__.__eq__, ["str"], true, "cmp_to_key __doc__ is str"]

invariant functools_extra292.cached_property_base_class:
  description: "cached_property base class is object"
  category: identity
  kind: python_call_eq
  function: functools.cached_property.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant functools_extra292.partial_base_class:
  description: "partial base class is object"
  category: identity
  kind: python_call_eq
  function: functools.partial.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant functools_extra292.cmp_to_key_module:
  description: "cmp_to_key lives in C extension _functools"
  category: identity
  kind: python_call_eq
  function: functools.cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra292.partialmethod_doc_is_str:
  description: "partialmethod __doc__ class name is str"
  category: identity
  kind: python_call_eq
  function: functools.partialmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
