spec: io_extra17
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra16.zspec.zsdl."
    - "io_extra15 covers __qualname__ for BytesIO/StringIO/FileIO/BufferedReader (class-level)."
    - "io_extra16 covers __qualname__ for BufferedWriter/BufferedRandom/TextIOWrapper/IncrementalNewlineDecoder/UnsupportedOperation (class-level)."
    - "No prior io spec covers __qualname__ for StringIO/BytesIO instance methods."
    - "No prior io spec covers __qualname__ for IOBase methods (close/flush/readable/writable/seekable/readline/readlines/writelines)."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — method qualname encodes the owning class."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — method qualname encodes the owning class."
    - "io.IOBase.close.__qualname__ == '_IOBase.close' — IOBase is exposed as io.IOBase but the C implementation uses _IOBase."
    - "io.IOBase.flush.__qualname__ == '_IOBase.flush', readable == '_IOBase.readable', writable == '_IOBase.writable', seekable == '_IOBase.seekable'."
    - "io.IOBase.readline.__qualname__ == '_IOBase.readline', readlines == '_IOBase.readlines', writelines == '_IOBase.writelines'."
    - "StringIO methods (read/write/seek/tell/truncate/close/getvalue) all have __qualname__ == 'StringIO.<method>'."
    - "BytesIO methods (read/write/seek/tell/truncate/close/getvalue) all have __qualname__ == 'BytesIO.<method>'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO and BytesIO method __qualname__ — getvalue, read, write, seek, tell
#
# io_extra15 covers class-level __qualname__ (BytesIO.__qualname__ == 'BytesIO').
# No prior io spec covers method-level __qualname__ for StringIO or BytesIO.
# For a method defined in class Foo, __qualname__ == 'Foo.method_name'.
# ---------------------------------------------------------------------------

invariant io_extra17.StringIO.getvalue.qualname:
  description: "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — method qualname encodes owning class"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__eq__
  args: ["StringIO.getvalue"]
  expected: true

invariant io_extra17.BytesIO.getvalue.qualname:
  description: "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — method qualname encodes owning class"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.getvalue.__qualname__.__eq__
  args: ["BytesIO.getvalue"]
  expected: true

invariant io_extra17.StringIO.read.qualname:
  description: "io.StringIO.read.__qualname__ == 'StringIO.read'"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.read.__qualname__.__eq__
  args: ["StringIO.read"]
  expected: true

invariant io_extra17.BytesIO.read.qualname:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read'"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__eq__
  args: ["BytesIO.read"]
  expected: true

invariant io_extra17.StringIO.write.qualname:
  description: "io.StringIO.write.__qualname__ == 'StringIO.write'"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.write.__qualname__.__eq__
  args: ["StringIO.write"]
  expected: true

invariant io_extra17.BytesIO.write.qualname:
  description: "io.BytesIO.write.__qualname__ == 'BytesIO.write'"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.write.__qualname__.__eq__
  args: ["BytesIO.write"]
  expected: true

invariant io_extra17.StringIO.seek.qualname:
  description: "io.StringIO.seek.__qualname__ == 'StringIO.seek'"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.seek.__qualname__.__eq__
  args: ["StringIO.seek"]
  expected: true

invariant io_extra17.BytesIO.seek.qualname:
  description: "io.BytesIO.seek.__qualname__ == 'BytesIO.seek'"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.seek.__qualname__.__eq__
  args: ["BytesIO.seek"]
  expected: true

# ---------------------------------------------------------------------------
# IOBase method __qualname__ — close, flush, readable, writable, seekable,
#                              readline, readlines, writelines
#
# io.IOBase is exposed as io.IOBase but the C implementation uses _IOBase
# as the internal name. As a result, all IOBase methods have __qualname__
# of the form '_IOBase.<method>' rather than 'IOBase.<method>'.
# No prior io spec covers __qualname__ for any IOBase methods.
# ---------------------------------------------------------------------------

invariant io_extra17.IOBase.close.qualname:
  description: "io.IOBase.close.__qualname__ == '_IOBase.close' — C type internal name is _IOBase"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.close.__qualname__.__eq__
  args: ["_IOBase.close"]
  expected: true

invariant io_extra17.IOBase.flush.qualname:
  description: "io.IOBase.flush.__qualname__ == '_IOBase.flush'"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.flush.__qualname__.__eq__
  args: ["_IOBase.flush"]
  expected: true

invariant io_extra17.IOBase.readable.qualname:
  description: "io.IOBase.readable.__qualname__ == '_IOBase.readable'"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.readable.__qualname__.__eq__
  args: ["_IOBase.readable"]
  expected: true

invariant io_extra17.IOBase.writable.qualname:
  description: "io.IOBase.writable.__qualname__ == '_IOBase.writable'"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.writable.__qualname__.__eq__
  args: ["_IOBase.writable"]
  expected: true

invariant io_extra17.IOBase.seekable.qualname:
  description: "io.IOBase.seekable.__qualname__ == '_IOBase.seekable'"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.seekable.__qualname__.__eq__
  args: ["_IOBase.seekable"]
  expected: true

invariant io_extra17.IOBase.readline.qualname:
  description: "io.IOBase.readline.__qualname__ == '_IOBase.readline'"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.readline.__qualname__.__eq__
  args: ["_IOBase.readline"]
  expected: true
