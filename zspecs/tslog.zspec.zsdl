spec: tslog
version: ">=4.0.0"
backend: node(tslog)

docs: https://tslog.js.org

provenance:
  derived_from:
    - "tslog docs — https://tslog.js.org"
    - "Test vectors verified with tslog via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tslog source"
  notes:
    - "Powerful but lightweight logger — pretty / json output, sub-loggers."
    - "Install: npm install tslog"
    - "v4 CJS; named export Logger."
    - "Logger.settings is a live config object — observable shape via chains."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor never throws on valid options."
  stderr: "Output is written to stderr by default (silly/trace/debug/info/warn/error/fatal levels)."
  stickiness: "N/A — each Logger independent."
  codes: {}

invariant tslog.default_type_pretty:
  description: "new Logger().settings.type defaults to 'pretty'"
  category: settings
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {get: "settings.type"}
  expected: "pretty"

invariant tslog.default_minLevel_zero:
  description: "Default minLevel is 0 (silly — emits everything)"
  category: settings
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {get: "settings.minLevel"}
  expected: 0

invariant tslog.json_type_via_options:
  description: "{type:'json'} is preserved in settings.type"
  category: settings
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: [{type: "json"}]
  chain:
    - {get: "settings.type"}
  expected: "json"

invariant tslog.minLevel_3_via_options:
  description: "{minLevel:3} is preserved (info threshold)"
  category: settings
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: [{minLevel: 3}]
  chain:
    - {get: "settings.minLevel"}
  expected: 3

invariant tslog.has_info_method:
  description: "Logger instance has an .info function"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {get: "info.constructor.name"}
  expected: "Function"

invariant tslog.has_warn_method:
  description: "Logger instance has a .warn function"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {get: "warn.constructor.name"}
  expected: "Function"

invariant tslog.has_error_method:
  description: "Logger instance has an .error function"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {get: "error.constructor.name"}
  expected: "Function"

invariant tslog.subLogger_inherits_name:
  description: "getSubLogger({name: 'child'}) carries the name into settings"
  category: subLogger
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {method: getSubLogger, args: [{name: "child"}]}
    - {get: "settings.name"}
  expected: "child"

invariant tslog.fresh_logger_no_name:
  description: "new Logger() has no name set by default"
  category: settings
  kind: node_chain_eq
  entry: constructor
  class: Logger
  entry_args: []
  chain:
    - {get: "settings.name"}
  expected: ~

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:53:08Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
