spec: decimal_extra185
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.Decimal.__init__.__name__ == '__init__' (len=8); class='wrapper_descriptor'."
    - "decimal.Decimal.__new__.__name__ == '__new__' (len=7); class='builtin_function_or_method'."
    - "decimal.Decimal.__class__.__name__ == 'type'; Decimal is a C extension type."
    - "decimal.Decimal.__module__ == 'decimal'."
    - "decimal.Decimal.__qualname__ == 'Decimal'."
    - "decimal.Decimal.__bases__[0].__name__ == 'object'; Decimal's single direct base is object."
    - "decimal.Decimal.__mro__ == [Decimal, object]; len=2."
    - "decimal.Decimal.__doc__.__class__.__name__ == 'str'; docstring is a plain string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal __init__ and __new__ method name equality
# __init__(8), __new__(7)
# ---------------------------------------------------------------------------

table decimal_extra185.decimal_init_new_names:
  description: "decimal.Decimal __init__ and __new__ __name__ values: __init__='__init__'(8), __new__='__new__'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldecimal185

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,  decimal.Decimal.__init__.__name__.__eq__, ["__init__"], true, "decimal.Decimal.__init__.__name__ == '__init__'; confirmed Python 3.14.3 macOS"]
    - [init_name_len, decimal.Decimal.__init__.__name__.__len__, [],          8,    "decimal.Decimal.__init__.__name__.__len__() == 8 — _(1)_(2)i(3)n(4)i(5)t(6)_(7)_(8); confirmed Python 3.14.3 macOS"]
    - [new_name_eq,   decimal.Decimal.__new__.__name__.__eq__,  ["__new__"],  true, "decimal.Decimal.__new__.__name__ == '__new__'; confirmed Python 3.14.3 macOS"]
    - [new_name_len,  decimal.Decimal.__new__.__name__.__len__,  [],          7,    "decimal.Decimal.__new__.__name__.__len__() == 7 — _(1)_(2)n(3)e(4)w(5)_(6)_(7); confirmed Python 3.14.3 macOS"]
    - [init_gt_new,   decimal.Decimal.__init__.__name__.__len__, [],          8,    "decimal.Decimal.__init__.__name__.__len__() == 8 > __new__.__name__.__len__() == 7; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal class-level identity attributes
# __class__(type), __module__(decimal), __qualname__(Decimal)
# ---------------------------------------------------------------------------

table decimal_extra185.decimal_class_identity:
  description: "decimal.Decimal class-level identity: __class__.__name__='type'(C extension type), __module__='decimal', __qualname__='Decimal'"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldecimal185

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,    decimal.Decimal.__class__.__name__.__eq__,    ["type"],    true, "decimal.Decimal.__class__.__name__ == 'type'; Decimal is a C extension type; confirmed Python 3.14.3 macOS"]
    - [module_eq,        decimal.Decimal.__module__.__eq__,             ["decimal"], true, "decimal.Decimal.__module__ == 'decimal'; confirmed Python 3.14.3 macOS"]
    - [qualname_eq,      decimal.Decimal.__qualname__.__eq__,           ["Decimal"], true, "decimal.Decimal.__qualname__ == 'Decimal'; top-level class, qualname matches class name; confirmed Python 3.14.3 macOS"]
    - [qualname_len,     decimal.Decimal.__qualname__.__len__,          [],          7,    "decimal.Decimal.__qualname__.__len__() == 7 — D(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [doc_class_eq,     decimal.Decimal.__doc__.__class__.__name__.__eq__, ["str"], true, "decimal.Decimal.__doc__.__class__.__name__ == 'str'; docstring is a plain string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal MRO and base class identity
# __bases__[0].__name__('object'), __mro__.__len__()(2)
# ---------------------------------------------------------------------------

table decimal_extra185.decimal_mro_bases:
  description: "decimal.Decimal MRO and base class: __bases__[0].__name__='object', __mro__.__len__()==2 (Decimal, object)"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldecimal185

  columns: [id, function, args, expected, description]
  rows:
    - [base_name_eq,  "decimal.Decimal.__bases__[0].__name__.__eq__", ["object"], true, "decimal.Decimal.__bases__[0].__name__ == 'object'; single direct base; confirmed Python 3.14.3 macOS"]
    - [mro_len_eq,    "decimal.Decimal.__mro__.__len__",               [],         2,    "decimal.Decimal.__mro__.__len__() == 2 — [Decimal, object]; no intermediate base classes; confirmed Python 3.14.3 macOS"]
    - [module_len,    decimal.Decimal.__module__.__len__,               [],         7,    "decimal.Decimal.__module__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [init_name_eq2, decimal.Decimal.__init__.__name__.__eq__,        ["__init__"], true, "decimal.Decimal.__init__.__name__ == '__init__'; cross-check with MRO table; confirmed Python 3.14.3 macOS"]
    - [new_name_eq2,  decimal.Decimal.__new__.__name__.__eq__,         ["__new__"],  true, "decimal.Decimal.__new__.__name__ == '__new__'; cross-check with MRO table; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra185.init_name_eq:
  description: "decimal.Decimal.__init__.__name__ == '__init__' — constructor dunder name, length 8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant decimal_extra185.new_name_eq:
  description: "decimal.Decimal.__new__.__name__ == '__new__' — allocation dunder name, length 7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__new__.__name__.__eq__
  args: ["__new__"]
  expected: true

invariant decimal_extra185.class_name_eq:
  description: "decimal.Decimal.__class__.__name__ == 'type' — Decimal is a C extension type, not a pure-Python class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra185.module_eq:
  description: "decimal.Decimal.__module__ == 'decimal' — class is attributed to the decimal module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra185.qualname_eq:
  description: "decimal.Decimal.__qualname__ == 'Decimal' — top-level class so qualname equals simple class name, length 7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__qualname__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra185.base_name_eq:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal's single direct base class is object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra185.mro_len_eq:
  description: "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object], no intermediate classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__mro__.__len__"
  args: []
  expected: 2

invariant decimal_extra185.doc_class_eq:
  description: "decimal.Decimal.__doc__.__class__.__name__ == 'str' — Decimal docstring is a plain Python string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

