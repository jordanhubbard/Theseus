spec: random_seed
version: ">=0.3.0"
backend: node(random-seed)

docs: https://github.com/skratchdot/random-seed#readme

provenance:
  derived_from:
    - "random-seed README — https://github.com/skratchdot/random-seed#readme"
    - "Test vectors verified with random-seed via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "random-seed source"
  notes:
    - "Deterministic PRNG. random-seed.create(seed) returns an rng function; calling rng(N) returns an integer in [0, N)."
    - "Install: npm install random-seed"
    - "Same seed always produces the same first/second/third draw — that's the spec property we exercise."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure deterministic generator; never throws on numeric N."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh seeded RNG."
  codes: {}

# Same seed → first call returns same value
invariant random_seed.same_seed_first_call:
  description: "random-seed.create('seed-1')(100) returns 1"
  category: deterministic
  kind: node_chain_eq
  entry: named
  function: create
  entry_args: ["seed-1"]
  chain:
    - {call: [100]}
  expected: 1

invariant random_seed.same_seed_first_call_other_n:
  description: "random-seed.create('seed-1')(1000) returns deterministic value 19"
  category: deterministic
  kind: node_chain_eq
  entry: named
  function: create
  entry_args: ["seed-1"]
  chain:
    - {call: [1000]}
  expected: 19

invariant random_seed.different_seed_different_first_call:
  description: "Different seed produces different first draw — seed-2 yields 24"
  category: deterministic
  kind: node_chain_eq
  entry: named
  function: create
  entry_args: ["seed-2"]
  chain:
    - {call: [100]}
  expected: 24

# range() returns float in [0,1)
invariant random_seed.range_returns_float_below_one:
  description: "rng.range() returns deterministic value in [0,1) for fixed seed"
  category: range
  kind: node_chain_eq
  entry: named
  function: create
  entry_args: ["seed-1"]
  chain:
    - {method: range, args: [1]}
  expected: 0
