spec: decimal_extra132
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: decimal rounding mode string constants (__class__.__name__, string value equality, __len__()) and decimal.Decimal / decimal.Context class identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__)."
    - "All decimal rounding mode constants (ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN) are plain Python str instances — not a subclass."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (length 13)."
    - "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' (length 15)."
    - "decimal.ROUND_CEILING == 'ROUND_CEILING' (length 13)."
    - "decimal.ROUND_FLOOR == 'ROUND_FLOOR' (length 11)."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (length 15)."
    - "decimal.ROUND_UP == 'ROUND_UP' (length 8)."
    - "decimal.ROUND_DOWN == 'ROUND_DOWN' (length 10)."
    - "decimal.Decimal.__name__ == 'Decimal' (length 7), __module__ == 'decimal' (length 7), __bases__[0].__name__ == 'object', __mro__.__len__() == 2, __class__.__name__ == 'type'."
    - "decimal.Context.__name__ == 'Context' (length 7), __module__ == 'decimal' (length 7), __bases__[0].__name__ == 'object', __mro__.__len__() == 2, __class__.__name__ == 'type'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal rounding constant string class identity
# Every rounding mode constant is a plain str instance (type(val) is str).
# ROUND_HALF_UP: __class__.__name__ == 'str', len == 13.
# ROUND_HALF_DOWN: __class__.__name__ == 'str', len == 15.
# ROUND_CEILING: __class__.__name__ == 'str', len == 13.
# ROUND_FLOOR: __class__.__name__ == 'str', len == 11.
# ROUND_HALF_EVEN: __class__.__name__ == 'str', len == 15.
# ROUND_UP: __class__.__name__ == 'str', len == 8.
# ROUND_DOWN: __class__.__name__ == 'str', len == 10.
# ---------------------------------------------------------------------------

table decimal_extra132.rounding_constant_class_identity:
  description: "decimal rounding constants __class__.__name__=='str' and __class__.__module__=='builtins': ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decrnd132

  columns: [id, function, args, expected]
  rows:
    - [rhu_cls_eq,   ROUND_HALF_UP.__class__.__name__.__eq__,    ["str"],      true]
    - [rhd_cls_eq,   ROUND_HALF_DOWN.__class__.__name__.__eq__,  ["str"],      true]
    - [rc_cls_eq,    ROUND_CEILING.__class__.__name__.__eq__,    ["str"],      true]
    - [rf_cls_eq,    ROUND_FLOOR.__class__.__name__.__eq__,      ["str"],      true]
    - [rhe_cls_eq,   ROUND_HALF_EVEN.__class__.__name__.__eq__,  ["str"],      true]
    - [ru_cls_eq,    ROUND_UP.__class__.__name__.__eq__,         ["str"],      true]
    - [rd_cls_eq,    ROUND_DOWN.__class__.__name__.__eq__,       ["str"],      true]
    - [rhu_mod_eq,   ROUND_HALF_UP.__class__.__module__.__eq__,  ["builtins"], true]
    - [rhd_mod_eq,   ROUND_HALF_DOWN.__class__.__module__.__eq__, ["builtins"], true]
    - [rc_mod_eq,    ROUND_CEILING.__class__.__module__.__eq__,  ["builtins"], true]

# ---------------------------------------------------------------------------
# decimal rounding constant string value equality
# Each constant equals its own name as a Python str literal.
# ---------------------------------------------------------------------------

table decimal_extra132.rounding_constant_values:
  description: "decimal rounding constants string value equality: ROUND_HALF_UP=='ROUND_HALF_UP', ROUND_HALF_DOWN=='ROUND_HALF_DOWN', ROUND_CEILING=='ROUND_CEILING', ROUND_FLOOR=='ROUND_FLOOR', ROUND_HALF_EVEN=='ROUND_HALF_EVEN', ROUND_UP=='ROUND_UP', ROUND_DOWN=='ROUND_DOWN'"
  kind: python_call_eq
  category: constant_value
  id_prefix: decrnd132

  columns: [id, function, args, expected]
  rows:
    - [rhu_eq,   ROUND_HALF_UP.__eq__,    ["ROUND_HALF_UP"],    true]
    - [rhd_eq,   ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"],  true]
    - [rc_eq,    ROUND_CEILING.__eq__,    ["ROUND_CEILING"],    true]
    - [rf_eq,    ROUND_FLOOR.__eq__,      ["ROUND_FLOOR"],      true]
    - [rhe_eq,   ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true]
    - [ru_eq,    ROUND_UP.__eq__,         ["ROUND_UP"],         true]
    - [rd_eq,    ROUND_DOWN.__eq__,       ["ROUND_DOWN"],       true]
    - [rhu_not,  ROUND_HALF_UP.__eq__,    ["ROUND_HALF_DOWN"],  false]
    - [rc_not,   ROUND_CEILING.__eq__,    ["ROUND_FLOOR"],      false]

# ---------------------------------------------------------------------------
# decimal rounding constant string lengths
# ROUND_HALF_UP: 13, ROUND_HALF_DOWN: 15, ROUND_CEILING: 13,
# ROUND_FLOOR: 11, ROUND_HALF_EVEN: 15, ROUND_UP: 8, ROUND_DOWN: 10.
# ---------------------------------------------------------------------------

table decimal_extra132.rounding_constant_lengths:
  description: "decimal rounding constant string lengths: ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_CEILING=13, ROUND_FLOOR=11, ROUND_HALF_EVEN=15, ROUND_UP=8, ROUND_DOWN=10"
  kind: python_call_eq
  category: constant_value
  id_prefix: decrnd132

  columns: [id, function, args, expected]
  rows:
    - [rhu_len,  ROUND_HALF_UP.__len__,    [], 13]
    - [rhd_len,  ROUND_HALF_DOWN.__len__,  [], 15]
    - [rc_len,   ROUND_CEILING.__len__,    [], 13]
    - [rf_len,   ROUND_FLOOR.__len__,      [], 11]
    - [rhe_len,  ROUND_HALF_EVEN.__len__,  [], 15]
    - [ru_len,   ROUND_UP.__len__,         [], 8]
    - [rd_len,   ROUND_DOWN.__len__,       [], 10]

# ---------------------------------------------------------------------------
# decimal.Decimal and decimal.Context class identity
# Both are C extension types (from _decimal) exposed via the decimal module.
# Decimal: __name__='Decimal' (7), __module__='decimal' (7),
#   __bases__[0].__name__='object' (6), __mro__.__len__()==2, __class__.__name__=='type'.
# Context: __name__='Context' (7), __module__='decimal' (7),
#   __bases__[0].__name__='object' (6), __mro__.__len__()==2, __class__.__name__=='type'.
# ---------------------------------------------------------------------------

table decimal_extra132.Decimal_Context_class_identity:
  description: "decimal.Decimal and decimal.Context class identity: both have __name__ len=7, __module__='decimal' (7), base='object', mro_len==2, metaclass='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decrnd132

  columns: [id, function, args, expected]
  rows:
    - [dec_name_eq,     Decimal.__name__.__eq__,                   ["Decimal"],  true]
    - [dec_name_len,    Decimal.__name__.__len__,                  [],           7]
    - [dec_module_eq,   Decimal.__module__.__eq__,                 ["decimal"],  true]
    - [dec_module_len,  Decimal.__module__.__len__,                [],           7]
    - [dec_base_eq,     "Decimal.__bases__[0].__name__.__eq__",    ["object"],   true]
    - [dec_mro_len,     Decimal.__mro__.__len__,                   [],           2]
    - [dec_cls_eq,      Decimal.__class__.__name__.__eq__,         ["type"],     true]
    - [ctx_name_eq,     Context.__name__.__eq__,                   ["Context"],  true]
    - [ctx_name_len,    Context.__name__.__len__,                  [],           7]
    - [ctx_module_eq,   Context.__module__.__eq__,                 ["decimal"],  true]
    - [ctx_base_eq,     "Context.__bases__[0].__name__.__eq__",    ["object"],   true]
    - [ctx_mro_len,     Context.__mro__.__len__,                   [],           2]
    - [ctx_cls_eq,      Context.__class__.__name__.__eq__,         ["type"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra132.ROUND_HALF_UP.is_str:
  description: "decimal.ROUND_HALF_UP.__class__.__name__ == 'str' (length 3; all decimal rounding mode constants are plain Python str instances, not a custom type)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_HALF_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra132.ROUND_HALF_UP.value_eq:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (length 13; the constant's string value is its own name)"
  category: constant_value
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra132.ROUND_HALF_DOWN.len_15:
  description: "decimal.ROUND_HALF_DOWN.__len__() == 15 ('ROUND_HALF_DOWN' is 15 characters; the longest rounding constant name, tied with ROUND_HALF_EVEN)"
  category: constant_value
  kind: python_call_eq
  function: ROUND_HALF_DOWN.__len__
  args: []
  expected: 15

invariant decimal_extra132.Decimal.module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' (length 7; Decimal is exposed via the decimal module even though it may be implemented in _decimal C extension)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra132.ROUND_UP.len_8:
  description: "decimal.ROUND_UP.__len__() == 8 ('ROUND_UP' is 8 characters; the shortest rounding constant name)"
  category: constant_value
  kind: python_call_eq
  function: ROUND_UP.__len__
  args: []
  expected: 8

