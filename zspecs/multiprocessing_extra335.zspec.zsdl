spec: multiprocessing_extra335
version: ">=3.4"
backend: python_module(multiprocessing.process)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.process module identity
# ---------------------------------------------------------------------------

invariant multiprocessing_extra335.module.name:
  description: "multiprocessing.process.__name__ == 'multiprocessing.process'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra335.module.package:
  description: "multiprocessing.process.__package__ == 'multiprocessing'"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# BaseProcess — name, module, and base class
#
# multiprocessing.process.BaseProcess is the abstract base for all process
# classes in multiprocessing. Its only base is object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra335.BaseProcess.name:
  description: "multiprocessing.process.BaseProcess.__name__ == 'BaseProcess'"
  category: base_process
  kind: python_call_eq
  function: BaseProcess.__name__.__eq__
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra335.BaseProcess.module:
  description: "multiprocessing.process.BaseProcess.__module__ == 'multiprocessing.process'"
  category: base_process
  kind: python_call_eq
  function: BaseProcess.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra335.BaseProcess.base:
  description: "multiprocessing.process.BaseProcess.__bases__[0].__name__ == 'object'"
  category: base_process
  kind: python_call_eq
  function: BaseProcess.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# AuthenticationString — name, module, and base class
#
# multiprocessing.process.AuthenticationString subclasses bytes so that
# process authentication keys cannot accidentally be printed or logged.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra335.AuthenticationString.name:
  description: "multiprocessing.process.AuthenticationString.__name__ == 'AuthenticationString'"
  category: authentication_string
  kind: python_call_eq
  function: AuthenticationString.__name__.__eq__
  args: ["AuthenticationString"]
  expected: true

invariant multiprocessing_extra335.AuthenticationString.module:
  description: "multiprocessing.process.AuthenticationString.__module__ == 'multiprocessing.process'"
  category: authentication_string
  kind: python_call_eq
  function: AuthenticationString.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra335.AuthenticationString.base:
  description: "multiprocessing.process.AuthenticationString.__bases__[0].__name__ == 'bytes'"
  category: authentication_string
  kind: python_call_eq
  function: AuthenticationString.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "bytes"

# ---------------------------------------------------------------------------
# current_process — function name and module
# ---------------------------------------------------------------------------

invariant multiprocessing_extra335.current_process.name:
  description: "multiprocessing.process.current_process.__name__ == 'current_process'"
  category: functions
  kind: python_call_eq
  function: current_process.__name__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra335.current_process.module:
  description: "multiprocessing.process.current_process.__module__ == 'multiprocessing.process'"
  category: functions
  kind: python_call_eq
  function: current_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# active_children — function name and module
# ---------------------------------------------------------------------------

invariant multiprocessing_extra335.active_children.name:
  description: "multiprocessing.process.active_children.__name__ == 'active_children'"
  category: functions
  kind: python_call_eq
  function: active_children.__name__.__eq__
  args: ["active_children"]
  expected: true

invariant multiprocessing_extra335.active_children.module:
  description: "multiprocessing.process.active_children.__module__ == 'multiprocessing.process'"
  category: functions
  kind: python_call_eq
  function: active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true
