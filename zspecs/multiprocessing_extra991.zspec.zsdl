spec: multiprocessing_extra991
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.Pool documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Pool method qualnames for apply, map, imap, starmap, and lifecycle methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra991.pool_apply_qualnames:
  description: "multiprocessing.Pool apply-family method __qualname__ identity"
  kind: python_call_eq
  category: pool_apply_qualnames
  id_prefix: mp991aq
  columns: [id, function, args, expected]
  rows:
    - [mp991aq001, multiprocessing.Pool.apply.__qualname__.__eq__, ["Pool.apply"], true]
    - [mp991aq002, multiprocessing.Pool.apply_async.__qualname__.__eq__, ["Pool.apply_async"], true]
    - [mp991aq003, multiprocessing.Pool.map.__qualname__.__eq__, ["Pool.map"], true]
    - [mp991aq004, multiprocessing.Pool.map_async.__qualname__.__eq__, ["Pool.map_async"], true]
    - [mp991aq005, multiprocessing.Pool.starmap.__qualname__.__eq__, ["Pool.starmap"], true]
    - [mp991aq006, multiprocessing.Pool.starmap_async.__qualname__.__eq__, ["Pool.starmap_async"], true]

table multiprocessing_extra991.pool_imap_qualnames:
  description: "multiprocessing.Pool imap-family method __qualname__ identity"
  kind: python_call_eq
  category: pool_imap_qualnames
  id_prefix: mp991iq
  columns: [id, function, args, expected]
  rows:
    - [mp991iq001, multiprocessing.Pool.imap.__qualname__.__eq__, ["Pool.imap"], true]
    - [mp991iq002, multiprocessing.Pool.imap_unordered.__qualname__.__eq__, ["Pool.imap_unordered"], true]
    - [mp991iq003, multiprocessing.Pool.__init__.__qualname__.__eq__, ["Pool.__init__"], true]
    - [mp991iq004, multiprocessing.Pool.__enter__.__qualname__.__eq__, ["Pool.__enter__"], true]
    - [mp991iq005, multiprocessing.Pool.__exit__.__qualname__.__eq__, ["Pool.__exit__"], true]

table multiprocessing_extra991.pool_lifecycle_qualnames:
  description: "multiprocessing.Pool lifecycle method __qualname__ identity"
  kind: python_call_eq
  category: pool_lifecycle_qualnames
  id_prefix: mp991lq
  columns: [id, function, args, expected]
  rows:
    - [mp991lq001, multiprocessing.Pool.terminate.__qualname__.__eq__, ["Pool.terminate"], true]
    - [mp991lq002, multiprocessing.Pool.close.__qualname__.__eq__, ["Pool.close"], true]
    - [mp991lq003, multiprocessing.Pool.join.__qualname__.__eq__, ["Pool.join"], true]
    - [mp991lq004, multiprocessing.Pool._get_tasks.__qualname__.__eq__, ["Pool._get_tasks"], true]
    - [mp991lq005, multiprocessing.Pool._help_stuff_finish.__qualname__.__eq__, ["Pool._help_stuff_finish"], true]
