spec: re_extra23
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra22.zspec.zsdl."
    - "re_extra22 covers: Pattern.__name__; Pattern.__module__; Match.__name__; Match.__module__; Pattern.__bases__[0].__name__; Match.__bases__[0].__name__; table of function __name__ attributes."
    - "re_extra21 covers: compile().__class__.__name__; match().__class__.__name__; IGNORECASE/DOTALL class names; error.__bases__[0].__name__."
    - "re_extra19 covers: DOTALL.__class__.__name__=='RegexFlag'; DOTALL.__int__()==16."
    - "NOT yet covered (now covered here): re.Pattern.__mro__.__len__() == 2 — Pattern MRO depth."
    - "NOT yet covered (now covered here): re.Match.__mro__.__len__() == 2 — Match MRO depth."
    - "NOT yet covered (now covered here): re.error.__mro__.__len__() == 4 — error MRO depth (PatternError->Exception->BaseException->object)."
    - "NOT yet covered (now covered here): re.Pattern.__mro__[0].__name__ == 'Pattern' — first MRO entry."
    - "NOT yet covered (now covered here): re.Pattern.__mro__[1].__name__ == 'object' — second MRO entry."
    - "NOT yet covered (now covered here): re.error.__mro__[1].__name__ == 'Exception' — second MRO entry for error."
    - "NOT yet covered (now covered here): re.error.__mro__[2].__name__ == 'BaseException' — third MRO entry for error."
    - "NOT yet covered (now covered here): table of function __module__ attributes — compile, match, search, findall, sub, split, fullmatch, purge, escape, subn."
    - "re.Pattern.__mro__.__len__() == 2 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "re.Match.__mro__.__len__() == 2 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "re.error.__mro__.__len__() == 4 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern — MRO depth and MRO entry names
#
# No prior spec verifies re.Pattern.__mro__.__len__() or individual MRO entry
# names as standalone invariants. Pattern inherits directly from object, giving
# an MRO of length 2: [Pattern, object].
# Verified at runtime: __len__() == 2; mro[0].__name__ == 'Pattern';
# mro[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant re_extra23.Pattern.mro_len:
  description: "re.Pattern.__mro__.__len__() == 2 — Pattern has a 2-entry MRO: [Pattern, object]"
  category: types
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra23.Pattern.mro_0:
  description: "re.Pattern.__mro__[0].__name__ == 'Pattern' — first MRO entry is Pattern itself"
  category: types
  kind: python_call_eq
  function: "Pattern.__mro__[0].__name__.__eq__"
  args: ["Pattern"]
  expected: true

invariant re_extra23.Pattern.mro_1:
  description: "re.Pattern.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: types
  kind: python_call_eq
  function: "Pattern.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match — MRO depth
#
# No prior spec verifies re.Match.__mro__.__len__(). Match, like Pattern,
# inherits directly from object, giving an MRO of length 2.
# Verified at runtime: __len__() == 2.
# ---------------------------------------------------------------------------

invariant re_extra23.Match.mro_len:
  description: "re.Match.__mro__.__len__() == 2 — Match has a 2-entry MRO: [Match, object]"
  category: types
  kind: python_call_eq
  function: Match.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# re.error — MRO depth and selected MRO entry names
#
# re.error is actually re.PatternError in Python 3.12+. It inherits from
# Exception, giving a 4-entry MRO: [PatternError, Exception, BaseException, object].
# No prior spec verifies error.__mro__.__len__() or the intermediate entries.
# re_extra21 covers error.__bases__[0].__name__ == 'Exception' (direct base only).
# Verified at runtime: __len__() == 4; mro[1].__name__ == 'Exception';
# mro[2].__name__ == 'BaseException'.
# ---------------------------------------------------------------------------

invariant re_extra23.error.mro_len:
  description: "re.error.__mro__.__len__() == 4 — error MRO: [PatternError, Exception, BaseException, object]"
  category: types
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant re_extra23.error.mro_1:
  description: "re.error.__mro__[1].__name__ == 'Exception' — second MRO entry is Exception"
  category: types
  kind: python_call_eq
  function: "error.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra23.error.mro_2:
  description: "re.error.__mro__[2].__name__ == 'BaseException' — third MRO entry is BaseException"
  category: types
  kind: python_call_eq
  function: "error.__mro__[2].__name__.__eq__"
  args: ["BaseException"]
  expected: true

# ---------------------------------------------------------------------------
# Table: re function __module__ attributes
#
# re_extra22 covers function __name__ attributes in a table. No prior spec
# groups re function __module__ checks into a single table. All module-level
# re functions have __module__ == 're'.
# Verified at runtime: compile, match, search, findall, sub, split, fullmatch,
# purge, escape, subn all report __module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra23.function_modules:
  description: "re module function __module__ attributes — compile, match, search, findall, sub, split, fullmatch, purge, escape, subn"
  kind: python_call_eq
  category: function_identity
  id_prefix: fm23

  columns: [id, function, args, expected]
  rows:
    - [compile_module,   compile.__module__.__eq__,   ["re"], true]
    - [match_module,     match.__module__.__eq__,     ["re"], true]
    - [search_module,    search.__module__.__eq__,    ["re"], true]
    - [findall_module,   findall.__module__.__eq__,   ["re"], true]
    - [sub_module,       sub.__module__.__eq__,       ["re"], true]
    - [split_module,     split.__module__.__eq__,     ["re"], true]
    - [fullmatch_module, fullmatch.__module__.__eq__, ["re"], true]
    - [purge_module,     purge.__module__.__eq__,     ["re"], true]
    - [escape_module,    escape.__module__.__eq__,    ["re"], true]
    - [subn_module,      subn.__module__.__eq__,      ["re"], true]
