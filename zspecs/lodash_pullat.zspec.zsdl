spec: lodash_pullat
version: ">=4.0.0"
backend: node(lodash.pullat)

docs: https://lodash.com/docs/#pullAt

provenance:
  derived_from:
    - "lodash.pullat README — https://www.npmjs.com/package/lodash.pullat"
    - "Test vectors verified with lodash.pullat@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pullat exports the _.pullAt function directly as module.exports."
    - "pullAt(array, indexes) removes elements at the given indexes and returns removed elements."
    - "Mutates the array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of removed elements."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pullat.pullat:
  kind: node_module_call_eq
  function: ~
  category: pullat
  id_prefix: lpat

  columns: [id, args, expected]
  rows:
    - [two_indexes,  [[5, 10, 15, 20], [1, 3]],  [10, 20]]
    - [one_index,    [[1, 2, 3, 4], [2]],          [3]]
    - [first,        [["a", "b", "c"], [0]],       ["a"]]
