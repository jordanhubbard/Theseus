spec: itertools_extra2566
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks."
    - "All itertools types are C extension types implemented in Modules/itertoolsmodule.c."
    - "None of the itertools iterator types define __getattr__, __setattr__, or __delattr__ in their own __dict__."
    - "C extension types that expose no Python-level writable attributes have no need for custom __setattr__ or __delattr__; attribute access is handled at the C level without Python-visible hooks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __getattr__ dict-presence for itertools types
#
# No itertools iterator class defines __getattr__.  All attribute lookups
# on itertools objects go through the standard C-level tp_getattro slot
# (PyObject_GenericGetAttr), not a Python-visible __getattr__ hook.
# ---------------------------------------------------------------------------

table itertools_extra2566.getattr_protocol:
  description: "itertools types __getattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2566

  columns: [id, function, args, expected]
  rows:
    - ["it2566001", "itertools.chain.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566002", "itertools.count.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566003", "itertools.repeat.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566004", "itertools.cycle.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566005", "itertools.islice.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566006", "itertools.product.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566007", "itertools.permutations.__dict__.__contains__", ["__getattr__"], false]
    - ["it2566008", "itertools.batched.__dict__.__contains__", ["__getattr__"], false]

# ---------------------------------------------------------------------------
# Table 2: __setattr__ dict-presence for itertools types
#
# No itertools iterator class defines __setattr__.  The itertools types are
# immutable C extension objects with no Python-assignable instance attributes,
# so there is no need for a Python-level setter guard.
# ---------------------------------------------------------------------------

table itertools_extra2566.setattr_protocol:
  description: "itertools types __setattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2566

  columns: [id, function, args, expected]
  rows:
    - ["it2566009", "itertools.chain.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566010", "itertools.count.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566011", "itertools.groupby.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566012", "itertools.repeat.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566013", "itertools.combinations.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566014", "itertools.accumulate.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566015", "itertools.pairwise.__dict__.__contains__", ["__setattr__"], false]
    - ["it2566016", "itertools.zip_longest.__dict__.__contains__", ["__getattr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __delattr__ dict-presence for itertools types
#
# No itertools iterator class defines __delattr__.  Like __setattr__, there
# are no Python-assignable attributes to protect, so no deletion guard is
# present in any of the itertools types.
# ---------------------------------------------------------------------------

table itertools_extra2566.delattr_protocol:
  description: "itertools types __delattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2566

  columns: [id, function, args, expected]
  rows:
    - ["it2566017", "itertools.chain.__dict__.__contains__", ["__delattr__"], false]
    - ["it2566018", "itertools.starmap.__dict__.__contains__", ["__delattr__"], false]
    - ["it2566019", "itertools.islice.__dict__.__contains__", ["__delattr__"], false]
    - ["it2566020", "itertools.filterfalse.__dict__.__contains__", ["__delattr__"], false]
