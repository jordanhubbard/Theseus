# ---------------------------------------------------------------------------
# Table 1: functools.cached_property — Python class identity, name, MRO
#
# Wave 273 theme: functools.cached_property — a descriptor class for computing
# and caching a property on first access, storing the result in the instance dict.
#
# functools.cached_property.__class__.__name__ == 'type'
# functools.cached_property.__name__ == 'cached_property' (len 15)
# functools.cached_property.__qualname__ == 'cached_property' (len 15)
# functools.cached_property.__module__ == 'functools' (len 9)
# functools.cached_property.__bases__[0].__name__ == 'object'
# len(functools.cached_property.__mro__) == 2
#
# cached_property is defined with 'class cached_property:' in Lib/functools.py;
# its __doc__ is None in Python 3.14.3. New to extra150.
# ---------------------------------------------------------------------------

