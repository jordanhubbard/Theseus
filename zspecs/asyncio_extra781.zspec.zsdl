spec: asyncio_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - asyncio standard library documentation
    - CPython source for asyncio.Task and asyncio.Future
  not_derived_from:
    - any third-party asyncio extensions
    - uvloop or alternate event loop implementations
  notes:
    - Covers method __qualname__ identity checks for Task and Future classes
    - All qualnames are verified against CPython 3.9+ behavior
  created_at: "2026-04-12"

table asyncio_extra781.name:
  description: asyncio.Task and Future method qualname identity checks
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: as781
  columns: [id, function, args, expected]
  rows:
    - [as781xx001, asyncio.Task.cancel.__qualname__.__eq__, ["Task.cancel"], true]
    - [as781xx002, asyncio.Task.result.__qualname__.__eq__, ["Task.result"], true]
    - [as781xx003, asyncio.Task.exception.__qualname__.__eq__, ["Task.exception"], true]
    - [as781xx004, asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true]
    - [as781xx005, asyncio.Task.done.__qualname__.__eq__, ["Task.done"], true]
    - [as781xx006, asyncio.Task.cancelled.__qualname__.__eq__, ["Task.cancelled"], true]
    - [as781xx007, asyncio.Task.get_name.__qualname__.__eq__, ["Task.get_name"], true]
    - [as781xx008, asyncio.Task.set_name.__qualname__.__eq__, ["Task.set_name"], true]
    - [as781xx009, asyncio.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true]
    - [as781xx010, asyncio.Future.result.__qualname__.__eq__, ["Future.result"], true]
    - [as781xx011, asyncio.Future.exception.__qualname__.__eq__, ["Future.exception"], true]
    - [as781xx012, asyncio.Future.done.__qualname__.__eq__, ["Future.done"], true]
