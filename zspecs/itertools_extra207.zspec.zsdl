spec: itertools_extra207
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools classes (chain, count, cycle, repeat, islice, starmap) are implemented in C (itertoolsmodule.c) and have no __code__ attribute. Their __doc__ strings are the primary Python-level inspectable property."
    - "itertools.chain.__doc__.__len__() == 190 — chain.__doc__ is 190 characters long. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__len__() == 205 — count.__doc__ is 205 characters long; the longest of the four main classes checked here. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__len__() == 95 — cycle.__doc__ is 95 characters long; the shortest of the four. cycle.__doc__ does NOT contain the substring 'cycle' — it reads 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.' Verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__len__() == 154 — repeat.__doc__ is 154 characters long. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__contains__('chain') == True — the word 'chain' appears in chain's docstring. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__contains__('count') == True — the word 'count' appears in count's docstring. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__len__() for itertools classes
#
# itertools classes are C-level and have no __code__. Their __doc__ strings
# are the primary inspectable property.
# Verified lengths: chain=190, count=205, cycle=95, repeat=154,
#                   islice=453, starmap=126.
# ---------------------------------------------------------------------------

table itertools_extra207.doc_len:
  description: "__doc__.__len__() for itertools C-level classes; chain=190, count=205, cycle=95, repeat=154, islice=453, starmap=126; verified with Python 3.14.3"
  kind: python_call_eq
  category: documentation
  id_prefix: iterdoc207

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_len,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — chain.__doc__ is 190 characters; chain is C-level so __doc__ is the primary inspectable attribute; new to extra207"]
    - [count_doc_len,
       "count.__doc__.__len__",
       [],
       205,
       "itertools.count.__doc__.__len__() == 205 — count.__doc__ is 205 characters; the longest of the four main classes checked here; new to extra207"]
    - [cycle_doc_len,
       "cycle.__doc__.__len__",
       [],
       95,
       "itertools.cycle.__doc__.__len__() == 95 — cycle.__doc__ is 95 characters; reads 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.'; new to extra207"]
    - [repeat_doc_len,
       "repeat.__doc__.__len__",
       [],
       154,
       "itertools.repeat.__doc__.__len__() == 154 — repeat.__doc__ is 154 characters; new to extra207"]
    - [islice_doc_len,
       "islice.__doc__.__len__",
       [],
       453,
       "itertools.islice.__doc__.__len__() == 453 — islice.__doc__ is 453 characters; the longest doc of the classes checked in this spec; new to extra207"]
    - [starmap_doc_len,
       "starmap.__doc__.__len__",
       [],
       126,
       "itertools.starmap.__doc__.__len__() == 126 — starmap.__doc__ is 126 characters; new to extra207"]

# ---------------------------------------------------------------------------
# Table 2: __doc__.__contains__ substring checks for itertools classes
#
# chain.__doc__ contains 'chain': True
# count.__doc__ contains 'count': True
# cycle.__doc__ does NOT contain 'cycle' (it contains 'repeat' and 'iterable')
# repeat.__doc__ contains 'repeat': True
# ---------------------------------------------------------------------------

table itertools_extra207.doc_contains:
  description: "__doc__.__contains__ substring checks for itertools classes; chain contains 'chain', count contains 'count', cycle does NOT contain 'cycle' (only 'repeat' and 'iterable'), repeat contains 'repeat'; verified with Python 3.14.3"
  kind: python_call_eq
  category: documentation
  id_prefix: iterdoc207

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_has_chain,
       "chain.__doc__.__contains__",
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — 'chain' appears in chain's docstring; str.__contains__ returns True; new to extra207"]
    - [count_doc_has_count,
       "count.__doc__.__contains__",
       ["count"],
       true,
       "itertools.count.__doc__.__contains__('count') == True — 'count' appears in count's docstring; str.__contains__ returns True; new to extra207"]
    - [cycle_doc_no_cycle,
       "cycle.__doc__.__contains__",
       ["cycle"],
       false,
       "itertools.cycle.__doc__.__contains__('cycle') == False — cycle.__doc__ reads 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.' — the word 'cycle' does not appear; str.__contains__ returns False; new to extra207"]
    - [cycle_doc_has_repeat,
       "cycle.__doc__.__contains__",
       ["repeat"],
       true,
       "itertools.cycle.__doc__.__contains__('repeat') == True — cycle.__doc__ contains 'repeat' (in 'repeat the sequence indefinitely'); str.__contains__ returns True; new to extra207"]
    - [repeat_doc_has_repeat,
       "repeat.__doc__.__contains__",
       ["repeat"],
       true,
       "itertools.repeat.__doc__.__contains__('repeat') == True — 'repeat' appears in repeat's docstring; str.__contains__ returns True; new to extra207"]
    - [chain_doc_has_iterable,
       "chain.__doc__.__contains__",
       ["iterable"],
       true,
       "itertools.chain.__doc__.__contains__('iterable') == True — 'iterable' appears in chain's docstring; str.__contains__ returns True; new to extra207"]

# ---------------------------------------------------------------------------
# Table 3: __doc__.__class__.__name__ for itertools classes
#
# All itertools class docstrings are plain str objects.
# This confirms the type of __doc__ for each C-level class.
# ---------------------------------------------------------------------------

table itertools_extra207.doc_class_name:
  description: "__doc__.__class__.__name__ == 'str' for itertools C-level classes; all six classes have str docstrings; verified with Python 3.14.3"
  kind: python_call_eq
  category: documentation
  id_prefix: iterdoc207

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__ == 'str' — chain.__doc__ is a plain str; new to extra207"]
    - [count_doc_class,
       "count.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__ == 'str' — count.__doc__ is a plain str; new to extra207"]
    - [cycle_doc_class,
       "cycle.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__ == 'str' — cycle.__doc__ is a plain str; new to extra207"]
    - [repeat_doc_class,
       "repeat.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__ == 'str' — repeat.__doc__ is a plain str; new to extra207"]
    - [islice_doc_class,
       "islice.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__ == 'str' — islice.__doc__ is a plain str; new to extra207"]
    - [starmap_doc_class,
       "starmap.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.starmap.__doc__.__class__.__name__ == 'str' — starmap.__doc__ is a plain str; new to extra207"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra207
# ---------------------------------------------------------------------------

invariant itertools_extra207.chain_doc_len_190:
  description: "itertools.chain.__doc__.__len__() == 190 — chain is a C-level class; __doc__ has 190 characters; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: chain.__doc__.__len__
  args: []
  expected: 190

invariant itertools_extra207.count_doc_len_205:
  description: "itertools.count.__doc__.__len__() == 205 — count is a C-level class; __doc__ has 205 characters; the longest of the four main classes; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: count.__doc__.__len__
  args: []
  expected: 205

invariant itertools_extra207.cycle_doc_len_95:
  description: "itertools.cycle.__doc__.__len__() == 95 — cycle is a C-level class; __doc__ has 95 characters; the shortest docstring of the four main classes; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: cycle.__doc__.__len__
  args: []
  expected: 95

invariant itertools_extra207.repeat_doc_len_154:
  description: "itertools.repeat.__doc__.__len__() == 154 — repeat is a C-level class; __doc__ has 154 characters; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: repeat.__doc__.__len__
  args: []
  expected: 154

invariant itertools_extra207.chain_doc_contains_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True — 'chain' appears in chain's docstring; chain is a C-level class; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: chain.__doc__.__contains__
  args: ["chain"]
  expected: true

invariant itertools_extra207.count_doc_contains_count:
  description: "itertools.count.__doc__.__contains__('count') == True — 'count' appears in count's docstring; count is a C-level class; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["count"]
  expected: true

invariant itertools_extra207.cycle_doc_no_cycle:
  description: "itertools.cycle.__doc__.__contains__('cycle') == False — cycle.__doc__ reads 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.' — the word 'cycle' does not appear; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: cycle.__doc__.__contains__
  args: ["cycle"]
  expected: false

invariant itertools_extra207.cycle_doc_contains_repeat:
  description: "itertools.cycle.__doc__.__contains__('repeat') == True — cycle.__doc__ contains 'repeat' (in 'repeat the sequence indefinitely'); new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: cycle.__doc__.__contains__
  args: ["repeat"]
  expected: true
