spec: socket_extra1906
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "socket.socket is a pure-Python class wrapping a C-level file descriptor; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "socket.error is an alias for the built-in OSError; socket.error.__qualname__ == 'OSError'."
    - "socket.timeout is an alias for the built-in TimeoutError; socket.timeout.__qualname__ == 'TimeoutError'."
    - "socket.gaierror is a proper subclass of socket.OSError; socket.gaierror.__qualname__ == 'gaierror'."
    - "socket.socket.__dict__ contains accept, close, makefile, detach, _closed, __init__, __repr__, __enter__, __exit__, type, family, dup, get_inheritable, set_inheritable."
    - "socket.socket.__dict__ does NOT contain connect, bind, listen, send, recv, fileno — these are provided by the underlying C _socket.socket type via inheritance."
    - "socket.error, socket.timeout, socket.gaierror do not define __match_args__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1906.reversed_protocol:
  description: "socket types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1906

  columns: [id, function, args, expected]
  rows:
    - ["sk1906001", "socket.socket.__dict__.__contains__", ["__reversed__"], false]
    - ["sk1906002", "socket.error.__dict__.__contains__", ["__reversed__"], false]
    - ["sk1906003", "socket.timeout.__dict__.__contains__", ["__reversed__"], false]
    - ["sk1906004", "socket.gaierror.__dict__.__contains__", ["__reversed__"], false]

