spec: functools_extra554
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity invariants for functools public API members via __qualname__ and __class__.__name__ checks"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra554.partial_method_qualnames:
  description: "Verify __qualname__ strings for functools.partial special methods"
  kind: python_call_eq
  category: identity
  id_prefix: fex554pm
  columns: [id, function, args, expected]
  rows:
    - [fex554pm001, functools.partial.__new__.__qualname__.__eq__, ["partial.__new__"], true]
    - [fex554pm002, functools.partial.__call__.__qualname__.__eq__, ["partial.__call__"], true]
    - [fex554pm003, functools.partial.__repr__.__qualname__.__eq__, ["partial.__repr__"], true]
    - [fex554pm004, functools.partial.__setstate__.__qualname__.__eq__, ["partial.__setstate__"], true]
    - [fex554pm005, functools.partial.__reduce__.__qualname__.__eq__, ["partial.__reduce__"], true]

table functools_extra554.api_class_names:
  description: "Verify __class__.__name__ for top-level functools API objects"
  kind: python_call_eq
  category: identity
  id_prefix: fex554cn
  columns: [id, function, args, expected]
  rows:
    - [fex554cn001, functools.partial.__class__.__name__.__eq__, ["type"], true]
    - [fex554cn002, functools.cached_property.__class__.__name__.__eq__, ["type"], true]
    - [fex554cn003, functools.singledispatch.__class__.__name__.__eq__, ["function"], true]
    - [fex554cn004, functools.lru_cache.__class__.__name__.__eq__, ["function"], true]
    - [fex554cn005, functools.wraps.__class__.__name__.__eq__, ["function"], true]

invariant functools_extra554.partial_is_type:
  description: "functools.partial is a type (class), not a plain function"
  category: identity
  kind: python_call_eq
  function: functools.partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra554.cached_property_is_type:
  description: "functools.cached_property is a type (class), not a plain function"
  category: identity
  kind: python_call_eq
  function: functools.cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true
