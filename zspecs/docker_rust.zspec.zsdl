spec: docker_rust
version: ">=3.9"
backend: rust_module(docker_rust)

docs: https://docker-py.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://docker-py.readthedocs.io/en/stable/ — Docker SDK for Python"
  not_derived_from:
    - "docker source: docker/__init__.py"
  notes:
    - "docker is the official Python SDK for Docker."
    - "docker.DockerClient is available."
    - "docker.DockerClient.__name__ == 'DockerClient'."
    - "docker.from_env is available."
    - "docker.__version__ is a non-empty string."
    - "Expose docker_client_name() -> str: docker.DockerClient.__name__."
    - "Expose docker_has_from_env() -> bool: hasattr(docker, 'from_env')."
    - "Expose docker_version_nonempty() -> bool: len(docker.__version__) > 0."
    - "All test vectors verified against docker 7.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# docker_client_name — DockerClient class name
invariant docker_rust.client.class_name:
  description: "docker.DockerClient.__name__ == 'DockerClient'"
  category: client
  kind: python_call_eq
  function: docker_client_name
  args: []
  expected: "DockerClient"

# docker_has_from_env — from_env present
invariant docker_rust.module.has_from_env:
  description: "docker.from_env is available"
  category: module
  kind: python_call_eq
  function: docker_has_from_env
  args: []
  expected: true

# docker_version_nonempty — version non-empty
invariant docker_rust.version.nonempty:
  description: "docker.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: docker_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
