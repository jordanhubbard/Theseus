    - [init_cv0_eq,    PurePath.__init__.__code__.co_varnames.__getitem__,  [0],          "self",    "PurePath.__init__.__code__.co_varnames[0] == 'self'"]
    - [init_argc_eq,   PurePath.__init__.__code__.co_argcount.__eq__,       [1],          true,      "PurePath.__init__.__code__.co_argcount == 1 (only self; *args not counted)"]
    - [init_cv_len,    PurePath.__init__.__code__.co_varnames.__len__,       [],           5,         "PurePath.__init__.__code__.co_varnames has 5 entries: self, args, paths, arg, path"]
    - [init_coname_eq, PurePath.__init__.__code__.co_name.__eq__,           ["__init__"], true,      "PurePath.__init__.__code__.co_name == '__init__'"]
    - [new_cv0_eq,     PurePath.__new__.__code__.co_varnames.__getitem__,   [0],          "cls",     "PurePath.__new__.__code__.co_varnames[0] == 'cls' (__new__ takes cls not self)"]
    - [new_argc_eq,    PurePath.__new__.__code__.co_argcount.__eq__,        [1],          true,      "PurePath.__new__.__code__.co_argcount == 1 (only cls)"]
    - [new_cv_len,     PurePath.__new__.__code__.co_varnames.__len__,        [],           3,         "PurePath.__new__.__code__.co_varnames has 3 entries: cls, args, kwargs"]
    - [new_coname_eq,  PurePath.__new__.__code__.co_name.__eq__,            ["__new__"],  true,      "PurePath.__new__.__code__.co_name == '__new__'"]

