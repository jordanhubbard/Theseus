# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra137.PurePath.init_varnames_first_is_self:
  description: "pathlib.PurePath.__init__.__code__.co_varnames[0] == 'self' (all instance method __code__.co_varnames start with 'self' as the first positional parameter)"
  category: code_attrs
  kind: python_call_eq
  function: PurePath.__init__.__code__.co_varnames.__getitem__
  args: [0]
  expected: "self"

invariant pathlib_extra137.PurePath.new_varnames_first_is_cls:
  description: "pathlib.PurePath.__new__.__code__.co_varnames[0] == 'cls' (__new__ is a static method that takes the class as its first argument rather than an instance)"
  category: code_attrs
  kind: python_call_eq
  function: PurePath.__new__.__code__.co_varnames.__getitem__
  args: [0]
  expected: "cls"

invariant pathlib_extra137.PurePath.init_argcount_is_1:
  description: "pathlib.PurePath.__init__.__code__.co_argcount == 1 (co_argcount counts only explicit positional/keyword parameters; *args and **kwargs are excluded)"
  category: code_attrs
  kind: python_call_eq
  function: PurePath.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra137.PurePath.eq_argcount_is_2:
  description: "pathlib.PurePath.__eq__.__code__.co_argcount == 2 (self and other are the two explicit positional parameters)"
  category: code_attrs
  kind: python_call_eq
  function: PurePath.__eq__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra137.PurePath.str_varnames_len_1:
  description: "pathlib.PurePath.__str__.__code__.co_varnames.__len__() == 1 (only 'self'; __str__ is a simple getter with no local variables beyond the parameter)"
  category: code_attrs
  kind: python_call_eq
  function: PurePath.__str__.__code__.co_varnames.__len__
  args: []
  expected: 1

