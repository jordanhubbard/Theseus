spec: pathlib_extra137
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath __code__ attributes (co_varnames and co_argcount) for __init__, __new__, __str__, __hash__, and __eq__."
    - "pathlib.PurePath.__init__.__code__.co_varnames[0] = 'self' (first arg is self, as expected for an instance method)."
    - "pathlib.PurePath.__init__.__code__.co_argcount = 1 (only 'self'; *args is captured via co_varnames but not counted in co_argcount)."
    - "pathlib.PurePath.__init__.__code__.co_varnames.__len__() = 5 (self, args, paths, arg, path — includes loop variables)."
    - "pathlib.PurePath.__new__.__code__.co_varnames[0] = 'cls' (first arg of __new__ is the class, not self)."
    - "pathlib.PurePath.__new__.__code__.co_argcount = 1 (only 'cls'; *args and **kwargs are not counted in co_argcount)."
    - "pathlib.PurePath.__new__.__code__.co_varnames.__len__() = 3 (cls, args, kwargs)."
    - "pathlib.PurePath.__str__.__code__.co_varnames[0] = 'self'."
    - "pathlib.PurePath.__str__.__code__.co_argcount = 1 (only self; __str__ takes no other arguments)."
    - "pathlib.PurePath.__str__.__code__.co_varnames.__len__() = 1 (only self; a simple getter)."
    - "pathlib.PurePath.__hash__.__code__.co_varnames[0] = 'self'."
    - "pathlib.PurePath.__hash__.__code__.co_argcount = 1."
    - "pathlib.PurePath.__eq__.__code__.co_varnames[0] = 'self'."
    - "pathlib.PurePath.__eq__.__code__.co_varnames[1] = 'other'."
    - "pathlib.PurePath.__eq__.__code__.co_argcount = 2 (self and other)."
    - "pathlib.Path.__init__.__code__.co_varnames[0] = 'self' (same as PurePath.__init__)."
    - "pathlib.Path.__init__.__code__.co_argcount = 1 (same as PurePath.__init__)."
    - "co_name for each method equals the dunder name: '__init__', '__new__', '__str__', '__hash__', '__eq__'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

