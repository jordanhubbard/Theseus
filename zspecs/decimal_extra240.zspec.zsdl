spec: decimal_extra240
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra238.zspec.zsdl — covers decimal.ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR rounding constants"
    - "decimal_extra239.zspec.zsdl — covers decimal.getcontext and decimal.localcontext identity"
  notes:
    - "This spec covers: decimal.ROUND_HALF_EVEN, ROUND_05UP, ROUND_UP, ROUND_DOWN string constants."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — plain str value; length 15; verified Python 3.14.3 macOS."
    - "decimal.ROUND_05UP == 'ROUND_05UP' — plain str value; length 10; verified Python 3.14.3 macOS."
    - "decimal.ROUND_UP == 'ROUND_UP' — plain str value; length 8; verified Python 3.14.3 macOS."
    - "decimal.ROUND_DOWN == 'ROUND_DOWN' — plain str value; length 10; verified Python 3.14.3 macOS."
    - "ROUND_HALF_EVEN.__class__.__name__ == 'str' — rounding constants are plain Python strings; verified Python 3.14.3 macOS."
    - "ROUND_05UP.__class__.__name__ == 'str' — verified Python 3.14.3 macOS."
    - "ROUND_UP.__class__.__name__ == 'str' — verified Python 3.14.3 macOS."
    - "ROUND_DOWN.__class__.__name__ == 'str' — verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal rounding constant string values
# ROUND_HALF_EVEN='ROUND_HALF_EVEN', ROUND_05UP='ROUND_05UP',
# ROUND_UP='ROUND_UP', ROUND_DOWN='ROUND_DOWN'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra240.rounding_constant_values:
  description: "decimal rounding constants string values: ROUND_HALF_EVEN, ROUND_05UP, ROUND_UP, ROUND_DOWN; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround240

  columns: [id, function, args, expected]
  rows:
    - [half_even_eq,  ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
    - [zero5up_eq,    ROUND_05UP.__eq__,      ["ROUND_05UP"],      true]
    - [up_eq,         ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [down_eq,       ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true]
    - [half_even_not, ROUND_HALF_EVEN.__eq__, ["ROUND_05UP"],      false]

# ---------------------------------------------------------------------------
# decimal rounding constant __class__.__name__ == 'str'
# All rounding mode constants are plain Python str instances.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra240.rounding_constant_class_names:
  description: "decimal rounding constants __class__.__name__ == 'str' for ROUND_HALF_EVEN, ROUND_05UP, ROUND_UP, ROUND_DOWN; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround240

  columns: [id, function, args, expected]
  rows:
    - [half_even_class_eq, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],   true]
    - [zero5up_class_eq,   ROUND_05UP.__class__.__name__.__eq__,     ["str"],   true]
    - [up_class_eq,        ROUND_UP.__class__.__name__.__eq__,        ["str"],   true]
    - [down_class_eq,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"],   true]
    - [class_not_bytes,    ROUND_HALF_EVEN.__class__.__name__.__eq__, ["bytes"], false]

# ---------------------------------------------------------------------------
# decimal rounding constant string lengths
# ROUND_HALF_EVEN len=15, ROUND_05UP len=10, ROUND_UP len=8, ROUND_DOWN len=10.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra240.rounding_constant_lengths:
  description: "decimal rounding constants string lengths: ROUND_HALF_EVEN=15, ROUND_05UP=10, ROUND_UP=8, ROUND_DOWN=10; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround240

  columns: [id, function, args, expected]
  rows:
    - [half_even_len, ROUND_HALF_EVEN.__len__, [], 15]
    - [zero5up_len,   ROUND_05UP.__len__,      [], 10]
    - [up_len,        ROUND_UP.__len__,        [], 8]
    - [down_len,      ROUND_DOWN.__len__,      [], 10]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra240.ROUND_HALF_EVEN.value_eq:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — the rounding constant string value; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra240.ROUND_HALF_EVEN.class_name_eq:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — rounding constants are plain Python str instances; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra240.ROUND_HALF_EVEN.len:
  description: "len(decimal.ROUND_HALF_EVEN) == 15 — 'ROUND_HALF_EVEN' has 15 characters; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__len__
  args: []
  expected: 15

