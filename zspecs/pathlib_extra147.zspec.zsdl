spec: pathlib_extra147
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath comparison method qualnames (__eq__, __hash__, __lt__, __le__, __gt__, __ge__), pathlib.Path method qualnames (stat, exists, is_file, is_dir, iterdir, open, read_text, write_text), and pathlib.PosixPath and pathlib.WindowsPath class identity and MRO."
    - "PurePath.__eq__, __hash__, __lt__, __le__, __gt__, __ge__ are all 'function' (pure Python methods, not C wrappers)."
    - "PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (15); __hash__.__qualname__ == 'PurePath.__hash__' (17)."
    - "PurePath.__lt__/__le__/__gt__/__ge__ qualnames all have length 15."
    - "Path.stat, Path.exists, Path.is_file, Path.is_dir, Path.iterdir, Path.open, Path.read_text, Path.write_text are all 'function'."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (9); __bases__[0].__name__ == 'Path'; MRO length == 5."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (11); __bases__[0].__name__ == 'Path'; MRO length == 5."
    - "PosixPath MRO: PosixPath, Path, PurePosixPath, PurePath, object (5 entries)."
    - "WindowsPath MRO: WindowsPath, Path, PureWindowsPath, PurePath, object (5 entries)."
    - "Note: pathlib.Path.__class_getitem__ does not exist in Python 3.14.3 (AttributeError)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath comparison method qualnames
# __eq__, __hash__, __lt__, __le__, __gt__, __ge__ are pure Python 'function'
# (not C wrapper_descriptor). Defined directly on PurePath in pathlib/_abc.py.
# __eq__.__qualname__ == 'PurePath.__eq__' (len=15).
# __hash__.__qualname__ == 'PurePath.__hash__' (len=17).
# __lt__/__le__/__gt__/__ge__ qualnames each have length 15.
# ---------------------------------------------------------------------------

table pathlib_extra147.PurePath_comparison_qualnames:
  description: "pathlib.PurePath comparison methods are 'function'; __eq__.__qualname__='PurePath.__eq__' (15), __hash__='PurePath.__hash__' (17), __lt__/__le__/__gt__/__ge__ each 15 chars"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibpp147

  columns: [id, function, args, expected]
  rows:
    - [eq_cls_eq,    "PurePath.__eq__.__class__.__name__.__eq__",    ["function"], true]
    - [eq_qn_eq,     "PurePath.__eq__.__qualname__.__eq__",          ["PurePath.__eq__"],   true]
    - [eq_qn_len,    "PurePath.__eq__.__qualname__.__len__",         [],                    15]
    - [hash_cls_eq,  "PurePath.__hash__.__class__.__name__.__eq__",  ["function"], true]
    - [hash_qn_eq,   "PurePath.__hash__.__qualname__.__eq__",        ["PurePath.__hash__"], true]
    - [hash_qn_len,  "PurePath.__hash__.__qualname__.__len__",       [],                    17]
    - [lt_cls_eq,    "PurePath.__lt__.__class__.__name__.__eq__",    ["function"], true]
    - [lt_qn_eq,     "PurePath.__lt__.__qualname__.__eq__",          ["PurePath.__lt__"],   true]
    - [lt_qn_len,    "PurePath.__lt__.__qualname__.__len__",         [],                    15]
    - [le_qn_eq,     "PurePath.__le__.__qualname__.__eq__",          ["PurePath.__le__"],   true]
    - [gt_qn_eq,     "PurePath.__gt__.__qualname__.__eq__",          ["PurePath.__gt__"],   true]
    - [ge_qn_eq,     "PurePath.__ge__.__qualname__.__eq__",          ["PurePath.__ge__"],   true]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem-query method qualnames
# stat, exists, is_file, is_dir, iterdir, open, read_text, write_text are
# all pure Python 'function' instances defined on Path.
# qualname lengths: stat=9, exists=11, is_file=12, is_dir=11,
# iterdir=12, open=9, read_text=14, write_text=15.
# ---------------------------------------------------------------------------

table pathlib_extra147.Path_filesystem_method_qualnames:
  description: "pathlib.Path filesystem methods are 'function': stat (9), exists (11), is_file (12), is_dir (11), iterdir (12), open (9), read_text (14), write_text (15)"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibpath147

  columns: [id, function, args, expected]
  rows:
    - [stat_cls_eq,      Path.stat.__class__.__name__.__eq__,      ["function"], true]
    - [stat_qn_eq,       Path.stat.__qualname__.__eq__,            ["Path.stat"],      true]
    - [stat_qn_len,      Path.stat.__qualname__.__len__,           [],                 9]
    - [exists_qn_eq,     Path.exists.__qualname__.__eq__,          ["Path.exists"],    true]
    - [exists_qn_len,    Path.exists.__qualname__.__len__,         [],                 11]
    - [isfile_qn_eq,     Path.is_file.__qualname__.__eq__,         ["Path.is_file"],   true]
    - [isfile_qn_len,    Path.is_file.__qualname__.__len__,        [],                 12]
    - [isdir_qn_eq,      Path.is_dir.__qualname__.__eq__,          ["Path.is_dir"],    true]
    - [isdir_qn_len,     Path.is_dir.__qualname__.__len__,         [],                 11]
    - [iterdir_qn_eq,    Path.iterdir.__qualname__.__eq__,         ["Path.iterdir"],   true]
    - [iterdir_qn_len,   Path.iterdir.__qualname__.__len__,        [],                 12]
    - [open_qn_eq,       Path.open.__qualname__.__eq__,            ["Path.open"],      true]
    - [open_qn_len,      Path.open.__qualname__.__len__,           [],                 9]
    - [rtext_qn_eq,      Path.read_text.__qualname__.__eq__,       ["Path.read_text"], true]
    - [rtext_qn_len,     Path.read_text.__qualname__.__len__,      [],                 14]
    - [wtext_qn_eq,      Path.write_text.__qualname__.__eq__,      ["Path.write_text"], true]
    - [wtext_qn_len,     Path.write_text.__qualname__.__len__,     [],                 15]

# ---------------------------------------------------------------------------
# pathlib.PosixPath class identity and MRO
# __name__ == 'PosixPath' (9), __module__ == 'pathlib' (7),
# __qualname__ == 'PosixPath' (9), __class__.__name__ == 'type'.
# __bases__[0].__name__ == 'Path'; MRO length == 5.
# MRO: PosixPath, Path, PurePosixPath, PurePath, object.
# ---------------------------------------------------------------------------

table pathlib_extra147.PosixPath_identity_mro:
  description: "pathlib.PosixPath class identity: __name__='PosixPath' (9), __module__='pathlib' (7), __class__.__name__='type'; MRO length 5 — PosixPath, Path, PurePosixPath, PurePath, object"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibposx147

  columns: [id, function, args, expected]
  rows:
    - [posx_name_eq,    PosixPath.__name__.__eq__,           ["PosixPath"], true]
    - [posx_name_len,   PosixPath.__name__.__len__,          [],            9]
    - [posx_module_eq,  PosixPath.__module__.__eq__,         ["pathlib"],   true]
    - [posx_module_len, PosixPath.__module__.__len__,        [],            7]
    - [posx_qn_eq,      PosixPath.__qualname__.__eq__,       ["PosixPath"], true]
    - [posx_cls_eq,     PosixPath.__class__.__name__.__eq__, ["type"],      true]
    - [posx_base0_eq,   "PosixPath.__bases__[0].__name__.__eq__", ["Path"], true]
    - [posx_mro_len,    "PosixPath.__mro__.__len__",         [],            5]
    - [posx_mro0_eq,    "PosixPath.__mro__[0].__name__.__eq__", ["PosixPath"],      true]
    - [posx_mro1_eq,    "PosixPath.__mro__[1].__name__.__eq__", ["Path"],           true]
    - [posx_mro2_eq,    "PosixPath.__mro__[2].__name__.__eq__", ["PurePosixPath"],  true]
    - [posx_mro3_eq,    "PosixPath.__mro__[3].__name__.__eq__", ["PurePath"],       true]
    - [posx_mro4_eq,    "PosixPath.__mro__[4].__name__.__eq__", ["object"],         true]

# ---------------------------------------------------------------------------
# pathlib.WindowsPath class identity and MRO
# __name__ == 'WindowsPath' (11), __module__ == 'pathlib' (7),
# __qualname__ == 'WindowsPath' (11), __class__.__name__ == 'type'.
# __bases__[0].__name__ == 'Path'; MRO length == 5.
# MRO: WindowsPath, Path, PureWindowsPath, PurePath, object.
# ---------------------------------------------------------------------------

table pathlib_extra147.WindowsPath_identity_mro:
  description: "pathlib.WindowsPath class identity: __name__='WindowsPath' (11), __module__='pathlib' (7), __class__.__name__='type'; MRO length 5 — WindowsPath, Path, PureWindowsPath, PurePath, object"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibwin147

  columns: [id, function, args, expected]
  rows:
    - [win_name_eq,    WindowsPath.__name__.__eq__,           ["WindowsPath"], true]
    - [win_name_len,   WindowsPath.__name__.__len__,          [],              11]
    - [win_module_eq,  WindowsPath.__module__.__eq__,         ["pathlib"],     true]
    - [win_module_len, WindowsPath.__module__.__len__,        [],              7]
    - [win_qn_eq,      WindowsPath.__qualname__.__eq__,       ["WindowsPath"], true]
    - [win_cls_eq,     WindowsPath.__class__.__name__.__eq__, ["type"],        true]
    - [win_base0_eq,   "WindowsPath.__bases__[0].__name__.__eq__", ["Path"],   true]
    - [win_mro_len,    "WindowsPath.__mro__.__len__",         [],              5]
    - [win_mro0_eq,    "WindowsPath.__mro__[0].__name__.__eq__", ["WindowsPath"],    true]
    - [win_mro1_eq,    "WindowsPath.__mro__[1].__name__.__eq__", ["Path"],           true]
    - [win_mro2_eq,    "WindowsPath.__mro__[2].__name__.__eq__", ["PureWindowsPath"], true]
    - [win_mro3_eq,    "WindowsPath.__mro__[3].__name__.__eq__", ["PurePath"],       true]
    - [win_mro4_eq,    "WindowsPath.__mro__[4].__name__.__eq__", ["object"],         true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra147.PurePath.__eq__is_function:
  description: "pathlib.PurePath.__eq__.__class__.__name__ == 'function' (PurePath comparison methods are pure Python functions defined in Lib/pathlib/_abc.py, not C slot wrappers; this distinguishes pathlib from built-in types whose __eq__ is wrapper_descriptor)"
  category: method_identity
  kind: python_call_eq
  function: "PurePath.__eq__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant pathlib_extra147.PurePath.__hash__qualname_len_17:
  description: "pathlib.PurePath.__hash__.__qualname__.__len__() == 17 ('PurePath.__hash__' has 17 characters; two more than __eq__ (15) because '__hash__' is longer than '__eq__' by two characters)"
  category: method_identity
  kind: python_call_eq
  function: "PurePath.__hash__.__qualname__.__len__"
  args: []
  expected: 17

invariant pathlib_extra147.Path.write_text_qualname_len_15:
  description: "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 characters; the longest qualname among the covered Path filesystem methods — one character longer than read_text (14))"
  category: method_identity
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra147.PosixPath.name_len_9:
  description: "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters; shorter than WindowsPath (11) by 2 — 'Posix' is 5 characters, 'Windows' is 7 characters, both sharing the 4-character 'Path' suffix)"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra147.PosixPath.mro_len_5:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 (MRO is: PosixPath, Path, PurePosixPath, PurePath, object — five entries; the deepest MRO among pathlib classes, reflecting the concrete-over-pure double-inheritance diamond)"
  category: class_identity
  kind: python_call_eq
  function: "PosixPath.__mro__.__len__"
  args: []
  expected: 5

invariant pathlib_extra147.WindowsPath.name_len_11:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters; the longest concrete class name in pathlib — two characters longer than PosixPath (9))"
  category: class_identity
  kind: python_call_eq
  function: WindowsPath.__name__.__len__
  args: []
  expected: 11
