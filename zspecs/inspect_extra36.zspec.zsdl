spec: inspect_extra36
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra35.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty.__class__.__name__.__len__()==4; Parameter.POSITIONAL_ONLY.__class__.__name__.__len__()==14; Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__len__()==14; _ParameterKind.__qualname__.__len__()==14; inspect.__all__.__len__()==107; inspect.__all__.__class__.__name__.__len__()==4; CO_OPTIMIZED==1; ArgInfo._fields.__len__(); Attribute._fields.__len__(); FrameInfo._fields.__len__(); FullArgSpec/__bases__.__len__()/mro.__len__(); findsource/__name__.__len__()==10; getmodule/__name__.__len__()==9; getfile/__name__.__len__()==7."
    - "This spec covers: cleandoc.__name__.__len__() (8 — 'cleandoc'); formatannotation.__name__.__len__() (16 — 'formatannotation', the longest function name in inspect); getattr_static.__name__.__len__() (14 — 'getattr_static'); classify_class_attrs.__name__.__len__() (20 — 'classify_class_attrs', the longest __name__ in inspect); CO_OPTIMIZED.__class__.__name__.__len__() (3 — 'int', the module-level integer constant)."
    - "Key findings: inspect.cleandoc.__name__ is 'cleandoc' (8 chars) — a string-cleaning utility, same length as iscode (6) plus 2. inspect.formatannotation.__name__ is 'formatannotation' (16 chars) — one of the longest function names in inspect. inspect.getattr_static.__name__ is 'getattr_static' (14 chars) — the non-descriptor-triggering attribute accessor. inspect.classify_class_attrs.__name__ is 'classify_class_attrs' (20 chars) — the longest __name__ of any function in inspect, surpassing iscoroutinefunction and isgeneratorfunction (both 19). inspect.CO_OPTIMIZED.__class__.__name__ is 'int' (3 chars) — the module constant is a plain integer."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# String-utility and annotation helper __name__.__len__() — extra36 namespace
#
# inspect.cleandoc.__name__ is 'cleandoc' (8 chars) — a utility that trims
# leading whitespace from docstrings. inspect.formatannotation.__name__ is
# 'formatannotation' (16 chars) — one of the longest function names in the
# inspect module. No prior inspect spec records cleandoc.__name__.__len__() or
# formatannotation.__name__.__len__() as standalone values. These two are
# recorded together for the first time in the extra36 namespace.
# ---------------------------------------------------------------------------

table inspect_extra36.utility_function_name_lengths:
  description: "inspect utility helper __name__.__len__(): cleandoc(8), formatannotation(16)"
  kind: python_call_eq
  category: string_properties
  id_prefix: utilitynamelen36

  columns: [id, function, args, expected, description]
  rows:
    - [cleandoc,
       cleandoc.__name__.__len__,
       [],
       8,
       "len(inspect.cleandoc.__name__) == 8 — 'cleandoc' (docstring whitespace-trimming utility; matches __qualname__)"]
    - [formatannotation,
       formatannotation.__name__.__len__,
       [],
       16,
       "len(inspect.formatannotation.__name__) == 16 — 'formatannotation' (one of the longest function names in inspect; matches __qualname__)"]

# ---------------------------------------------------------------------------
# Static/attribute introspection __name__.__len__() — extra36 namespace
#
# inspect.getattr_static.__name__ is 'getattr_static' (14 chars) — the
# non-descriptor-triggering attribute accessor. inspect.classify_class_attrs.
# __name__ is 'classify_class_attrs' (20 chars) — the longest __name__ of any
# function in the inspect module, surpassing iscoroutinefunction and
# isgeneratorfunction (both 19 chars). No prior inspect spec records
# getattr_static.__name__.__len__() or classify_class_attrs.__name__.__len__()
# as standalone values. These two are recorded together for the first time in
# the extra36 namespace.
# ---------------------------------------------------------------------------

table inspect_extra36.static_introspection_name_lengths:
  description: "inspect attribute/class introspection __name__.__len__(): getattr_static(14), classify_class_attrs(20)"
  kind: python_call_eq
  category: string_properties
  id_prefix: staticnamelen36

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static,
       getattr_static.__name__.__len__,
       [],
       14,
       "len(inspect.getattr_static.__name__) == 14 — 'getattr_static' (non-descriptor-triggering accessor; same length as Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__)"]
    - [classify_class_attrs,
       classify_class_attrs.__name__.__len__,
       [],
       20,
       "len(inspect.classify_class_attrs.__name__) == 20 — 'classify_class_attrs' (longest __name__ in inspect; one char longer than iscoroutinefunction and isgeneratorfunction)"]

# ---------------------------------------------------------------------------
# CO_OPTIMIZED module constant class name — extra36 namespace
#
# inspect.CO_OPTIMIZED is a module-level integer constant (value 1).
# Its __class__.__name__ is 'int' (3 chars). This confirms that Python
# compile-flag constants exported by the inspect module are plain Python
# ints, not enums or special types. No prior inspect spec records
# CO_OPTIMIZED.__class__.__name__.__len__() == 3 in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra36.CO_OPTIMIZED_classname_len:
  description: "len(inspect.CO_OPTIMIZED.__class__.__name__) == 3 — 'int' (module compile-flag constant is a plain Python integer)"
  category: string_properties
  kind: python_call_eq
  function: CO_OPTIMIZED.__class__.__name__.__len__
  args: []
  expected: 3
