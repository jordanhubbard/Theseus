spec: asyncio_extra2251
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/futures.py, Lib/asyncio/locks.py, Lib/asyncio/queues.py, Lib/asyncio/streams.py"
    - "CPython source: Modules/_asynciomodule.c — C implementation of Task and Future"
  notes:
    - "Wave 2251 (_extra2251): callable protocol and function-attribute dict-presence — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ checks."
    - "Classes checked: asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Queue, asyncio.Semaphore, asyncio.Condition, asyncio.StreamReader."
    - "asyncio.Task and asyncio.Future are C extension types; the others are pure Python classes."
    - "__call__ is NOT in __dict__ for any of these classes — they are not themselves callable-protocol types; none define __call__ in their own class body."
    - "__code__ is NOT in __dict__ for any of these classes — __code__ is an attribute of plain function objects, not of class objects."
    - "__globals__ is NOT in __dict__ for any of these classes — __globals__ is an attribute of plain function objects, not of class objects."
    - "__defaults__ is NOT in __dict__ for any of these classes — __defaults__ is an attribute of plain function objects, not of class objects."
    - "__kwdefaults__ is NOT in __dict__ for any of these classes — __kwdefaults__ is an attribute of plain function objects, not of class objects."
    - "__annotations__ is NOT in __dict__ for any of these classes — none of the eight asyncio class bodies carry a class-level __annotations__ dict entry."
    - "__builtins__ is NOT in __dict__ for any of these classes — __builtins__ is a module-level name, not a class attribute."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — all 8 asyncio classes
#
# __call__ is NOT in the __dict__ of any asyncio class checked here.
# These classes (Task, Future, Event, Lock, Queue, Semaphore, Condition,
# StreamReader) do not define a __call__ method in their own class body.
# All 8 return False.
# ---------------------------------------------------------------------------

table asyncio_extra2251.call_dict_presence:
  description: "__call__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2251

  columns: [id, function, args, expected]
  rows:
    - ["as2251001", "asyncio.Task.__dict__.__contains__", ["__call__"], false]
    - ["as2251002", "asyncio.Future.__dict__.__contains__", ["__call__"], false]
    - ["as2251003", "asyncio.Event.__dict__.__contains__", ["__call__"], false]
    - ["as2251004", "asyncio.Lock.__dict__.__contains__", ["__call__"], false]
    - ["as2251005", "asyncio.Queue.__dict__.__contains__", ["__call__"], false]
    - ["as2251006", "asyncio.Semaphore.__dict__.__contains__", ["__call__"], false]
    - ["as2251007", "asyncio.Condition.__dict__.__contains__", ["__call__"], false]
    - ["as2251008", "asyncio.StreamReader.__dict__.__contains__", ["__call__"], false]

