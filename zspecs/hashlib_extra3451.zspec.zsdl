spec: hl3451
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (hl3451): __getitem__, __setitem__, __delitem__ dict-presence checks for hashlib types."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (obj[key], obj[key]=val, del obj[key])."
    - "All values False — hashlib/uuid/struct/socket types do not implement container/mapping access protocols."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3451.getitem:
  description: "hashlib types __getitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3451
  columns: [id, function, args, expected]
  rows:
    - ["hl3451001", operator.contains, [type(hashlib.md5()).__dict__,        "__getitem__"], false]
    - ["hl3451002", operator.contains, [type(hashlib.sha1()).__dict__,       "__getitem__"], false]
    - ["hl3451003", operator.contains, [type(hashlib.sha256()).__dict__,     "__getitem__"], false]
    - ["hl3451004", operator.contains, [type(hashlib.sha512()).__dict__,     "__getitem__"], false]
    - ["hl3451005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__getitem__"], false]

