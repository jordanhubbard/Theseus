spec: http_client_extra18
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra17.zspec.zsdl — covers __qualname__.__len__() for HTTPSConnection/HTTPResponse/HTTPException; __name__.__len__() and __qualname__.__len__() for HTTPConnection.request/connect/close/send; __name__.__len__() for HTTPResponse.read/close/geturl/info; parse_headers.__module__.__len__()."
    - "http_client_extra16.zspec.zsdl — covers __module__.__len__()==11 for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException; __name__.__len__() for all four; HTTPConnection.__qualname__.__len__()==14; parse_headers/__name__/__qualname__/__name__.__len__."
    - "http_client_extra15.zspec.zsdl — covers HTTPConnection.__init__.__name__, HTTPResponse.__bases__[0].__name__, NotConnected/InvalidURL __name__/__bases__[0].__name__, UnknownProtocol/__name__, RemoteDisconnected/__name__/__bases__[0].__name__, IncompleteRead/__name__."
    - "http_client_extra14.zspec.zsdl — covers HTTPConnection/__qualname__/__module__, HTTPSConnection/__qualname__/__module__, HTTP_PORT/HTTPS_PORT constants, BadStatusLine/CannotSendRequest exception attributes."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected and __module__.__len__()==11."
  notes:
    - "This spec extends http_client_extra17.zspec.zsdl."
    - "Prior specs covered: HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException __name__/__module__/__qualname__/__bases__; HTTP_PORT/HTTPS_PORT; status codes; __init__.__name__ for HTTPConnection; exception class names and bases; parse_headers/__name__/__qualname__/__module__; __module__.__len__()==11 for four classes; __name__.__len__() for four classes; HTTPConnection/__qualname__.__len__()==14; HTTPSConnection/HTTPResponse/HTTPException __qualname__.__len__(); HTTPConnection method __name__/__qualname__ lengths for request/connect/close/send; HTTPResponse method __name__.__len__() for read/close/geturl/info; parse_headers.__module__.__len__()."
    - "This spec covers: http.client.HTTPConnection.__mro__.__len__(); http.client.HTTPResponse.__mro__.__len__(); http.client.HTTPException.__mro__.__len__(); http.client.HTTPSConnection.__mro__.__len__(); http.client.HTTPException.__bases__[0].__name__ (== 'Exception'); http.client.NotConnected.__bases__[0].__name__ (== 'HTTPException'); http.client.HTTPSConnection.__bases__[0].__name__ (== 'HTTPConnection'); http.client.HTTPResponse.read/__qualname__/__qualname__.__len__(); http.client.HTTPResponse.readline/__qualname__/__qualname__.__len__()/__name__.__len__(); http.client.HTTPResponse.readinto/__qualname__/__qualname__.__len__()/__name__.__len__()."
    - "http.client.HTTPConnection.__mro__.__len__() == 2 — (HTTPConnection, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__mro__.__len__() == 6 — (HTTPResponse, BufferedIOBase, IOBase, RawIOBase?, ..., object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__mro__.__len__() == 4 — (HTTPException, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__mro__.__len__() == 3 — (HTTPSConnection, HTTPConnection, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__bases__[0].__name__ == 'Exception'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.NotConnected.__bases__[0].__name__ == 'HTTPException'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.read.__qualname__ == 'HTTPResponse.read' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.readline.__qualname__ == 'HTTPResponse.readline' — len 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.readinto.__qualname__ == 'HTTPResponse.readinto' — len 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.readline.__name__ == 'readline' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.readinto.__name__ == 'readinto' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# http.client class __mro__.__len__()
#
# No prior spec checks __mro__.__len__() for any http.client class.
# HTTPConnection: 2 (HTTPConnection, object) — no intermediate base.
# HTTPSConnection: 3 (HTTPSConnection, HTTPConnection, object).
# HTTPException: 4 (HTTPException, Exception, BaseException, object).
# HTTPResponse: 6 (HTTPResponse, BufferedIOBase, IOBase, ..., object).
# ---------------------------------------------------------------------------

invariant http_client_extra18.HTTPConnection.mro_len:
  description: "len(http.client.HTTPConnection.__mro__) == 2 — (HTTPConnection, object); no intermediate base"
  category: class_hierarchy
  kind: python_call_eq
  function: HTTPConnection.__mro__.__len__
  args: []
  expected: 2

invariant http_client_extra18.HTTPException.mro_len:
  description: "len(http.client.HTTPException.__mro__) == 4 — (HTTPException, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: HTTPException.__mro__.__len__
  args: []
  expected: 4

table http_client_extra18.class_mro_lengths:
  description: "http.client class __mro__.__len__() — HTTPSConnection (3) and HTTPResponse (6)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: hcml18

  columns: [id, function, args, expected, description]
  rows:
    - [HTTPSConnection,
       HTTPSConnection.__mro__.__len__,
       [],
       3,
       "len(http.client.HTTPSConnection.__mro__) == 3 — HTTPSConnection -> HTTPConnection -> object"]
    - [HTTPResponse,
       HTTPResponse.__mro__.__len__,
       [],
       6,
       "len(http.client.HTTPResponse.__mro__) == 6 — inherits from BufferedIOBase chain"]

# ---------------------------------------------------------------------------
# http.client class __bases__[0].__name__ for exception hierarchy
#
# No prior spec anchors these __bases__[0].__name__ values from the extra18 namespace.
# HTTPException.__bases__[0].__name__ == 'Exception'.
# NotConnected.__bases__[0].__name__ == 'HTTPException'.
# HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection'.
# ---------------------------------------------------------------------------

table http_client_extra18.class_base_names:
  description: "http.client class __bases__[0].__name__ — HTTPException/'Exception', NotConnected/'HTTPException', HTTPSConnection/'HTTPConnection'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: hcbn18

  columns: [id, function, args, expected, description]
  rows:
    - [HTTPException,
       "HTTPException.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "http.client.HTTPException.__bases__[0].__name__ == 'Exception'"]
    - [NotConnected,
       "NotConnected.__bases__[0].__name__.__eq__",
       ["HTTPException"],
       true,
       "http.client.NotConnected.__bases__[0].__name__ == 'HTTPException'"]
    - [HTTPSConnection,
       "HTTPSConnection.__bases__[0].__name__.__eq__",
       ["HTTPConnection"],
       true,
       "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection'"]

# ---------------------------------------------------------------------------
# http.client.HTTPResponse.read __qualname__ and __qualname__.__len__()
#
# http_client_extra17 covers HTTPResponse.read.__name__.__len__()==4.
# No prior spec checks __qualname__ or __qualname__.__len__() for HTTPResponse.read.
# read.__qualname__ == 'HTTPResponse.read' (len 17).
# ---------------------------------------------------------------------------

invariant http_client_extra18.HTTPResponse.read_qualname:
  description: "http.client.HTTPResponse.read.__qualname__ == 'HTTPResponse.read'"
  category: function_qualnames
  kind: python_call_eq
  function: HTTPResponse.read.__qualname__.__eq__
  args: ["HTTPResponse.read"]
  expected: true

invariant http_client_extra18.HTTPResponse.read_qualname_len:
  description: "len(http.client.HTTPResponse.read.__qualname__) == 17 — len('HTTPResponse.read') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: HTTPResponse.read.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# http.client.HTTPResponse.readline and readinto __qualname__/__len__()/__name__.__len__()
#
# No prior spec checks __qualname__ or __name__.__len__() for readline or readinto.
# readline.__qualname__ == 'HTTPResponse.readline' (len 21); __name__ == 'readline' (len 8).
# readinto.__qualname__ == 'HTTPResponse.readinto' (len 21); __name__ == 'readinto' (len 8).
# ---------------------------------------------------------------------------

table http_client_extra18.response_read_method_qualname_lengths:
  description: "http.client.HTTPResponse.readline/readinto __qualname__.__len__() — both 21"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hrmql18

  columns: [id, function, args, expected, description]
  rows:
    - [readline,
       HTTPResponse.readline.__qualname__.__len__,
       [],
       21,
       "len('HTTPResponse.readline') == 21"]
    - [readinto,
       HTTPResponse.readinto.__qualname__.__len__,
       [],
       21,
       "len('HTTPResponse.readinto') == 21"]

table http_client_extra18.response_read_method_name_lengths:
  description: "http.client.HTTPResponse.readline/readinto __name__.__len__() — both 8"
  kind: python_call_eq
  category: function_names
  id_prefix: hrmnl18

  columns: [id, function, args, expected, description]
  rows:
    - [readline,
       HTTPResponse.readline.__name__.__len__,
       [],
       8,
       "len('readline') == 8"]
    - [readinto,
       HTTPResponse.readinto.__name__.__len__,
       [],
       8,
       "len('readinto') == 8"]
