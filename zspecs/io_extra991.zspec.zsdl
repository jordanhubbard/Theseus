spec: io_extra991
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module BytesIO and StringIO documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.BytesIO and io.StringIO method __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra991.bytesio_method_qualnames:
  description: "io.BytesIO method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io991x
  columns: [id, function, args, expected]
  rows:
    - [io991x001, io.BytesIO.read.__qualname__.__eq__,     ["BytesIO.read"],     true]
    - [io991x002, io.BytesIO.write.__qualname__.__eq__,    ["BytesIO.write"],    true]
    - [io991x003, io.BytesIO.seek.__qualname__.__eq__,     ["BytesIO.seek"],     true]
    - [io991x004, io.BytesIO.tell.__qualname__.__eq__,     ["BytesIO.tell"],     true]
    - [io991x005, io.BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true]

table io_extra991.stringio_method_qualnames:
  description: "io.StringIO method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io991s
  columns: [id, function, args, expected]
  rows:
    - [io991s001, io.StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true]
    - [io991s002, io.StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true]
    - [io991s003, io.StringIO.seek.__qualname__.__eq__,     ["StringIO.seek"],     true]
    - [io991s004, io.StringIO.tell.__qualname__.__eq__,     ["StringIO.tell"],     true]
    - [io991s005, io.StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true]

table io_extra991.class_identity:
  description: "io.BytesIO and io.StringIO class identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: io991c
  columns: [id, function, args, expected]
  rows:
    - [io991c001, io.BytesIO.__module__.__eq__,              ["io"],          true]
    - [io991c002, io.StringIO.__module__.__eq__,             ["io"],          true]
    - [io991c003, io.BytesIO.__qualname__.__eq__,            ["BytesIO"],     true]
    - [io991c004, io.StringIO.__qualname__.__eq__,           ["StringIO"],    true]
    - [io991c005, io.BytesIO.__class__.__name__.__eq__,      ["type"],        true]
    - [io991c006, io.StringIO.__class__.__name__.__eq__,     ["type"],        true]
