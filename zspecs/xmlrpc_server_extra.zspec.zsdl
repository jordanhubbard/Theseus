spec: xmlrpc_server_extra
version: ">=3.0"
backend: python_module(xmlrpc.server)

docs: https://docs.python.org/3/library/xmlrpc.server.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xmlrpc.server.html — Python xmlrpc.server module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/server.py"
  notes:
    - "This spec extends xmlrpc_server.zspec.zsdl."
    - "Focus: __qualname__ attributes and Fault class not yet covered."
    - "xmlrpc.server.SimpleXMLRPCServer.__qualname__ == 'SimpleXMLRPCServer' — top-level class."
    - "xmlrpc.server.MultiPathXMLRPCServer.__qualname__ == 'MultiPathXMLRPCServer'."
    - "xmlrpc.server.SimpleXMLRPCRequestHandler.__qualname__ == 'SimpleXMLRPCRequestHandler'."
    - "xmlrpc.server.SimpleXMLRPCDispatcher.__qualname__ == 'SimpleXMLRPCDispatcher'."
    - "xmlrpc.server.CGIXMLRPCRequestHandler.__qualname__ == 'CGIXMLRPCRequestHandler'."
    - "xmlrpc.server.Fault is re-exported from xmlrpc.client; Fault.__qualname__ == 'Fault'."
    - "xmlrpc.server.SimpleXMLRPCServer.__module__ == 'xmlrpc.server'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — server and handler classes
# xmlrpc_server.zspec.zsdl covers __name__; this spec adds __qualname__.
# ---------------------------------------------------------------------------

table xmlrpc_server_extra.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [SimpleXMLRPCServer,         SimpleXMLRPCServer.__qualname__.__eq__,         ["SimpleXMLRPCServer"],         true]
    - [MultiPathXMLRPCServer,      MultiPathXMLRPCServer.__qualname__.__eq__,      ["MultiPathXMLRPCServer"],      true]
    - [SimpleXMLRPCRequestHandler, SimpleXMLRPCRequestHandler.__qualname__.__eq__, ["SimpleXMLRPCRequestHandler"], true]
    - [SimpleXMLRPCDispatcher,     SimpleXMLRPCDispatcher.__qualname__.__eq__,     ["SimpleXMLRPCDispatcher"],     true]
    - [CGIXMLRPCRequestHandler,    CGIXMLRPCRequestHandler.__qualname__.__eq__,    ["CGIXMLRPCRequestHandler"],    true]
    - [Fault,                      Fault.__qualname__.__eq__,                      ["Fault"],                      true]

# ---------------------------------------------------------------------------
# __module__ check — SimpleXMLRPCServer
# xmlrpc_server.zspec.zsdl has a standalone invariant for this; we add it
# here as a table-companion standalone to anchor the qualname bundle.
# ---------------------------------------------------------------------------

invariant xmlrpc_server_extra.SimpleXMLRPCServer.module:
  description: "xmlrpc.server.SimpleXMLRPCServer.__module__ == 'xmlrpc.server'"
  category: modules
  kind: python_call_eq
  function: SimpleXMLRPCServer.__module__.__eq__
  args: ["xmlrpc.server"]
  expected: true
