    - "threading.__loader__.__class__.__module__.__len__() == 26 ('_frozen_importlib_external'). Verified with Python 3.14.3."
    - "threading.__spec__.origin.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "threading.__spec__.parent == '' (empty string, len 0). Verified with Python 3.14.3."
    - "threading.__spec__.cached.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__spec__.__class__ name and module string lengths
#
# Wave 269 theme: threading.__spec__ is an instance of importlib.machinery.
# ModuleSpec, whose class is defined in _frozen_importlib. Previously covered
# in extra103: __spec__.__class__.__name__.__eq__ ('ModuleSpec') and
# __spec__.__class__.__module__.__eq__ ('_frozen_importlib'). New here:
# the string lengths — __spec__.__class__.__name__.__len__() == 10
# ('ModuleSpec' is 10 chars) and __spec__.__class__.__module__.__len__() == 17
# ('_frozen_importlib' is 17 chars). The module string (17) is much longer than
# the class name (10).
#
# __spec__.__class__.__name__.__len__() == 10
# __spec__.__class__.__module__.__len__() == 17
#
# New to extra119.
# ---------------------------------------------------------------------------

table threading_extra119.spec_class_name_module_lens:
  description: "threading.__spec__ class string lengths: __class__.__name__ len=10 ('ModuleSpec'), __class__.__module__ len=17 ('_frozen_importlib'); module string longer than class name; wave 269; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingscnml119

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_len,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "threading.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 chars: M-o-d-u-l-e(6)+S-p-e-c(4); the importlib ModuleSpec class name; str.__len__() returns 10; new to extra119"]
    - [spec_class_module_len,
       "__spec__.__class__.__module__.__len__",
       [],
       17,
       "threading.__spec__.__class__.__module__.__len__() == 17 — '_frozen_importlib' has 17 chars: _(1)+f-r-o-z-e-n(6)+_(1)+i-m-p-o-r-t-l-i-b(9); the frozen bootstrap module where ModuleSpec is defined; str.__len__() returns 17; new to extra119"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — confirming the spec class name for anchoring the length comparisons; already covered in extra103 but repeated for context; str.__eq__ returns True; new to extra119"]
    - [spec_class_module_vs_name_len_diff,
       "__spec__.__class__.__module__.__len__",
       [],
       17,
       "threading.__spec__.__class__.__module__.__len__() == 17 — '_frozen_importlib' (17) is 7 chars longer than 'ModuleSpec' (10); the module name is longer than the class name it contains; str.__len__() returns 17; new to extra119"]
    - [spec_class_name_len_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "threading.__spec__.__class__.__name__.__len__() == 10 — anchor: 'ModuleSpec' has 10 chars; used as comparison baseline against __class__.__module__ len (17) and loader class name len (16); str.__len__() returns 10; new to extra119"]

# ---------------------------------------------------------------------------
# Table 2: threading.__loader__.__class__ name and module string lengths
#
# Wave 269 theme: threading.__loader__ is an instance of SourceFileLoader,
# which is defined in importlib._bootstrap_external (frozen as
# _frozen_importlib_external). Previously covered in extra103:
# __loader__.__class__.__name__.__eq__ ('SourceFileLoader') and
# __loader__.__class__.__module__.__eq__ ('_frozen_importlib_external').
# New here: the string lengths — __loader__.__class__.__name__.__len__() == 16
# ('SourceFileLoader' is 16 chars) and
# __loader__.__class__.__module__.__len__() == 26
# ('_frozen_importlib_external' is 26 chars, the longest string in these tables).
#
# __loader__.__class__.__name__.__len__() == 16
# __loader__.__class__.__module__.__len__() == 26
#
# New to extra119.
# ---------------------------------------------------------------------------

