       [],
       16,
       "threading.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 chars: S-o-u-r-c-e(6)+F-i-l-e(4)+L-o-a-d-e-r(6); the loader class for pure-Python .py files; str.__len__() returns 16; new to extra119"]
    - [loader_class_module_len,
       "__loader__.__class__.__module__.__len__",
       [],
       26,
       "threading.__loader__.__class__.__module__.__len__() == 26 — '_frozen_importlib_external' has 26 chars: _(1)+f-r-o-z-e-n(6)+_(1)+i-m-p-o-r-t-l-i-b(9)+_(1)+e-x-t-e-r-n-a-l(8); the longest module string in these threading specs; str.__len__() returns 26; new to extra119"]
    - [loader_class_name_eq,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — confirming the loader class name (16 chars) for context; str.__eq__('SourceFileLoader') returns True; new to extra119"]
    - [loader_class_module_eq,
       "__loader__.__class__.__module__.__eq__",
       ["_frozen_importlib_external"],
       true,
       "threading.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True — confirming the loader class module (26 chars) for context; str.__eq__('_frozen_importlib_external') returns True; new to extra119"]
    - [loader_class_module_26_vs_spec_module_17,
       "__loader__.__class__.__module__.__len__",
       [],
       26,
       "threading.__loader__.__class__.__module__.__len__() == 26 — '_frozen_importlib_external' (26) is 9 chars longer than '_frozen_importlib' (17); the external bootstrap adds '_external' (9 chars) to distinguish it; str.__len__() returns 26; new to extra119"]

# ---------------------------------------------------------------------------
# Table 3: threading.__spec__.origin, parent, and cached class attributes
#
# Wave 269 theme: threading.__spec__ carries several secondary attributes.
# origin is the filesystem path to threading.py — a str value; its
# __class__.__name__ is 'str'. parent is the empty string '' for a top-level
# module (no parent package) — len 0 and __class__.__name__ is 'str'. cached
# is the path to the .pyc bytecode cache file — also a str, so its
# __class__.__name__ is 'str'. All three are str values, confirming that the
# path-like attributes of ModuleSpec are plain Python strings. None of these
# have been covered in prior threading specs.
#
# __spec__.origin.__class__.__name__ == 'str'
# __spec__.parent.__len__() == 0     (parent is '' for top-level module)
# __spec__.cached.__class__.__name__ == 'str'
#
# New to extra119.
# ---------------------------------------------------------------------------

table threading_extra119.spec_origin_parent_cached_attrs:
  description: "threading.__spec__ path attrs: origin.__class__.__name__='str', parent='' (len 0), cached.__class__.__name__='str'; all three path attributes are plain Python strings; top-level module has empty parent; wave 269; new to extra119"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingsopc119

  columns: [id, function, args, expected, description]
  rows:
    - [spec_origin_class_name,
       "__spec__.origin.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.__spec__.origin.__class__.__name__.__eq__('str') == True — origin holds the filesystem path to threading.py; it is a plain Python str; __class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; new to extra119"]
    - [spec_parent_len,
       "__spec__.parent.__len__",
       [],
       0,
       "threading.__spec__.parent.__len__() == 0 — threading is a top-level stdlib module with no parent package; parent is the empty string ''; len('') == 0; str.__len__() returns 0; new to extra119"]
    - [spec_parent_class_name,
       "__spec__.parent.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.__spec__.parent.__class__.__name__.__eq__('str') == True — parent is the empty string ''; its __class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; new to extra119"]
    - [spec_cached_class_name,
       "__spec__.cached.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.__spec__.cached.__class__.__name__.__eq__('str') == True — cached holds the path to the .pyc bytecode file; it is a plain Python str; __class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; new to extra119"]
    - [spec_parent_eq_empty,
       "__spec__.parent.__eq__",
       [""],
       true,
       "threading.__spec__.parent.__eq__('') == True — parent is the empty string for a top-level module; threading has no containing package; str.__eq__('') returns True; new to extra119"]

