spec: multiprocessing_extra249
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.cpu_count.__name__ == 'cpu_count' (len=9); __qualname__ == 'BaseContext.cpu_count' (len=21); __module__ == 'multiprocessing.context' (len=23); __class__.__name__ == 'method'."
    - "multiprocessing.current_process.__name__ == 'current_process' (len=15); __module__ == 'multiprocessing.process' (len=23); __class__.__name__ == 'function'."
    - "multiprocessing.active_children.__name__ == 'active_children' (len=15); __module__ == 'multiprocessing.process' (len=23); __class__.__name__ == 'function'."
    - "current_process and active_children share the same __name__ length (15) and __module__ (multiprocessing.process, len=23)."
    - "cpu_count is a bound method (method) of a context object; current_process and active_children are plain functions — different object types."
    - "cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21) — the 'BaseContext.' prefix reveals it is defined on BaseContext; qualname len 21 vs name len 9 difference is 12 (len of 'BaseContext.')."
    - "multiprocessing.Process.pid, exitcode, name, and daemon are all 'property' objects."
    - "multiprocessing.Process.__name__ == 'Process' (len=7); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'BaseProcess' (len=11)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.cpu_count function identity
#
# multiprocessing.cpu_count.__name__ == 'cpu_count' (len=9)
# multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21)
# multiprocessing.cpu_count.__module__ == 'multiprocessing.context' (len=23)
# multiprocessing.cpu_count.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra249.cpu_count_identity:
  description: "multiprocessing.cpu_count identity — name='cpu_count'(len=9), qualname='BaseContext.cpu_count'(len=21), module='multiprocessing.context'(len=23), class='method'; cpu_count is a bound method unlike current_process/active_children which are functions; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: mp249cc

  columns: [id, function, args, expected, description]
  rows:
    - [cc_name_eq,         multiprocessing.cpu_count.__name__.__eq__,              ["cpu_count"],                     true, "multiprocessing.cpu_count.__name__ == 'cpu_count'; verified with Python 3.14.4"]
    - [cc_name_len,        multiprocessing.cpu_count.__name__.__len__,             [],                                9,    "multiprocessing.cpu_count.__name__.__len__() == 9; verified with Python 3.14.4"]
    - [cc_qn_eq,           multiprocessing.cpu_count.__qualname__.__eq__,          ["BaseContext.cpu_count"],         true, "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count'; verified with Python 3.14.4"]
    - [cc_qn_len,          multiprocessing.cpu_count.__qualname__.__len__,         [],                                21,   "multiprocessing.cpu_count.__qualname__.__len__() == 21 — 'BaseContext.' prefix (12 chars) + name (9 chars); verified with Python 3.14.4"]
    - [cc_mod_eq,          multiprocessing.cpu_count.__module__.__eq__,            ["multiprocessing.context"],       true, "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'; verified with Python 3.14.4"]
    - [cc_mod_len,         multiprocessing.cpu_count.__module__.__len__,           [],                                23,   "multiprocessing.cpu_count.__module__.__len__() == 23; verified with Python 3.14.4"]
    - [cc_cls_eq,          multiprocessing.cpu_count.__class__.__name__.__eq__,    ["method"],                        true, "multiprocessing.cpu_count.__class__.__name__ == 'method' — cpu_count is a bound context method; verified with Python 3.14.4"]

