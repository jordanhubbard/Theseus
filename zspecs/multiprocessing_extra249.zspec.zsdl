# type(multiprocessing.Process.daemon).__name__ == 'property'
# ---------------------------------------------------------------------------

table multiprocessing_extra249.process_class_identity:
  description: "multiprocessing.Process(len=7) class identity — inherits from BaseProcess(len=11); defined in multiprocessing.context(len=23); pid, exitcode, name, and daemon are all property descriptors; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: mp249pc

  columns: [id, function, args, expected, description]
  rows:
    - [pc_name_eq,         multiprocessing.Process.__name__.__eq__,                ["Process"],                       true, "multiprocessing.Process.__name__ == 'Process'; verified with Python 3.14.4"]
    - [pc_name_len,        multiprocessing.Process.__name__.__len__,               [],                                7,    "multiprocessing.Process.__name__.__len__() == 7; verified with Python 3.14.4"]
    - [pc_mod_eq,          multiprocessing.Process.__module__.__eq__,              ["multiprocessing.context"],       true, "multiprocessing.Process.__module__ == 'multiprocessing.context'; verified with Python 3.14.4"]
    - [pc_mod_len,         multiprocessing.Process.__module__.__len__,             [],                                23,   "multiprocessing.Process.__module__.__len__() == 23 — same as cpu_count module length; verified with Python 3.14.4"]
    - [pc_base_eq,         "multiprocessing.Process.__bases__[0].__name__.__eq__", ["BaseProcess"],                   true, "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits from BaseProcess; verified with Python 3.14.4"]
    - [pc_base_len,        "multiprocessing.Process.__bases__[0].__name__.__len__", [],                               11,   "multiprocessing.Process.__bases__[0].__name__.__len__() == 11 — 'BaseProcess'; verified with Python 3.14.4"]
    - [pc_pid_type,        "multiprocessing.Process.pid.__class__.__name__.__eq__", ["property"],                     true, "type(multiprocessing.Process.pid).__name__ == 'property' — pid is a property descriptor; verified with Python 3.14.4"]
    - [pc_exitcode_type,   "multiprocessing.Process.exitcode.__class__.__name__.__eq__", ["property"],                true, "type(multiprocessing.Process.exitcode).__name__ == 'property' — exitcode is a property descriptor; verified with Python 3.14.4"]
    - [pc_name_type,       "multiprocessing.Process.name.__class__.__name__.__eq__", ["property"],                    true, "type(multiprocessing.Process.name).__name__ == 'property' — name is a property descriptor; verified with Python 3.14.4"]
    - [pc_daemon_type,     "multiprocessing.Process.daemon.__class__.__name__.__eq__", ["property"],                  true, "type(multiprocessing.Process.daemon).__name__ == 'property' — daemon is a property descriptor; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra249
# ---------------------------------------------------------------------------

invariant multiprocessing_extra249.cpu_count_is_bound_method:
  description: "multiprocessing.cpu_count.__class__.__name__.__eq__('method') returns True — cpu_count is a bound method of a DefaultContext instance (unlike current_process and active_children which are plain functions); cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21) reveals its origin on BaseContext; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra249.current_process_and_active_children_share_name_length:
  description: "multiprocessing.current_process.__name__.__len__() == 15 — both current_process and active_children have __name__ length 15; both are plain functions in multiprocessing.process (len=23); this distinguishes them from cpu_count which is a 'method' in multiprocessing.context (len=23, same length); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: multiprocessing.current_process.__name__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra249.process_properties_are_property_type:
  description: "multiprocessing.Process.pid.__class__.__name__.__eq__('property') returns True — all four Process attributes (pid, exitcode, name, daemon) are property descriptors; this is consistent with them being read-only or read-write attributes accessed via descriptor protocol; Process inherits from BaseProcess (len=11); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.pid.__class__.__name__.__eq__"
  args: ["property"]
  expected: true
