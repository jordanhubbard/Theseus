# multiprocessing.active_children.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra249.process_functions_identity:
  description: "multiprocessing.current_process(len=15) and active_children(len=15) function identity — both are plain functions (class='function') in multiprocessing.process(len=23); both share name length 15 and same module; unlike cpu_count they are not bound methods; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: mp249pf

  columns: [id, function, args, expected, description]
  rows:
    - [cp_name_eq,         multiprocessing.current_process.__name__.__eq__,        ["current_process"],               true, "multiprocessing.current_process.__name__ == 'current_process'; verified with Python 3.14.4"]
    - [cp_name_len,        multiprocessing.current_process.__name__.__len__,       [],                                15,   "multiprocessing.current_process.__name__.__len__() == 15 — same length as active_children; verified with Python 3.14.4"]
    - [cp_qn_eq,           multiprocessing.current_process.__qualname__.__eq__,    ["current_process"],               true, "multiprocessing.current_process.__qualname__ == 'current_process' — module-level function, qualname equals name; verified with Python 3.14.4"]
    - [cp_mod_eq,          multiprocessing.current_process.__module__.__eq__,      ["multiprocessing.process"],       true, "multiprocessing.current_process.__module__ == 'multiprocessing.process'; verified with Python 3.14.4"]
    - [cp_mod_len,         multiprocessing.current_process.__module__.__len__,     [],                                23,   "multiprocessing.current_process.__module__.__len__() == 23 — same length as cpu_count module; verified with Python 3.14.4"]
    - [cp_cls_eq,          multiprocessing.current_process.__class__.__name__.__eq__, ["function"],                   true, "multiprocessing.current_process.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.4"]
    - [ac_name_eq,         multiprocessing.active_children.__name__.__eq__,        ["active_children"],               true, "multiprocessing.active_children.__name__ == 'active_children'; verified with Python 3.14.4"]
    - [ac_name_len,        multiprocessing.active_children.__name__.__len__,       [],                                15,   "multiprocessing.active_children.__name__.__len__() == 15 — same length as current_process; verified with Python 3.14.4"]
    - [ac_qn_eq,           multiprocessing.active_children.__qualname__.__eq__,    ["active_children"],               true, "multiprocessing.active_children.__qualname__ == 'active_children' — module-level function, qualname equals name; verified with Python 3.14.4"]
    - [ac_mod_eq,          multiprocessing.active_children.__module__.__eq__,      ["multiprocessing.process"],       true, "multiprocessing.active_children.__module__ == 'multiprocessing.process' — same module as current_process; verified with Python 3.14.4"]
    - [ac_cls_eq,          multiprocessing.active_children.__class__.__name__.__eq__, ["function"],                   true, "multiprocessing.active_children.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.4"]

