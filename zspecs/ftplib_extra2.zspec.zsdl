spec: ftplib_extra2
version: ">=3.9"
backend: python_module(ftplib)

docs: https://docs.python.org/3/library/ftplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ftplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ftplib.py internal socket handling"
    - "ftplib.zspec.zsdl — covers class names table (FTP/FTP_TLS/error_reply/error_temp/error_perm/error_proto), FTP.__module__, FTP.port, Error.__bases__[0].__name__, exception_bases table, FTP method names"
    - "ftplib_extra.zspec.zsdl — covers FTP_TLS.__module__, FTP_TLS.__bases__[0].__name__, all_errors.__class__.__name__, all_errors.__len__, all_errors element names (Error/OSError/EOFError), error_proto.__module__"
  notes:
    - "This spec extends ftplib.zspec.zsdl and ftplib_extra.zspec.zsdl with new vectors."
    - "ftplib.all_errors is a tuple (not a class); all_errors.__class__.__name__ == 'tuple'."
    - "ftplib.MSG_OOB is an integer constant (value 0x1); MSG_OOB.__class__.__name__ == 'int'."
    - "ftplib.error_reply.__module__ == 'ftplib' — module check not covered for error_reply in prior specs."
    - "ftplib.error_temp.__module__ == 'ftplib' — module check not covered for error_temp in prior specs."
    - "ftplib.error_perm.__module__ == 'ftplib' — module check not covered for error_perm in prior specs."
    - "ftplib.Error.__name__ == 'Error' — the base ftplib exception class name."
    - "ftplib.Error.__module__ == 'ftplib'."
    - "ftplib.FTP_TLS.__name__ == 'FTP_TLS' — covered in ftplib.zspec table; repeated as a standalone invariant."
    - "ftplib.FTP.port.__class__.__name__ == 'int' — the port class attribute is an integer."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class module checks — error_reply, error_temp, error_perm
# (ftplib_extra covers error_proto.__module__; this adds the remaining three.)
# ---------------------------------------------------------------------------

table ftplib_extra2.exception_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [error_reply, error_reply.__module__.__eq__, ["ftplib"], true]
    - [error_temp,  error_temp.__module__.__eq__,  ["ftplib"], true]
    - [error_perm,  error_perm.__module__.__eq__,  ["ftplib"], true]

# ---------------------------------------------------------------------------
# ftplib.Error — base exception class name and module
# (ftplib.zspec covers Error.__bases__ hierarchy but not Error.__name__ or module.)
# ---------------------------------------------------------------------------

invariant ftplib_extra2.Error.name:
  description: "ftplib.Error.__name__ == 'Error' — base ftplib exception class"
  category: class_names
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant ftplib_extra2.Error.module:
  description: "ftplib.Error.__module__ == 'ftplib'"
  category: class_modules
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["ftplib"]
  expected: true

# ---------------------------------------------------------------------------
# ftplib.MSG_OOB — integer constant (out-of-band data flag)
# ---------------------------------------------------------------------------

invariant ftplib_extra2.MSG_OOB.class_name:
  description: "ftplib.MSG_OOB.__class__.__name__ == 'int' — MSG_OOB is an integer constant"
  category: constants
  kind: python_call_eq
  function: MSG_OOB.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ftplib.FTP.port class attribute type — is an int
# (ftplib.zspec covers FTP.port == 21; this adds type check.)
# ---------------------------------------------------------------------------

invariant ftplib_extra2.FTP.port_class_name:
  description: "ftplib.FTP.port.__class__.__name__ == 'int' — port is an integer class attribute"
  category: constants
  kind: python_call_eq
  function: FTP.port.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class names table — standalone invariants for the four error types
# (ftplib.zspec covers these in a table; this spec adds as standalone invariants
#  for cross-spec verification.)
# ---------------------------------------------------------------------------

table ftplib_extra2.exception_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [error_reply, error_reply.__name__.__eq__, ["error_reply"], true]
    - [error_temp,  error_temp.__name__.__eq__,  ["error_temp"],  true]
    - [error_perm,  error_perm.__name__.__eq__,  ["error_perm"],  true]
    - [error_proto, error_proto.__name__.__eq__,  ["error_proto"], true]

# ---------------------------------------------------------------------------
# all_errors[3].__name__ — the fourth element is ssl.SSLError
# (ftplib_extra covers indices 0-2; this adds index 3.)
# ---------------------------------------------------------------------------

invariant ftplib_extra2.all_errors.sslerror:
  description: "ftplib.all_errors[3].__name__ == 'SSLError' — the fourth element is ssl.SSLError"
  category: all_errors
  kind: python_call_eq
  function: all_errors.__getitem__
  args: [3]
  method: __name__
  expected: "SSLError"
