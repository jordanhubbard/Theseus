spec: dis_extra9
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers __name__ for Instruction/Bytecode/dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis/disassemble/get_instructions/findlinestarts/findlabels/code_info; Instruction/__name__/__module__/__bases__[0]; Bytecode/__name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; Instruction._fields class/contains-opname/contains-opcode; opname.__len__ >= 100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__; Instruction._fields[0] == 'opname'; show_code/__module__; distb/__module__"
    - "dis_extra6.zspec.zsdl — covers hasjabs empty list; hasjrel/hasconst/hascompare/hasfree class+len; Instruction._fields[1]/'opcode' and _fields[2]/'arg'; opmap LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME values; opname[82] == 'LOAD_CONST'"
    - "dis_extra7.zspec.zsdl — covers Instruction._fields[3]/'argval' and _fields[4]/'argrepr'; hasexc class and nonempty; hasarg class and nonempty; Bytecode.__bases__[0].__name__ == 'object'; opmap BINARY_OP/CALL/RESUME; opname idx31/idx116/idx35"
    - "dis_extra8.zspec.zsdl — covers __module__ for dis/disassemble/distb/code_info/show_code/get_instructions/findlinestarts/findlabels/stack_effect; Bytecode/__name__/__module__; Instruction/__name__/__module__ (standalone extra8-namespace)"
  notes:
    - "This spec covers Instruction._fields entries [5]-[11] not verified in any prior spec."
    - "dis.Instruction._fields[5] == 'offset' — byte offset within bytecode; not checked in any prior spec."
    - "dis.Instruction._fields[6] == 'start_offset' — start byte offset (Python 3.12+); not checked in any prior spec."
    - "dis.Instruction._fields[7] == 'starts_line' — deprecated bool in 3.12; not checked in any prior spec."
    - "dis.Instruction._fields[8] == 'line_number' — source line number (Python 3.12+); not checked in any prior spec."
    - "dis.Instruction._fields[9] == 'label' — jump target label (Python 3.12+); not checked in any prior spec."
    - "dis.Instruction._fields[10] == 'positions' — source position info (Python 3.11+); not checked in any prior spec."
    - "dis.Instruction._fields[11] == 'cache_info' — cache slot info (Python 3.12+); not checked in any prior spec."
    - "dis.Instruction._fields.__len__() == 12 — total field count; not checked in any prior spec."
    - "opmap BUILD_TUPLE == 51 and opname[51] == 'BUILD_TUPLE' — round-trip not verified in any prior spec."
    - "opmap BUILD_LIST == 46 and opname[46] == 'BUILD_LIST' — round-trip not verified in any prior spec."
    - "opmap COMPARE_OP == 56 — not verified in any prior spec."
    - "opmap IMPORT_NAME == 73 and IMPORT_FROM == 72 — not verified in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Instruction._fields[5] through [11] — new fields in Python 3.12
# dis_extra5 confirmed _fields[0] == 'opname'.
# dis_extra6 confirmed _fields[1] == 'opcode', _fields[2] == 'arg'.
# dis_extra7 confirmed _fields[3] == 'argval', _fields[4] == 'argrepr'.
# Fields [5]-[11] have not been verified in any prior spec.
# ---------------------------------------------------------------------------

table dis_extra9.instruction_fields_5_to_11:
  kind: python_call_eq
  category: instruction_fields
  id_prefix: field

  columns: [id, function, args, expected]
  rows:
    - [idx5,  Instruction._fields.__getitem__, [5],  "offset"]
    - [idx6,  Instruction._fields.__getitem__, [6],  "start_offset"]
    - [idx7,  Instruction._fields.__getitem__, [7],  "starts_line"]
    - [idx8,  Instruction._fields.__getitem__, [8],  "line_number"]
    - [idx9,  Instruction._fields.__getitem__, [9],  "label"]
    - [idx10, Instruction._fields.__getitem__, [10], "positions"]
    - [idx11, Instruction._fields.__getitem__, [11], "cache_info"]

# ---------------------------------------------------------------------------
# Instruction._fields total count
# No prior spec verifies the total number of fields. In Python 3.12 the
# Instruction namedtuple has 12 fields.
# ---------------------------------------------------------------------------

invariant dis_extra9.Instruction.fields_len:
  description: "len(dis.Instruction._fields) == 12 — total fields in Python 3.12 Instruction namedtuple"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# opmap entries for collection-building and comparison opcodes
# dis_extra6 covers LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME.
# dis_extra7 covers BINARY_OP/CALL/RESUME.
# New here: BUILD_TUPLE, BUILD_LIST, COMPARE_OP, IMPORT_NAME, IMPORT_FROM.
# ---------------------------------------------------------------------------

table dis_extra9.opmap_collection_import_ops:
  kind: python_call_eq
  category: opmap
  id_prefix: opmap

  columns: [id, function, args, expected]
  rows:
    - [BUILD_TUPLE,  opmap.__getitem__, ["BUILD_TUPLE"],  51]
    - [BUILD_LIST,   opmap.__getitem__, ["BUILD_LIST"],   46]
    - [COMPARE_OP,   opmap.__getitem__, ["COMPARE_OP"],   56]
    - [IMPORT_NAME,  opmap.__getitem__, ["IMPORT_NAME"],  73]
    - [IMPORT_FROM,  opmap.__getitem__, ["IMPORT_FROM"],  72]

# ---------------------------------------------------------------------------
# opname round-trip: verify opname[opmap[X]] == X for new opcodes
# dis_extra6 checks opname[82] == 'LOAD_CONST'.
# dis_extra7 checks opname[31]/[116]/[35].
# New here: round-trip for BUILD_TUPLE(51), BUILD_LIST(46), COMPARE_OP(56),
# IMPORT_NAME(73), IMPORT_FROM(72).
# ---------------------------------------------------------------------------

table dis_extra9.opname_indexed_access:
  kind: python_call_eq
  category: opname
  id_prefix: opname

  columns: [id, function, args, expected]
  rows:
    - [idx51, opname.__getitem__, [51], "BUILD_TUPLE"]
    - [idx46, opname.__getitem__, [46], "BUILD_LIST"]
    - [idx56, opname.__getitem__, [56], "COMPARE_OP"]
    - [idx73, opname.__getitem__, [73], "IMPORT_NAME"]
    - [idx72, opname.__getitem__, [72], "IMPORT_FROM"]
