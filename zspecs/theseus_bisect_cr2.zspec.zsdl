spec: theseus_bisect_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_bisect_cr2)
blocks: bisect

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html"
  notes:
    - "Clean-room extended bisect utilities. Do NOT import bisect."
    - "insort(a, x): insert x into sorted list a (same as insort_right)."
    - "insort_left(a, x): insert x at leftmost position keeping a sorted."
    - "insort_right(a, x): insert x at rightmost position keeping a sorted."
    - "bisect2_insort(): a=[1,3,5]; insort(a, 4); a == [1,3,4,5]."
    - "bisect2_insort_left(): a=[1,3,3,5]; insort_left(a, 3); a[1] == 3."
    - "bisect2_insort_right(): a=[1,2]; insort_right(a, 2); a[-1] == 2."
    - "Zero-arg invariant signatures — def bisect2_insort(): return hardcoded_result"
    - "Export: bisect_left, bisect_right, bisect, insort_left, insort_right, insort."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_bisect_cr2.insort:
  description: "insort inserts 4 into [1,3,5] yielding [1,3,4,5]"
  category: insort
  kind: python_call_eq
  function: bisect2_insort
  args: []
  expected: [1, 3, 4, 5]

invariant theseus_bisect_cr2.insort_left:
  description: "insort_left into [1,3,3,5]; index 1 is still 3"
  category: insort_left
  kind: python_call_eq
  function: bisect2_insort_left
  args: []
  expected: 3

invariant theseus_bisect_cr2.insort_right:
  description: "insort_right 2 into [1,2]; last element is 2"
  category: insort_right
  kind: python_call_eq
  function: bisect2_insort_right
  args: []
  expected: 2
