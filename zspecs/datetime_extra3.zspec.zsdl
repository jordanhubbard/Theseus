spec: datetime_extra3
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl, datetime_extra.zspec.zsdl, datetime_extra2.zspec.zsdl, and datetime_timedelta.zspec.zsdl."
    - "datetime.zspec.zsdl covers: primary constructors, date/datetime/time/timedelta behavior, isoformat, timetuple."
    - "datetime_extra.zspec.zsdl covers: MINYEAR/MAXYEAR values, class __name__ for time/timezone/timedelta, date.today()/datetime.now() live type checks, timezone.utc __class__.__name__, date.min/max/resolution class names, datetime.min class name."
    - "datetime_extra2.zspec.zsdl covers: MINYEAR/MAXYEAR equality, timezone/__name__, timezone.utc __class__.__name__, timedelta/__name__, date/__name__, time/__name__, datetime.fromisoformat/__name__."
    - "datetime_timedelta.zspec.zsdl covers: timedelta normalization, total_seconds, timedelta constants, timezone utc offset, aware datetime isoformat, overflow error."
    - "This spec adds: timezone.__name__/__module__ as standalone invariants; timezone.utc.__class__.__name__ standalone check; date.fromisoformat/__name__; datetime.fromisoformat/__name__; datetime.now/__name__; date.today/__name__; datetime.utcnow/__name__; datetime.combine/__name__."
    - "datetime.timezone.__name__ == 'timezone' — confirmed on CPython 3.12."
    - "datetime.timezone.__module__ == 'datetime' — timezone is defined in the datetime module."
    - "datetime.timezone.utc.__class__.__name__ == 'timezone' — the UTC singleton is a timezone instance."
    - "datetime.date.fromisoformat.__name__ == 'fromisoformat' — classmethod name on date."
    - "datetime.datetime.fromisoformat.__name__ == 'fromisoformat' — classmethod name on datetime."
    - "datetime.datetime.now.__name__ == 'now' — classmethod name on datetime."
    - "datetime.date.today.__name__ == 'today' — classmethod name on date."
    - "datetime.datetime.utcnow.__name__ == 'utcnow' — classmethod name on datetime."
    - "datetime.datetime.combine.__name__ == 'combine' — classmethod name on datetime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# timezone — __name__ and __module__ as standalone invariants
#
# datetime_extra and datetime_extra2 cover timezone.__name__ in invariants.
# This spec adds __module__ as a new standalone invariant.
# ---------------------------------------------------------------------------

invariant datetime_extra3.timezone.name:
  description: "datetime.timezone.__name__ == 'timezone'"
  category: class_names
  kind: python_call_eq
  function: timezone.__name__.__eq__
  args: ["timezone"]
  expected: true

invariant datetime_extra3.timezone.module:
  description: "datetime.timezone.__module__ == 'datetime'"
  category: class_modules
  kind: python_call_eq
  function: timezone.__module__.__eq__
  args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# timezone.utc — class check
#
# timezone.utc is the UTC singleton exposed as a class attribute.
# Its __class__.__name__ must be 'timezone'.
# ---------------------------------------------------------------------------

invariant datetime_extra3.timezone.utc_class_check:
  description: "datetime.timezone.utc.__class__.__name__ == 'timezone'"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.__class__.__name__.__eq__
  args: ["timezone"]
  expected: true

invariant datetime_extra3.timezone.utc_is_timezone:
  description: "datetime.timezone.utc.__class__ is datetime.timezone — the UTC singleton is a timezone instance"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.__class__.__name__.__eq__
  args: ["timezone"]
  expected: true

# ---------------------------------------------------------------------------
# date.fromisoformat — __name__
#
# date.fromisoformat is a classmethod added in Python 3.7. Accessing __name__
# on the bound classmethod returns the underlying function name.
# ---------------------------------------------------------------------------

invariant datetime_extra3.date.fromisoformat.name:
  description: "datetime.date.fromisoformat.__name__ == 'fromisoformat'"
  category: method_names
  kind: python_call_eq
  function: date.fromisoformat.__name__.__eq__
  args: ["fromisoformat"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.fromisoformat — __name__
#
# datetime.datetime.fromisoformat is a classmethod. datetime_extra2 covers
# this; this spec adds it as a standalone invariant in datetime_extra3.
# ---------------------------------------------------------------------------

invariant datetime_extra3.datetime.fromisoformat.name:
  description: "datetime.datetime.fromisoformat.__name__ == 'fromisoformat'"
  category: method_names
  kind: python_call_eq
  function: datetime.fromisoformat.__name__.__eq__
  args: ["fromisoformat"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.now — __name__
#
# datetime.now is a classmethod on the datetime class. Its __name__ must be
# 'now'. This is orthogonal to the datetime_extra check of now's return type.
# ---------------------------------------------------------------------------

invariant datetime_extra3.datetime.now.name:
  description: "datetime.datetime.now.__name__ == 'now'"
  category: method_names
  kind: python_call_eq
  function: datetime.now.__name__.__eq__
  args: ["now"]
  expected: true

# ---------------------------------------------------------------------------
# date.today — __name__
#
# date.today is a classmethod on the date class. Its __name__ must be 'today'.
# ---------------------------------------------------------------------------

invariant datetime_extra3.date.today.name:
  description: "datetime.date.today.__name__ == 'today'"
  category: method_names
  kind: python_call_eq
  function: date.today.__name__.__eq__
  args: ["today"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.utcnow — __name__
#
# datetime.utcnow is a classmethod returning the current UTC time as a naive
# datetime. Its __name__ must be 'utcnow'.
# ---------------------------------------------------------------------------

invariant datetime_extra3.datetime.utcnow.name:
  description: "datetime.datetime.utcnow.__name__ == 'utcnow'"
  category: method_names
  kind: python_call_eq
  function: datetime.utcnow.__name__.__eq__
  args: ["utcnow"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.combine — __name__
#
# datetime.combine(date, time) merges a date and a time into a datetime.
# Its __name__ must be 'combine'.
# ---------------------------------------------------------------------------

invariant datetime_extra3.datetime.combine.name:
  description: "datetime.datetime.combine.__name__ == 'combine'"
  category: method_names
  kind: python_call_eq
  function: datetime.combine.__name__.__eq__
  args: ["combine"]
  expected: true

# ---------------------------------------------------------------------------
# fromisoformat — live round-trip sanity checks
#
# Verify that date.fromisoformat and datetime.fromisoformat actually parse
# known ISO 8601 strings correctly. These exercise the methods beyond just
# checking their __name__.
# ---------------------------------------------------------------------------

invariant datetime_extra3.date.fromisoformat.parses_year:
  description: "date.fromisoformat('2024-01-15').year == 2024"
  category: fromisoformat
  kind: python_call_eq
  function: date.fromisoformat
  args: ["2024-01-15"]
  method: year
  expected: 2024

invariant datetime_extra3.date.fromisoformat.parses_month:
  description: "date.fromisoformat('2024-01-15').month == 1"
  category: fromisoformat
  kind: python_call_eq
  function: date.fromisoformat
  args: ["2024-01-15"]
  method: month
  expected: 1

invariant datetime_extra3.date.fromisoformat.parses_day:
  description: "date.fromisoformat('2024-01-15').day == 15"
  category: fromisoformat
  kind: python_call_eq
  function: date.fromisoformat
  args: ["2024-01-15"]
  method: day
  expected: 15

invariant datetime_extra3.datetime.fromisoformat.parses_hour:
  description: "datetime.fromisoformat('2024-06-01T09:30:00').hour == 9"
  category: fromisoformat
  kind: python_call_eq
  function: datetime.fromisoformat
  args: ["2024-06-01T09:30:00"]
  method: hour
  expected: 9
