  kind: python_call_eq
  category: identity
  id_prefix: mpbpdictlen169

  columns: [id, function, args, expected, description]
  rows:
    - [bp_dict_len2,     multiprocessing.process.BaseProcess.__dict__.__len__,       [],            27,    "BaseProcess.__dict__.__len__() == 27 (27 total entries; is_alive and terminate both among them); verified with Python 3.14.3"]
    - [bp_is_alive2,     multiprocessing.process.BaseProcess.__dict__.__contains__,  ["is_alive"],  true,  "BaseProcess.__dict__.__contains__('is_alive') == True (is_alive is 1 of 27 entries); verified with Python 3.14.3"]
    - [bp_terminate2,    multiprocessing.process.BaseProcess.__dict__.__contains__,  ["terminate"], true,  "BaseProcess.__dict__.__contains__('terminate') == True (terminate is 1 of 27 entries); verified with Python 3.14.3"]
    - [bp_dict_len3,     multiprocessing.process.BaseProcess.__dict__.__len__,       [],            27,    "BaseProcess.__dict__.__len__() == 27 (cross-check; largest dict in this spec series); verified with Python 3.14.3"]

