spec: multiprocessing_extra169
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: multiprocessing.process.BaseProcess.__dict__.__contains__('start')==True; multiprocessing.process.BaseProcess.__dict__.__contains__('join')==True; multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive')==True; multiprocessing.process.BaseProcess.__dict__.__contains__('terminate')==True; multiprocessing.process.BaseProcess.__dict__.__len__()==27; multiprocessing.process.BaseProcess.__name__=='BaseProcess'; multiprocessing.process.BaseProcess.__module__=='multiprocessing.process'. KEY FINDINGS: all four methods are in BaseProcess.__dict__ (True); 'start', 'join', 'terminate' were established in extra168 in different table contexts; 'is_alive' is new in this spec; BaseProcess.__name__=='BaseProcess' (len=11: 'Base'=4+'Process'=7=11); BaseProcess.__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.__name__=='BaseProcess' (len=11: 'Base'=4+'Process'=7=11); __module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23). BaseProcess.__dict__.__len__()==27 (27 entries: established in extra168). Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__ key 'is_alive': BaseProcess.is_alive() returns True if the process is alive (has been started and has not yet terminated); also checks if the process sentinel is readable (which it becomes when the process exits). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__dict__.__contains__ — start and join — extra169
#
# Cross-checks of extra168 established values with new context:
# multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True
# multiprocessing.process.BaseProcess.__dict__.__contains__('join')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra169.mp_baseprocess_dict_start_join_crosscheck:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ cross-checks for 'start' and 'join' in mpbpstartjoin169 namespace — multiprocessing.process.BaseProcess.__dict__.__contains__('start')==True (cross-check of extra168 value in new context: 'start' IS in BaseProcess.__dict__; BaseProcess.start() is the method that spawns/forks the child process; it can only be called once per process object; it sets up the sentinel file descriptor and registers the child with the _children set); multiprocessing.process.BaseProcess.__dict__.__contains__('join')==True (cross-check of extra168 value in new context: 'join' IS in BaseProcess.__dict__; BaseProcess.join(timeout=None) blocks until the child exits or timeout expires; the STANDARD IDIOM for graceful shutdown is: process.terminate(); process.join() — terminate sends SIGTERM then join reaps the zombie); multiprocessing.process.BaseProcess.__dict__.__len__()==27 (cross-check; 27 total entries — 'start' and 'join' are 2 of 27); multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive')==True (preview: 'is_alive' IS in BaseProcess.__dict__; used with join(timeout) to check if the timeout was reached); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpstartjoin169

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_start,    multiprocessing.process.BaseProcess.__dict__.__contains__,  ["start"],     true,  "BaseProcess.__dict__.__contains__('start') == True (cross-check; start() spawns child process); verified with Python 3.14.3"]
    - [bp_has_join,     multiprocessing.process.BaseProcess.__dict__.__contains__,  ["join"],      true,  "BaseProcess.__dict__.__contains__('join') == True (cross-check; join() waits for child to exit); verified with Python 3.14.3"]
    - [bp_dict_len,     multiprocessing.process.BaseProcess.__dict__.__len__,       [],            27,    "BaseProcess.__dict__.__len__() == 27 (cross-check; 27 entries; start and join are 2 of 27); verified with Python 3.14.3"]
    - [bp_has_is_alive, multiprocessing.process.BaseProcess.__dict__.__contains__,  ["is_alive"],  true,  "BaseProcess.__dict__.__contains__('is_alive') == True (is_alive() returns True if started and not yet terminated); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__dict__.__contains__ — is_alive — extra169
#
# multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra169.mp_baseprocess_dict_is_alive:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ checks for 'is_alive' and related lifecycle methods in mpbpisalive169 namespace — multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive')==True ('is_alive' IS in BaseProcess.__dict__; BaseProcess.is_alive() returns True if the process has been started and has not yet terminated; internally, is_alive() checks the process sentinel — a file descriptor that becomes readable when the process exits; is_alive() is typically used after join(timeout=N) to determine whether the timeout was reached or whether the process actually finished within the timeout: after join(timeout=5), if process.is_alive() returns True, the join timed out; is_alive() returns False for a process that has been started and has exited, and also for a process that was close()d); multiprocessing.process.BaseProcess.__dict__.__contains__('terminate')==True (cross-check of extra168; 'terminate' IS in BaseProcess.__dict__; sends SIGTERM; typically paired with join()); multiprocessing.process.BaseProcess.__dict__.__contains__('start')==True (cross-check; 'start' IS in BaseProcess.__dict__); multiprocessing.process.BaseProcess.__dict__.__contains__('join')==True (cross-check; 'join' IS in BaseProcess.__dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpisalive169

  columns: [id, function, args, expected, description]
  rows:
    - [bp_is_alive,      multiprocessing.process.BaseProcess.__dict__.__contains__,  ["is_alive"],   true,  "BaseProcess.__dict__.__contains__('is_alive') == True (is_alive checks sentinel fd for process exit); verified with Python 3.14.3"]
    - [bp_terminate,     multiprocessing.process.BaseProcess.__dict__.__contains__,  ["terminate"],  true,  "BaseProcess.__dict__.__contains__('terminate') == True (cross-check; terminate() sends SIGTERM); verified with Python 3.14.3"]
    - [bp_has_start2,    multiprocessing.process.BaseProcess.__dict__.__contains__,  ["start"],      true,  "BaseProcess.__dict__.__contains__('start') == True (cross-check; start() launches the child process); verified with Python 3.14.3"]
    - [bp_has_join2,     multiprocessing.process.BaseProcess.__dict__.__contains__,  ["join"],       true,  "BaseProcess.__dict__.__contains__('join') == True (cross-check; join() used with is_alive() after timeout); verified with Python 3.14.3"]

