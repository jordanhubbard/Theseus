table multiprocessing_extra169.mp_baseprocess_name_and_module:
  description: "multiprocessing.process.BaseProcess class name and module identity checks in mpbpnamemod169 namespace — multiprocessing.process.BaseProcess.__name__.__eq__('BaseProcess')==True (BaseProcess.__name__=='BaseProcess' (len=11: 'Base'=4+'Process'=7=11); BaseProcess is the abstract base class for all multiprocessing process types; it is defined in Lib/multiprocessing/process.py; the concrete Process class is a subclass of BaseProcess created by the platform-specific context); multiprocessing.process.BaseProcess.__name__.__len__()==11 ('BaseProcess'=11: 'Base'=4+'Process'=7=11; compare: 'Process'=7 is 4 shorter — 'Base' prefix adds 4 chars); multiprocessing.process.BaseProcess.__module__.__eq__('multiprocessing.process')==True (BaseProcess.__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); the module name matches the submodule where the class is defined: Lib/multiprocessing/process.py; 'multiprocessing.process'=23 is the longest module path so far in the multiprocessing spec series); multiprocessing.process.BaseProcess.__module__.__len__()==23 ('multiprocessing.process'=23: 15 longer than 'asyncio.events'=14 (from asyncio_extra171); 8 longer than '_asyncio'=8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpnamemod169

  columns: [id, function, args, expected, description]
  rows:
    - [bp_name_eq,   multiprocessing.process.BaseProcess.__name__.__eq__,    ["BaseProcess"],              true,  "BaseProcess.__name__ == 'BaseProcess' (len=11: 'Base'=4+'Process'=7=11); verified with Python 3.14.3"]
    - [bp_name_len,  multiprocessing.process.BaseProcess.__name__.__len__,   [],                           11,    "BaseProcess.__name__.__len__() == 11 ('BaseProcess'=11: 'Base'=4+'Process'=7=11); verified with Python 3.14.3"]
    - [bp_mod_eq,    multiprocessing.process.BaseProcess.__module__.__eq__,   ["multiprocessing.process"],  true,  "BaseProcess.__module__ == 'multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); verified with Python 3.14.3"]
    - [bp_mod_len,   multiprocessing.process.BaseProcess.__module__.__len__, [],                           23,    "BaseProcess.__module__.__len__() == 23 ('multiprocessing.process'=23; 8 longer than '_asyncio'=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra169
# ---------------------------------------------------------------------------

invariant multiprocessing_extra169.mp_BaseProcess_dict_has_is_alive:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive') returns True — multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive')==True; BaseProcess.is_alive() returns True if the process has been started and has not yet terminated; is_alive() uses the process sentinel — a file descriptor (on Unix) that becomes readable when the process exits; is_alive() is the QUERY method for process state while start(), join(), terminate(), and kill() are the ACTION methods; the canonical usage is: process.join(timeout=N); if process.is_alive(): process.terminate()  # timed out, must kill; 'is_alive'=8 chars: 'is'=2+'_'=1+'alive'=5=8; LENGTH ORDERING for BaseProcess lifecycle methods: run(3) < kill(4) < start=join(5) < is_alive(8) < terminate(9); 'is_alive' is 1 of 27 entries in BaseProcess.__dict__; NEW in extra169: first standalone BaseProcess.__dict__.__contains__('is_alive') invariant in mpbpisalive169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["is_alive"]
  expected: true

invariant multiprocessing_extra169.mp_BaseProcess_dict_has_terminate_crosscheck:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') returns True — cross-check of extra168 value in extra169 namespace: multiprocessing.process.BaseProcess.__dict__.__contains__('terminate')==True; BaseProcess.terminate() sends SIGTERM (Unix) or TerminateProcess (Windows); SIGTERM can be caught by the child process (unlike SIGKILL); the terminate + join idiom: process.terminate(); process.join() is the standard graceful stop sequence; terminate() and is_alive() interact: after terminate() + join(), is_alive() returns False; note that terminate() alone does not guarantee the child is dead — the child might ignore SIGTERM; use kill() for unconditional stop; 'terminate'=9 chars is the longest public lifecycle method name in BaseProcess.__dict__ (run=3, kill=4, start=join=5, is_alive=8, terminate=9); NEW in extra169: cross-check of BaseProcess.__dict__.__contains__('terminate') in mpbpisalive169 namespace (establishing that is_alive and terminate are both present together); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["terminate"]
  expected: true

invariant multiprocessing_extra169.mp_BaseProcess_name_eq:
  description: "multiprocessing.process.BaseProcess.__name__.__eq__('BaseProcess') returns True — multiprocessing.process.BaseProcess.__name__=='BaseProcess' (len=11: 'Base'=4+'Process'=7=11); BaseProcess is the root class in the multiprocessing process hierarchy; all platform-specific process classes inherit from it: on Unix, SpawnProcess, ForkProcess, and ForkServerProcess (created by their respective contexts) all inherit from BaseProcess; multiprocessing.Process (the user-facing class) is also a subclass of BaseProcess; BaseProcess defines all the lifecycle methods (start, run, join, terminate, kill, is_alive, close) so that platform-specific subclasses only need to override _Popen and _after_fork; BaseProcess.__name__='BaseProcess'=11 vs 'Process'=7 — the 'Base' prefix (4 chars) signals this is an abstract base not meant for direct instantiation; NEW in extra169: first standalone BaseProcess.__name__ invariant in mpbpnamemod169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__name__.__eq__
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra169.mp_BaseProcess_module_eq:
  description: "multiprocessing.process.BaseProcess.__module__.__eq__('multiprocessing.process') returns True — multiprocessing.process.BaseProcess.__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); BaseProcess is defined in Lib/multiprocessing/process.py; the module path reflects the subpackage structure: the top-level 'multiprocessing' package (len=15) has a 'process' submodule (len=7); 'multiprocessing.process'=23 is the longest module path in the multiprocessing spec series: 'multiprocessing.context'=23 (from extra167: same length! both multiprocessing.context and multiprocessing.process have 23-char paths); compare: 'asyncio.events'=14 < 'asyncio.runners'=15 < 'multiprocessing.context'=23 == 'multiprocessing.process'=23; the 'multiprocessing' prefix (15 chars) is the longest package name prefix encountered in this spec series; NEW in extra169: first standalone BaseProcess.__module__ invariant in mpbpnamemod169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra169.mp_BaseProcess_dict_len_crosscheck:
  description: "multiprocessing.process.BaseProcess.__dict__.__len__() returns 27 — cross-check of extra168 value in extra169 namespace: multiprocessing.process.BaseProcess.__dict__.__len__()==27; in extra168, the 27 entries were established alongside start, run, join, terminate, kill, and mappingproxy checks; in extra169, we confirm 27 again alongside is_alive checks; all 6 public lifecycle methods (start, run, join, is_alive, terminate, kill) plus close and interrupt are among the 27 entries; the remaining entries include property descriptors (name, daemon, authkey, exitcode, ident, pid, sentinel) and private methods (__init__, _Popen, _check_closed, _bootstrap, _after_fork) and dunder entries (__module__, __firstlineno__, __doc__, __repr__, __static_attributes__, __dict__, __weakref__); SIZING: abc.ABC(7) < abc.ABCMeta(11) < TPE(12) < Executor(11) < Future(21) < BaseProcess(27) — BaseProcess has the largest __dict__ of any class in this spec series at 27 entries; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__len__
  args: []
  expected: 27

invariant multiprocessing_extra169.mp_BaseProcess_name_len:
  description: "multiprocessing.process.BaseProcess.__name__.__len__() returns 11 — multiprocessing.process.BaseProcess.__name__.__len__()==11 ('BaseProcess'=11: 'Base'=4+'Process'=7=11); COMPARISON of class name lengths in this spec series: abc.ABC.__name__='ABC'=3 < abc.ABCMeta.__name__='ABCMeta'=7 == 'Process'=7 < 'BaseProcess'=11 == abc.ABCMeta.__dict__.__len__()==11 (coincidence) < abc.abstractproperty.__name__='abstractproperty'=16 < abc.abstractstaticmethod.__name__='abstractstaticmethod'=20; 'BaseProcess'=11 is notable: it equals the number of entries in abc.ABCMeta.__dict__ (11), and the length of the 'mappingproxy' type name (12-1=11... no: 'mappingproxy'=12); the 'Base' prefix (4 chars) is a Python convention signaling an abstract or root class (like BaseException=13, BaseContext=11 from extra167, BaseProcess=11); NEW in extra169: first standalone BaseProcess.__name__.__len__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__name__.__len__
  args: []
  expected: 11

invariant multiprocessing_extra169.mp_BaseProcess_module_len:
  description: "multiprocessing.process.BaseProcess.__module__.__len__() returns 23 — multiprocessing.process.BaseProcess.__module__.__len__()==23 ('multiprocessing.process'=23: 'multiprocessing'=15+'.'=1+'process'=7=23); 23 is the longest module path length in the multiprocessing spec series; COMPARISON of module path lengths across spec series: 'abc'=3 < '_asyncio'=8 < 'asyncio.events'=14 < 'asyncio.runners'=15 < 'multiprocessing.context'=23 == 'multiprocessing.process'=23; 'multiprocessing'=15 is the longest top-level package name (by character count) encountered in this spec series: 'abc'=3, 'asyncio'=7, '_asyncio'=8, 'concurrent'=10, 'multiprocessing'=15; 'process'=7 (the submodule) is shorter than 'context'=7 (same length — both are 7-char submodule names that produce 23-char full paths); NEW in extra169: first standalone BaseProcess.__module__.__len__ invariant confirming length 23; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__module__.__len__
  args: []
  expected: 23

