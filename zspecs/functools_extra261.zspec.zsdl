spec: functools_extra261
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.singledispatch and functools.singledispatchmethod identity contracts."
    - "functools.singledispatch.__name__ == 'singledispatch' — the function name. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('dispatch') == True — dispatch is a key concept in the docstring. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('register') == True — register is documented. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — class name. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' — defined in functools. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__class__.__name__ == 'type' — it is a class (metaclass is type). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__init__.__qualname__ == 'singledispatchmethod.__init__' — bound method. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__get__.__qualname__ == 'singledispatchmethod.__get__' — descriptor protocol. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.register.__qualname__ == 'singledispatchmethod.register' — register is a method on the class. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__doc__.__contains__('Single') == True — doc starts with 'Single-dispatch'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__doc__.__contains__('descriptor') == True — it is a descriptor. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch identity contracts
#
# functools.singledispatch.__name__     == 'singledispatch'
# functools.singledispatch.__qualname__ == 'singledispatch'
# functools.singledispatch.__module__   == 'functools'
# functools.singledispatch.__doc__.__contains__('dispatch') == True
# functools.singledispatch.__doc__.__contains__('register') == True
#
# singledispatch is a pure-Python function decorator. New to extra261.
# ---------------------------------------------------------------------------

table functools_extra261.singledispatch_identity:
  description: "functools.singledispatch name, qualname, module, doc contains contracts; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: ftsd261

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_eq,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a top-level function; new to extra261"]
    - [sd_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — top-level function; qualname equals name; new to extra261"]
    - [sd_module_eq,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in the functools module; new to extra261"]
    - [sd_doc_contains_dispatch,
       singledispatch.__doc__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatch.__doc__.__contains__('dispatch') == True — dispatch is a key concept in the docstring; new to extra261"]
    - [sd_doc_contains_register,
       singledispatch.__doc__.__contains__,
       ["register"],
       true,
       "functools.singledispatch.__doc__.__contains__('register') == True — register is documented; new to extra261"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatchmethod class identity contracts
#
# functools.singledispatchmethod.__name__              == 'singledispatchmethod'
# functools.singledispatchmethod.__module__            == 'functools'
# functools.singledispatchmethod.__class__.__name__    == 'type'
# functools.singledispatchmethod.__bases__[0].__name__ == 'object'
# functools.singledispatchmethod.__init__.__qualname__ == 'singledispatchmethod.__init__'
#
# singledispatchmethod is a class (descriptor). New to extra261.
# ---------------------------------------------------------------------------

table functools_extra261.singledispatchmethod_identity:
  description: "functools.singledispatchmethod class name, module, bases, method qualname contracts; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: ftsdm261

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_name_eq,
       singledispatchmethod.__name__.__eq__,
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — class name; new to extra261"]
    - [sdm_module_eq,
       singledispatchmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — defined in functools; new to extra261"]
    - [sdm_class_name_eq,
       singledispatchmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra261"]
    - [sdm_base_name_eq,
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra261"]
    - [sdm_init_qualname_eq,
       singledispatchmethod.__init__.__qualname__.__eq__,
       ["singledispatchmethod.__init__"],
       true,
       "functools.singledispatchmethod.__init__.__qualname__.__eq__('singledispatchmethod.__init__') == True — bound initializer; new to extra261"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod method qualnames and doc contracts
#
# functools.singledispatchmethod.__get__.__qualname__      == 'singledispatchmethod.__get__'
# functools.singledispatchmethod.register.__qualname__     == 'singledispatchmethod.register'
# functools.singledispatchmethod.__doc__.__contains__('Single')     == True
# functools.singledispatchmethod.__doc__.__contains__('descriptor') == True
# functools.singledispatchmethod.__doc__.__contains__('wrapping')   == True
#
# New to extra261.
# ---------------------------------------------------------------------------

table functools_extra261.singledispatchmethod_methods:
  description: "functools.singledispatchmethod __get__, register qualnames, and doc contains contracts; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: ftsdmm261

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_get_qualname_eq,
       singledispatchmethod.__get__.__qualname__.__eq__,
       ["singledispatchmethod.__get__"],
       true,
       "functools.singledispatchmethod.__get__.__qualname__.__eq__('singledispatchmethod.__get__') == True — descriptor protocol method; new to extra261"]
    - [sdm_register_qualname_eq,
       singledispatchmethod.register.__qualname__.__eq__,
       ["singledispatchmethod.register"],
       true,
       "functools.singledispatchmethod.register.__qualname__.__eq__('singledispatchmethod.register') == True — register is a method on the class; new to extra261"]
    - [sdm_doc_contains_single,
       singledispatchmethod.__doc__.__contains__,
       ["Single"],
       true,
       "functools.singledispatchmethod.__doc__.__contains__('Single') == True — doc starts with 'Single-dispatch'; new to extra261"]
    - [sdm_doc_contains_descriptor,
       singledispatchmethod.__doc__.__contains__,
       ["descriptor"],
       true,
       "functools.singledispatchmethod.__doc__.__contains__('descriptor') == True — it is a generic method descriptor; new to extra261"]
    - [sdm_doc_contains_wrapping,
       singledispatchmethod.__doc__.__contains__,
       ["wrapping"],
       true,
       "functools.singledispatchmethod.__doc__.__contains__('wrapping') == True — doc mentions supporting wrapping existing descriptors; new to extra261"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra261
# ---------------------------------------------------------------------------

invariant functools_extra261.singledispatch.name_eq:
  description: "functools.singledispatch.__name__ == 'singledispatch' — top-level function name; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra261.singledispatch.module_eq:
  description: "functools.singledispatch.__module__ == 'functools' — defined in functools; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra261.singledispatch.doc_contains_dispatch:
  description: "functools.singledispatch.__doc__.__contains__('dispatch') == True — dispatch is documented; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["dispatch"]
  expected: true

invariant functools_extra261.singledispatch.doc_contains_register:
  description: "functools.singledispatch.__doc__.__contains__('register') == True — register is documented; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["register"]
  expected: true

invariant functools_extra261.singledispatchmethod.name_eq:
  description: "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — class name; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatchmethod.__name__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra261.singledispatchmethod.module_eq:
  description: "functools.singledispatchmethod.__module__ == 'functools' — defined in functools; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatchmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra261.singledispatchmethod.class_is_type:
  description: "functools.singledispatchmethod.__class__.__name__ == 'type' — it is a class; metaclass is type; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatchmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra261.singledispatchmethod.base_is_object:
  description: "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra261"
  category: identity
  kind: python_call_eq
  function: "singledispatchmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra261.singledispatchmethod.register_qualname:
  description: "functools.singledispatchmethod.register.__qualname__ == 'singledispatchmethod.register' — register is a method on the class; new to extra261"
  category: identity
  kind: python_call_eq
  function: singledispatchmethod.register.__qualname__.__eq__
  args: ["singledispatchmethod.register"]
  expected: true
