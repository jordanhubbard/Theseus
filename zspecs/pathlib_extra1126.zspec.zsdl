spec: pathlib_extra1126
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module __doc__ class name, Path/__doc__ class name, PurePath/PurePosixPath/PureWindowsPath/PosixPath __doc__ class name documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.__doc__.__class__.__name__, pathlib.Path.__doc__.__class__.__name__, pathlib.PurePath.__doc__.__class__.__name__, pathlib.PurePosixPath/__doc__/__class__.__name__, pathlib.PureWindowsPath/__doc__/__class__.__name__, pathlib.PosixPath/__doc__/__class__.__name__; doc class name checks not covered in _extra1096 or _extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1126.module_and_purepath_doc_class_names:
  description: "pathlib module and PurePath-family __doc__.__class__.__name__ checks"
  kind: python_call_eq
  category: module_and_purepath_doc_class_names
  id_prefix: pl1126md
  columns: [id, function, args, expected]
  rows:
    - [pl1126md001, pathlib.__doc__.__class__.__name__.__eq__,              ["str"],  true]
    - [pl1126md002, pathlib.PurePath.__doc__.__class__.__name__.__eq__,     ["str"],  true]
    - [pl1126md003, pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl1126md004, pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl1126md005, pathlib.__doc__.__class__.__name__.__eq__,              ["bytes"], false]
    - [pl1126md006, pathlib.PurePath.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [pl1126md007, pathlib.__doc__.__class__.__name__.__eq__,              ["str"],  true]

table pathlib_extra1126.path_and_posixpath_doc_class_names:
  description: "pathlib.Path and pathlib.PosixPath __doc__.__class__.__name__ checks"
  kind: python_call_eq
  category: path_and_posixpath_doc_class_names
  id_prefix: pl1126pd
  columns: [id, function, args, expected]
  rows:
    - [pl1126pd001, pathlib.Path.__doc__.__class__.__name__.__eq__,      ["str"],  true]
    - [pl1126pd002, pathlib.PosixPath.__doc__.__class__.__name__.__eq__, ["str"],  true]
    - [pl1126pd003, pathlib.Path.__doc__.__class__.__name__.__eq__,      ["bytes"], false]
    - [pl1126pd004, pathlib.PurePath.__name__.__class__.__name__.__eq__, ["str"],  true]
    - [pl1126pd005, pathlib.Path.__name__.__class__.__name__.__eq__,     ["str"],  true]
    - [pl1126pd006, pathlib.PosixPath.__name__.__class__.__name__.__eq__, ["str"], true]
    - [pl1126pd007, pathlib.PosixPath.__module__.__eq__,                 ["pathlib"], true]
    - [pl1126pd008, pathlib.PosixPath.__qualname__.__eq__,               ["PosixPath"], true]

table pathlib_extra1126.purewindowspath_and_pureposixpath_identity:
  description: "pathlib.PurePosixPath and pathlib.PureWindowsPath __name__, __module__, __qualname__ checks"
  kind: python_call_eq
  category: purewindowspath_and_pureposixpath_identity
  id_prefix: pl1126wp
  columns: [id, function, args, expected]
  rows:
    - [pl1126wp001, pathlib.PurePosixPath.__name__.__eq__,      ["PurePosixPath"],   true]
    - [pl1126wp002, pathlib.PurePosixPath.__module__.__eq__,    ["pathlib"],         true]
    - [pl1126wp003, pathlib.PurePosixPath.__qualname__.__eq__,  ["PurePosixPath"],   true]
    - [pl1126wp004, pathlib.PureWindowsPath.__name__.__eq__,    ["PureWindowsPath"], true]
    - [pl1126wp005, pathlib.PureWindowsPath.__module__.__eq__,  ["pathlib"],         true]
    - [pl1126wp006, pathlib.PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [pl1126wp007, pathlib.PurePosixPath.__name__.__eq__,      ["PureWindowsPath"], false]
    - [pl1126wp008, pathlib.PureWindowsPath.__name__.__eq__,    ["PurePosixPath"],   false]
    - [pl1126wp009, pathlib.__spec__.name.__eq__,               ["pathlib"],         true]
