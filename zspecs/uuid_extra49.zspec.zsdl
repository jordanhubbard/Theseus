spec: uuid_extra49
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra47.zspec.zsdl — covers UUID.__repr__/__hash__.__class__.__name__.__eq__('function'); UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor')."
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low .fget.__qualname__.__eq__; getnode.__module__.__eq__('uuid'); uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str')."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/NAMESPACE_DNS __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra48; it does NOT duplicate invariants present in those files."
    - "Wave 224 theme: __all__.__contains__ membership + module __package__ identity + class __doc__.__class__.__name__ checks."
    - "NOTE: uuid has no __all__ (confirmed: uuid_extra48 documents uuid.__dict__.__contains__('__all__') == False). No __all__.__contains__ checks are possible for this module."
    - "NOTE: uuid.__package__ was covered by the base uuid.zspec (early extras reference 'uuid.__name__/__package__'). NOT duplicated here."
    - "NOTE: UUID.__doc__.__class__.__name__.__eq__('str') covered by uuid_extra41. uuid4/uuid1.__doc__.__class__.__name__ also covered by uuid_extra41. NOT duplicated here."
    - "NOTE: UUID.__lt__.__qualname__.__eq__('UUID.__lt__') covered by uuid_extra17. NOT duplicated here."
    - "Coverage gap 1: uuid_extra42 checks __doc__.__class__.__qualname__ indirectly via uuid4/getnode/UUID __module__.__class__.__name__, but NOT __doc__.__class__.__qualname__.__eq__('str') for any uuid object. No prior uuid spec checks __doc__.__class__.__qualname__ for UUID, uuid4, or uuid1. For Python str objects, __qualname__ == __name__ == 'str', but .__qualname__ is a distinct attribute chain and an independent regression vector. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__class__.__qualname__ == 'str'. UUID has a docstring; that docstring is a Python str; str.__qualname__ == 'str'. uuid_extra41 covers UUID.__doc__.__class__.__name__.__eq__('str') (the __name__ axis) but NOT __qualname__. No prior uuid spec checks UUID.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__doc__.__class__.__qualname__ == 'str'. uuid4 is a Python function with docstring 'Generate a random UUID.'; the docstring is a str; str.__qualname__ == 'str'. uuid_extra41 covers __doc__.__class__.__name__ and uuid_extra29 covers __doc__.__class__.__name__.__len__()==3 — neither checks __qualname__. No prior uuid spec checks uuid4.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__class__.__qualname__ == 'str'. uuid1 is a Python function with a docstring; str.__qualname__ == 'str'. uuid_extra41 covers uuid1.__doc__.__class__.__name__.__eq__('str') but NOT __qualname__. No prior uuid spec checks uuid1.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks uuid.__dict__.__contains__ for the presence of specific public names like 'UUID', 'uuid4', 'uuid1', 'getnode', or 'NAMESPACE_DNS'. uuid_extra48 covers uuid.__dict__.__contains__('__all__') == False (absence of __all__). But no prior spec checks __dict__.__contains__ for actual public names. uuid.__dict__.__contains__('UUID') == True confirms that the UUID class is present in the module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('UUID') == True. The UUID class is a member of the uuid module namespace. uuid_extra48 checks __dict__.__contains__('__all__') == False but does not check for any positive membership. No prior uuid spec checks uuid.__dict__.__contains__('UUID'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('uuid4') == True. uuid4 is a function defined in Lib/uuid.py and is present in the module namespace. No prior uuid spec checks uuid.__dict__.__contains__('uuid4'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('NAMESPACE_DNS') == True. NAMESPACE_DNS is a predefined UUID constant in the uuid module. No prior uuid spec checks uuid.__dict__.__contains__('NAMESPACE_DNS'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('getnode') == True. getnode is a function in the uuid module. No prior uuid spec checks uuid.__dict__.__contains__('getnode'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module-level object __doc__.__class__.__qualname__.__eq__('str')
#
# uuid_extra41 checks __doc__.__class__.__name__.__eq__('str') for UUID,
# uuid4, uuid1, uuid3, uuid5, getnode, and the module — the __name__ axis.
# No prior uuid spec checks __doc__.__class__.__qualname__ for any uuid object.
# For the built-in str type, __qualname__ == __name__ == 'str', but the
# .__qualname__ attribute chain is distinct from .__name__ and provides an
# independent regression vector: a custom type named 'str' that sets __name__
# to 'str' could still expose a different __qualname__. uuid has no __all__,
# so no __all__.__contains__ checks are performed.
# ---------------------------------------------------------------------------

table uuid_extra49.doc_class_qualname:
  description: "uuid.UUID/uuid4/uuid1 __doc__.__class__.__qualname__.__eq__('str') — docstrings are Python str; str.__qualname__ == 'str'; uuid_extra41 covers __doc__.__class__.__name__.__eq__('str') (the __name__ axis) for these objects but NOT __qualname__; no prior uuid spec checks __doc__.__class__.__qualname__.__eq__('str') for any uuid object"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidpkg49

  columns: [id, function, args, expected]
  rows:
    - [UUID_doc_class_qualname_eq,  UUID.__doc__.__class__.__qualname__.__eq__,  ["str"], true]
    - [uuid4_doc_class_qualname_eq, uuid4.__doc__.__class__.__qualname__.__eq__, ["str"], true]
    - [uuid1_doc_class_qualname_eq, uuid1.__doc__.__class__.__qualname__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__ for specific public names
#
# uuid_extra48 checks uuid.__dict__.__contains__('__all__') == False — the
# absence of __all__. No prior uuid spec checks __dict__.__contains__ for
# any positive membership. uuid.__dict__ is the module namespace; checking
# that 'UUID', 'uuid4', 'NAMESPACE_DNS', and 'getnode' are present confirms
# that the core public API members reside in the module namespace. This is
# distinct from the __all__ axis (uuid has none) and from __class__.__name__
# checks (which confirm object types, not namespace membership).
# ---------------------------------------------------------------------------

table uuid_extra49.dict_contains:
  description: "uuid.__dict__.__contains__('UUID'/'uuid4'/'NAMESPACE_DNS'/'getnode') == True — confirms core public names are present in the module namespace; uuid_extra48 checks __dict__.__contains__('__all__') == False (absence check) but no prior uuid spec checks positive __dict__ membership for any uuid public name; independent from __all__ (which uuid lacks) and from type/attribute checks"
  kind: python_call_eq
  category: module_structure
  id_prefix: uuidpkg49

  columns: [id, function, args, expected]
  rows:
    - [dict_contains_UUID,         __dict__.__contains__, ["UUID"],         true]
    - [dict_contains_uuid4,        __dict__.__contains__, ["uuid4"],        true]
    - [dict_contains_NAMESPACE_DNS, __dict__.__contains__, ["NAMESPACE_DNS"], true]
    - [dict_contains_getnode,      __dict__.__contains__, ["getnode"],      true]

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('uuid1') — standalone invariant
#
# 'uuid1' is the function that generates version-1 UUIDs from the host MAC
# address, sequence number, and current time. Its presence in uuid.__dict__
# confirms it is defined in the module namespace. uuid_extra48 checks
# __dict__.__contains__('__all__') == False; no prior uuid spec checks
# __dict__.__contains__('uuid1'). This is an independent regression vector:
# if uuid1 were accidentally removed from the module, this invariant would
# catch the regression.
# ---------------------------------------------------------------------------

invariant uuid_extra49.dict_contains_uuid1:
  description: "uuid.__dict__.__contains__('uuid1') == True — uuid1 function is present in the module namespace; uuid_extra48 checks __dict__.__contains__('__all__') == False (absence) but no prior uuid spec checks __dict__.__contains__ for 'uuid1' specifically; independent regression vector for uuid1 namespace presence"
  category: module_structure
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["uuid1"]
  expected: true
