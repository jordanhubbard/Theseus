spec: markdown_it
version: ">=14.0.0"
backend: node(markdown-it)

docs: https://markdown-it.github.io/

provenance:
  derived_from:
    - "markdown-it README — https://github.com/markdown-it/markdown-it#readme"
    - "CommonMark Spec — https://spec.commonmark.org/"
    - "Test vectors verified with markdown-it via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "markdown-it source"
  notes:
    - "markdown-it is the dominant CommonMark parser for Node.js."
    - "Install: npm install markdown-it"
    - "Usage: const MarkdownIt = require('markdown-it'); MarkdownIt().render(md) -> html string"
    - "markdown-it's CJS export IS the parser class. The class supports both `new MarkdownIt()` and `MarkdownIt()` (no-new) call patterns; this spec uses the no-new form via `entry: module` so the chain runs `m()` then `.render(...)`."
    - "Default options: html=false (escapes raw HTML), breaks=false, typographer=false."
    - "render() wraps content in a <p>; renderInline() does not (no block wrapping)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function — no IO; never throws on valid markdown input."
  stderr: "null"
  stickiness: "N/A — each MarkdownIt instance and call is independent."
  codes: {}

# ── render() — block-level with paragraph wrapping ──────────────────────────

table markdown_it.render:
  kind: node_chain_eq
  category: render
  entry: module
  entry_args: []
  id_prefix: render

  columns: [id, chain, expected]
  rows:
    - [h1_header,
       [{method: render, args: ["# Hi"]}],
       "<h1>Hi</h1>\n"]

    - [bold,
       [{method: render, args: ["**bold**"]}],
       "<p><strong>bold</strong></p>\n"]

    - [italic,
       [{method: render, args: ["*em*"]}],
       "<p><em>em</em></p>\n"]

    - [link,
       [{method: render, args: ["[link](https://example.com)"]}],
       "<p><a href=\"https://example.com\">link</a></p>\n"]

    - [unordered_list,
       [{method: render, args: ["- a\n- b"]}],
       "<ul>\n<li>a</li>\n<li>b</li>\n</ul>\n"]

    - [code_block,
       [{method: render, args: ["```\ncode\n```"]}],
       "<pre><code>code\n</code></pre>\n"]

    - [plain_text,
       [{method: render, args: ["plain"]}],
       "<p>plain</p>\n"]

# ── renderInline() — no block wrapping ──────────────────────────────────────

table markdown_it.render_inline:
  kind: node_chain_eq
  category: render_inline
  entry: module
  entry_args: []
  id_prefix: inline

  columns: [id, chain, expected]
  rows:
    - [bold_inline,
       [{method: renderInline, args: ["**bold** text"]}],
       "<strong>bold</strong> text"]

    - [italic_inline,
       [{method: renderInline, args: ["*em* text"]}],
       "<em>em</em> text"]

    - [link_inline,
       [{method: renderInline, args: ["[x](https://e.com)"]}],
       "<a href=\"https://e.com\">x</a>"]

    - [plain_inline,
       [{method: renderInline, args: ["plain"]}],
       "plain"]

# ── utils.escapeHtml — exposed escaping helper ──────────────────────────────

table markdown_it.escape_html:
  kind: node_chain_eq
  category: escape_html
  entry: module
  entry_args: []
  id_prefix: escape

  columns: [id, chain, expected]
  rows:
    - [angle_brackets,
       [{get: utils}, {get: escapeHtml}, {call: ["<b>"]}],
       "&lt;b&gt;"]

    - [ampersand,
       [{get: utils}, {get: escapeHtml}, {call: ["A & B"]}],
       "A &amp; B"]

    - [quote,
       [{get: utils}, {get: escapeHtml}, {call: ["\"hi\""]}],
       "&quot;hi&quot;"]

    - [no_special,
       [{get: utils}, {get: escapeHtml}, {call: ["plain"]}],
       "plain"]

