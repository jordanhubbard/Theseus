spec: threading_extra185
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Lock and threading.RLock class identity — threading.Lock.__class__.__name__=='type' (Lock is actually the _thread.lock C type, not a factory function); threading.Lock.__name__=='lock' (the C type's true name, lowercase); threading.Lock.__module__=='_thread'; threading.RLock.__class__.__name__=='function' (RLock is a factory function returning a _RLock instance); threading.RLock.__name__=='RLock' (len=5); threading.RLock.__module__=='threading'; threading._RLock.__name__=='_RLock' (len=6); threading._RLock.__class__.__name__=='type'; threading.TIMEOUT_MAX.__class__.__name__=='float'; threading.TIMEOUT_MAX.__gt__(0)==True."
    - "threading.Lock.__class__.__name__ == 'type' — threading.Lock is actually the C type _thread.lock (not a factory function as the docs might imply); type(threading.Lock).__name__ is 'type'. Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' — the C type is named 'lock' (lowercase), not 'Lock'; its __name__ is 'lock', 4 characters. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — threading.Lock is an alias for the C type _thread.lock; its __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — threading.RLock is a factory function in Lib/threading.py that returns a _RLock instance; type(threading.RLock).__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' — the factory function's __name__ is 'RLock', 5 characters. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' — the factory function RLock is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading._RLock.__name__ == '_RLock' — _RLock is the actual class (type) behind RLock; its __name__ is '_RLock', 6 characters. Verified with Python 3.14.3."
    - "threading._RLock.__class__.__name__ == 'type' — _RLock is a class, so type(_RLock).__name__ is 'type'. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant holding the maximum timeout value for blocking operations; its __class__.__name__ is 'float'. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0 on macOS/Darwin 25.4.0); float.__gt__(0) returns True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock identity
#
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__name__ == 'lock'
# threading.Lock.__name__.__len__() == 4
# threading.Lock.__module__ == '_thread'
#
# threading.Lock is actually the C type _thread.lock (not a Python factory
# function as documentation sometimes implies). Its __class__.__name__ is
# 'type' because it is a type/class. Its __name__ is 'lock' (lowercase, 4
# chars) — the C type's true name — and its __module__ is '_thread'.
# New to extra185.
# ---------------------------------------------------------------------------

table threading_extra185.lock_identity:
  description: "threading.Lock.__class__.__name__=='type'; Lock.__name__=='lock' len 4; Lock.__module__=='_thread' (C extension); new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglock185

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_eq,
       Lock.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is the C type _thread.lock (not a factory function); type(threading.Lock).__name__ is 'type'; str.__eq__('type') returns True; new to extra185"]
    - [lock_name_eq,
       Lock.__name__.__eq__,
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — the C type is named 'lock' (lowercase), not 'Lock'; threading.Lock is an alias to _thread.lock; its __name__ is 'lock'; str.__eq__('lock') returns True; new to extra185"]
    - [lock_name_len_4,
       Lock.__name__.__len__,
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — the name 'lock' has exactly 4 characters: l-o-c-k; str.__len__() returns 4; new to extra185"]
    - [lock_module_eq,
       Lock.__module__.__eq__,
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is an alias for the C type _thread.lock; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock identity
#
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__name__ == 'RLock'
# threading.RLock.__name__.__len__() == 5
# threading.RLock.__module__ == 'threading'
#
# threading.RLock is a factory function defined in Lib/threading.py that
# returns a _RLock instance. Unlike Lock, RLock is a Python function wrapper,
# so its __class__.__name__ is 'function'. Its __name__ is 'RLock' (5 chars)
# and __module__ is 'threading'. New to extra185.
# ---------------------------------------------------------------------------

table threading_extra185.rlock_identity:
  description: "threading.RLock.__class__.__name__=='function' (factory function); RLock.__name__=='RLock' len 5; RLock.__module__=='threading'; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglock185

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_class_eq,
       RLock.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a factory function in Lib/threading.py that returns a _RLock instance; type(threading.RLock).__name__ is 'function'; str.__eq__('function') returns True; new to extra185"]
    - [rlock_name_eq,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — the factory function's __name__ is 'RLock' (5 chars, uppercase R and L); str.__eq__('RLock') returns True; new to extra185"]
    - [rlock_name_len_5,
       RLock.__name__.__len__,
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — the name 'RLock' has exactly 5 characters: R-L-o-c-k; str.__len__() returns 5; new to extra185"]
    - [rlock_module_eq,
       RLock.__module__.__eq__,
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock factory function is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: threading._RLock and threading.TIMEOUT_MAX identity
#
# threading._RLock.__name__ == '_RLock'
# threading._RLock.__name__.__len__() == 6
# threading._RLock.__class__.__name__ == 'type'
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(0) == True
#
# threading._RLock is the actual reentrant lock class (a Python class defined
# in Lib/threading.py); its __name__ is '_RLock' (6 chars) and __class__
# is 'type'. TIMEOUT_MAX is a float constant (9223372036.0 on Darwin 25.4.0).
# New to extra185.
# ---------------------------------------------------------------------------

table threading_extra185.rlockclass_and_timeout_max:
  description: "threading._RLock.__name__=='_RLock' len 6; _RLock.__class__.__name__=='type'; TIMEOUT_MAX.__class__.__name__=='float'; TIMEOUT_MAX.__gt__(0)==True; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglock185

  columns: [id, function, args, expected, description]
  rows:
    - [rlockclass_name_eq,
       _RLock.__name__.__eq__,
       ["_RLock"],
       true,
       "threading._RLock.__name__.__eq__('_RLock') == True — _RLock is the actual reentrant lock class in Lib/threading.py; its __name__ is '_RLock' (6 chars); str.__eq__('_RLock') returns True; new to extra185"]
    - [rlockclass_name_len_6,
       _RLock.__name__.__len__,
       [],
       6,
       "threading._RLock.__name__.__len__() == 6 — the name '_RLock' has exactly 6 characters: _-R-L-o-c-k; str.__len__() returns 6; new to extra185"]
    - [rlockclass_class_eq,
       _RLock.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading._RLock.__class__.__name__.__eq__('type') == True — _RLock is a Python class (type), so type(_RLock).__name__ is 'type'; str.__eq__('type') returns True; new to extra185"]
    - [timeout_max_class_eq,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant holding the maximum timeout for blocking operations; type(TIMEOUT_MAX).__name__ is 'float'; str.__eq__('float') returns True; new to extra185"]
    - [timeout_max_gt_zero,
       TIMEOUT_MAX.__gt__,
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0 on Darwin 25.4.0); float.__gt__(0) confirms it is greater than zero and returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant threading_extra185.lock_class_is_type:
  description: "threading.Lock.__class__.__name__ == 'type' — threading.Lock is the C type _thread.lock (not a factory function); type(threading.Lock).__name__ == 'type'; new to extra185"
  category: identity
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra185.lock_name_is_lock_lowercase:
  description: "threading.Lock.__name__ == 'lock' — the C type is named 'lock' (lowercase); threading.Lock is an alias to _thread.lock; __name__ is 'lock' (4 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra185.lock_module_is_thread_c:
  description: "threading.Lock.__module__ == '_thread' — threading.Lock is an alias for the C type _thread.lock; its __module__ is '_thread'; new to extra185"
  category: identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra185.rlock_class_is_function:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function in Lib/threading.py returning a _RLock instance; type(RLock).__name__ == 'function'; new to extra185"
  category: identity
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra185.rlock_name_is_RLock:
  description: "threading.RLock.__name__ == 'RLock' — factory function for reentrant locks; __name__ is 'RLock' (5 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra185.rlock_module_is_threading:
  description: "threading.RLock.__module__ == 'threading' — RLock factory function defined in Lib/threading.py; its __module__ is 'threading'; new to extra185"
  category: identity
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra185.rlockclass_name_is_underscore_RLock:
  description: "threading._RLock.__name__ == '_RLock' — the actual reentrant lock class in Lib/threading.py; __name__ is '_RLock' (6 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: _RLock.__name__.__eq__
  args: ["_RLock"]
  expected: true

invariant threading_extra185.timeout_max_class_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant for the maximum blocking timeout; type(TIMEOUT_MAX).__name__ == 'float'; new to extra185"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra185.timeout_max_is_positive:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0 on Darwin 25.4.0); float.__gt__(0) returns True; new to extra185"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true
