spec: multiprocessing_extra601
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing Queue and Value/Array identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __module__, __class__.__name__, and __name__ identity for multiprocessing.Queue, Value, and Array"
  created_at: "2026-04-12T00:00:00Z"

table multiprocessing_extra601.mp601qn:
  id_prefix: mp601qn

  columns: [id, function, args, expected]
  rows:
    - [mp601qn01, multiprocessing.Queue.__qualname__.__eq__, ["Queue"], true]
    - [mp601qn02, multiprocessing.Queue.__module__.__eq__, ["multiprocessing.queues"], true]
    - [mp601qn03, multiprocessing.Queue.put.__qualname__.__eq__, ["Queue.put"], true]
    - [mp601qn04, multiprocessing.Queue.get.__qualname__.__eq__, ["Queue.get"], true]
    - [mp601qn05, multiprocessing.Queue.empty.__qualname__.__eq__, ["Queue.empty"], true]
    - [mp601qn06, multiprocessing.Queue.full.__qualname__.__eq__, ["Queue.full"], true]
    - [mp601qn07, multiprocessing.Queue.qsize.__qualname__.__eq__, ["Queue.qsize"], true]
    - [mp601qn08, multiprocessing.Queue.close.__qualname__.__eq__, ["Queue.close"], true]

table multiprocessing_extra601.mp601dc:
  id_prefix: mp601dc

  columns: [id, function, args, expected]
  rows:
    - [mp601dc01, multiprocessing.Value.__class__.__name__.__eq__, ["function"], true]
    - [mp601dc02, multiprocessing.Array.__class__.__name__.__eq__, ["function"], true]
    - [mp601dc03, multiprocessing.Value.__name__.__eq__, ["Value"], true]
    - [mp601dc04, multiprocessing.Array.__name__.__eq__, ["Array"], true]
