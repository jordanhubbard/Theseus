spec: reprlib_extra15
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl through reprlib_extra14.zspec.zsdl."
    - "reprlib_extra14 covers: Repr.__bases__[0].__name__=='object'; recursive_repr __name__/__qualname__/__module__; aRepr.__class__.__qualname__=='Repr'; Repr.__module__=='reprlib'."
    - "reprlib_extra12 covers: Repr.__init__.__name__=='__init__' standalone."
    - "reprlib_extra4 covers: repr.__qualname__=='Repr.repr'."
    - "No prior spec verifies Repr.__init__.__qualname__ as a standalone invariant."
    - "No prior spec verifies reprlib.__name__ == 'reprlib' as a standalone invariant."
    - "No prior spec verifies Repr.__qualname__.__len__(), Repr.__init__.__qualname__.__len__(), or recursive_repr.__qualname__.__len__() as standalone invariants."
    - "This spec covers: Repr.__init__.__qualname__=='Repr.__init__'; reprlib.__name__=='reprlib'; Repr.__qualname__.__len__()==4; Repr.__init__.__qualname__.__len__()==13; recursive_repr.__qualname__.__len__()==14."
    - "reprlib.Repr.__init__.__qualname__ == 'Repr.__init__' — method qualname includes the owning class name. Verified at runtime."
    - "reprlib.__name__ == 'reprlib' — the module __name__ attribute equals the module's canonical name. Verified at runtime."
    - "reprlib.Repr.__qualname__.__len__() == 4 — len('Repr') == 4. Verified at runtime."
    - "reprlib.Repr.__init__.__qualname__.__len__() == 13 — len('Repr.__init__') == 13. Verified at runtime."
    - "reprlib.recursive_repr.__qualname__.__len__() == 14 — len('recursive_repr') == 14. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr.__init__.__qualname__
#
# reprlib_extra12 covers Repr.__init__.__name__ == '__init__'.
# No prior spec verifies Repr.__init__.__qualname__ as a standalone invariant.
# For a method defined in class Repr, __qualname__ takes the form 'Repr.__init__'.
# Verified: reprlib.Repr.__init__.__qualname__ == 'Repr.__init__'.
# ---------------------------------------------------------------------------

invariant reprlib_extra15.Repr.init_qualname:
  description: "reprlib.Repr.__init__.__qualname__ == 'Repr.__init__' — method qualname includes the owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.__init__.__qualname__.__eq__
  args: ["Repr.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.__name__
#
# No prior spec verifies reprlib.__name__ == 'reprlib' as a standalone invariant.
# Every Python module has a __name__ attribute equal to its canonical name.
# Verified: reprlib.__name__ == 'reprlib'.
# ---------------------------------------------------------------------------

invariant reprlib_extra15.module.name:
  description: "reprlib.__name__ == 'reprlib' — module __name__ attribute equals canonical module name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ string lengths — Repr class and Repr.__init__ method
#
# No prior spec verifies Repr.__qualname__.__len__() or
# Repr.__init__.__qualname__.__len__() as standalone invariants.
# 'Repr' has 4 characters; 'Repr.__init__' has 13 characters.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra15.Repr.qualname_len:
  description: "reprlib.Repr.__qualname__.__len__() == 4 — len('Repr') == 4"
  category: class_identity
  kind: python_call_eq
  function: Repr.__qualname__.__len__
  args: []
  expected: 4

invariant reprlib_extra15.Repr.init_qualname_len:
  description: "reprlib.Repr.__init__.__qualname__.__len__() == 13 — len('Repr.__init__') == 13"
  category: function_identity
  kind: python_call_eq
  function: Repr.__init__.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# recursive_repr.__qualname__ string length
#
# reprlib_extra14 covers recursive_repr.__qualname__ == 'recursive_repr'.
# No prior spec verifies recursive_repr.__qualname__.__len__() as a standalone
# invariant. 'recursive_repr' has 14 characters.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra15.recursive_repr.qualname_len:
  description: "reprlib.recursive_repr.__qualname__.__len__() == 14 — len('recursive_repr') == 14"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# Table: Repr.__init__ and Repr class qualname checks
#
# Groups Repr.__init__.__qualname__, Repr.__qualname__.__len__, and
# Repr.__init__.__qualname__.__len__ checks together.
# ---------------------------------------------------------------------------

table reprlib_extra15.Repr_init_identity:
  description: "reprlib.Repr.__init__ method identity and qualname string lengths"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [reprlib_extra15.Repr_init_identity.qualname,
       Repr.__init__.__qualname__.__eq__,
       ["Repr.__init__"],
       true,
       "Repr.__init__.__qualname__ == 'Repr.__init__'"]
    - [reprlib_extra15.Repr_init_identity.class_qualname_len,
       Repr.__qualname__.__len__,
       [],
       4,
       "Repr.__qualname__.__len__() == 4 — len('Repr') == 4"]
    - [reprlib_extra15.Repr_init_identity.init_qualname_len,
       Repr.__init__.__qualname__.__len__,
       [],
       13,
       "Repr.__init__.__qualname__.__len__() == 13 — len('Repr.__init__') == 13"]

# ---------------------------------------------------------------------------
# Table: module name and recursive_repr qualname length
#
# Groups the module __name__ check and the recursive_repr qualname-length check.
# ---------------------------------------------------------------------------

table reprlib_extra15.module_and_decorator_identity:
  description: "reprlib module __name__ and recursive_repr __qualname__ string length"
  kind: python_call_eq
  category: module_identity
  columns: [id, function, args, expected, description]
  rows:
    - [reprlib_extra15.module_and_decorator_identity.module_name,
       __name__.__eq__,
       ["reprlib"],
       true,
       "reprlib.__name__ == 'reprlib'"]
    - [reprlib_extra15.module_and_decorator_identity.recursive_repr_qualname_len,
       recursive_repr.__qualname__.__len__,
       [],
       14,
       "recursive_repr.__qualname__.__len__() == 14 — len('recursive_repr') == 14"]
