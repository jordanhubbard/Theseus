spec: cf3181
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (cf3181): __truediv__, __floordiv__, __mod__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor."
    - "Key finding (__truediv__): all 4 concurrent.futures classes return false for __truediv__. True division (/) has no meaning for any futures or executor type. concurrent.futures.Future encapsulates a single pending computation result — future / future is not a defined operation. ThreadPoolExecutor/ProcessPoolExecutor manage worker pools dispatching callables via submit()/map(); dividing a pool is not part of the API. Executor is an abstract base class with no arithmetic interface."
    - "Key finding (__floordiv__): all 4 concurrent.futures classes return false for __floordiv__. Floor division (//) is not defined for any concurrent.futures type. There is no concept of partitioning a Future or an Executor by floor division. ThreadPoolExecutor does not support executor // n to split into sub-pools; work partitioning is done at the application layer via map() with chunksize. ProcessPoolExecutor does not define floor division either."
    - "Key finding (__mod__): all 4 concurrent.futures classes return false for __mod__. Modulo (%) is not defined for any concurrent.futures type. concurrent.futures.Future does not define % for result modulo; its result is accessed via result() and exceptions via exception(). The % operator on str (old-style formatting) would require __mod__ on a string subclass — not relevant here. ThreadPoolExecutor/ProcessPoolExecutor/Executor: no modulo protocol."
    - "This is the seventh consecutive all-false wave for all 4 concurrent.futures subjects. Every dunder tested since wave 652 has returned false for all 4 subjects except Future.__repr__ (wave 655). The concurrent.futures API is deliberately narrow — submit work, retrieve results, shut down — with no arithmetic, sequence, or collection protocol."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 652 (cf3076): __get__/__set__/__delete__ — all false for all 4."
    - "  Wave 653 (cf3091): __hash__/__eq__/__bool__ — all false for all 4."
    - "  Wave 654 (cf3106): __lt__/__le__/__gt__ — all false for all 4."
    - "  Wave 655 (cf3121): __ge__ false; __repr__ true only for Future; __str__ false."
    - "  Wave 656 (cf3136): __call__/__len__/__getitem__ — all false for all 4."
    - "  Wave 657 (cf3151): __setitem__/__delitem__/__contains__ — all false for all 4."
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 4."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 4."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — operator.contains(Cls.__dict__, '__truediv__')
#
# All 4 concurrent.futures classes return false for __truediv__.
# concurrent.futures.Future: holds a single pending computation result;
#   future / future is not a valid expression.
# ThreadPoolExecutor: manages a thread pool dispatching work via submit()/map();
#   executor / n has no defined meaning.
# ProcessPoolExecutor: manages a process pool; no true division protocol.
# Executor: abstract base class; no arithmetic interface of any kind.
# ---------------------------------------------------------------------------

table cf3181.truediv:
  description: "concurrent.futures types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3181

  columns: [id, function, args, expected]
  rows:
    - ["cf3181001", operator.contains, [concurrent.futures.Future.__dict__,              "__truediv__"], false]
    - ["cf3181002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__truediv__"], false]
    - ["cf3181003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__truediv__"], false]
    - ["cf3181004", operator.contains, [concurrent.futures.Executor.__dict__,            "__truediv__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — operator.contains(Cls.__dict__, '__floordiv__')
#
# All 4 concurrent.futures classes return false for __floordiv__.
# concurrent.futures.Future: a single-result container; future // n is undefined.
# ThreadPoolExecutor: work partitioning is done at the application layer via
#   map() with a chunksize argument — not via the // operator on the executor.
# ProcessPoolExecutor: similarly, chunksize controls batching for map();
#   executor // n is not a valid operation.
# Executor: abstract base; no arithmetic protocol.
# ---------------------------------------------------------------------------

table cf3181.floordiv:
  description: "concurrent.futures types __floordiv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3181

  columns: [id, function, args, expected]
  rows:
    - ["cf3181005", operator.contains, [concurrent.futures.Future.__dict__,              "__floordiv__"], false]
    - ["cf3181006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__floordiv__"], false]
    - ["cf3181007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__floordiv__"], false]
    - ["cf3181008", operator.contains, [concurrent.futures.Executor.__dict__,            "__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — operator.contains(Cls.__dict__, '__mod__')
#
# All 4 concurrent.futures classes return false for __mod__.
# concurrent.futures.Future: result is accessed via result(); no % operator.
#   Cancellation uses cancel(); timeout is passed to result(timeout=). Neither
#   maps to modulo arithmetic.
# ThreadPoolExecutor/ProcessPoolExecutor: worker count is set at construction
#   (max_workers); no runtime modulo operation on the pool size.
# Executor: abstract base; no arithmetic protocol.
# ---------------------------------------------------------------------------

table cf3181.mod:
  description: "concurrent.futures types __mod__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
