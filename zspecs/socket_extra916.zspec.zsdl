spec: socket_extra916
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ attributes of socket classes, exception types, and utility functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra916.socket_class_qualnames:
  description: "socket.socket class __qualname__ identity"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: sk916sc
  columns: [id, function, args, expected]
  rows:
    - [sk916sc001, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [sk916sc002, socket.socket.__module__.__eq__,   ["socket"], true]
    - [sk916sc003, socket.socket.__class__.__name__.__eq__, ["type"], true]

table socket_extra916.exception_qualnames:
  description: "socket exception class __qualname__ identity"
  kind: python_call_eq
  category: exception_qualnames
  id_prefix: sk916eq
  columns: [id, function, args, expected]
  rows:
    - [sk916eq001, socket.error.__qualname__.__eq__,   ["error"],   true]
    - [sk916eq002, socket.timeout.__qualname__.__eq__, ["timeout"], true]
    - [sk916eq003, socket.herror.__qualname__.__eq__,  ["herror"],  true]
    - [sk916eq004, socket.gaierror.__qualname__.__eq__, ["gaierror"], true]
    - [sk916eq005, socket.error.__module__.__eq__,   ["socket"], true]
    - [sk916eq006, socket.timeout.__module__.__eq__, ["socket"], true]
    - [sk916eq007, socket.herror.__module__.__eq__,  ["socket"], true]
    - [sk916eq008, socket.gaierror.__module__.__eq__, ["socket"], true]

table socket_extra916.utility_function_qualnames:
  description: "socket utility function __qualname__ identity"
  kind: python_call_eq
  category: utility_qualnames
  id_prefix: sk916uq
  columns: [id, function, args, expected]
  rows:
    - [sk916uq001, socket.getfqdn.__qualname__.__eq__,      ["getfqdn"],      true]
    - [sk916uq002, socket.gethostname.__qualname__.__eq__,  ["gethostname"],  true]
    - [sk916uq003, socket.gethostbyname.__qualname__.__eq__, ["gethostbyname"], true]
    - [sk916uq004, socket.getfqdn.__module__.__eq__,        ["socket"],       true]
    - [sk916uq005, socket.gethostname.__module__.__eq__,    ["socket"],       true]
    - [sk916uq006, socket.gethostbyname.__module__.__eq__,  ["socket"],       true]
