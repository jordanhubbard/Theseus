spec: inspect_extra225
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect __doc__ string contains checks."
    - "inspect.__doc__ contains 'Python' — module docstring is 'Get useful information from live Python objects.'. Verified with Python 3.14.3."
    - "inspect.isfunction.__doc__ contains 'function'. Verified with Python 3.14.3."
    - "inspect.isclass.__doc__ contains 'class'. Verified with Python 3.14.3."
    - "inspect.ismodule.__doc__ contains 'module'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__doc__ contains 'built-in'. Verified with Python 3.14.3."
    - "inspect.signature.__doc__ contains 'signature'. Verified with Python 3.14.3 — docstring is 'Get a signature object for the passed callable.'"
    - "inspect.getmembers.__doc__ contains 'members'. Verified with Python 3.14.3."
    - "inspect.getsource.__doc__ contains 'source'. Verified with Python 3.14.3."
    - "inspect.getdoc.__doc__ contains 'documentation'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect __doc__ contains checks (module + predicate functions)
#
# Verified with Python 3.14.3:
#   inspect.__doc__ contains 'Python' (module docstring: 'Get useful information from live Python objects.')
#   inspect.isfunction.__doc__ contains 'function'
#   inspect.isclass.__doc__ contains 'class'
#   inspect.ismodule.__doc__ contains 'module'
#   inspect.isbuiltin.__doc__ contains 'built-in'
# ---------------------------------------------------------------------------

table inspect_extra225.doc_contains_predicates:
  description: "inspect __doc__ string contains checks for module and predicate functions; new to extra225"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: inspectextra225docpred

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_contains_python,
       __doc__.__contains__,
       ["Python"],
       true,
       "inspect.__doc__.__contains__('Python') == True — module docstring is 'Get useful information from live Python objects.'; contains 'Python'; new to extra225"]
    - [isfunction_doc_contains_function,
       isfunction.__doc__.__contains__,
       ["function"],
       true,
       "inspect.isfunction.__doc__.__contains__('function') == True — isfunction docstring is 'Return true if the object is a user-defined function.'; contains 'function'; new to extra225"]
    - [isclass_doc_contains_class,
       isclass.__doc__.__contains__,
       ["class"],
       true,
       "inspect.isclass.__doc__.__contains__('class') == True — isclass docstring is 'Return true if the object is a class.'; contains 'class'; new to extra225"]
    - [ismodule_doc_contains_module,
       ismodule.__doc__.__contains__,
       ["module"],
       true,
       "inspect.ismodule.__doc__.__contains__('module') == True — ismodule docstring is 'Return true if the object is a module.'; contains 'module'; new to extra225"]
    - [isbuiltin_doc_contains_builtin,
       isbuiltin.__doc__.__contains__,
       ["built-in"],
       true,
       "inspect.isbuiltin.__doc__.__contains__('built-in') == True — isbuiltin docstring is 'Return true if the object is a built-in function or method.'; contains 'built-in'; new to extra225"]

# ---------------------------------------------------------------------------
# Table 2: inspect __doc__ contains checks (utility functions)
#
# Verified with Python 3.14.3:
#   inspect.signature.__doc__ contains 'signature' (docstring: 'Get a signature object for the passed callable.')
#   inspect.getmembers.__doc__ contains 'members' (docstring: 'Return all members of an object as (name, value) pairs...')
#   inspect.getsource.__doc__ contains 'source'
#   inspect.getdoc.__doc__ contains 'documentation' (docstring: 'Get the documentation string for an object.')
# ---------------------------------------------------------------------------

table inspect_extra225.doc_contains_utils:
  description: "inspect __doc__ string contains checks for utility functions; new to extra225"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: inspectextra225docutil

  columns: [id, function, args, expected, description]
  rows:
    - [signature_doc_contains_signature,
       signature.__doc__.__contains__,
       ["signature"],
       true,
       "inspect.signature.__doc__.__contains__('signature') == True — signature docstring is 'Get a signature object for the passed callable.'; contains 'signature'; new to extra225"]
    - [getmembers_doc_contains_members,
       getmembers.__doc__.__contains__,
       ["members"],
       true,
       "inspect.getmembers.__doc__.__contains__('members') == True — getmembers docstring is 'Return all members of an object as (name, value) pairs sorted by name.'; contains 'members'; new to extra225"]
    - [getsource_doc_contains_source,
       getsource.__doc__.__contains__,
       ["source"],
       true,
       "inspect.getsource.__doc__.__contains__('source') == True — getsource docstring is 'Return the text of the source code for an object.'; contains 'source'; new to extra225"]
    - [getdoc_doc_contains_documentation,
       getdoc.__doc__.__contains__,
       ["documentation"],
       true,
       "inspect.getdoc.__doc__.__contains__('documentation') == True — getdoc docstring is 'Get the documentation string for an object.'; contains 'documentation'; new to extra225"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra225
# ---------------------------------------------------------------------------

invariant inspect_extra225.module_doc_contains_python:
  description: "inspect.__doc__.__contains__('Python') == True — module docstring contains 'Python'; new to extra225"
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["Python"]
  expected: true

invariant inspect_extra225.isfunction_doc_contains_function:
  description: "inspect.isfunction.__doc__.__contains__('function') == True — isfunction docstring contains 'function'; new to extra225"
  kind: python_call_eq
  function: isfunction.__doc__.__contains__
  args: ["function"]
  expected: true

invariant inspect_extra225.isclass_doc_contains_class:
  description: "inspect.isclass.__doc__.__contains__('class') == True — isclass docstring contains 'class'; new to extra225"
  kind: python_call_eq
  function: isclass.__doc__.__contains__
  args: ["class"]
  expected: true

invariant inspect_extra225.ismodule_doc_contains_module:
  description: "inspect.ismodule.__doc__.__contains__('module') == True — ismodule docstring contains 'module'; new to extra225"
  kind: python_call_eq
  function: ismodule.__doc__.__contains__
  args: ["module"]
  expected: true

invariant inspect_extra225.isbuiltin_doc_contains_builtin:
  description: "inspect.isbuiltin.__doc__.__contains__('built-in') == True — isbuiltin docstring contains 'built-in'; new to extra225"
  kind: python_call_eq
  function: isbuiltin.__doc__.__contains__
  args: ["built-in"]
  expected: true

invariant inspect_extra225.signature_doc_contains_signature:
  description: "inspect.signature.__doc__.__contains__('signature') == True — signature docstring contains 'signature'; new to extra225"
  kind: python_call_eq
  function: signature.__doc__.__contains__
  args: ["signature"]
  expected: true

invariant inspect_extra225.getmembers_doc_contains_members:
  description: "inspect.getmembers.__doc__.__contains__('members') == True — getmembers docstring contains 'members'; new to extra225"
  kind: python_call_eq
  function: getmembers.__doc__.__contains__
  args: ["members"]
  expected: true

invariant inspect_extra225.getsource_doc_contains_source:
  description: "inspect.getsource.__doc__.__contains__('source') == True — getsource docstring contains 'source'; new to extra225"
  kind: python_call_eq
  function: getsource.__doc__.__contains__
  args: ["source"]
  expected: true

invariant inspect_extra225.getdoc_doc_contains_documentation:
  description: "inspect.getdoc.__doc__.__contains__('documentation') == True — getdoc docstring contains 'documentation'; new to extra225"
  kind: python_call_eq
  function: getdoc.__doc__.__contains__
  args: ["documentation"]
  expected: true
