spec: dis_extra25
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra24.zspec.zsdl — covers Instruction._fields.__len__() and _fields[0]/_fields[1]; findlinestarts/findlabels/distb __qualname__ standalone; Bytecode.__init__.__qualname__/__module__"
    - "dis_extra23.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/code_info/show_code __module__ (table); Instruction/__module__ and Bytecode/__module__ standalone; stack_effect/__qualname__ and __module__; code_info/show_code __qualname__ standalone"
    - "dis_extra21.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __qualname__.__eq__ (table); Instruction/__qualname__.__eq__ standalone"
    - "dis_extra20.zspec.zsdl — covers __qualname__.__len__() for dis/disassemble/findlinestarts/findlabels/stack_effect/pretty_flags/print_instructions"
    - "dis_extra17.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __name__ and __module__; Instruction/__name__"
    - "dis_extra5.zspec.zsdl — covers code_info/show_code/stack_effect/findlabels/distb __qualname__"
    - "dis_extra4.zspec.zsdl — covers Instruction/__qualname__; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
  notes:
    - "This spec extends dis_extra24.zspec.zsdl."
    - "Prior specs covered: dis.__name__/__package__, dis/__name__/__module__, disassemble/__name__, distb/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, findlinestarts/__name__, findlabels/__name__, Instruction/__name__/__module__, dis.COMPILER_FLAGS/__class__.__name__, dis.stack_effect/__name__, dis.hasjabs/__class__/__name__, various __qualname__ checks."
    - "This spec covers: dis.dis/__qualname__, dis.disassemble/__qualname__, dis.code_info/__qualname__, dis.show_code/__qualname__, dis.get_instructions/__qualname__, dis.findlinestarts/__qualname__, dis.findlabels/__qualname__ as standalone invariants in dis_extra25 namespace; dis.dis/__module__.__len__(), dis.code_info/__module__.__len__(), dis.show_code/__module__.__len__() (all == 3, 'dis' has length 3); dis.Instruction/__qualname__ as standalone invariant in dis_extra25 namespace."
    - "dis.dis.__qualname__ == 'dis' — dis_extra21 covers this in a table; distinct standalone invariant in dis_extra25 namespace."
    - "dis.disassemble.__qualname__ == 'disassemble' — dis_extra21 covers this in a table; distinct standalone invariant in dis_extra25 namespace."
    - "dis.code_info.__qualname__ == 'code_info' — dis_extra23 covers this as standalone in its namespace; distinct standalone invariant in dis_extra25 namespace."
    - "dis.show_code.__qualname__ == 'show_code' — dis_extra23 covers this as standalone in its namespace; distinct standalone invariant in dis_extra25 namespace."
    - "dis.get_instructions.__qualname__ == 'get_instructions' — dis_extra21 covers this in a table; distinct standalone invariant in dis_extra25 namespace."
    - "dis.findlinestarts.__qualname__ == 'findlinestarts' — dis_extra21 and dis_extra24 cover this; distinct standalone invariant in dis_extra25 namespace."
    - "dis.findlabels.__qualname__ == 'findlabels' — dis_extra21 and dis_extra24 cover this; distinct standalone invariant in dis_extra25 namespace."
    - "dis.dis.__module__.__len__() == 3 — 'dis' has 3 characters; no prior dis spec covers this as a standalone __eq__ invariant."
    - "dis.code_info.__module__.__len__() == 3 — same; no prior dis spec covers this."
    - "dis.show_code.__module__.__len__() == 3 — same; no prior dis spec covers this."
    - "dis.Instruction.__qualname__ == 'Instruction' — dis_extra21 covers this as standalone in its namespace; distinct standalone invariant in dis_extra25 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dis/disassemble __qualname__ — standalone invariants
# (dis_extra25 namespace)
#
# dis_extra21 covers these in a table (__qualname__.__eq__).
# dis_extra24 covers findlinestarts/findlabels/distb as standalone.
# These are distinct standalone invariants in the dis_extra25 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra25.dis_func.qualname:
  description: "dis.dis.__qualname__ == 'dis' — the top-level dis function"
  category: function_qualnames
  kind: python_call_eq
  function: dis.__qualname__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra25.disassemble.qualname:
  description: "dis.disassemble.__qualname__ == 'disassemble'"
  category: function_qualnames
  kind: python_call_eq
  function: disassemble.__qualname__.__eq__
  args: ["disassemble"]
  expected: true

# ---------------------------------------------------------------------------
# get_instructions, findlinestarts, findlabels __qualname__ — standalone
# (dis_extra25 namespace)
#
# dis_extra21 covers all three in a table. These are distinct standalone
# invariants in the dis_extra25 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra25.get_instructions.qualname:
  description: "dis.get_instructions.__qualname__ == 'get_instructions'"
  category: function_qualnames
  kind: python_call_eq
  function: get_instructions.__qualname__.__eq__
  args: ["get_instructions"]
  expected: true

invariant dis_extra25.findlinestarts.qualname:
  description: "dis.findlinestarts.__qualname__ == 'findlinestarts'"
  category: function_qualnames
  kind: python_call_eq
  function: findlinestarts.__qualname__.__eq__
  args: ["findlinestarts"]
  expected: true

invariant dis_extra25.findlabels.qualname:
  description: "dis.findlabels.__qualname__ == 'findlabels'"
  category: function_qualnames
  kind: python_call_eq
  function: findlabels.__qualname__.__eq__
  args: ["findlabels"]
  expected: true

# ---------------------------------------------------------------------------
# code_info and show_code __qualname__ — standalone invariants
# (dis_extra25 namespace)
#
# dis_extra23 covers code_info/show_code __qualname__ in its namespace.
# These are distinct standalone invariants in the dis_extra25 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra25.code_info.qualname:
  description: "dis.code_info.__qualname__ == 'code_info'"
  category: function_qualnames
  kind: python_call_eq
  function: code_info.__qualname__.__eq__
  args: ["code_info"]
  expected: true

invariant dis_extra25.show_code.qualname:
  description: "dis.show_code.__qualname__ == 'show_code'"
  category: function_qualnames
  kind: python_call_eq
  function: show_code.__qualname__.__eq__
  args: ["show_code"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction.__qualname__ — standalone invariant
# (dis_extra25 namespace)
#
# dis_extra21 covers Instruction/__qualname__.__eq__ as a standalone in its
# namespace. This is a distinct standalone invariant in dis_extra25 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra25.Instruction.qualname:
  description: "dis.Instruction.__qualname__ == 'Instruction'"
  category: class_qualnames
  kind: python_call_eq
  function: Instruction.__qualname__.__eq__
  args: ["Instruction"]
  expected: true

# ---------------------------------------------------------------------------
# dis/code_info/show_code __module__.__len__() — table
# (dis_extra25 namespace)
#
# 'dis' has 3 characters. dis_extra23 covers __module__.__eq__ for these
# functions in a table. No prior dis spec covers __module__.__len__() for
# any of them as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

table dis_extra25.function_module_lengths:
  description: "__module__.__len__() for dis top-level functions — all equal 3 ('dis')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [dis_func,  dis.__module__.__len__,       [], 3]
    - [code_info, code_info.__module__.__len__, [], 3]
    - [show_code, show_code.__module__.__len__, [], 3]

# ---------------------------------------------------------------------------
# Function __qualname__ table — convenience grouping
# (dis_extra25 namespace)
#
# Groups all seven function __qualname__ values confirmed above into a single
# table for cross-reference. Each is also covered by a standalone invariant
# in this spec.
# ---------------------------------------------------------------------------

table dis_extra25.function_qualnames:
  description: "__qualname__ values for dis top-level functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [dis_func,          dis.__qualname__.__eq__,              ["dis"],              true]
    - [disassemble,       disassemble.__qualname__.__eq__,       ["disassemble"],      true]
    - [code_info,         code_info.__qualname__.__eq__,         ["code_info"],        true]
    - [show_code,         show_code.__qualname__.__eq__,         ["show_code"],        true]
    - [get_instructions,  get_instructions.__qualname__.__eq__,  ["get_instructions"], true]
    - [findlinestarts,    findlinestarts.__qualname__.__eq__,    ["findlinestarts"],   true]
    - [findlabels,        findlabels.__qualname__.__eq__,        ["findlabels"],       true]
