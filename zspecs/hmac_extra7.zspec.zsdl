spec: hmac_extra7
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC), July 2008"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac through hmac_extra6; it does NOT duplicate invariants present in those files."
    - "hmac.zspec.zsdl covers: HMAC-SHA256/SHA1 hexdigest; compare_digest strings; SHA256 digest_size/block_size/name; class/function identity."
    - "hmac_extra covers: __name__ table; new returns HMAC; MD5 digest_size; compare_digest bytes; hexdigest str/len."
    - "hmac_extra2 covers: __module__ for new/compare_digest/digest; HMAC.__bases__; SHA256 digest_size/block_size (via __eq__); name is str; compare_digest b'a'/b'b'."
    - "hmac_extra4 covers: function_names table; SHA256/MD5 digest_size; instance_class; compare_digest equal/unequal strings; name attr."
    - "hmac_extra5 covers: __qualname__ for HMAC/new/compare_digest/digest; SHA384 digest_size/name/block_size; hmac.digest() returns bytes/sha256_len/md5_len; HMAC has_doc."
    - "hmac_extra6 covers: identity_anchor table; HMAC base is object; HMAC MRO second is object; SHA512 digest_size/name/block_size/digest_len; compare_digest type mismatch."
    - "No prior spec covers: HMAC-SHA1 hexdigest as a standalone python_call_eq invariant (hmac.zspec.zsdl covers it but uses {type:bytes_ascii} protocol)."
    - "No prior spec covers: HMAC-MD5 hexdigest value."
    - "No prior spec covers: hmac.digest(key, msg, 'sha1') return length."
    - "No prior spec covers: hmac.digest(key, msg, 'sha384') return length."
    - "No prior spec covers: HMAC-SHA1 name == 'hmac-sha1'."
    - "No prior spec covers: HMAC-MD5 name == 'hmac-md5'."
    - "No prior spec covers: HMAC-MD5 block_size == 64."
    - "No prior spec covers: hmac.HMAC.__mro__[0].__name__ == 'HMAC'."
    - "hmac.new(b'key', b'msg', 'sha1').hexdigest() == '102900b72b7bf1031eec76b4804b66052376896b' — verified on Python 3.12."
    - "hmac.new(b'key', b'msg', 'md5').hexdigest() == '18e3548c59ad40dd03907b7aeee71d67' — verified on Python 3.12."
    - "hmac.new(b'key', b'msg', 'md5').name == 'hmac-md5'."
    - "hmac.new(b'key', b'msg', 'sha1').name == 'hmac-sha1'."
    - "hmac.digest(b'key', b'msg', 'sha1') returns 20 bytes."
    - "hmac.digest(b'key', b'msg', 'sha384') returns 48 bytes."
    - "hmac.HMAC.__mro__[0].__name__ == 'HMAC' — first MRO entry is the class itself."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC-SHA1 known vector — key=b'key', msg=b'msg'
#
# hmac.zspec.zsdl covers this vector via {type:bytes_ascii} protocol.
# Here we re-record it using the !hex tag protocol — orthogonal representation,
# same invariant axis, from the hmac_extra7 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra7.new.sha1.hexdigest:
  description: "hmac.new(b'key', b'msg', 'sha1').hexdigest() == '102900b72b7bf1031eec76b4804b66052376896b'"
  category: known_vector
  rfc: "RFC 2104"
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: hexdigest
  method_args: []
  expected: "102900b72b7bf1031eec76b4804b66052376896b"

invariant hmac_extra7.new.sha1.name:
  description: "hmac.new(b'key', b'msg', 'sha1').name == 'hmac-sha1'"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: name.__eq__
  method_args: ["hmac-sha1"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC-MD5 known vector — not covered in any prior hmac spec
#
# Prior specs cover MD5 digest_size (hmac_extra/hmac_extra4) but never the
# hexdigest value, name attribute, or block_size for HMAC-MD5.
# ---------------------------------------------------------------------------

invariant hmac_extra7.new.md5.hexdigest:
  description: "hmac.new(b'key', b'msg', 'md5').hexdigest() == '18e3548c59ad40dd03907b7aeee71d67'"
  category: known_vector
  rfc: "RFC 2104"
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "md5"]
  method: hexdigest
  method_args: []
  expected: "18e3548c59ad40dd03907b7aeee71d67"

invariant hmac_extra7.new.md5.name:
  description: "hmac.new(b'key', b'msg', 'md5').name == 'hmac-md5'"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "md5"]
  method: name.__eq__
  method_args: ["hmac-md5"]
  expected: true

invariant hmac_extra7.new.md5.block_size:
  description: "hmac.new(b'key', b'msg', 'md5').block_size == 64 — MD5 uses 64-byte blocks"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "md5"]
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# HMAC-SHA1 properties — digest_size and block_size
#
# No prior hmac spec checks SHA-1 block_size (all prior sha1 coverage is
# digest_size only, and only in hmac.zspec.zsdl).
# ---------------------------------------------------------------------------

invariant hmac_extra7.new.sha1.block_size:
  description: "hmac.new(b'key', b'msg', 'sha1').block_size == 64 — SHA-1 uses 64-byte blocks"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hmac.digest() — SHA-1 and SHA-384 output lengths
#
# hmac_extra5 covers hmac.digest() for sha256 (32 bytes) and md5 (16 bytes).
# hmac_extra6 covers hmac.new().digest() for sha512 (64 bytes).
# No prior spec covers hmac.digest() (the one-shot function) for sha1 or sha384.
# ---------------------------------------------------------------------------

invariant hmac_extra7.digest.sha1_length:
  description: "len(hmac.digest(b'key', b'msg', 'sha1')) == 20 — SHA-1 produces 20 bytes"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: __len__
  method_args: []
  expected: 20

invariant hmac_extra7.digest.sha384_length:
  description: "len(hmac.digest(b'key', b'msg', 'sha384')) == 48 — SHA-384 produces 48 bytes"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha384"]
  method: __len__
  method_args: []
  expected: 48

# ---------------------------------------------------------------------------
# hmac.HMAC.__mro__[0].__name__ == 'HMAC'
#
# hmac_extra6 covers __mro__[1].__name__ == 'object' (second MRO entry).
# No prior spec checks __mro__[0] (the class itself).
# ---------------------------------------------------------------------------

invariant hmac_extra7.HMAC.mro_first_is_HMAC:
  description: "hmac.HMAC.__mro__[0].__name__ == 'HMAC' — first entry in MRO is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: HMAC.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "HMAC"

# ---------------------------------------------------------------------------
# hmac.HMAC.__mro__ length
#
# HMAC inherits only from object, so __mro__ has exactly two entries:
# [HMAC, object]. No prior spec checks the MRO length.
# ---------------------------------------------------------------------------

invariant hmac_extra7.HMAC.mro_length:
  description: "len(hmac.HMAC.__mro__) == 2 — HMAC MRO is [HMAC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: HMAC.__mro__.__len__
  args: []
  expected: 2
