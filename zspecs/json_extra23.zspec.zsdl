spec: json_extra23
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra22.zspec.zsdl."
    - "Prior specs covered: JSONDecoder/JSONEncoder/__name__/__module__/__qualname__/__bases__[0].__name__, JSONDecodeError/__name__/__module__/__bases__[0].__name__, loads/dumps/load/dump __name__/__module__/__qualname__, JSONDecoder/JSONEncoder/JSONDecodeError __init__.__name__, loads/dumps __qualname__ type checks."
    - "This spec covers: __len__() of __module__ strings for JSONDecoder, JSONEncoder, JSONDecodeError, loads, dumps, load, dump; __len__() of __name__ strings for JSONDecoder, JSONEncoder, JSONDecodeError, loads, dumps."
    - "No prior json spec checks json.JSONDecoder.__module__.__len__()."
    - "No prior json spec checks json.JSONEncoder.__module__.__len__()."
    - "No prior json spec checks json.JSONDecodeError.__module__.__len__()."
    - "No prior json spec checks json.JSONDecoder.__name__.__len__()."
    - "No prior json spec checks json.JSONEncoder.__name__.__len__()."
    - "No prior json spec checks json.JSONDecodeError.__name__.__len__()."
    - "No prior json spec checks json.loads.__module__.__len__()."
    - "No prior json spec checks json.dumps.__module__.__len__()."
    - "No prior json spec checks json.load.__module__.__len__()."
    - "No prior json spec checks json.dump.__module__.__len__()."
    - "No prior json spec checks json.loads.__name__.__len__()."
    - "No prior json spec checks json.dumps.__name__.__len__()."
    - "json.JSONDecoder.__module__ == 'json.decoder' — len 12."
    - "json.JSONEncoder.__module__ == 'json.encoder' — len 12."
    - "json.JSONDecodeError.__module__ == 'json.decoder' — len 12."
    - "json.JSONDecoder.__name__ == 'JSONDecoder' — len 11."
    - "json.JSONEncoder.__name__ == 'JSONEncoder' — len 11."
    - "json.JSONDecodeError.__name__ == 'JSONDecodeError' — len 15."
    - "json.loads.__module__ == 'json' — len 4."
    - "json.dumps.__module__ == 'json' — len 4."
    - "json.load.__module__ == 'json' — len 4."
    - "json.dump.__module__ == 'json' — len 4."
    - "json.loads.__name__ == 'loads' — len 5."
    - "json.dumps.__name__ == 'dumps' — len 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for JSONDecoder, JSONEncoder, JSONDecodeError
#
# JSONDecoder.__module__ and JSONDecodeError.__module__ are both 'json.decoder'
# (len 12).  JSONEncoder.__module__ is 'json.encoder' (len 12).  No prior json
# spec checks the length of any class's __module__ string.
# ---------------------------------------------------------------------------

invariant json_extra23.JSONDecoder.module.len:
  description: "json.JSONDecoder.__module__.__len__() == 12 — 'json.decoder' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: JSONDecoder.__module__.__len__
  args: []
  expected: 12

invariant json_extra23.JSONEncoder.module.len:
  description: "json.JSONEncoder.__module__.__len__() == 12 — 'json.encoder' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: JSONEncoder.__module__.__len__
  args: []
  expected: 12

invariant json_extra23.JSONDecodeError.module.len:
  description: "json.JSONDecodeError.__module__.__len__() == 12 — 'json.decoder' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: JSONDecodeError.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# __name__.__len__() for JSONDecoder, JSONEncoder, JSONDecodeError
#
# JSONDecoder.__name__ == 'JSONDecoder' (len 11), JSONEncoder.__name__ ==
# 'JSONEncoder' (len 11), JSONDecodeError.__name__ == 'JSONDecodeError' (len 15).
# No prior json spec checks the length of any class's __name__ string.
# ---------------------------------------------------------------------------

invariant json_extra23.JSONDecoder.name.len:
  description: "json.JSONDecoder.__name__.__len__() == 11 — 'JSONDecoder' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: JSONDecoder.__name__.__len__
  args: []
  expected: 11

invariant json_extra23.JSONEncoder.name.len:
  description: "json.JSONEncoder.__name__.__len__() == 11 — 'JSONEncoder' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: JSONEncoder.__name__.__len__
  args: []
  expected: 11

invariant json_extra23.JSONDecodeError.name.len:
  description: "json.JSONDecodeError.__name__.__len__() == 15 — 'JSONDecodeError' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: JSONDecodeError.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# __module__.__len__() for loads, dumps, load, dump
#
# All four top-level json functions have __module__ == 'json' (len 4).
# No prior json spec checks the length of any function's __module__ string.
# ---------------------------------------------------------------------------

invariant json_extra23.loads.module.len:
  description: "json.loads.__module__.__len__() == 4 — 'json' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: loads.__module__.__len__
  args: []
  expected: 4

invariant json_extra23.dumps.module.len:
  description: "json.dumps.__module__.__len__() == 4 — 'json' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: dumps.__module__.__len__
  args: []
  expected: 4

invariant json_extra23.load.module.len:
  description: "json.load.__module__.__len__() == 4 — 'json' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: load.__module__.__len__
  args: []
  expected: 4

invariant json_extra23.dump.module.len:
  description: "json.dump.__module__.__len__() == 4 — 'json' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: dump.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __name__.__len__() for loads and dumps
#
# loads.__name__ == 'loads' (len 5), dumps.__name__ == 'dumps' (len 5).
# No prior json spec checks the length of any function's __name__ string.
# ---------------------------------------------------------------------------

invariant json_extra23.loads.name.len:
  description: "json.loads.__name__.__len__() == 5 — 'loads' has 5 characters"
  category: string_lengths
  kind: python_call_eq
  function: loads.__name__.__len__
  args: []
  expected: 5

invariant json_extra23.dumps.name.len:
  description: "json.dumps.__name__.__len__() == 5 — 'dumps' has 5 characters"
  category: string_lengths
  kind: python_call_eq
  function: dumps.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Consolidated table — all twelve new invariants
#
# All twelve are first covered in this spec (json_extra23).
# ---------------------------------------------------------------------------

table json_extra23.module_and_name_lengths:
  description: "json class and function __module__/__name__ string lengths via __len__()"
  kind: python_call_eq
  category: string_lengths
  id_prefix: jfa23

  columns: [id, function, args, expected]
  rows:
    - [JSONDecoder_module_len,    JSONDecoder.__module__.__len__,    [], 12]
    - [JSONEncoder_module_len,    JSONEncoder.__module__.__len__,    [], 12]
    - [JSONDecodeError_module_len, JSONDecodeError.__module__.__len__, [], 12]
    - [JSONDecoder_name_len,      JSONDecoder.__name__.__len__,      [], 11]
    - [JSONEncoder_name_len,      JSONEncoder.__name__.__len__,      [], 11]
    - [JSONDecodeError_name_len,  JSONDecodeError.__name__.__len__,  [], 15]
    - [loads_module_len,          loads.__module__.__len__,          [],  4]
    - [dumps_module_len,          dumps.__module__.__len__,          [],  4]
    - [load_module_len,           load.__module__.__len__,           [],  4]
    - [dump_module_len,           dump.__module__.__len__,           [],  4]
    - [loads_name_len,            loads.__name__.__len__,            [],  5]
    - [dumps_name_len,            dumps.__name__.__len__,            [],  5]
