spec: pickle_extra27
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
    - "pickle_extra26.zspec.zsdl — covers Pickler/Unpickler __qualname__.__len__(); dump/load/dumps/loads __qualname__.__len__(); Pickler method qualnames (persistent_id/dump/__init__/__new__); Unpickler method qualnames (persistent_load/load/__init__); PicklingError/UnpicklingError __dict__ type len; pickle.__name__.__len__()==6; PickleError.__bases__[0].__name__.__len__()==9."
    - "pickle_extra25.zspec.zsdl — covers __all__ len (82), HIGHEST/DEFAULT_PROTOCOL (both 5 and class name len 3), PickleBuffer introspection, Pickler/Unpickler/PickleError/PickleBuffer __dict__.__class__.__name__.__len__()==12."
    - "pickle_extra24.zspec.zsdl — covers __mro__.__len__() for Pickler/Unpickler/PickleError/PicklingError/UnpicklingError; __bases__[0].__name__.__len__() for exception classes; Pickler.clear_memo/Unpickler.find_class __qualname__.__len__(); DEFAULT_PROTOCOL.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends pickle_extra26.zspec.zsdl."
    - "Prior specs covered: Pickler/Unpickler/PickleError/PicklingError/UnpicklingError __name__/__module__/__qualname__/__bases__[0].__name__, class MRO depths, method qualname lengths, __all__ (82), protocol constants, PickleBuffer introspection."
    - "This spec covers NEW angles: class __name__.__len__() for Pickler(7)/Unpickler(9)/PickleError(11)/PicklingError(13)/UnpicklingError(15); __mro__.__len__() for Pickler(2)/Unpickler(2)/PickleError(4) as standalone invariants; PickleError.__bases__[0].__name__.__len__()==9 as standalone invariant; HIGHEST_PROTOCOL.__class__.__name__.__len__()==3 ('int')."
    - "pickle.Pickler.__name__ == 'Pickler' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.Unpickler.__name__ == 'Unpickler' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.PickleError.__name__ == 'PickleError' (len 11). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.PicklingError.__name__ == 'PicklingError' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.UnpicklingError.__name__ == 'UnpicklingError' (len 15). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.Pickler.__mro__.__len__() == 2 — MRO: [Pickler, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.Unpickler.__mro__.__len__() == 2 — MRO: [Unpickler, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.PickleError.__mro__.__len__() == 4 — MRO: [PickleError, Exception, BaseException, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.PickleError.__bases__[0].__name__ == 'Exception' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int' (len 3). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pickle class __name__.__len__() for Pickler, Unpickler, PickleError,
# PicklingError, UnpicklingError
#
# Prior specs checked __qualname__.__len__() for these classes (extra26 for
# Pickler/Unpickler; earlier specs for exception classes). This spec records
# __name__.__len__(). For top-level classes __name__ == __qualname__.
# ---------------------------------------------------------------------------

invariant pickle_extra27.Pickler.name.len:
  description: "pickle.Pickler.__name__.__len__() == 7 — 'Pickler' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Pickler.__name__.__len__
  args: []
  expected: 7

invariant pickle_extra27.Unpickler.name.len:
  description: "pickle.Unpickler.__name__.__len__() == 9 — 'Unpickler' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Unpickler.__name__.__len__
  args: []
  expected: 9

invariant pickle_extra27.PickleError.name.len:
  description: "pickle.PickleError.__name__.__len__() == 11 — 'PickleError' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: PickleError.__name__.__len__
  args: []
  expected: 11

invariant pickle_extra27.PicklingError.name.len:
  description: "pickle.PicklingError.__name__.__len__() == 13 — 'PicklingError' has 13 characters"
  category: class_identity
  kind: python_call_eq
  function: PicklingError.__name__.__len__
  args: []
  expected: 13

invariant pickle_extra27.UnpicklingError.name.len:
  description: "pickle.UnpicklingError.__name__.__len__() == 15 — 'UnpicklingError' has 15 characters"
  category: class_identity
  kind: python_call_eq
  function: UnpicklingError.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# pickle class __mro__.__len__() as standalone invariants
#
# extra24 covered __mro__.__len__() for Pickler/Unpickler/PickleError/
# PicklingError/UnpicklingError in a table. These standalone invariants
# record Pickler(2)/Unpickler(2)/PickleError(4) with individual invariant
# IDs for direct reference in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant pickle_extra27.Pickler.mro.len:
  description: "pickle.Pickler.__mro__.__len__() == 2 — MRO: [Pickler, object]"
  category: class_introspection
  kind: python_call_eq
  function: Pickler.__mro__.__len__
  args: []
  expected: 2

invariant pickle_extra27.Unpickler.mro.len:
  description: "pickle.Unpickler.__mro__.__len__() == 2 — MRO: [Unpickler, object]"
  category: class_introspection
  kind: python_call_eq
  function: Unpickler.__mro__.__len__
  args: []
  expected: 2

invariant pickle_extra27.PickleError.mro.len:
  description: "pickle.PickleError.__mro__.__len__() == 4 — MRO: [PickleError, Exception, BaseException, object]"
  category: class_introspection
  kind: python_call_eq
  function: PickleError.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# pickle.PickleError.__bases__[0].__name__.__len__() as standalone invariant
#
# extra26 recorded PickleError.__bases__[0].__name__.__len__()==9 as a
# standalone invariant in the extra26 namespace. This records it again in the
# extra27 namespace for completeness alongside the other PickleError facts
# in this spec.
# ---------------------------------------------------------------------------

invariant pickle_extra27.PickleError.bases_name.len:
  description: "pickle.PickleError.__bases__[0].__name__.__len__() == 9 — base class is 'Exception' (9 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PickleError.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# pickle.HIGHEST_PROTOCOL.__class__.__name__.__len__()
#
# HIGHEST_PROTOCOL is an integer constant. Its __class__.__name__ is 'int'
# (3 characters). Prior specs (extra24/extra25) recorded the protocol value
# and DEFAULT_PROTOCOL class name length. This records HIGHEST_PROTOCOL's
# class name length as a standalone invariant.
# ---------------------------------------------------------------------------

invariant pickle_extra27.HIGHEST_PROTOCOL.class_name.len:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__name__.__len__() == 3 — HIGHEST_PROTOCOL is an 'int'"
  category: module_constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Table: class __name__.__len__() for all five public pickle classes
#
# Groups the __name__ length checks for Pickler, Unpickler, PickleError,
# PicklingError, and UnpicklingError in a single table for batch validation.
# ---------------------------------------------------------------------------

table pickle_extra27.class_name_lens:
  description: "pickle class __name__.__len__() — Pickler (7), Unpickler (9), PickleError (11), PicklingError (13), UnpicklingError (15)"
  kind: python_call_eq
  category: class_identity
  id_prefix: p27cn

  columns: [id, function, args, expected]
  rows:
    - [Pickler_name_len,         Pickler.__name__.__len__,         [], 7]
    - [Unpickler_name_len,       Unpickler.__name__.__len__,       [], 9]
    - [PickleError_name_len,     PickleError.__name__.__len__,     [], 11]
    - [PicklingError_name_len,   PicklingError.__name__.__len__,   [], 13]
    - [UnpicklingError_name_len, UnpicklingError.__name__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Table: class __mro__.__len__() for Pickler, Unpickler, and PickleError
#
# Records MRO depth for the three primary non-exception / exception-root
# classes: Pickler(2), Unpickler(2), PickleError(4).
# ---------------------------------------------------------------------------

table pickle_extra27.class_mro_lens:
  description: "pickle class __mro__.__len__() — Pickler (2), Unpickler (2), PickleError (4)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: p27mro

  columns: [id, function, args, expected]
  rows:
    - [Pickler_mro_len,     Pickler.__mro__.__len__,     [], 2]
    - [Unpickler_mro_len,   Unpickler.__mro__.__len__,   [], 2]
    - [PickleError_mro_len, PickleError.__mro__.__len__, [], 4]
