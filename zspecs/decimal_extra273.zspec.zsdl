spec: decimal_extra273
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.zspec.zsdl covers: str_repr, predicates, as_tuple, class name, getcontext().prec, error case."
    - "decimal_extra272 covers: context function identity, Context class, getcontext() result, BasicContext/DefaultContext."
    - "This spec focuses on to_integral_value() rounding (ROUND_HALF_EVEN) and exact string representation."
    - "Decimal.to_integral_value() uses ROUND_HALF_EVEN by default: 1.5→2, 2.5→2, 3.5→4, -1.5→-2, -2.5→-2."
    - "ROUND_HALF_EVEN (banker's rounding) rounds to the nearest even digit at exactly halfway — 2.5→2 (even), 3.5→4 (even)."
    - "Decimal('0.1').__str__() == '0.1' — exact decimal representation, unlike binary float 0.1."
    - "Decimal('0.3').__str__() == '0.3' — exact; contrast with float 0.1+0.2 == 0.30000000000000004."
    - "Decimal('1.0').__eq__(1) is True — Decimal compares equal to int with same value."
    - "Decimal('1.00').__eq__(1) is True — equality ignores trailing zeros."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.to_integral_value() — rounds to integer using ROUND_HALF_EVEN (default)
#
# ROUND_HALF_EVEN (banker's rounding): 1.5→2, 2.5→2, 3.5→4
# Negative values: -1.5→-2, -2.5→-2 (rounds to even in absolute value)
# to_integral_value() takes no required args — safe to call with method: to_integral_value
# Result accessed via __str__ for comparison
# ---------------------------------------------------------------------------

table decimal_extra273.to_integral_value:
  description: "Decimal.to_integral_value() with ROUND_HALF_EVEN — banker's rounding to nearest integer"
  kind: python_call_eq
  category: rounding
  id_prefix: tiv
  function: Decimal
  method: to_integral_value
  method_chain: __str__

  columns: [id, args, expected, description]
  rows:
    - [one_point_five,    ["1.5"],  "2",  "Decimal('1.5').to_integral_value() == '2' — rounds to even (2 is even)"]
    - [two_point_five,    ["2.5"],  "2",  "Decimal('2.5').to_integral_value() == '2' — rounds to even (2 is even)"]
    - [three_point_five,  ["3.5"],  "4",  "Decimal('3.5').to_integral_value() == '4' — rounds to even (4 is even)"]
    - [one_point_four,    ["1.4"],  "1",  "Decimal('1.4').to_integral_value() == '1' — rounds down (below 0.5)"]
    - [one_point_six,     ["1.6"],  "2",  "Decimal('1.6').to_integral_value() == '2' — rounds up (above 0.5)"]
    - [neg_one_point_five, ["-1.5"], "-2", "Decimal('-1.5').to_integral_value() == '-2' — ROUND_HALF_EVEN applies to negatives too"]
    - [neg_two_point_five, ["-2.5"], "-2", "Decimal('-2.5').to_integral_value() == '-2' — rounds to even (2 is even in absolute value)"]

# ---------------------------------------------------------------------------
# Decimal.quantize(1) — same as to_integral_value but via quantize with integer exp
# quantize(1) is equivalent to quantize(Decimal('1')) since int->Decimal conversion works
# ---------------------------------------------------------------------------

table decimal_extra273.quantize_to_integer:
  description: "Decimal.quantize(1) — rounding to integer precision (ROUND_HALF_EVEN default)"
  kind: python_call_eq
  category: quantize
  id_prefix: qti
  function: Decimal
  method: quantize
  method_args: [1]
  method_chain: __str__

  columns: [id, args, expected, description]
  rows:
    - [one_point_five,   ["1.5"],  "2", "Decimal('1.5').quantize(1) == '2' — ROUND_HALF_EVEN to integer"]
    - [two_point_five,   ["2.5"],  "2", "Decimal('2.5').quantize(1) == '2' — rounds to even integer"]
    - [three_point_five, ["3.5"],  "4", "Decimal('3.5').quantize(1) == '4' — rounds to even integer"]
    - [neg_two_five,     ["-2.5"], "-2", "Decimal('-2.5').quantize(1) == '-2' — rounds to even for negative"]

# ---------------------------------------------------------------------------
# Exact string representation — Decimal preserves decimal exactness
# Decimal('0.1') str is '0.1' (not '0.10000000000000001')
# Decimal('0.3') str is '0.3' (showing decimal arithmetic can produce exact '0.3')
# ---------------------------------------------------------------------------

invariant decimal_extra273.str_repr.zero_point_one:
  description: "str(Decimal('0.1')) == '0.1' — Decimal preserves exact decimal encoding; contrast with float 0.1"
  category: string_repr
  kind: python_call_eq
  function: Decimal
  args: ["0.1"]
  method: __str__
  expected: "0.1"

invariant decimal_extra273.str_repr.zero_point_three:
  description: "str(Decimal('0.3')) == '0.3' — Decimal('0.3') is exactly '0.3'; float 0.1+0.2 is 0.30000000000000004"
  category: string_repr
  kind: python_call_eq
  function: Decimal
  args: ["0.3"]
  method: __str__
  expected: "0.3"

invariant decimal_extra273.str_repr.one_point_21:
  description: "str(Decimal('1.21')) == '1.21' — Decimal preserves two-decimal-place exactness"
  category: string_repr
  kind: python_call_eq
  function: Decimal
  args: ["1.21"]
  method: __str__
  expected: "1.21"

# ---------------------------------------------------------------------------
# Equality: Decimal == int — Decimal values compare equal to int of same value
# Decimal('1.0').__eq__(1) == True — equality ignores trailing zeros and matches int
# ---------------------------------------------------------------------------

invariant decimal_extra273.equality.decimal_1_0_eq_int_1:
  description: "Decimal('1.0').__eq__(1) == True — Decimal('1.0') compares equal to integer 1"
  category: equality
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: __eq__
  method_args: [1]
  expected: true

invariant decimal_extra273.equality.decimal_1_00_eq_int_1:
  description: "Decimal('1.00').__eq__(1) == True — trailing zeros do not affect equality"
  category: equality
  kind: python_call_eq
  function: Decimal
  args: ["1.00"]
  method: __eq__
  method_args: [1]
  expected: true

invariant decimal_extra273.equality.decimal_class_name:
  description: "Decimal('0.3').__class__.__name__ == 'Decimal' — result of Decimal constructor is a Decimal instance"
  category: class_metadata
  kind: python_call_eq
  function: Decimal
  args: ["0.3"]
  method: __class__.__name__
  expected: "Decimal"
