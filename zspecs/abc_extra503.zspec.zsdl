spec: abc_extra503
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Abstract Base Classes module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abstractproperty, abstractclassmethod, abstractstaticmethod are deprecated since Python 3.3 but still present"
    - "__subclasshook__ is a classmethod defined on ABC via ABCMeta"
    - "qualname checks confirm no nesting for top-level abc symbols"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra503.subclasshook_identity:
  description: "abc.ABC.__subclasshook__ method name invariant"
  kind: python_call_eq
  category: class_identity
  id_prefix: SSH

  columns: [id, function, args, expected]
  rows:
    - [SSH001, abc.ABC.__subclasshook__.__name__.__eq__, ["__subclasshook__"], true]

table abc_extra503.abcmeta_qualnames:
  description: "ABCMeta method qualname invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: AMQ

  columns: [id, function, args, expected]
  rows:
    - [AMQ001, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true]
    - [AMQ002, abc.ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true]
    - [AMQ003, abc.ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"], true]

table abc_extra503.class_qualnames:
  description: "Top-level abc class qualname invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: CLQ

  columns: [id, function, args, expected]
  rows:
    - [CLQ001, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [CLQ002, abc.ABC.__qualname__.__eq__, ["ABC"], true]

table abc_extra503.decorator_qualnames:
  description: "abc decorator and deprecated class qualname invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: DCQ

  columns: [id, function, args, expected]
  rows:
    - [DCQ001, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [DCQ002, abc.abstractproperty.__qualname__.__eq__, ["abstractproperty"], true]
    - [DCQ003, abc.abstractclassmethod.__qualname__.__eq__, ["abstractclassmethod"], true]
    - [DCQ004, abc.abstractstaticmethod.__qualname__.__eq__, ["abstractstaticmethod"], true]
