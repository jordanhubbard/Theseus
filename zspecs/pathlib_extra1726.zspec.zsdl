spec: pathlib_extra1726
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "pathlib.PurePath defines all comparison operators directly in its own __dict__."
    - "pathlib.PurePath.__dict__.__contains__('__lt__') is True — PurePath is orderable."
    - "pathlib.PurePath.__dict__.__contains__('__le__') is True."
    - "pathlib.PurePath.__dict__.__contains__('__gt__') is True."
    - "pathlib.PurePath.__dict__.__contains__('__ge__') is True."
    - "pathlib.PurePath.__dict__.__contains__('__eq__') is True — PurePath defines equality."
    - "pathlib.PurePath.__dict__.__contains__('__hash__') is True — PurePath is hashable."
    - "pathlib.Path.__dict__.__contains__('__lt__') is False — Path inherits from PurePath and does not redefine ordering."
    - "pathlib.PurePosixPath.__dict__.__contains__('__lt__') is False — PurePosixPath inherits from PurePath."
    - "All comparison methods are defined on PurePath, not on any of its subclasses."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra1726.purepath_comparison_protocol:
  description: "pathlib.PurePath comparison protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1726

  columns: [id, function, args, expected]
  rows:
    - ["pl1726001", "pathlib.PurePath.__dict__.__contains__",      ["__lt__"], true ]
    - ["pl1726002", "pathlib.PurePath.__dict__.__contains__",      ["__le__"], true ]
    - ["pl1726003", "pathlib.PurePath.__dict__.__contains__",      ["__gt__"], true ]
    - ["pl1726004", "pathlib.PurePath.__dict__.__contains__",      ["__ge__"], true ]
    - ["pl1726005", "pathlib.PurePath.__dict__.__contains__",      ["__eq__"], true ]
    - ["pl1726006", "pathlib.PurePath.__dict__.__contains__",      ["__hash__"], true]
    - ["pl1726007", "pathlib.Path.__dict__.__contains__",          ["__lt__"], false]
    - ["pl1726008", "pathlib.Path.__dict__.__contains__",          ["__le__"], false]
    - ["pl1726009", "pathlib.Path.__dict__.__contains__",          ["__gt__"], false]
    - ["pl1726010", "pathlib.Path.__dict__.__contains__",          ["__ge__"], false]
    - ["pl1726011", "pathlib.Path.__dict__.__contains__",          ["__ne__"], false]
    - ["pl1726012", "pathlib.PurePosixPath.__dict__.__contains__", ["__lt__"], false]
    - ["pl1726013", "pathlib.PurePosixPath.__dict__.__contains__", ["__le__"], false]
    - ["pl1726014", "pathlib.PurePosixPath.__dict__.__contains__", ["__gt__"], false]
    - ["pl1726015", "pathlib.PurePosixPath.__dict__.__contains__", ["__ge__"], false]
    - ["pl1726016", "pathlib.PurePosixPath.__dict__.__contains__", ["__ne__"], false]

table pathlib_extra1726.purepath_ne_protocol:
  description: "pathlib.PurePath __ne__ and subclass eq/hash dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1726

  columns: [id, function, args, expected]
  rows:
    - ["pl1726017", "pathlib.PurePath.__dict__.__contains__",      ["__ne__"],   false]
    - ["pl1726018", "pathlib.Path.__dict__.__contains__",          ["__eq__"],   false]
    - ["pl1726019", "pathlib.Path.__dict__.__contains__",          ["__hash__"], false]
    - ["pl1726020", "pathlib.PurePosixPath.__dict__.__contains__", ["__eq__"],   false]
    - ["pl1726021", "pathlib.PurePosixPath.__dict__.__contains__", ["__hash__"], false]
