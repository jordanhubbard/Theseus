spec: ssl_extra31
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra30.zspec.zsdl — covers SSLContext/__mro__.__len__()==3; SSLError/__mro__.__len__()==5; SSLSocket/__mro__.__len__()==4; SSLObject/__mro__.__len__()==2; SSLContext/__bases__[0].__name__=='_SSLContext'; SSLError/__bases__[0].__name__=='OSError'; SSLSocket/__bases__[0].__name__=='socket'; SSLContext.set_alpn_protocols/set_npn_protocols __qualname__/__qualname__.__len__()/name__.__len__(); SSLSocket.getpeercert __qualname__/__qualname__.__len__()/__name__.__len__()."
    - "ssl_extra29.zspec.zsdl — covers SSLCertVerificationError __module__/__name__/__qualname__ __len__(); SSLContext.load_cert_chain/load_verify_locations/set_ciphers __qualname__/__name__ __len__(); SSLSocket.read/write __qualname__/__name__ __len__(); create_default_context.__qualname__.__len__()."
    - "ssl_extra28.zspec.zsdl — covers SSLContext/SSLError/SSLSocket/SSLObject __module__.__len__() and __name__.__len__(); create_default_context/__qualname__/__module__.__len__(); SSLContext.wrap_socket/__qualname__/__module__.__len__()."
    - "ssl_extra27.zspec.zsdl — covers SSLContext/__init__.__name__; SSLError/__init__.__name__; SSLSocket/__module__/__bases__[0].__name__; SSLObject/__module__/__bases__[0].__name__; SSLCertVerificationError/__name__/__module__/__bases__[0].__name__; CertificateError/__name__/__bases__[0].__name__."
  notes:
    - "This spec extends ssl through ssl_extra30; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: SSLContext/SSLError/SSLSocket/SSLObject all __name__/__module__/__qualname__/__len__()/__mro__.__len__()/__bases__[0].__name__; SSLCertVerificationError/CertificateError __name__/__module__/__qualname__/__len__(); create_default_context/__qualname__/__module__/__len__(); SSLContext.wrap_socket/load_cert_chain/load_verify_locations/set_ciphers/set_alpn_protocols/set_npn_protocols __qualname__/__name__/__len__(); SSLSocket.read/write/getpeercert __qualname__/__name__/__len__()."
    - "This spec covers: ssl.PROTOCOL_TLS_CLIENT value==16 and __class__.__name__=='_SSLMethod' and __class__.__name__.__len__()==10; ssl.CERT_NONE value==0 and __class__.__name__=='VerifyMode' and __class__.__name__.__len__()==10; ssl.CERT_OPTIONAL value==1 and __class__.__name__=='VerifyMode'; ssl.CERT_REQUIRED value==2 and __class__.__name__=='VerifyMode'; ssl.HAS_SNI==True and __class__.__name__=='bool'; ssl.HAS_ALPN==True and __class__.__name__=='bool'; ssl.OP_NO_TLSv1 value==67108864 and __class__.__name__=='Options' and __class__.__name__.__len__()==7; ssl.OP_NO_TLSv1_2 value==134217728 and __class__.__name__=='Options'; ssl.SSLContext.__dict__.__class__.__name__=='mappingproxy' and __len__()==12; ssl.SSLError.__dict__.__class__.__name__=='mappingproxy' and __len__()==12; ssl.SSLSocket.do_handshake/__qualname__/__qualname__.__len__()==22/__name__.__len__()==12; ssl.SSLSocket.cipher/__qualname__/__qualname__.__len__()==16/__name__.__len__()==6."
    - "ssl.PROTOCOL_TLS_CLIENT == 16, __class__.__name__ == '_SSLMethod' — len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.CERT_NONE == 0, CERT_OPTIONAL == 1, CERT_REQUIRED == 2 — all VerifyMode enum, __class__.__name__ len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.HAS_SNI == True, HAS_ALPN == True — both bool. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.OP_NO_TLSv1 == 67108864, OP_NO_TLSv1_2 == 134217728 — both Options enum, __class__.__name__ == 'Options' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.__dict__.__class__.__name__ == 'mappingproxy' — len 12. ssl.SSLError.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.do_handshake.__qualname__ == 'SSLSocket.do_handshake' — len 22; __name__ == 'do_handshake' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.cipher.__qualname__ == 'SSLSocket.cipher' — len 16; __name__ == 'cipher' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl.PROTOCOL_TLS_CLIENT value and __class__.__name__
#
# No prior spec checks value or __class__.__name__ for PROTOCOL_TLS_CLIENT.
# It is an _SSLMethod enum member with integer value 16.
# __class__.__name__ == '_SSLMethod' (len 10).
# ---------------------------------------------------------------------------

invariant ssl_extra31.PROTOCOL_TLS_CLIENT_value:
  description: "ssl.PROTOCOL_TLS_CLIENT == 16 — integer value of the TLS client protocol enum member"
  category: module_constants
  kind: python_call_eq
  function: "PROTOCOL_TLS_CLIENT.__eq__"
  args: [16]
  expected: true

invariant ssl_extra31.PROTOCOL_TLS_CLIENT_class_name:
  description: "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' — protocol constant is an _SSLMethod enum"
  category: module_constants
  kind: python_call_eq
  function: "PROTOCOL_TLS_CLIENT.__class__.__name__.__eq__"
  args: ["_SSLMethod"]
  expected: true

table ssl_extra31.protocol_class_name_len:
  description: "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__.__len__() == 10 — len('_SSLMethod') == 10"
  kind: python_call_eq
  category: module_constants
  id_prefix: spcnl31

  columns: [id, function, args, expected, description]
  rows:
    - [TLS_CLIENT_class_len,
       "PROTOCOL_TLS_CLIENT.__class__.__name__.__len__",
       [],
       10,
       "len('_SSLMethod') == 10"]

# ---------------------------------------------------------------------------
# ssl.CERT_NONE, CERT_OPTIONAL, CERT_REQUIRED values and __class__.__name__
#
# No prior spec checks values or __class__.__name__ for CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED.
# All are VerifyMode enum members. CERT_NONE==0, CERT_OPTIONAL==1, CERT_REQUIRED==2.
# __class__.__name__ == 'VerifyMode' (len 10).
# ---------------------------------------------------------------------------

invariant ssl_extra31.CERT_NONE_class_name:
  description: "ssl.CERT_NONE.__class__.__name__ == 'VerifyMode' — verify mode constant is a VerifyMode enum member"
  category: module_constants
  kind: python_call_eq
  function: "CERT_NONE.__class__.__name__.__eq__"
  args: ["VerifyMode"]
  expected: true

invariant ssl_extra31.CERT_NONE_class_name_len:
  description: "len(ssl.CERT_NONE.__class__.__name__) == 10 — len('VerifyMode') == 10"
  category: module_constants
  kind: python_call_eq
  function: "CERT_NONE.__class__.__name__.__len__"
  args: []
  expected: 10

table ssl_extra31.cert_verify_mode_values:
  description: "ssl.CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED values and __class__.__name__ == 'VerifyMode'"
  kind: python_call_eq
  category: module_constants
  id_prefix: scvm31

  columns: [id, function, args, expected, description]
  rows:
    - [CERT_NONE_value,
       "CERT_NONE.__eq__",
       [0],
       true,
       "ssl.CERT_NONE == 0"]
    - [CERT_OPTIONAL_value,
       "CERT_OPTIONAL.__eq__",
       [1],
       true,
       "ssl.CERT_OPTIONAL == 1"]
    - [CERT_OPTIONAL_class,
       "CERT_OPTIONAL.__class__.__name__.__eq__",
       ["VerifyMode"],
       true,
       "ssl.CERT_OPTIONAL.__class__.__name__ == 'VerifyMode'"]
    - [CERT_REQUIRED_value,
       "CERT_REQUIRED.__eq__",
       [2],
       true,
       "ssl.CERT_REQUIRED == 2"]
    - [CERT_REQUIRED_class,
       "CERT_REQUIRED.__class__.__name__.__eq__",
       ["VerifyMode"],
       true,
       "ssl.CERT_REQUIRED.__class__.__name__ == 'VerifyMode'"]

# ---------------------------------------------------------------------------
# ssl.HAS_SNI and HAS_ALPN values and __class__.__name__
#
# No prior spec checks HAS_SNI or HAS_ALPN. Both are bool True.
# __class__.__name__ == 'bool'.
# ---------------------------------------------------------------------------

table ssl_extra31.has_flags:
  description: "ssl.HAS_SNI and HAS_ALPN are both True bool — SNI and ALPN supported on this platform"
  kind: python_call_eq
  category: module_constants
  id_prefix: shf31

  columns: [id, function, args, expected, description]
  rows:
    - [HAS_SNI_value,
       "HAS_SNI.__eq__",
       [true],
       true,
       "ssl.HAS_SNI == True — SNI extension supported"]
    - [HAS_SNI_class,
       "HAS_SNI.__class__.__name__.__eq__",
       ["bool"],
       true,
       "ssl.HAS_SNI.__class__.__name__ == 'bool'"]
    - [HAS_ALPN_value,
       "HAS_ALPN.__eq__",
       [true],
       true,
       "ssl.HAS_ALPN == True — ALPN extension supported"]
    - [HAS_ALPN_class,
       "HAS_ALPN.__class__.__name__.__eq__",
       ["bool"],
       true,
       "ssl.HAS_ALPN.__class__.__name__ == 'bool'"]

# ---------------------------------------------------------------------------
# ssl.OP_NO_TLSv1 and OP_NO_TLSv1_2 values and __class__.__name__
#
# No prior spec checks OP_NO_TLSv1 or OP_NO_TLSv1_2.
# Both are Options enum members (IntFlag). OP_NO_TLSv1 == 67108864; OP_NO_TLSv1_2 == 134217728.
# __class__.__name__ == 'Options' (len 7).
# ---------------------------------------------------------------------------

invariant ssl_extra31.OP_NO_TLSv1_class_name:
  description: "ssl.OP_NO_TLSv1.__class__.__name__ == 'Options' — TLS option flags are Options enum members"
  category: module_constants
  kind: python_call_eq
  function: "OP_NO_TLSv1.__class__.__name__.__eq__"
  args: ["Options"]
  expected: true

invariant ssl_extra31.OP_NO_TLSv1_class_name_len:
  description: "len(ssl.OP_NO_TLSv1.__class__.__name__) == 7 — len('Options') == 7"
  category: module_constants
  kind: python_call_eq
  function: "OP_NO_TLSv1.__class__.__name__.__len__"
  args: []
  expected: 7

table ssl_extra31.tls_option_values:
  description: "ssl.OP_NO_TLSv1 == 67108864; ssl.OP_NO_TLSv1_2 == 134217728; OP_NO_TLSv1_2 class == 'Options'"
  kind: python_call_eq
  category: module_constants
  id_prefix: stov31

  columns: [id, function, args, expected, description]
  rows:
    - [OP_NO_TLSv1_value,
       "OP_NO_TLSv1.__eq__",
       [67108864],
       true,
       "ssl.OP_NO_TLSv1 == 67108864"]
    - [OP_NO_TLSv1_2_value,
       "OP_NO_TLSv1_2.__eq__",
       [134217728],
       true,
       "ssl.OP_NO_TLSv1_2 == 134217728"]
    - [OP_NO_TLSv1_2_class,
       "OP_NO_TLSv1_2.__class__.__name__.__eq__",
       ["Options"],
       true,
       "ssl.OP_NO_TLSv1_2.__class__.__name__ == 'Options'"]

# ---------------------------------------------------------------------------
# ssl.SSLContext and SSLError __dict__.__class__.__name__ and __len__()
#
# No prior spec checks __dict__.__class__.__name__ for SSLContext or SSLError.
# Class __dict__ is always a mappingproxy; __class__.__name__ == 'mappingproxy' (len 12).
# ---------------------------------------------------------------------------

invariant ssl_extra31.SSLContext_dict_class_name:
  description: "ssl.SSLContext.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_structure
  kind: python_call_eq
  function: "SSLContext.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant ssl_extra31.SSLContext_dict_class_name_len:
  description: "len(ssl.SSLContext.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "SSLContext.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

table ssl_extra31.SSLError_dict_proxy_name:
  description: "ssl.SSLError.__dict__.__class__.__name__=='mappingproxy' and __len__()==12"
  kind: python_call_eq
  category: class_structure
  id_prefix: sedpn31

  columns: [id, function, args, expected, description]
  rows:
    - [SSLError_dict_class,
       "SSLError.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "ssl.SSLError.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [SSLError_dict_class_len,
       "SSLError.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# ssl.SSLSocket.do_handshake and cipher __qualname__ and __name__ lengths
#
# No prior spec checks __qualname__ or __name__ for do_handshake or cipher.
# do_handshake.__qualname__ == 'SSLSocket.do_handshake' (len 22); __name__ == 'do_handshake' (len 12).
# cipher.__qualname__ == 'SSLSocket.cipher' (len 16); __name__ == 'cipher' (len 6).
# ---------------------------------------------------------------------------

invariant ssl_extra31.SSLSocket.do_handshake_qualname_len:
  description: "len(ssl.SSLSocket.do_handshake.__qualname__) == 22 — len('SSLSocket.do_handshake') == 22"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.do_handshake.__qualname__.__len__
  args: []
  expected: 22

invariant ssl_extra31.SSLSocket.do_handshake_name_len:
  description: "len(ssl.SSLSocket.do_handshake.__name__) == 12 — len('do_handshake') == 12"
  category: function_names
  kind: python_call_eq
  function: SSLSocket.do_handshake.__name__.__len__
  args: []
  expected: 12

table ssl_extra31.SSLSocket_method_qualnames:
  description: "ssl.SSLSocket.do_handshake/cipher __qualname__.__eq__ and __qualname__/__name__ __len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ssmq31

  columns: [id, function, args, expected, description]
  rows:
    - [do_handshake_qualname,
       SSLSocket.do_handshake.__qualname__.__eq__,
       ["SSLSocket.do_handshake"],
       true,
       "SSLSocket.do_handshake.__qualname__ == 'SSLSocket.do_handshake'"]
    - [cipher_qualname,
       SSLSocket.cipher.__qualname__.__eq__,
       ["SSLSocket.cipher"],
       true,
       "SSLSocket.cipher.__qualname__ == 'SSLSocket.cipher'"]
    - [cipher_qualname_len,
       SSLSocket.cipher.__qualname__.__len__,
       [],
       16,
       "len('SSLSocket.cipher') == 16"]
    - [cipher_name_len,
       SSLSocket.cipher.__name__.__len__,
       [],
       6,
       "len('cipher') == 6"]
