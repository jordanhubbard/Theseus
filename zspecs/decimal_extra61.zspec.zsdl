spec: decimal_extra61
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra60.zspec.zsdl — covers Decimal/__doc__.__contains__('integer'/'string'); DecimalException/__doc__.__contains__('signal') raises AttributeError; decimal/__spec__.name/__class__.__name__.__eq__('str'); ROUND_HALF_UP/__contains__('HALF'); ROUND_HALF_EVEN/__contains__('HALF')."
    - "decimal_extra58.zspec.zsdl — covers Decimal/__doc__.__contains__('Decimal'/'value'); ROUND_UP/ROUND_DOWN __class__.__name__.__eq__('str') and __contains__('ROUND')."
    - "decimal_extra25.zspec.zsdl — covers ROUND_HALF_EVEN/__class__.__name__.__eq__('str'); ROUND_HALF_UP/__class__.__name__.__eq__('str')."
    - "decimal_extra23.zspec.zsdl — covers ROUND_HALF_UP/__class__.__name__.__eq__('str') and ROUND_HALF_EVEN/__class__.__name__.__eq__('str')."
    - "decimal_extra6.zspec.zsdl — covers ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN')."
    - "decimal_extra4.zspec.zsdl — covers ROUND_HALF_UP.__eq__('ROUND_HALF_UP') and ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN')."
    - "decimal_extra2.zspec.zsdl — covers ROUND_HALF_UP.__eq__('ROUND_HALF_UP')."
    - "decimal_extra.zspec.zsdl — covers ROUND_HALF_UP.__eq__('ROUND_HALF_UP')."
  notes:
    - "This spec extends decimal_extra60.zspec.zsdl."
    - "Theme: rounding constant string lengths and getcontext class identity."
    - "Decimal and Context are C extensions — no __code__. decimal module-level functions (getcontext/setcontext/localcontext) are C built-in functions — no __code__."
    - "ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 characters (R-O-U-N-D-_-H-A-L-F-_-U-P). No prior decimal spec checks ROUND_HALF_UP.__len__() in decimalconst61 namespace. Novel __len__ anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_HALF_DOWN.__len__() == 15 — 'ROUND_HALF_DOWN' has 15 characters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 characters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_UP.__len__() == 8 — 'ROUND_UP' has 8 characters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 characters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_CEILING.__len__() == 13 — 'ROUND_CEILING' has 13 characters (R-O-U-N-D-_-C-E-I-L-I-N-G). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_FLOOR.__len__() == 11 — 'ROUND_FLOOR' has 11 characters (R-O-U-N-D-_-F-L-O-O-R). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_05UP.__len__() == 10 — 'ROUND_05UP' has 10 characters (R-O-U-N-D-_-0-5-U-P). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "getcontext.__class__.__name__ == 'builtin_function_or_method' — getcontext is a C built-in function from the _decimal extension module. Its type is builtin_function_or_method. No prior decimal spec checks getcontext.__class__.__name__ in decimalconst61 namespace. Novel class-name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_HALF_UP.__class__.__name__ == 'str' — rounding constants are strings. decimal_extra25 and extra23 covered ROUND_HALF_UP/__class__.__name__.__eq__('str') in prior namespaces. The decimalconst61 namespace is fresh; these serve as namespace-local anchors alongside the __len__ checks."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Rounding constant __class__.__name__ == 'str' for five constants
#
# All rounding constants in the decimal module are plain Python strings.
# Their type is str; __class__.__name__ is 'str'.
#
# decimal_extra23 and extra25 covered ROUND_HALF_UP and ROUND_HALF_EVEN
# __class__.__name__.__eq__('str') in prior namespaces. The decimalconst61
# namespace is fresh. Coverage extended to ROUND_HALF_DOWN, ROUND_UP,
# ROUND_DOWN as well. Novel namespace-local anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra61.rounding_constant_class_name:
  description: "ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__name__.__eq__('str') — all rounding constants in the decimal module are plain Python strings; type is str; __class__.__name__ is 'str'; prior specs covered ROUND_HALF_UP and ROUND_HALF_EVEN in other namespaces; decimalconst61 is a fresh namespace extending to ROUND_HALF_DOWN/ROUND_UP/ROUND_DOWN; novel namespace-local anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: rounding_constant_identity
  id_prefix: decimalconst61classname

  columns: [id, function, args, expected]
  rows:
    - [half_up_class_name,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true]
    - [half_down_class_name, ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true]
    - [half_even_class_name, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true]
    - [up_class_name,        ROUND_UP.__class__.__name__.__eq__,        ["str"], true]
    - [down_class_name,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# Rounding constant string lengths — first four constants
#
# Each rounding constant is a string whose length equals the number of
# characters in its name:
#
#   len('ROUND_HALF_UP')   == 13
#   len('ROUND_HALF_DOWN') == 15
#   len('ROUND_HALF_EVEN') == 15
#   len('ROUND_UP')        == 8
#
# No prior decimal spec checks __len__() for any rounding constant.
# Novel __len__ anchors in decimalconst61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra61.rounding_constant_lengths_1:
  description: "ROUND_HALF_UP/__len__()==13, ROUND_HALF_DOWN/__len__()==15, ROUND_HALF_EVEN/__len__()==15, ROUND_UP/__len__()==8 — each rounding constant is a string; __len__() returns its character count; 'ROUND_HALF_UP' is 13 chars; 'ROUND_HALF_DOWN' is 15 chars; 'ROUND_HALF_EVEN' is 15 chars; 'ROUND_UP' is 8 chars; no prior decimal spec checks __len__() for any rounding constant; novel __len__ anchors in decimalconst61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: rounding_constant_length
  id_prefix: decimalconst61len1

  columns: [id, function, args, expected]
  rows:
    - [half_up_len,   ROUND_HALF_UP.__len__,   [], 13]
    - [half_down_len, ROUND_HALF_DOWN.__len__, [], 15]
    - [half_even_len, ROUND_HALF_EVEN.__len__, [], 15]
    - [up_len,        ROUND_UP.__len__,        [], 8]

# ---------------------------------------------------------------------------
# Rounding constant string lengths — remaining four constants
#
#   len('ROUND_DOWN')    == 10
#   len('ROUND_CEILING') == 13
#   len('ROUND_FLOOR')   == 11
#   len('ROUND_05UP')    == 10
#
# No prior decimal spec checks __len__() for any rounding constant.
# Novel __len__ anchors in decimalconst61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra61.rounding_constant_lengths_2:
  description: "ROUND_DOWN/__len__()==10, ROUND_CEILING/__len__()==13, ROUND_FLOOR/__len__()==11, ROUND_05UP/__len__()==10 — each rounding constant is a string; __len__() returns its character count; 'ROUND_DOWN' is 10 chars; 'ROUND_CEILING' is 13 chars; 'ROUND_FLOOR' is 11 chars; 'ROUND_05UP' is 10 chars; no prior decimal spec checks __len__() for any rounding constant; novel __len__ anchors in decimalconst61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: rounding_constant_length
  id_prefix: decimalconst61len2

  columns: [id, function, args, expected]
  rows:
    - [down_len,    ROUND_DOWN.__len__,    [], 10]
    - [ceiling_len, ROUND_CEILING.__len__, [], 13]
    - [floor_len,   ROUND_FLOOR.__len__,   [], 11]
    - [up05_len,    ROUND_05UP.__len__,    [], 10]

# ---------------------------------------------------------------------------
# getcontext.__class__.__name__ == 'builtin_function_or_method'
#
# decimal.getcontext is a C built-in function from the _decimal C extension
# module. Its runtime type is builtin_function_or_method.
#
#   getcontext.__class__.__name__ == 'builtin_function_or_method'
#
# No prior decimal spec checks getcontext.__class__.__name__ in the
# decimalconst61 namespace. Novel class-name anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra61.getcontext_class:
  description: "getcontext.__class__.__name__.__eq__('builtin_function_or_method') — decimal.getcontext is a C built-in function from the _decimal extension module; its runtime type is builtin_function_or_method; no prior decimal spec checks getcontext.__class__.__name__ in decimalconst61 namespace; novel class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: builtin_function_identity
  id_prefix: decimalconst61getctx

  columns: [id, function, args, expected]
  rows:
    - [getcontext_class_name_eq, getcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

invariant decimal_extra61.round_half_up_class_str:
  description: "ROUND_HALF_UP.__class__.__name__.__eq__('str') == True — decimal.ROUND_HALF_UP is the string 'ROUND_HALF_UP'; its runtime type is str; decimalconst61 is a fresh namespace; prior specs (extra23/extra25) covered this in other namespaces; novel namespace-local anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: rounding_constant_identity
  kind: python_call_eq
  function: ROUND_HALF_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra61.round_half_up_len:
  description: "ROUND_HALF_UP.__len__() == 13 — decimal.ROUND_HALF_UP is the string 'ROUND_HALF_UP' which has 13 characters; no prior decimal spec checks ROUND_HALF_UP.__len__() in decimalconst61 namespace; novel __len__ anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: rounding_constant_length
  kind: python_call_eq
  function: ROUND_HALF_UP.__len__
  args: []
  expected: 13

invariant decimal_extra61.round_half_even_len:
  description: "ROUND_HALF_EVEN.__len__() == 15 — decimal.ROUND_HALF_EVEN is the string 'ROUND_HALF_EVEN' which has 15 characters; no prior decimal spec checks ROUND_HALF_EVEN.__len__() in decimalconst61 namespace; novel __len__ anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: rounding_constant_length
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__len__
  args: []
  expected: 15

invariant decimal_extra61.getcontext_class_builtin:
  description: "getcontext.__class__.__name__.__eq__('builtin_function_or_method') == True — decimal.getcontext is a C built-in function from the _decimal extension module; its runtime type is builtin_function_or_method; no prior decimal spec checks getcontext.__class__.__name__ in decimalconst61 namespace; novel class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: builtin_function_identity
  kind: python_call_eq
  function: getcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
