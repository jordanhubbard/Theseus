spec: itertools_extra90
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra89

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra89.zspec.zsdl."
    - "This spec covers: itertools C-type __module__ string equality for all iterator types (Wave 250)."
    - "For C types defined in the itertools module, __module__ is 'itertools'."
    - "itertools.chain.__module__ == 'itertools' — C type in itertoolsmodule.c; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — C type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain, product, combinations, permutations __module__ strings
#
# Wave 250 theme: itertools C-type __module__ string equality — group 1.
#
# itertools.chain.__module__.__eq__('itertools')       == True
# itertools.product.__module__.__eq__('itertools')     == True
# itertools.combinations.__module__.__eq__('itertools') == True
# itertools.permutations.__module__.__eq__('itertools') == True
#
# Prior spec extra89 checked __qualname__. This spec (extra90) checks __module__. New to extra90.
# ---------------------------------------------------------------------------

table itertools_extra90.modules_group1:
  description: "chain/product/combinations/permutations __module__ == 'itertools'; all C types in itertoolsmodule.c; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmodule90

  columns: [id, function, args, expected, description]
  rows:
    - [chain_module_eq_itertools,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type in Modules/itertoolsmodule.c; C types defined in itertoolsmodule.c have __module__ set to 'itertools'; str.__eq__('itertools') returns True; prior spec extra89 checked chain.__qualname__; this spec (extra90) checks __module__; new to extra90"]
    - [product_module_eq_itertools,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is a C extension type in Modules/itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; prior spec extra89 checked product.__qualname__; this spec (extra90) checks __module__; new to extra90"]
    - [combinations_module_eq_itertools,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is a C extension type in Modules/itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; prior spec extra89 checked combinations.__qualname__; this spec (extra90) checks __module__; new to extra90"]
    - [permutations_module_eq_itertools,
       permutations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is a C extension type in Modules/itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; prior spec extra89 checked permutations.__qualname__; this spec (extra90) checks __module__; new to extra90"]

