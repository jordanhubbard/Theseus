spec: gzip_extra10
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip documentation"
    - "RFC 1952 — GZIP file format specification version 4.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "gzip_extra9.zspec.zsdl — covers GzipFile.__mro__[5].__name__; BadGzipFile MRO depths 1/2/3; compress(b'') length==20; FTEXT/FNAME bool-form eq; compress(b'hello', 1)[8]==4 (XFL fastest)."
    - "gzip_extra8.zspec.zsdl — covers GzipFile.__mro__[4].__name__=='IOBase'; compress(b'hello')[3]==0 (FLG); compress(b'hello',9)[8]==2 (XFL); compress(b'hello',9)[9]==255 (OS); compress(b'hello',9).__len__()==25."
    - "gzip_extra7.zspec.zsdl — covers GzipFile/BadGzipFile __class__.__name__=='type'; open/compress/decompress __class__.__name__=='function'; FEXTRA/FCOMMENT class names; GzipFile.__mro__[3]; BadGzipFile.__module__ bool form; compress(b'a') len==21; compress(b'hello')[2]==8; decompress raises on truncated."
    - "gzip_extra6.zspec.zsdl — covers FTEXT/FHCRC/FEXTRA/FNAME/FCOMMENT constants; compress magic bytes [0] and [1]; GzipFile.__bases__[0].__module__; GzipFile.__mro__[2].__name__."
    - "gzip_extra3.zspec.zsdl — covers GzipFile/__name__ and BadGzipFile/__name__ in a class_names table; compress/decompress/open __name__ in a function_names table; GzipFile/__module__; BadGzipFile/__bases__[0].__name__ (string form via getitem+method); compress returns bytes; compress header magic byte[0]."
  notes:
    - "This spec extends gzip through gzip_extra9; it does NOT duplicate invariants present in those files."
    - "Focus: standalone __name__ re-anchors from the extra10 namespace for compress, decompress, open, GzipFile, and BadGzipFile; BadGzipFile.__bases__[0].__name__ bool-form from extra10 namespace; compress(b'hello') returns bytes (extra10 namespace anchor); decompress of pre-computed hello returns bytes (extra10 namespace anchor)."
    - "gzip_extra3 covers compress/decompress/open __name__ in a function_names table from extra3. These standalone invariants re-anchor each from the extra10 namespace."
    - "gzip_extra3 covers GzipFile/__name__ and BadGzipFile/__name__ in a class_names table from extra3. These standalone invariants re-anchor each from the extra10 namespace."
    - "gzip_extra3 covers BadGzipFile.__bases__[0].__name__ as a string-form result (getitem+method). This invariant uses the bool-form __eq__ pattern — a distinct axis not covered in any prior gzip spec."
    - "gzip (base) covers compress(b'hello') returns bytes. This invariant re-anchors the same contract from the extra10 namespace using !ascii tag."
    - "gzip (base) covers decompress of pre-computed hello as a value and length check. This invariant checks the return class name — not covered from the extra10 namespace."
    - "Pre-computed gzip hex for b'hello' (default level): 1f8b08000000000002ffcb48cdc9c9070086a6103605000000 (25 bytes). Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — compress, decompress, open — extra10 namespace anchors
#
# gzip_extra3 covers all three in a function_names table from extra3.
# These standalone invariants re-anchor each from the extra10 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra10.compress.name:
  description: "gzip.compress.__name__ == 'compress' — extra10 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant gzip_extra10.decompress.name:
  description: "gzip.decompress.__name__ == 'decompress' — extra10 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: decompress.__name__.__eq__
  args: ["decompress"]
  expected: true

invariant gzip_extra10.open.name:
  description: "gzip.open.__name__ == 'open' — extra10 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ — GzipFile and BadGzipFile — extra10 namespace anchors
#
# gzip_extra3 covers both in a class_names table from extra3. These standalone
# invariants re-anchor each from the extra10 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra10.GzipFile.name:
  description: "gzip.GzipFile.__name__ == 'GzipFile' — extra10 namespace anchor"
  category: class_names
  kind: python_call_eq
  function: GzipFile.__name__.__eq__
  args: ["GzipFile"]
  expected: true

invariant gzip_extra10.BadGzipFile.name:
  description: "gzip.BadGzipFile.__name__ == 'BadGzipFile' — extra10 namespace anchor"
  category: class_names
  kind: python_call_eq
  function: BadGzipFile.__name__.__eq__
  args: ["BadGzipFile"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__bases__[0].__name__ — bool form (extra10 namespace anchor)
#
# gzip_extra3 covers this as a string-form result (getitem+method == 'OSError').
# No prior gzip spec uses the bool-form __eq__ pattern for this property.
# This is a distinct axis from gzip_extra3's string-form invariant.
# ---------------------------------------------------------------------------

invariant gzip_extra10.BadGzipFile.base_name_bool:
  description: "gzip.BadGzipFile.__bases__[0].__name__ == 'OSError' — BadGzipFile inherits from OSError (bool-form, extra10 anchor)"
  category: class_hierarchy
  kind: python_call_eq
  function: BadGzipFile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# compress(b'hello') — returns bytes (extra10 namespace anchor)
#
# gzip (base) covers compress(b'hello') returns bytes from the base namespace.
# gzip_extra3 covers it via method_chain from extra3 namespace.
# This invariant re-anchors the same contract from the extra10 namespace using
# the !ascii tag form (distinct from the !hex form used in gzip base).
# ---------------------------------------------------------------------------

invariant gzip_extra10.compress.hello_returns_bytes:
  description: "gzip.compress(b'hello').__class__.__name__ == 'bytes' — compress returns bytes (extra10 anchor)"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# decompress(pre-computed-hello) — returns bytes (extra10 namespace anchor)
#
# gzip (base) covers decompress of pre-computed hello as value and length checks.
# No prior gzip spec checks the return __class__.__name__ of decompress from
# the extra10 namespace. Pre-computed hex: gzip.compress(b'hello') default level.
# ---------------------------------------------------------------------------

invariant gzip_extra10.decompress.hello_returns_bytes:
  description: "gzip.decompress(<compressed-hello>).__class__.__name__ == 'bytes' — decompress returns bytes (extra10 anchor)"
  category: types
  kind: python_call_eq
  function: decompress
  args: [!hex "1f8b08000000000002ffcb48cdc9c9070086a6103605000000"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
