spec: hex_rgb
version: ">=5.0.0"
backend: node(hex-rgb)

docs: https://www.npmjs.com/package/hex-rgb

provenance:
  derived_from:
    - "hex-rgb README — https://www.npmjs.com/package/hex-rgb"
    - "Test vectors verified with hex-rgb via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "hex-rgb source"
  notes:
    - "hex-rgb is an npm package. Install: npm install hex-rgb"
    - "Converts a hex color string to an RGBA object. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object with red, green, blue, alpha fields."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table hex_rgb.hexRgb:
  kind: node_module_call_eq
  function: "default"
  category: convert
  id_prefix: hexrgb

  columns: [id, args, expected]
  rows:
    - [red,   ["ff0000"], {"red": 255, "green": 0,   "blue": 0,   "alpha": 1}]
    - [green, ["#00ff00"], {"red": 0,   "green": 255, "blue": 0,   "alpha": 1}]
