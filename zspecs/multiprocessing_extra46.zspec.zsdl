spec: multiprocessing_extra46
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.context.BaseContext — BaseContext documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra45.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process', Process/__module__=='multiprocessing.context', Queue/__name__=='Queue', Pipe/__name__=='Pipe', Process method qualname lens for start/join/run, Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager', function __name__/__module__ string equality for cpu_count/current_process/active_children, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', Queue/__qualname__=='BaseContext.Queue', Pipe/__qualname__=='BaseContext.Pipe', cpu_count/__qualname__=='BaseContext.cpu_count', current_process/__qualname__=='current_process', active_children/__qualname__=='active_children', get_start_method/__qualname__=='DefaultContext.get_start_method', set_start_method/__name__=='set_start_method', ProcessError/__qualname__=='ProcessError', AuthenticationError/__qualname__=='AuthenticationError', TimeoutError/__qualname__=='TimeoutError', BufferTooShort/__qualname__=='BufferTooShort', BaseContext/__qualname__/__module__/__mro__.__len__(), SpawnContext/ForkContext/ForkServerContext/DefaultContext __name__ equality, context subclass __qualname__.__len__() tables, context subclass __mro__.__len__()==3 (extra43), SpawnContext/ForkContext/ForkServerContext/DefaultContext __qualname__ string equality, all four context subclass __module__ string equality and __module__.__len__()==23 (extra44), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', active_children/__class__.__name__=='function', ProcessError/__class__.__name__=='type', AuthenticationError/__class__.__name__=='type', context.SpawnContext/__class__.__name__=='type', context.BaseContext/__class__.__name__=='type', __class__.__name__.__len__() for all eight objects (extra45)."
    - "This spec covers: Process/__class__.__qualname__=='type'; ProcessError/__class__.__qualname__=='type'; AuthenticationError/__class__.__qualname__=='type'; current_process/__class__.__qualname__=='function'; active_children/__class__.__qualname__=='function'; cpu_count/__class__.__qualname__=='method'; Process/__class__.__module__=='builtins'; current_process/__class__.__module__=='builtins'; cpu_count/__class__.__module__=='builtins'."
    - "multiprocessing.Process.__class__.__qualname__ == 'type'. Process is a plain Python class; its metaclass is the built-in 'type'. The built-in type has __qualname__ == __name__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__class__.__qualname__ == 'type'. ProcessError is an exception class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__class__.__qualname__ == 'type'. AuthenticationError is an exception class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__class__.__qualname__ == 'function'. current_process is a standalone function in multiprocessing.process; its __class__ is the built-in 'function' type whose __qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.active_children.__class__.__qualname__ == 'function'. active_children is a standalone function in multiprocessing.process; its __class__.__qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.cpu_count.__class__.__qualname__ == 'method'. cpu_count is a bound method of the DefaultContext singleton; its __class__ is the built-in 'method' type whose __qualname__ == 'method' (6 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__class__.__module__ == 'builtins'. The 'type' metaclass is a built-in type defined in builtins; therefore Process.__class__.__module__ == 'builtins' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__class__.__module__ == 'builtins'. The 'function' type is a built-in type defined in builtins; therefore current_process.__class__.__module__ == 'builtins' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.cpu_count.__class__.__module__ == 'builtins'. The 'method' type is a built-in type defined in builtins; therefore cpu_count.__class__.__module__ == 'builtins' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "cpu_count is again the notable exception among multiprocessing callables: its __class__.__qualname__ is 'method' (6 chars) rather than 'function' (8 chars) or 'type' (4 chars), because it is a bound method of the DefaultContext singleton rather than a plain function. All three callable types ('type', 'function', 'method') share __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing class __class__.__qualname__ string equality — extra46
#
# All class-type objects have __class__.__qualname__ == 'type':
#   Process.__class__.__qualname__             == 'type'
#   ProcessError.__class__.__qualname__        == 'type'
#   AuthenticationError.__class__.__qualname__ == 'type'
# The built-in 'type' metaclass has __qualname__ == __name__ == 'type'.
# Prior specs captured __class__.__name__ (extra45). Extra46 captures
# __class__.__qualname__ for the first time.
# ---------------------------------------------------------------------------

table multiprocessing_extra46.class_metaclass_qualname_eq:
  description: "multiprocessing class __class__.__qualname__ string equality in extra46 namespace — classes have metaclass qualname 'type'"
  kind: python_call_eq
  category: class_names
  id_prefix: mpclsqual46

  columns: [id, function, args, expected, description]
  rows:
    - [Process,             Process.__class__.__qualname__.__eq__,             ["type"], true, "Process.__class__.__qualname__ == 'type' — plain Python class; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [ProcessError,        ProcessError.__class__.__qualname__.__eq__,        ["type"], true, "ProcessError.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [AuthenticationError, AuthenticationError.__class__.__qualname__.__eq__, ["type"], true, "AuthenticationError.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing callable __class__.__qualname__ string equality — extra46
#
# cpu_count is a bound method (not a plain function):
#   cpu_count.__class__.__qualname__      == 'method'    (6 chars)
# current_process and active_children are plain functions:
#   current_process.__class__.__qualname__ == 'function' (8 chars)
#   active_children.__class__.__qualname__ == 'function' (8 chars)
#
# cpu_count is exposed as a bound method of the DefaultContext singleton.
# current_process and active_children are defined directly in process.py.
# For built-in types, __qualname__ == __name__, so these match extra45.
# ---------------------------------------------------------------------------

table multiprocessing_extra46.callable_class_qualname_eq:
  description: "multiprocessing callable __class__.__qualname__ string equality in extra46 namespace — cpu_count is 'method', others are 'function'"
  kind: python_call_eq
  category: class_names
  id_prefix: mpcallclsqual46

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count,       cpu_count.__class__.__qualname__.__eq__,       ["method"],   true, "cpu_count.__class__.__qualname__ == 'method' — bound method of DefaultContext singleton; built-in 'method' type has __qualname__ == 'method' (6 chars)"]
    - [current_process, current_process.__class__.__qualname__.__eq__, ["function"], true, "current_process.__class__.__qualname__ == 'function' — standalone function in process.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"]
    - [active_children, active_children.__class__.__qualname__.__eq__, ["function"], true, "active_children.__class__.__qualname__ == 'function' — standalone function in process.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing object __class__.__module__ string equality — extra46
#
# All three __class__ types ('type', 'function', 'method') are built-in types
# defined in builtins, so __class__.__module__ == 'builtins' in all cases:
#   Process.__class__.__module__         == 'builtins'  (type → builtins)
#   current_process.__class__.__module__ == 'builtins'  (function → builtins)
#   cpu_count.__class__.__module__       == 'builtins'  (method → builtins)
# ---------------------------------------------------------------------------

table multiprocessing_extra46.class_module_eq:
  description: "multiprocessing object __class__.__module__ string equality in extra46 namespace — type/function/method metaclasses all report 'builtins'"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpclsmoduleq46

  columns: [id, function, args, expected, description]
  rows:
    - [Process,         Process.__class__.__module__.__eq__,         ["builtins"], true, "Process.__class__.__module__ == 'builtins' — 'type' metaclass is a built-in type whose __module__ == 'builtins' (8 chars)"]
    - [current_process, current_process.__class__.__module__.__eq__, ["builtins"], true, "current_process.__class__.__module__ == 'builtins' — 'function' type is a built-in type whose __module__ == 'builtins' (8 chars)"]
    - [cpu_count,       cpu_count.__class__.__module__.__eq__,       ["builtins"], true, "cpu_count.__class__.__module__ == 'builtins' — 'method' type is a built-in type whose __module__ == 'builtins' (8 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing object __class__.__qualname__.__len__() — extra46
#
# Classes (__class__.__qualname__ == 'type'):
#   Process/ProcessError/AuthenticationError == 4
# Callables:
#   cpu_count.__class__.__qualname__.__len__()       == 6  ('method')
#   current_process.__class__.__qualname__.__len__() == 8  ('function')
#   active_children.__class__.__qualname__.__len__() == 8  ('function')
# ---------------------------------------------------------------------------

table multiprocessing_extra46.object_class_qualname_lengths:
  description: "multiprocessing object __class__.__qualname__.__len__() in extra46 namespace — classes == 4, method == 6, functions == 8"
  kind: python_call_eq
  category: class_names
  id_prefix: mpobjclsquallen46

  columns: [id, function, args, expected, description]
  rows:
    - [Process,             Process.__class__.__qualname__.__len__,             [], 4, "Process.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [ProcessError,        ProcessError.__class__.__qualname__.__len__,        [], 4, "ProcessError.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [AuthenticationError, AuthenticationError.__class__.__qualname__.__len__, [], 4, "AuthenticationError.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [cpu_count,           cpu_count.__class__.__qualname__.__len__,           [], 6, "cpu_count.__class__.__qualname__.__len__() == 6 — 'method' has 6 characters; cpu_count is a bound method"]
    - [current_process,     current_process.__class__.__qualname__.__len__,     [], 8, "current_process.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]
    - [active_children,     active_children.__class__.__qualname__.__len__,     [], 8, "active_children.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra46
# ---------------------------------------------------------------------------

invariant multiprocessing_extra46.Process_class_qualname_eq:
  description: "multiprocessing.Process.__class__.__qualname__ == 'type' — plain Python class in process.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Process.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra46.ProcessError_class_qualname_eq:
  description: "multiprocessing.ProcessError.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra46.AuthenticationError_class_qualname_eq:
  description: "multiprocessing.AuthenticationError.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra46.current_process_class_qualname_eq:
  description: "multiprocessing.current_process.__class__.__qualname__ == 'function' — standalone function in process.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: current_process.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra46.active_children_class_qualname_eq:
  description: "multiprocessing.active_children.__class__.__qualname__ == 'function' — standalone function in process.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: active_children.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra46.cpu_count_class_qualname_eq:
  description: "multiprocessing.cpu_count.__class__.__qualname__ == 'method' — bound method of DefaultContext singleton; built-in 'method' type has __qualname__ == 'method' (6 chars)"
  category: class_names
  kind: python_call_eq
  function: cpu_count.__class__.__qualname__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra46.Process_class_module_eq:
  description: "multiprocessing.Process.__class__.__module__ == 'builtins' — 'type' metaclass is a built-in type; its __module__ == 'builtins' (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: Process.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant multiprocessing_extra46.current_process_class_module_eq:
  description: "multiprocessing.current_process.__class__.__module__ == 'builtins' — 'function' type is a built-in type; its __module__ == 'builtins' (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: current_process.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant multiprocessing_extra46.cpu_count_class_module_eq:
  description: "multiprocessing.cpu_count.__class__.__module__ == 'builtins' — 'method' type is a built-in type; its __module__ == 'builtins' (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: cpu_count.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant multiprocessing_extra46.Process_class_qualname_len:
  description: "multiprocessing.Process.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: Process.__class__.__qualname__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra46.cpu_count_class_qualname_len:
  description: "multiprocessing.cpu_count.__class__.__qualname__.__len__() == 6 — 'method' has 6 characters; cpu_count is a bound method of DefaultContext"
  category: class_names
  kind: python_call_eq
  function: cpu_count.__class__.__qualname__.__len__
  args: []
  expected: 6

invariant multiprocessing_extra46.current_process_class_qualname_len:
  description: "multiprocessing.current_process.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: current_process.__class__.__qualname__.__len__
  args: []
  expected: 8
