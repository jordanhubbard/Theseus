spec: itertools_extra267
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools types in this spec are C-level types: __class__.__name__ == 'type' for all."
    - "All itertools types have __module__ == 'itertools' (len=9)."
    - "itertools.accumulate.__name__ (10) < itertools.filterfalse.__name__ (11) < itertools.zip_longest.__name__ (12) < itertools.combinations_with_replacement.__name__ (29)."
    - "combinations_with_replacement.__name__ (len=29) is the longest name in this spec."
    - "accumulate (10), compress (8), groupby (7), pairwise (8) — groupby is shortest at 7."
    - "compress (8) == pairwise (8) — tied."
    - "All qualnames equal names (module-level, no nesting)."
    - "itertools.pairwise requires Python 3.10+."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools accumulate, compress, filterfalse, groupby identity
#
# All C-level types with __module__ == 'itertools'.
# groupby.__name__ (7) is shortest in table.
# compress.__name__ (8) == pairwise.__name__ (8).
# accumulate.__name__ (10) < filterfalse.__name__ (11).
# ---------------------------------------------------------------------------

table itertools_extra267.accumulate_compress_filterfalse_groupby_identity:
  description: "itertools.accumulate(10), compress(8), filterfalse(11), groupby(7) identity — all C-level types(4) in itertools(9); groupby(7) shortest; accumulate(10) < filterfalse(11); all qualnames equal names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex267a

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_eq,         accumulate.__name__.__eq__,                 ["accumulate"],                 true, "itertools.accumulate.__name__ == 'accumulate'; verified with Python 3.14.3"]
    - [ac_name_len,        accumulate.__name__.__len__,                [],                             10,   "itertools.accumulate.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ac_qn_eq,           accumulate.__qualname__.__eq__,             ["accumulate"],                 true, "itertools.accumulate.__qualname__ == 'accumulate' — qualname equals name; verified with Python 3.14.3"]
    - [ac_mod_eq,          accumulate.__module__.__eq__,               ["itertools"],                  true, "itertools.accumulate.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ac_cls_eq,          accumulate.__class__.__name__.__eq__,       ["type"],                       true, "itertools.accumulate.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [cp_name_eq,         compress.__name__.__eq__,                   ["compress"],                   true, "itertools.compress.__name__ == 'compress'; verified with Python 3.14.3"]
    - [cp_name_len,        compress.__name__.__len__,                  [],                             8,    "itertools.compress.__name__.__len__() == 8 — tied with pairwise; verified with Python 3.14.3"]
    - [cp_qn_eq,           compress.__qualname__.__eq__,               ["compress"],                   true, "itertools.compress.__qualname__ == 'compress' — qualname equals name; verified with Python 3.14.3"]
    - [cp_mod_eq,          compress.__module__.__eq__,                 ["itertools"],                  true, "itertools.compress.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cp_cls_eq,          compress.__class__.__name__.__eq__,         ["type"],                       true, "itertools.compress.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [ff_name_eq,         filterfalse.__name__.__eq__,                ["filterfalse"],                true, "itertools.filterfalse.__name__ == 'filterfalse'; verified with Python 3.14.3"]
    - [ff_name_len,        filterfalse.__name__.__len__,               [],                             11,   "itertools.filterfalse.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [ff_qn_eq,           filterfalse.__qualname__.__eq__,            ["filterfalse"],                true, "itertools.filterfalse.__qualname__ == 'filterfalse' — qualname equals name; verified with Python 3.14.3"]
    - [ff_mod_eq,          filterfalse.__module__.__eq__,              ["itertools"],                  true, "itertools.filterfalse.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ff_cls_eq,          filterfalse.__class__.__name__.__eq__,      ["type"],                       true, "itertools.filterfalse.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [gb_name_eq,         groupby.__name__.__eq__,                    ["groupby"],                    true, "itertools.groupby.__name__ == 'groupby'; verified with Python 3.14.3"]
    - [gb_name_len,        groupby.__name__.__len__,                   [],                             7,    "itertools.groupby.__name__.__len__() == 7 — shortest in table; verified with Python 3.14.3"]
    - [gb_qn_eq,           groupby.__qualname__.__eq__,                ["groupby"],                    true, "itertools.groupby.__qualname__ == 'groupby' — qualname equals name; verified with Python 3.14.3"]
    - [gb_mod_eq,          groupby.__module__.__eq__,                  ["itertools"],                  true, "itertools.groupby.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [gb_cls_eq,          groupby.__class__.__name__.__eq__,          ["type"],                       true, "itertools.groupby.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools zip_longest, pairwise, combinations_with_replacement identity
#
# zip_longest.__name__ (12) < combinations_with_replacement.__name__ (29).
# pairwise.__name__ (8) tied with compress.
# combinations_with_replacement (29) is the longest name in spec.
# All C-level types with __module__ == 'itertools'.
# pairwise requires Python 3.10+.
# ---------------------------------------------------------------------------

table itertools_extra267.zip_longest_pairwise_cwr_identity:
  description: "itertools.zip_longest(12), pairwise(8), combinations_with_replacement(29) identity — all C-level types in itertools(9); combinations_with_replacement(29) longest name in spec; pairwise(8) tied with compress; requires Python 3.10+ for pairwise; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex267z

  columns: [id, function, args, expected, description]
  rows:
    - [zl_name_eq,         zip_longest.__name__.__eq__,                ["zip_longest"],                true, "itertools.zip_longest.__name__ == 'zip_longest'; verified with Python 3.14.3"]
    - [zl_name_len,        zip_longest.__name__.__len__,               [],                             12,   "itertools.zip_longest.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [zl_qn_eq,           zip_longest.__qualname__.__eq__,            ["zip_longest"],                true, "itertools.zip_longest.__qualname__ == 'zip_longest' — qualname equals name; verified with Python 3.14.3"]
    - [zl_mod_eq,          zip_longest.__module__.__eq__,              ["itertools"],                  true, "itertools.zip_longest.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [zl_cls_eq,          zip_longest.__class__.__name__.__eq__,      ["type"],                       true, "itertools.zip_longest.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [pw_name_eq,         pairwise.__name__.__eq__,                   ["pairwise"],                   true, "itertools.pairwise.__name__ == 'pairwise'; Python 3.10+; verified with Python 3.14.3"]
    - [pw_name_len,        pairwise.__name__.__len__,                  [],                             8,    "itertools.pairwise.__name__.__len__() == 8 — tied with compress; verified with Python 3.14.3"]
    - [pw_qn_eq,           pairwise.__qualname__.__eq__,               ["pairwise"],                   true, "itertools.pairwise.__qualname__ == 'pairwise' — qualname equals name; verified with Python 3.14.3"]
    - [pw_mod_eq,          pairwise.__module__.__eq__,                 ["itertools"],                  true, "itertools.pairwise.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pw_cls_eq,          pairwise.__class__.__name__.__eq__,         ["type"],                       true, "itertools.pairwise.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [cwr_name_eq,        combinations_with_replacement.__name__.__eq__, ["combinations_with_replacement"], true, "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'; verified with Python 3.14.3"]
    - [cwr_name_len,       combinations_with_replacement.__name__.__len__, [],                         29,   "itertools.combinations_with_replacement.__name__.__len__() == 29 — longest name in spec; verified with Python 3.14.3"]
    - [cwr_qn_eq,          combinations_with_replacement.__qualname__.__eq__, ["combinations_with_replacement"], true, "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'; verified with Python 3.14.3"]
    - [cwr_mod_eq,         combinations_with_replacement.__module__.__eq__, ["itertools"],             true, "itertools.combinations_with_replacement.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cwr_cls_eq,         combinations_with_replacement.__class__.__name__.__eq__, ["type"],          true, "itertools.combinations_with_replacement.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra267
# ---------------------------------------------------------------------------

invariant itertools_extra267.accumulate_module_is_itertools:
  description: "itertools.accumulate.__module__ == 'itertools' (len=9) — all itertools types share this module; accumulate name len=10 > module name len=9"
  category: identity
  kind: python_call_eq
  function: accumulate.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra267.cwr_name_is_longest:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — longest name in spec; far longer than zip_longest(12), filterfalse(11), accumulate(10)"
  category: identity
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

invariant itertools_extra267.compress_name_len_equals_pairwise:
  description: "itertools.compress.__name__.__len__() == 8 == itertools.pairwise.__name__.__len__() — compress and pairwise names are both length 8"
  category: identity
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

invariant itertools_extra267.groupby_is_shortest_basic:
  description: "itertools.groupby.__name__.__len__() == 7 — shortest name among accumulate/compress/filterfalse/groupby; equals module name 'itertools' len-2"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra267.all_are_c_types:
  description: "itertools.accumulate.__class__.__name__ == 'type' — all itertools iterators in this spec are C-level types; this holds for accumulate, compress, filterfalse, groupby, zip_longest, pairwise, and combinations_with_replacement"
  category: identity
  kind: python_call_eq
  function: accumulate.__class__.__name__.__eq__
  args: ["type"]
  expected: true
