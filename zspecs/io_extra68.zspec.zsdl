spec: io_extra68
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra67.zspec.zsdl — covers BytesIO.readable/writable/seekable/readlines/flush __qualname__.__eq__(); StringIO.readable/writable/seekable __qualname__.__eq__(); StringIO.readlines/__qualname__.__eq__('_IOBase.readlines') and StringIO.flush/__qualname__.__eq__('_IOBase.flush')."
    - "io_extra66.zspec.zsdl — covers io.__loader__.__name__.__eq__('FrozenImporter'); io.__spec__.origin.__eq__('frozen'); io.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'); io.__spec__.has_location.__eq__(False)."
    - "io_extra65.zspec.zsdl — covers io.__loader__/__spec__/__file__ class identity checks."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method __qualname__.__eq__() equality anchors; DEFAULT_BUFFER_SIZE.__eq__(131072)."
  notes:
    - "This spec extends io_extra67.zspec.zsdl."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "io.open is a C built-in function (_io.open). C extension functions do NOT have __annotations__; hasattr(io.open, '__annotations__') is False. Thus all __annotations__-based tests focus on pure-Python methods that do carry __annotations__, such as io.open_code (also C, skip) and instead the annotations identity tests use io module-level __doc__ and class __doc__ content. Pure Python items in io: io.open_code is C, skip. TextIOWrapper is a C type. Focus on __doc__.__contains__ content anchors for the wave 228 theme. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BytesIO.__doc__.__contains__('bytes') — BytesIO.__doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.' The word 'bytes' appears. Novel __doc__.__contains__ content anchor in ioann68 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "IOBase.__doc__.__contains__('I/O') — IOBase.__doc__ begins 'The abstract base class for all I/O classes.' The substring 'I/O' appears. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__doc__.__class__.__name__.__eq__('str') — io module has a string docstring (1473 chars). Verifies that the module-level __doc__ is a str object. Novel class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__doc__.__len__() == 1473 — module-level docstring length. Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "RawIOBase.__doc__.__contains__('raw') — RawIOBase.__doc__ is 'Base class for raw binary I/O.' The word 'raw' appears. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedIOBase.__doc__.__contains__('buffer') — BufferedIOBase.__doc__ begins 'Base class for buffered IO objects.' The word 'buffer' appears. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__doc__ class identity and length
#
# The io module has a string docstring. __doc__.__class__.__name__ is 'str'
# and __doc__.__len__() is 1473.
#
# No prior io spec checks io.__doc__.__class__.__name__.__eq__('str') or
# the module-level __doc__.__len__(). Novel class identity and length anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra68.module_doc_class:
  description: "io.__doc__.__class__.__name__.__eq__('str') — io module has a string docstring (1473 chars); __doc__.__class__.__name__ is 'str'; novel module-level __doc__ class identity anchor in ioann68 namespace; no prior io spec checks io.__doc__.__class__.__name__.__eq__('str'); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_doc_identity
  id_prefix: ioann68moddoc

  columns: [id, function, args, expected]
  rows:
    - [doc_class_name_eq,  io.__doc__.__class__.__name__.__eq__,  ["str"],  true]
    - [doc_len_eq,         io.__doc__.__len__,                    [],       1473]

# ---------------------------------------------------------------------------
# BytesIO.__doc__.__contains__ content check
#
# BytesIO.__doc__ is:
#   'Buffered I/O implementation using an in-memory bytes buffer.'
#
# The word 'bytes' appears in the docstring. __doc__.__contains__('bytes')
# returns True. No prior io spec checks BytesIO.__doc__.__contains__().
# Novel __doc__ content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra68.bytesio_doc_contains:
  description: "BytesIO.__doc__.__contains__('bytes') — BytesIO.__doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.'; the word 'bytes' appears; __doc__.__class__.__name__ is 'str'; no prior io spec checks BytesIO.__doc__.__contains__(); novel __doc__ content anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: ioann68biodoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_bytes,  BytesIO.__doc__.__contains__,  ["bytes"],  true]
    - [doc_class_name_eq,   BytesIO.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# IOBase.__doc__.__contains__ content check
#
# IOBase.__doc__ begins:
#   'The abstract base class for all I/O classes.'
#
# The substring 'I/O' appears in the docstring. 'abstract' also appears.
# No prior io spec checks IOBase.__doc__.__contains__(). Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra68.iobase_doc_contains:
  description: "IOBase.__doc__.__contains__('I/O') and __contains__('abstract') — IOBase.__doc__ begins 'The abstract base class for all I/O classes.'; both 'I/O' and 'abstract' appear; no prior io spec checks IOBase.__doc__.__contains__(); novel __doc__ content anchors in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: ioann68iobasedoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_io,       IOBase.__doc__.__contains__, ["I/O"],      true]
    - [doc_contains_abstract, IOBase.__doc__.__contains__, ["abstract"], true]

# ---------------------------------------------------------------------------
# RawIOBase and BufferedIOBase __doc__.__contains__ content checks
#
# RawIOBase.__doc__ == 'Base class for raw binary I/O.'  -> 'raw' present
# BufferedIOBase.__doc__ begins 'Base class for buffered IO objects.' -> 'buffer' present
#
# No prior io spec checks RawIOBase or BufferedIOBase __doc__.__contains__().
# Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra68.rawbuf_doc_contains:
  description: "RawIOBase.__doc__.__contains__('raw') and BufferedIOBase.__doc__.__contains__('buffer') — RawIOBase.__doc__=='Base class for raw binary I/O.' contains 'raw'; BufferedIOBase.__doc__ begins 'Base class for buffered IO objects.' contains 'buffer'; no prior io spec checks either __doc__.__contains__(); novel content anchors in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: ioann68rawbufdoc

  columns: [id, function, args, expected]
  rows:
    - [raw_doc_contains_raw,     RawIOBase.__doc__.__contains__,      ["raw"],    true]
    - [buf_doc_contains_buffer,  BufferedIOBase.__doc__.__contains__,  ["buffer"], true]

invariant io_extra68.module_doc_class_str:
  description: "io.__doc__.__class__.__name__.__eq__('str') == True — io module has a string docstring; __doc__.__class__.__name__ is 'str'; no prior io spec checks io.__doc__.__class__.__name__.__eq__('str'); novel module-level __doc__ class identity anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_doc_identity
  kind: python_call_eq
  function: io.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant io_extra68.module_doc_len:
  description: "io.__doc__.__len__() == 1473 — io module docstring is 1473 characters; no prior io spec checks io.__doc__.__len__(); novel length anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_doc_identity
  kind: python_call_eq
  function: io.__doc__.__len__
  args: []
  expected: 1473

invariant io_extra68.bytesio_doc_contains_bytes:
  description: "BytesIO.__doc__.__contains__('bytes') == True — BytesIO.__doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.'; the word 'bytes' appears; no prior io spec checks BytesIO.__doc__.__contains__(); novel __doc__ content anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BytesIO.__doc__.__contains__
  args: ["bytes"]
  expected: true

invariant io_extra68.iobase_doc_contains_io:
  description: "IOBase.__doc__.__contains__('I/O') == True — IOBase.__doc__ begins 'The abstract base class for all I/O classes.'; 'I/O' appears; no prior io spec checks IOBase.__doc__.__contains__(); novel __doc__ content anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: IOBase.__doc__.__contains__
  args: ["I/O"]
  expected: true

invariant io_extra68.rawiobase_doc_contains_raw:
  description: "RawIOBase.__doc__.__contains__('raw') == True — RawIOBase.__doc__ is 'Base class for raw binary I/O.'; 'raw' appears; no prior io spec checks RawIOBase.__doc__.__contains__(); novel __doc__ content anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: RawIOBase.__doc__.__contains__
  args: ["raw"]
  expected: true

invariant io_extra68.bufferediobase_doc_contains_buffer:
  description: "BufferedIOBase.__doc__.__contains__('buffer') == True — BufferedIOBase.__doc__ begins 'Base class for buffered IO objects.'; 'buffer' appears; no prior io spec checks BufferedIOBase.__doc__.__contains__(); novel __doc__ content anchor in ioann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BufferedIOBase.__doc__.__contains__
  args: ["buffer"]
  expected: true
