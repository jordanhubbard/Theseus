spec: dotenv_defaults
version: ">=5.0.0"
backend: node(dotenv-defaults)

docs: https://github.com/mrsteele/dotenv-defaults#readme

provenance:
  derived_from:
    - "dotenv-defaults README — https://github.com/mrsteele/dotenv-defaults#readme"
    - "Test vectors verified with dotenv-defaults via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "dotenv-defaults source"
  notes:
    - "dotenv with .env.defaults — fills missing keys from a defaults file."
    - "Install: npm install dotenv-defaults"
    - "v5 CJS; named exports config / parse plus default-export object."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "parse() never throws on string input; config() reports {error} for missing files."
  stderr: "null"
  stickiness: "config() mutates process.env."
  codes: {}

invariant dotenv_defaults.parse_basic:
  description: "parse('FOO=bar') returns {FOO:'bar'}"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["FOO=bar"]
  chain:
    - {get: FOO}
  expected: "bar"

invariant dotenv_defaults.parse_two_lines:
  description: "parse two-line input yields both keys"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["FOO=bar\nBAZ=qux"]
  chain:
    - {get: BAZ}
  expected: "qux"

invariant dotenv_defaults.parse_with_comment:
  description: "Comment lines are ignored"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["# comment\nKEY=val"]
  chain:
    - {get: KEY}
  expected: "val"

invariant dotenv_defaults.parse_empty_string:
  description: "parse('') returns {} (empty object)"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: [""]
  chain: []
  expected: {}

invariant dotenv_defaults.has_config:
  description: "config() exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "config.constructor.name"}
  expected: "Function"

invariant dotenv_defaults.has_parse:
  description: "parse() exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant dotenv_defaults.parse_quoted_value:
  description: "parse('K=\"hello world\"') strips quotes"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["K=\"hello world\""]
  chain:
    - {get: K}
  expected: "hello world"
