spec: io_extra81
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra80."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths."
    - "io_extra80 covers BufferedReader/BufferedWriter/TextIOWrapper __name__, __module__, __bases__[0].__name__, and MRO lengths."
    - "This spec covers: BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ == 'mappingproxy'; BufferedReader.__dict__.__contains__('read') == True; BufferedReader.__dict__.__contains__('readline') == True; BufferedWriter.__dict__.__contains__('write') == True; BufferedWriter.__dict__.__contains__('flush') == True; TextIOWrapper.__dict__.__contains__('read') == True; TextIOWrapper.__dict__.__contains__('write') == True; TextIOWrapper.__dict__.__contains__('readline') == True."
    - "io.BufferedReader.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "io.BufferedReader.__dict__.__contains__('read') == True — BufferedReader defines read() directly in C."
    - "io.BufferedReader.__dict__.__contains__('readline') == True — BufferedReader defines readline() directly in C."
    - "io.BufferedWriter.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "io.BufferedWriter.__dict__.__contains__('write') == True — BufferedWriter defines write() directly in C."
    - "io.BufferedWriter.__dict__.__contains__('flush') == True — BufferedWriter defines flush() directly in C."
    - "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "io.TextIOWrapper.__dict__.__contains__('read') == True — TextIOWrapper defines read() directly in C."
    - "io.TextIOWrapper.__dict__.__contains__('write') == True — TextIOWrapper defines write() directly in C."
    - "io.TextIOWrapper.__dict__.__contains__('readline') == True — TextIOWrapper defines readline() directly in C."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BufferedReader __dict__ class name
# BufferedReader is a C extension type; its __dict__ attribute is a
# mappingproxy, not a plain dict.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra81.BufferedReader_dict_class:
  description: "BufferedReader.__dict__.__class__.__name__ == 'mappingproxy'"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore81

  columns: [id, function, args, expected]
  rows:
    - [br_dict_cls, BufferedReader.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# BufferedReader __dict__ membership for key methods
# BufferedReader defines read() and readline() directly in C (_io extension).
# Verified: 'read' in io.BufferedReader.__dict__ == True.
# Verified: 'readline' in io.BufferedReader.__dict__ == True.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra81.BufferedReader_dict_contains:
  description: "BufferedReader.__dict__ contains 'read' and 'readline'"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore81

  columns: [id, function, args, expected]
  rows:
    - [br_has_read,     "BufferedReader.__dict__.__contains__", ["read"],     true]
    - [br_has_readline, "BufferedReader.__dict__.__contains__", ["readline"], true]

# ---------------------------------------------------------------------------
# BufferedWriter __dict__ class name and membership
# BufferedWriter is a C extension type; its __dict__ is a mappingproxy.
# write() and flush() are both defined directly in the C BufferedWriter type.
# Verified: 'flush' in io.BufferedWriter.__dict__ == True.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra81.BufferedWriter_dict_class_and_contains:
  description: "BufferedWriter.__dict__.__class__.__name__ and key method membership"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore81

  columns: [id, function, args, expected]
  rows:
    - [bw_dict_cls,  BufferedWriter.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [bw_has_write, "BufferedWriter.__dict__.__contains__",            ["write"],        true]
    - [bw_has_flush, "BufferedWriter.__dict__.__contains__",            ["flush"],        true]

# ---------------------------------------------------------------------------
# TextIOWrapper __dict__ class name and membership
# TextIOWrapper is a C extension type; its __dict__ is a mappingproxy.
# read(), write(), and readline() are all defined directly in the C type.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra81.TextIOWrapper_dict_class_and_contains:
  description: "TextIOWrapper.__dict__.__class__.__name__ and key method membership"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore81

  columns: [id, function, args, expected]
  rows:
    - [tw_dict_cls,    TextIOWrapper.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [tw_has_read,    "TextIOWrapper.__dict__.__contains__",            ["read"],         true]
    - [tw_has_write,   "TextIOWrapper.__dict__.__contains__",            ["write"],        true]
    - [tw_has_readline,"TextIOWrapper.__dict__.__contains__",            ["readline"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra81.BufferedReader_dict_class:
  description: "io.BufferedReader.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: BufferedReader.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra81.BufferedReader_dict.has_read:
  description: "io.BufferedReader.__dict__.__contains__('read') == True"
  category: class_dict
  kind: python_call_eq
  function: "BufferedReader.__dict__.__contains__"
  args: ["read"]
  expected: true

invariant io_extra81.BufferedWriter_dict.has_flush:
  description: "io.BufferedWriter.__dict__.__contains__('flush') == True"
  category: class_dict
  kind: python_call_eq
  function: "BufferedWriter.__dict__.__contains__"
  args: ["flush"]
  expected: true

invariant io_extra81.TextIOWrapper_dict_class:
  description: "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra81.TextIOWrapper_dict.has_readline:
  description: "io.TextIOWrapper.__dict__.__contains__('readline') == True"
  category: class_dict
  kind: python_call_eq
  function: "TextIOWrapper.__dict__.__contains__"
  args: ["readline"]
  expected: true
