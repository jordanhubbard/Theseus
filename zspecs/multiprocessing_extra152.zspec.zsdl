spec: multiprocessing_extra152
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec covers multiprocessing.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, submodule_search_locations.__class__.__name__."
    - "multiprocessing.__spec__.name == 'multiprocessing' — the ModuleSpec's name attribute matches the module name. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.has_location == True — multiprocessing is loaded from disk; has_location is True for file-backed packages. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.parent == 'multiprocessing' — multiprocessing is a top-level package; __spec__.parent equals __spec__.name. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.submodule_search_locations.__class__.__name__ == 'list' — multiprocessing is a package; submodule_search_locations is a list of directory paths. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.has_location.__class__.__name__ == 'bool' — has_location is a plain Python bool. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

