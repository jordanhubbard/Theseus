spec: multiprocessing_extra152
version: ">=3.9"
backend: python_module(multiprocessing.pool)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers: multiprocessing.pool.Pool class identity and Pool method qualnames. multiprocessing.pool.Pool.__name__=='Pool' (len=4); multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=19; Pool is defined in Lib/multiprocessing/pool.py — its __module__ matches the submodule name); multiprocessing.pool.Pool.__bases__[0].__name__=='object' (Pool inherits directly from object — it is NOT a subclass of BaseProcess or any other multiprocessing base class); multiprocessing.pool.Pool.map.__qualname__=='Pool.map' (len=8); multiprocessing.pool.Pool.apply.__qualname__=='Pool.apply' (len=10); multiprocessing.pool.Pool.starmap.__qualname__=='Pool.starmap' (len=13); multiprocessing.pool.Pool.map_async.__qualname__=='Pool.map_async' (len=15). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__module__=='multiprocessing.pool' — Pool is defined in Lib/multiprocessing/pool.py and its __module__ is 'multiprocessing.pool' (len=19: 'multiprocessing'=15+'.'=1+'pool'=4=20... wait: len('multiprocessing.pool')=20); Pool.__module__.__len__()==20; compare: multiprocessing.Value.__module__=='multiprocessing.context' (len=23); Pool is accessed as multiprocessing.pool.Pool (explicitly via the pool submodule), unlike Process which is re-exported at the top level. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__bases__[0].__name__=='object' — Pool inherits directly from object (single inheritance); this contrasts with multiprocessing.Process which inherits from BaseProcess; Pool manages a pool of worker processes internally but is not itself a subclass of any Process class; Pool.__bases__==(object,); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Pool method qualnames use the 'Pool.' prefix — Pool.map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8); Pool.apply.__qualname__=='Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10); Pool.starmap.__qualname__=='Pool.starmap' (len=13: 'Pool'=4+'.'=1+'starmap'=7... wait: 'starmap'=7, total=4+1+7=12); Pool.map_async.__qualname__=='Pool.map_async' (len=15: 'Pool'=4+'.'=1+'map_async'=9... wait: 'map_async'=9, total=4+1+9=14). Actual lengths verified with Python 3.14.3: Pool.map(8), Pool.apply(10), Pool.starmap(12), Pool.map_async(14). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — extra152
#
# multiprocessing.pool.Pool.__name__.__eq__('Pool')                       == True
# multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool')     == True
# multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object')        == True
# ---------------------------------------------------------------------------

table multiprocessing_extra152.mp_pool_class_identity:
  description: "multiprocessing.pool.Pool class identity checks in mppool152 namespace — multiprocessing.pool.Pool.__name__=='Pool' (len=4; the primary worker-pool class in multiprocessing; manages a pool of worker processes for parallel task execution); multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; Pool is defined in Lib/multiprocessing/pool.py and its __module__ matches the submodule path); multiprocessing.pool.Pool.__bases__[0].__name__=='object' (len=6; Pool inherits directly from object — NOT from BaseProcess or any process class; Pool is a manager for a pool of worker processes, not itself a process subclass); Pool.__name__.__len__()==4; Pool.__module__.__len__()==20; compare: multiprocessing.Process.__module__=='multiprocessing.context' (len=23, 3 chars longer than Pool's module len=20); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool152

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,   multiprocessing.pool.Pool.__name__.__eq__,                  ["Pool"],                  true,  "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4); verified with Python 3.14.3"]
    - [pool_mod_eq,    multiprocessing.pool.Pool.__module__.__eq__,                 ["multiprocessing.pool"], true,  "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' (len=20); verified with Python 3.14.3"]
    - [pool_base_eq,   "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__",   ["object"],                true,  "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' (Pool inherits directly from object, not from a Process class); verified with Python 3.14.3"]
    - [pool_name_len,  multiprocessing.pool.Pool.__name__.__len__,                  [],                       4,     "multiprocessing.pool.Pool.__name__.__len__() == 4 ('Pool'); verified with Python 3.14.3"]
    - [pool_mod_len,   multiprocessing.pool.Pool.__module__.__len__,                [],                       20,    "multiprocessing.pool.Pool.__module__.__len__() == 20 ('multiprocessing.pool'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method qualnames — extra152
#
# multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map')           == True
# multiprocessing.pool.Pool.apply.__qualname__.__eq__('Pool.apply')       == True
# multiprocessing.pool.Pool.starmap.__qualname__.__eq__('Pool.starmap')   == True
# multiprocessing.pool.Pool.map_async.__qualname__.__eq__('Pool.map_async') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra152.mp_pool_method_qualnames:
  description: "multiprocessing.pool.Pool method qualname checks in mppoolmeth152 namespace — multiprocessing.pool.Pool.map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8; map() applies a function to each item in an iterable in parallel, blocking until all results are ready); multiprocessing.pool.Pool.apply.__qualname__=='Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10; apply() calls a function in a worker process and blocks); multiprocessing.pool.Pool.starmap.__qualname__=='Pool.starmap' (len=12: 'Pool'=4+'.'=1+'starmap'=7=12; starmap() like map() but unpacks iterable elements as function arguments); multiprocessing.pool.Pool.map_async.__qualname__=='Pool.map_async' (len=14: 'Pool'=4+'.'=1+'map_async'=9=14; map_async() like map() but returns an AsyncResult immediately without blocking); qualname length ordering: Pool.map_async(14) > Pool.starmap(12) > Pool.apply(10) > Pool.map(8); all have 'Pool.' prefix (5 chars) plus the method name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolmeth152

  columns: [id, function, args, expected, description]
  rows:
    - [map_qualname_eq,      multiprocessing.pool.Pool.map.__qualname__.__eq__,      ["Pool.map"],       true,  "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map' (len=8); verified with Python 3.14.3"]
    - [apply_qualname_eq,    multiprocessing.pool.Pool.apply.__qualname__.__eq__,    ["Pool.apply"],     true,  "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply' (len=10); verified with Python 3.14.3"]
    - [starmap_qualname_eq,  multiprocessing.pool.Pool.starmap.__qualname__.__eq__,  ["Pool.starmap"],   true,  "multiprocessing.pool.Pool.starmap.__qualname__ == 'Pool.starmap' (len=12); verified with Python 3.14.3"]
    - [mapasync_qualname_eq, multiprocessing.pool.Pool.map_async.__qualname__.__eq__, ["Pool.map_async"], true,  "multiprocessing.pool.Pool.map_async.__qualname__ == 'Pool.map_async' (len=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant multiprocessing_extra152.mp_Pool_name_eq:
  description: "multiprocessing.pool.Pool.__name__.__eq__('Pool') returns True — multiprocessing.pool.Pool is the primary worker-pool class in multiprocessing; it provides map(), apply(), starmap(), map_async(), apply_async(), starmap_async(), imap(), and imap_unordered() methods for parallel task execution; Pool.__name__=='Pool' (len=4); Pool.__module__=='multiprocessing.pool' (len=20); Pool.__bases__[0].__name__=='object' (inherits from object, not from a Process class); Pool is accessed via multiprocessing.pool.Pool (explicitly via submodule) or multiprocessing.Pool (re-exported at top level); NEW in extra152: first standalone multiprocessing.pool.Pool.__name__ identity invariant in mppool152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra152.mp_Pool_module_eq:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — Pool is defined in Lib/multiprocessing/pool.py and its __module__ is 'multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); compare: multiprocessing.Process.__module__=='multiprocessing.context' (len=23, 3 chars longer) and multiprocessing.Value.__module__=='multiprocessing.context' (also len=23); Pool's module 'multiprocessing.pool' (len=20) is shorter than the context module (len=23) because 'pool'=4 is shorter than 'context'=7; Pool.__module__.__len__()==20; NEW in extra152: first standalone multiprocessing.pool.Pool.__module__ identity invariant in mppool152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra152.mp_Pool_bases0_is_object:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.pool.Pool inherits directly from object (single inheritance); Pool is NOT a subclass of multiprocessing.Process or BaseProcess — it is a separate manager class that owns a pool of worker processes internally; Pool.__bases__==(object,); Pool.__bases__[0].__name__=='object' (len=6); compare: multiprocessing.Process.__bases__[0].__name__=='BaseProcess' (Process IS a process subclass) and concurrent.futures.Executor.__bases__[0].__name__=='object' (Executor also inherits from object — both Pool and Executor are manager classes that inherit from object); NEW in extra152: first standalone multiprocessing.pool.Pool.__bases__[0] name identity invariant in mppool152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra152.mp_Pool_map_qualname_eq:
  description: "multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map') returns True — Pool.map is an instance method with qualname 'Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8); the qualname follows the 'ClassName.methodname' pattern confirming map is defined directly on Pool; Pool.map() applies a function to each element in an iterable using the worker pool and returns results in order (blocking); qualname length ordering for Pool methods: Pool.map_async(14) > Pool.starmap(12) > Pool.apply(10) > Pool.map(8); map's qualname is the shortest among the 4 methods in this spec because 'map'=3 is the shortest method name; NEW in extra152: first standalone multiprocessing.pool.Pool.map.__qualname__ identity invariant in mppoolmeth152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map.__qualname__.__eq__
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra152.mp_Pool_map_async_qualname_eq:
  description: "multiprocessing.pool.Pool.map_async.__qualname__.__eq__('Pool.map_async') returns True — Pool.map_async is an instance method with qualname 'Pool.map_async' (len=14: 'Pool'=4+'.'=1+'map_async'=9=14); map_async() is the non-blocking variant of map() — it returns an AsyncResult object immediately without waiting for the worker processes to finish; the caller can then call AsyncResult.get() to retrieve results; Pool.map_async.__qualname__.__len__()==14 (the longest qualname among the 4 methods in this spec: map_async(14) > starmap(12) > apply(10) > map(8)); NEW in extra152: first standalone multiprocessing.pool.Pool.map_async.__qualname__ identity invariant in mppoolmeth152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map_async.__qualname__.__eq__
  args: ["Pool.map_async"]
  expected: true
