spec: inspect_extra168
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.isfunction.__name__ 'isfunction'; inspect.isfunction.__module__ 'inspect'; inspect.ismethod.__name__ 'ismethod'; inspect.ismethod.__module__ 'inspect'; inspect.isclass.__name__ 'isclass'; inspect.isclass.__module__ 'inspect'; inspect.ismodule.__name__ 'ismodule'; inspect.ismodule.__module__ 'inspect'; inspect.iscoroutine.__name__ 'iscoroutine'; inspect.iscoroutine.__module__ 'inspect' (Wave 297)."
    - "inspect.isfunction.__name__ == 'isfunction' — inspect.isfunction is a Python function defined in Lib/inspect.py that returns True if the object is a Python function (created by a def statement); its __name__ is 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect' — isfunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismethod.__name__ == 'ismethod' — inspect.ismethod is a Python function defined in Lib/inspect.py that returns True if the object is a bound method; its __name__ is 'ismethod'. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect' — ismethod is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' — inspect.isclass is a Python function defined in Lib/inspect.py that returns True if the object is a class; its __name__ is 'isclass'. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' — isclass is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismodule.__name__ == 'ismodule' — inspect.ismodule is a Python function defined in Lib/inspect.py that returns True if the object is a module; its __name__ is 'ismodule'. Verified with Python 3.14.3."
    - "inspect.ismodule.__module__ == 'inspect' — ismodule is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__name__ == 'iscoroutine' — inspect.iscoroutine is a Python function defined in Lib/inspect.py that returns True if the object is a coroutine object; its __name__ is 'iscoroutine'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__module__ == 'inspect' — iscoroutine is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isfunction and inspect.ismethod Python function identity
#
# Wave 297 theme: inspect predicate functions for function/method detection —
# __name__, __module__, and __class__.__name__.
#
# inspect.isfunction.__name__ == 'isfunction'
# inspect.isfunction.__module__ == 'inspect'
# inspect.ismethod.__name__ == 'ismethod'
# inspect.ismethod.__module__ == 'inspect'
#
# inspect.isfunction(object) returns True if the object is a Python function
# (i.e., created by a def statement); it returns False for built-in functions,
# lambda, functools.partial, etc. inspect.ismethod(object) returns True if the
# object is a bound method (a function bound to an instance). Both are Python
# functions defined in Lib/inspect.py. New to extra168.
# ---------------------------------------------------------------------------

table inspect_extra168.isfunction_ismethod_identity:
  description: "inspect.isfunction and ismethod: __name__ 'isfunction'/'ismethod', __module__ 'inspect', __class__.__name__ 'function'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: inspectifimi168

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_isfunction,
       "isfunction.__name__.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — inspect.isfunction is a Python function defined in Lib/inspect.py that returns True if an object is a Python function (created by def); its __name__ attribute is 'isfunction'; str.__eq__('isfunction') returns True; new to extra168"]
    - [isfunction_module_inspect,
       "isfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — inspect.isfunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra168"]
    - [ismethod_name_ismethod,
       "ismethod.__name__.__eq__",
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — inspect.ismethod is a Python function defined in Lib/inspect.py that returns True if an object is a bound method; its __name__ attribute is 'ismethod'; str.__eq__('ismethod') returns True; new to extra168"]
    - [ismethod_module_inspect,
       "ismethod.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — inspect.ismethod is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isclass and inspect.ismodule Python function identity
#
# Wave 297 theme: inspect predicate functions for class/module detection —
# __name__, __module__, and __class__.__name__.
#
# inspect.isclass.__name__ == 'isclass'
# inspect.isclass.__module__ == 'inspect'
# inspect.ismodule.__name__ == 'ismodule'
# inspect.ismodule.__module__ == 'inspect'
#
# inspect.isclass(object) returns True if the object is a class (as created by
# a class statement, or by type() or metaclasses). inspect.ismodule(object)
# returns True if the object is a module (sys, os, collections, etc.). Both are
# Python functions defined in Lib/inspect.py with __class__.__name__ 'function'.
# New to extra168.
# ---------------------------------------------------------------------------

table inspect_extra168.isclass_ismodule_identity:
  description: "inspect.isclass and ismodule: __name__ 'isclass'/'ismodule', __module__ 'inspect', __class__.__name__ 'function'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: inspecticism168

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_name_isclass,
       "isclass.__name__.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — inspect.isclass is a Python function defined in Lib/inspect.py that returns True if an object is a class (including those created by class statements, type(), or metaclasses); its __name__ attribute is 'isclass'; str.__eq__('isclass') returns True; new to extra168"]
    - [isclass_module_inspect,
       "isclass.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — inspect.isclass is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra168"]
    - [ismodule_name_ismodule,
       "ismodule.__name__.__eq__",
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — inspect.ismodule is a Python function defined in Lib/inspect.py that returns True if an object is a module; its __name__ attribute is 'ismodule'; str.__eq__('ismodule') returns True; new to extra168"]
    - [ismodule_module_inspect,
       "ismodule.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — inspect.ismodule is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 3: inspect.iscoroutine Python function identity
#
# Wave 297 theme: inspect.iscoroutine — __name__, __module__, and
# __class__.__name__.
#
# inspect.iscoroutine.__name__ == 'iscoroutine'
# inspect.iscoroutine.__module__ == 'inspect'
# inspect.iscoroutine.__class__.__name__ == 'function'
# inspect.iscoroutine.__name__ != 'iscoroutinefunction'
#
# inspect.iscoroutine(object) returns True if the object is a coroutine object
# (the result of calling an async def function), as distinct from
# inspect.iscoroutinefunction() which tests the function itself rather than the
# coroutine object it produces. Both are Python functions in Lib/inspect.py.
# New to extra168.
# ---------------------------------------------------------------------------

table inspect_extra168.iscoroutine_identity:
  description: "inspect.iscoroutine: __name__ 'iscoroutine', __module__ 'inspect', __class__.__name__ 'function', __name__ != 'iscoroutinefunction'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: inspectici168

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutine_name_iscoroutine,
       "iscoroutine.__name__.__eq__",
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__name__.__eq__('iscoroutine') == True — inspect.iscoroutine is a Python function defined in Lib/inspect.py that returns True if an object is a coroutine object (the result of calling an async def function); its __name__ attribute is 'iscoroutine'; str.__eq__('iscoroutine') returns True; new to extra168"]
    - [iscoroutine_module_inspect,
       "iscoroutine.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.iscoroutine.__module__.__eq__('inspect') == True — inspect.iscoroutine is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra168"]
    - [iscoroutine_class_name_function,
       "iscoroutine.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.iscoroutine.__class__.__name__.__eq__('function') == True — inspect.iscoroutine is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra168"]
    - [iscoroutine_name_ne_iscoroutinefunction,
       "iscoroutine.__name__.__eq__",
       ["iscoroutinefunction"],
       false,
       "inspect.iscoroutine.__name__.__eq__('iscoroutinefunction') == False — inspect.iscoroutine tests whether an object is a coroutine object; inspect.iscoroutinefunction (a distinct function) tests whether a callable is a coroutine function; iscoroutine.__name__ is 'iscoroutine', not 'iscoroutinefunction'; str.__eq__('iscoroutinefunction') returns False; new to extra168"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — isfunction, ismethod, isclass, ismodule all distinct
# and share __class__.__name__ 'function'
#
# Wave 297 theme: cross-checks confirming that all five inspect predicate
# functions (isfunction, ismethod, isclass, ismodule, iscoroutine) have distinct
# __name__ values and all have __class__.__name__ == 'function'.
#
# inspect.isfunction.__name__ != 'ismethod'
# inspect.isclass.__name__ != 'ismodule'
# inspect.isfunction.__class__.__name__ == 'function'
# inspect.isclass.__class__.__name__ == 'function'
#
# All five are regular Python functions defined in Lib/inspect.py with
# __class__.__name__ 'function'. Their __name__ values are distinct; none
# equals another's. New to extra168.
# ---------------------------------------------------------------------------

table inspect_extra168.predicate_functions_cross_checks:
  description: "inspect: isfunction.__name__ != 'ismethod', isclass.__name__ != 'ismodule', isfunction and isclass __class__.__name__ 'function'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpfcc168

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_ne_ismethod,
       "isfunction.__name__.__eq__",
       ["ismethod"],
       false,
       "inspect.isfunction.__name__.__eq__('ismethod') == False — isfunction.__name__ is 'isfunction', not 'ismethod'; inspect.isfunction tests for Python functions (def) while inspect.ismethod tests for bound methods; they are distinct functions; str.__eq__('ismethod') returns False; new to extra168"]
    - [isclass_name_ne_ismodule,
       "isclass.__name__.__eq__",
       ["ismodule"],
       false,
       "inspect.isclass.__name__.__eq__('ismodule') == False — isclass.__name__ is 'isclass', not 'ismodule'; inspect.isclass tests for class objects while inspect.ismodule tests for module objects; they are distinct functions; str.__eq__('ismodule') returns False; new to extra168"]
    - [isfunction_class_name_function,
       "isfunction.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isfunction.__class__.__name__.__eq__('function') == True — inspect.isfunction is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra168"]
    - [isclass_class_name_function,
       "isclass.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isclass.__class__.__name__.__eq__('function') == True — inspect.isclass is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 5: Negative checks — isfunction, ismethod, isclass module not 'builtins'
#
# Wave 297 theme: confirming that isfunction, ismethod, isclass, ismodule,
# and iscoroutine all have __module__ 'inspect' and not 'builtins'.
#
# inspect.isfunction.__module__ != 'builtins'
# inspect.isclass.__module__ != 'builtins'
# inspect.iscoroutine.__module__ != 'builtins'
# inspect.ismodule.__name__ != 'isclass'
#
# These predicate functions are all defined in Lib/inspect.py, not in the
# builtins module. This distinguishes them from the built-in isinstance() and
# issubclass() functions which are in builtins. New to extra168.
# ---------------------------------------------------------------------------

table inspect_extra168.predicate_functions_negative_checks:
  description: "inspect: isfunction, isclass, iscoroutine __module__ != 'builtins'; ismodule.__name__ != 'isclass'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpfnc168

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_module_not_builtins,
       "isfunction.__module__.__eq__",
       ["builtins"],
       false,
       "inspect.isfunction.__module__.__eq__('builtins') == False — inspect.isfunction is defined in Lib/inspect.py with __module__ 'inspect'; it is NOT in builtins (unlike isinstance() or issubclass()); str.__eq__('builtins') returns False; new to extra168"]
    - [isclass_module_not_builtins,
       "isclass.__module__.__eq__",
       ["builtins"],
       false,
       "inspect.isclass.__module__.__eq__('builtins') == False — inspect.isclass is defined in Lib/inspect.py with __module__ 'inspect'; it is NOT in builtins; str.__eq__('builtins') returns False; new to extra168"]
    - [iscoroutine_module_not_builtins,
       "iscoroutine.__module__.__eq__",
       ["builtins"],
       false,
       "inspect.iscoroutine.__module__.__eq__('builtins') == False — inspect.iscoroutine is defined in Lib/inspect.py with __module__ 'inspect'; it is NOT in builtins; str.__eq__('builtins') returns False; new to extra168"]
    - [ismodule_name_ne_isclass,
       "ismodule.__name__.__eq__",
       ["isclass"],
       false,
       "inspect.ismodule.__name__.__eq__('isclass') == False — ismodule.__name__ is 'ismodule', not 'isclass'; inspect.ismodule tests for module objects while inspect.isclass tests for class objects; they are distinct functions; str.__eq__('isclass') returns False; new to extra168"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra168
# ---------------------------------------------------------------------------

invariant inspect_extra168.isfunction_name_isfunction:
  description: "inspect.isfunction.__name__ == 'isfunction' — Python function returning True if object is a Python function (created by def); wave 297; new to extra168"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra168.isfunction_module_inspect:
  description: "inspect.isfunction.__module__ == 'inspect' — isfunction is defined in Lib/inspect.py; wave 297; new to extra168"
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra168.ismethod_name_ismethod:
  description: "inspect.ismethod.__name__ == 'ismethod' — Python function returning True if object is a bound method; wave 297; new to extra168"
  kind: python_call_eq
  function: ismethod.__name__.__eq__
  args: ["ismethod"]
  expected: true

invariant inspect_extra168.ismethod_module_inspect:
  description: "inspect.ismethod.__module__ == 'inspect' — ismethod is defined in Lib/inspect.py; wave 297; new to extra168"
  kind: python_call_eq
  function: ismethod.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra168.isclass_name_isclass:
  description: "inspect.isclass.__name__ == 'isclass' — Python function returning True if object is a class; wave 297; new to extra168"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra168.isclass_module_inspect:
  description: "inspect.isclass.__module__ == 'inspect' — isclass is defined in Lib/inspect.py; wave 297; new to extra168"
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra168.ismodule_name_ismodule:
  description: "inspect.ismodule.__name__ == 'ismodule' — Python function returning True if object is a module; wave 297; new to extra168"
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra168.ismodule_module_inspect:
  description: "inspect.ismodule.__module__ == 'inspect' — ismodule is defined in Lib/inspect.py; wave 297; new to extra168"
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra168.iscoroutine_name_iscoroutine:
  description: "inspect.iscoroutine.__name__ == 'iscoroutine' — Python function returning True if object is a coroutine object (result of calling async def); wave 297; new to extra168"
  kind: python_call_eq
  function: iscoroutine.__name__.__eq__
  args: ["iscoroutine"]
  expected: true

invariant inspect_extra168.iscoroutine_module_inspect:
  description: "inspect.iscoroutine.__module__ == 'inspect' — iscoroutine is defined in Lib/inspect.py; wave 297; new to extra168"
  kind: python_call_eq
  function: iscoroutine.__module__.__eq__
  args: ["inspect"]
  expected: true
