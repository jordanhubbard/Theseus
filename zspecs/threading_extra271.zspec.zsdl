# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra271
# ---------------------------------------------------------------------------

invariant threading_extra271.condition_name_is_condition:
  description: "threading.Condition.__name__ == 'Condition' (len=9) — class name matches the export name"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra271.condition_notify_all_name_is_longest:
  description: "threading.Condition.notify_all.__name__.__len__() == 10 — 'notify_all' is the longest Condition method name; longer than wait_for(8), notify(6), wait(4)"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__name__.__len__
  args: []
  expected: 10

invariant threading_extra271.condition_wait_name_is_shortest:
  description: "threading.Condition.wait.__name__.__len__() == 4 — 'wait' is the shortest Condition method name; shorter than notify(6), wait_for(8), notify_all(10)"
  category: identity
  kind: python_call_eq
  function: Condition.wait.__name__.__len__
  args: []
  expected: 4

invariant threading_extra271.barrier_name_is_barrier:
  description: "threading.Barrier.__name__ == 'Barrier' (len=7) — class name matches the export name"
  category: identity
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra271.barrier_n_waiting_is_property:
  description: "threading.Barrier.n_waiting.__class__.__name__ == 'property' — n_waiting is a property descriptor on Barrier"
  category: identity
  kind: python_call_eq
  function: Barrier.n_waiting.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra271.barrier_n_waiting_fget_name_is_longest:
  description: "threading.Barrier.n_waiting.fget.__name__.__len__() == 9 — 'n_waiting' is the longest property fget name in this spec; longer than broken(6)"
  category: identity
  kind: python_call_eq
  function: Barrier.n_waiting.fget.__name__.__len__
  args: []
  expected: 9

invariant threading_extra271.barrier_wait_is_function:
  description: "threading.Barrier.wait.__class__.__name__ == 'function' — wait is a pure Python function method on Barrier"
  category: identity
  kind: python_call_eq
  function: Barrier.wait.__class__.__name__.__eq__
  args: ["function"]
  expected: true
