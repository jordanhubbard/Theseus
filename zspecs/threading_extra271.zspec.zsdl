spec: threading_extra271
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Condition.__bases__[0].__name__ == 'object'; Condition methods are pure Python functions."
    - "Condition has 4 methods: wait(4), wait_for(8), notify(6), notify_all(10 longest)."
    - "Condition.wait.__qualname__ == 'Condition.wait' (len=14); all method qualnames start with 'Condition.'."
    - "threading.Barrier.__bases__[0].__name__ == 'object'; Barrier methods are pure Python functions."
    - "Barrier has 3 methods: wait(4), reset(5), abort(5); and 2 properties: n_waiting(9), broken(6)."
    - "Barrier.n_waiting.fget.__qualname__ == 'Barrier.n_waiting' (len=17); Barrier.broken.fget.__qualname__ == 'Barrier.broken' (len=14)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Condition class and method identity
#
# Condition.__module__ == 'threading'; __bases__[0].__name__ == 'object'.
# Methods: wait(4) < notify(6) < wait_for(8) < notify_all(10 longest name).
# All methods are 'function' class with qualname 'Condition.<method>'.
# ---------------------------------------------------------------------------

table threading_extra271.condition_identity:
  description: "threading.Condition class and method identity — module 'threading', base 'object'; methods wait(4), notify(6), wait_for(8), notify_all(10 longest); all are function class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex271co

  columns: [id, function, args, expected, description]
  rows:
    - [co_name_eq,           Condition.__name__.__eq__,                   ["Condition"],                  true, "threading.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [co_name_len,          Condition.__name__.__len__,                  [],                             9,    "threading.Condition.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [co_mod_eq,            Condition.__module__.__eq__,                 ["threading"],                  true, "threading.Condition.__module__ == 'threading'; verified with Python 3.14.3"]
    - [co_base_eq,           Condition.__bases__.__getitem__(0).__name__.__eq__, ["object"],              true, "threading.Condition.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [wa_name_eq,           Condition.wait.__name__.__eq__,              ["wait"],                       true, "threading.Condition.wait.__name__ == 'wait' (len=4 — shortest method); verified with Python 3.14.3"]
    - [wa_name_len,          Condition.wait.__name__.__len__,             [],                             4,    "threading.Condition.wait.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [wa_qn_eq,             Condition.wait.__qualname__.__eq__,          ["Condition.wait"],             true, "threading.Condition.wait.__qualname__ == 'Condition.wait' (len=14); verified with Python 3.14.3"]
    - [wa_cls_eq,            Condition.wait.__class__.__name__.__eq__,    ["function"],                   true, "threading.Condition.wait.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [no_name_eq,           Condition.notify.__name__.__eq__,            ["notify"],                     true, "threading.Condition.notify.__name__ == 'notify' (len=6); verified with Python 3.14.3"]
    - [no_name_len,          Condition.notify.__name__.__len__,           [],                             6,    "threading.Condition.notify.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [no_qn_eq,             Condition.notify.__qualname__.__eq__,        ["Condition.notify"],           true, "threading.Condition.notify.__qualname__ == 'Condition.notify' (len=16); verified with Python 3.14.3"]
    - [no_cls_eq,            Condition.notify.__class__.__name__.__eq__,  ["function"],                   true, "threading.Condition.notify.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [wf_name_eq,           Condition.wait_for.__name__.__eq__,          ["wait_for"],                   true, "threading.Condition.wait_for.__name__ == 'wait_for' (len=8); verified with Python 3.14.3"]
    - [wf_name_len,          Condition.wait_for.__name__.__len__,         [],                             8,    "threading.Condition.wait_for.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [wf_qn_eq,             Condition.wait_for.__qualname__.__eq__,      ["Condition.wait_for"],         true, "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18); verified with Python 3.14.3"]
    - [na_name_eq,           Condition.notify_all.__name__.__eq__,        ["notify_all"],                 true, "threading.Condition.notify_all.__name__ == 'notify_all' (len=10 — longest method name); verified with Python 3.14.3"]
    - [na_name_len,          Condition.notify_all.__name__.__len__,       [],                             10,   "threading.Condition.notify_all.__name__.__len__() == 10 — longest Condition method name; verified with Python 3.14.3"]
    - [na_qn_eq,             Condition.notify_all.__qualname__.__eq__,    ["Condition.notify_all"],       true, "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20); verified with Python 3.14.3"]
    - [na_cls_eq,            Condition.notify_all.__class__.__name__.__eq__, ["function"],                true, "threading.Condition.notify_all.__class__.__name__ == 'function'; verified with Python 3.14.3"]

