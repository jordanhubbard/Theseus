spec: inspect_extra2266
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of inspect classes."
    - "inspect.Parameter: __reduce__ present (True), __setstate__ present (True); all others absent."
    - "inspect.Signature: __reduce__ present (True), __setstate__ present (True); all others absent."
    - "inspect.BoundArguments: __getstate__ present (True), __setstate__ present (True); all others absent."
    - "inspect.FrameInfo: all protocol keys absent. FrameInfo is a namedtuple subclass with bases (inspect._FrameInfo,) and mro including tuple."
    - "inspect.FullArgSpec: __getnewargs__ present (True); all others absent. FullArgSpec is a namedtuple with bases (tuple,)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2266.parameter_pickle:
  description: "inspect.Parameter pickle/serialization protocol dict-presence — __reduce__ and __setstate__ present; others absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2266

  columns: [id, function, args, expected]
  rows:
    - ["in2266001", "inspect.Parameter.__dict__.__contains__", ["__reduce__"], true]
    - ["in2266002", "inspect.Parameter.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2266003", "inspect.Parameter.__dict__.__contains__", ["__getstate__"], false]
    - ["in2266004", "inspect.Parameter.__dict__.__contains__", ["__setstate__"], true]
    - ["in2266005", "inspect.Parameter.__dict__.__contains__", ["__getnewargs__"], false]
    - ["in2266006", "inspect.Parameter.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["in2266007", "inspect.Parameter.__dict__.__contains__", ["__copy__"], false]
    - ["in2266008", "inspect.Parameter.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in2266009", "inspect.Parameter.__dict__.__contains__", ["__sizeof__"], false]
    - ["in2266010", "inspect.Parameter.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2266011", "inspect.Parameter.__dict__.__contains__", ["__init_subclass__"], false]

