spec: multiprocessing_extra2836
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, base class, factory __name__ checks"
    - "multiprocessing_extra2.zspec.zsdl — covers factory __module__ checks, extra primitive names"
    - "multiprocessing_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
    - "multiprocessing_extra2821.zspec.zsdl — covers __radd__, __rsub__, __rmul__ dict-presence checks"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "None of the multiprocessing public classes define __rtruediv__, __rfloordiv__, or __rmod__ in their __dict__."
    - "multiprocessing.Process is a real class (Lib/multiprocessing/process.py); Pool and ApplyResult are in Lib/multiprocessing/pool.py."
    - "multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult; __name__ is 'ApplyResult' in Python 3.14.4."
    - "Process, Pool, and ApplyResult are process-management/coordination classes, not numeric types."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — __rtruediv__/__rfloordiv__/__rmod__ dict-presence checks
#
# Process is the core class for spawning new OS processes. It manages process
# lifecycle (start, join, terminate) and does not implement reflected division
# or modulo operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2836.process_operator_dict:
  description: "multiprocessing.Process __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2836p

  columns: [id, function, args, expected]
  rows:
    - ["mp2836p_rtd",  multiprocessing.Process.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["mp2836p_rfd",  multiprocessing.Process.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["mp2836p_rmd",  multiprocessing.Process.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — __rtruediv__/__rfloordiv__/__rmod__ dict-presence checks
#
# Pool is a process pool manager providing map/apply/starmap/imap interfaces.
# It coordinates worker processes and does not define reflected division or
# modulo operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2836.pool_operator_dict:
  description: "multiprocessing.pool.Pool __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2836pl

  columns: [id, function, args, expected]
  rows:
    - ["mp2836pl_rtd",  multiprocessing.pool.Pool.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["mp2836pl_rfd",  multiprocessing.pool.Pool.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["mp2836pl_rmd",  multiprocessing.pool.Pool.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.ApplyResult — __rtruediv__/__rfloordiv__/__rmod__ dict-presence checks
#
# ApplyResult (also exported as AsyncResult) is the result object returned by
# Pool.apply_async(). It wraps a pending result and provides get()/ready()/wait().
# It does not implement reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2836.applyresult_operator_dict:
  description: "multiprocessing.pool.ApplyResult __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2836ar

  columns: [id, function, args, expected]
  rows:
    - ["mp2836ar_rtd",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["mp2836ar_rfd",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["mp2836ar_rmd",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — Process, Pool, ApplyResult × three reflected division/modulo operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Process, Pool, and ApplyResult do not define /, //, or %
# reflected operator dunders in their respective __dict__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2836.all_types_rtruediv_rfloordiv_rmod_matrix:
  description: "Full 3×3 dict-presence matrix for multiprocessing types vs __rtruediv__/__rfloordiv__/__rmod__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2836mx

  columns: [id, function, args, expected]
  rows:
    - ["mp2836mx_p_rtd",   multiprocessing.Process.__dict__.__contains__,          ["__rtruediv__"],   false]
    - ["mp2836mx_p_rfd",   multiprocessing.Process.__dict__.__contains__,          ["__rfloordiv__"],  false]
    - ["mp2836mx_p_rmd",   multiprocessing.Process.__dict__.__contains__,          ["__rmod__"],       false]
    - ["mp2836mx_pl_rtd",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__rtruediv__"],   false]
    - ["mp2836mx_pl_rfd",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__rfloordiv__"],  false]
    - ["mp2836mx_pl_rmd",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__rmod__"],       false]
    - ["mp2836mx_ar_rtd",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["mp2836mx_ar_rfd",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["mp2836mx_ar_rmd",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__rmod__"],       false]
