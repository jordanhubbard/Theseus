spec: socket_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - socket module CPython source
    - Python documentation for socket
  not_derived_from:
    - any third-party networking library
  notes:
    - covers qualname and module identity for socket class and module-level functions
    - includes getfqdn, gethostname, gethostbyname, getaddrinfo, getnameinfo, setdefaulttimeout, getdefaulttimeout, create_connection, create_server
  created_at: "2026-04-12"

table socket_extra811.qualnames_and_modules:
  description: socket module-level functions and class qualnames
  kind: python_call_eq
  category: identity
  id_prefix: sk811xx
  columns: [id, function, args, expected]
  rows:
    - [sk811xx001, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [sk811xx002, socket.socket.__module__.__eq__, ["socket"], true]
    - [sk811xx003, socket.getfqdn.__qualname__.__eq__, ["getfqdn"], true]
    - [sk811xx004, socket.getfqdn.__module__.__eq__, ["socket"], true]
    - [sk811xx005, socket.gethostname.__qualname__.__eq__, ["gethostname"], true]
    - [sk811xx006, socket.gethostbyname.__qualname__.__eq__, ["gethostbyname"], true]
    - [sk811xx007, socket.getaddrinfo.__qualname__.__eq__, ["getaddrinfo"], true]
    - [sk811xx008, socket.getnameinfo.__qualname__.__eq__, ["getnameinfo"], true]
    - [sk811xx009, socket.setdefaulttimeout.__qualname__.__eq__, ["setdefaulttimeout"], true]
    - [sk811xx010, socket.getdefaulttimeout.__qualname__.__eq__, ["getdefaulttimeout"], true]
    - [sk811xx011, socket.create_connection.__qualname__.__eq__, ["create_connection"], true]
    - [sk811xx012, socket.create_server.__qualname__.__eq__, ["create_server"], true]
