spec: theseus_tomllib_cr
version: ">=3.11"
backend: python_cleanroom(theseus_tomllib_cr)
blocks: tomllib

docs: https://docs.python.org/3/library/tomllib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tomllib.html"
  not_derived_from:
    - "CPython source: Lib/tomllib/__init__.py"
  notes:
    - "Clean-room tomllib module. Do NOT import tomllib."

error_model: python_exceptions

invariant theseus_tomllib_cr.tomllib2_loads:
  description: "loads() parses a TOML string"
  category: behavior
  kind: python_call_eq
  function: tomllib2_loads
  args: []
  expected: true

invariant theseus_tomllib_cr.tomllib2_load:
  description: "load() parses a TOML file"
  category: behavior
  kind: python_call_eq
  function: tomllib2_load
  args: []
  expected: true

invariant theseus_tomllib_cr.tomllib2_error:
  description: "TOMLDecodeError exists as a ValueError subclass"
  category: behavior
  kind: python_call_eq
  function: tomllib2_error
  args: []
  expected: true
