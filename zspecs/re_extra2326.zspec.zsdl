spec: re_extra2326
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "re.RegexFlag integer values: NOFLAG=0, IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64, DEBUG=128, ASCII=256."
    - "re.error.__name__ == 'PatternError' in Python 3.13+ (renamed from 'error')."
    - "re.Pattern.__name__ == 'Pattern', re.Match.__name__ == 'Match'."
    - "re.RegexFlag.__name__ == 'RegexFlag' — the flag enum class name."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: RegexFlag integer values — __int__ attribute access
# ---------------------------------------------------------------------------

table re_extra2326.flag_values:
  description: "re.RegexFlag integer constant values via __int__"
  kind: python_call_eq
  category: constants
  id_prefix: re2326

  columns: [id, function, args, expected]
  rows:
    - ["re2326001", "re.NOFLAG.__int__",     [], 0]
    - ["re2326002", "re.IGNORECASE.__int__", [], 2]
    - ["re2326003", "re.LOCALE.__int__",     [], 4]
    - ["re2326004", "re.MULTILINE.__int__",  [], 8]
    - ["re2326005", "re.DOTALL.__int__",     [], 16]
    - ["re2326006", "re.UNICODE.__int__",    [], 32]
    - ["re2326007", "re.VERBOSE.__int__",    [], 64]
    - ["re2326008", "re.DEBUG.__int__",      [], 128]
    - ["re2326009", "re.ASCII.__int__",      [], 256]

# ---------------------------------------------------------------------------
# Table 2: RegexFlag short alias integer values
# ---------------------------------------------------------------------------

table re_extra2326.flag_short_aliases:
  description: "re.RegexFlag short alias constants match their long-form integer values"
  kind: python_call_eq
  category: constants
  id_prefix: re2326

  columns: [id, function, args, expected]
  rows:
    - ["re2326010", "re.I.__int__", [], 2]
    - ["re2326011", "re.M.__int__", [], 8]
    - ["re2326012", "re.S.__int__", [], 16]
    - ["re2326013", "re.X.__int__", [], 64]
    - ["re2326014", "re.A.__int__", [], 256]

# ---------------------------------------------------------------------------
# Table 3: Class __name__ attributes — Pattern, Match, RegexFlag, error
# ---------------------------------------------------------------------------

table re_extra2326.class_names:
  description: "re module class and type __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: re2326

  columns: [id, function, args, expected]
  rows:
    - ["re2326015", "re.RegexFlag.__name__", [], "RegexFlag"]
    - ["re2326016", "re.Pattern.__name__",   [], "Pattern"]
    - ["re2326017", "re.Match.__name__",     [], "Match"]
    - ["re2326018", "re.error.__name__",     [], "PatternError"]

# ---------------------------------------------------------------------------
# Table 4: Flag type checks — all RegexFlag constants are RegexFlag instances
# ---------------------------------------------------------------------------

table re_extra2326.flag_types:
  description: "re flag constants have __class__.__name__ == 'RegexFlag'"
  kind: python_call_eq
  category: constants
  id_prefix: re2326

  columns: [id, function, args, expected]
  rows:
    - ["re2326019", "re.IGNORECASE.__class__.__name__", [], "RegexFlag"]
    - ["re2326020", "re.MULTILINE.__class__.__name__",  [], "RegexFlag"]
    - ["re2326021", "re.DOTALL.__class__.__name__",     [], "RegexFlag"]
    - ["re2326022", "re.ASCII.__class__.__name__",      [], "RegexFlag"]
