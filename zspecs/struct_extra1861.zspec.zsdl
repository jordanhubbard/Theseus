spec: struct_extra1861
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python struct documentation — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 571: bitwise and in-place operators for struct module classes"
    - "struct.Struct and struct.error do not define bitwise or in-place operators in their own __dict__"
    - "struct.error inherits from Exception; __init__ and __new__ are not in struct.error.__dict__ directly"
    - "struct.error.__dict__ contains __doc__, __module__, __weakref__ but not __dict__, __repr__, __str__"
  created_at: "2026-04-12"

table struct_extra1861.bitwise_operators:
  columns: [id, function, args, expected]
  rows:
    - ["st1861-bit-001", "struct.Struct.__dict__.__contains__", ["__or__"], false]
    - ["st1861-bit-002", "struct.Struct.__dict__.__contains__", ["__and__"], false]
    - ["st1861-bit-003", "struct.Struct.__dict__.__contains__", ["__xor__"], false]
    - ["st1861-bit-004", "struct.Struct.__dict__.__contains__", ["__invert__"], false]
    - ["st1861-bit-005", "struct.error.__dict__.__contains__", ["__or__"], false]
    - ["st1861-bit-006", "struct.__dict__.__contains__", ["__or__"], false]
    - ["st1861-bit-007", "struct.__dict__.__contains__", ["__and__"], false]
    - ["st1861-bit-008", "struct.__dict__.__contains__", ["__xor__"], false]

table struct_extra1861.inplace_operators:
  columns: [id, function, args, expected]
  rows:
    - ["st1861-iop-001", "struct.Struct.__dict__.__contains__", ["__iadd__"], false]
    - ["st1861-iop-002", "struct.Struct.__dict__.__contains__", ["__ior__"], false]
    - ["st1861-iop-003", "struct.Struct.__dict__.__contains__", ["__imul__"], false]
    - ["st1861-iop-004", "struct.error.__dict__.__contains__", ["__iadd__"], false]
    - ["st1861-iop-005", "struct.__dict__.__contains__", ["__iadd__"], false]
    - ["st1861-iop-006", "struct.__dict__.__contains__", ["__ior__"], false]
    - ["st1861-iop-007", "struct.__dict__.__contains__", ["__imul__"], false]
    - ["st1861-iop-008", "struct.__dict__.__contains__", ["__isub__"], false]

table struct_extra1861.struct_error_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["st1861-err-001", "struct.error.__dict__.__contains__", ["__init__"], false]
    - ["st1861-err-002", "struct.error.__dict__.__contains__", ["__new__"], false]
    - ["st1861-err-003", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st1861-err-004", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st1861-err-005", "struct.error.__dict__.__contains__", ["__weakref__"], true]
    - ["st1861-err-006", "struct.error.__dict__.__contains__", ["__dict__"], false]
    - ["st1861-err-007", "struct.error.__dict__.__contains__", ["__repr__"], false]
    - ["st1861-err-008", "struct.error.__dict__.__contains__", ["__str__"], false]
    - ["st1861-err-009", "struct.__dict__.__contains__", ["error"], true]
    - ["st1861-err-010", "struct.__dict__.__contains__", ["Struct"], true]
