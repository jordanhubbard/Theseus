spec: pathlib_extra28
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra19.zspec.zsdl — covers Path.home/cwd/stat/open/mkdir/exists __qualname__."
    - "pathlib_extra27.zspec.zsdl — covers __qualname__ equality and lengths for the five main pathlib classes."
  notes:
    - "This spec extends pathlib_extra27.zspec.zsdl."
    - "Focus: __qualname__ for Path instance methods not yet covered (read_text, write_text, resolve, iterdir) and Path.is_absolute.__qualname__ which resolves to 'PurePath.is_absolute'."
    - "Path.is_absolute.__qualname__ == 'PurePath.is_absolute' — is_absolute is defined on PurePath, so the qualname carries the PurePath prefix even when accessed via Path."
    - "Path.read_text.__qualname__ == 'Path.read_text' — instance method qualname includes class prefix."
    - "Path.write_text.__qualname__ == 'Path.write_text' — instance method qualname includes class prefix."
    - "Path.resolve.__qualname__ == 'Path.resolve' — instance method qualname includes class prefix."
    - "Path.iterdir.__qualname__ == 'Path.iterdir' — instance method qualname includes class prefix."
    - "No prior pathlib spec covers __qualname__ for read_text, write_text, resolve, or iterdir."
    - "No prior pathlib spec covers Path.is_absolute.__qualname__ as an attribute access."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.is_absolute.__qualname__ — defined on PurePath
#
# is_absolute is defined on PurePath, not Path. When accessed via Path.is_absolute,
# the __qualname__ attribute still carries the defining class prefix:
# 'PurePath.is_absolute'. This is a notable distinction from methods like
# Path.exists whose qualname is 'Path.exists'.
# Verified: pathlib.Path.is_absolute.__qualname__ == 'PurePath.is_absolute'
# ---------------------------------------------------------------------------

invariant pathlib_extra28.Path.is_absolute.qualname:
  description: "pathlib.Path.is_absolute.__qualname__ == 'PurePath.is_absolute' — defined on PurePath, qualname carries PurePath prefix"
  category: method_identity
  kind: python_call_eq
  function: "Path.is_absolute.__qualname__.__eq__"
  args: ["PurePath.is_absolute"]
  expected: true

invariant pathlib_extra28.Path.is_absolute.name:
  description: "pathlib.Path.is_absolute.__name__ == 'is_absolute' — simple method name without class prefix"
  category: method_identity
  kind: python_call_eq
  function: Path.is_absolute.__name__.__eq__
  args: ["is_absolute"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __qualname__ for Path instance methods not yet covered
#
# pathlib_extra4 covers __name__ for read_text/write_text/iterdir.
# pathlib_extra19 covers __qualname__ for stat/open/mkdir/exists.
# No prior spec covers __qualname__ for read_text, write_text, resolve,
# or iterdir. For instance methods, qualname == 'Path.<method_name>'.
# Verified: read_text='Path.read_text', write_text='Path.write_text',
#           resolve='Path.resolve', iterdir='Path.iterdir'.
# ---------------------------------------------------------------------------

table pathlib_extra28.path_method_qualnames:
  description: "__qualname__ for Path instance methods read_text/write_text/resolve/iterdir"
  kind: python_call_eq
  category: method_identity
  id_prefix: pmqn28

  columns: [id, function, args, expected]
  rows:
    - [read_text,  Path.read_text.__qualname__.__eq__,  ["Path.read_text"],  true]
    - [write_text, Path.write_text.__qualname__.__eq__, ["Path.write_text"], true]
    - [resolve,    Path.resolve.__qualname__.__eq__,    ["Path.resolve"],    true]
    - [iterdir,    Path.iterdir.__qualname__.__eq__,    ["Path.iterdir"],    true]
