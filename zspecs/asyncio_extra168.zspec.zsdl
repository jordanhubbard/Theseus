table asyncio_extra168.asyncio_queue_exceptions_identity:
  description: "asyncio.QueueEmpty and asyncio.QueueFull exception name, module, and base class checks in asyncioqex168 namespace — asyncio.QueueEmpty.__name__.__eq__('QueueEmpty')==True (QueueEmpty.__name__=='QueueEmpty' (len=10: 'Queue'=5+'Empty'=5=10); asyncio.QueueEmpty is raised by Queue.get_nowait() when the queue contains no items; compare Queue.get() which blocks until an item is available vs Queue.get_nowait() which raises QueueEmpty immediately if the queue is empty; QueueEmpty.__module__=='asyncio.queues' (len=14; same module as Queue, LifoQueue, PriorityQueue — all four asyncio queue types are in the same module)); asyncio.QueueEmpty.__bases__[0].__name__.__eq__('Exception')==True (QueueEmpty inherits from Exception directly; the MRO is QueueEmpty -> Exception -> BaseException -> object (len=4)); asyncio.QueueFull.__name__.__eq__('QueueFull')==True (QueueFull.__name__=='QueueFull' (len=9: 'Queue'=5+'Full'=4=9; 1 char shorter than QueueEmpty=10 because 'Full'=4 < 'Empty'=5 by 1)); asyncio.QueueFull.__bases__[0].__name__.__eq__('Exception')==True (QueueFull also inherits from Exception directly; raised by Queue.put_nowait() when the queue is at capacity (maxsize > 0)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqex168

  columns: [id, function, args, expected, description]
  rows:
    - [qempty_name_eq,      asyncio.QueueEmpty.__name__.__eq__,                  ["QueueEmpty"],       true,  "QueueEmpty.__name__ == 'QueueEmpty' (len=10: 'Queue'=5+'Empty'=5=10); verified with Python 3.14.3"]
    - [qempty_mod_eq,       asyncio.QueueEmpty.__module__.__eq__,                ["asyncio.queues"],   true,  "QueueEmpty.__module__ == 'asyncio.queues' (len=14; same as Queue module); verified with Python 3.14.3"]
    - [qempty_base_name_eq, "asyncio.QueueEmpty.__bases__[0].__name__.__eq__",   ["Exception"],        true,  "QueueEmpty.__bases__[0].__name__ == 'Exception' (inherits from Exception; MRO len=4); verified with Python 3.14.3"]
    - [qfull_name_eq,       asyncio.QueueFull.__name__.__eq__,                   ["QueueFull"],        true,  "QueueFull.__name__ == 'QueueFull' (len=9: 'Queue'=5+'Full'=4=9; 1 shorter than QueueEmpty=10); verified with Python 3.14.3"]
    - [qfull_base_name_eq,  "asyncio.QueueFull.__bases__[0].__name__.__eq__",    ["Exception"],        true,  "QueueFull.__bases__[0].__name__ == 'Exception' (inherits from Exception; raised by put_nowait()); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra168
# ---------------------------------------------------------------------------

invariant asyncio_extra168.asyncio_Queue_name_eq:
  description: "asyncio.Queue.__name__.__eq__('Queue') returns True — asyncio.Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5); asyncio.Queue is the core async-safe FIFO queue for coroutine coordination; it supports bounded capacity (maxsize parameter; 0=unbounded) with backpressure: Queue.put(item) is a coroutine that blocks when the queue is full; Queue.get() is a coroutine that blocks when the queue is empty; Queue.put_nowait() raises QueueFull immediately if full; Queue.get_nowait() raises QueueEmpty immediately if empty; Queue.join() blocks until all put items have had task_done() called; Queue.__module__=='asyncio.queues' (len=14: same total length as asyncio.Handle.__module__='asyncio.events'=14 from extra166 — both use 6-char submodule names after 'asyncio.'); KEY FINDING: Queue.__bases__[0].__name__=='_LoopBoundMixin' (NOT 'object' — Queue does not inherit from object directly; the intermediate mixin binds it to the event loop); name length ordering so far: Task(4) < Queue(5) < Handle=Future(6); NEW in extra168: first standalone Queue.__name__ identity invariant in asyncioq168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra168.asyncio_Queue_module_eq:
  description: "asyncio.Queue.__module__.__eq__('asyncio.queues') returns True — asyncio.Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14); the 'queues' submodule (len=6) has the same character count as the 'events' submodule (len=6) from asyncio.Handle's module (asyncio.events=14 from extra166) — both submodule names are 6 chars giving the same 14-char full module path; asyncio.queues defines: Queue, LifoQueue, PriorityQueue, QueueEmpty, QueueFull; the module was originally named asyncio.queues because all queue types live there; compare: asyncio.streams.__len__()==15 (asyncio.StreamReader from extra164 has module len=15 because 'streams'=7 > 'queues'=6 by 1); asyncio.queues(14) < asyncio.streams(15) by 1; NEW in extra168: first standalone Queue.__module__ identity invariant in asyncioq168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra168.asyncio_Queue_base_is_LoopBoundMixin:
  description: "asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — KEY FINDING: asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15; leading underscore marks it as private/internal); asyncio.Queue does NOT inherit from object directly; it inherits from asyncio.mixins._LoopBoundMixin which provides the _get_loop() method that lazily binds the queue to the running event loop; this design was introduced to eliminate the deprecated loop parameter that asyncio objects previously accepted; _LoopBoundMixin.__bases__[0].__name__=='object' so the full MRO is Queue -> _LoopBoundMixin -> object (len=3); compare: asyncio.AbstractEventLoop.__bases__[0].__name__=='object' (from extra167: AbstractEventLoop inherits from object directly) vs asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue does NOT inherit from object directly — there is an intermediate mixin); the base class name '_LoopBoundMixin'=15 is longer than Queue.__name__='Queue'=5 by 10 chars; NEW in extra168: first standalone Queue.__bases__[0].__name__ invariant in asyncioqbase168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra168.asyncio_LifoQueue_name_eq:
  description: "asyncio.LifoQueue.__name__.__eq__('LifoQueue') returns True — asyncio.LifoQueue.__name__=='LifoQueue' (len=9: 'Lifo'=4+'Queue'=5=9); asyncio.LifoQueue is a LIFO (Last In First Out) variant of asyncio.Queue; it overrides Queue._get() to pop from the end of the internal list rather than the front, achieving stack-like LIFO semantics; LifoQueue inherits from Queue: LifoQueue.__bases__[0].__name__=='Queue'; the MRO is LifoQueue -> Queue -> _LoopBoundMixin -> object (len=4; one more than Queue's MRO len=3); 'Lifo'=4 is the distinctive prefix; 'Queue'=5 is the shared suffix; LifoQueue(9) = Lifo(4) + Queue(5); compare: asyncio.PriorityQueue.__name__.__len__()==13 (Priority=8+Queue=5=13; 4 chars longer than LifoQueue=9); asyncio.Queue.__name__.__len__()==5 (4 shorter than LifoQueue=9; Lifo=4 is the prefix accounting for all the difference); LENGTH ORDERING: Queue(5) < LifoQueue(9) < PriorityQueue(13); NEW in extra168: first standalone LifoQueue.__name__ identity invariant in asynciolpq168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.LifoQueue.__name__.__eq__
  args: ["LifoQueue"]
  expected: true

invariant asyncio_extra168.asyncio_LifoQueue_base_is_Queue:
  description: "asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue') returns True — asyncio.LifoQueue.__bases__[0] is asyncio.Queue; LifoQueue.__bases__[0].__name__=='Queue' (len=5); LifoQueue IS-A Queue — isinstance checks against asyncio.Queue return True for LifoQueue instances; LifoQueue inherits all public Queue methods (get, put, get_nowait, put_nowait, join, task_done, qsize, empty, full) and overrides the internal _get() to use list.pop() for LIFO ordering; the MRO is LifoQueue -> Queue -> _LoopBoundMixin -> object (len=4); compare: asyncio.PriorityQueue.__bases__[0].__name__=='Queue' (PriorityQueue also inherits from Queue — same parent class for both LIFO and Priority variants; both override Queue's internal _get() and _put() methods); Queue's name 'Queue'=5 appears as the suffix in both 'LifoQueue'=9 and 'PriorityQueue'=13, visually encoding the inheritance relationship in the class names; NEW in extra168: first standalone LifoQueue.__bases__[0].__name__ invariant in asynciolpqbase168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra168.asyncio_QueueEmpty_name_eq:
  description: "asyncio.QueueEmpty.__name__.__eq__('QueueEmpty') returns True — asyncio.QueueEmpty.__name__=='QueueEmpty' (len=10: 'Queue'=5+'Empty'=5=10); asyncio.QueueEmpty is the exception raised by Queue.get_nowait(), LifoQueue.get_nowait(), and PriorityQueue.get_nowait() when the queue contains no items; it inherits from Exception directly (QueueEmpty.__bases__[0].__name__=='Exception') and has a 4-entry MRO: QueueEmpty -> Exception -> BaseException -> object; QueueEmpty is symmetric with QueueFull: QueueEmpty for get_nowait on empty queue, QueueFull for put_nowait on full queue; compare: QueueEmpty(10) vs QueueFull(9) — QueueEmpty is 1 char longer because 'Empty'=5 > 'Full'=4 by 1; compare: asyncio.Queue.__name__.__len__()==5 ('Queue'=5) is the common prefix appearing in both QueueEmpty=10 and QueueFull=9; NEW in extra168: first standalone QueueEmpty.__name__ identity invariant in asyncioqex168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.QueueEmpty.__name__.__eq__
  args: ["QueueEmpty"]
  expected: true

invariant asyncio_extra168.asyncio_QueueFull_name_eq:
  description: "asyncio.QueueFull.__name__.__eq__('QueueFull') returns True — asyncio.QueueFull.__name__=='QueueFull' (len=9: 'Queue'=5+'Full'=4=9); asyncio.QueueFull is the exception raised by Queue.put_nowait(), LifoQueue.put_nowait(), and PriorityQueue.put_nowait() when the queue has reached its maxsize capacity (maxsize > 0); QueueFull inherits from Exception directly (QueueFull.__bases__[0].__name__=='Exception'); QueueFull is only relevant when the queue was created with a positive maxsize; an unbounded queue (maxsize=0) never raises QueueFull; compare: QueueFull(9) vs QueueEmpty(10) — QueueFull is 1 char shorter because 'Full'=4 < 'Empty'=5 by 1; compare: QueueFull(9)==LifoQueue(9) — both are 9-char names despite being unrelated classes ('Full'=4 suffix for QueueFull vs 'Lifo'=4 prefix for LifoQueue; both are 4-char affixes around 5-char 'Queue'); NEW in extra168: first standalone QueueFull.__name__ identity invariant in asyncioqex168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.QueueFull.__name__.__eq__
  args: ["QueueFull"]
