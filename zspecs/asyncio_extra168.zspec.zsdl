# asyncio.PriorityQueue.__name__.__eq__('PriorityQueue') == True
# asyncio.PriorityQueue.__bases__[0].__name__        == 'Queue'
# ---------------------------------------------------------------------------

table asyncio_extra168.asyncio_lifo_priority_queue_identity:
  description: "asyncio.LifoQueue and asyncio.PriorityQueue class name and base class identity checks in asynciolpq168 namespace — asyncio.LifoQueue.__name__.__eq__('LifoQueue')==True (LifoQueue.__name__=='LifoQueue' (len=9: 'Lifo'=4+'Queue'=5=9); asyncio.LifoQueue is a LIFO (Last In First Out) queue — it overrides Queue._get() to use list.pop() instead of list.popleft(); LifoQueue.__bases__[0].__name__=='Queue' (LifoQueue inherits from Queue directly; MRO: LifoQueue -> Queue -> _LoopBoundMixin -> object, len=4)); asyncio.PriorityQueue.__name__.__eq__('PriorityQueue')==True (PriorityQueue.__name__=='PriorityQueue' (len=13: 'Priority'=8+'Queue'=5=13); asyncio.PriorityQueue stores items in sorted order using heapq; the smallest item is always at the front; items should be comparable or be (priority_number, item) tuples; PriorityQueue.__bases__[0].__name__=='Queue' (PriorityQueue also inherits from Queue; MRO: PriorityQueue -> Queue -> _LoopBoundMixin -> object, len=4)); KEY: both LifoQueue(9) and PriorityQueue(13) inherit from Queue(5); LENGTH ORDERING: Queue(5) < LifoQueue(9) < PriorityQueue(13) in class name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolpq168

  columns: [id, function, args, expected, description]
  rows:
    - [lifo_name_eq,   asyncio.LifoQueue.__name__.__eq__,                  ["LifoQueue"],      true,  "LifoQueue.__name__ == 'LifoQueue' (len=9: 'Lifo'=4+'Queue'=5=9); verified with Python 3.14.3"]
    - [lifo_name_len,  asyncio.LifoQueue.__name__.__len__,                  [],                 9,     "LifoQueue.__name__.__len__() == 9 ('LifoQueue'=9; Queue=5+Lifo=4=9); verified with Python 3.14.3"]
    - [pq_name_eq,     asyncio.PriorityQueue.__name__.__eq__,               ["PriorityQueue"],  true,  "PriorityQueue.__name__ == 'PriorityQueue' (len=13: 'Priority'=8+'Queue'=5=13); verified with Python 3.14.3"]
    - [pq_name_len,    asyncio.PriorityQueue.__name__.__len__,              [],                 13,    "PriorityQueue.__name__.__len__() == 13 ('PriorityQueue'=13; longest queue name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
