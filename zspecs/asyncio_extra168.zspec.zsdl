spec: asyncio_extra168
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/mixins.py"
  notes:
    - "This spec covers: asyncio.Queue class name, module, and base class identity; asyncio.LifoQueue class name and base class; asyncio.PriorityQueue class name and base class; asyncio.QueueEmpty exception name, module, and base class; asyncio.QueueFull exception name, module, and base class. KEY FINDING: asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (NOT 'object'); Queue inherits from asyncio.mixins._LoopBoundMixin which provides the bound event-loop accessor; the MRO is Queue -> _LoopBoundMixin -> object (len=3). asyncio.QueueEmpty and asyncio.QueueFull both inherit from Exception directly. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5); asyncio.Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; 'queues'=6 matches 'events'=6 from Handle's module — both 6-char submodule names give the same total 14); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (KEY: len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15; the leading underscore indicates internal/private; _LoopBoundMixin provides loop-binding semantics; defined in asyncio.mixins). Verified with Python 3.14.3."
    - "asyncio.LifoQueue.__name__=='LifoQueue' (len=9: 'Lifo'=4+'Queue'=5=9); asyncio.LifoQueue.__bases__[0].__name__=='Queue' (inherits from Queue; LIFO = Last In First Out; uses a list as the internal container with list.append and list.pop); asyncio.PriorityQueue.__name__=='PriorityQueue' (len=13: 'Priority'=8+'Queue'=5=13); asyncio.PriorityQueue.__bases__[0].__name__=='Queue' (inherits from Queue; uses heapq internally; items must be comparable — typically (priority, item) tuples). Verified with Python 3.14.3."
    - "asyncio.QueueEmpty.__name__=='QueueEmpty' (len=10: 'Queue'=5+'Empty'=5=10); asyncio.QueueEmpty.__module__=='asyncio.queues' (len=14; same module as Queue, LifoQueue, PriorityQueue); asyncio.QueueEmpty.__bases__[0].__name__=='Exception' (QueueEmpty inherits from Exception — it is raised by Queue.get_nowait() and PriorityQueue.get_nowait() when the queue is empty); asyncio.QueueFull.__name__=='QueueFull' (len=9: 'Queue'=5+'Full'=4=9; 1 char shorter than QueueEmpty=10 because 'Full'=4 < 'Empty'=5); asyncio.QueueFull.__bases__[0].__name__=='Exception' (QueueFull also inherits from Exception; raised by Queue.put_nowait() when the queue is at maxsize). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue class identity — extra168
#
# asyncio.Queue.__name__.__eq__('Queue')               == True
# asyncio.Queue.__name__.__len__()                     == 5
# asyncio.Queue.__module__.__eq__('asyncio.queues')    == True
# asyncio.Queue.__module__.__len__()                   == 14
# ---------------------------------------------------------------------------

table asyncio_extra168.asyncio_queue_identity:
  description: "asyncio.Queue class name and module identity checks in asyncioq168 namespace — asyncio.Queue.__name__.__eq__('Queue')==True (Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5); asyncio.Queue is the async-safe FIFO queue for producer-consumer coordination in asyncio; Queue.put(item) blocks if the queue is at maxsize; Queue.get() blocks until an item is available; Queue.join() blocks until all items have been processed via task_done(); asyncio.Queue is used to coordinate coroutines — it is NOT thread-safe and must only be used within a single event loop); asyncio.Queue.__name__.__len__()==5 ('Queue'=5; compare: 'Task'=4 from extra166 is 1 shorter than Queue=5; 'Handle'=6 and 'Future'=6 from extra166 are 1 longer than Queue=5); asyncio.Queue.__module__.__eq__('asyncio.queues')==True (__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; 'queues'=6 matches 'events'=6 in asyncio.events module — both submodules have 6-char names giving the same 14-char full path)); asyncio.Queue.__module__.__len__()==14 (same length as asyncio.Handle.__module__.__len__()==14 from extra166); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioq168

  columns: [id, function, args, expected, description]
  rows:
    - [q_name_eq,  asyncio.Queue.__name__.__eq__,    ["Queue"],           true,  "Queue.__name__ == 'Queue' (len=5: 'Queue'=5; FIFO async-safe queue); verified with Python 3.14.3"]
    - [q_name_len, asyncio.Queue.__name__.__len__,   [],                  5,     "Queue.__name__.__len__() == 5 ('Queue'=5; Task=4 < Queue=5 < Handle=6=Future=6); verified with Python 3.14.3"]
    - [q_mod_eq,   asyncio.Queue.__module__.__eq__,  ["asyncio.queues"],  true,  "Queue.__module__ == 'asyncio.queues' (len=14; 'queues'=6 matches 'events'=6 in len); verified with Python 3.14.3"]
    - [q_mod_len,  asyncio.Queue.__module__.__len__, [],                  14,    "Queue.__module__.__len__() == 14 ('asyncio.queues'=14; same as asyncio.Handle module len=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Queue base class — extra168
#
# KEY: asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (NOT 'object')
# asyncio.Queue.__bases__[0].__name__.__len__() == 15
# asyncio.Queue.__mro__.__len__()               == 3
# ---------------------------------------------------------------------------

table asyncio_extra168.asyncio_queue_base_class:
  description: "asyncio.Queue base class checks in asyncioqbase168 namespace — KEY FINDING: asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Queue.__bases__ == (<class 'asyncio.mixins._LoopBoundMixin'>,); __bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); the leading underscore indicates internal/private; asyncio.Queue does NOT inherit from object directly — it inherits from _LoopBoundMixin which in turn inherits from object; _LoopBoundMixin (defined in asyncio.mixins) provides the _get_loop() accessor that binds a queue to the event loop running when the first waiter or item is added; this design replaced earlier explicit loop parameter passing); asyncio.Queue.__bases__[0].__name__.__len__()==15 ('_LoopBoundMixin'=15; compare: 'AbstractEventLoop'=17 from extra167 is 2 longer; '_AbstractEventLoopPolicy'=24 is 9 longer; '_LoopBoundMixin'=15 is the longest base class name so far for queue types); asyncio.Queue.__mro__.__len__()==3 (MRO: Queue -> _LoopBoundMixin -> object; 3 entries); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqbase168

  columns: [id, function, args, expected, description]
  rows:
    - [q_base_name_eq,  "asyncio.Queue.__bases__[0].__name__.__eq__",  ["_LoopBoundMixin"],  true,  "Queue.__bases__[0].__name__ == '_LoopBoundMixin' (NOT object; asyncio.mixins mixin class); verified with Python 3.14.3"]
    - [q_base_name_len, "asyncio.Queue.__bases__[0].__name__.__len__", [],                   15,    "Queue.__bases__[0].__name__.__len__() == 15 ('_LoopBoundMixin'=15: '_'=1+'LoopBoundMixin'=14=15); verified with Python 3.14.3"]
    - [q_mro_len,       asyncio.Queue.__mro__.__len__,                 [],                   3,     "Queue.__mro__.__len__() == 3 (Queue -> _LoopBoundMixin -> object; 3 entries); verified with Python 3.14.3"]
    - [q_name_len2,     asyncio.Queue.__name__.__len__,                [],                   5,     "Queue.__name__.__len__() == 5 (cross-check; 'Queue'=5); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.LifoQueue and asyncio.PriorityQueue identity — extra168
#
# asyncio.LifoQueue.__name__.__eq__('LifoQueue')     == True
