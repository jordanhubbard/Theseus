table asyncio_extra168.asyncio_lifo_priority_queue_bases:
  description: "asyncio.LifoQueue and asyncio.PriorityQueue base class and MRO length checks in asynciolpqbase168 namespace — asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue')==True (LifoQueue.__bases__[0].__name__=='Queue' (len=5); LifoQueue inherits from Queue; the MRO is LifoQueue -> Queue -> _LoopBoundMixin -> object (len=4)); asyncio.LifoQueue.__mro__.__len__()==4 (4 entries: LifoQueue, Queue, _LoopBoundMixin, object; one more than Queue's MRO len=3 because LifoQueue adds itself at the top); asyncio.PriorityQueue.__bases__[0].__name__.__eq__('Queue')==True (PriorityQueue.__bases__[0].__name__=='Queue' (len=5); PriorityQueue inherits from Queue; the MRO is PriorityQueue -> Queue -> _LoopBoundMixin -> object (len=4)); asyncio.PriorityQueue.__mro__.__len__()==4 (same 4-entry MRO as LifoQueue; both subclass Queue adding themselves at the top); KEY: both LifoQueue and PriorityQueue have MRO len=4 (Queue MRO=3 + 1 extra for the subclass itself); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolpqbase168

  columns: [id, function, args, expected, description]
  rows:
    - [lifo_base_name_eq,  "asyncio.LifoQueue.__bases__[0].__name__.__eq__",      ["Queue"],  true,  "LifoQueue.__bases__[0].__name__ == 'Queue' (inherits from Queue; MRO len=4); verified with Python 3.14.3"]
    - [lifo_mro_len,       asyncio.LifoQueue.__mro__.__len__,                      [],         4,     "LifoQueue.__mro__.__len__() == 4 (LifoQueue->Queue->_LoopBoundMixin->object); verified with Python 3.14.3"]
    - [pq_base_name_eq,    "asyncio.PriorityQueue.__bases__[0].__name__.__eq__",   ["Queue"],  true,  "PriorityQueue.__bases__[0].__name__ == 'Queue' (inherits from Queue; MRO len=4); verified with Python 3.14.3"]
    - [pq_mro_len,         asyncio.PriorityQueue.__mro__.__len__,                  [],         4,     "PriorityQueue.__mro__.__len__() == 4 (PriorityQueue->Queue->_LoopBoundMixin->object); verified with Python 3.14.3"]

