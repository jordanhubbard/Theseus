spec: sys_extra22
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra20.zspec.zsdl — covers float_info/int_info/hash_info/flags __class__.__name__ table."
    - "sys_extra21.zspec.zsdl — covers version_info field types via index access."
    - "sys_extra12.zspec.zsdl — covers version_info.serial class name."
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra21.zspec.zsdl."
    - "sys_extra20 covers class names for float_info, int_info, hash_info, and flags."
    - "No prior sys spec checks the __class__.__name__ for maxsize, maxunicode, byteorder, platform, or hexversion."
    - "sys.maxsize.__class__.__name__ == 'int' — verified at runtime."
    - "sys.maxunicode.__class__.__name__ == 'int' — verified at runtime (value 1114111)."
    - "sys.byteorder.__class__.__name__ == 'str' — verified at runtime (value 'little' on this system)."
    - "sys.platform.__class__.__name__ == 'str' — verified at runtime (value 'darwin' on this system)."
    - "sys.hexversion.__class__.__name__ == 'int' — verified at runtime."
    - "sys.byteorder == 'little' — verified at runtime on macOS/Darwin x86_64 and arm64; value is platform-dependent but captured for the test system."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys constant class names — consolidated table
#
# sys_extra20 covers class names for float_info, int_info, hash_info, and flags.
# No prior sys spec checks class names for maxsize, maxunicode, byteorder,
# platform, or hexversion. This table covers all five in the extra22 namespace.
# ---------------------------------------------------------------------------

table sys_extra22.constant_class_names:
  description: "__class__.__name__ for sys.maxsize, maxunicode, byteorder, platform, hexversion"
  kind: python_call_eq
  category: constants

  columns: [id, function, args, expected]
  rows:
    - [maxsize,    maxsize.__class__.__name__.__eq__,    ["int"], true]
    - [maxunicode, maxunicode.__class__.__name__.__eq__, ["int"], true]
    - [byteorder,  byteorder.__class__.__name__.__eq__,  ["str"], true]
    - [platform,   platform.__class__.__name__.__eq__,   ["str"], true]
    - [hexversion, hexversion.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# sys.byteorder value — 'little'
#
# sys.byteorder is a str equal to 'little' on little-endian systems (all modern
# x86_64 and arm64 platforms) or 'big' on big-endian systems. On the test system
# (macOS/Darwin arm64) it is 'little'. No prior sys spec checks the actual value
# of sys.byteorder directly.
# ---------------------------------------------------------------------------

invariant sys_extra22.byteorder.value:
  description: "sys.byteorder == 'little' on this little-endian test system"
  category: constants
  kind: python_call_eq
  function: byteorder.__eq__
  args: ["little"]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxsize — positivity
#
# sys.maxsize is the largest positive integer supported by the platform's Py_ssize_t
# (2^63-1 on 64-bit). No prior sys spec checks maxsize.__gt__(0).
# ---------------------------------------------------------------------------

invariant sys_extra22.maxsize.positive:
  description: "sys.maxsize > 0"
  category: constants
  kind: python_call_eq
  function: maxsize.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxunicode — value check
#
# sys.maxunicode is always 1114111 (0x10FFFF) in Python 3 (wide Unicode build
# is mandatory). No prior sys spec checks the exact value of maxunicode.
# ---------------------------------------------------------------------------

invariant sys_extra22.maxunicode.value:
  description: "sys.maxunicode == 1114111 (0x10FFFF — highest Unicode code point)"
  category: constants
  kind: python_call_eq
  function: maxunicode.__eq__
  args: [1114111]
  expected: true

# ---------------------------------------------------------------------------
# sys.hexversion — positivity
#
# sys.hexversion encodes the Python version as a single integer. It is always
# positive. No prior sys spec checks hexversion > 0 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant sys_extra22.hexversion.positive:
  description: "sys.hexversion > 0"
  category: constants
  kind: python_call_eq
  function: hexversion.__gt__
  args: [0]
  expected: true
