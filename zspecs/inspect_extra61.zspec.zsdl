spec: inspect_extra61
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra60.zspec.zsdl."
    - "Wave 227 theme: class method __qualname__ equality checks — full string equality for methods not yet covered."
    - "inspect.Parameter and inspect.Signature method qualnames covered by __eq__ in prior specs (extra23): Parameter.__repr__/__eq__/__init__/replace, Signature.__eq__/__init__/replace. Wave 227 focuses on methods NOT yet covered by __eq__: BoundArguments.__init__/__repr__/apply_defaults/__eq__, and Signature.bind/bind_partial."
    - "inspect.BoundArguments is a pure-Python class (Lib/inspect.py). Its methods are plain Python functions with qualnames following the 'BoundArguments.method_name' pattern. BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__' (23 chars); BoundArguments.__repr__.__qualname__ == 'BoundArguments.__repr__' (23 chars); BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' (29 chars); BoundArguments.__eq__.__qualname__ == 'BoundArguments.__eq__' (21 chars). Prior specs covered __len__ values (extra30/extra37) but NO prior inspect spec checks these by __eq__."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' (14 chars); Signature.bind_partial.__qualname__ == 'Signature.bind_partial' (22 chars). Prior specs covered __len__ values (extra37) but NO prior inspect spec checks these by __eq__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BoundArguments method __qualname__.__eq__ checks — extra61
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# inspect.BoundArguments is a pure-Python class (Lib/inspect.py).
# Its methods are plain Python functions with qualnames:
#   BoundArguments.__init__.__qualname__   == 'BoundArguments.__init__'    (23)
#   BoundArguments.__repr__.__qualname__   == 'BoundArguments.__repr__'    (23)
#   BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' (29)
#   BoundArguments.__eq__.__qualname__     == 'BoundArguments.__eq__'      (21)
#
# Prior specs covered:
# - BoundArguments.__init__.__qualname__.__len__() == 23 (extra30/extra37)
# - BoundArguments.__repr__.__qualname__.__len__() == 23 (extra30)
# - BoundArguments.apply_defaults.__qualname__.__len__() == 29 (extra37)
# But NO prior inspect spec has checked these by __eq__. New to extra61.
# ---------------------------------------------------------------------------

table inspect_extra61.bound_arguments_method_qualnames:
  description: "BoundArguments method __qualname__.__eq__ checks — __init__/repr/apply_defaults/__eq__; __len__ covered in extra30/37 but __eq__ not yet done; wave 227 method qualname equality; new to extra61"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: inspqual61

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_init_qualname_eq,
       BoundArguments.__init__.__qualname__.__eq__,
       ["BoundArguments.__init__"],
       true,
       "inspect.BoundArguments.__init__.__qualname__.__eq__('BoundArguments.__init__') == True — BoundArguments is a pure-Python class in Lib/inspect.py that holds the result of Signature.bind(); its __init__ is a plain Python function; the qualname follows the 'ClassName.method_name' pattern; 'BoundArguments.__init__' is 23 chars (15-char 'BoundArguments.' prefix + 8-char '__init__'); extra30 and extra37 confirmed __qualname__.__len__()==23 but no prior inspect spec checks __qualname__.__eq__('BoundArguments.__init__'); new to extra61"]
    - [bound_arguments_repr_qualname_eq,
       BoundArguments.__repr__.__qualname__.__eq__,
       ["BoundArguments.__repr__"],
       true,
       "inspect.BoundArguments.__repr__.__qualname__.__eq__('BoundArguments.__repr__') == True — BoundArguments.__repr__ is a pure-Python function that provides a human-readable string representation of the bound arguments; its qualname is 'BoundArguments.__repr__' (23 chars = 15-char prefix + 8-char '__repr__'); same length as BoundArguments.__init__ because both have 8-char dunder method names; extra30 confirmed __qualname__.__len__()==23 but no prior inspect spec checks __qualname__.__eq__('BoundArguments.__repr__'); new to extra61"]
    - [bound_arguments_apply_defaults_qualname_eq,
       BoundArguments.apply_defaults.__qualname__.__eq__,
       ["BoundArguments.apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — BoundArguments.apply_defaults is a pure-Python method that fills in default parameter values for any parameters not yet bound; its qualname is 'BoundArguments.apply_defaults' (29 chars = 15-char prefix + 14-char 'apply_defaults'); this is the longest qualname among the core Signature-related classes (Parameter/Signature/BoundArguments) recorded by any prior spec; extra37 confirmed __qualname__.__len__()==29 but no prior inspect spec checks __qualname__.__eq__('BoundArguments.apply_defaults'); new to extra61"]
    - [bound_arguments_eq_qualname_eq,
       BoundArguments.__eq__.__qualname__.__eq__,
       ["BoundArguments.__eq__"],
       true,
       "inspect.BoundArguments.__eq__.__qualname__.__eq__('BoundArguments.__eq__') == True — BoundArguments.__eq__ is a pure-Python method implementing equality comparison between two BoundArguments instances; its qualname is 'BoundArguments.__eq__' (21 chars = 15-char prefix + 6-char '__eq__'); the 6-char '__eq__' makes this the shortest dunder name among the methods checked here; no prior inspect spec has checked BoundArguments.__eq__.__qualname__.__eq__; new to extra61"]

# ---------------------------------------------------------------------------
# Signature.bind and bind_partial __qualname__.__eq__ checks — extra61
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# inspect.Signature.bind.__qualname__ == 'Signature.bind' (14 chars)
# inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial' (22 chars)
#
# Prior specs covered:
# - Signature.bind.__qualname__.__len__() == 14 (extra37)
# - Signature.bind_partial.__qualname__.__len__() == 22 (extra37)
# But NO prior inspect spec checks these by __eq__. New to extra61.
# ---------------------------------------------------------------------------

table inspect_extra61.signature_bind_qualnames:
  description: "Signature.bind/__bind_partial __qualname__.__eq__ — __len__ covered in extra37 but __eq__ not yet done; wave 227 method qualname equality; new to extra61"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: inspqual61

  columns: [id, function, args, expected, description]
  rows:
    - [signature_bind_qualname_eq,
       Signature.bind.__qualname__.__eq__,
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — Signature.bind is the primary method for matching positional and keyword arguments to a function's parameters, returning a BoundArguments instance; its qualname is 'Signature.bind' (14 chars = 10-char 'Signature.' prefix + 4-char 'bind'); 'bind' is the shortest method name among Signature's bind-related methods; extra37 confirmed __qualname__.__len__()==14 but no prior inspect spec checks __qualname__.__eq__('Signature.bind'); new to extra61"]
    - [signature_bind_partial_qualname_eq,
       Signature.bind_partial.__qualname__.__eq__,
       ["Signature.bind_partial"],
       true,
       "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — Signature.bind_partial works like Signature.bind but allows omitting required arguments (useful for partial application); its qualname is 'Signature.bind_partial' (22 chars = 10-char 'Signature.' prefix + 12-char 'bind_partial'); extra37 confirmed __qualname__.__len__()==22 but no prior inspect spec checks __qualname__.__eq__('Signature.bind_partial'); new to extra61"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant inspect_extra61.bound_arguments_init_qualname_eq:
  description: "inspect.BoundArguments.__init__.__qualname__.__eq__('BoundArguments.__init__') == True — pure-Python method; qualname 23 chars; extra37 checked __len__; wave 227 adds __eq__; new to extra61"
  kind: python_call_eq
  function: BoundArguments.__init__.__qualname__.__eq__
  args: ["BoundArguments.__init__"]
  expected: true

invariant inspect_extra61.bound_arguments_apply_defaults_qualname_eq:
  description: "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — qualname 29 chars, longest in core Signature-related classes; extra37 checked __len__; wave 227 adds __eq__; new to extra61"
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__qualname__.__eq__
  args: ["BoundArguments.apply_defaults"]
  expected: true

invariant inspect_extra61.signature_bind_partial_qualname_eq:
  description: "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — qualname 22 chars; extra37 checked __len__; wave 227 adds __eq__; new to extra61"
  kind: python_call_eq
  function: Signature.bind_partial.__qualname__.__eq__
  args: ["Signature.bind_partial"]
  expected: true
