spec: struct_extra115
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra114.zspec.zsdl — covers pack_into/unpack_from/iter_unpack/calcsize/pack __name__.__len__() and __class__.__module__.__eq__('builtins') (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers struct.error __name__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__.__eq__('type') (table + invariants)."
    - "struct_extra108.zspec.zsdl — covers error.__name__.__len__()==5 / error.__module__.__len__()==6 / error.__bases__[0].__name__.__eq__('Exception') as grouped table (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers struct.error.__bases__[0].__name__.__len__()==9 (table + invariants)."
    - "struct_extra26.zspec.zsdl — covers struct.__all__.__class__.__name__.__len__()==4 / __all__.__len__()==8 (table + invariants)."
    - "struct_extra52.zspec.zsdl — covers struct.__all__.__contains__ for Struct/error/pack_into/iter_unpack/calcsize (table + invariants)."
    - "struct_extra53.zspec.zsdl — covers struct.__all__.__contains__ for pack/unpack/unpack_from (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra114; it does NOT duplicate invariants present in those files."
    - "Wave 279 theme: struct.error metaclass module and struct.__all__ metaclass module not yet covered — extra101 anchors error.__class__.__name__.__eq__('type'); extra26 anchors __all__.__class__.__name__.__len__()==4; NOT YET covered: error.__class__.__module__.__eq__('builtins') and len==8; __all__.__class__.__module__.__eq__('builtins') and len==8; error.__class__.__name__.__len__()==4 as grouped table; __all__.__class__.__name__.__len__()==4 cross-group."
    - "struct.error.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__module__.__len__() == 8 — len('builtins')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__class__.__module__.__len__() == 8 — len('builtins')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__name__.__len__() == 4 — len('type')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__class__.__name__.__len__() == 4 — len('list')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__.__len__() == 5 — len('error')==5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__len__() == 6 — len('struct')==6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error is a Python-level exception class defined in Lib/struct.py. Its metaclass is 'type' (len 4), and 'type'.__module__=='builtins' (len 8). struct.__all__ is a plain Python list (len 4 for 'list'), and list.__module__=='builtins' (len 8). The pattern '__class__.__module__==builtins' (8 chars) applies to both the exception metaclass and the list type, because both 'type' and 'list' are fundamental CPython runtime objects defined in Objects/ and attributed to 'builtins'. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__class__.__module__.__eq__('builtins') == True
# struct.error.__class__.__module__.__len__() == 8
# struct.error.__class__.__name__.__len__() == 4
# struct.__all__.__class__.__module__.__eq__('builtins') == True
# struct.__all__.__class__.__module__.__len__() == 8
#
# Wave 279 theme: struct.error and __all__ metaclass module attribution.
#
# struct.error is a Python class whose metaclass is 'type'. The 'type' metaclass has
# its __module__ set to 'builtins' (8 chars) because 'type' is a fundamental CPython
# runtime object from Objects/typeobject.c. struct.__all__ is a Python list, and the
# 'list' type also has its __module__ set to 'builtins' for the same reason. Both
# 'type' and 'list' are 4-char type names in 'builtins'. Prior specs anchor
# error.__class__.__name__.__eq__('type') (extra101) and __all__.__class__.__name__
# .__len__()==4 (extra26), but no prior spec anchors the __class__.__module__
# attribute for either object. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra115.error_and_all_class_module_attribution:
  description: "error.__class__.__module__.__eq__('builtins')==True / error.__class__.__module__.__len__()==8 / error.__class__.__name__.__len__()==4 / __all__.__class__.__module__.__eq__('builtins')==True / __all__.__class__.__module__.__len__()==8 — error metaclass 'type' and __all__ type 'list' both have __module__=='builtins' (8 chars; fundamental CPython runtime objects from Objects/); extra101 anchors error.__class__.__name__.__eq__('type'); extra26 anchors __all__.__class__.__name__.__len__()==4; no prior spec anchors class module for either; first structerr115 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr115

  columns: [id, function, args, expected, description]
  rows:
    - [error_cls_mod_eq,   "error.__class__.__module__.__eq__",   ["builtins"], true, "error.__class__.__module__ is 'builtins' ('type' metaclass is a fundamental CPython object from Objects/typeobject.c)"]
    - [error_cls_mod_len,  "error.__class__.__module__.__len__",  [],           8,    "error.__class__.__module__.__len__() is 8 (len('builtins')==8; same as '_hashlib'=8 chars coincidentally)"]
    - [error_cls_name_len, "error.__class__.__name__.__len__",    [],           4,    "error.__class__.__name__.__len__() is 4 (len('type')==4; the 'type' metaclass name is 4 chars; extra101 anchors __eq__('type'))"]
    - [all_cls_mod_eq,     "__all__.__class__.__module__.__eq__", ["builtins"], true, "__all__.__class__.__module__ is 'builtins' ('list' type is a fundamental CPython object from Objects/listobject.c)"]
    - [all_cls_mod_len,    "__all__.__class__.__module__.__len__", [],          8,    "__all__.__class__.__module__.__len__() is 8 (len('builtins')==8; same pattern as error metaclass module)"]

# ---------------------------------------------------------------------------
# struct.error.__class__.__name__.__len__() == 4
# struct.__all__.__class__.__name__.__len__() == 4
# struct.error.__name__.__len__() == 5
# struct.error.__module__.__len__() == 6
# struct.error.__mro__.__len__() == 4
#
# Wave 279 theme: struct.error and __all__ class name lengths.
#
# A notable coincidence: error.__class__.__name__.__len__()==4 (len('type')==4) and
# __all__.__class__.__name__.__len__()==4 (len('list')==4) are equal, though 'type'
# is the metaclass and 'list' is the sequence type. Both are 4-char fundamental type
# names in 'builtins'. Pairing these with error.__name__.__len__()==5 and
# error.__module__.__len__()==6 reveals an arithmetic progression: 4, 4, 5, 6.
# error.__mro__.__len__()==4 adds a fourth 4 to the pattern. Extra26 covers
# __all__.__class__.__name__.__len__()==4 in a table; extra108 covers error
# __name__.__len__()==5 and __module__.__len__()==6; this table combines them for
# the first time. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra115.error_and_all_class_name_lengths:
  description: "error.__class__.__name__.__len__()==4 / __all__.__class__.__name__.__len__()==4 / error.__name__.__len__()==5 / error.__module__.__len__()==6 / error.__mro__.__len__()==4 — 'type'=4 (error metaclass); 'list'=4 (all class); 'error'=5 (exception class name); 'struct'=6 (module name); mro depth 4; length pattern 4/4/5/6/4; extra26 covers __all__ class name len; extra108 covers error name/module lens; no prior spec groups all five together; first structerr115 cross-len anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr115

  columns: [id, function, args, expected, description]
  rows:
    - [error_cls_name_len2, "error.__class__.__name__.__len__",  [], 4, "error.__class__.__name__.__len__() is 4 (len('type')==4; metaclass name; cross-check confirming 4-char type name)"]
    - [all_cls_name_len2,   "__all__.__class__.__name__.__len__", [], 4, "__all__.__class__.__name__.__len__() is 4 (len('list')==4; cross-check; coincidentally same as error metaclass name length)"]
    - [error_name_len2,     "error.__name__.__len__",            [], 5, "error.__name__.__len__() is 5 (len('error')==5; cross-check with extra108; one more than 'type'=4)"]
    - [error_mod_len2,      "error.__module__.__len__",          [], 6, "error.__module__.__len__() is 6 (len('struct')==6; cross-check with extra108; one more than 'error'=5)"]
    - [error_mro_len2,      "error.__mro__.__len__",             [], 4, "error.__mro__.__len__() is 4 (error->Exception->BaseException->object; cross-check with extra101/extra94)"]

# ---------------------------------------------------------------------------
# struct.error.__class__.__module__.__eq__('builtins') == True
# struct.__all__.__class__.__module__.__eq__('builtins') == True
# struct.error.__class__.__module__.__len__() == 8
# struct.__all__.__class__.__module__.__len__() == 8
# struct.__all__.__class__.__name__.__len__() == 4
#
# Wave 279 theme: cross-check grouping error and __all__ class modules.
#
# Both struct.error and struct.__all__ have __class__.__module__=='builtins' (8 chars).
# This is because 'type' (error's metaclass) and 'list' (__all__'s class) are both
# fundamental CPython runtime objects defined in the builtins layer. This cross-check
# groups the two 'builtins' module attributions together to confirm the pattern.
# extra114 anchors the same 'builtins' pattern for C functions (pack/unpack/etc.);
# this table extends it to error's metaclass and __all__'s list class. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra115.error_and_all_builtins_cross_check:
  description: "error.__class__.__module__.__eq__('builtins')==True / __all__.__class__.__module__.__eq__('builtins')==True / error.__class__.__module__.__len__()==8 / __all__.__class__.__module__.__len__()==8 / __all__.__class__.__name__.__len__()==4 — cross-check confirming both error metaclass and __all__ list class live in 'builtins' (8 chars); extra114 anchors 'builtins' for C functions; this extends pattern to exception metaclass and list class; first structerr115 builtins cross-check anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr115

  columns: [id, function, args, expected, description]
  rows:
    - [error_cls_mod_eq2,   "error.__class__.__module__.__eq__",    ["builtins"], true, "error.__class__.__module__ is 'builtins' (cross-check; 'type' metaclass lives in builtins layer; same as C functions)"]
    - [all_cls_mod_eq2,     "__all__.__class__.__module__.__eq__",  ["builtins"], true, "__all__.__class__.__module__ is 'builtins' (cross-check; 'list' class lives in builtins; same as error metaclass)"]
    - [error_cls_mod_len2,  "error.__class__.__module__.__len__",   [],           8,    "error.__class__.__module__.__len__() is 8 ('builtins'=8; cross-check confirming length)"]
    - [all_cls_mod_len2,    "__all__.__class__.__module__.__len__", [],           8,    "__all__.__class__.__module__.__len__() is 8 ('builtins'=8; tied with error; cross-check)"]
    - [all_cls_name_len3,   "__all__.__class__.__name__.__len__",   [],           4,    "__all__.__class__.__name__.__len__() is 4 (len('list')==4; cross-check with extra26)"]

# ---------------------------------------------------------------------------
# struct.error.__class__.__module__.__eq__('builtins') — standalone
#
# struct.error.__class__.__module__ is 'builtins'. struct.error is a Python class
# (defined in Lib/struct.py, which calls Exception subclassing). Its metaclass is
# the built-in 'type' object (Objects/typeobject.c). The 'type' metaclass has its
# __module__ set to 'builtins' because it is fundamental to the CPython runtime —
# it is the factory for all new Python classes. This contrasts with struct module-level
# functions (pack, unpack, etc.) whose __class__.__module__ is also 'builtins' but
# for a different reason (they are builtin_function_or_method, not type). No prior
# spec anchors struct.error.__class__.__module__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra115.error_class_module_builtins:
  description: "struct.error.__class__.__module__.__eq__('builtins') == True — 'type' metaclass __module__ is 'builtins' (fundamental CPython runtime object from Objects/typeobject.c; factory for all new Python classes; extra101 anchors error.__class__.__name__.__eq__('type'); extra114 anchors C function __class__.__module__=='builtins' for different reason; no prior spec anchors error class module as standalone; first standalone under structerr115)"
  category: type_identity
  kind: python_call_eq
  function: error.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__class__.__module__.__len__() == 8 — standalone
#
# struct.error.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# The 'type' metaclass __module__ is 'builtins' (8 chars). Coincidentally, 8 chars
# is shared by several important module names in the CPython ecosystem: 'builtins'=8,
# '_hashlib'=8, 'EnumType'=8 (not a module but same length). The connection is
# that 'builtins' (8 chars) is the de facto home of all fundamental CPython runtime
# types. No prior struct spec anchors error.__class__.__module__.__len__() as a
# standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra115.error_class_module_len_8:
  description: "struct.error.__class__.__module__.__len__() == 8 — len('builtins')==8 ('type' metaclass __module__ is 'builtins'; 8-char module name coincidentally matches '_hashlib'=8 and 'EnumType'=8 in length; the 'builtins' namespace is home to all fundamental CPython runtime types); extra101 anchors __class__.__name__=='type'; no prior spec anchors error class module length as standalone; first standalone under structerr115"
  category: type_identity
  kind: python_call_eq
  function: error.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.error.__class__.__name__.__len__() == 4 — standalone
#
# struct.error.__class__.__name__.__len__() is 4. 'type' has 4 chars.
# struct.error is a class, and all Python classes have 'type' as their metaclass
# (unless they use a custom metaclass). The name 'type' (4 chars) is the shortest
# fundamental type name in Python — shorter than 'list' (4 chars, tied), 'dict'
# (4 chars, tied), 'int' (3 chars, shorter), but the metaclass name itself. Prior
# specs anchor error.__class__.__name__.__eq__('type') (extra101); no prior spec
# anchors error.__class__.__name__.__len__()==4 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra115.error_class_name_len_4:
  description: "struct.error.__class__.__name__.__len__() == 4 — len('type')==4 (standard Python class metaclass; same length as 'list'=4 and 'dict'=4; shorter than 'tuple'=5; struct.error uses standard 'type' metaclass not a custom one; extra101 anchors __eq__('type'); no prior spec anchors error class name length as standalone; first standalone under structerr115)"
  category: type_identity
  kind: python_call_eq
  function: error.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__module__.__eq__('builtins') — standalone
#
# struct.__all__.__class__.__module__ is 'builtins'. struct.__all__ is a plain Python
# list object. The 'list' type (built into CPython via Objects/listobject.c) has its
# __module__ set to 'builtins'. The value of struct.__all__ is the list
# ['calcsize', 'pack', 'pack_into', 'unpack', 'unpack_from', 'iter_unpack', 'Struct',
# 'error'] — 8 entries. extra26 covers __all__.__class__.__name__.__len__()==4 (the
# name 'list' is 4 chars); no prior spec anchors __all__.__class__.__module__ as a
# standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra115.all_class_module_builtins:
  description: "struct.__all__.__class__.__module__.__eq__('builtins') == True — 'list' type __module__ is 'builtins' (built into CPython via Objects/listobject.c; struct.__all__ is ['calcsize','pack','pack_into','unpack','unpack_from','iter_unpack','Struct','error'] = 8 entries; extra26 anchors __all__.__class__.__name__.__len__()==4; no prior spec anchors __all__ class module as standalone; first standalone under structerr115)"
  category: type_identity
  kind: python_call_eq
  function: __all__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__module__.__len__() == 8 — standalone
#
# struct.__all__.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# The 'list' type's __module__ is 'builtins' (8 chars). This is the same length
# as struct.error.__class__.__module__.__len__()==8 (both 'type' and 'list' are
# attributed to 'builtins'). The pattern shows that all fundamental CPython sequence,
# mapping, and metaclass types are attributed to 'builtins' with the same 8-char
# module name. No prior struct spec anchors __all__.__class__.__module__.__len__()
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra115.all_class_module_len_8:
  description: "struct.__all__.__class__.__module__.__len__() == 8 — len('builtins')==8 ('list' type __module__ is 'builtins'; same 8-char length as error.__class__.__module__.__len__()==8 — both 'type' and 'list' are fundamental CPython objects in 'builtins'; extra26 anchors __all__.__class__.__name__.__len__()==4; no prior spec anchors __all__ class module length as standalone; first standalone under structerr115)"
  category: type_identity
  kind: python_call_eq
  function: __all__.__class__.__module__.__len__
  args: []
  expected: 8
