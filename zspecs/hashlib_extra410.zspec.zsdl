spec: hashlib_extra410
version: ">=3.9"
backend: python_module(_hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "_hashlib.HASH.digest_size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.block_size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.name.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: _hashlib.HASH is the C extension type returned by hashlib.new() for OpenSSL-backed algorithms. Its per-instance attributes (digest_size, block_size, name) are exposed as getset_descriptor objects on the class — the standard C-level mechanism for computed attributes. hashlib.sha256 is a builtin_function_or_method whose __name__ carries the 'openssl_' prefix, distinguishing it from pure-Python or BLAKE2 constructors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH descriptor types: digest_size, block_size, name
#
# Wave 410 theme: _hashlib.HASH class-level descriptor identity.
#
# _hashlib.HASH is the C extension type returned by hashlib.new() for all
# OpenSSL-backed algorithms (sha256, sha512, md5, etc.). Its per-instance
# readable attributes (digest_size, block_size, name) are implemented as
# C-level getset descriptors. When accessed on the class rather than an
# instance, Python returns the descriptor object itself. The descriptor's
# __class__.__name__ is 'getset_descriptor' — the standard CPython type
# for C slots exposed via PyGetSetDef.
#
# Covered attributes:
#   digest_size — number of bytes in the final digest
#   block_size  — internal block size in bytes (for HMAC construction)
#   name        — canonical algorithm name string
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra410.hash_descriptor_types:
  description: "_hashlib.HASH.digest_size, block_size, name are getset_descriptor objects — these C-level computed attributes use PyGetSetDef and appear as getset_descriptor when accessed on the class; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibhd410

  columns: [id, function, args, expected]
  rows:
    - [digest_size_class,  HASH.digest_size.__class__.__name__.__eq__,  ["getset_descriptor"],  true]
    - [block_size_class,   HASH.block_size.__class__.__name__.__eq__,   ["getset_descriptor"],  true]
    - [name_class,         HASH.name.__class__.__name__.__eq__,         ["getset_descriptor"],  true]

# ---------------------------------------------------------------------------
# hashlib.sha256 constructor identity
#
# hashlib.sha256 is the OpenSSL-backed SHA-256 constructor exposed directly
# on the hashlib namespace. It is a builtin_function_or_method (not a type
# like blake2b/blake2s). Its __name__ carries the 'openssl_' prefix used
# internally by the _hashlib C extension. Its __module__ is '_hashlib',
# confirming it originates from the C extension rather than pure Python.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra410.sha256_dunder_name:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — the OpenSSL-backed sha256 constructor carries an 'openssl_' prefix in its __name__, unlike BLAKE2 types which use bare names; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra410.sha256_type_name:
  description: "type(hashlib.sha256).__name__.__eq__('builtin_function_or_method') == True — hashlib.sha256 is a builtin_function_or_method rather than a type, distinguishing OpenSSL constructors from the BLAKE2 class objects; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: sha256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra410.sha256_module:
  description: "hashlib.sha256.__module__.__eq__('_hashlib') == True — the sha256 constructor belongs to the _hashlib C extension module, not the pure-Python hashlib wrapper; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true
