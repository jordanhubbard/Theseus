spec: traceback_extra28
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
    - "traceback_extra27.zspec.zsdl — covers TracebackException/StackSummary/FrameSummary __qualname__.__len__(); module-level function __qualname__.__len__() for print_tb/format_tb/print_stack/format_stack/extract_tb/extract_stack; TracebackException.from_exception.__qualname__.__len__()==33."
    - "traceback_extra26.zspec.zsdl — covers __all__.__len__()==20; __all__.__class__.__name__.__len__()==4; TracebackException/StackSummary/FrameSummary __dict__.__class__.__name__.__len__()==12; walk_stack/walk_tb/clear_frames/format_exception/print_exception __qualname__.__len__()."
    - "traceback_extra25.zspec.zsdl — covers __mro__.__len__() for TracebackException/StackSummary/FrameSummary; __bases__[0].__name__.__len__() for all three; FrameSummary method __qualname__.__len__(); TracebackException.__init__ __qualname__.__len__()==27."
  notes:
    - "This spec extends traceback_extra27.zspec.zsdl."
    - "Prior specs covered: TracebackException/StackSummary/FrameSummary __mro__/__bases__/__dict__/__qualname__, method __qualname__.__len__() for TracebackException/StackSummary/FrameSummary methods, module-level function __name__/__qualname__ lengths."
    - "This spec covers NEW angles: class __name__.__len__() for TracebackException(18)/StackSummary(12)/FrameSummary(12); __mro__.__len__() for TracebackException(2)/StackSummary(3)/FrameSummary(2) as standalone invariants; __bases__[0].__name__.__len__() for TracebackException(6)/StackSummary(4); TracebackException.from_exception.__name__.__len__()==14."
    - "traceback.TracebackException.__name__ == 'TracebackException' (len 18). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.__name__ == 'StackSummary' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.__name__ == 'FrameSummary' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.__mro__.__len__() == 2 — MRO: [TracebackException, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.__mro__.__len__() == 3 — MRO: [StackSummary, list, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.__mro__.__len__() == 2 — MRO: [FrameSummary, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.__bases__[0].__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.from_exception.__name__ == 'from_exception' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback class __name__.__len__() for TracebackException, StackSummary,
# FrameSummary
#
# Prior specs checked __qualname__.__len__() for these classes (extra27) but
# not __name__.__len__(). Both __name__ and __qualname__ equal the simple class
# name for top-level classes, so the values match: 18, 12, 12.
# ---------------------------------------------------------------------------

invariant traceback_extra28.TracebackException.name.len:
  description: "traceback.TracebackException.__name__.__len__() == 18 — 'TracebackException' has 18 characters"
  category: class_identity
  kind: python_call_eq
  function: TracebackException.__name__.__len__
  args: []
  expected: 18

invariant traceback_extra28.StackSummary.name.len:
  description: "traceback.StackSummary.__name__.__len__() == 12 — 'StackSummary' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: StackSummary.__name__.__len__
  args: []
  expected: 12

invariant traceback_extra28.FrameSummary.name.len:
  description: "traceback.FrameSummary.__name__.__len__() == 12 — 'FrameSummary' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: FrameSummary.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# traceback class __mro__.__len__() as standalone invariants
#
# extra25 covered __mro__.__len__() for these three classes in a table. These
# standalone invariants record the same facts with individual invariant IDs
# for direct reference. TracebackException inherits only from object (depth 2);
# StackSummary inherits from list then object (depth 3); FrameSummary inherits
# only from object (depth 2).
# ---------------------------------------------------------------------------

invariant traceback_extra28.TracebackException.mro.len:
  description: "traceback.TracebackException.__mro__.__len__() == 2 — MRO: [TracebackException, object]"
  category: class_introspection
  kind: python_call_eq
  function: TracebackException.__mro__.__len__
  args: []
  expected: 2

invariant traceback_extra28.StackSummary.mro.len:
  description: "traceback.StackSummary.__mro__.__len__() == 3 — MRO: [StackSummary, list, object]"
  category: class_introspection
  kind: python_call_eq
  function: StackSummary.__mro__.__len__
  args: []
  expected: 3

invariant traceback_extra28.FrameSummary.mro.len:
  description: "traceback.FrameSummary.__mro__.__len__() == 2 — MRO: [FrameSummary, object]"
  category: class_introspection
  kind: python_call_eq
  function: FrameSummary.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# traceback class __bases__[0].__name__.__len__()
#
# TracebackException.__bases__[0] is object (len 6).
# StackSummary.__bases__[0] is list (len 4) — StackSummary extends list.
# FrameSummary.__bases__[0] is object — covered via the mro note; here we
# record the TracebackException and StackSummary base class name lengths.
# ---------------------------------------------------------------------------

invariant traceback_extra28.TracebackException.bases_name.len:
  description: "traceback.TracebackException.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "TracebackException.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant traceback_extra28.StackSummary.bases_name.len:
  description: "traceback.StackSummary.__bases__[0].__name__.__len__() == 4 — base class is 'list'"
  category: class_hierarchy
  kind: python_call_eq
  function: "StackSummary.__bases__[0].__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# TracebackException.from_exception.__name__.__len__()
#
# from_exception is a classmethod on TracebackException. Its __name__ attribute
# equals 'from_exception' (14 characters). Prior spec (extra27) covered
# from_exception.__qualname__.__len__() == 33; this spec records the shorter
# __name__ length of 14.
# ---------------------------------------------------------------------------

invariant traceback_extra28.TracebackException.from_exception.name.len:
  description: "traceback.TracebackException.from_exception.__name__.__len__() == 14 — 'from_exception' has 14 characters"
  category: string_length
  kind: python_call_eq
  function: TracebackException.from_exception.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# Table: class __name__.__len__() for all three public traceback classes
#
# Groups the __name__ length checks for TracebackException, StackSummary,
# and FrameSummary in a single table for convenient batch validation.
# ---------------------------------------------------------------------------

table traceback_extra28.class_name_lens:
  description: "traceback class __name__.__len__() — TracebackException (18), StackSummary (12), FrameSummary (12)"
  kind: python_call_eq
  category: class_identity
  id_prefix: tb28cn

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_name_len, TracebackException.__name__.__len__, [], 18]
    - [StackSummary_name_len,       StackSummary.__name__.__len__,       [], 12]
    - [FrameSummary_name_len,       FrameSummary.__name__.__len__,       [], 12]

# ---------------------------------------------------------------------------
# Table: class __mro__.__len__() and __bases__[0].__name__.__len__()
#
# Combines MRO depth and base class name length for TracebackException and
# StackSummary. Provides a compact record of the inheritance topology.
# ---------------------------------------------------------------------------

table traceback_extra28.class_mro_and_base_lens:
  description: "traceback class __mro__.__len__() and __bases__[0].__name__.__len__() — TracebackException mro(2)/base(6), StackSummary mro(3)/base(4), FrameSummary mro(2)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: tb28mb

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_mro_len,       TracebackException.__mro__.__len__,                [], 2]
    - [StackSummary_mro_len,             StackSummary.__mro__.__len__,                      [], 3]
    - [FrameSummary_mro_len,             FrameSummary.__mro__.__len__,                      [], 2]
    - [TracebackException_base_name_len, "TracebackException.__bases__[0].__name__.__len__", [], 6]
    - [StackSummary_base_name_len,       "StackSummary.__bases__[0].__name__.__len__",       [], 4]
