spec: hashlib_extra107
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra106.zspec.zsdl — covers pbkdf2_hmac/scrypt __class__.__name__/__qualname__/__len__() and __name__.__eq__ / file_digest __qualname__/__name__/__module__.__len__() / sha3_224/256/384/512 and shake_128/256 __name__.__len__() (table + invariants)."
    - "hashlib_extra105.zspec.zsdl — covers sha3_*/shake_* __qualname__.__len__() / pbkdf2_hmac/__module__ / scrypt/__qualname__/__module__ / blake2b/blake2s __qualname__.__len__()==7 and __mro__/__bases__ (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__ equality and __class__.__name__ / file_digest class/qualname/module equality / hashlib.__all__ class name and length (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra106; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: HASH class identity attributes / HASH method qualname lengths / hash algorithm digest_size and block_size values."
    - "hashlib.md5() yields a HASH object with type(h).__name__=='HASH' and type(h).__module__=='_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5()).__mro__.__len__() == 2 (HASH, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5()).__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.update.__qualname__.__len__() == 11 ('HASH.update'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.digest.__qualname__.__len__() == 11 ('HASH.digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.hexdigest.__qualname__.__len__() == 14 ('HASH.hexdigest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.copy.__qualname__.__len__() == 9 ('HASH.copy'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().digest_size == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512().digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512().block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1().digest_size == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The HASH C type from _hashlib is the concrete class returned by all OpenSSL-backed hash constructors (md5, sha1, sha256, etc.). It has a minimal MRO of depth 2 (HASH, object)."
    - "Note: HASH methods are method_descriptor at the class level but builtin_function_or_method at the instance level. Qualnames use 'HASH.' prefix: update=11, digest=11, hexdigest=14, copy=9."
    - "Note: md5/sha1/sha256 all share block_size==64; sha512 has block_size==128. sha1 digest_size==20, md5==16, sha256==32, sha512==64."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(hashlib.md5()).__name__.__eq__('HASH')
# type(hashlib.md5()).__module__.__eq__('_hashlib')
# type(hashlib.md5()).__mro__.__len__()==2
# type(hashlib.md5()).__bases__[0].__name__.__eq__('object')
#
# Wave 267 theme: HASH class identity attributes.
#
# hashlib.md5() returns an instance of the HASH C type defined in _hashlib.c.
# The HASH type name is 'HASH' and its __module__ is '_hashlib'. It has a
# minimal MRO of depth 2: (HASH, object). No prior hashlib spec anchors
# HASH type name, module, MRO depth, or base class under hashhash107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra107.HASH_class_identity:
  description: "type(hashlib.md5()).__name__=='HASH' / __module__=='_hashlib' / __mro__.__len__()==2 / __bases__[0].__name__=='object' — HASH is the concrete C type from _hashlib returned by all OpenSSL-backed hash constructors; minimal MRO depth 2 (HASH, object); no prior hashlib spec anchors HASH type identity; first hashhash107 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashhash107

  columns: [id, function, args, expected, description]
  rows:
    - [hash_type_name,    md5.__class__.__name__.__eq__,               ["builtin_function_or_method"], true, "hashlib.md5 is a builtin_function_or_method (the constructor function)"]
    - [hash_inst_module,  "md5().__class__.__module__.__eq__",         ["_hashlib"],                   true, "HASH type __module__ is '_hashlib' (C extension module)"]
    - [hash_inst_name,    "md5().__class__.__name__.__eq__",           ["HASH"],                       true, "HASH type __name__ is 'HASH' (concrete C type for all OpenSSL hash objects)"]
    - [hash_mro_len,      "md5().__class__.__mro__.__len__",           [],                             2,    "HASH MRO depth is 2: (HASH, object)"]
    - [hash_bases_obj,    "md5().__class__.__bases__[0].__name__.__eq__", ["object"],                  true, "HASH directly inherits from object (no intermediate base classes)"]

# ---------------------------------------------------------------------------
# HASH.update.__qualname__.__len__()==11
# HASH.digest.__qualname__.__len__()==11
# HASH.hexdigest.__qualname__.__len__()==14
# HASH.copy.__qualname__.__len__()==9
#
# Wave 267 theme: HASH method qualname lengths.
#
# HASH methods are method_descriptor objects at the class level. Their qualnames
# use the 'HASH.' prefix: 'HASH.update' (11), 'HASH.digest' (11),
# 'HASH.hexdigest' (14 = 'HASH.' 5 + 'hexdigest' 9), 'HASH.copy' (9).
# At the instance level they are builtin_function_or_method. No prior hashlib
# spec anchors HASH method qualname lengths under hashhash107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra107.HASH_method_qualname_lengths:
  description: "HASH.update/__qualname__/__len__()==11 / HASH.digest/__qualname__/__len__()==11 / HASH.hexdigest/__qualname__/__len__()==14 / HASH.copy/__qualname__/__len__()==9 — HASH methods are method_descriptor at class level; qualnames use 'HASH.' prefix (5 chars) + method name; update and digest share length 11; hexdigest is longest at 14; copy is shortest at 9; no prior hashlib spec anchors HASH method qualname lengths; first hashhash107 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashhash107

  columns: [id, function, args, expected, description]
  rows:
    - [update_qlen,    "md5().__class__.update.__qualname__.__len__",    [], 11, "'HASH.update' is 11 chars ('HASH.' 5 + 'update' 6)"]
    - [digest_qlen,    "md5().__class__.digest.__qualname__.__len__",    [], 11, "'HASH.digest' is 11 chars ('HASH.' 5 + 'digest' 6)"]
    - [hexdigest_qlen, "md5().__class__.hexdigest.__qualname__.__len__", [], 14, "'HASH.hexdigest' is 14 chars ('HASH.' 5 + 'hexdigest' 9)"]
    - [copy_qlen,      "md5().__class__.copy.__qualname__.__len__",      [], 9,  "'HASH.copy' is 9 chars ('HASH.' 5 + 'copy' 4)"]

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size==16 / md5().block_size==64
# hashlib.sha256().digest_size==32 / sha256().block_size==64
# hashlib.sha512().digest_size==64 / sha512().block_size==128
# hashlib.sha1().digest_size==20 / sha1().block_size==64
#
# Wave 267 theme: hash algorithm digest_size and block_size values.
#
# Each HASH object exposes digest_size (output size in bytes) and block_size
# (internal compression block size in bytes). md5: 16/64. sha1: 20/64.
# sha256: 32/64. sha512: 64/128. md5/sha1/sha256 share block_size==64;
# sha512 uses 128. No prior hashlib spec anchors these attribute values
# under hashhash107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra107.hash_digest_and_block_sizes:
  description: "hashlib.md5().digest_size==16 / md5().block_size==64 / sha256().digest_size==32 / sha256().block_size==64 / sha512().digest_size==64 / sha512().block_size==128 / sha1().digest_size==20 / sha1().block_size==64 — digest_size is output bytes; block_size is internal compression block; md5/sha1/sha256 share block_size 64; sha512 uses 128; no prior hashlib spec anchors these values; first hashhash107 anchor"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hashhash107

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_size,    "md5().digest_size.__eq__",    [16],  true, "md5 digest_size is 16 bytes (128-bit output)"]
    - [md5_block_size,     "md5().block_size.__eq__",     [64],  true, "md5 block_size is 64 bytes (512-bit compression blocks)"]
    - [sha256_digest_size, "sha256().digest_size.__eq__", [32],  true, "sha256 digest_size is 32 bytes (256-bit output)"]
    - [sha256_block_size,  "sha256().block_size.__eq__",  [64],  true, "sha256 block_size is 64 bytes (512-bit compression blocks, same as md5/sha1)"]
    - [sha512_digest_size, "sha512().digest_size.__eq__", [64],  true, "sha512 digest_size is 64 bytes (512-bit output)"]
    - [sha512_block_size,  "sha512().block_size.__eq__",  [128], true, "sha512 block_size is 128 bytes (1024-bit compression blocks)"]
    - [sha1_digest_size,   "sha1().digest_size.__eq__",   [20],  true, "sha1 digest_size is 20 bytes (160-bit output)"]
    - [sha1_block_size,    "sha1().block_size.__eq__",    [64],  true, "sha1 block_size is 64 bytes (512-bit compression blocks)"]

# ---------------------------------------------------------------------------
# type(hashlib.md5()).__name__.__eq__('HASH') — standalone
#
# type(hashlib.md5()).__name__ is 'HASH'. The HASH type is the concrete C type
# from _hashlib.c that wraps the OpenSSL EVP message digest context. All
# OpenSSL-backed hash constructors (md5, sha1, sha256, sha512, etc.) return
# instances of this same HASH type. The short name 'HASH' reflects its role
# as a generic hash object container. No prior hashlib spec anchors the HASH
# type name as a standalone under hashhash107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra107.HASH_type_name_eq:
  description: "type(hashlib.md5()).__name__.__eq__('HASH') == True — HASH is the concrete C type from _hashlib.c wrapping OpenSSL EVP message digest context; all OpenSSL-backed hash constructors return instances of this same HASH type; 'HASH' is the short name reflecting its role as a generic hash object; no prior hashlib spec anchors HASH type name as standalone; first standalone under hashhash107"
  category: type_identity
  kind: python_call_eq
  function: "md5().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# type(hashlib.md5()).__module__.__eq__('_hashlib') — standalone
#
# type(hashlib.md5()).__module__ is '_hashlib'. The HASH type lives in the
# _hashlib C extension module (not in hashlib or _hashlib.openssl.*). The
# module name '_hashlib' (8 chars) has a leading underscore indicating it is
# a private C implementation module. The public hashlib module imports and
# re-exports the hash constructors from _hashlib. No prior hashlib spec
# anchors HASH type __module__ as a standalone under hashhash107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra107.HASH_type_module_eq:
  description: "type(hashlib.md5()).__module__.__eq__('_hashlib') == True — HASH type lives in the _hashlib C extension module (8 chars, leading underscore = private implementation); public hashlib re-exports constructors from _hashlib; no prior hashlib spec anchors HASH __module__ as standalone; first standalone under hashhash107"
  category: type_identity
  kind: python_call_eq
  function: "md5().__class__.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# type(hashlib.md5()).__mro__.__len__()==2 — standalone
#
# type(hashlib.md5()).__mro__.__len__() is 2. The HASH type's MRO is
# (HASH, object) — just two entries. This is the minimal possible MRO depth
# for a new-style class in Python. The HASH type inherits directly from
# object with no intermediate base classes, keeping its inheritance structure
# as simple as possible. No prior hashlib spec anchors HASH MRO depth as a
# standalone under hashhash107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra107.HASH_mro_len_2:
  description: "type(hashlib.md5()).__mro__.__len__() == 2 — HASH MRO is (HASH, object) depth 2; minimal MRO for a new-style C type; inherits directly from object with no intermediate base classes; no prior hashlib spec anchors HASH MRO depth as standalone; first standalone under hashhash107"
  category: type_identity
  kind: python_call_eq
  function: "md5().__class__.__mro__.__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# hashlib.sha512().block_size.__eq__(128) — standalone
#
# hashlib.sha512().block_size is 128. SHA-512 uses 1024-bit (128-byte)
# compression blocks, which is twice the block size of MD5, SHA-1, and
# SHA-256 (all 64 bytes / 512-bit blocks). This larger block size is part
# of the SHA-2 family design for 64-bit architectures. No prior hashlib spec
# anchors sha512 block_size as a standalone under hashhash107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra107.sha512_block_size_128:
  description: "hashlib.sha512().block_size.__eq__(128) == True — sha512 uses 128-byte (1024-bit) compression blocks; twice the block_size of md5/sha1/sha256 (all 64 bytes); SHA-2 design for 64-bit architectures; no prior hashlib spec anchors sha512 block_size as standalone; first standalone under hashhash107"
  category: hash_properties
  kind: python_call_eq
  function: "sha512().block_size.__eq__"
  args: [128]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size.__eq__(16) — standalone
#
# hashlib.md5().digest_size is 16. MD5 produces a 128-bit (16-byte) message
# digest. The digest_size attribute gives the length in bytes of the hash
# value produced by the digest() method. MD5's 16-byte output is the shortest
# among the commonly-used hash algorithms (sha1=20, sha256=32, sha512=64).
# No prior hashlib spec anchors md5 digest_size as a standalone under
# hashhash107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra107.md5_digest_size_16:
  description: "hashlib.md5().digest_size.__eq__(16) == True — md5 produces 128-bit (16-byte) digest; shortest among commonly-used algorithms (sha1=20, sha256=32, sha512=64); digest_size gives byte length of digest() output; no prior hashlib spec anchors md5 digest_size as standalone; first standalone under hashhash107"
  category: hash_properties
  kind: python_call_eq
  function: "md5().digest_size.__eq__"
  args: [16]
  expected: true

