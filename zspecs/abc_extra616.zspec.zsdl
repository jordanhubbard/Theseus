spec: abc_extra616
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta method __doc__ type and ABC class hierarchy introspection"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers ABCMeta method __doc__ type checks, class identity checks for abc types, and inherited __qualname__ checks for ABC and ABCMeta"
  created_at: "2026-04-12T00:00:00Z"

table abc_extra616.abcmeta_doc_class_name:
  description: "Verify that ABCMeta method __doc__ attributes are strings"
  kind: python_call_eq
  category: doc_type
  id_prefix: ab616dc
  columns: [id, function, args, expected]
  rows:
    - [ab616dc001, abc.ABCMeta.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab616dc002, abc.ABCMeta.register.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab616dc003, abc.ABCMeta.__instancecheck__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab616dc004, abc.ABCMeta.__subclasscheck__.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra616.class_identity:
  description: "Verify that abc classes are themselves type objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab616ci
  columns: [id, function, args, expected]
  rows:
    - [ab616ci001, abc.ABC.__class__.__name__.__eq__, ["type"], true]
    - [ab616ci002, abc.ABCMeta.__class__.__name__.__eq__, ["type"], true]
    - [ab616ci003, abc.abstractproperty.__class__.__name__.__eq__, ["type"], true]
    - [ab616ci004, abc.abstractclassmethod.__class__.__name__.__eq__, ["type"], true]
    - [ab616ci005, abc.abstractstaticmethod.__class__.__name__.__eq__, ["type"], true]

table abc_extra616.inherited_qualnames:
  description: "Verify __qualname__ of methods inherited from object and type on ABC and ABCMeta"
  kind: python_call_eq
  category: qualname
  id_prefix: ab616qn
  columns: [id, function, args, expected]
  rows:
    - [ab616qn001, abc.ABC.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [ab616qn002, abc.ABCMeta.__prepare__.__qualname__.__eq__, ["type.__prepare__"], true]
