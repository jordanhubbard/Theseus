spec: compute_mean
version: ">=3.0.0"
backend: node(compute-mean)

docs: https://www.npmjs.com/package/compute-mean

provenance:
  derived_from:
    - "compute-mean README — https://www.npmjs.com/package/compute-mean"
    - "Test vectors verified with compute-mean via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-mean source"
  notes:
    - "compute-mean is an npm package. Install: npm install compute-mean"
    - "Returns the arithmetic mean of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_mean.mean:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: cmean

  columns: [id, args, expected]
  rows:
    - [five,   [[1, 2, 3, 4, 5]],   3]
    - [three,  [[10, 20, 30]],       20]
    - [one,    [[7]],                7]
