spec: concurrent_futures_extra1036
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures Future and ThreadPoolExecutor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.Future method qualnames, module doc class identity, and descriptor types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1036.future_method_qualnames:
  description: "concurrent.futures.Future method __qualname__ identity"
  kind: python_call_eq
  category: future_method_qualnames
  id_prefix: cf1036fm
  columns: [id, function, args, expected]
  rows:
    - [cf1036fm001, concurrent.futures.Future.__repr__.__qualname__.__eq__,   ["Future.__repr__"],   true]
    - [cf1036fm002, concurrent.futures.Future.__str__.__qualname__.__eq__,    ["Future.__str__"],    true]
    - [cf1036fm003, concurrent.futures.Future.cancel.__qualname__.__eq__,     ["Future.cancel"],     true]
    - [cf1036fm004, concurrent.futures.Future.result.__qualname__.__eq__,     ["Future.result"],     true]
    - [cf1036fm005, concurrent.futures.Future.done.__qualname__.__eq__,       ["Future.done"],       true]
    - [cf1036fm006, concurrent.futures.Future.running.__qualname__.__eq__,    ["Future.running"],    true]
    - [cf1036fm007, concurrent.futures.Future.cancelled.__qualname__.__eq__,  ["Future.cancelled"],  true]
    - [cf1036fm008, concurrent.futures.Future.exception.__qualname__.__eq__,  ["Future.exception"],  true]

table concurrent_futures_extra1036.executor_descriptors:
  description: "concurrent.futures.ThreadPoolExecutor attribute class identity"
  kind: python_call_eq
  category: executor_descriptors
  id_prefix: cf1036ed
  columns: [id, function, args, expected]
  rows:
    - [cf1036ed001, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__,  ["type"],  true]
    - [cf1036ed002, concurrent.futures.ThreadPoolExecutor.__module__.__eq__,          ["concurrent.futures"], true]
    - [cf1036ed003, concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__, ["ThreadPoolExecutor.submit"], true]
    - [cf1036ed004, concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__,    ["ThreadPoolExecutor.map"], true]
    - [cf1036ed005, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true]

table concurrent_futures_extra1036.module_identity:
  description: "concurrent.futures module and Future descriptor identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf1036mi
  columns: [id, function, args, expected]
  rows:
    - [cf1036mi001, concurrent.futures.__doc__.__class__.__name__.__eq__,              ["str"],                true]
    - [cf1036mi002, concurrent.futures.Future.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"],  true]
    - [cf1036mi003, concurrent.futures.Future.__module__.__eq__,                       ["concurrent.futures"], true]
    - [cf1036mi004, concurrent.futures.__name__.__eq__,                                ["concurrent.futures"], true]
    - [cf1036mi005, concurrent.futures.Future.__class__.__name__.__eq__,               ["type"],               true]
