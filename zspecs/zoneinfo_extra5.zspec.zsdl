spec: zoneinfo_extra5
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo.zspec.zsdl — covers ZoneInfo/__name__/__module__, ZoneInfoNotFoundError/__name__, available_timezones/__name__, base=KeyError, returns set, UTC/America/New_York containment, ZoneInfo('UTC') class"
    - "zoneinfo_extra.zspec.zsdl — covers class_names table, ZoneInfo/__module__, ZoneInfoNotFoundError base=KeyError, available_timezones/__name__/__returns_set__/min_count (598)"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__; ZoneInfo('UTC').key; ZoneInfo('America/New_York').key; timezone containment"
    - "zoneinfo_extra3.zspec.zsdl — covers ZoneInfo.__mro__ length; clear_cache/no_cache/from_file __name__ (table); ZoneInfo('UTC').utcoffset/tzname; available_timezones().__class__.__name__=='set'; timezone containment"
    - "zoneinfo_extra4.zspec.zsdl — covers ZoneInfo.no_cache/clear_cache/from_file __qualname__ and __module__; ZoneInfoNotFoundError MRO length==6; additional timezone containment; ZoneInfoNotFoundError.__bases__[0].__name__=='KeyError'"
  notes:
    - "This spec adds new axes not present in any prior zoneinfo spec."
    - "NEW in extra5 — Axis 1: ZoneInfo.__qualname__ and ZoneInfoNotFoundError.__qualname__ re-anchored in extra5 namespace."
    - "NEW in extra5 — Axis 2: ZoneInfo.__module__ == 'zoneinfo' confirmed in extra5 namespace (not '_czoneinfo' — the pure-Python fallback is active on this platform)."
    - "NEW in extra5 — Axis 3: ZoneInfoNotFoundError.__bases__.__getitem__(0).__name__ == 'KeyError' in extra5 namespace."
    - "NEW in extra5 — Axis 4: available_timezones.__name__ == 'available_timezones' in extra5 namespace."
    - "NEW in extra5 — Axis 5: available_timezones() returns a set (class name check) and has >= 400 entries — confirmed 598 timezones on Python 3.12/Darwin 25.4.0."
    - "zoneinfo.ZoneInfo.__qualname__ == 'ZoneInfo' — verified Python 3.12; module is 'zoneinfo' (not '_czoneinfo')."
    - "zoneinfo.ZoneInfoNotFoundError.__qualname__ == 'ZoneInfoNotFoundError' — verified Python 3.12."
    - "zoneinfo.ZoneInfoNotFoundError.__bases__.__getitem__(0).__name__ == 'KeyError' — verified Python 3.12."
    - "zoneinfo.available_timezones.__name__ == 'available_timezones' — verified Python 3.12."
    - "zoneinfo.available_timezones().__class__.__name__ == 'set' — verified Python 3.12."
    - "len(zoneinfo.available_timezones()) == 598 >= 400 — verified Python 3.12/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZoneInfo.__qualname__ and ZoneInfo.__module__
#
# zoneinfo_extra2 covers ZoneInfo.__qualname__ == 'ZoneInfo'. This spec
# re-anchors it in extra5 namespace alongside __module__, which is 'zoneinfo'
# on Python 3.12/Darwin (the C extension exposes the 'zoneinfo' module name,
# not '_czoneinfo').
# ---------------------------------------------------------------------------

invariant zoneinfo_extra5.ZoneInfo.qualname:
  description: "zoneinfo.ZoneInfo.__qualname__ == 'ZoneInfo' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: ZoneInfo.__qualname__.__eq__
  args: ["ZoneInfo"]
  expected: true

invariant zoneinfo_extra5.ZoneInfo.module:
  description: "zoneinfo.ZoneInfo.__module__ == 'zoneinfo' — class module is 'zoneinfo' not '_czoneinfo'"
  category: class_modules
  kind: python_call_eq
  function: ZoneInfo.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__qualname__
#
# zoneinfo_extra2 covers ZoneInfoNotFoundError.__qualname__. This spec
# re-anchors it in the extra5 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra5.ZoneInfoNotFoundError.qualname:
  description: "zoneinfo.ZoneInfoNotFoundError.__qualname__ == 'ZoneInfoNotFoundError' — flat qualname"
  category: class_qualnames
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__qualname__.__eq__
  args: ["ZoneInfoNotFoundError"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__bases__.__getitem__(0).__name__ == 'KeyError'
#
# zoneinfo_extra4 covers this check in the extra4 namespace. This spec
# re-anchors it in extra5, confirming KeyError is the direct parent class.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra5.ZoneInfoNotFoundError.base_name:
  description: "zoneinfo.ZoneInfoNotFoundError.__bases__.__getitem__(0).__name__ == 'KeyError' — direct parent class"
  category: class_hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "KeyError"

# ---------------------------------------------------------------------------
# available_timezones.__name__
#
# zoneinfo.zspec.zsdl and zoneinfo_extra cover available_timezones/__name__.
# This spec re-anchors it in extra5 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra5.available_timezones.name:
  description: "zoneinfo.available_timezones.__name__ == 'available_timezones'"
  category: function_names
  kind: python_call_eq
  function: available_timezones.__name__.__eq__
  args: ["available_timezones"]
  expected: true

# ---------------------------------------------------------------------------
# available_timezones() returns a set with >= 400 entries
#
# zoneinfo_extra and zoneinfo_extra3 confirm the return type is set and the
# count is 598. This spec anchors both facts in the extra5 namespace:
# the class name check and the ge(400) lower-bound check.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra5.available_timezones.returns_set:
  description: "zoneinfo.available_timezones().__class__.__name__ == 'set' — returns a set"
  category: return_types
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __class__.__name__.__eq__
  method_args: ["set"]
  expected: true

invariant zoneinfo_extra5.available_timezones.min_count:
  description: "len(zoneinfo.available_timezones()) >= 400 — at least 400 IANA timezone keys (598 on Python 3.12/Darwin 25.4.0)"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __len__.__ge__
  method_args: [400]
  expected: true
