table asyncio_extra1216.queue_task_future_mro_len:
  description: "asyncio.Queue, asyncio.Task, and asyncio.Future MRO lengths — Queue and Task have 3 entries, Future has 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: as1216qt
  columns: [id, function, args, expected]
  rows:
    - [as1216qt001, asyncio.Queue.__mro__.__len__,                        [], 3]
    - [as1216qt002, asyncio.Task.__mro__.__len__,                         [], 3]
    - [as1216qt003, asyncio.Future.__mro__.__len__,                       [], 2]
    - [as1216qt004, asyncio.Queue.__mro__.__class__.__name__.__eq__,      ["tuple"], true]
    - [as1216qt005, asyncio.Task.__mro__.__class__.__name__.__eq__,       ["tuple"], true]
    - [as1216qt006, asyncio.Future.__mro__.__class__.__name__.__eq__,     ["tuple"], true]
    - [as1216qt007, asyncio.Queue.__name__.__eq__,                        ["Queue"],  true]
    - [as1216qt008, asyncio.Task.__name__.__eq__,                         ["Task"],   true]

