spec: uuid_extra82
version: ">=3.9"
extends: uuid_extra81
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra81.zspec.zsdl — covers uuid.UUID.__dict__ comparison method membership (__lt__/__gt__/__le__/__ge__) / field property dict membership (time_low/time_mid/clock_seq_hi_variant/clock_seq_low/node/urn/bytes_le/fields) (table + invariants)."
    - "uuid_extra80.zspec.zsdl — covers UUID property __class__.__name__ identity for hex/bytes/bytes_le/fields/time_low/time_mid/variant/version / SafeUUID class identity (__name__/__module__/__qualname__/__bases__[0].__name__) / SafeUUID.__mro__.__len__()==3 (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra81; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: uuid.SafeUUID enum member identity and uuid module identity."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.__class__.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.name == 'safe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.name == 'unsafe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.value == -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__name__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__file__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe/__class__/__name__.__eq__('SafeUUID')
# uuid.SafeUUID.unsafe/__class__/__name__.__eq__('SafeUUID')
# uuid.SafeUUID.safe/__class__/__name__.__eq__('SafeUUID') (cross-check)
# uuid.SafeUUID.unsafe/__class__/__name__.__eq__('SafeUUID') (cross-check)
#
# Wave 256 theme: SafeUUID member class identity.
#
# SafeUUID.safe and SafeUUID.unsafe are both enum members whose __class__.__name__
# is 'SafeUUID'. uuid_extra80 anchors SafeUUID class identity (__name__/__module__);
# this table anchors the member-level __class__.__name__.__eq__ calls under
# uuidsafeuuid82.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra82.safeuuid_member_class_names:
  description: "uuid.SafeUUID.safe/__class__.__name__.__eq__('SafeUUID')==True / SafeUUID.unsafe/__class__.__name__.__eq__('SafeUUID')==True — SafeUUID.safe and SafeUUID.unsafe are both SafeUUID enum members; uuid_extra80 anchors SafeUUID class identity; this table anchors the two members' __class__.__name__.__eq__ calls under uuidsafeuuid82; first uuidsafeuuid82 anchor for SafeUUID member class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidsafeuuid82

  columns: [id, function, args, expected]
  rows:
    - [safe_class_name_eq,    SafeUUID.safe.__class__.__name__.__eq__,    ["SafeUUID"], true]
    - [unsafe_class_name_eq,  SafeUUID.unsafe.__class__.__name__.__eq__,  ["SafeUUID"], true]
    - [safe_class_name_eq2,   SafeUUID.safe.__class__.__name__.__eq__,    ["SafeUUID"], true]
    - [unsafe_class_name_eq2, SafeUUID.unsafe.__class__.__name__.__eq__,  ["SafeUUID"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.name.__eq__('safe')
# uuid.SafeUUID.unsafe.name.__eq__('unsafe')
# uuid.SafeUUID.safe/__class__/__name__.__eq__('SafeUUID') (cross-check)
# uuid.SafeUUID.unsafe/__class__/__name__.__eq__('SafeUUID') (cross-check)
#
# Wave 256 theme: SafeUUID member .name attribute.
#
# SafeUUID.safe.name is 'safe' and SafeUUID.unsafe.name is 'unsafe'. The .name
# attribute on enum members returns the member's string name. No prior uuid spec
# anchors SafeUUID member .name.__eq__ calls under uuidsafeuuid82.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra82.safeuuid_member_names:
  description: "uuid.SafeUUID.safe.name.__eq__('safe')==True / SafeUUID.unsafe.name.__eq__('unsafe')==True / SafeUUID.safe/__class__.__name__.__eq__('SafeUUID')==True / SafeUUID.unsafe/__class__.__name__.__eq__('SafeUUID')==True — SafeUUID enum members carry .name attributes returning their string names ('safe' and 'unsafe'); cross-checks anchor class identity; first uuidsafeuuid82 anchor for SafeUUID member .name __eq__ calls"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidsafeuuid82

  columns: [id, function, args, expected]
  rows:
    - [safe_name_eq,         SafeUUID.safe.name.__eq__,              ["safe"],     true]
    - [unsafe_name_eq,       SafeUUID.unsafe.name.__eq__,            ["unsafe"],   true]
    - [safe_class_xcheck,    SafeUUID.safe.__class__.__name__.__eq__, ["SafeUUID"], true]
    - [unsafe_class_xcheck,  SafeUUID.unsafe.__class__.__name__.__eq__, ["SafeUUID"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.value.__eq__(0)
# uuid.SafeUUID.unsafe.value.__eq__(-1)
# uuid.SafeUUID.safe.name.__eq__('safe') (cross-check)
# uuid.SafeUUID.unsafe.name.__eq__('unsafe') (cross-check)
#
# Wave 256 theme: SafeUUID member .value attribute.
#
# SafeUUID.safe.value is 0 and SafeUUID.unsafe.value is -1. The .value
# attribute on enum members returns the numeric value. No prior uuid spec
# anchors SafeUUID member .value.__eq__ calls under uuidsafeuuid82.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra82.safeuuid_member_values:
  description: "uuid.SafeUUID.safe.value.__eq__(0)==True / SafeUUID.unsafe.value.__eq__(-1)==True / SafeUUID.safe.name.__eq__('safe')==True / SafeUUID.unsafe.name.__eq__('unsafe')==True — SafeUUID.safe has value 0 and SafeUUID.unsafe has value -1; cross-checks anchor the .name attributes; first uuidsafeuuid82 anchor for SafeUUID member .value __eq__ calls"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidsafeuuid82

  columns: [id, function, args, expected]
  rows:
    - [safe_value_eq,    SafeUUID.safe.value.__eq__,    [0],  true]
    - [unsafe_value_eq,  SafeUUID.unsafe.value.__eq__,  [-1], true]
    - [safe_name_xcheck, SafeUUID.safe.name.__eq__,     ["safe"],   true]
    - [unsafe_name_xcheck, SafeUUID.unsafe.name.__eq__, ["unsafe"], true]

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid')
# uuid.__package__.__eq__('')
# uuid.__spec__/__class__/__name__.__eq__('ModuleSpec')
# uuid.__loader__/__class__/__name__.__eq__('SourceFileLoader')
#
# Wave 256 theme: uuid module identity.
#
# uuid.__name__ is 'uuid', __package__ is '' (empty string), __spec__.__class__.__name__
# is 'ModuleSpec', and __loader__.__class__.__name__ is 'SourceFileLoader'.
# These anchor the module-level identity of the uuid module under uuidsafeuuid82.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra82.uuid_module_identity:
  description: "uuid.__name__.__eq__('uuid')==True / uuid.__package__.__eq__('')==True / uuid.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / uuid.__loader__/__class__.__name__.__eq__('SourceFileLoader')==True — uuid module identity: name is 'uuid', package is empty string, spec class is ModuleSpec, loader class is SourceFileLoader; first uuidsafeuuid82 anchor for uuid module identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidsafeuuid82

  columns: [id, function, args, expected]
  rows:
    - [uuid_name_eq,          __name__.__eq__,                          ["uuid"],             true]
    - [uuid_package_eq,       __package__.__eq__,                       [""],                 true]
    - [uuid_spec_class_eq,    __spec__.__class__.__name__.__eq__,        ["ModuleSpec"],       true]
    - [uuid_loader_class_eq,  __loader__.__class__.__name__.__eq__,      ["SourceFileLoader"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') — standalone
#
# SafeUUID.safe is an instance of the SafeUUID enum class. Its __class__.__name__
# is 'SafeUUID'. No prior uuid spec anchors SafeUUID.safe.__class__.__name__.__eq__
# as a standalone under uuidsafeuuid82. First standalone for SafeUUID.safe class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra82.safe_class_name_eq:
  description: "uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') == True — SafeUUID.safe is an instance of the SafeUUID enum; its __class__.__name__ is 'SafeUUID'; uuid_extra80 anchors the SafeUUID class itself; this standalone anchors the safe member's class identity; first standalone under uuidsafeuuid82"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.safe.__class__.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.unsafe.value.__eq__(-1) — standalone
#
# SafeUUID.unsafe.value is -1. The unsafe member indicates that UUID generation
# is not safe from a threading/multiprocessing perspective. No prior uuid spec
# anchors SafeUUID.unsafe.value.__eq__ as a standalone. First standalone for
# SafeUUID.unsafe.value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra82.unsafe_value_eq:
  description: "uuid.SafeUUID.unsafe.value.__eq__(-1) == True — SafeUUID.unsafe has value -1 indicating UUID generation is not thread/process safe; SafeUUID.safe has value 0; no prior uuid spec anchors this value __eq__ call; first standalone for SafeUUID.unsafe.value under uuidsafeuuid82"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.unsafe.value.__eq__
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.value.__eq__(0) — standalone
#
# SafeUUID.safe.value is 0 indicating UUID generation is safe (e.g., using
# os.urandom or similar safe RNG). No prior uuid spec anchors SafeUUID.safe.value.__eq__
# as a standalone. First standalone for SafeUUID.safe.value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra82.safe_value_eq:
  description: "uuid.SafeUUID.safe.value.__eq__(0) == True — SafeUUID.safe has value 0 indicating UUID generation is thread/process safe; SafeUUID.unsafe has value -1; no prior uuid spec anchors this value __eq__ call; first standalone for SafeUUID.safe.value under uuidsafeuuid82"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.safe.value.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# uuid.__spec__.__class__.__name__ is 'ModuleSpec'. The __spec__ attribute
# holds the module's importlib.machinery.ModuleSpec. No prior uuid spec anchors
# __spec__.__class__.__name__.__eq__ as a standalone. First standalone for
# uuid.__spec__ class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra82.uuid_spec_class_eq:
  description: "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — uuid.__spec__ holds an importlib.machinery.ModuleSpec instance; its __class__.__name__ is 'ModuleSpec'; no prior uuid spec anchors this __eq__ call; first standalone for uuid.__spec__ class identity under uuidsafeuuid82"
  category: class_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# uuid.__loader__.__class__.__name__ is 'SourceFileLoader'. uuid is a pure-Python
# module loaded from source by importlib's SourceFileLoader. No prior uuid spec
# anchors __loader__.__class__.__name__.__eq__ as a standalone. First standalone
# for uuid.__loader__ class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra82.uuid_loader_class_eq:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — uuid is a pure-Python module; its __loader__ is an importlib.machinery.SourceFileLoader; __class__.__name__ is 'SourceFileLoader'; no prior uuid spec anchors this __eq__ call; first standalone for uuid.__loader__ class identity under uuidsafeuuid82"
  category: class_attrs
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
