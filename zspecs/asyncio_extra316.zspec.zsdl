spec: asyncio_extra316
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_extra.zspec.zsdl, asyncio_extra2.zspec.zsdl, asyncio_extra3.zspec.zsdl."
    - "asyncio_extra.zspec.zsdl covers __name__ for ensure_future, gather, sleep, run, create_task."
    - "asyncio_extra3.zspec.zsdl covers __qualname__ for gather, sleep, create_task; __name__ for wait, shield, wait_for."
    - "This spec focuses on __name__ and __module__ for the top-level asyncio functions: get_event_loop, get_running_loop, new_event_loop, set_event_loop, run, sleep, gather, wait, ensure_future."
    - "asyncio.get_event_loop.__module__ == '_asyncio' — implemented in the C extension."
    - "asyncio.get_running_loop.__module__ == '_asyncio' — also a C extension builtin."
    - "asyncio.new_event_loop and set_event_loop are Python functions in asyncio.events."
    - "asyncio.run.__module__ == 'asyncio.runners'."
    - "asyncio.sleep, gather, wait, ensure_future all live in asyncio.tasks."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — top-level asyncio module-level functions
#
# These verify the unqualified function name attribute for each function
# exposed at the asyncio namespace level.
# ---------------------------------------------------------------------------

table asyncio_extra316.function_names:
  description: "asyncio module-level functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_event_loop,  get_event_loop.__name__.__eq__,  ["get_event_loop"],  true]
    - [get_running_loop, get_running_loop.__name__.__eq__, ["get_running_loop"], true]
    - [new_event_loop,  new_event_loop.__name__.__eq__,  ["new_event_loop"],  true]
    - [set_event_loop,  set_event_loop.__name__.__eq__,  ["set_event_loop"],  true]
    - [run,             run.__name__.__eq__,             ["run"],             true]
    - [sleep,           sleep.__name__.__eq__,           ["sleep"],           true]
    - [gather,          gather.__name__.__eq__,          ["gather"],          true]
    - [wait,            wait.__name__.__eq__,            ["wait"],            true]
    - [ensure_future,   ensure_future.__name__.__eq__,   ["ensure_future"],   true]

# ---------------------------------------------------------------------------
# __module__ checks — where each function is defined
#
# get_event_loop and get_running_loop are C-extension builtins in '_asyncio'.
# new_event_loop and set_event_loop are Python functions in asyncio.events.
# run is defined in asyncio.runners.
# sleep, gather, wait, and ensure_future are defined in asyncio.tasks.
# ---------------------------------------------------------------------------

invariant asyncio_extra316.modules.get_event_loop:
  description: "asyncio.get_event_loop.__module__ == '_asyncio' — C extension builtin"
  category: function_modules
  kind: python_call_eq
  function: get_event_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra316.modules.get_running_loop:
  description: "asyncio.get_running_loop.__module__ == '_asyncio' — C extension builtin"
  category: function_modules
  kind: python_call_eq
  function: get_running_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra316.modules.new_event_loop:
  description: "asyncio.new_event_loop.__module__ == 'asyncio.events'"
  category: function_modules
  kind: python_call_eq
  function: new_event_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra316.modules.set_event_loop:
  description: "asyncio.set_event_loop.__module__ == 'asyncio.events'"
  category: function_modules
  kind: python_call_eq
  function: set_event_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra316.modules.run:
  description: "asyncio.run.__module__ == 'asyncio.runners'"
  category: function_modules
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra316.modules.sleep:
  description: "asyncio.sleep.__module__ == 'asyncio.tasks'"
  category: function_modules
  kind: python_call_eq
  function: sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra316.modules.gather:
  description: "asyncio.gather.__module__ == 'asyncio.tasks'"
  category: function_modules
  kind: python_call_eq
  function: gather.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra316.modules.wait:
  description: "asyncio.wait.__module__ == 'asyncio.tasks'"
  category: function_modules
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra316.modules.ensure_future:
  description: "asyncio.ensure_future.__module__ == 'asyncio.tasks'"
  category: function_modules
  kind: python_call_eq
  function: ensure_future.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true
