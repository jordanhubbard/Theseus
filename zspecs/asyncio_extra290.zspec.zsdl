spec: asyncio_extra290
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queue classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py, Lib/asyncio/queues.py"
  notes:
    - "asyncio.Lock.__module__ is 'asyncio.locks' not 'asyncio'"
    - "asyncio.Queue.__module__ is 'asyncio.queues' not 'asyncio'"
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'"
    - "asyncio.PriorityQueue.__bases__[0].__name__ is 'Queue'"
    - "asyncio.LifoQueue.__bases__[0].__name__ is 'Queue'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra290.sync_primitive_names:
  description: "__name__ identity for asyncio synchronization primitive classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio290

  columns: [id, function, args, expected, description]
  rows:
    - [aio290_001, asyncio.Lock.__name__.__eq__, ["Lock"], true, "Lock class name is 'Lock'"]
    - [aio290_002, asyncio.Event.__name__.__eq__, ["Event"], true, "Event class name is 'Event'"]
    - [aio290_003, asyncio.Condition.__name__.__eq__, ["Condition"], true, "Condition class name is 'Condition'"]
    - [aio290_004, asyncio.Semaphore.__name__.__eq__, ["Semaphore"], true, "Semaphore class name is 'Semaphore'"]
    - [aio290_005, asyncio.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "BoundedSemaphore class name is 'BoundedSemaphore'"]

table asyncio_extra290.queue_names_and_bases:
  description: "__name__ and base class checks for asyncio queue classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio290q

  columns: [id, function, args, expected, description]
  rows:
    - [aio290q_001, asyncio.Queue.__name__.__eq__, ["Queue"], true, "Queue class name is 'Queue'"]
    - [aio290q_002, asyncio.PriorityQueue.__name__.__eq__, ["PriorityQueue"], true, "PriorityQueue class name is 'PriorityQueue'"]
    - [aio290q_003, asyncio.LifoQueue.__name__.__eq__, ["LifoQueue"], true, "LifoQueue class name is 'LifoQueue'"]
    - [aio290q_004, asyncio.QueueEmpty.__name__.__eq__, ["QueueEmpty"], true, "QueueEmpty class name is 'QueueEmpty'"]
    - [aio290q_005, asyncio.QueueFull.__name__.__eq__, ["QueueFull"], true, "QueueFull class name is 'QueueFull'"]
    - [aio290q_006, "asyncio.PriorityQueue.__bases__[0].__name__.__eq__", ["Queue"], true, "PriorityQueue base class is Queue"]
    - [aio290q_007, "asyncio.LifoQueue.__bases__[0].__name__.__eq__", ["Queue"], true, "LifoQueue base class is Queue"]

invariant asyncio_extra290.lock_module:
  description: "asyncio.Lock.__module__ is 'asyncio.locks'"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra290.queue_module:
  description: "asyncio.Queue.__module__ is 'asyncio.queues'"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra290.lock_base_is_object:
  description: "asyncio.Lock.__bases__[0].__name__ is 'object'"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant asyncio_extra290.bounded_semaphore_base:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra290.priority_queue_base:
  description: "asyncio.PriorityQueue.__bases__[0].__name__ is 'Queue'"
  category: identity
  kind: python_call_eq
  function: asyncio.PriorityQueue.__bases__[0].__name__.__eq__
  args: ["Queue"]
  expected: true
