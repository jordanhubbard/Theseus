spec: decimal_extra2686
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2671.zspec.zsdl — covers __sub__/__floordiv__/__mod__ dict-presence"
  notes:
    - "Wave 626 (decimal_extra2686) theme: __and__, __or__, and __xor__ dict-presence checks."
    - "decimal.Decimal does NOT define __and__, __or__, or __xor__ in its own __dict__ — Decimal has no bitwise operators."
    - "decimal.Decimal DOES define logical_and, logical_or, and logical_xor as named methods for digit-by-digit logical operations on coefficient strings — these are NOT the dunder __and__/__or__/__xor__ bitwise operators."
    - "decimal.Context also defines logical_and, logical_or, and logical_xor as methods (context-aware variants) — again, NOT dunder bitwise operators."
    - "decimal.Context and decimal.DecimalException also define none of __and__, __or__, or __xor__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2686.no_and_in_decimal_classes:
  description: "__and__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal's logical_and is a named method, NOT a dunder bitwise operator"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2686

  columns: [id, function, args, expected]
  rows:
    - ["dc2686001", "decimal.Decimal.__dict__.__contains__",          ["__and__"], false]
    - ["dc2686002", "decimal.Context.__dict__.__contains__",          ["__and__"], false]
    - ["dc2686003", "decimal.DecimalException.__dict__.__contains__", ["__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2686.no_or_in_decimal_classes:
  description: "__or__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal's logical_or is a named method, NOT a dunder bitwise operator"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2686

  columns: [id, function, args, expected]
  rows:
    - ["dc2686004", "decimal.Decimal.__dict__.__contains__",          ["__or__"], false]
    - ["dc2686005", "decimal.Context.__dict__.__contains__",          ["__or__"], false]
    - ["dc2686006", "decimal.DecimalException.__dict__.__contains__", ["__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2686.no_xor_in_decimal_classes:
  description: "__xor__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal's logical_xor is a named method, NOT a dunder bitwise operator"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2686

  columns: [id, function, args, expected]
  rows:
    - ["dc2686007", "decimal.Decimal.__dict__.__contains__",          ["__xor__"], false]
    - ["dc2686008", "decimal.Context.__dict__.__contains__",          ["__xor__"], false]
    - ["dc2686009", "decimal.DecimalException.__dict__.__contains__", ["__xor__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal and decimal.Context have named logical methods (NOT dunder bitwise)
# Contrasts the named logical_and/logical_or/logical_xor with the absent __and__/__or__/__xor__ dunders
# ---------------------------------------------------------------------------

table decimal_extra2686.decimal_has_named_logical_methods_not_bitwise_dunders:
  description: "decimal.Decimal defines logical_and/logical_or/logical_xor as named methods but NOT __and__/__or__/__xor__; decimal.Context likewise defines logical_and/logical_or/logical_xor but NOT __and__/__or__/__xor__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2686

  columns: [id, function, args, expected]
  rows:
    - ["dc2686010", "decimal.Decimal.__dict__.__contains__", ["logical_and"],  true]
    - ["dc2686011", "decimal.Decimal.__dict__.__contains__", ["logical_or"],   true]
    - ["dc2686012", "decimal.Decimal.__dict__.__contains__", ["logical_xor"],  true]
    - ["dc2686013", "decimal.Decimal.__dict__.__contains__", ["__and__"],      false]
    - ["dc2686014", "decimal.Decimal.__dict__.__contains__", ["__or__"],       false]
    - ["dc2686015", "decimal.Decimal.__dict__.__contains__", ["__xor__"],      false]
    - ["dc2686016", "decimal.Context.__dict__.__contains__", ["logical_and"],  true]
    - ["dc2686017", "decimal.Context.__dict__.__contains__", ["logical_or"],   true]
    - ["dc2686018", "decimal.Context.__dict__.__contains__", ["logical_xor"],  true]
    - ["dc2686019", "decimal.Context.__dict__.__contains__", ["__and__"],      false]
    - ["dc2686020", "decimal.Context.__dict__.__contains__", ["__or__"],       false]
    - ["dc2686021", "decimal.Context.__dict__.__contains__", ["__xor__"],      false]
