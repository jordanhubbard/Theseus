  id_prefix: dc2536

  columns: [id, function, args, expected]
  rows:
    - ["dc2536004", decimal.Context.__dict__.__contains__, ["__format__"], false]
    - ["dc2536005", decimal.Context.__dict__.__contains__, ["__bytes__"], false]
    - ["dc2536006", decimal.Context.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Cross-class parity — Decimal vs Context __format__ dict-presence
#
# Decimal defines __format__ (True); Context does not (False).
# This contrast highlights that the custom format support belongs to Decimal
# only, not to the arithmetic context object.
# ---------------------------------------------------------------------------

table decimal_extra2536.format_parity:
