spec: decimal_extra2536
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence checks on decimal.Decimal."
    - "decimal.Decimal defines __format__ in its own __dict__ (True): Decimal supports custom format specifiers such as 'f', 'e', 'E', 'g', 'G', 'n', and '%'."
    - "decimal.Decimal does NOT define __bytes__ in its own __dict__ (False): Decimal is not directly bytes-convertible via bytes()."
    - "decimal.Decimal does NOT define __fspath__ in its own __dict__ (False): Decimal is a numeric type and does not implement the filesystem path protocol."
    - "The presence of __format__ on Decimal distinguishes it from most numeric types; it handles locale-aware formatting via the 'n' specifier."
    - "decimal.Context does not define __format__, __bytes__, or __fspath__ in its own __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal — __format__, __bytes__, __fspath__ dict-presence
#
# Decimal defines __format__ (True) for custom format specifiers.
# Decimal does NOT define __bytes__ or __fspath__.
# ---------------------------------------------------------------------------

table decimal_extra2536.decimal_proto_dict:
  description: "decimal.Decimal.__dict__ defines __format__ (True) but not __bytes__ or __fspath__ (both False); verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dc2536

  columns: [id, function, args, expected]
  rows:
    - ["dc2536001", decimal.Decimal.__dict__.__contains__, ["__format__"], true]
    - ["dc2536002", decimal.Decimal.__dict__.__contains__, ["__bytes__"], false]
    - ["dc2536003", decimal.Decimal.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# decimal.Context — __format__, __bytes__, __fspath__ dict-presence
# ---------------------------------------------------------------------------

table decimal_extra2536.context_proto_dict:
  description: "decimal.Context.__dict__ contains no __format__, __bytes__, or __fspath__; all __dict__.__contains__ calls return False; verified with Python 3.14.4"
  kind: python_call_eq
