spec: socket_extra86
version: ">=3.9"
extends: socket_extra85
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra85.zspec.zsdl — covers socket.socket.__dict__.__contains__ for accept/close/__init__/makefile/detach/dup/sendfile/__enter__/__exit__/__repr__/family/type/get_inheritable/set_inheritable / socket.socket.__dict__.__class__.__name__=='mappingproxy' (table + invariants)."
    - "socket_extra84.zspec.zsdl — covers INADDR_ANY/INADDR_BROADCAST/INADDR_LOOPBACK/INADDR_NONE class and value identity / SHUT_RD/SHUT_WR/SHUT_RDWR class and value / SOL_TCP class identity (table + invariants)."
    - "socket_extra82.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/AF_UNSPEC/__class__/__qualname__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__/__qualname__=='SocketKind' (table + invariants)."
    - "socket_extra80.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__.__name__=='SocketKind' / AF_INET/__eq__(2)/AF_INET6/__eq__(30)/SOCK_STREAM/__eq__(1)/SOCK_DGRAM/__eq__(2) (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra85; it does NOT duplicate invariants present in those files."
    - "Wave 252 theme: socket.socket class hierarchy and socket.AddressFamily/socket.SocketKind enum identity."
    - "socket.socket.__module__ == 'socket' — the Python-level wrapper class is defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket' — the class name is 'socket' (same as the module). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3 — MRO is [socket.socket, _socket.socket, object]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket' — the C-level _socket.socket class name is also 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__module__ == '_socket' — the base C class lives in _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket/__module__/__eq__('socket') / socket.socket/__qualname__/__eq__('socket')
# socket.socket/__mro__/__len__() == 3
# socket.socket/__bases__[0]/__name__/__eq__('socket')
#
# Wave 252 theme: socket.socket class hierarchy identity.
#
# socket.socket is the Python-level wrapper in socket.py that inherits from
# _socket.socket (the C class, also named 'socket'). The MRO has 3 entries:
# [socket.socket, _socket.socket, object].
# No prior socket spec checks socket.socket.__module__ or __qualname__ or
# __mro__.__len__() or __bases__[0].__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra86.socket_class_hierarchy:
  description: "socket.socket/__module__/__eq__('socket')==True / socket.socket/__qualname__/__eq__('socket')==True / socket.socket/__mro__/__len__()==3 / socket.socket/__bases__[0]/__name__/__eq__('socket')==True — socket.socket is the Python-level wrapper class in socket.py; it inherits from _socket.socket (C class also named 'socket'); the MRO is [socket.socket, _socket.socket, object] with 3 entries; no prior socket spec checks socket.socket __module__/__qualname__/__mro__.__len__/__bases__[0].__name__; first class hierarchy anchor for socket.socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: sockethier86

  columns: [id, function, args, expected]
  rows:
    - [socket_cls_module_eq,       socket.__module__.__eq__,                ["socket"], true]
    - [socket_cls_qualname_eq,     socket.__qualname__.__eq__,              ["socket"], true]
    - [socket_cls_mro_len_3,       socket.__mro__.__len__,                  [],         3]
    - [socket_cls_bases_name_eq,   "socket.__bases__[0].__name__.__eq__",   ["socket"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET/__class__/__name__/__eq__('AddressFamily')
# socket.SOCK_STREAM/__class__/__name__/__eq__('SocketKind')
# socket.AF_INET/__class__/__qualname__/__eq__('AddressFamily')
# socket.SOCK_STREAM/__class__/__qualname__/__eq__('SocketKind')
#
# Wave 252 theme: AF_INET/SOCK_STREAM enum class identity.
#
# socket_extra80 checks __class__.__name__ for AF_INET/SOCK_STREAM; this
# table anchors the __eq__ call form and also __qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra86.enum_member_class_identity:
  description: "socket.AF_INET/__class__/__name__/__eq__('AddressFamily')==True / socket.SOCK_STREAM/__class__/__name__/__eq__('SocketKind')==True / socket.AF_INET/__class__/__qualname__/__eq__('AddressFamily')==True / socket.SOCK_STREAM/__class__/__qualname__/__eq__('SocketKind')==True — AF_INET is an AddressFamily enum member; SOCK_STREAM is a SocketKind enum member; socket_extra80 anchors __class__.__name__ as value; this table anchors __class__.__name__.__eq__ and __class__.__qualname__.__eq__; first __qualname__.__eq__ anchor for AF_INET/SOCK_STREAM class"
  kind: python_call_eq
  category: class_attrs
  id_prefix: sockethier86

  columns: [id, function, args, expected]
  rows:
    - [af_inet_class_name_eq,       AF_INET.__class__.__name__.__eq__,       ["AddressFamily"], true]
    - [sock_stream_class_name_eq,   SOCK_STREAM.__class__.__name__.__eq__,   ["SocketKind"],    true]
    - [af_inet_class_qualname_eq,   AF_INET.__class__.__qualname__.__eq__,   ["AddressFamily"], true]
    - [sock_stream_class_qualname_eq, SOCK_STREAM.__class__.__qualname__.__eq__, ["SocketKind"], true]

# ---------------------------------------------------------------------------
# socket.AddressFamily/__bases__[0]/__name__/__eq__('IntEnum')
# socket.SocketKind/__bases__[0]/__name__/__eq__('IntEnum')
# socket.AddressFamily/__qualname__/__eq__('AddressFamily')
# socket.SocketKind/__qualname__/__eq__('SocketKind')
#
# Wave 252 theme: AddressFamily and SocketKind enum base class identity.
#
# AddressFamily and SocketKind are IntEnum subclasses defined in socket.py.
# socket_extra82 checks __class__.__qualname__ for members but not base classes.
# No prior socket spec checks AddressFamily/__bases__[0]/__name__ or
# SocketKind/__bases__[0]/__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra86.enum_base_class_identity:
  description: "socket.AddressFamily/__bases__[0]/__name__/__eq__('IntEnum')==True / socket.SocketKind/__bases__[0]/__name__/__eq__('IntEnum')==True / socket.AddressFamily/__qualname__/__eq__('AddressFamily')==True / socket.SocketKind/__qualname__/__eq__('SocketKind')==True — AddressFamily and SocketKind both inherit from IntEnum; their __qualname__ equals their class name; no prior socket spec checks __bases__[0].__name__ for AddressFamily/SocketKind; first __bases__[0].__name__.__eq__ and __qualname__.__eq__ anchor for socket.AddressFamily/SocketKind"
  kind: python_call_eq
  category: class_attrs
  id_prefix: sockethier86

  columns: [id, function, args, expected]
  rows:
    - [addr_family_bases_intenum,  "AddressFamily.__bases__[0].__name__.__eq__", ["IntEnum"],         true]
    - [sock_kind_bases_intenum,    "SocketKind.__bases__[0].__name__.__eq__",    ["IntEnum"],         true]
    - [addr_family_qualname_eq,    AddressFamily.__qualname__.__eq__,             ["AddressFamily"],  true]
    - [sock_kind_qualname_eq,      SocketKind.__qualname__.__eq__,                ["SocketKind"],     true]

# ---------------------------------------------------------------------------
# socket.error/__name__/__eq__('OSError')
# socket.timeout/__name__/__eq__('TimeoutError')
# socket.socket/__dict__/__class__/__name__/__eq__('mappingproxy')
# socket.socket/__module__/__eq__('socket')
#
# Wave 252 theme: socket error aliases and dict type identity.
#
# socket.error is an alias for OSError; socket.timeout is an alias for TimeoutError.
# socket.socket.__dict__.__class__.__name__ is 'mappingproxy' (cross-check
# from socket_extra85).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra86.socket_error_aliases_and_dict:
  description: "socket.error/__name__/__eq__('OSError')==True / socket.timeout/__name__/__eq__('TimeoutError')==True / socket.socket/__dict__/__class__/__name__.__eq__('mappingproxy')==True / socket.socket/__module__/__eq__('socket')==True — socket.error is the OSError class (an alias); socket.timeout is the TimeoutError class (an alias); socket.socket.__dict__ is a mappingproxy (cross-check from socket_extra85); socket.socket.__module__ cross-checks the class hierarchy table; no prior socket spec checks socket.error.__name__.__eq__ or socket.timeout.__name__.__eq__; first __name__.__eq__ anchor for socket.error/timeout"
  kind: python_call_eq
  category: class_attrs
  id_prefix: sockethier86

  columns: [id, function, args, expected]
  rows:
    - [socket_error_name_eq,     error.__name__.__eq__,                    ["OSError"],       true]
    - [socket_timeout_name_eq,   timeout.__name__.__eq__,                  ["TimeoutError"],  true]
    - [socket_dict_class_proxy2, socket.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [socket_cls_module_eq2,    socket.__module__.__eq__,                  ["socket"],       true]

# ---------------------------------------------------------------------------
# socket.socket.__mro__.__len__() == 3 — standalone
#
# socket.socket.__mro__ has 3 entries: [socket.socket, _socket.socket, object].
# No prior socket spec checks socket.socket.__mro__.__len__().
# First __mro__.__len__ standalone for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra86.socket_cls_mro_len_3:
  description: "socket.socket.__mro__.__len__() == 3 — socket.socket (Python wrapper) inherits from _socket.socket (C class) which inherits from object; the MRO is [socket.socket, _socket.socket, object] with exactly 3 entries; no prior socket spec checks socket.socket.__mro__.__len__(); first __mro__.__len__ standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: socket.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') — standalone
#
# AddressFamily.__bases__[0].__name__ is 'IntEnum'. No prior socket spec
# checks AddressFamily.__bases__[0].__name__. First __bases__[0].__name__
# standalone for socket.AddressFamily. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra86.addr_family_bases_intenum:
  description: "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') == True — AddressFamily inherits from IntEnum which allows its members to behave as integers; no prior socket spec checks AddressFamily.__bases__[0].__name__; first __bases__[0].__name__ standalone for socket.AddressFamily"
  category: class_attrs
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error.__name__ is 'OSError'. socket.error is an alias for the
# builtin OSError class. No prior socket spec checks socket.error.__name__.__eq__.
# First __name__.__eq__ standalone for socket.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra86.socket_error_name_eq:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is simply the OSError class aliased into the socket module; its __name__ is 'OSError' not 'error'; no prior socket spec checks socket.error.__name__.__eq__; first __name__.__eq__ standalone for socket.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__qualname__.__eq__('socket') — standalone
#
# socket.socket.__qualname__ is 'socket'. socket.socket is the Python wrapper
# class in socket.py whose unqualified name matches the module name.
# No prior socket spec checks socket.socket.__qualname__.__eq__.
# First __qualname__.__eq__ standalone for socket.socket class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra86.socket_cls_qualname_eq:
  description: "socket.socket.__qualname__.__eq__('socket') == True — socket.socket is a top-level class in socket.py whose __qualname__ is just 'socket' (same as the module name); no prior socket spec checks socket.socket.__qualname__.__eq__; first __qualname__.__eq__ standalone for socket.socket class"
  category: class_attrs
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError'. socket.timeout is an alias for
# the builtin TimeoutError class. No prior socket spec checks
# socket.timeout.__name__.__eq__. First __name__.__eq__ standalone for
# socket.timeout. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra86.socket_timeout_name_eq:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout is simply the TimeoutError class aliased into the socket module; its __name__ is 'TimeoutError' not 'timeout'; no prior socket spec checks socket.timeout.__name__.__eq__; first __name__.__eq__ standalone for socket.timeout"
  category: class_attrs
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true
