spec: pp3241
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (pp3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "No pathlib class defines __rtruediv__ in its own __dict__: path objects represent filesystem paths, not numeric types, and do not implement reflected true division."
    - "No pathlib class defines __rfloordiv__ in its own __dict__: path objects do not implement reflected floor division."
    - "No pathlib class defines __rmod__ in its own __dict__: path objects do not implement reflected modulo."
    - "In wave 659, pathlib.PurePath.__truediv__ was True (path joining via /); no reflected division or modulo operators are defined on PurePath or any subclass."
    - "pathlib defines __truediv__ (wave 659) but NOT __rtruediv__, __rfloordiv__, or __rmod__."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "Key finding: decimal.Decimal defines all 3 reflected operators — consistent with wave 662 (__radd__/__rsub__/__rmul__ all true)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rtruediv__ dict-presence — operator.contains(Cls.__dict__, '__rtruediv__')
#
# No pathlib class defines __rtruediv__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths, not numeric operands.
# Contrast with __truediv__ (wave 659) which PurePath does define.
# ---------------------------------------------------------------------------

table pp3241.rtruediv:
  description: "pathlib types __rtruediv__ dict-presence checks; wave 663"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3241

  columns: [id, function, args, expected]
  rows:
    - ["pp3241001", operator.contains, [pathlib.PurePath.__dict__,         "__rtruediv__"], false]
    - ["pp3241002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__rtruediv__"], false]
    - ["pp3241003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__rtruediv__"], false]
    - ["pp3241004", operator.contains, [pathlib.Path.__dict__,             "__rtruediv__"], false]
    - ["pp3241005", operator.contains, [pathlib.PosixPath.__dict__,        "__rtruediv__"], false]

