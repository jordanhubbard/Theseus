spec: multiprocessing_extra29
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra28.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() for map/apply/close/terminate/join/apply_async/map_async/starmap/imap, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/AuthenticationError/ProcessError __mro__.__len__()."
    - "This spec covers: multiprocessing.__all__.__len__() and __class__.__name__.__len__(); class __dict__.__class__.__name__.__len__() for Process/AuthenticationError/ProcessError; Pool additional method __qualname__.__len__() for starmap_async/imap_unordered; cpu_count.__qualname__.__len__(); BufferTooShort/__mro__.__len__() and multiprocessing.TimeoutError/__mro__.__len__(); multiprocessing.TimeoutError/__bases__[0].__name__."
    - "multiprocessing.__all__ is a list — __class__.__name__ == 'list', __len__() == 4."
    - "multiprocessing.__all__.__len__() == 37 — the module exports 37 public names."
    - "Process.__dict__.__class__.__name__.__len__() == 12 — mappingproxy."
    - "Pool.starmap_async.__qualname__ == 'Pool.starmap_async' — length 18."
    - "Pool.imap_unordered.__qualname__ == 'Pool.imap_unordered' — length 19."
    - "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' — length 21 (context-bound method)."
    - "BufferTooShort.__mro__.__len__() == 5 — [BufferTooShort, ProcessError, Exception, BaseException, object]."
    - "multiprocessing.TimeoutError.__mro__.__len__() == 5 — [TimeoutError, ProcessError, Exception, BaseException, object]."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError' — subclasses ProcessError, not built-in TimeoutError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__all__ metadata — extra29 namespace
#
# multiprocessing.__all__ is a list (not a tuple).
# __class__.__name__ == 'list' (4 chars); __len__() == 37.
# The 37 public names reflect multiprocessing's broad API surface.
# Prior specs have not measured __all__ metadata for multiprocessing.
# ---------------------------------------------------------------------------

table multiprocessing_extra29.all_metadata:
  description: "multiprocessing.__all__ metadata: list type name length and export count in extra29 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: allmetadata29

  columns: [id, function, args, expected]
  rows:
    - [all_class_name_len, multiprocessing.__all__.__class__.__name__.__len__, [], 4]
    - [all_len,            multiprocessing.__all__.__len__,                    [], 37]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() table — extra29 namespace
#
# Pure-Python multiprocessing classes have __dict__ of type mappingproxy.
# 'mappingproxy' has 12 characters. Measured: Process, AuthenticationError,
# ProcessError — all yield 12. Prior specs have not measured this for
# multiprocessing classes.
# ---------------------------------------------------------------------------

table multiprocessing_extra29.class_dict_class_name_lengths:
  description: "multiprocessing class __dict__.__class__.__name__.__len__() for Process/AuthenticationError/ProcessError in extra29 namespace"
  kind: python_call_eq
  category: class_structure
  id_prefix: classdictnamelen29

  columns: [id, function, args, expected]
  rows:
    - [Process,             Process.__dict__.__class__.__name__.__len__,             [], 12]
    - [AuthenticationError, AuthenticationError.__dict__.__class__.__name__.__len__, [], 12]
    - [ProcessError,        ProcessError.__dict__.__class__.__name__.__len__,        [], 12]

# ---------------------------------------------------------------------------
# Pool extended method __qualname__ length table — extra29 namespace
#
# Prior spec (extra28) covered Pool map/apply/close/terminate/join and
# apply_async/map_async/starmap/imap. This table extends to the two
# remaining bulk-dispatch methods:
#   Pool.starmap_async.__qualname__ == 'Pool.starmap_async' (18)
#   Pool.imap_unordered.__qualname__ == 'Pool.imap_unordered' (19)
# starmap_async handles async mapped calls on iterables of argument tuples;
# imap_unordered returns results in completion order rather than input order.
# ---------------------------------------------------------------------------

table multiprocessing_extra29.pool_extended_method_qualname_lengths:
  description: "multiprocessing Pool extended method __qualname__ lengths for starmap_async/imap_unordered in extra29 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: poolextmqualnamelen29

  columns: [id, function, args, expected]
  rows:
    - [starmap_async,  Pool.starmap_async.__qualname__.__len__,  [], 18]
    - [imap_unordered, Pool.imap_unordered.__qualname__.__len__, [], 19]

# ---------------------------------------------------------------------------
# Exception __mro__.__len__() table for BufferTooShort and TimeoutError — extra29
#
# Prior spec (extra28) covered AuthenticationError (5) and ProcessError (4).
# This table extends to the two remaining multiprocessing exception classes:
#   BufferTooShort.__mro__.__len__() == 5
#     — [BufferTooShort, ProcessError, Exception, BaseException, object]
#   multiprocessing.TimeoutError.__mro__.__len__() == 5
#     — [TimeoutError, ProcessError, Exception, BaseException, object]
# Note: multiprocessing.TimeoutError is distinct from the built-in TimeoutError.
# Both exceptions share MRO depth 5 by sitting one level below ProcessError.
# ---------------------------------------------------------------------------

table multiprocessing_extra29.exception_mro_lengths:
  description: "multiprocessing exception __mro__.__len__() for BufferTooShort/TimeoutError in extra29 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excmrolen29

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [BufferTooShort, BufferTooShort.__mro__, [], !ascii "", __len__, [], "BufferTooShort MRO depth == 5"]
    - [TimeoutError,   TimeoutError.__mro__,   [], !ascii "", __len__, [], "multiprocessing.TimeoutError MRO depth == 5"]

# ---------------------------------------------------------------------------
# multiprocessing.TimeoutError __bases__[0].__name__ — extra29 namespace
#
# multiprocessing.TimeoutError subclasses ProcessError — NOT the built-in
# OSError-derived TimeoutError. This distinguishes it from
# concurrent.futures.TimeoutError (which subclasses OSError).
# Prior spec (extra28) covered AuthenticationError/ProcessError/BufferTooShort
# __bases__[0].__name__; this invariant adds TimeoutError.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra29.TimeoutError_base_name_eq:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError' — subclasses ProcessError, not built-in OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

# ---------------------------------------------------------------------------
# cpu_count __qualname__ length — extra29 standalone invariant
#
# multiprocessing.cpu_count is a context-bound method; its __qualname__ is
# 'BaseContext.cpu_count' (21 chars), reflecting that it is defined on
# BaseContext and dispatched through the default context. Prior specs
# measured the __qualname__ string itself; this invariant confirms the length.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra29.cpu_count_qualname_len:
  description: "multiprocessing.cpu_count.__qualname__.__len__() == 21 — 'BaseContext.cpu_count' context-bound method"
  category: method_names
  kind: python_call_eq
  function: cpu_count.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra29.all_len:
  description: "multiprocessing.__all__.__len__() == 37 — the module exports 37 public names"
  category: module_structure
  kind: python_call_eq
  function: multiprocessing.__all__.__len__
  args: []
  expected: 37

invariant multiprocessing_extra29.Pool_starmap_async_qualname_len:
  description: "multiprocessing.pool.Pool.starmap_async.__qualname__.__len__() == 18 — 'Pool.starmap_async' has eighteen characters"
  category: method_names
  kind: python_call_eq
  function: Pool.starmap_async.__qualname__.__len__
  args: []
  expected: 18
