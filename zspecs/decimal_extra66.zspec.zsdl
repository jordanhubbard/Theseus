spec: decimal_extra66
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras through decimal_extra7."
    - "Prior specs covered: Decimal arithmetic (__add__/__sub__/__mul__/__truediv__/__abs__/__neg__); comparisons (__lt__/__le__/__gt__/__ge__/__eq__); copy_abs/copy_negate; __int__ conversion; Context/InvalidOperation/DecimalException modules; rounding constants; exception class __qualname__; getcontext/setcontext/localcontext identity; MAX_PREC/MAX_EMAX; Decimal.__module__."
    - "This spec covers: Decimal.__dict__ membership for arithmetic dunder methods; Decimal.__dict__.__class__.__name__; getcontext docstring class and content; setcontext class name and module."
    - "Decimal.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy."
    - "Decimal.__dict__.__contains__('__add__') == True — Decimal defines __add__ in C."
    - "Decimal.__dict__.__contains__('__sub__') == True."
    - "Decimal.__dict__.__contains__('__mul__') == True."
    - "Decimal.__dict__.__contains__('__repr__') == True."
    - "getcontext.__doc__.__class__.__name__ == 'str' — getcontext has a docstring."
    - "getcontext.__doc__.__contains__('context') == True — docstring mentions context."
    - "setcontext.__class__.__name__ == 'builtin_function_or_method' — setcontext is a C builtin."
    - "setcontext.__module__ == '_decimal' — setcontext is implemented in the _decimal C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership checks
# The Decimal C type defines arithmetic dunder methods; they appear in its
# __dict__. No prior decimal spec checks __dict__ membership.
# ---------------------------------------------------------------------------

table decimal_extra66.Decimal_dict_contains:
  description: "Decimal.__dict__ contains its C-implemented arithmetic and repr methods"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore66

  columns: [id, function, args, expected]
  rows:
    - [has_add,  "Decimal.__dict__.__contains__", ["__add__"],  true]
    - [has_sub,  "Decimal.__dict__.__contains__", ["__sub__"],  true]
    - [has_mul,  "Decimal.__dict__.__contains__", ["__mul__"],  true]
    - [has_repr, "Decimal.__dict__.__contains__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ class name — mappingproxy
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra66.Decimal_dict_class:
  description: "Decimal.__dict__ is a mappingproxy"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore66

  columns: [id, function, args, expected]
  rows:
    - [mappingproxy, Decimal.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# getcontext docstring — class name and content
# decimal_extra3 covers getcontext.__name__ and __module__.
# No prior spec checks getcontext.__doc__.
# ---------------------------------------------------------------------------

table decimal_extra66.getcontext_doc:
  description: "getcontext has a str docstring that mentions 'context'"
  kind: python_call_eq
  category: docstrings
  id_prefix: decimalmore66

  columns: [id, function, args, expected]
  rows:
    - [doc_class,   getcontext.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [doc_context, getcontext.__doc__.__contains__,              ["context"], true]

# ---------------------------------------------------------------------------
# setcontext class name and module
# decimal_extra3 covers setcontext.__name__ and __qualname__.
# No prior spec checks setcontext.__class__.__name__ or setcontext.__module__.
# setcontext is implemented in the _decimal C extension.
# ---------------------------------------------------------------------------

table decimal_extra66.setcontext_identity:
  description: "setcontext is a builtin from the _decimal C extension"
  kind: python_call_eq
  category: function_identity
  id_prefix: decimalmore66

  columns: [id, function, args, expected]
  rows:
    - [class_name, setcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [module,     setcontext.__module__.__eq__,         ["_decimal"],                   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra66.Decimal_dict.has_add:
  description: "Decimal.__dict__ contains '__add__' — Decimal defines addition in C"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__add__"]
  expected: true

invariant decimal_extra66.Decimal_dict.mappingproxy:
  description: "Decimal.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: Decimal.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant decimal_extra66.getcontext_doc.str:
  description: "getcontext.__doc__.__class__.__name__ == 'str' — docstring is a str"
  category: docstrings
  kind: python_call_eq
  function: getcontext.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra66.getcontext_doc.context:
  description: "getcontext.__doc__.__contains__('context') == True — docstring mentions context"
  category: docstrings
  kind: python_call_eq
  function: getcontext.__doc__.__contains__
  args: ["context"]
  expected: true

invariant decimal_extra66.setcontext.class_builtin:
  description: "setcontext.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
