spec: inspect_extra232
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.Parameter kind constants: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' (len=14) — all kind constants are _ParameterKind enum members. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' (len=15); value == 0. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' (len=21); value == 1. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL' (len=14); value == 2. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY' (len=12); value == 3. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD' (len=11); value == 4. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' (len=9) — the Parameter class name. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' (len=7) — defined in the inspect module. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter.POSITIONAL_ONLY and POSITIONAL_OR_KEYWORD contracts
#
# Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' (len=15), value == 0
# Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' (len=21), value == 1
# Both are _ParameterKind enum members
#
# New to extra232.
# ---------------------------------------------------------------------------

table inspect_extra232.positional_kind_constants:
  description: "inspect.Parameter POSITIONAL_ONLY and POSITIONAL_OR_KEYWORD kind constant contracts: name, value, class; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra232poskinds

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_eq,
       "Parameter.POSITIONAL_ONLY.name.__eq__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY is a _ParameterKind enum constant; its .name attribute is 'POSITIONAL_ONLY' (len=15); new to extra232"]
    - [positional_only_value_eq,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY has integer value 0; it is the first kind in the _ParameterKind enum; new to extra232"]
    - [positional_only_class_eq,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of the _ParameterKind enum; __class__.__name__ is '_ParameterKind' (len=14); new to extra232"]
    - [positional_or_keyword_name_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.name.__eq__",
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — POSITIONAL_OR_KEYWORD is a _ParameterKind enum constant; its .name attribute is 'POSITIONAL_OR_KEYWORD' (len=21); new to extra232"]
    - [positional_or_keyword_value_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD has integer value 1; it is the second kind in the _ParameterKind enum; new to extra232"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.VAR_POSITIONAL and KEYWORD_ONLY contracts
#
# Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL' (len=14), value == 2
# Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY' (len=12), value == 3
# Both are _ParameterKind enum members
#
# New to extra232.
# ---------------------------------------------------------------------------

table inspect_extra232.var_keyword_kind_constants:
  description: "inspect.Parameter VAR_POSITIONAL and KEYWORD_ONLY kind constant contracts: name, value; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra232varkey

  columns: [id, function, args, expected, description]
  rows:
    - [var_positional_name_eq,
       "Parameter.VAR_POSITIONAL.name.__eq__",
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL is a _ParameterKind enum constant for *args parameters; its .name is 'VAR_POSITIONAL' (len=14); new to extra232"]
    - [var_positional_value_eq,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL has integer value 2; it is the third kind in the _ParameterKind enum; new to extra232"]
    - [keyword_only_name_eq,
       "Parameter.KEYWORD_ONLY.name.__eq__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — KEYWORD_ONLY is a _ParameterKind enum constant for keyword-only parameters after *args; its .name is 'KEYWORD_ONLY' (len=12); new to extra232"]
    - [keyword_only_value_eq,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY has integer value 3; it is the fourth kind in the _ParameterKind enum; new to extra232"]
    - [var_keyword_name_eq,
       "Parameter.VAR_KEYWORD.name.__eq__",
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — VAR_KEYWORD is a _ParameterKind enum constant for **kwargs parameters; its .name is 'VAR_KEYWORD' (len=11); new to extra232"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.VAR_KEYWORD value and Parameter class identity
#
# Parameter.VAR_KEYWORD.value == 4
# Parameter.__name__ == 'Parameter' (len=9)
# Parameter.__module__ == 'inspect' (len=7)
# Parameter.__class__.__name__ == 'type'
# Parameter.POSITIONAL_ONLY.__class__.__name__.__len__() == 14
#
# New to extra232.
# ---------------------------------------------------------------------------

table inspect_extra232.parameter_class_identity:
  description: "inspect.Parameter VAR_KEYWORD value and Parameter class identity contracts; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra232paramclassid

  columns: [id, function, args, expected, description]
  rows:
    - [var_keyword_value_eq,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD has integer value 4; it is the fifth and final kind in the _ParameterKind enum; new to extra232"]
    - [parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is the class in inspect that describes a single parameter in a function signature; __name__ is 'Parameter' (len=9); new to extra232"]
    - [parameter_name_len_9,
       Parameter.__name__.__len__,
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has exactly 9 characters (P-a-r-a-m-e-t-e-r); str.__len__() returns 9; new to extra232"]
    - [parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in the inspect module (Lib/inspect.py); __module__ is 'inspect' (len=7); new to extra232"]
    - [parameter_class_is_type,
       Parameter.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; new to extra232"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra232
# ---------------------------------------------------------------------------

invariant inspect_extra232.positional_only_name_eq:
  description: "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'; new to extra232"
  kind: python_call_eq
  function: "Parameter.POSITIONAL_ONLY.name.__eq__"
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra232.positional_only_value_eq:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0; new to extra232"
  kind: python_call_eq
  function: "Parameter.POSITIONAL_ONLY.value.__eq__"
  args: [0]
  expected: true

invariant inspect_extra232.positional_only_class_eq:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'; new to extra232"
  kind: python_call_eq
  function: "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra232.positional_or_keyword_name_eq:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD'; new to extra232"
  kind: python_call_eq
  function: "Parameter.POSITIONAL_OR_KEYWORD.name.__eq__"
  args: ["POSITIONAL_OR_KEYWORD"]
  expected: true

invariant inspect_extra232.positional_or_keyword_value_eq:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1; new to extra232"
  kind: python_call_eq
  function: "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__"
  args: [1]
  expected: true

invariant inspect_extra232.var_positional_name_eq:
  description: "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'; new to extra232"
  kind: python_call_eq
  function: "Parameter.VAR_POSITIONAL.name.__eq__"
  args: ["VAR_POSITIONAL"]
  expected: true

invariant inspect_extra232.var_positional_value_eq:
  description: "inspect.Parameter.VAR_POSITIONAL.value == 2; new to extra232"
  kind: python_call_eq
  function: "Parameter.VAR_POSITIONAL.value.__eq__"
  args: [2]
  expected: true

invariant inspect_extra232.keyword_only_name_eq:
  description: "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'; new to extra232"
  kind: python_call_eq
  function: "Parameter.KEYWORD_ONLY.name.__eq__"
  args: ["KEYWORD_ONLY"]
  expected: true

invariant inspect_extra232.keyword_only_value_eq:
  description: "inspect.Parameter.KEYWORD_ONLY.value == 3; new to extra232"
  kind: python_call_eq
  function: "Parameter.KEYWORD_ONLY.value.__eq__"
  args: [3]
  expected: true

invariant inspect_extra232.var_keyword_name_eq:
  description: "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'; new to extra232"
  kind: python_call_eq
  function: "Parameter.VAR_KEYWORD.name.__eq__"
  args: ["VAR_KEYWORD"]
  expected: true

invariant inspect_extra232.var_keyword_value_eq:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4; new to extra232"
  kind: python_call_eq
  function: "Parameter.VAR_KEYWORD.value.__eq__"
  args: [4]
  expected: true

invariant inspect_extra232.parameter_name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter' (len=9); new to extra232"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra232.parameter_module_eq:
  description: "inspect.Parameter.__module__ == 'inspect'; new to extra232"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true
