spec: uuid_extra378
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID.__slots__ == ('int', 'is_safe', '__weakref__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__.__class__.__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex is a property; UUID.hex.fget.__name__ == 'hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version is a property; UUID.version.fget.__name__ == 'version'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes is a property; UUID.bytes.fget.__name__ == 'bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le is a property; UUID.bytes_le.fget.__name__ == 'bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node is a property; UUID.node.fget.__name__ == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time is a property; UUID.time.fget.__name__ == 'time'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int is a member_descriptor (slot), not a property. UUID.__slots__ = ('int', 'is_safe', '__weakref__'). The 128-bit integer is stored directly in the slot for efficiency."
    - "Note: All other UUID attributes (hex, version, bytes, bytes_le, fields, time, node, clock_seq) are Python properties with fget functions whose __name__ matches the attribute name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__ — slot membership and identity
# uuid.UUID property fget.__name__ values
#
# Wave 378 theme: uuid.UUID class internals — __slots__ and property identity.
#
# uuid.UUID uses __slots__ = ('int', 'is_safe', '__weakref__') to store the
# 128-bit integer value efficiently. This means uuid.UUID.int is a
# member_descriptor (not a property), while all computed attributes (hex,
# bytes, version, node, time, etc.) are Python properties defined with
# @property decorators in Lib/uuid.py.
#
# For properties, fget.__name__ matches the attribute name exactly because
# the property getter function is defined with def <name>(self) in the
# class body.
#
# uuid.UUID.__slots__ is a tuple of three strings: 'int', 'is_safe', and
# '__weakref__'. Its __class__ is 'tuple'.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra378.uuid_class_name:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID is defined as class UUID in Lib/uuid.py; pure-Python class representing an RFC 4122 UUID; __name__ is 'UUID'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra378.uuid_class_module:
  description: "uuid.UUID.__module__.__eq__('uuid') == True — UUID class is defined in Lib/uuid.py (pure Python, not a C extension); __module__ is 'uuid'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra378.uuid_slots_class_name:
  description: "uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') == True — UUID.__slots__ is a tuple of strings ('int', 'is_safe', '__weakref__'); storing the 128-bit int as a slot avoids __dict__ overhead; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

table hashlib_extra378.uuid_slots_membership:
  description: "uuid.UUID.__slots__ contains 'int' and 'is_safe' — the 128-bit UUID integer is stored as a slot descriptor for efficiency; is_safe indicates whether the UUID was generated safely (RFC 4122 §6.1); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: set_membership
  id_prefix: uuidslots378

  columns: [id, function, args, expected]
  rows:
    - [int_in_slots,    UUID.__slots__.__contains__, ["int"],       true]
    - [is_safe_in_slots, UUID.__slots__.__contains__, ["is_safe"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID property fget.__name__ values
#
# Most UUID attributes are Python properties. The getter function for each
# property has a __name__ matching the attribute name, because they are defined
# with def <name>(self): in the class body and then wrapped with @property.
#
# hex: returns the UUID as a 32-char lowercase hex string (no hyphens).
# bytes: returns the UUID as a 16-byte big-endian bytes object.
# bytes_le: returns the UUID as 16 bytes in little-endian (Windows GUID order).
# node: returns the 48-bit hardware address (bits 0-47 of the UUID integer).
# time: returns the 60-bit timestamp field for version-1 UUIDs.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra378.property_fget_names:
  description: "uuid.UUID property fget.__name__ values match the attribute name — hex/bytes/bytes_le/node/time are all Python properties in Lib/uuid.py; fget.__name__ equals the attribute name exactly; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidpropfget378

  columns: [id, function, args, expected]
  rows:
    - [hex_fget,      UUID.hex.fget.__name__.__eq__,      ["hex"],      true]
    - [bytes_fget,    UUID.bytes.fget.__name__.__eq__,    ["bytes"],    true]
    - [bytes_le_fget, UUID.bytes_le.fget.__name__.__eq__, ["bytes_le"], true]
    - [node_fget,     UUID.node.fget.__name__.__eq__,     ["node"],     true]
    - [time_fget,     UUID.time.fget.__name__.__eq__,     ["time"],     true]
