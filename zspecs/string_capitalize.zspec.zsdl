spec: string_capitalize
version: ">=1.0.1"
backend: node(string-capitalize)

docs: https://www.npmjs.com/package/string-capitalize

provenance:
  derived_from:
    - "string-capitalize README — https://www.npmjs.com/package/string-capitalize"
    - "Test vectors verified with string-capitalize via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "string-capitalize source"
  notes:
    - "string-capitalize is an npm package. Install: npm install string-capitalize"
    - "Capitalizes the first character of a string (sentence case, not title case)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_capitalize.capitalize:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: strcap

  columns: [id, args, expected]
  rows:
    - [sentence,    ["hello world"],  "Hello world"]
    - [already_cap, ["Hello World"],  "Hello world"]
    - [single_word, ["foo"],          "Foo"]
    - [single_char, ["a"],            "A"]
