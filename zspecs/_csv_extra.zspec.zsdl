spec: _csv_extra
version: ">=3.9"
backend: python_module(_csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
  notes:
    - "This spec extends csv.zspec.zsdl, csv_extra.zspec.zsdl, csv_extra2.zspec.zsdl, and csv_extra3.zspec.zsdl."
    - "The _csv module is the C accelerator for the csv stdlib module."
    - "_csv.reader and _csv.writer are C-extension callable types; __name__ reflects the type name."
    - "_csv.Dialect is the abstract base class for all CSV dialects; __name__ == 'Dialect'."
    - "_csv.Error.__name__ == 'Error' and it subclasses Exception directly."
    - "_csv.Error.__bases__[0].__name__ == 'Exception' — direct subclass of Exception."
    - "QUOTE_ALL==1, QUOTE_MINIMAL==0, QUOTE_NONNUMERIC==2, QUOTE_NONE==3 are plain int values."
    - "All QUOTE_* constants are instances of int: __class__.__name__ == 'int'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Callable/type __name__ — reader and writer
# ---------------------------------------------------------------------------

invariant _csv_extra.reader.__name__:
  description: "_csv.reader.__name__ == 'reader'"
  category: identity
  kind: python_call_eq
  function: reader.__name__.__eq__
  args: ["reader"]
  expected: true

invariant _csv_extra.writer.__name__:
  description: "_csv.writer.__name__ == 'writer'"
  category: identity
  kind: python_call_eq
  function: writer.__name__.__eq__
  args: ["writer"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ — Dialect and Error
# ---------------------------------------------------------------------------

invariant _csv_extra.Dialect.__name__:
  description: "_csv.Dialect.__name__ == 'Dialect'"
  category: identity
  kind: python_call_eq
  function: Dialect.__name__.__eq__
  args: ["Dialect"]
  expected: true

invariant _csv_extra.Error.__name__:
  description: "_csv.Error.__name__ == 'Error'"
  category: identity
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — Error subclasses Exception
# ---------------------------------------------------------------------------

invariant _csv_extra.Error.base_is_Exception:
  description: "_csv.Error.__bases__[0].__name__ == 'Exception' — Error inherits directly from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# QUOTE_* constants — exact integer values
# ---------------------------------------------------------------------------

invariant _csv_extra.QUOTE_ALL.value:
  description: "_csv.QUOTE_ALL == 1"
  category: constants
  kind: python_call_eq
  function: QUOTE_ALL.__eq__
  args: [1]
  expected: true

invariant _csv_extra.QUOTE_MINIMAL.value:
  description: "_csv.QUOTE_MINIMAL == 0"
  category: constants
  kind: python_call_eq
  function: QUOTE_MINIMAL.__eq__
  args: [0]
  expected: true

invariant _csv_extra.QUOTE_NONNUMERIC.value:
  description: "_csv.QUOTE_NONNUMERIC == 2"
  category: constants
  kind: python_call_eq
  function: QUOTE_NONNUMERIC.__eq__
  args: [2]
  expected: true

invariant _csv_extra.QUOTE_NONE.value:
  description: "_csv.QUOTE_NONE == 3"
  category: constants
  kind: python_call_eq
  function: QUOTE_NONE.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_* constants — class type is int
# ---------------------------------------------------------------------------

table _csv_extra.quote_class_types:
  kind: python_call_eq
  category: constants
  id_prefix: qtype

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_ALL,         QUOTE_ALL.__class__.__name__.__eq__,         ["int"], true]
    - [QUOTE_MINIMAL,     QUOTE_MINIMAL.__class__.__name__.__eq__,     ["int"], true]
    - [QUOTE_NONNUMERIC,  QUOTE_NONNUMERIC.__class__.__name__.__eq__,  ["int"], true]
    - [QUOTE_NONE,        QUOTE_NONE.__class__.__name__.__eq__,        ["int"], true]

# ---------------------------------------------------------------------------
# Module affiliation — classes and callables report __module__ == '_csv'
# ---------------------------------------------------------------------------

table _csv_extra.class_modules:
  kind: python_call_eq
  category: identity
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [reader,  reader.__module__.__eq__,  ["_csv"], true]
    - [writer,  writer.__module__.__eq__,  ["_csv"], true]
    - [Dialect, Dialect.__module__.__eq__, ["_csv"], true]
    - [Error,   Error.__module__.__eq__,   ["_csv"], true]
