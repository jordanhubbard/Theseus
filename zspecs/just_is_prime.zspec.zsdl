spec: just_is_prime
version: ">=2.3.0"
backend: node(just-is-prime)

docs: https://www.npmjs.com/package/just-is-prime

provenance:
  derived_from:
    - "just-is-prime README — https://www.npmjs.com/package/just-is-prime"
    - "Test vectors verified with just-is-prime via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-is-prime source"
  notes:
    - "just-is-prime is an npm package. Install: npm install just-is-prime"
    - "Returns true if the given number is a prime number."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_is_prime.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: jisp

  columns: [id, args, expected]
  rows:
    - [prime,       [7],  true]
    - [not_prime,   [9],  false]
    - [smallest,    [2],  true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
