spec: abc_extra259
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.AsyncIterator.__name__ == 'AsyncIterator'; inherits from AsyncIterable."
    - "AsyncIterator has exactly one abstract method: __anext__."
    - "collections.abc.AsyncIterable.__name__ == 'AsyncIterable'; inherits from object."
    - "AsyncIterable has exactly one abstract method: __aiter__."
    - "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator'; inherits from AsyncIterator."
    - "AsyncGenerator has exactly two abstract methods: asend and athrow."
    - "All three classes have __module__ == 'collections.abc'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.AsyncIterator — class identity and abstract methods
#
# AsyncIterator inherits from AsyncIterable. It has exactly one abstract
# method: __anext__.
# ---------------------------------------------------------------------------

invariant abc_extra259.async_iterator.name:
  description: "collections.abc.AsyncIterator.__name__ == 'AsyncIterator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__name__.__eq__
  args: ["AsyncIterator"]
  expected: true

invariant abc_extra259.async_iterator.module:
  description: "collections.abc.AsyncIterator.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra259.async_iterator.base:
  description: "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AsyncIterable"

invariant abc_extra259.async_iterator.abstractmethods_anext:
  description: "collections.abc.AsyncIterator.__abstractmethods__ contains '__anext__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__abstractmethods__.__contains__
  args: ["__anext__"]
  expected: true

invariant abc_extra259.async_iterator.abstractmethods_count:
  description: "len(collections.abc.AsyncIterator.__abstractmethods__) == 1"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__abstractmethods__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# collections.abc.AsyncIterable — class identity and abstract methods
#
# AsyncIterable inherits from object. It has exactly one abstract method:
# __aiter__.
# ---------------------------------------------------------------------------

invariant abc_extra259.async_iterable.name:
  description: "collections.abc.AsyncIterable.__name__ == 'AsyncIterable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterable.__name__.__eq__
  args: ["AsyncIterable"]
  expected: true

invariant abc_extra259.async_iterable.module:
  description: "collections.abc.AsyncIterable.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra259.async_iterable.base:
  description: "collections.abc.AsyncIterable.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra259.async_iterable.abstractmethods_aiter:
  description: "collections.abc.AsyncIterable.__abstractmethods__ contains '__aiter__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterable.__abstractmethods__.__contains__
  args: ["__aiter__"]
  expected: true

invariant abc_extra259.async_iterable.abstractmethods_count:
  description: "len(collections.abc.AsyncIterable.__abstractmethods__) == 1"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterable.__abstractmethods__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# collections.abc.AsyncGenerator — class identity and abstract methods
#
# AsyncGenerator inherits from AsyncIterator. It has exactly two abstract
# methods: asend and athrow.
# ---------------------------------------------------------------------------

invariant abc_extra259.async_generator.name:
  description: "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__name__.__eq__
  args: ["AsyncGenerator"]
  expected: true

invariant abc_extra259.async_generator.module:
  description: "collections.abc.AsyncGenerator.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra259.async_generator.base:
  description: "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AsyncIterator"

invariant abc_extra259.async_generator.abstractmethods_asend:
  description: "collections.abc.AsyncGenerator.__abstractmethods__ contains 'asend'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__abstractmethods__.__contains__
  args: ["asend"]
  expected: true

invariant abc_extra259.async_generator.abstractmethods_athrow:
  description: "collections.abc.AsyncGenerator.__abstractmethods__ contains 'athrow'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__abstractmethods__.__contains__
  args: ["athrow"]
  expected: true

invariant abc_extra259.async_generator.abstractmethods_count:
  description: "len(collections.abc.AsyncGenerator.__abstractmethods__) == 2"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__abstractmethods__.__len__
  args: []
  expected: 2
