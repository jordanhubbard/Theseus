spec: uuid_extra282
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID field accessor properties"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "UUID field accessors time_low through node are property descriptors"
    - "uuid.UUID.int is a member_descriptor (confirmed in wave 453d)"
    - "urn, is_safe, hex, bytes, bytes_le, fields, variant, version are all property descriptors"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra282.uuid_field_accessor_properties:
  description: "UUID field accessor property class names (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node, time, clock_seq)"
  kind: python_call_eq
  category: identity
  id_prefix: uuid282a

  columns: [id, function, args, expected, description]
  rows:
    - [uuid282a001, uuid.UUID.time_low.__class__.__name__, [], "property", "UUID.time_low is a property"]
    - [uuid282a002, uuid.UUID.time_mid.__class__.__name__, [], "property", "UUID.time_mid is a property"]
    - [uuid282a003, uuid.UUID.time_hi_version.__class__.__name__, [], "property", "UUID.time_hi_version is a property"]
    - [uuid282a004, uuid.UUID.clock_seq_hi_variant.__class__.__name__, [], "property", "UUID.clock_seq_hi_variant is a property"]
    - [uuid282a005, uuid.UUID.clock_seq_low.__class__.__name__, [], "property", "UUID.clock_seq_low is a property"]
    - [uuid282a006, uuid.UUID.node.__class__.__name__, [], "property", "UUID.node is a property"]
    - [uuid282a007, uuid.UUID.time.__class__.__name__, [], "property", "UUID.time is a property"]
    - [uuid282a008, uuid.UUID.clock_seq.__class__.__name__, [], "property", "UUID.clock_seq is a property"]

table uuid_extra282.uuid_more_property_class_names:
  description: "Additional UUID property class names (urn, is_safe, hex, bytes, bytes_le, fields, variant, version)"
  kind: python_call_eq
  category: identity
  id_prefix: uuid282b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid282b001, uuid.UUID.urn.__class__.__name__, [], "property", "UUID.urn is a property"]
    - [uuid282b002, uuid.UUID.is_safe.__class__.__name__, [], "property", "UUID.is_safe is a property"]
    - [uuid282b003, uuid.UUID.hex.__class__.__name__, [], "property", "UUID.hex is a property"]
    - [uuid282b004, uuid.UUID.bytes.__class__.__name__, [], "property", "UUID.bytes is a property"]
    - [uuid282b005, uuid.UUID.bytes_le.__class__.__name__, [], "property", "UUID.bytes_le is a property"]
    - [uuid282b006, uuid.UUID.fields.__class__.__name__, [], "property", "UUID.fields is a property"]
    - [uuid282b007, uuid.UUID.variant.__class__.__name__, [], "property", "UUID.variant is a property"]
    - [uuid282b008, uuid.UUID.version.__class__.__name__, [], "property", "UUID.version is a property"]

invariant uuid_extra282.uuid_int_member_descriptor:
  description: "UUID.int is a member_descriptor (not a property)"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.int.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant uuid_extra282.uuid_time_low_is_property:
  description: "UUID.time_low class name equals 'property'"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.time_low.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant uuid_extra282.uuid_urn_is_property:
  description: "UUID.urn class name equals 'property'"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.urn.__class__.__name__.__eq__
  args: ["property"]
  expected: true
