spec: fractions_extra12
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra11)."
    - "fractions_extra11 covers Fraction(2,4) auto-reduction, Fraction(3,1).__eq__(3), Fraction('3/4'), float constructor."
    - "No prior spec covers Fraction(1,2).__add__(1) numerator == 3 (sum 3/2)."
    - "No prior spec covers Fraction(1,2).__mul__(2) == 1 (product is integer 1)."
    - "No prior spec covers Fraction(3,4).__gt__(0) == True (positive fraction > 0)."
    - "No prior spec covers Fraction(1,4).__lt__(1) == True (fraction < 1)."
    - "No prior spec covers Fraction(1,2).__abs__() numerator == 1."
    - "No prior spec covers Fraction(-3,4).__abs__() numerator == 3 and denominator == 4."
    - "No prior spec covers Fraction(22,7).__floor__() == 3."
    - "No prior spec covers Fraction(22,7).__ceil__() == 4."
    - "Fraction(1,2).__add__(1) == 3/2: 1/2 + 2/2 = 3/2, numerator is 3."
    - "Fraction(1,2).__mul__(2) == 1: 1/2 * 2 = 1, numerator is 1."
    - "Fraction(3,4).__gt__(0) == True: 0.75 > 0."
    - "Fraction(1,4).__lt__(1) == True: 0.25 < 1."
    - "Fraction(1,2).__abs__() == 1/2: abs of positive fraction is itself, numerator is 1."
    - "Fraction(-3,4).__abs__() == 3/4: abs of negative fraction strips sign, numerator is 3."
    - "Fraction(22,7).__floor__() == 3: floor(22/7) = floor(3.142...) = 3."
    - "Fraction(22,7).__ceil__() == 4: ceil(22/7) = ceil(3.142...) = 4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __add__ — addition of a Fraction and an integer
#
# Fraction(1,2).__add__(1) == 3/2 (1/2 + 2/2 = 3/2).
# Integer method_args are accepted and auto-converted.
# We check the numerator of the result.
# No prior spec covers __add__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.add_half_plus_one_numerator:
  description: "Fraction(1,2).__add__(1).numerator == 3 — 1/2 + 1 = 3/2, numerator is 3"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __add__
  method_args: [1]
  method_chain: numerator
  expected: 3

invariant fractions_extra12.Fraction.add_half_plus_one_denominator:
  description: "Fraction(1,2).__add__(1).denominator == 2 — 1/2 + 1 = 3/2, denominator is 2"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __add__
  method_args: [1]
  method_chain: denominator
  expected: 2

# ---------------------------------------------------------------------------
# __mul__ — multiplication of a Fraction and an integer
#
# Fraction(1,2).__mul__(2) == 1: 1/2 * 2 = 1, numerator is 1, denominator is 1.
# No prior spec covers __mul__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.mul_half_times_two_numerator:
  description: "Fraction(1,2).__mul__(2).numerator == 1 — 1/2 * 2 = 1, numerator is 1"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __mul__
  method_args: [2]
  method_chain: numerator
  expected: 1

# ---------------------------------------------------------------------------
# __gt__ — greater-than comparison against an integer
#
# Fraction(3,4).__gt__(0) == True: 0.75 > 0.
# No prior spec covers __gt__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.gt_threequarters_vs_zero:
  description: "Fraction(3,4).__gt__(0) == True — 0.75 is greater than 0"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# __lt__ — less-than comparison against an integer
#
# Fraction(1,4).__lt__(1) == True: 0.25 < 1.
# No prior spec covers __lt__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.lt_quarter_vs_one:
  description: "Fraction(1,4).__lt__(1) == True — 0.25 is less than 1"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [1, 4]
  method: __lt__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# __abs__ — absolute value of a Fraction
#
# Fraction(1,2).__abs__() == 1/2: positive fraction is unchanged, numerator is 1.
# Fraction(-3,4).__abs__() == 3/4: negative fraction becomes positive, numerator is 3.
# No prior spec covers __abs__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.abs_positive_numerator:
  description: "Fraction(1,2).__abs__().numerator == 1 — abs of positive fraction is itself"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __abs__
  method_chain: numerator
  expected: 1

invariant fractions_extra12.Fraction.abs_negative_numerator:
  description: "Fraction(-3,4).__abs__().numerator == 3 — abs of negative fraction strips sign"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [-3, 4]
  method: __abs__
  method_chain: numerator
  expected: 3

invariant fractions_extra12.Fraction.abs_negative_denominator:
  description: "Fraction(-3,4).__abs__().denominator == 4 — denominator unchanged by abs"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [-3, 4]
  method: __abs__
  method_chain: denominator
  expected: 4

# ---------------------------------------------------------------------------
# __floor__ — floor of a Fraction (greatest integer not exceeding the value)
#
# Fraction(22,7).__floor__() == 3: 22/7 == 3.142..., floor is 3.
# No prior spec covers __floor__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.floor_twenty_two_sevenths:
  description: "Fraction(22,7).__floor__() == 3 — floor(22/7) = floor(3.142...) = 3"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [22, 7]
  method: __floor__
  expected: 3

# ---------------------------------------------------------------------------
# __ceil__ — ceiling of a Fraction (smallest integer not less than the value)
#
# Fraction(22,7).__ceil__() == 4: 22/7 == 3.142..., ceiling is 4.
# No prior spec covers __ceil__ on a Fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra12.Fraction.ceil_twenty_two_sevenths:
  description: "Fraction(22,7).__ceil__() == 4 — ceil(22/7) = ceil(3.142...) = 4"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [22, 7]
  method: __ceil__
  expected: 4
