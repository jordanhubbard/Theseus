spec: enum_extra7
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends prior enum specs."
    - "Focus: IntEnum, IntFlag, StrEnum (3.11+) behavior and attributes."
    - "enum.IntEnum members are both int instances and enum members."
    - "enum.Flag is the base for flag enumerations."
    - "enum.CONFORM, enum.EJECT, enum.KEEP, enum.STRICT are boundary behaviors (3.11+)."
    - "enum.auto().__class__.__name__ == 'int' after evaluation."
    - "enum.unique is a class decorator; unique.__name__ == 'unique'."
    - "enum.global_enum.__name__ == 'global_enum' (3.11+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table enum_extra7.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__name__.__eq__,    ["Enum"],    true]
    - [IntEnum, IntEnum.__name__.__eq__, ["IntEnum"], true]
    - [Flag,    Flag.__name__.__eq__,    ["Flag"],    true]
    - [IntFlag, IntFlag.__name__.__eq__, ["IntFlag"], true]

table enum_extra7.function_decorator_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [unique,    unique.__name__.__eq__,    ["unique"],    true]
    - [auto,      auto.__name__.__eq__,      ["auto"],      true]
    - [property,  property.__name__.__eq__,  ["property"],  true]
    - [member,    member.__name__.__eq__,    ["member"],    true]
    - [nonmember, nonmember.__name__.__eq__, ["nonmember"], true]

invariant enum_extra7.IntEnum.base_class:
  description: "enum.IntEnum.__bases__[0].__name__ == 'int'"
  category: hierarchy
  kind: python_call_eq
  function: IntEnum.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

invariant enum_extra7.Flag.module:
  description: "enum.Flag.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: Flag.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra7.IntFlag.module:
  description: "enum.IntFlag.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: IntFlag.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra7.auto.class_name:
  description: "enum.auto.__name__ == 'auto'"
  category: class_names
  kind: python_call_eq
  function: auto.__name__.__eq__
  args: ["auto"]
  expected: true

invariant enum_extra7.auto.module:
  description: "enum.auto.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: auto.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra7.unique.module:
  description: "enum.unique.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: unique.__module__.__eq__
  args: ["enum"]
  expected: true
