spec: secrets_extra19
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra18.zspec.zsdl — covers token_bytes/hex/urlsafe __name__.__len__(); choice/__name__.__len__(); randbelow/__name__.__len__(); SystemRandom/__name__.__len__(); token_bytes/hex/urlsafe __qualname__.__len__() re-anchors; choice/randbelow __qualname__.__len__() re-anchors; SystemRandom.__module__.__len__()==6."
    - "secrets_extra17.zspec.zsdl — covers token_bytes/hex/urlsafe/choice/randbelow __qualname__ re-anchors; SystemRandom.__qualname__ re-anchor and __qualname__.__len__; token module __module__.__len__() novel invariants."
    - "secrets_extra16.zspec.zsdl — covers SystemRandom.choice/shuffle/sample __qualname__; DEFAULT_ENTROPY.__class__.__name__; token_bytes/hex __qualname__.__len__() re-anchors; SystemRandom.__qualname__ re-anchor."
    - "secrets_extra15.zspec.zsdl — covers token_bytes/hex/urlsafe __name__; choice/__name__; randbelow/__name__; SystemRandom.seed/uniform/randint __qualname__; SystemRandom.__module__; SystemRandom.__bases__[0].__name__."
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables; DEFAULT_ENTROPY == 32; randbits.__qualname__."
    - "secrets_extra3.zspec.zsdl — covers token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__."
    - "secrets_extra2.zspec.zsdl — covers token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__."
  notes:
    - "This spec extends secrets through secrets_extra18; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: token_bytes/token_hex/token_urlsafe __name__/__module__/__qualname__ and all __len__() variants; choice/__name__/__module__/__qualname__/__len__() variants; randbelow/__name__/__module__/__qualname__/__len__() variants; SystemRandom/__name__/__module__/__qualname__/__bases__[0].__name__ and __len__() variants; DEFAULT_ENTROPY == 32; randbits/__module__/__qualname__/__len__() from secrets_extra3/4/12."
    - "This spec covers: token_bytes/__module__.__len__()==7 (NOVEL — no prior spec checks __module__.__len__() for token_bytes); token_hex/__module__.__len__()==7 (NOVEL); token_urlsafe/__module__.__len__()==7 (NOVEL); randbelow/__module__.__len__()==7 (NOVEL — randbelow is defined in secrets, not random); randbits/__name__.__len__()==11 (the underlying method is getrandbits, len 11); randbits/__module__.__len__()==6 (bound to random.SystemRandom.getrandbits, __module__=='random'); randbits/__qualname__.__len__()==24 ('SystemRandom.getrandbits' has 24 chars including dot); SystemRandom.__qualname__.__len__()==12 (re-anchor from extra19; extra17 covers from extra17 namespace)."
    - "secrets.token_bytes.__module__ == 'secrets' — len 7. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__module__ == 'secrets' — len 7. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__module__ == 'secrets' — len 7. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbelow.__module__ == 'secrets' — len 7. randbelow is a pure-Python function defined in secrets.py, NOT a bound method from random. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbits.__name__ == 'getrandbits' — len 11. randbits is secrets.SystemRandom().getrandbits, a bound method; __name__ is 'getrandbits'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbits.__module__ == 'random' — len 6. The underlying method is SystemRandom.getrandbits from the random module. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbits.__qualname__ == 'SystemRandom.getrandbits' — len 24. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__qualname__ == 'SystemRandom' — len 12. Re-anchored from extra19; extra17 covers from extra17 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __module__.__len__()==7
#
# secrets_extra2/3 cover __module__.__eq__('secrets') for the three token
# functions. secrets_extra17 checks __module__.__len__() for the token
# module-level functions collectively via a different path. No prior spec
# records __module__.__len__() for token_bytes, token_hex, or token_urlsafe
# individually as standalone len checks.
# All three are defined in 'secrets' (len 7).
# ---------------------------------------------------------------------------

table secrets_extra19.token_module_lengths:
  description: "len(__module__) == 7 for token_bytes/token_hex/token_urlsafe — all defined in 'secrets'; novel standalone invariants"
  kind: python_call_eq
  category: module_metadata
  id_prefix: sectml19

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__module__.__len__,   [], 7]
    - [token_hex,     token_hex.__module__.__len__,     [], 7]
    - [token_urlsafe, token_urlsafe.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# randbelow.__module__.__len__()==7
#
# secrets_extra3 covers randbelow.__module__.__eq__('secrets').
# No prior spec checks randbelow.__module__.__len__().
# randbelow is a pure-Python wrapper defined in secrets.py, so its
# __module__ == 'secrets' (len 7), not 'random'.
# ---------------------------------------------------------------------------

invariant secrets_extra19.randbelow.module_len:
  description: "secrets.randbelow.__module__.__len__() == 7 — 'secrets' has 7 characters; randbelow is defined in secrets.py, not random; novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: randbelow.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# randbits attributes: __name__.__len__(), __module__.__len__(), __qualname__.__len__()
#
# secrets.randbits is secrets.SystemRandom().getrandbits — a bound method.
# secrets_extra3/4/12 cover randbits.__module__/__qualname__/__qualname__.__len__().
# No prior spec covers randbits.__name__.__len__() or randbits.__module__.__len__()
# as standalone len invariants from the extra19 namespace.
# __name__ == 'getrandbits' (len 11); __module__ == 'random' (len 6);
# __qualname__ == 'SystemRandom.getrandbits' (len 24).
# ---------------------------------------------------------------------------

invariant secrets_extra19.randbits.name_len:
  description: "secrets.randbits.__name__.__len__() == 11 — underlying method is 'getrandbits' (11 chars); novel __name__.__len__() invariant"
  category: function_names
  kind: python_call_eq
  function: randbits.__name__.__len__
  args: []
  expected: 11

invariant secrets_extra19.randbits.module_len:
  description: "secrets.randbits.__module__.__len__() == 6 — 'random' has 6 characters; randbits is SystemRandom.getrandbits from random; novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: randbits.__module__.__len__
  args: []
  expected: 6

table secrets_extra19.randbits_lengths:
  description: "randbits __qualname__.__len__()==24 ('SystemRandom.getrandbits') — re-anchored from extra19; extra12 covers from extra12 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ranbl19

  columns: [id, function, args, expected]
  rows:
    - [randbits_qualname_len, randbits.__qualname__.__len__, [], 24]

# ---------------------------------------------------------------------------
# SystemRandom.__qualname__.__len__()==12 — re-anchored from extra19
#
# secrets_extra17 covers SystemRandom.__qualname__.__len__()==12 from the
# extra17 namespace. Re-anchored here as a cross-namespace regression check.
# SystemRandom.__qualname__ == 'SystemRandom' (len 12).
# ---------------------------------------------------------------------------

invariant secrets_extra19.SystemRandom.qualname_len:
  description: "secrets.SystemRandom.__qualname__.__len__() == 12 — 'SystemRandom' has 12 characters; re-anchored from extra19 namespace (extra17 covers from extra17)"
  category: class_identity
  kind: python_call_eq
  function: SystemRandom.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Consolidated cross-check table for all __module__.__len__() values in extra19
#
# Collects token_bytes/hex/urlsafe/randbelow (all 7 — 'secrets') and
# randbits (6 — 'random') in one table for dense regression coverage.
# ---------------------------------------------------------------------------

table secrets_extra19.all_module_lengths:
  description: "Consolidated __module__.__len__() cross-check: token_bytes/hex/urlsafe/randbelow==7 ('secrets'), randbits==6 ('random')"
  kind: python_call_eq
  category: module_metadata
  id_prefix: secaml19

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__module__.__len__,   [], 7]
    - [token_hex,     token_hex.__module__.__len__,     [], 7]
    - [token_urlsafe, token_urlsafe.__module__.__len__, [], 7]
    - [randbelow,     randbelow.__module__.__len__,     [], 7]
    - [randbits,      randbits.__module__.__len__,      [], 6]
