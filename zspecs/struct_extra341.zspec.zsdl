spec: struct_extra341
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "_struct.__name__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>I', -1) raises struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>i', 2147483648) raises struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>B', -1) raises struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.pack, struct.unpack, and struct.Struct are implemented in the _struct C extension (Modules/_struct.c). The Python-level struct module re-exports from _struct."
    - "Note: struct.error.__module__ == 'struct' (defined in the Python wrapper, not the C extension)."
    - "Note: '>I' is big-endian unsigned 32-bit int (0..4294967295); '>i' is big-endian signed 32-bit int (-2147483648..2147483647); '>B' is big-endian unsigned 8-bit int (0..255)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__qualname__.__eq__('error')
# struct.pack.__module__.__eq__('_struct')
# struct.Struct.__qualname__.__eq__('Struct')
#
# Wave 341 theme: struct exception type identity and C extension attribution.
#
# struct.error is the exception raised by pack/unpack/calcsize when the
# format string or value is invalid. Its base class is Exception (not
# ValueError or TypeError — struct.error is a direct Exception subclass).
# struct.error.__qualname__ is 'error' (lowercase, unconventional name for
# an exception class, matching the original C implementation convention).
# struct.pack.__module__ is '_struct' — the pack function is implemented in
# the C extension. struct.Struct.__qualname__ is 'Struct' — top-level C type.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra341.struct_error_and_cext_identity:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception')==True / error.__qualname__.__eq__('error')==True / pack.__module__.__eq__('_struct')==True / Struct.__qualname__.__eq__('Struct')==True — struct.error base is Exception (direct subclass, not ValueError/TypeError); error qualname is lowercase 'error' (C convention); pack.__module__ '_struct' confirms C extension implementation; Struct qualname confirms top-level C type; first structid341 anchor"
  kind: python_call_eq
  category: error_and_c_identity
  id_prefix: structid341

  columns: [id, function, args, expected, description]
  rows:
    - [error_base_name,    "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ is 'Exception' — struct.error is a direct subclass of Exception"]
    - [error_qualname,     "error.__qualname__.__eq__",          ["error"],     true, "struct.error.__qualname__ is 'error' — lowercase convention from original C implementation"]
    - [pack_module,        "pack.__module__.__eq__",             ["_struct"],   true, "struct.pack.__module__ is '_struct' — pack is implemented in the C extension (Modules/_struct.c)"]
    - [struct_qualname,    "Struct.__qualname__.__eq__",         ["Struct"],    true, "struct.Struct.__qualname__ is 'Struct' — top-level C type for compiled format objects"]

# ---------------------------------------------------------------------------
# struct.pack('>I', -1) raises struct.error — uint32 cannot be negative
# struct.pack('>i', 2147483648) raises struct.error — int32 overflow
# struct.pack('>B', -1) raises struct.error — uint8 cannot be negative
#
# Wave 341 theme: struct.pack format constraint error behaviors.
#
# '>I' is big-endian unsigned 32-bit integer, range 0..4294967295. Passing -1
# is out of range and raises struct.error. '>i' is big-endian signed 32-bit
# integer, range -2147483648..2147483647. Passing 2147483648 (one above max)
# raises struct.error. '>B' is big-endian unsigned 8-bit integer, range 0..255.
# Passing -1 is out of range and raises struct.error. All three cases confirm
# that struct.pack enforces format-specific value ranges at pack time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra341.pack_uint32_negative_raises:
  description: "struct.pack('>I', -1) raises struct.error — '>I' format requires unsigned 32-bit int (0..4294967295); negative value -1 is out of range; struct.pack enforces value bounds at pack time; first standalone for '>I' negative error under structid341"
  category: error_behavior
  kind: python_call_raises
  function: pack
  args: [">I", -1]
  raises: error

invariant struct_extra341.pack_int32_overflow_raises:
  description: "struct.pack('>i', 2147483648) raises struct.error — '>i' format requires signed 32-bit int (-2147483648..2147483647); value 2147483648 is one above INT32_MAX and out of range; struct.pack enforces value bounds at pack time; first standalone for '>i' overflow error under structid341"
  category: error_behavior
  kind: python_call_raises
  function: pack
  args: [">i", 2147483648]
  raises: error

invariant struct_extra341.pack_uint8_negative_raises:
  description: "struct.pack('>B', -1) raises struct.error — '>B' format requires unsigned 8-bit int (0..255); negative value -1 is out of range; struct.pack enforces value bounds at pack time; first standalone for '>B' negative error under structid341"
  category: error_behavior
  kind: python_call_raises
  function: pack
  args: [">B", -1]
  raises: error

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. struct.error is a direct
# subclass of the built-in Exception class — it is not a subclass of
# ValueError, TypeError, or any other standard exception. This means callers
# cannot catch struct errors using `except ValueError` or `except TypeError`;
# they must use `except struct.error` or `except Exception`. This design
# reflects the original C implementation convention.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra341.error_base_is_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error is a direct subclass of Exception (not ValueError/TypeError); callers must use 'except struct.error' to catch; reflects original C implementation convention; first standalone for struct.error base under structid341"
  category: error_and_c_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.__qualname__ is 'Struct'. struct.Struct is the compiled
# format class — it pre-compiles a format string so that pack/unpack
# operations can be repeated efficiently without re-parsing the format.
# Its __qualname__ is 'Struct', matching its __name__, confirming it is
# a top-level class in the struct module (not nested). Struct is implemented
# as a C type in Modules/_struct.c.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra341.Struct_qualname_is_Struct:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — Struct.__qualname__ is 'Struct', confirming it is a top-level class (not nested); pre-compiles format strings for efficient repeated pack/unpack; implemented as C type in Modules/_struct.c; first standalone for Struct.__qualname__ under structid341"
  category: error_and_c_identity
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('_struct') — standalone
#
# struct.pack.__module__ is '_struct'. struct.pack is a C built-in function
# defined in Modules/_struct.c. Although it is accessed via the Python-level
# struct module (Lib/struct.py re-exports it from _struct), its __module__
# attribute reports '_struct', the C extension where it is actually defined.
# This is analogous to how str methods report their module as 'builtins'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra341.pack_module_is__struct:
  description: "struct.pack.__module__.__eq__('_struct') == True — struct.pack is a C built-in function defined in Modules/_struct.c; __module__ reports '_struct' even though accessed via the Python struct wrapper; analogous to str methods reporting 'builtins'; first standalone for pack.__module__ under structid341"
  category: error_and_c_identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true
