spec: itertools_extra291
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module spec, loader, and class doc attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools is a C extension; __loader__ is BuiltinImporter and __spec__.origin is 'built-in'"
    - "All itertools class __doc__ attributes are str instances"
    - "chain.from_iterable is a builtin_function_or_method with qualname 'chain.from_iterable'"
    - "pairwise and batched are available from Python 3.12+"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra291.module_spec:
  description: "itertools module spec and loader identity"
  kind: python_call_eq
  category: identity
  id_prefix: itl291m

  columns: [id, function, args, expected, description]
  rows:
    - [itl291m_001, itertools.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "__spec__ is a ModuleSpec instance"]
    - [itl291m_002, itertools.__loader__.__name__.__eq__, ["BuiltinImporter"], true, "__loader__ is BuiltinImporter for C extension"]
    - [itl291m_003, itertools.__spec__.origin.__eq__, ["built-in"], true, "__spec__.origin is 'built-in' for C extension"]

table itertools_extra291.class_doc_types:
  description: "__doc__.__class__.__name__ for itertools classes and chain.from_iterable"
  kind: python_call_eq
  category: identity
  id_prefix: itl291d

  columns: [id, function, args, expected, description]
  rows:
    - [itl291d_001, itertools.chain.__doc__.__class__.__name__.__eq__, ["str"], true, "chain.__doc__ is a str"]
    - [itl291d_002, itertools.count.__doc__.__class__.__name__.__eq__, ["str"], true, "count.__doc__ is a str"]
    - [itl291d_003, itertools.cycle.__doc__.__class__.__name__.__eq__, ["str"], true, "cycle.__doc__ is a str"]
    - [itl291d_004, itertools.repeat.__doc__.__class__.__name__.__eq__, ["str"], true, "repeat.__doc__ is a str"]
    - [itl291d_005, itertools.product.__doc__.__class__.__name__.__eq__, ["str"], true, "product.__doc__ is a str"]
    - [itl291d_006, itertools.accumulate.__doc__.__class__.__name__.__eq__, ["str"], true, "accumulate.__doc__ is a str"]
    - [itl291d_007, itertools.chain.from_iterable.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "chain.from_iterable is builtin_function_or_method"]
    - [itl291d_008, itertools.pairwise.__doc__.__class__.__name__.__eq__, ["str"], true, "pairwise.__doc__ is a str (Python 3.12+)"]
    - [itl291d_009, itertools.batched.__doc__.__class__.__name__.__eq__, ["str"], true, "batched.__doc__ is a str (Python 3.12+)"]

invariant itertools_extra291.inv_chain_from_iterable_qualname:
  description: "chain.from_iterable.__qualname__ equals 'chain.from_iterable'"
  category: identity
  kind: python_call_eq
  function: itertools.chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra291.inv_chain_from_iterable_class:
  description: "chain.from_iterable is a builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: itertools.chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra291.inv_spec_origin:
  description: "itertools.__spec__.origin is 'built-in'"
  category: identity
  kind: python_call_eq
  function: itertools.__spec__.origin.__eq__
  args: ["built-in"]
  expected: true

invariant itertools_extra291.inv_loader_name:
  description: "itertools.__loader__.__name__ is 'BuiltinImporter'"
  category: identity
  kind: python_call_eq
  function: itertools.__loader__.__name__.__eq__
  args: ["BuiltinImporter"]
  expected: true
