spec: inspect_extra160
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.ismodule.__code__.co_argcount 1, co_name 'ismodule'; inspect.isbuiltin.__code__.co_argcount 1, co_name 'isbuiltin'; inspect.isclass.__code__.co_argcount 1, co_name 'isclass'; inspect.getmembers.__code__.co_argcount 2, co_name 'getmembers'; len(inspect.getmembers.__code__.co_varnames) 2; inspect.getmembers.__code__.co_varnames[0] 'object' (Wave 289)."
    - "inspect.ismodule.__code__.co_argcount == 1 — ismodule(object) takes 1 positional-or-keyword argument; it returns True if the object is a module. Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_name == 'ismodule' — the code object co_name for ismodule is 'ismodule'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1 — isbuiltin(object) takes 1 positional-or-keyword argument; it returns True if the object is a built-in function or bound built-in method. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_name == 'isbuiltin' — the code object co_name for isbuiltin is 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_argcount == 1 — isclass(object) takes 1 positional-or-keyword argument; it returns True if the object is a class. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_name == 'isclass' — the code object co_name for isclass is 'isclass'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2 — getmembers(object, predicate=None) takes 2 positional-or-keyword arguments: object and predicate. Verified with Python 3.14.3."
    - "len(inspect.getmembers.__code__.co_varnames) == 2 — getmembers has exactly 2 local variable names in co_varnames: 'object' and 'predicate'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_varnames[0] == 'object' — the first co_varname in getmembers is 'object', the inspected object argument. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.ismodule, inspect.isbuiltin, inspect.isclass code attributes
#
# Wave 289 theme: inspect.ismodule, inspect.isbuiltin, and inspect.isclass
# __code__ co_argcount and co_name attributes.
#
# inspect.ismodule.__code__.co_argcount == 1
# inspect.ismodule.__code__.co_name == 'ismodule'
# inspect.isbuiltin.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_name == 'isbuiltin'
# inspect.isclass.__code__.co_argcount == 1
# inspect.isclass.__code__.co_name == 'isclass'
#
# ismodule(object), isbuiltin(object), and isclass(object) are Python
# predicate functions defined in Lib/inspect.py. Each takes exactly 1
# positional-or-keyword argument (the object to test). ismodule returns
# True if the object is a module. isbuiltin returns True if the object is a
# built-in function or bound built-in method. isclass returns True if the
# object is a class. Their co_argcount is 1 and their co_name matches their
# Python function name. New to extra160.
# ---------------------------------------------------------------------------

table inspect_extra160.ismodule_isbuiltin_isclass_code_attrs:
  description: "inspect: ismodule co_argcount 1 and co_name 'ismodule'; isbuiltin co_argcount 1 and co_name 'isbuiltin'; isclass co_argcount 1 and co_name 'isclass'; wave 289; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: inspectismbica160

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_co_argcount_eq_1,
       "ismodule.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — ismodule(object) takes exactly 1 positional-or-keyword argument; it returns True if the object is a module instance; co_argcount is 1; int.__eq__(1) returns True; new to extra160"]
    - [ismodule_co_name_eq,
       "ismodule.__code__.co_name.__eq__",
       ["ismodule"],
       true,
       "inspect.ismodule.__code__.co_name.__eq__('ismodule') == True — ismodule is a Python predicate function in Lib/inspect.py that tests whether an object is a module; its code object co_name is 'ismodule'; str.__eq__('ismodule') returns True; new to extra160"]
    - [isbuiltin_co_argcount_eq_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin(object) takes exactly 1 positional-or-keyword argument; it returns True if the object is a built-in function or bound built-in method such as len or [].append; co_argcount is 1; int.__eq__(1) returns True; new to extra160"]
    - [isbuiltin_co_name_eq,
       "isbuiltin.__code__.co_name.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — isbuiltin is a Python predicate function in Lib/inspect.py that tests whether an object is a built-in function; its code object co_name is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra160"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isclass and inspect.getmembers code attributes
#
# Wave 289 theme: inspect.isclass and inspect.getmembers __code__ attributes.
#
# inspect.isclass.__code__.co_argcount == 1
# inspect.isclass.__code__.co_name == 'isclass'
# inspect.getmembers.__code__.co_argcount == 2
# len(inspect.getmembers.__code__.co_varnames) == 2
# inspect.getmembers.__code__.co_varnames[0] == 'object'
#
# isclass(object) is a predicate function that returns True if its argument
# is a class. getmembers(object, predicate=None) returns all the members of
# an object as (name, value) pairs, optionally filtered by a predicate
# function. getmembers takes 2 positional-or-keyword arguments (object and
# predicate), so co_argcount is 2. Its co_varnames tuple contains exactly 2
# elements ('object' and 'predicate'). New to extra160.
# ---------------------------------------------------------------------------

table inspect_extra160.isclass_and_getmembers_code_attrs:
  description: "inspect.isclass: co_argcount 1, co_name 'isclass'; inspect.getmembers: co_argcount 2, co_varnames len 2, co_varnames[0] 'object'; wave 289; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: inspectisclsgmca160

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_co_argcount_eq_1,
       "isclass.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass(object) takes exactly 1 positional-or-keyword argument; it returns True if the object is a class (including built-in classes such as int and list); co_argcount is 1; int.__eq__(1) returns True; new to extra160"]
    - [isclass_co_name_eq,
       "isclass.__code__.co_name.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__code__.co_name.__eq__('isclass') == True — isclass is a Python predicate function in Lib/inspect.py that tests whether an object is a class; its code object co_name is 'isclass'; str.__eq__('isclass') returns True; new to extra160"]
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) takes 2 positional-or-keyword arguments: object (the inspected object) and predicate (an optional filtering callable); co_argcount is 2; int.__eq__(2) returns True; new to extra160"]
    - [getmembers_co_varnames_len_eq_2,
       "getmembers.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getmembers.__code__.co_varnames.__len__() == 2 — getmembers has exactly 2 entries in co_varnames: 'object' (the inspected object) and 'predicate' (the optional filter); tuple.__len__() returns 2; new to extra160"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra160
# ---------------------------------------------------------------------------

invariant inspect_extra160.ismodule_co_argcount_1:
  description: "inspect.ismodule.__code__.co_argcount == 1 — ismodule(object) takes 1 arg; tests if object is a module; wave 289; new to extra160"
  kind: python_call_eq
  function: ismodule.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra160.ismodule_co_name_ismodule:
  description: "inspect.ismodule.__code__.co_name == 'ismodule' — code object name for the ismodule predicate; wave 289; new to extra160"
  kind: python_call_eq
  function: ismodule.__code__.co_name.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra160.isbuiltin_co_argcount_1:
  description: "inspect.isbuiltin.__code__.co_argcount == 1 — isbuiltin(object) takes 1 arg; tests if object is a built-in function; wave 289; new to extra160"
  kind: python_call_eq
  function: isbuiltin.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra160.isclass_co_argcount_1:
  description: "inspect.isclass.__code__.co_argcount == 1 — isclass(object) takes 1 arg; tests if object is a class; wave 289; new to extra160"
  kind: python_call_eq
  function: isclass.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra160.getmembers_co_argcount_2:
  description: "inspect.getmembers.__code__.co_argcount == 2 — getmembers(object, predicate) takes 2 args; returns all members as (name, value) pairs; wave 289; new to extra160"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra160.getmembers_co_varnames_0_object:
  description: "inspect.getmembers.__code__.co_varnames[0] == 'object' — first co_varname in getmembers is the inspected object argument; wave 289; new to extra160"
  kind: python_call_eq
  function: "getmembers.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "object"

