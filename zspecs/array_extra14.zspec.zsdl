spec: array_extra14
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl through array_extra13.zspec.zsdl."
    - "array_extra2 covers: typecodes.__contains__ for b/B/h/i/l/q/f/d (id_prefix contains)."
    - "array_extra4 covers: typecodes.__contains__ for H/L/Q (id_prefix contains)."
    - "array_extra5 covers: typecodes.__contains__ for 'I' (unsigned int) as standalone invariant."
    - "array_extra6 covers: typecodes.__contains__ for 'u' and 'w'; class identity table (id_prefix aident) covering array.__module__.__eq__/array.__qualname__.__eq__."
    - "array_extra8 covers: typecodes.__class__.__name__.__eq__('str') standalone; array.__module__.__eq__ standalone."
    - "No prior array spec covers all 12 standard numeric typecodes b/B/h/H/i/I/l/L/q/Q/f/d in a single table with a fresh id_prefix."
    - "No prior array spec covers array.__module__.__len__() as a standalone invariant."
    - "No prior array spec covers array.__qualname__.__len__() as a standalone invariant."
    - "No prior array spec covers typecodes.__class__.__name__.__len__() as a standalone invariant."
    - "array.__module__ == 'array'; len('array') == 5."
    - "array.__qualname__ == 'array'; len('array') == 5."
    - "typecodes.__class__.__name__ == 'str'; len('str') == 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typecodes.__contains__ — all 12 standard numeric typecodes in one table
#
# Prior specs cover the 12 typecodes in three separate tables/invariants across
# different spec files. This table unifies all 12 in a single table using
# id_prefix tc14, providing a fresh namespace anchor for the complete set.
# Typecodes b/B/h/H/i/I/l/L/q/Q/f/d all return True on Python 3.9+.
# ---------------------------------------------------------------------------

table array_extra14.typecodes.contains_all:
  kind: python_call_eq
  category: typecodes
  id_prefix: tc14

  columns: [id, function, args, expected]
  rows:
    - [b, typecodes.__contains__, ["b"], true]
    - [B, typecodes.__contains__, ["B"], true]
    - [h, typecodes.__contains__, ["h"], true]
    - [H, typecodes.__contains__, ["H"], true]
    - [i, typecodes.__contains__, ["i"], true]
    - [I, typecodes.__contains__, ["I"], true]
    - [l, typecodes.__contains__, ["l"], true]
    - [L, typecodes.__contains__, ["L"], true]
    - [q, typecodes.__contains__, ["q"], true]
    - [Q, typecodes.__contains__, ["Q"], true]
    - [f, typecodes.__contains__, ["f"], true]
    - [d, typecodes.__contains__, ["d"], true]

# ---------------------------------------------------------------------------
# typecodes.__class__.__name__.__len__() — string class name length
#
# array_extra8 covers typecodes.__class__.__name__.__eq__('str') standalone.
# No prior spec records typecodes.__class__.__name__.__len__() == 3.
# len('str') == 3.
# ---------------------------------------------------------------------------

invariant array_extra14.typecodes.class_name_len:
  description: "array.typecodes.__class__.__name__.__len__() == 3 — len('str')"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# array.__module__.__len__() — module name length cross-check
#
# array_extra6/array_extra8 cover array.__module__.__eq__('array').
# No prior array spec records array.__module__.__len__() == 5 as a standalone
# invariant. len('array') == 5.
# ---------------------------------------------------------------------------

invariant array_extra14.array.module_len:
  description: "array.array.__module__.__len__() == 5 — len('array')"
  category: module_identity
  kind: python_call_eq
  function: array.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# array.__qualname__.__len__() — qualified name length cross-check
#
# array_extra4/array_extra6 cover array.__qualname__.__eq__('array').
# No prior array spec records array.__qualname__.__len__() == 5 as a standalone
# invariant. len('array') == 5.
# ---------------------------------------------------------------------------

invariant array_extra14.array.qualname_len:
  description: "array.array.__qualname__.__len__() == 5 — len('array')"
  category: class_qualnames
  kind: python_call_eq
  function: array.__qualname__.__len__
  args: []
  expected: 5
