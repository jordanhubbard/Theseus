spec: platform_extra3
version: ">=3.9"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/platform.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/platform.py"
  notes:
    - "This spec extends platform.zspec.zsdl, platform_extra.zspec.zsdl, and platform_extra2.zspec.zsdl."
    - "platform.zspec.zsdl: __name__ table for python_version/python_implementation/python_version_tuple/system/machine/processor/architecture/node/uname; python_impl_cpython; version_tuple_major/is_tuple/len3; python_version_is_str/nonempty; architecture_64bit; node_is_str; uname_system/release_is_str."
    - "platform_extra.zspec.zsdl: __name__ for release/version/python_build; return types for system/machine/processor/release/version/python_implementation/python_build; uname_result type + machine/node/processor/version fields as str."
    - "platform_extra2.zspec.zsdl: __module__ table for all functions; __name__ spot-checks for system/node/release/machine/python_compiler; python_compiler is str and non-empty."
    - "This spec adds: python_version_tuple minor/micro element type checks; node() non-empty; python_implementation() non-empty; uname().node non-empty; uname() len check; architecture()[1] is str; python_build()[0] non-empty."
    - "python_version_tuple()[1].__class__.__name__ == 'str' — the minor version element is always a str."
    - "python_version_tuple()[2].__class__.__name__ == 'str' — the micro version element is always a str."
    - "len(node()) >= 1 — the hostname is always a non-empty string."
    - "len(python_implementation()) >= 1 — the implementation name is always a non-empty string."
    - "uname().node.__len__() >= 1 — uname().node is a non-empty string."
    - "len(uname()) == 6 — uname_result always has exactly 6 fields."
    - "architecture()[1].__class__.__name__ == 'str' — the linkage field is always a str."
    - "python_build()[0].__len__() >= 1 — buildno string is always non-empty."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# python_version_tuple() — element type checks for minor and micro positions
# platform.zspec.zsdl covers: [0] == '3', __class__.__name__ == 'tuple', len == 3
# New here: [1] is str, [2] is str
# ---------------------------------------------------------------------------

invariant platform_extra3.version_tuple_minor_is_str:
  description: "python_version_tuple()[1].__class__.__name__ == 'str' — minor version element is a str"
  category: python_info
  kind: python_call_eq
  function: python_version_tuple().__getitem__
  args: [1]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant platform_extra3.version_tuple_micro_is_str:
  description: "python_version_tuple()[2].__class__.__name__ == 'str' — micro version element is a str"
  category: python_info
  kind: python_call_eq
  function: python_version_tuple().__getitem__
  args: [2]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# node() — hostname is non-empty (platform.zspec.zsdl only confirms it is str)
# ---------------------------------------------------------------------------

invariant platform_extra3.node_nonempty:
  description: "len(node()) >= 1 — hostname is always a non-empty string"
  category: node
  kind: python_call_eq
  function: node().__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# python_implementation() — non-empty string
# platform_extra.zspec.zsdl confirms it is str; platform.zspec.zsdl checks value == 'CPython'
# New here: length check >= 1 (implementation-agnostic non-emptiness guarantee)
# ---------------------------------------------------------------------------

invariant platform_extra3.python_implementation_nonempty:
  description: "len(python_implementation()) >= 1 — implementation name is always non-empty"
  category: python_info
  kind: python_call_eq
  function: python_implementation().__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uname() — length check and node field non-emptiness
# platform.zspec.zsdl: uname().system and .release are str
# platform_extra.zspec.zsdl: uname_result class name, .machine/.node/.processor/.version are str
# New here: len(uname()) == 6 (the named-tuple always has 6 fields); uname().node non-empty
# ---------------------------------------------------------------------------

invariant platform_extra3.uname_len:
  description: "len(uname()) == 6 — uname_result always has exactly 6 fields (system, node, release, version, machine, processor)"
  category: uname
  kind: python_call_eq
  function: uname().__len__
  args: []
  expected: 6

invariant platform_extra3.uname_node_nonempty:
  description: "len(uname().node) >= 1 — uname().node is a non-empty hostname string"
  category: uname
  kind: python_call_eq
  function: uname().node.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# architecture() — second element (linkage string) is always a str
# platform.zspec.zsdl covers: architecture()[0] == '64bit'
# New here: architecture()[1].__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

invariant platform_extra3.architecture_linkage_is_str:
  description: "architecture()[1].__class__.__name__ == 'str' — the linkage field is always a str"
  category: architecture
  kind: python_call_eq
  function: architecture().__getitem__
  args: [1]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# python_build() — buildno string is non-empty
# platform_extra.zspec.zsdl: python_build()[0] is str, python_build()[1] is str
# New here: python_build()[0].__len__() >= 1 (buildno is always a non-empty string)
# ---------------------------------------------------------------------------

invariant platform_extra3.python_build_buildno_nonempty:
  description: "len(python_build()[0]) >= 1 — buildno is a non-empty string"
  category: python_build
  kind: python_call_eq
  function: python_build().__getitem__
  args: [0]
  method: __len__.__ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# python_version() — version string contains a dot (x.y.z format)
# platform.zspec.zsdl: python_version() is str and non-empty
# New here: '__contains__' for '.' — a version string always contains at least one dot
# ---------------------------------------------------------------------------

invariant platform_extra3.python_version_contains_dot:
  description: "python_version().__contains__('.') — version string always contains a dot separator"
  category: python_info
  kind: python_call_eq
  function: python_version().__contains__
  args: ["."]
  expected: true
