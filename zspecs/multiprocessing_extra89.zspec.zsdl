spec: multiprocessing_extra89
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra88

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra88.zspec.zsdl."
    - "This spec covers: wave 251 theme — multiprocessing module identity: __name__, __package__, __spec__, __loader__. NEW in extra89: multiprocessing.__name__.__eq__('multiprocessing')==True; multiprocessing.__package__.__eq__('multiprocessing')==True (multiprocessing is a package); multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec')==True; multiprocessing.__spec__.name.__eq__('multiprocessing')==True; multiprocessing.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True; multiprocessing.__file__.__class__.__name__.__eq__('str')==True; multiprocessing.__doc__ is None (multiprocessing has no docstring in Python 3.14.3; __doc__.__class__.__name__=='NoneType'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__name__ == 'multiprocessing'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__package__ == 'multiprocessing'. multiprocessing is a package; __package__ equals the full module name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'. The module spec is a ModuleSpec instance from importlib. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__spec__.name == 'multiprocessing'. The ModuleSpec name field equals the module name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'. multiprocessing is a pure-Python package loaded from source. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__file__.__class__.__name__ == 'str'. The __file__ attribute is a str path to the __init__.py file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__doc__ is None. multiprocessing has no module-level docstring in Python 3.14.3; __doc__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing module name and package — extra89
#
# Wave 251 theme: multiprocessing module identity.
#
# __name__ == 'multiprocessing'
# __package__ == 'multiprocessing'
# ---------------------------------------------------------------------------

table multiprocessing_extra89.module_name_package:
  description: "multiprocessing module __name__ and __package__ checks in mpmoduleid89 namespace — wave 251 theme: multiprocessing module identity: __name__, __package__, __spec__, __loader__; __name__.__eq__('multiprocessing')==True; __package__.__eq__('multiprocessing')==True (multiprocessing is a package; __package__ equals the full module name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmoduleid89

  columns: [id, function, args, expected, description]
  rows:
    - [mp_name_eq,    __name__.__eq__,    ["multiprocessing"], true, "__name__ == 'multiprocessing' — verified with Python 3.14.3"]
    - [mp_package_eq, __package__.__eq__, ["multiprocessing"], true, "__package__ == 'multiprocessing' — multiprocessing is a package; __package__ equals full module name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing module spec identity — extra89
#
# __spec__.__class__.__name__ == 'ModuleSpec'
# __spec__.name == 'multiprocessing'
# ---------------------------------------------------------------------------

table multiprocessing_extra89.module_spec_identity:
  description: "multiprocessing module __spec__ identity checks in mpmoduleid89 namespace — wave 251 theme: multiprocessing module identity: __name__, __package__, __spec__, __loader__; __spec__.__class__.__name__.__eq__('ModuleSpec')==True (importlib ModuleSpec instance); __spec__.name.__eq__('multiprocessing')==True (ModuleSpec.name field equals the module name); __name__.__eq__('multiprocessing')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmoduleid89a

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_name, __spec__.__class__.__name__.__eq__, ["ModuleSpec"],       true, "__spec__.__class__.__name__ == 'ModuleSpec' — importlib ModuleSpec instance; verified with Python 3.14.3"]
    - [spec_name_eq,  __spec__.name.__eq__,               ["multiprocessing"],  true, "__spec__.name == 'multiprocessing' — ModuleSpec.name field equals the module name; verified with Python 3.14.3"]
    - [name_cross,    __name__.__eq__,                    ["multiprocessing"],  true, "__name__ == 'multiprocessing' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing module loader and file — extra89
#
# __loader__.__class__.__name__ == 'SourceFileLoader'
# __file__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table multiprocessing_extra89.module_loader_file:
  description: "multiprocessing module __loader__ and __file__ checks in mpmoduleid89 namespace — wave 251 theme: multiprocessing module identity: __name__, __package__, __spec__, __loader__; __loader__.__class__.__name__.__eq__('SourceFileLoader')==True (pure-Python package loaded from source); __file__.__class__.__name__.__eq__('str')==True (path to __init__.py is a str); __spec__.__class__.__name__.__eq__('ModuleSpec')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmoduleid89b

  columns: [id, function, args, expected, description]
  rows:
    - [loader_cls_name, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python package loaded from source; verified with Python 3.14.3"]
    - [file_cls_name,   __file__.__class__.__name__.__eq__,   ["str"],              true, "__file__.__class__.__name__ == 'str' — path to __init__.py is a str; verified with Python 3.14.3"]
    - [spec_cls_cross,  __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],       true, "__spec__.__class__.__name__ == 'ModuleSpec' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing module doc class and cross-checks — extra89
#
# __doc__.__class__.__name__ == 'NoneType'  (multiprocessing has no docstring)
# Cross-checks from the other tables in this spec.
# ---------------------------------------------------------------------------

table multiprocessing_extra89.module_doc_and_cross_checks:
  description: "multiprocessing module __doc__ class and identity cross-checks in mpmoduleid89 namespace — wave 251 theme: multiprocessing module identity: __name__, __package__, __spec__, __loader__; __doc__.__class__.__name__.__eq__('NoneType')==True (multiprocessing has no docstring; __doc__ is None); __name__.__eq__('multiprocessing')==True (cross-check); __package__.__eq__('multiprocessing')==True (cross-check); __loader__.__class__.__name__.__eq__('SourceFileLoader')==True (cross-check); __file__.__class__.__name__.__eq__('str')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmoduleid89c

  columns: [id, function, args, expected, description]
  rows:
    - [doc_cls_name,     __doc__.__class__.__name__.__eq__,    ["NoneType"],         true, "__doc__.__class__.__name__ == 'NoneType' — multiprocessing has no docstring in Python 3.14.3; __doc__ is None; verified with Python 3.14.3"]
    - [name_cross,       __name__.__eq__,                      ["multiprocessing"],  true, "__name__ == 'multiprocessing' — cross-check; verified with Python 3.14.3"]
    - [package_cross,    __package__.__eq__,                   ["multiprocessing"],  true, "__package__ == 'multiprocessing' — cross-check; verified with Python 3.14.3"]
    - [loader_cls_cross, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "__loader__.__class__.__name__ == 'SourceFileLoader' — cross-check; verified with Python 3.14.3"]
    - [file_cls_cross,   __file__.__class__.__name__.__eq__,   ["str"],              true, "__file__.__class__.__name__ == 'str' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra89
# ---------------------------------------------------------------------------

invariant multiprocessing_extra89.module_name_is_multiprocessing:
  description: "multiprocessing.__name__.__eq__('multiprocessing') returns True — the module's __name__ attribute is 'multiprocessing', the canonical dotted name of the module; NEW in extra89: first standalone __name__ equality invariant for multiprocessing in mpmoduleid89 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra89.module_package_is_multiprocessing:
  description: "multiprocessing.__package__.__eq__('multiprocessing') returns True — multiprocessing is a package (has an __init__.py); its __package__ equals its own full name; NEW in extra89: first standalone __package__ equality invariant for multiprocessing in mpmoduleid89 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra89.module_spec_is_ModuleSpec:
  description: "multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — the module's __spec__ is a ModuleSpec instance from importlib._bootstrap; this is the standard module specification object used by the import system; NEW in extra89: first standalone __spec__ class name invariant for multiprocessing in mpmoduleid89 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra89.module_loader_is_SourceFileLoader:
  description: "multiprocessing.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — multiprocessing is a pure-Python package loaded from source files; its loader is a SourceFileLoader instance from importlib._bootstrap_external; NEW in extra89: first standalone __loader__ class name invariant for multiprocessing in mpmoduleid89 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant multiprocessing_extra89.module_doc_is_NoneType:
  description: "multiprocessing.__doc__.__class__.__name__.__eq__('NoneType') returns True — multiprocessing has no module-level docstring in Python 3.14.3; __doc__ is None; this distinguishes multiprocessing from modules that do have docstrings; NEW in extra89: first standalone __doc__ class name invariant for multiprocessing in mpmoduleid89 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
