invariant inspect_extra145.getfile_doc_len:
  description: "len(inspect.getfile.__doc__) == 64 — getfile docstring has 64 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: getfile.__doc__.__len__
  args: []
  expected: 64

invariant inspect_extra145.getsource_doc_len:
  description: "len(inspect.getsource.__doc__) == 250 — getsource docstring has 250 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: getsource.__doc__.__len__
  args: []
  expected: 250

invariant inspect_extra145.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount == 2 — takes object and predicate; wave 273; new to extra145"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

