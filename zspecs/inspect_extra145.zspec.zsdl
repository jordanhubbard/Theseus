invariant inspect_extra145.parameter_mro_len:
  description: "len(inspect.Parameter.__mro__) == 2 — Parameter inherits only from object; wave 273; new to extra145"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
