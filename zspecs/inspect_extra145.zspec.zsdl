spec: inspect_extra145
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.FrameInfo namedtuple class identity — __name__ 'FrameInfo' len 9, __bases__[0].__name__ '_FrameInfo', MRO len 4, _fields len 6; inspect.Traceback namedtuple class identity — __bases__[0].__name__ '_FrameInfo' like FrameInfo, MRO len 4, _fields len 5; inspect.Parameter plain class identity — __bases__[0].__name__ 'object', MRO len 2, __doc__ len 708; inspect introspection functions: getdoc (__doc__ len 237, co_argcount 1), getfile (__doc__ len 64, co_argcount 1), getsource (__doc__ len 250, co_argcount 1), getmembers (__doc__ len 134, co_argcount 2) (Wave 273)."
    - "inspect.FrameInfo in Python 3.14.3 has MRO [FrameInfo, _FrameInfo, tuple, object] (length 4); its __bases__[0].__name__ is '_FrameInfo' (not 'tuple' as in older Python versions where FrameInfo was a simpler namedtuple). Verified with Python 3.14.3."
    - "inspect.Traceback has the same MRO structure as FrameInfo: [Traceback, _Traceback, tuple, object] (length 4); _fields has 5 entries: filename, lineno, function, code_context, index. Verified with Python 3.14.3."
    - "inspect.Parameter is a plain Python class inheriting from object; MRO len is 2; __doc__ len is 708. Verified with Python 3.14.3."
    - "inspect.getdoc: __qualname__ 'getdoc', __doc__ len 237, co_argcount 1. Verified with Python 3.14.3."
    - "inspect.getfile: __qualname__ 'getfile', __doc__ len 64, co_argcount 1. Verified with Python 3.14.3."
    - "inspect.getsource: __qualname__ 'getsource', __doc__ len 250, co_argcount 1. Verified with Python 3.14.3."
    - "inspect.getmembers: __qualname__ 'getmembers', __doc__ len 134, co_argcount 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FrameInfo namedtuple class identity (Python 3.14 structure)
#
# Wave 273 theme: inspect.FrameInfo — namedtuple with intermediate private base.
#
# inspect.FrameInfo.__class__.__name__ == 'type'
# inspect.FrameInfo.__name__ == 'FrameInfo' (len 9)
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# len(inspect.FrameInfo.__mro__) == 4
# len(inspect.FrameInfo._fields) == 6
#
# In Python 3.14 FrameInfo has an intermediate private base '_FrameInfo';
# MRO is [FrameInfo, _FrameInfo, tuple, object] (length 4). New to extra145.
# ---------------------------------------------------------------------------

table inspect_extra145.frameinfo_identity:
  description: "inspect.FrameInfo: __name__ 'FrameInfo' len 9, __module__ 'inspect', __bases__[0].__name__ '_FrameInfo', MRO len 4, _fields len 6; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectframeinfo145

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_class_name_eq_type,
       "FrameInfo.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FrameInfo.__class__.__name__.__eq__('type') == True — FrameInfo is a namedtuple-derived class defined in Lib/inspect.py; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra145"]
    - [frameinfo_name_eq,
       "FrameInfo.__name__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — the class __name__ is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra145"]
    - [frameinfo_name_len_eq_9,
       "FrameInfo.__name__.__len__",
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — __name__ is 'FrameInfo' which has 9 characters; len('FrameInfo') == 9; new to extra145"]
    - [frameinfo_module_eq_inspect,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra145"]
    - [frameinfo_bases_first_eq__FrameInfo,
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — in Python 3.14, FrameInfo has an intermediate private base class '_FrameInfo'; __bases__[0].__name__ is '_FrameInfo'; str.__eq__('_FrameInfo') returns True; new to extra145"]
    - [frameinfo_mro_len_eq_4,
       "FrameInfo.__mro__.__len__",
       [],
       4,
       "inspect.FrameInfo.__mro__.__len__() == 4 — MRO is [FrameInfo, _FrameInfo, tuple, object]; in Python 3.14 there is an intermediate _FrameInfo base so MRO length is 4 (not 3); len(__mro__) is 4; new to extra145"]
    - [frameinfo_fields_len_eq_6,
       "FrameInfo._fields.__len__",
       [],
       6,
       "inspect.FrameInfo._fields.__len__() == 6 — FrameInfo._fields is ('frame', 'filename', 'lineno', 'function', 'code_context', 'index'); 6 fields; len(_fields) is 6; new to extra145"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Traceback namedtuple class identity (Python 3.14 structure)
#
# Wave 273 theme: inspect.Traceback — namedtuple with intermediate _Traceback base.
#
# inspect.Traceback.__class__.__name__ == 'type'
# inspect.Traceback.__name__ == 'Traceback' (len 9)
# inspect.Traceback.__module__ == 'inspect'
# inspect.Traceback.__bases__[0].__name__ == '_Traceback'
# len(inspect.Traceback.__mro__) == 4
# len(inspect.Traceback._fields) == 5
#
# Like FrameInfo, Traceback has an intermediate private base in Python 3.14.
# _fields has 5 entries: filename, lineno, function, code_context, index.
# New to extra145.
# ---------------------------------------------------------------------------

table inspect_extra145.traceback_identity:
  description: "inspect.Traceback: __name__ 'Traceback' len 9, __module__ 'inspect', __bases__[0].__name__ '_Traceback', MRO len 4, _fields len 5; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspecttraceback145

  columns: [id, function, args, expected, description]
  rows:
    - [traceback_class_name_eq_type,
       "Traceback.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Traceback.__class__.__name__.__eq__('type') == True — Traceback is a namedtuple-derived class defined in Lib/inspect.py; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra145"]
    - [traceback_name_eq,
       "Traceback.__name__.__eq__",
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — the class __name__ is 'Traceback'; str.__eq__('Traceback') returns True; new to extra145"]
    - [traceback_module_eq_inspect,
       "Traceback.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra145"]
    - [traceback_bases_first_eq__Traceback,
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — in Python 3.14, Traceback has an intermediate private base '_Traceback'; __bases__[0].__name__ is '_Traceback'; str.__eq__('_Traceback') returns True; new to extra145"]
    - [traceback_mro_len_eq_4,
       "Traceback.__mro__.__len__",
       [],
       4,
       "inspect.Traceback.__mro__.__len__() == 4 — MRO is [Traceback, _Traceback, tuple, object]; len(__mro__) is 4; new to extra145"]
    - [traceback_fields_len_eq_5,
       "Traceback._fields.__len__",
       [],
       5,
       "inspect.Traceback._fields.__len__() == 5 — Traceback._fields is ('filename', 'lineno', 'function', 'code_context', 'index'); 5 fields; len(_fields) is 5; new to extra145"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter class identity and doc
#
# Wave 273 theme: inspect.Parameter — represents a parameter in a callable's signature.
#
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__bases__[0].__name__ == 'object'
# len(inspect.Parameter.__mro__) == 2
# len(inspect.Parameter.__doc__) == 708
#
# Parameter is a plain Python class (not a namedtuple); it inherits from object.
# New to extra145.
# ---------------------------------------------------------------------------

table inspect_extra145.parameter_identity:
  description: "inspect.Parameter: __name__ 'Parameter', __module__ 'inspect', __bases__[0]=='object', MRO len 2, __doc__ len 708; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam145

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_class_name_eq_type,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a Python class defined in Lib/inspect.py representing a callable parameter; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra145"]
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — the class __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra145"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra145"]
    - [parameter_bases_first_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra145"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter inherits directly from object; MRO is [Parameter, object]; len(__mro__) is 2; new to extra145"]
    - [parameter_doc_len_eq_708,
       "Parameter.__doc__.__len__",
       [],
       708,
       "inspect.Parameter.__doc__.__len__() == 708 — the Parameter class docstring has 708 characters; len(__doc__) == 708; verified with Python 3.14.3; new to extra145"]

# ---------------------------------------------------------------------------
# Table 4: inspect introspection functions — qualname, doc, co_argcount
#
# Wave 273 theme: inspect utility functions for introspection.
#
# inspect.getdoc.__qualname__ == 'getdoc'; len(__doc__) == 237; co_argcount == 1
# inspect.getfile.__qualname__ == 'getfile'; len(__doc__) == 64; co_argcount == 1
# inspect.getsource.__qualname__ == 'getsource'; len(__doc__) == 250; co_argcount == 1
# inspect.getmembers.__qualname__ == 'getmembers'; len(__doc__) == 134; co_argcount == 2
#
# These are Python functions in Lib/inspect.py. New to extra145.
# ---------------------------------------------------------------------------

table inspect_extra145.introspection_function_attrs:
  description: "inspect.getdoc/getfile/getsource/getmembers: Python functions, __qualname__, __doc__ len, co_argcount; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfuncs145

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_qualname_eq,
       "getdoc.__qualname__.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__.__eq__('getdoc') == True — getdoc is a Python function defined in Lib/inspect.py; its __qualname__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra145"]
    - [getdoc_doc_len_eq_237,
       "getdoc.__doc__.__len__",
       [],
       237,
       "inspect.getdoc.__doc__.__len__() == 237 — the getdoc docstring has 237 characters; getdoc retrieves the docstring for an object, cleaning up indentation; len(__doc__) == 237; verified with Python 3.14.3; new to extra145"]
    - [getdoc_co_argcount_eq_1,
       "getdoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra145"]
    - [getfile_qualname_eq,
       "getfile.__qualname__.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__qualname__.__eq__('getfile') == True — getfile is a Python function in Lib/inspect.py; its __qualname__ is 'getfile'; str.__eq__('getfile') returns True; new to extra145"]
    - [getfile_doc_len_eq_64,
       "getfile.__doc__.__len__",
       [],
       64,
       "inspect.getfile.__doc__.__len__() == 64 — the getfile docstring has 64 characters; getfile returns the file in which an object was defined; len(__doc__) == 64; verified with Python 3.14.3; new to extra145"]
    - [getsource_doc_len_eq_250,
       "getsource.__doc__.__len__",
       [],
       250,
       "inspect.getsource.__doc__.__len__() == 250 — the getsource docstring has 250 characters; getsource returns the source code text for a Python object; len(__doc__) == 250; verified with Python 3.14.3; new to extra145"]
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers takes 2 positional-or-keyword arguments: object and optional predicate; co_argcount is 2; int.__eq__(2) returns True; new to extra145"]
    - [getmembers_doc_len_eq_134,
       "getmembers.__doc__.__len__",
       [],
       134,
       "inspect.getmembers.__doc__.__len__() == 134 — the getmembers docstring has 134 characters; getmembers returns all attributes of object as (name, value) pairs; len(__doc__) == 134; verified with Python 3.14.3; new to extra145"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra145
# ---------------------------------------------------------------------------

invariant inspect_extra145.frameinfo_name_len:
  description: "len(inspect.FrameInfo.__name__) == 9 — __name__ is 'FrameInfo'; wave 273; new to extra145"
  kind: python_call_eq
  function: FrameInfo.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra145.frameinfo_mro_len:
  description: "len(inspect.FrameInfo.__mro__) == 4 — MRO is [FrameInfo, _FrameInfo, tuple, object] in Python 3.14; wave 273; new to extra145"
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra145.frameinfo_bases_first:
  description: "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — intermediate private base in Python 3.14; wave 273; new to extra145"
  kind: python_call_eq
  function: "FrameInfo.__bases__[0].__name__.__eq__"
  args: ["_FrameInfo"]
  expected: true

invariant inspect_extra145.frameinfo_fields_len:
  description: "len(inspect.FrameInfo._fields) == 6 — fields: frame, filename, lineno, function, code_context, index; wave 273; new to extra145"
  kind: python_call_eq
  function: FrameInfo._fields.__len__
  args: []
  expected: 6

invariant inspect_extra145.traceback_mro_len:
