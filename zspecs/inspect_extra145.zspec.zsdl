invariant inspect_extra145.parameter_doc_len:
  description: "len(inspect.Parameter.__doc__) == 708 — Parameter class docstring has 708 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: Parameter.__doc__.__len__
  args: []
