spec: functools_extra270
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools module __name__, __package__, __spec__ identity; functools.__all__ type and length; key exported names present in functools.__all__."
    - "functools.__name__ == 'functools' — the module's own name attribute. Verified with Python 3.14.3."
    - "functools.__package__ == '' — functools is a top-level Python module (Lib/functools.py), not a package directory; its __package__ is the empty string. Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec' — functools.__spec__ is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' — the spec's name matches the module name. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is loaded from Lib/functools.py by SourceFileLoader. Verified with Python 3.14.3."
    - "type(functools.__all__).__name__ == 'list' — functools.__all__ is a plain Python list. Verified with Python 3.14.3."
    - "len(functools.__all__) == 15 — functools.__all__ lists 15 public names. Verified with Python 3.14.3."
    - "functools.__all__ contains 'reduce', 'wraps', 'lru_cache', 'cached_property', 'partial', 'total_ordering'. All verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools module __name__, __package__, __spec__ identity
#
# functools.__name__ == 'functools'
# functools.__package__ == ''
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.name == 'functools'
# functools.__loader__.__class__.__name__ == 'SourceFileLoader'
#
# functools is a top-level module in Lib/functools.py loaded by SourceFileLoader.
# Its __package__ is '' (empty string). New to extra270.
# ---------------------------------------------------------------------------

table functools_extra270.module_identity:
  description: "functools module __name__, __package__, __spec__, __loader__ identity; new to extra270"
  kind: python_call_eq
  category: identity
  id_prefix: ftmod270

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       "__name__.__eq__",
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the functools module's __name__ attribute is the string 'functools'; str.__eq__('functools') returns True; new to extra270"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "functools.__package__.__eq__('') == True — functools is a top-level Python module in Lib/functools.py; its __package__ is the empty string '' (not a package directory); str.__eq__('') returns True; new to extra270"]
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — functools.__spec__ is an importlib.machinery.ModuleSpec instance describing the functools module; str.__eq__('ModuleSpec') returns True; new to extra270"]
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — the ModuleSpec's name field matches the module's __name__; str.__eq__('functools') returns True; new to extra270"]
    - [loader_class_source_file_loader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is loaded from Lib/functools.py by importlib._bootstrap_external.SourceFileLoader; str.__eq__('SourceFileLoader') returns True; new to extra270"]

# ---------------------------------------------------------------------------
# Table 2: functools.__all__ type and length
#
# type(functools.__all__).__name__ == 'list'
# len(functools.__all__) == 15
# functools.__name__.__len__() == 9
# functools.__package__.__len__() == 0
# functools.__package__.__class__.__name__ == 'str'
#
# functools.__all__ is a plain Python list of 15 exported names. New to extra270.
# ---------------------------------------------------------------------------

table functools_extra270.all_type_and_length:
  description: "functools.__all__ type list, length 15; __name__ len 9; __package__ len 0; new to extra270"
  kind: python_call_eq
  category: identity
  id_prefix: ftall270

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "functools.__all__.__class__.__name__.__eq__('list') == True — functools.__all__ is a plain Python list (not a tuple or set); its __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra270"]
    - [all_len_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — functools.__all__ contains 15 exported public names including update_wrapper, wraps, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, total_ordering, cache, cmp_to_key, lru_cache, reduce, partial, partialmethod, singledispatch, singledispatchmethod, cached_property, Placeholder; list.__len__() returns 15; new to extra270"]
    - [mod_name_len_9,
       "__name__.__len__",
       [],
       9,
       "functools.__name__.__len__() == 9 — the string 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra270"]
    - [mod_package_len_0,
       "__package__.__len__",
       [],
       0,
       "functools.__package__.__len__() == 0 — functools.__package__ is the empty string ''; its length is 0; str.__len__() returns 0; new to extra270"]
    - [mod_package_class_str,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__package__.__class__.__name__.__eq__('str') == True — functools.__package__ is a string (the empty string ''); its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra270"]

# ---------------------------------------------------------------------------
# Table 3: functools.__all__ membership — key exported names
#
# 'reduce' in functools.__all__ == True
# 'wraps' in functools.__all__ == True
# 'lru_cache' in functools.__all__ == True
# 'cached_property' in functools.__all__ == True
# 'partial' in functools.__all__ == True
#
# These are the most widely used names from the functools module. New to extra270.
# ---------------------------------------------------------------------------

table functools_extra270.all_membership:
  description: "functools.__all__ contains reduce, wraps, lru_cache, cached_property, partial; new to extra270"
  kind: python_call_eq
  category: identity
  id_prefix: ftallm270

  columns: [id, function, args, expected, description]
  rows:
    - [has_reduce,
       "__all__.__contains__",
       ["reduce"],
       true,
       "functools.__all__.__contains__('reduce') == True — 'reduce' is listed in functools.__all__; list.__contains__('reduce') returns True; new to extra270"]
    - [has_wraps,
       "__all__.__contains__",
       ["wraps"],
       true,
       "functools.__all__.__contains__('wraps') == True — 'wraps' is listed in functools.__all__; list.__contains__('wraps') returns True; new to extra270"]
    - [has_lru_cache,
       "__all__.__contains__",
       ["lru_cache"],
       true,
       "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is listed in functools.__all__; list.__contains__('lru_cache') returns True; new to extra270"]
    - [has_cached_property,
       "__all__.__contains__",
       ["cached_property"],
       true,
       "functools.__all__.__contains__('cached_property') == True — 'cached_property' is listed in functools.__all__; list.__contains__('cached_property') returns True; new to extra270"]
    - [has_partial,
       "__all__.__contains__",
       ["partial"],
       true,
       "functools.__all__.__contains__('partial') == True — 'partial' is listed in functools.__all__; list.__contains__('partial') returns True; new to extra270"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra270
# ---------------------------------------------------------------------------

invariant functools_extra270.module_name.eq:
  description: "functools.__name__.__eq__('functools') == True; new to extra270"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra270.module_package.empty:
  description: "functools.__package__.__eq__('') == True — top-level module, not a package; new to extra270"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant functools_extra270.spec_class.modulespec:
  description: "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True; new to extra270"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant functools_extra270.spec_name.eq:
  description: "functools.__spec__.name.__eq__('functools') == True; new to extra270"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra270.loader_class.source_file_loader:
  description: "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True; new to extra270"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant functools_extra270.all_class.list:
  description: "functools.__all__.__class__.__name__.__eq__('list') == True — __all__ is a plain list; new to extra270"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant functools_extra270.all_len.15:
  description: "functools.__all__.__len__() == 15 — 15 public names exported; new to extra270"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15

invariant functools_extra270.all.has_total_ordering:
  description: "functools.__all__.__contains__('total_ordering') == True; new to extra270"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["total_ordering"]
  expected: true
