spec: decimal_extra95
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra94

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra94.zspec.zsdl."
    - "This spec covers: decimal signal/exception class identity — DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, Clamped."
    - "decimal.DecimalException.__class__.__name__ = 'type' — uses the standard type metaclass."
    - "decimal.DecimalException.__module__ = 'decimal' — defined in the public decimal module."
    - "decimal.DecimalException.__bases__[0].__name__ = 'ArithmeticError' — DecimalException extends ArithmeticError."
    - "decimal.DecimalException.__mro__.__len__() = 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.InvalidOperation.__bases__[0].__name__ = 'DecimalException' — directly extends DecimalException."
    - "decimal.InvalidOperation.__mro__.__len__() = 6 — MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.DivisionByZero.__bases__ has two entries: ['DecimalException', 'ZeroDivisionError'] — multiple inheritance from both decimal and built-in exception hierarchies."
    - "decimal.DivisionByZero.__mro__.__len__() = 7 — includes ZeroDivisionError in the MRO."
    - "decimal.Overflow.__bases__[0].__name__ = 'Inexact' — Overflow extends Inexact (and also Rounded)."
    - "decimal.Overflow.__mro__.__len__() = 8 — MRO is [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Underflow.__bases__[0].__name__ = 'Inexact' — same first base as Overflow."
    - "decimal.Underflow.__mro__.__len__() = 9 — includes Subnormal in the MRO."
    - "decimal.Inexact.__bases__[0].__name__ = 'DecimalException' — direct subclass of DecimalException."
    - "decimal.Rounded.__bases__[0].__name__ = 'DecimalException' — direct subclass of DecimalException."
    - "decimal.Subnormal.__bases__[0].__name__ = 'DecimalException' — direct subclass of DecimalException."
    - "decimal.Clamped.__bases__[0].__name__ = 'DecimalException' — direct subclass of DecimalException."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.DecimalException class hierarchy
# DecimalException is the root of the decimal exception hierarchy.
# It extends ArithmeticError (a built-in exception class).
# MRO length == 5: [DecimalException, ArithmeticError, Exception, BaseException, object].
# ---------------------------------------------------------------------------

table decimal_extra95.DecimalException_class_hierarchy:
  description: "decimal.DecimalException class hierarchy: __class__.__name__, __module__, __name__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigcls95

  columns: [id, function, args, expected, description]
  rows:
    - [dexc_meta_eq,      DecimalException.__class__.__name__.__eq__,           ["type"],             true,  "DecimalException.__class__.__name__ == 'type' (standard type metaclass)"]
    - [dexc_module_eq,    DecimalException.__module__.__eq__,                   ["decimal"],          true,  "DecimalException.__module__ == 'decimal' (public module, not '_decimal')"]
    - [dexc_name_eq,      DecimalException.__name__.__eq__,                     ["DecimalException"], true,  "DecimalException.__name__ == 'DecimalException' (bare class name)"]
    - [dexc_qualname_eq,  DecimalException.__qualname__.__eq__,                 ["DecimalException"], true,  "DecimalException.__qualname__ == 'DecimalException'"]
    - [dexc_qualname_len, DecimalException.__qualname__.__len__,                [],                   16,    "DecimalException.__qualname__.__len__() == 16 ('DecimalException' has 16 characters)"]
    - [dexc_base_eq,      "DecimalException.__bases__[0].__name__.__eq__",        ["ArithmeticError"],  true,  "DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException is a subclass of the built-in ArithmeticError)"]
    - [dexc_mro_len,      DecimalException.__mro__.__len__,                     [],                   5,     "DecimalException.__mro__.__len__() == 5 (MRO is [DecimalException, ArithmeticError, Exception, BaseException, object])"]
    - [dexc_mro_not_2,    DecimalException.__mro__.__len__.__eq__,              [2],                  false, "DecimalException.__mro__.__len__() is NOT 2 (it is a 5-deep exception hierarchy)"]

# ---------------------------------------------------------------------------
# decimal.InvalidOperation and decimal.DivisionByZero class hierarchy
# InvalidOperation directly extends DecimalException (MRO length 6).
# DivisionByZero uses multiple inheritance: extends both DecimalException AND
# ZeroDivisionError, giving it a 7-entry MRO.
# ---------------------------------------------------------------------------

table decimal_extra95.InvalidOperation_DivisionByZero_hierarchy:
  description: "decimal.InvalidOperation and decimal.DivisionByZero class hierarchy; DivisionByZero uses multiple inheritance from both DecimalException and ZeroDivisionError"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigcls95

  columns: [id, function, args, expected, description]
  rows:
    - [invop_meta_eq,   InvalidOperation.__class__.__name__.__eq__,           ["type"],             true,  "InvalidOperation.__class__.__name__ == 'type'"]
    - [invop_module_eq, InvalidOperation.__module__.__eq__,                   ["decimal"],          true,  "InvalidOperation.__module__ == 'decimal'"]
    - [invop_base_eq,   "InvalidOperation.__bases__[0].__name__.__eq__",        ["DecimalException"],  true,  "InvalidOperation.__bases__[0].__name__ == 'DecimalException' (direct subclass)"]
    - [invop_mro_len,   InvalidOperation.__mro__.__len__,                     [],                   6,     "InvalidOperation.__mro__.__len__() == 6 (MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object])"]
    - [invop_qn_len,    InvalidOperation.__qualname__.__len__,                [],                   16,    "InvalidOperation.__qualname__.__len__() == 16 ('InvalidOperation' has 16 characters)"]
    - [divz_meta_eq,    DivisionByZero.__class__.__name__.__eq__,             ["type"],             true,  "DivisionByZero.__class__.__name__ == 'type'"]
    - [divz_module_eq,  DivisionByZero.__module__.__eq__,                     ["decimal"],          true,  "DivisionByZero.__module__ == 'decimal'"]
    - [divz_base_eq,    "DivisionByZero.__bases__[0].__name__.__eq__",          ["DecimalException"],  true,  "DivisionByZero.__bases__[0].__name__ == 'DecimalException' (first base in MRO)"]
    - [divz_base1_eq,   "DivisionByZero.__bases__[1].__name__.__eq__",          ["ZeroDivisionError"], true,  "DivisionByZero.__bases__[1].__name__ == 'ZeroDivisionError' (second base; DivisionByZero uses multiple inheritance to also be a ZeroDivisionError)"]
    - [divz_mro_len,    DivisionByZero.__mro__.__len__,                       [],                   7,     "DivisionByZero.__mro__.__len__() == 7 (MRO includes ZeroDivisionError: [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object])"]
    - [divz_qn_len,     DivisionByZero.__qualname__.__len__,                  [],                   14,    "DivisionByZero.__qualname__.__len__() == 14 ('DivisionByZero' has 14 characters)"]

# ---------------------------------------------------------------------------
# decimal.Overflow and decimal.Underflow class hierarchy
# Both Overflow and Underflow extend Inexact (and Rounded), giving them
# deeper MROs. Overflow.__mro__.__len__() == 8; Underflow.__mro__.__len__() == 9.
# Underflow also extends Subnormal, adding one extra entry.
# ---------------------------------------------------------------------------

table decimal_extra95.Overflow_Underflow_Inexact_hierarchy:
  description: "decimal.Overflow and Underflow extend Inexact; Overflow MRO length==8, Underflow MRO length==9 (adds Subnormal); Inexact, Rounded, Subnormal, Clamped all directly extend DecimalException"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigcls95

  columns: [id, function, args, expected, description]
  rows:
    - [inexact_base_eq,   "Inexact.__bases__[0].__name__.__eq__",     ["DecimalException"], true,  "Inexact.__bases__[0].__name__ == 'DecimalException' (Inexact is a direct subclass)"]
    - [inexact_mro_len,   Inexact.__mro__.__len__,                   [],                   6,     "Inexact.__mro__.__len__() == 6"]
    - [rounded_base_eq,   "Rounded.__bases__[0].__name__.__eq__",     ["DecimalException"], true,  "Rounded.__bases__[0].__name__ == 'DecimalException'"]
    - [rounded_mro_len,   Rounded.__mro__.__len__,                   [],                   6,     "Rounded.__mro__.__len__() == 6"]
    - [subnorm_base_eq,   "Subnormal.__bases__[0].__name__.__eq__",   ["DecimalException"], true,  "Subnormal.__bases__[0].__name__ == 'DecimalException'"]
    - [clamped_base_eq,   "Clamped.__bases__[0].__name__.__eq__",     ["DecimalException"], true,  "Clamped.__bases__[0].__name__ == 'DecimalException'"]
    - [overflow_base_eq,  "Overflow.__bases__[0].__name__.__eq__",    ["Inexact"],          true,  "Overflow.__bases__[0].__name__ == 'Inexact' (Overflow extends Inexact, not DecimalException directly; an overflow is always an inexact result)"]
    - [overflow_mro_len,  Overflow.__mro__.__len__,                  [],                   8,     "Overflow.__mro__.__len__() == 8 (MRO is [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object])"]
    - [overflow_module_eq, Overflow.__module__.__eq__,               ["decimal"],          true,  "Overflow.__module__ == 'decimal'"]
    - [underflow_base_eq,  "Underflow.__bases__[0].__name__.__eq__",   ["Inexact"],          true,  "Underflow.__bases__[0].__name__ == 'Inexact' (same first base as Overflow)"]
    - [underflow_mro_len,  Underflow.__mro__.__len__,                [],                   9,     "Underflow.__mro__.__len__() == 9 (MRO is [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]; adds Subnormal)"]
    - [underflow_module_eq, Underflow.__module__.__eq__,             ["decimal"],          true,  "Underflow.__module__ == 'decimal'"]
    - [overflow_qn_len,    Overflow.__qualname__.__len__,            [],                   8,     "Overflow.__qualname__.__len__() == 8 ('Overflow' has 8 characters)"]
    - [underflow_qn_len,   Underflow.__qualname__.__len__,           [],                   9,     "Underflow.__qualname__.__len__() == 9 ('Underflow' has 9 characters)"]
    - [inexact_not_dexc,   "Inexact.__bases__[0].__name__.__eq__",    ["ArithmeticError"],  false, "Inexact.__bases__[0].__name__ is NOT 'ArithmeticError' (Inexact directly extends DecimalException, not ArithmeticError)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra95.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException is the root of the decimal exception hierarchy and extends the built-in ArithmeticError, making all decimal exceptions catchable as ArithmeticError)"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__bases__[0].__name__.__eq__
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra95.DecimalException.mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 (the MRO of DecimalException is [DecimalException, ArithmeticError, Exception, BaseException, object]; it is a 5-deep exception hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra95.DivisionByZero.second_base_is_ZeroDivisionError:
  description: "decimal.DivisionByZero.__bases__[1].__name__ == 'ZeroDivisionError' (DivisionByZero uses multiple inheritance: it extends both DecimalException and ZeroDivisionError, so it can be caught by either base class)"
  category: class_identity
  kind: python_call_eq
  function: DivisionByZero.__bases__[1].__name__.__eq__
  args: ["ZeroDivisionError"]
  expected: true

invariant decimal_extra95.Overflow.base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow extends Inexact because an arithmetic overflow always produces an inexact result; the exception hierarchy reflects this semantic relationship)"
  category: class_identity
  kind: python_call_eq
  function: Overflow.__bases__[0].__name__.__eq__
  args: ["Inexact"]
  expected: true

invariant decimal_extra95.Underflow.mro_len_9:
  description: "decimal.Underflow.__mro__.__len__() == 9 (the MRO of Underflow is [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]; it is the deepest single-base-chain decimal exception)"
  category: class_identity
  kind: python_call_eq
  function: Underflow.__mro__.__len__
  args: []
  expected: 9
