spec: asyncio_extra256
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-policy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-policy.html — asyncio event loop policy documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py, Lib/asyncio/locks.py"
  notes:
    - "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy' (len=24) — the public alias exposes the private implementation class; __module__ == 'asyncio.events' (len=14); __bases__[0].__name__ == 'object'."
    - "asyncio.AbstractEventLoopPolicy.get_event_loop.__name__ == 'get_event_loop' (len=14); set_event_loop.__name__ == 'set_event_loop' (len=14); new_event_loop.__name__ == 'new_event_loop' (len=14) — all three policy method names share the same length (14)."
    - "asyncio.Semaphore and asyncio.Lock both inherit from '_ContextManagerMixin'; Semaphore.__module__ == 'asyncio.locks' (len=12); Lock.__module__ == 'asyncio.locks' (len=12)."
    - "asyncio.Semaphore.acquire.__name__ == 'acquire' (len=7); Semaphore.release.__name__ == 'release' (len=7); Lock.acquire.__name__ == 'acquire' (len=7); Lock.release.__name__ == 'release' (len=7) — acquire and release are exactly length 7 for both primitives."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio AbstractEventLoopPolicy class identity
#
# asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy' (len=24)
# asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events' (len=14)
# asyncio.AbstractEventLoopPolicy.__bases__[0].__name__ == 'object' (len=6)
# asyncio.AbstractEventLoopPolicy.get_event_loop.__name__ == 'get_event_loop' (len=14)
# asyncio.AbstractEventLoopPolicy.set_event_loop.__name__ == 'set_event_loop' (len=14)
# asyncio.AbstractEventLoopPolicy.new_event_loop.__name__ == 'new_event_loop' (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra256.abstract_event_loop_policy_identity:
  description: "asyncio AbstractEventLoopPolicy class identity — __name__ is '_AbstractEventLoopPolicy'(len=24), a private implementation class exposed via public alias; __module__ == 'asyncio.events'(len=14); inherits from object; all three policy methods (get/set/new_event_loop) share name length 14; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: async256aelp

  columns: [id, function, args, expected, description]
  rows:
    - [aelp_name_eq,      AbstractEventLoopPolicy.__name__.__eq__,                        ["_AbstractEventLoopPolicy"],  true, "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy'; verified with Python 3.14.4"]
    - [aelp_name_len,     AbstractEventLoopPolicy.__name__.__len__,                       [],                             24,   "asyncio.AbstractEventLoopPolicy.__name__.__len__() == 24; verified with Python 3.14.4"]
    - [aelp_mod_eq,       AbstractEventLoopPolicy.__module__.__eq__,                      ["asyncio.events"],            true, "asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events'; verified with Python 3.14.4"]
    - [aelp_mod_len,      AbstractEventLoopPolicy.__module__.__len__,                     [],                             14,   "asyncio.AbstractEventLoopPolicy.__module__.__len__() == 14; verified with Python 3.14.4"]
    - [aelp_base_eq,      "AbstractEventLoopPolicy.__bases__[0].__name__.__eq__",         ["object"],                    true, "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__ == 'object' — policy root class inherits directly from object; verified with Python 3.14.4"]
    - [aelp_base_len,     "AbstractEventLoopPolicy.__bases__[0].__name__.__len__",        [],                             6,    "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.4"]
    - [aelp_get_name_eq,  AbstractEventLoopPolicy.get_event_loop.__name__.__eq__,         ["get_event_loop"],            true, "asyncio.AbstractEventLoopPolicy.get_event_loop.__name__ == 'get_event_loop'; verified with Python 3.14.4"]
    - [aelp_get_name_len, AbstractEventLoopPolicy.get_event_loop.__name__.__len__,        [],                             14,   "asyncio.AbstractEventLoopPolicy.get_event_loop.__name__.__len__() == 14; verified with Python 3.14.4"]
    - [aelp_set_name_eq,  AbstractEventLoopPolicy.set_event_loop.__name__.__eq__,         ["set_event_loop"],            true, "asyncio.AbstractEventLoopPolicy.set_event_loop.__name__ == 'set_event_loop'; verified with Python 3.14.4"]
    - [aelp_set_name_len, AbstractEventLoopPolicy.set_event_loop.__name__.__len__,        [],                             14,   "asyncio.AbstractEventLoopPolicy.set_event_loop.__name__.__len__() == 14; verified with Python 3.14.4"]
    - [aelp_new_name_eq,  AbstractEventLoopPolicy.new_event_loop.__name__.__eq__,         ["new_event_loop"],            true, "asyncio.AbstractEventLoopPolicy.new_event_loop.__name__ == 'new_event_loop'; verified with Python 3.14.4"]
    - [aelp_new_name_len, AbstractEventLoopPolicy.new_event_loop.__name__.__len__,        [],                             14,   "asyncio.AbstractEventLoopPolicy.new_event_loop.__name__.__len__() == 14 — all three policy method names share length 14; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# asyncio Lock and Semaphore method identity
#
# asyncio.Semaphore.__name__ == 'Semaphore' (len=9)
# asyncio.Semaphore.__module__ == 'asyncio.locks' (len=12)
# asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'
# asyncio.Semaphore.acquire.__name__ == 'acquire' (len=7)
# asyncio.Semaphore.release.__name__ == 'release' (len=7)
# asyncio.Lock.__name__ == 'Lock' (len=4)
# asyncio.Lock.__module__ == 'asyncio.locks' (len=12)
# asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'
# asyncio.Lock.acquire.__name__ == 'acquire' (len=7)
# asyncio.Lock.release.__name__ == 'release' (len=7)
# ---------------------------------------------------------------------------

table asyncio_extra256.lock_semaphore_method_identity:
  description: "asyncio Lock(len=4) and Semaphore(len=9) method identity — both inherit from '_ContextManagerMixin'; both defined in asyncio.locks(len=12); acquire(len=7) and release(len=7) method names are symmetric for both primitives; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: async256ls

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,    Semaphore.__name__.__eq__,                          ["Semaphore"],               true, "asyncio.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.4"]
    - [sem_name_len,   Semaphore.__name__.__len__,                         [],                           9,    "asyncio.Semaphore.__name__.__len__() == 9; verified with Python 3.14.4"]
    - [sem_mod_eq,     Semaphore.__module__.__eq__,                        ["asyncio.locks"],            true, "asyncio.Semaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.4"]
    - [sem_mod_len,    Semaphore.__module__.__len__,                       [],                           12,   "asyncio.Semaphore.__module__.__len__() == 12; verified with Python 3.14.4"]
    - [sem_base_eq,    "Semaphore.__bases__[0].__name__.__eq__",           ["_ContextManagerMixin"],    true, "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.4"]
    - [sem_acq_eq,     Semaphore.acquire.__name__.__eq__,                  ["acquire"],                 true, "asyncio.Semaphore.acquire.__name__ == 'acquire'; verified with Python 3.14.4"]
    - [sem_acq_len,    Semaphore.acquire.__name__.__len__,                 [],                           7,    "asyncio.Semaphore.acquire.__name__.__len__() == 7; verified with Python 3.14.4"]
    - [sem_rel_eq,     Semaphore.release.__name__.__eq__,                  ["release"],                 true, "asyncio.Semaphore.release.__name__ == 'release'; verified with Python 3.14.4"]
    - [sem_rel_len,    Semaphore.release.__name__.__len__,                 [],                           7,    "asyncio.Semaphore.release.__name__.__len__() == 7; verified with Python 3.14.4"]
    - [lk_name_eq,     Lock.__name__.__eq__,                               ["Lock"],                    true, "asyncio.Lock.__name__ == 'Lock'; verified with Python 3.14.4"]
    - [lk_name_len,    Lock.__name__.__len__,                              [],                           4,    "asyncio.Lock.__name__.__len__() == 4; verified with Python 3.14.4"]
    - [lk_mod_eq,      Lock.__module__.__eq__,                             ["asyncio.locks"],            true, "asyncio.Lock.__module__ == 'asyncio.locks'; verified with Python 3.14.4"]
    - [lk_mod_len,     Lock.__module__.__len__,                            [],                           12,   "asyncio.Lock.__module__.__len__() == 12; verified with Python 3.14.4"]
    - [lk_base_eq,     "Lock.__bases__[0].__name__.__eq__",                ["_ContextManagerMixin"],    true, "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.4"]
    - [lk_acq_eq,      Lock.acquire.__name__.__eq__,                       ["acquire"],                 true, "asyncio.Lock.acquire.__name__ == 'acquire'; verified with Python 3.14.4"]
    - [lk_acq_len,     Lock.acquire.__name__.__len__,                      [],                           7,    "asyncio.Lock.acquire.__name__.__len__() == 7; verified with Python 3.14.4"]
    - [lk_rel_eq,      Lock.release.__name__.__eq__,                       ["release"],                 true, "asyncio.Lock.release.__name__ == 'release'; verified with Python 3.14.4"]
    - [lk_rel_len,     Lock.release.__name__.__len__,                      [],                           7,    "asyncio.Lock.release.__name__.__len__() == 7 — acquire and release are exactly length 7 for both Lock and Semaphore; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra256
# ---------------------------------------------------------------------------

invariant asyncio_extra256.policy_name_is_private:
  description: "asyncio.AbstractEventLoopPolicy.__name__.__eq__('_AbstractEventLoopPolicy') returns True — the public alias exposes a private implementation class (len=24); the leading underscore is preserved in __name__ despite the public alias lacking it; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoopPolicy.__name__.__eq__
  args: ["_AbstractEventLoopPolicy"]
  expected: true

invariant asyncio_extra256.lock_semaphore_share_base:
  description: "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — Lock and Semaphore share the same private base class '_ContextManagerMixin', establishing both as context-manager-capable synchronization primitives defined in asyncio.locks; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true
