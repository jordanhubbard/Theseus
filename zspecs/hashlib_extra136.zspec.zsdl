spec: hashlib_extra136
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / md5/sha1/sha224/sha256/sha384/sha512 __name__ equality / blake2b/blake2s class identity and module / new function class / algorithms_guaranteed length (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 345 theme: sha3_224/sha3_256/sha3_384/sha3_512/shake_128/shake_256 __name__ equality / file_digest __name__/__qualname__/__module__/__code__.co_argcount / hashlib.new true __name__ ('__hash_new') and __qualname__."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new'. The public attribute 'new' in hashlib actually points to a private function named '__hash_new' — its __name__ and __qualname__ are both '__hash_new', not 'new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. Same as __name__: the qualname is '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__name__ == 'file_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__ == 'file_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_argcount == 2. file_digest takes (fileobj, digest) — two positional args. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__.__len__() == 16 ('openssl_sha3_224'). hashlib.shake_128.__name__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra98 anchors sha3/shake __qualname__ and __module__; extra99 anchors sha3/shake __class__.__name__. This spec is the first to anchor sha3/shake __name__ equality and file_digest code attributes under hashlibfn136."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224')
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_384.__name__.__eq__('openssl_sha3_384')
# hashlib.sha3_512.__name__.__eq__('openssl_sha3_512')
# hashlib.shake_128.__name__.__eq__('openssl_shake_128')
# hashlib.shake_256.__name__.__eq__('openssl_shake_256')
#
# Wave 345 theme: sha3/shake constructor __name__ equality.
#
# The sha3_* and shake_* family constructors in hashlib are OpenSSL-backed C
# builtins (builtin_function_or_method) from the _hashlib C extension. Like the
# MD5/SHA-1/SHA-2 family, their __name__ carries the 'openssl_' prefix and
# matches their __qualname__. hashlib_extra98 anchors their __qualname__ and
# __module__ at table level; hashlib_extra99 anchors their __class__.__name__==
# 'builtin_function_or_method' at table level. This spec is the first to anchor
# sha3/shake __name__ equality as a table under hashlibfn136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra136.sha3_shake_constructor_names:
  description: "hashlib.sha3_224/__name__.__eq__('openssl_sha3_224')==True / sha3_256/__name__.__eq__('openssl_sha3_256')==True / sha3_384/__name__.__eq__('openssl_sha3_384')==True / sha3_512/__name__.__eq__('openssl_sha3_512')==True / shake_128/__name__.__eq__('openssl_shake_128')==True / shake_256/__name__.__eq__('openssl_shake_256')==True — sha3/shake constructors are OpenSSL C builtins with 'openssl_' prefix in __name__; extra98 anchors __qualname__/__module__; extra99 anchors __class__.__name__; first hashlibfn136 anchor for sha3/shake __name__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfn136

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_name,  sha3_224.__name__.__eq__,  ["openssl_sha3_224"],  true, "sha3_224 is OpenSSL C builtin; __name__ is 'openssl_sha3_224' (16 chars)"]
    - [sha3_256_name,  sha3_256.__name__.__eq__,  ["openssl_sha3_256"],  true, "sha3_256 is OpenSSL C builtin; __name__ is 'openssl_sha3_256' (16 chars)"]
    - [sha3_384_name,  sha3_384.__name__.__eq__,  ["openssl_sha3_384"],  true, "sha3_384 is OpenSSL C builtin; __name__ is 'openssl_sha3_384' (16 chars)"]
    - [sha3_512_name,  sha3_512.__name__.__eq__,  ["openssl_sha3_512"],  true, "sha3_512 is OpenSSL C builtin; __name__ is 'openssl_sha3_512' (16 chars)"]
    - [shake_128_name, shake_128.__name__.__eq__, ["openssl_shake_128"], true, "shake_128 is OpenSSL C builtin; __name__ is 'openssl_shake_128' (17 chars)"]
    - [shake_256_name, shake_256.__name__.__eq__, ["openssl_shake_256"], true, "shake_256 is OpenSSL C builtin; __name__ is 'openssl_shake_256' (17 chars)"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__name__.__eq__('file_digest')
# hashlib.file_digest.__qualname__.__eq__('file_digest')
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__code__.co_argcount.__eq__(2)
# hashlib.file_digest.__class__.__name__.__eq__('function')
#
# Wave 345 theme: file_digest function identity and code attributes.
#
# hashlib.file_digest is a pure-Python function (added in Python 3.11) that
# hashes the contents of a file-like object. It takes two arguments: (fileobj,
# digest) where digest can be a hash name string or a callable returning a hash
# object. hashlib_extra98 anchors file_digest __class__.__name__=='function' and
# __module__=='hashlib' at table level; this spec anchors __name__/__qualname__/
# __module__/__code__.co_argcount via __eq__ calls under hashlibfn136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra136.file_digest_identity:
  description: "hashlib.file_digest/__name__.__eq__('file_digest')==True / file_digest/__qualname__.__eq__('file_digest')==True / file_digest/__module__.__eq__('hashlib')==True / file_digest/__code__/co_argcount.__eq__(2)==True / file_digest/__class__.__name__.__eq__('function')==True — file_digest is a pure-Python function (Python 3.11+) hashing file contents; takes (fileobj, digest) two args; extra98 anchors __class__.__name__ and __module__ at table level; first hashlibfn136 anchor for file_digest __name__/__qualname__/co_argcount"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfn136

  columns: [id, function, args, expected, description]
  rows:
    - [fd_name,     file_digest.__name__.__eq__,                ["file_digest"], true, "file_digest.__name__ is 'file_digest' (11 chars)"]
    - [fd_qualname, file_digest.__qualname__.__eq__,            ["file_digest"], true, "file_digest.__qualname__ is 'file_digest' (top-level, no class prefix)"]
    - [fd_module,   file_digest.__module__.__eq__,              ["hashlib"],     true, "file_digest.__module__ is 'hashlib' (pure-Python in Lib/hashlib.py)"]
    - [fd_argc,     file_digest.__code__.co_argcount.__eq__,    [2],             true, "file_digest takes (fileobj, digest) — co_argcount == 2"]
    - [fd_class,    file_digest.__class__.__name__.__eq__,      ["function"],    true, "file_digest is a pure-Python function (class 'function')"]

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new')
# hashlib.new.__qualname__.__eq__('__hash_new')
# hashlib.new.__module__.__eq__('hashlib')
# hashlib.new.__code__.co_argcount.__eq__(1)
#
# Wave 345 theme: hashlib.new true __name__ and __qualname__ reveal.
#
# The public attribute hashlib.new points to a private function whose actual
# __name__ and __qualname__ are both '__hash_new' (not 'new'). This is the
# result of Python name-mangling / private-function aliasing in Lib/hashlib.py:
# the function is defined as '__hash_new' and then exposed as 'new'. The function
# takes one required positional argument (co_argcount==1, the hash name), plus
# **kwargs via **usedforsecurity. hashlib_extra97 anchors new/__qualname__.__len__()
# == 10 (len('__hash_new')); this spec anchors the string equality and co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra136.new_private_name_reveal:
  description: "hashlib.new/__name__.__eq__('__hash_new')==True / new/__qualname__.__eq__('__hash_new')==True / new/__module__.__eq__('hashlib')==True / new/__code__/co_argcount.__eq__(1)==True — hashlib.new is aliased from private '__hash_new'; its true __name__ and __qualname__ are '__hash_new' (not 'new'); extra97 anchors __qualname__.__len__()==10; first hashlibfn136 anchor for new __name__/__qualname__ string equality and co_argcount"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfn136

  columns: [id, function, args, expected, description]
  rows:
    - [new_name,     new.__name__.__eq__,               ["__hash_new"], true, "hashlib.new.__name__ is '__hash_new' (private function alias)"]
    - [new_qualname, new.__qualname__.__eq__,            ["__hash_new"], true, "hashlib.new.__qualname__ is '__hash_new' (matches __name__ for top-level function)"]
    - [new_module,   new.__module__.__eq__,              ["hashlib"],    true, "hashlib.new.__module__ is 'hashlib' (pure-Python in Lib/hashlib.py)"]
    - [new_argc,     new.__code__.co_argcount.__eq__,    [1],            true, "hashlib.new co_argcount==1 (the hash name string is the required positional arg)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') — standalone
#
# hashlib.sha3_224.__name__ is 'openssl_sha3_224' (16 chars). All SHA-3 family
# constructors carry the 'openssl_' prefix in their __name__, confirming they
# are backed by OpenSSL's SHA-3 implementation via the _hashlib C extension.
# Their __name__ equals their __qualname__ because they are top-level C builtin
# functions. hashlib_extra98 anchors sha3_224.__qualname__ and __module__;
# hashlib_extra99 anchors sha3_224.__class__.__name__. This is the first
# standalone for sha3_224.__name__.__eq__('openssl_sha3_224') under hashlibfn136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra136.sha3_224_name:
  description: "hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') == True — sha3_224 is OpenSSL-backed C builtin; __name__ 'openssl_sha3_224' (16 chars) equals __qualname__; extra98 anchors __qualname__/__module__; extra99 anchors __class__.__name__; first standalone for sha3_224 __name__ equality under hashlibfn136"
  category: type_identity
  kind: python_call_eq
  function: sha3_224.__name__.__eq__
  args: ["openssl_sha3_224"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128') — standalone
#
# hashlib.shake_128.__name__ is 'openssl_shake_128' (17 chars). The shake_128
# and shake_256 constructors are extendable-output functions (XOFs) — unlike
# fixed-output SHA algorithms, their digest length is variable and specified
# at digest-time. Their __name__ still carries the 'openssl_' prefix. This is
# the first standalone for shake_128.__name__.__eq__('openssl_shake_128')
# under hashlibfn136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra136.shake_128_name:
  description: "hashlib.shake_128.__name__.__eq__('openssl_shake_128') == True — shake_128 is an extendable-output function (XOF); __name__ is 'openssl_shake_128' (17 chars); extra98 anchors __qualname__/__module__; first standalone for shake_128 __name__ equality under hashlibfn136"
  category: type_identity
  kind: python_call_eq
  function: shake_128.__name__.__eq__
  args: ["openssl_shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__name__.__eq__('file_digest') — standalone
#
# hashlib.file_digest.__name__ is 'file_digest' (11 chars). Unlike the sha3/shake
# constructors whose __name__ carries the 'openssl_' prefix, file_digest is a
# pure-Python function and its __name__ equals the public attribute name. It was
# added in Python 3.11 as a convenience function for hashing file contents
# efficiently. hashlib_extra98 anchors file_digest __class__.__name__=='function'
# at table level; this is the first standalone for file_digest.__name__.__eq__
# under hashlibfn136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra136.file_digest_name:
  description: "hashlib.file_digest.__name__.__eq__('file_digest') == True — file_digest is a pure-Python function (Python 3.11+) whose __name__ equals the public attribute name (no private aliasing unlike hashlib.new); extra98 anchors __class__.__name__ at table level; first standalone for file_digest.__name__.__eq__ under hashlibfn136"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__name__.__eq__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new'. The public hashlib.new attribute is
# bound to a private function named '__hash_new'. This aliasing is a CPython
# implementation detail: the function is defined privately in Lib/hashlib.py
# as '__hash_new' and exposed as the public 'new' attribute. Inspecting __name__
# reveals the internal name. hashlib_extra97 anchors new/__qualname__.__len__()
# == 10 (len('__hash_new')); this is the first standalone for new.__name__.__eq__
# ('__hash_new') under hashlibfn136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra136.new_name_hash_new:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — the public 'new' attribute is aliased from a private function '__hash_new'; __name__ reveals the internal CPython implementation name; extra97 anchors __qualname__.__len__()==10; first standalone for new.__name__.__eq__ under hashlibfn136"
  category: type_identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_argcount.__eq__(2) — standalone
#
# hashlib.file_digest.__code__.co_argcount is 2. The function signature is
# file_digest(fileobj, digest) where fileobj is a file-like object and digest
# is either a hash name string or a callable returning a new hash object.
# This is distinct from hashlib.new which has co_argcount==1. The file_digest
# function was introduced in Python 3.11 to provide an efficient, safe way
# to hash file contents. This is the first standalone for file_digest co_argcount
# under hashlibfn136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra136.file_digest_co_argcount:
  description: "hashlib.file_digest.__code__.co_argcount.__eq__(2) == True — file_digest(fileobj, digest) takes 2 positional args; distinct from hashlib.new (co_argcount==1); introduced Python 3.11 for efficient file hashing; first standalone for file_digest co_argcount under hashlibfn136"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__code__.co_argcount.__eq__
  args: [2]
  expected: true

