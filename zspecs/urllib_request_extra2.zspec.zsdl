spec: urllib_request_extra2
version: ">=3.0"
backend: python_module(urllib.request)

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "Python 3 urllib.request documentation — https://docs.python.org/3/library/urllib.request.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/request.py"
  notes:
    - "This spec extends urllib_request.zspec.zsdl and urllib_request_extra.zspec.zsdl."
    - "urllib_request.zspec.zsdl covers: class_names table (Request, OpenerDirector, BaseHandler, HTTPDefaultErrorHandler, HTTPRedirectHandler, URLError, HTTPError, HTTPHandler, FileHandler), function_names table (urlopen, build_opener, install_opener, pathname2url), Request construction and method, pathname2url, URLError/HTTPError attributes."
    - "urllib_request_extra.zspec.zsdl covers: urlretrieve.__name__, url2pathname.__name__, pathname2url.__name__, urlopen.__name__, Request.__name__, HTTPError.__name__, URLError.__name__, Request.__module__, URLError.__module__, HTTPError.__module__, HTTPError.__bases__[0].__name__."
    - "Focus: __qualname__ checks for urllib.request symbols not yet checked in prior specs."
    - "For top-level functions and classes, __qualname__ == __name__ (no enclosing class or function)."
    - "urllib.request.urlopen.__qualname__ == 'urlopen'."
    - "urllib.request.Request.__qualname__ == 'Request'."
    - "urllib.request.BaseHandler.__qualname__ == 'BaseHandler'."
    - "urllib.request.HTTPHandler.__qualname__ == 'HTTPHandler'."
    - "urllib.request.FileHandler.__qualname__ == 'FileHandler'."
    - "urllib.request.OpenerDirector.__qualname__ == 'OpenerDirector'."
    - "urllib.request.build_opener.__qualname__ == 'build_opener'."
    - "urllib.request.install_opener.__qualname__ == 'install_opener'."
    - "urllib.request.urlretrieve.__qualname__ == 'urlretrieve'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — functions in urllib.request
# Prior specs only check __name__; __qualname__ is a new dimension.
# ---------------------------------------------------------------------------

table urllib_request_extra2.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [urlopen,        urlopen.__qualname__.__eq__,        ["urlopen"],        true]
    - [build_opener,   build_opener.__qualname__.__eq__,   ["build_opener"],   true]
    - [install_opener, install_opener.__qualname__.__eq__,  ["install_opener"], true]
    - [urlretrieve,    urlretrieve.__qualname__.__eq__,    ["urlretrieve"],    true]

# ---------------------------------------------------------------------------
# __qualname__ checks — classes in urllib.request
# ---------------------------------------------------------------------------

table urllib_request_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Request,         Request.__qualname__.__eq__,         ["Request"],         true]
    - [BaseHandler,     BaseHandler.__qualname__.__eq__,     ["BaseHandler"],     true]
    - [HTTPHandler,     HTTPHandler.__qualname__.__eq__,     ["HTTPHandler"],     true]
    - [FileHandler,     FileHandler.__qualname__.__eq__,     ["FileHandler"],     true]
    - [OpenerDirector,  OpenerDirector.__qualname__.__eq__,  ["OpenerDirector"],  true]

# ---------------------------------------------------------------------------
# __module__ checks — functions whose __module__ has not been verified yet
# urllib_request_extra covers Request.__module__, URLError.__module__, HTTPError.__module__.
# urlopen.__module__ and urlretrieve.__module__ are new.
# ---------------------------------------------------------------------------

invariant urllib_request_extra2.urlopen.module:
  description: "urllib.request.urlopen.__module__ == 'urllib.request'"
  category: modules
  kind: python_call_eq
  function: urlopen.__module__.__eq__
  args: ["urllib.request"]
  expected: true

invariant urllib_request_extra2.urlretrieve.module:
  description: "urllib.request.urlretrieve.__module__ == 'urllib.request'"
  category: modules
  kind: python_call_eq
  function: urlretrieve.__module__.__eq__
  args: ["urllib.request"]
  expected: true

invariant urllib_request_extra2.build_opener.module:
  description: "urllib.request.build_opener.__module__ == 'urllib.request'"
  category: modules
  kind: python_call_eq
  function: build_opener.__module__.__eq__
  args: ["urllib.request"]
  expected: true
