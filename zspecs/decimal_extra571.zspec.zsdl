spec: decimal_extra571
version: ">=3.9"
backend: python_module(decimal)
docs: "Cover decimal module method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Decimal and decimal.Context method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that arithmetic dunder methods on Decimal and lifecycle methods on Context report correct __qualname__ values"
  created_at: "2026-04-12T00:00:00Z"

table decimal_extra571.decimal_method_qualnames:
  description: "Verify that decimal.Decimal arithmetic and comparison methods have correct __qualname__ values"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: DECEX571DQ
  columns: [id, function, args, expected]
  rows:
    - [DECEX571DQ001, decimal.Decimal.__add__.__qualname__.__eq__, ["Decimal.__add__"], true]
    - [DECEX571DQ002, decimal.Decimal.__sub__.__qualname__.__eq__, ["Decimal.__sub__"], true]
    - [DECEX571DQ003, decimal.Decimal.__mul__.__qualname__.__eq__, ["Decimal.__mul__"], true]
    - [DECEX571DQ004, decimal.Decimal.__truediv__.__qualname__.__eq__, ["Decimal.__truediv__"], true]
    - [DECEX571DQ005, decimal.Decimal.__neg__.__qualname__.__eq__, ["Decimal.__neg__"], true]
    - [DECEX571DQ006, decimal.Decimal.__abs__.__qualname__.__eq__, ["Decimal.__abs__"], true]
    - [DECEX571DQ007, decimal.Decimal.__str__.__qualname__.__eq__, ["Decimal.__str__"], true]
    - [DECEX571DQ008, decimal.Decimal.__repr__.__qualname__.__eq__, ["Decimal.__repr__"], true]
    - [DECEX571DQ009, decimal.Decimal.__eq__.__qualname__.__eq__, ["Decimal.__eq__"], true]
    - [DECEX571DQ010, decimal.Decimal.__lt__.__qualname__.__eq__, ["Decimal.__lt__"], true]
    - [DECEX571DQ011, decimal.Decimal.__le__.__qualname__.__eq__, ["Decimal.__le__"], true]
    - [DECEX571DQ012, decimal.Decimal.__gt__.__qualname__.__eq__, ["Decimal.__gt__"], true]
table decimal_extra571.context_method_qualnames:
  description: "Verify that decimal.Context lifecycle methods have correct __qualname__ values"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: DECEX571CQ
  columns: [id, function, args, expected]
  rows:
    - [DECEX571CQ001, decimal.Context.__init__.__qualname__.__eq__, ["Context.__init__"], true]
    - [DECEX571CQ002, decimal.Context.__repr__.__qualname__.__eq__, ["Context.__repr__"], true]