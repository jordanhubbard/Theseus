spec: abc_extra1951
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.ABCMeta, abc.ABC, and abc.abstractmethod define none of the iteration or membership protocol dunder methods."
    - "abc.ABCMeta.__dict__ does not contain __iter__, __next__, __contains__, __aiter__, or __anext__."
    - "abc.abstractmethod is a plain function; its instance __dict__ is empty and defines none of these dunders."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty also define none of these dunders."
  created_at: "2026-04-12"
error_model: python_exceptions

table abc_extra1951.contains_protocol:
  description: "abc types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1951

  columns: [id, function, args, expected]
  rows:
    - ["ab1951001", "abc.ABCMeta.__dict__.__contains__",             ["__contains__"], false]
    - ["ab1951002", "abc.ABC.__dict__.__contains__",                 ["__contains__"], false]
    - ["ab1951003", "abc.abstractmethod.__dict__.__contains__",      ["__contains__"], false]
    - ["ab1951004", "abc.abstractclassmethod.__dict__.__contains__", ["__contains__"], false]
    - ["ab1951005", "abc.abstractstaticmethod.__dict__.__contains__", ["__contains__"], false]
    - ["ab1951006", "abc.abstractproperty.__dict__.__contains__",    ["__contains__"], false]

