spec: multiprocessing_extra277
version: ">=3.9"
backend: python_module(multiprocessing)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — synchronization primitives (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "multiprocessing.synchronize.Lock.__bases__[0] is SemLock"
    - "multiprocessing.synchronize.RLock.__bases__[0] is SemLock"
    - "multiprocessing.synchronize.Semaphore.__bases__[0] is SemLock"
    - "multiprocessing.synchronize.BoundedSemaphore.__bases__[0] is Semaphore (not SemLock directly)"
    - "multiprocessing.synchronize.Event.__bases__[0] is object (not SemLock)"
    - "multiprocessing.synchronize.Condition.__bases__[0] is object (not SemLock)"
    - "multiprocessing.synchronize.Barrier.__bases__[0].__name__ is 'Barrier' (inherits from threading.Barrier)"
    - "multiprocessing.Lock.__name__ is 'Lock' (it is a class, not a factory function)"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra277.synchronize_names:
  description: "multiprocessing.synchronize class __name__ checks for Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier"
  kind: python_call_eq
  category: identity
  id_prefix: mp277n

  columns: [id, function, args, expected, description]
  rows:
    - [mp277n_001, multiprocessing.synchronize.Lock.__name__.__eq__, ["Lock"], true, "synchronize.Lock class name is 'Lock'"]
    - [mp277n_002, multiprocessing.synchronize.RLock.__name__.__eq__, ["RLock"], true, "synchronize.RLock class name is 'RLock'"]
    - [mp277n_003, multiprocessing.synchronize.Semaphore.__name__.__eq__, ["Semaphore"], true, "synchronize.Semaphore class name is 'Semaphore'"]
    - [mp277n_004, multiprocessing.synchronize.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "synchronize.BoundedSemaphore class name is 'BoundedSemaphore'"]
    - [mp277n_005, multiprocessing.synchronize.Event.__name__.__eq__, ["Event"], true, "synchronize.Event class name is 'Event'"]
    - [mp277n_006, multiprocessing.synchronize.Condition.__name__.__eq__, ["Condition"], true, "synchronize.Condition class name is 'Condition'"]
    - [mp277n_007, multiprocessing.synchronize.Barrier.__name__.__eq__, ["Barrier"], true, "synchronize.Barrier class name is 'Barrier'"]

table multiprocessing_extra277.synchronize_bases:
  description: "multiprocessing.synchronize class __bases__[0].__name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp277b

  columns: [id, function, args, expected, description]
  rows:
    - [mp277b_001, "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__", ["SemLock"], true, "Lock base is SemLock"]
    - [mp277b_002, "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__", ["SemLock"], true, "RLock base is SemLock"]
    - [mp277b_003, "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__", ["SemLock"], true, "Semaphore base is SemLock"]
    - [mp277b_004, "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"], true, "BoundedSemaphore base is Semaphore (not SemLock directly)"]
    - [mp277b_005, "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__", ["object"], true, "Event base is object (not SemLock)"]
    - [mp277b_006, "multiprocessing.synchronize.Condition.__bases__[0].__name__.__eq__", ["object"], true, "Condition base is object (not SemLock)"]
    - [mp277b_007, "multiprocessing.synchronize.Barrier.__bases__[0].__name__.__eq__", ["Barrier"], true, "Barrier base is threading.Barrier (name is 'Barrier')"]

invariant multiprocessing_extra277.lock_module:
  description: "multiprocessing.synchronize.Lock.__module__ is 'multiprocessing.synchronize'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra277.rlock_module:
  description: "multiprocessing.synchronize.RLock.__module__ is 'multiprocessing.synchronize'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.RLock.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra277.semlock_exists:
  description: "multiprocessing.synchronize.SemLock class name is 'SemLock'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.SemLock.__name__.__eq__
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra277.toplevel_lock_name:
  description: "multiprocessing.Lock class __name__ is 'Lock'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant multiprocessing_extra277.toplevel_rlock_name:
  description: "multiprocessing.RLock class __name__ is 'RLock'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.RLock.__name__.__eq__
  args: ["RLock"]
  expected: true
