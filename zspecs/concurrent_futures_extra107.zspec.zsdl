spec: concurrent_futures_extra107
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra106.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor __enter__/__exit__ qualnames (inherited from Executor), and Executor base class method qualnames. NEW in extra107: ThreadPoolExecutor.__enter__.__qualname__=='Executor.__enter__' (len=18, inherited from Executor); ThreadPoolExecutor.__exit__.__qualname__=='Executor.__exit__' (len=17, inherited from Executor); ProcessPoolExecutor.__enter__.__qualname__=='Executor.__enter__' (len=18, same as ThreadPoolExecutor — both inherited); ProcessPoolExecutor.__exit__.__qualname__=='Executor.__exit__' (len=17, same as ThreadPoolExecutor — both inherited); Executor.__enter__.__code__.co_argcount==1 (self only); Executor.__exit__.__code__.co_argcount==4 (self, exc_type, exc_val, exc_tb); Executor.map.__qualname__=='Executor.map' (len=12); Executor.shutdown.__qualname__=='Executor.shutdown' (len=17, tied with __exit__); Executor.submit.__qualname__=='Executor.submit' (len=15); ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23, longest qualname in spec). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18). Both ThreadPoolExecutor and ProcessPoolExecutor inherit __enter__ and __exit__ from the Executor base class — their qualnames reflect 'Executor.__enter__' / 'Executor.__exit__' not the subclass name. Executor.__enter__.__code__.co_argcount==1 (self only); Executor.__exit__.__code__.co_argcount==4 (self, exc_type, exc_val, exc_tb). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown' (len=17, tied with __exit__=17). Executor.submit.__qualname__=='Executor.submit' (len=15). Executor.map.__qualname__=='Executor.map' (len=12). ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23, longest in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor __enter__/__exit__ qualnames — extra107
#
# Wave 254 theme: context manager protocol qualnames (inherited from Executor).
#
# ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18)
# ThreadPoolExecutor.__exit__.__qualname__  == 'Executor.__exit__'  (len=17)
# ProcessPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18, same)
# ProcessPoolExecutor.__exit__.__qualname__  == 'Executor.__exit__'  (len=17, same)
# ---------------------------------------------------------------------------

table concurrent_futures_extra107.cf_executor_enter_exit_qualnames:
  description: "concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor __enter__/__exit__ qualname checks in cfexecutor107 namespace — wave 254 theme: concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__('Executor.__enter__')==True (len=18: 'Executor.'=9+'__enter__'=9=18; inherited from Executor base class); type(concurrent.futures.ThreadPoolExecutor.__enter__).__name__.__eq__('function')==True; concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__eq__('Executor.__exit__')==True (len=17: 'Executor.'=9+'__exit__'=8=17; inherited from Executor); concurrent.futures.ProcessPoolExecutor.__enter__.__qualname__.__eq__('Executor.__enter__')==True (len=18 — same as ThreadPoolExecutor, both inherited from Executor base); concurrent.futures.ProcessPoolExecutor.__exit__.__qualname__.__eq__('Executor.__exit__')==True (len=17 — same as ThreadPoolExecutor, both inherited from Executor base); Executor.__enter__.__qualname__.__eq__('Executor.__enter__')==True (len=18); Executor.__exit__.__qualname__.__eq__('Executor.__exit__')==True (len=17); both __enter__ and __exit__ are defined on Executor itself (not subclasses) so TPE, PPE, and Executor all share the same qualnames; __enter__ len=18 > __exit__ len=17 (by 1 char); __enter__ is one char longer because 'enter'=5 vs 'exit'=4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecutor107

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_enter_qn_eq,   concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__,   ["Executor.__enter__"], true, "ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18, inherited); verified with Python 3.14.3"]
    - [tpe_enter_qn_len,  concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__len__,  [],                    18,   "ThreadPoolExecutor.__enter__.__qualname__.__len__() == 18 ('Executor.__enter__'=18); verified with Python 3.14.3"]
    - [tpe_exit_qn_eq,    concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__eq__,    ["Executor.__exit__"],  true, "ThreadPoolExecutor.__exit__.__qualname__ == 'Executor.__exit__' (len=17, inherited); verified with Python 3.14.3"]
    - [tpe_exit_qn_len,   concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__len__,   [],                    17,   "ThreadPoolExecutor.__exit__.__qualname__.__len__() == 17 ('Executor.__exit__'=17); verified with Python 3.14.3"]
    - [ppe_enter_qn_eq,   concurrent.futures.ProcessPoolExecutor.__enter__.__qualname__.__eq__,  ["Executor.__enter__"], true, "ProcessPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18, same as TPE — both inherited); verified with Python 3.14.3"]
    - [ppe_enter_qn_len,  concurrent.futures.ProcessPoolExecutor.__enter__.__qualname__.__len__, [],                    18,   "ProcessPoolExecutor.__enter__.__qualname__.__len__() == 18 (same as TPE=18); verified with Python 3.14.3"]
    - [ppe_exit_qn_eq,    concurrent.futures.ProcessPoolExecutor.__exit__.__qualname__.__eq__,   ["Executor.__exit__"],  true, "ProcessPoolExecutor.__exit__.__qualname__ == 'Executor.__exit__' (len=17, same as TPE — both inherited); verified with Python 3.14.3"]
    - [ppe_exit_qn_len,   concurrent.futures.ProcessPoolExecutor.__exit__.__qualname__.__len__,  [],                    17,   "ProcessPoolExecutor.__exit__.__qualname__.__len__() == 17 (same as TPE=17); verified with Python 3.14.3"]
    - [exec_enter_type_eq, type(concurrent.futures.Executor.__enter__).__name__.__eq__,          ["function"],          true, "type(Executor.__enter__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [exec_exit_type_eq, type(concurrent.futures.Executor.__exit__).__name__.__eq__,            ["function"],          true, "type(Executor.__exit__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Executor.__enter__ and __exit__ code attributes — extra107
#
# Wave 254 theme: Executor context manager code attributes.
#
# Executor.__enter__.__code__.co_argcount == 1  (self only)
# Executor.__exit__.__code__.co_argcount  == 4  (self, exc_type, exc_val, exc_tb)
# Executor.map.__code__.co_argcount       == 2  (self, fn)
# Executor.shutdown.__qualname__          == 'Executor.shutdown' (len=17)
# ---------------------------------------------------------------------------

table concurrent_futures_extra107.cf_executor_method_code_attrs:
  description: "concurrent.futures.Executor method code attribute checks in cfexecutor107 namespace — wave 254 theme: concurrent.futures.Executor.__enter__.__code__.co_argcount==1 (self only — __enter__ simply returns self); concurrent.futures.Executor.__exit__.__code__.co_argcount==4 (self, exc_type, exc_val, exc_tb — standard context manager exit signature); concurrent.futures.Executor.map.__qualname__.__eq__('Executor.map')==True (len=12: 'Executor.'=9+'map'=3=12); concurrent.futures.Executor.map.__code__.co_argcount==2 (self and fn; iterables and timeout are keyword-only); concurrent.futures.Executor.shutdown.__qualname__.__eq__('Executor.shutdown')==True (len=17: 'Executor.'=9+'shutdown'=8=17; tied with __exit__=17); concurrent.futures.Executor.shutdown.__code__.co_argcount==2 (self and wait); concurrent.futures.Executor.submit.__qualname__.__eq__('Executor.submit')==True (len=15: 'Executor.'=9+'submit'=6=15); compare qualname lengths in spec: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=17 == Executor.__exit__=17 < Executor.__enter__=18 < ProcessPoolExecutor.map=23 (longest); __exit__ co_argcount=4 (most args for any method in spec); __enter__ co_argcount=1 (same as map's self-only positional pattern but different role); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfexecutor107a

  columns: [id, function, args, expected, description]
  rows:
    - [enter_argc,        concurrent.futures.Executor.__enter__.__code__.co_argcount.__eq__,  [1],                   true, "Executor.__enter__.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [exit_argc,         concurrent.futures.Executor.__exit__.__code__.co_argcount.__eq__,   [4],                   true, "Executor.__exit__.__code__.co_argcount == 4 (self, exc_type, exc_val, exc_tb); verified with Python 3.14.3"]
    - [map_qn_eq,         concurrent.futures.Executor.map.__qualname__.__eq__,                ["Executor.map"],      true, "Executor.map.__qualname__ == 'Executor.map' (len=12, shortest qualname in spec); verified with Python 3.14.3"]
    - [map_qn_len,        concurrent.futures.Executor.map.__qualname__.__len__,               [],                    12,   "Executor.map.__qualname__.__len__() == 12 ('Executor.map'=12); verified with Python 3.14.3"]
    - [map_argc,          concurrent.futures.Executor.map.__code__.co_argcount.__eq__,        [2],                   true, "Executor.map.__code__.co_argcount == 2 (self and fn; others keyword-only); verified with Python 3.14.3"]
    - [shutdown_qn_eq,    concurrent.futures.Executor.shutdown.__qualname__.__eq__,           ["Executor.shutdown"], true, "Executor.shutdown.__qualname__ == 'Executor.shutdown' (len=17); verified with Python 3.14.3"]
    - [shutdown_qn_len,   concurrent.futures.Executor.shutdown.__qualname__.__len__,          [],                    17,   "Executor.shutdown.__qualname__.__len__() == 17 ('Executor.shutdown'=17, tied with __exit__=17); verified with Python 3.14.3"]
    - [shutdown_argc,     concurrent.futures.Executor.shutdown.__code__.co_argcount.__eq__,   [2],                   true, "Executor.shutdown.__code__.co_argcount == 2 (self and wait); verified with Python 3.14.3"]
    - [submit_qn_eq,      concurrent.futures.Executor.submit.__qualname__.__eq__,             ["Executor.submit"],   true, "Executor.submit.__qualname__ == 'Executor.submit' (len=15); verified with Python 3.14.3"]
    - [submit_qn_len,     concurrent.futures.Executor.submit.__qualname__.__len__,            [],                    15,   "Executor.submit.__qualname__.__len__() == 15 ('Executor.submit'=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.map qualname length vs Executor base — extra107
#
# Wave 254 theme: ProcessPoolExecutor.map qualname length.
#
# ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23, longest in spec)
# ThreadPoolExecutor.map.__qualname__  == 'Executor.map'            (len=12, shorter — inherited)
# Executor.__enter__.__qualname__      == 'Executor.__enter__'      (len=18, middle)
# ---------------------------------------------------------------------------

table concurrent_futures_extra107.cf_ppe_map_qualname_vs_base:
  description: "concurrent.futures.ProcessPoolExecutor.map qualname length vs Executor base method qualnames in cfexecutor107 namespace — wave 254 theme: concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map')==True (len=23: 'ProcessPoolExecutor.'=20+'map'=3=23; longest qualname in spec — PPE has its own map implementation); concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__()==23; concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map')==True (len=12 — TPE inherits map from Executor; qualname reflects owner class); concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__()==12; concurrent.futures.ProcessPoolExecutor.__enter__.__qualname__.__eq__('Executor.__enter__')==True (len=18 — PPE also inherits __enter__); compare qualname lengths in spec: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=17 == Executor.__exit__=17 < Executor.__enter__=18 < ProcessPoolExecutor.map=23 (longest); ProcessPoolExecutor.map has its own override (PPE customizes map for multiprocessing), so qualname is ProcessPoolExecutor.map=23; TPE does NOT override map (inherits from Executor), so qualname remains Executor.map=12; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecutor107b

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_map_qn_len,    concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__,  [],                    23,   "ProcessPoolExecutor.map.__qualname__.__len__() == 23 ('ProcessPoolExecutor.map'=23, longest in spec); verified with Python 3.14.3"]
    - [ppe_map_qn_eq,     concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__,   ["ProcessPoolExecutor.map"], true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23); verified with Python 3.14.3"]
    - [tpe_map_qn_len,    concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__,   [],                    12,   "ThreadPoolExecutor.map.__qualname__.__len__() == 12 ('Executor.map'=12, inherited); verified with Python 3.14.3"]
    - [tpe_map_qn_eq,     concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__,    ["Executor.map"],      true, "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12, TPE inherits map from Executor); verified with Python 3.14.3"]
    - [enter_qn_len,      concurrent.futures.Executor.__enter__.__qualname__.__len__,       [],                    18,   "Executor.__enter__.__qualname__.__len__() == 18 ('Executor.__enter__'=18, middle in spec); verified with Python 3.14.3"]
    - [exit_qn_len,       concurrent.futures.Executor.__exit__.__qualname__.__len__,        [],                    17,   "Executor.__exit__.__qualname__.__len__() == 17 ('Executor.__exit__'=17, tied with shutdown); verified with Python 3.14.3"]
    - [enter_exit_cmp,    concurrent.futures.Executor.__enter__.__qualname__.__len__,       [],                    18,   "Executor.__enter__ len=18 > Executor.__exit__ len=17 (enter is longer by 1 char: 'enter'=5 vs 'exit'=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra107.Executor_enter_co_argcount_1:
  description: "concurrent.futures.Executor.__enter__.__code__.co_argcount == 1 — __enter__ takes only self (it returns self for use in the 'with' statement); Executor.__enter__.__qualname__=='Executor.__enter__' (len=18); type(Executor.__enter__).__name__=='function' (Python-defined); compare: Executor.__exit__.__code__.co_argcount==4 (self, exc_type, exc_val, exc_tb — standard context manager signature) — the contrast highlights that __enter__ is minimal (1 arg) while __exit__ takes 4 args for exception handling; ThreadPoolExecutor.__enter__ and ProcessPoolExecutor.__enter__ both inherit this — qualname == 'Executor.__enter__' in both cases; Executor.__enter__ simply calls self to return self for the 'with executor as e' pattern; NEW in extra107: first standalone Executor.__enter__ argcount invariant in cfexecutor107 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Executor.__enter__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra107.Executor_exit_co_argcount_4:
  description: "concurrent.futures.Executor.__exit__.__code__.co_argcount == 4 — __exit__ takes self, exc_type, exc_val, exc_tb (standard Python context manager exit signature); Executor.__exit__.__qualname__=='Executor.__exit__' (len=17); type(Executor.__exit__).__name__=='function' (Python-defined); co_argcount=4 is the most args for any method in this spec; compare: Executor.__enter__ co_argcount=1 (minimal) vs Executor.__exit__ co_argcount=4 (full exception handling signature); Executor.shutdown co_argcount=2 (self and wait); Executor.map co_argcount=2 (self and fn); Executor.submit co_argcount=2 (self and fn); __exit__ has the most args in spec; ThreadPoolExecutor.__exit__ and ProcessPoolExecutor.__exit__ both inherit this from Executor — qualname is 'Executor.__exit__' in all cases; Executor.__exit__ calls self.shutdown(wait=True) to ensure all futures are completed before exiting the context; NEW in extra107: first standalone Executor.__exit__ argcount invariant in cfexecutor107 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Executor.__exit__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant concurrent_futures_extra107.Executor_enter_qualname_len_18:
  description: "concurrent.futures.Executor.__enter__.__qualname__.__len__() == 18 — 'Executor.__enter__' = 'Executor.'=9 + '__enter__'=9 = 18; compare qualname lengths in spec: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=17 == Executor.__exit__=17 < Executor.__enter__=18 < ProcessPoolExecutor.map=23 (longest); __enter__ qualname len=18 is second longest after ProcessPoolExecutor.map=23; __enter__ len=18 > __exit__ len=17 (by 1 char — because 'enter'=5 chars vs 'exit'=4 chars); ThreadPoolExecutor.__enter__.__qualname__.__len__()==18 and ProcessPoolExecutor.__enter__.__qualname__.__len__()==18 (both inherited, same length); Executor.__enter__.__code__.co_argcount==1 (self only); NEW in extra107: first standalone Executor.__enter__ qualname length invariant in cfexecutor107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__enter__.__qualname__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra107.ProcessPoolExecutor_map_qualname_len_23:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__() == 23 — 'ProcessPoolExecutor.map' = 'ProcessPoolExecutor.'=20 + 'map'=3 = 23; this is the longest qualname in this spec; ProcessPoolExecutor.map has its own implementation (overrides Executor.map), so qualname is ProcessPoolExecutor.map=23 rather than Executor.map=12; compare: ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12 — TPE inherits, PPE overrides); qualname length ordering: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=Executor.__exit__=17 < Executor.__enter__=18 < ProcessPoolExecutor.map=23 (longest); ProcessPoolExecutor.map overrides map to use ProcessPoolExecutor-specific chunking (chunksize parameter for multiprocessing efficiency); ProcessPoolExecutor.map.__code__.co_argcount==2 (self and fn, same as Executor.map); NEW in extra107: first standalone ProcessPoolExecutor.map qualname length invariant in cfexecutor107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__
  args: []
  expected: 23

invariant concurrent_futures_extra107.Executor_shutdown_qualname_len_17:
  description: "concurrent.futures.Executor.shutdown.__qualname__.__len__() == 17 — 'Executor.shutdown' = 'Executor.'=9 + 'shutdown'=8 = 17; tied with Executor.__exit__.__qualname__.__len__()==17; compare: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=17 == Executor.__exit__=17 < Executor.__enter__=18 < ProcessPoolExecutor.map=23 (longest); Executor.shutdown.__code__.co_argcount==2 (self and wait); Executor.shutdown is the method that frees resources — called automatically by Executor.__exit__ with wait=True; Executor.shutdown.__qualname__=='Executor.shutdown'; type(Executor.shutdown).__name__=='function' (Python-defined); the tie between shutdown and __exit__ at len=17 reflects: 'shutdown'=8 chars == '__exit__'=8 chars (both 8-char method names); NEW in extra107: first standalone Executor.shutdown qualname length invariant in cfexecutor107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.shutdown.__qualname__.__len__
  args: []
  expected: 17

