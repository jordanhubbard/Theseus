spec: threading_extra410
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.RLock is a factory function (type(threading.RLock).__name__ == 'function'); the object it returns is a _thread.RLock instance with __class__.__name__ == 'RLock' and __class__.__module__ == '_thread'. Verified with Python 3.14.0."
    - "threading.Semaphore.acquire.__name__ == 'acquire' — Semaphore.acquire is a Python method defined in Lib/threading.py; __name__ is 'acquire'. Verified with Python 3.14.0."
    - "threading.Semaphore.release.__name__ == 'release' — Semaphore.release is a Python method defined in Lib/threading.py; __name__ is 'release'. Verified with Python 3.14.0."
    - "threading.Event.set.__name__ == 'set' — Event.set is a Python method defined in Lib/threading.py; __name__ is 'set'. Verified with Python 3.14.0."
    - "threading.Event.clear.__name__ == 'clear' — Event.clear is a Python method defined in Lib/threading.py; __name__ is 'clear'. Verified with Python 3.14.0."
    - "threading.Event.wait.__name__ == 'wait' — Event.wait is a Python method defined in Lib/threading.py; __name__ is 'wait'. Verified with Python 3.14.0."
    - "threading.Event.is_set.__name__ == 'is_set' — Event.is_set is a Python method defined in Lib/threading.py; __name__ is 'is_set'. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore method __name__ values
#
# threading.Semaphore is a plain Python class defined in Lib/threading.py.
# Its acquire and release methods are Python functions; their __name__
# attribute equals the bare method name string.
# ---------------------------------------------------------------------------

table threading_extra410.semaphore_method_name:
  description: "threading.Semaphore method __name__ values — Python methods on Semaphore class; new to extra410"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsm410

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_acquire_name_eq,
       "Semaphore.acquire.__name__.__eq__",
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — acquire is a Python method on Semaphore defined in Lib/threading.py; __name__ is 'acquire'; str.__eq__('acquire') returns True; new to extra410"]
    - [semaphore_release_name_eq,
       "Semaphore.release.__name__.__eq__",
       ["release"],
       true,
       "threading.Semaphore.release.__name__.__eq__('release') == True — release is a Python method on Semaphore defined in Lib/threading.py; __name__ is 'release'; str.__eq__('release') returns True; new to extra410"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event method __name__ values
#
# threading.Event is a plain Python class defined in Lib/threading.py.
# Its set, clear, wait, and is_set methods are Python functions; their
# __name__ attribute equals the bare method name string.
# ---------------------------------------------------------------------------

table threading_extra410.event_method_name:
  description: "threading.Event method __name__ values — Python methods on Event class; new to extra410"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingem410

  columns: [id, function, args, expected, description]
  rows:
    - [event_set_name_eq,
       "Event.set.__name__.__eq__",
       ["set"],
       true,
       "threading.Event.set.__name__.__eq__('set') == True — set is a Python method on Event defined in Lib/threading.py; __name__ is 'set'; str.__eq__('set') returns True; new to extra410"]
    - [event_clear_name_eq,
       "Event.clear.__name__.__eq__",
       ["clear"],
       true,
       "threading.Event.clear.__name__.__eq__('clear') == True — clear is a Python method on Event defined in Lib/threading.py; __name__ is 'clear'; str.__eq__('clear') returns True; new to extra410"]
    - [event_wait_name_eq,
       "Event.wait.__name__.__eq__",
       ["wait"],
       true,
       "threading.Event.wait.__name__.__eq__('wait') == True — wait is a Python method on Event defined in Lib/threading.py; __name__ is 'wait'; str.__eq__('wait') returns True; new to extra410"]
    - [event_is_set_name_eq,
       "Event.is_set.__name__.__eq__",
       ["is_set"],
       true,
       "threading.Event.is_set.__name__.__eq__('is_set') == True — is_set is a Python method on Event defined in Lib/threading.py; __name__ is 'is_set'; str.__eq__('is_set') returns True; new to extra410"]

# ---------------------------------------------------------------------------
# Table 3: threading.RLock factory and instance class identity
#
# threading.RLock is a factory function (not a class). Calling it returns
# a _thread.RLock instance. The factory itself has type 'function';
# the returned instance's class name is 'RLock' and its module is '_thread'.
# ---------------------------------------------------------------------------

table threading_extra410.rlock_identity:
  description: "threading.RLock factory type and instance class identity — RLock is a function returning _thread.RLock; new to extra410"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrl410

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_factory_type_name_eq,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a factory function in Lib/threading.py; type(threading.RLock).__name__ is 'function'; str.__eq__('function') returns True; new to extra410"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra410
# ---------------------------------------------------------------------------

invariant threading_extra410.semaphore_acquire_name:
  description: "threading.Semaphore.acquire.__name__ == 'acquire' — Python method on Semaphore; new to extra410"
  kind: python_call_eq
  function: Semaphore.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra410.semaphore_release_name:
  description: "threading.Semaphore.release.__name__ == 'release' — Python method on Semaphore; new to extra410"
  kind: python_call_eq
  function: Semaphore.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant threading_extra410.event_set_name:
  description: "threading.Event.set.__name__ == 'set' — Python method on Event; new to extra410"
  kind: python_call_eq
  function: Event.set.__name__.__eq__
  args: ["set"]
  expected: true

invariant threading_extra410.event_clear_name:
  description: "threading.Event.clear.__name__ == 'clear' — Python method on Event; new to extra410"
  kind: python_call_eq
  function: Event.clear.__name__.__eq__
  args: ["clear"]
  expected: true

invariant threading_extra410.event_wait_name:
  description: "threading.Event.wait.__name__ == 'wait' — Python method on Event; new to extra410"
  kind: python_call_eq
  function: Event.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra410.event_is_set_name:
  description: "threading.Event.is_set.__name__ == 'is_set' — Python method on Event; new to extra410"
  kind: python_call_eq
  function: Event.is_set.__name__.__eq__
  args: ["is_set"]
  expected: true

invariant threading_extra410.rlock_factory_type_name:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; new to extra410"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true
