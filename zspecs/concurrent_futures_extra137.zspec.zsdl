# Standalone invariants — extra137
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra137.thread_pool_executor_name_len_18:
  description: "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 — ThreadPoolExecutor.__name__ is 'ThreadPoolExecutor' (18 chars: 'Thread'=6+'Pool'=4+'Executor'=8=18); ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); ThreadPoolExecutor.__bases__[0].__name__=='Executor'; name len (18) is one less than ProcessPoolExecutor name len (19); NEW in extra137: first standalone ThreadPoolExecutor name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__name__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra137.process_pool_executor_name_len_19:
  description: "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 — ProcessPoolExecutor.__name__ is 'ProcessPoolExecutor' (19 chars: 'Process'=7+'Pool'=4+'Executor'=8=19); ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26); ProcessPoolExecutor.__bases__[0].__name__=='Executor'; name len (19) is one more than ThreadPoolExecutor name len (18); NEW in extra137: first standalone ProcessPoolExecutor name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__name__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra137.tpe_init_qualname_len_27:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 — ThreadPoolExecutor.__init__.__qualname__ is 'ThreadPoolExecutor.__init__' (27 chars: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27); __init__.__module__=='concurrent.futures.thread' (len=25); co_argcount==5; co_varnames.__len__()==6; NEW in extra137: first standalone ThreadPoolExecutor.__init__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
