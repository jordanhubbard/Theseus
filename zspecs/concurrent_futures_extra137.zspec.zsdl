spec: concurrent_futures_extra137
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor — their __name__, __qualname__, __module__, and __bases__[0].__name__. Also ThreadPoolExecutor.__init__ (co_argcount==5, co_varnames.__len__()==6) and ProcessPoolExecutor.__init__ (co_argcount==5, co_varnames.__len__()==7). Also concurrent.futures.thread._WorkItem and process._WorkItem — both named '_WorkItem' (len=9), __bases__[0].__name__=='object'. Also ThreadPoolExecutor.submit (co_argcount==2, co_varnames.__len__()==7). ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27); co_argcount==5 (self,max_workers,thread_name_prefix,initializer,initargs); co_varnames.__len__()==6 (adds 'ctxkwargs'). ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28); co_argcount==5 (self,max_workers,mp_context,initializer,initargs); co_varnames.__len__()==7 (adds 'max_tasks_per_child','queue_size'). thread._WorkItem.__name__=='_WorkItem' (len=9); process._WorkItem.__name__=='_WorkItem' (len=9); they are distinct objects from different modules. ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); co_argcount==2 (self,fn); co_varnames.__len__()==7. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor class identity — extra137
#
# ThreadPoolExecutor.__name__              == 'ThreadPoolExecutor' (len=18)
# ThreadPoolExecutor.__qualname__          == 'ThreadPoolExecutor' (len=18)
# ThreadPoolExecutor.__module__            == 'concurrent.futures.thread' (len=25)
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra137.thread_pool_executor_identity:
  description: "concurrent.futures.ThreadPoolExecutor class identity checks — ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18, same as __name__ — top-level class); ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (len=25: same module as BrokenThreadPool); ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (direct subclass of Executor); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpe137

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    concurrent.futures.ThreadPoolExecutor.__name__.__eq__,              ["ThreadPoolExecutor"],         true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [name_len,   concurrent.futures.ThreadPoolExecutor.__name__.__len__,              [],                            18,   "ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [qn_eq,      concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__,          ["ThreadPoolExecutor"],         true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18, same as __name__); verified with Python 3.14.3"]
    - [mod_eq,     concurrent.futures.ThreadPoolExecutor.__module__.__eq__,            ["concurrent.futures.thread"],  true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [mod_len,    concurrent.futures.ThreadPoolExecutor.__module__.__len__,            [],                            25,   "ThreadPoolExecutor.__module__.__len__() == 25; verified with Python 3.14.3"]
    - ["base_name", "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                  true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]

