# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra137.process_pool_executor_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity checks — ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19, one more than ThreadPoolExecutor len=18); ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True (len=19, same as __name__); ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26: same module as BrokenProcessPool); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (both TPE and PPE inherit from Executor); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppe137

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    concurrent.futures.ProcessPoolExecutor.__name__.__eq__,              ["ProcessPoolExecutor"],         true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); verified with Python 3.14.3"]
    - [name_len,   concurrent.futures.ProcessPoolExecutor.__name__.__len__,              [],                             19,   "ProcessPoolExecutor.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [qn_eq,      concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__,          ["ProcessPoolExecutor"],         true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19, same as __name__); verified with Python 3.14.3"]
    - [mod_eq,     concurrent.futures.ProcessPoolExecutor.__module__.__eq__,            ["concurrent.futures.process"],  true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [mod_len,    concurrent.futures.ProcessPoolExecutor.__module__.__len__,            [],                             26,   "ProcessPoolExecutor.__module__.__len__() == 26; verified with Python 3.14.3"]
    - ["base_name", "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                   true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]

