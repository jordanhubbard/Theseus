invariant concurrent_futures_extra137.tpe_submit_qualname_len_25:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__() == 25 — ThreadPoolExecutor.submit.__qualname__ is 'ThreadPoolExecutor.submit' (25 chars: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25); coincidentally the same value as the module length (concurrent.futures.thread is also 25 chars); submit.__code__.co_argcount==2; co_varnames.__len__()==7; NEW in extra137: first standalone ThreadPoolExecutor.submit qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__
