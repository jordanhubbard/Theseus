# ---------------------------------------------------------------------------

table concurrent_futures_extra137.thread_pool_executor_submit:
  description: "concurrent.futures.ThreadPoolExecutor.submit qualname and code attribute checks — submit.__qualname__.__eq__('ThreadPoolExecutor.submit')==True (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25); submit.__module__.__eq__('concurrent.futures.thread')==True (len=25: submit qualname len == module len, a coincidence); submit.__code__.co_argcount==2 ('self','fn' are positional; args and kwargs are var-positional/var-keyword); submit.__code__.co_varnames.__len__()==7 ('self','fn','args','kwargs','f','task','w'); 'fn' in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpesubmit137

  columns: [id, function, args, expected, description]
  rows:
    - [qn_len,       concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__,           [],                           25,   "ThreadPoolExecutor.submit.__qualname__.__len__() == 25 ('ThreadPoolExecutor.submit' is 25 chars); verified with Python 3.14.3"]
    - [mod_eq,       concurrent.futures.ThreadPoolExecutor.submit.__module__.__eq__,              ["concurrent.futures.thread"], true, "ThreadPoolExecutor.submit.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [argc,         concurrent.futures.ThreadPoolExecutor.submit.__code__.co_argcount.__eq__,    [2],                           true, "ThreadPoolExecutor.submit.__code__.co_argcount == 2 ('self','fn'); verified with Python 3.14.3"]
    - [varnames_len, concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__,    [],                           7,    "ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7 ('self','fn','args','kwargs','f','task','w'); verified with Python 3.14.3"]
    - [fn_in,        concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__contains__, ["fn"],                      true, "ThreadPoolExecutor.submit.__code__.co_varnames contains 'fn'; verified with Python 3.14.3"]

