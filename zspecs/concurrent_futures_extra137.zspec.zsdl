invariant concurrent_futures_extra137.tpe_submit_co_varnames_len_7:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7 — submit.__code__.co_varnames is ('self','fn','args','kwargs','f','task','w') (len=7); co_argcount==2 (self,fn); 'args' and 'kwargs' are var-positional/var-keyword; 'f','task','w' are locals; 7 is the largest co_varnames len of any method covered in this spec; NEW in extra137: first standalone submit co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__
  args: []
  expected: 7
