table concurrent_futures_extra137.thread_pool_executor_init:
  description: "concurrent.futures.ThreadPoolExecutor.__init__ qualname, module, and code attribute checks — __init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27); __init__.__module__.__eq__('concurrent.futures.thread')==True (len=25); co_argcount==5 ('self','max_workers','thread_name_prefix','initializer','initargs'); co_varnames.__len__()==6 (adds 'ctxkwargs'); 'max_workers' in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpeinit137

  columns: [id, function, args, expected, description]
  rows:
    - [qn_len,       concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__,           [],                           27, "ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 ('ThreadPoolExecutor.__init__' is 27 chars); verified with Python 3.14.3"]
    - [mod_eq,       concurrent.futures.ThreadPoolExecutor.__init__.__module__.__eq__,              ["concurrent.futures.thread"], true, "ThreadPoolExecutor.__init__.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [argc,         concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__,    [5],                           true, "ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self,max_workers,thread_name_prefix,initializer,initargs); verified with Python 3.14.3"]
    - [varnames_len, concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__,    [],                           6,   "ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6 (adds 'ctxkwargs'); verified with Python 3.14.3"]
    - [mw_in,        concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__contains__, ["max_workers"],             true, "ThreadPoolExecutor.__init__.__code__.co_varnames contains 'max_workers'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.submit qualname and code — extra137
