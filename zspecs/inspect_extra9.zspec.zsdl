spec: inspect_extra9
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra8.zspec.zsdl."
    - "inspect_extra8 covers: isroutine __name__/__module__/__qualname__, isroutine(len)/isroutine(isroutine) behavioral checks, iscoroutinefunction/__qualname__, isgeneratorfunction/__qualname__, Traceback.__module__/__qualname__, BlockFinder.__module__/__qualname__."
    - "inspect_extra7 covers: getsource/__module__, signature/__module__, BoundArguments/__module__/__metaclass__, FrameInfo/__module__, class/function __qualname__ tables."
    - "NOT yet covered: isasyncgenfunction.__qualname__ and isasyncgenfunction.__module__."
    - "NOT yet covered: getfile.__qualname__ and getfile.__module__."
    - "NOT yet covered: currentframe.__qualname__ and currentframe.__module__."
    - "NOT yet covered: stack.__qualname__ and stack.__module__."
    - "NOT yet covered: getcomments.__qualname__ and getcomments.__module__."
    - "NOT yet covered: FullArgSpec.__name__, FullArgSpec.__module__, FullArgSpec.__qualname__."
    - "NOT yet covered: isclass(42) == False (only table false-cases; not covered as standalone invariant for isroutine(42))."
    - "inspect.isasyncgenfunction.__qualname__ == 'isasyncgenfunction' — top-level Python function."
    - "inspect.isasyncgenfunction.__module__ == 'inspect'."
    - "inspect.getfile.__qualname__ == 'getfile' — module-level function."
    - "inspect.getfile.__module__ == 'inspect'."
    - "inspect.currentframe.__qualname__ == 'currentframe' — module-level function."
    - "inspect.currentframe.__module__ == 'inspect'."
    - "inspect.stack.__qualname__ == 'stack' — module-level function."
    - "inspect.stack.__module__ == 'inspect'."
    - "inspect.getcomments.__qualname__ == 'getcomments' — module-level function."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' — namedtuple class."
    - "inspect.FullArgSpec.__module__ == 'inspect'."
    - "inspect.FullArgSpec.__qualname__ == 'FullArgSpec'."
    - "inspect.isroutine(42) == False — integers are not routines."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isasyncgenfunction — __qualname__ and __module__
#
# inspect.zspec.zsdl covers isasyncgenfunction.__name__; inspect_extra8
# covers iscoroutinefunction and isgeneratorfunction __qualname__ but not
# isasyncgenfunction. This gap is filled here.
# ---------------------------------------------------------------------------

invariant inspect_extra9.isasyncgenfunction.qualname:
  description: "inspect.isasyncgenfunction.__qualname__ == 'isasyncgenfunction'"
  category: function_qualnames
  kind: python_call_eq
  function: isasyncgenfunction.__qualname__.__eq__
  args: ["isasyncgenfunction"]
  expected: true

invariant inspect_extra9.isasyncgenfunction.module:
  description: "inspect.isasyncgenfunction.__module__ == 'inspect'"
  category: function_modules
  kind: python_call_eq
  function: isasyncgenfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# getfile, currentframe, stack, getcomments — __qualname__ and __module__
#
# inspect_extra5 covers getfile.__name__; inspect_extra7 covers getsource/__module__
# and signature/__module__. No prior spec checks __qualname__ or __module__ for
# getfile, currentframe, stack, or getcomments.
# ---------------------------------------------------------------------------

table inspect_extra9.utility_function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [getfile,      getfile.__qualname__.__eq__,      ["getfile"],      true]
    - [currentframe, currentframe.__qualname__.__eq__,  ["currentframe"],  true]
    - [stack,        stack.__qualname__.__eq__,         ["stack"],         true]
    - [getcomments,  getcomments.__qualname__.__eq__,  ["getcomments"],  true]

table inspect_extra9.utility_function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [getfile,      getfile.__module__.__eq__,      ["inspect"], true]
    - [currentframe, currentframe.__module__.__eq__,  ["inspect"], true]
    - [stack,        stack.__module__.__eq__,         ["inspect"], true]

# ---------------------------------------------------------------------------
# FullArgSpec — __name__, __module__, __qualname__
#
# inspect.zspec.zsdl covers FullArgSpec.__name__ as a class name invariant.
# No prior spec checks __module__ or __qualname__ for FullArgSpec.
# FullArgSpec is a namedtuple returned by getfullargspec().
# ---------------------------------------------------------------------------

invariant inspect_extra9.FullArgSpec.name:
  description: "inspect.FullArgSpec.__name__ == 'FullArgSpec'"
  category: class_names
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra9.FullArgSpec.module:
  description: "inspect.FullArgSpec.__module__ == 'inspect'"
  category: class_modules
  kind: python_call_eq
  function: FullArgSpec.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra9.FullArgSpec.qualname:
  description: "inspect.FullArgSpec.__qualname__ == 'FullArgSpec'"
  category: class_qualnames
  kind: python_call_eq
  function: FullArgSpec.__qualname__.__eq__
  args: ["FullArgSpec"]
  expected: true

# ---------------------------------------------------------------------------
# isroutine — false cases for additional types
#
# inspect.zspec.zsdl table covers isroutine(42)/isroutine("hello")/isroutine(None)
# as table rows. inspect_extra8 adds isroutine(len) and isroutine(isroutine) true
# cases. This adds a standalone invariant for isroutine(42) == False and a new
# true case: isroutine(isfunction) — Python function is a routine.
# ---------------------------------------------------------------------------

invariant inspect_extra9.isroutine.int_false:
  description: "inspect.isroutine(42) == False — integers are not routines"
  category: behavior
  kind: python_call_eq
  function: isroutine
  args: [42]
  expected: false

invariant inspect_extra9.isroutine.isfunction_is_routine:
  description: "inspect.isroutine(isfunction) == True — Python function is a routine"
  category: behavior
  kind: python_call_eq
  function: isroutine
  args: [isfunction]
  expected: true
