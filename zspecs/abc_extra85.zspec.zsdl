spec: abc_extra85
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra84

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra84.zspec.zsdl."
    - "This spec covers: wave 250 theme — abc module identity: __name__, __package__, __spec__, __loader__, __file__ class names. NEW in extra85: abc.__name__.__eq__('abc')==True; abc.__package__.__eq__('')==True (abc is a top-level module, __package__ is empty string); abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True; abc.__loader__.__class__.__name__.__eq__('type')==True (abc is a frozen module; loader is the FrozenImporter class itself, a type); abc.__file__.__class__.__name__.__eq__('str')==True (abc has __file__ pointing to abc.py even though it is frozen); abc.__doc__.__class__.__name__.__eq__('str')==True; abc.__spec__.name.__eq__('abc')==True. NOTE: abc does NOT have __all__ in Python 3.14.3 (removed) and does NOT have __cached__ (frozen module). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__name__ == 'abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__package__ == ''. abc is a top-level module; its __package__ is the empty string. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec'. The module spec is a ModuleSpec instance from importlib. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__loader__.__class__.__name__ == 'type'. abc is a frozen module; its __loader__ is the FrozenImporter class itself (a type object, not an instance). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__file__.__class__.__name__ == 'str'. abc has __file__ pointing to the source .py file even though the module is frozen. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__doc__.__class__.__name__ == 'str'. The abc module has a docstring. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.name == 'abc'. The ModuleSpec name field equals the module name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module name and package — extra85
#
# Wave 250 theme: abc module identity: __name__, __package__, __spec__,
# __loader__, __file__ class names.
#
# abc.__name__ == 'abc'
# abc.__package__ == ''
# ---------------------------------------------------------------------------

table abc_extra85.module_name_package:
  description: "abc module __name__ and __package__ checks in abcmoduleid85 namespace — wave 250 theme: abc module identity: __name__, __package__, __spec__, __loader__, __file__ class names; abc.__name__.__eq__('abc')==True (module name is 'abc'); abc.__package__.__eq__('')==True (top-level module, empty string __package__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduleid85

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,    __name__.__eq__,    ["abc"], true, "abc.__name__ == 'abc' — verified with Python 3.14.3"]
    - [abc_package_eq, __package__.__eq__, [""],    true, "abc.__package__ == '' — top-level module; __package__ is empty string; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module spec and loader class names — extra85
#
# abc.__spec__.__class__.__name__ == 'ModuleSpec'
# abc.__loader__.__class__.__name__ == 'type'
# abc.__spec__.name == 'abc'
# ---------------------------------------------------------------------------

table abc_extra85.module_spec_loader:
  description: "abc module __spec__ and __loader__ class name checks in abcmoduleid85 namespace — wave 250 theme: abc module identity: __name__, __package__, __spec__, __loader__, __file__ class names; abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (importlib ModuleSpec); abc.__loader__.__class__.__name__.__eq__('type')==True (abc is frozen; loader is FrozenImporter class, a type object); abc.__spec__.name.__eq__('abc')==True (ModuleSpec.name field); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduleid85a

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_name,   __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' — importlib ModuleSpec instance; verified with Python 3.14.3"]
    - [loader_cls_name, __loader__.__class__.__name__.__eq__, ["type"],     true, "abc.__loader__.__class__.__name__ == 'type' — abc is frozen; FrozenImporter is a class (type), not an instance; verified with Python 3.14.3"]
    - [spec_name_eq,    __spec__.name.__eq__,               ["abc"],        true, "abc.__spec__.name == 'abc' — ModuleSpec.name field equals the module name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module file and doc class names — extra85
#
# abc.__file__.__class__.__name__ == 'str'
# abc.__doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table abc_extra85.module_file_doc:
  description: "abc module __file__ and __doc__ class name checks in abcmoduleid85 namespace — wave 250 theme: abc module identity: __name__, __package__, __spec__, __loader__, __file__ class names; abc.__file__.__class__.__name__.__eq__('str')==True (abc has a __file__ attribute pointing to abc.py even though it is a frozen module); abc.__doc__.__class__.__name__.__eq__('str')==True (abc module has a docstring); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduleid85b

  columns: [id, function, args, expected, description]
  rows:
    - [file_cls_name, __file__.__class__.__name__.__eq__, ["str"], true, "abc.__file__.__class__.__name__ == 'str' — abc has __file__ pointing to abc.py even as a frozen module; verified with Python 3.14.3"]
    - [doc_cls_name,  __doc__.__class__.__name__.__eq__,  ["str"], true, "abc.__doc__.__class__.__name__ == 'str' — abc module has a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module identity cross-checks — extra85
#
# Cross-checks combining facts from name/package/spec/loader/file/doc tables.
# ---------------------------------------------------------------------------

table abc_extra85.module_identity_cross_checks:
  description: "abc module identity cross-checks in abcmoduleid85 namespace — wave 250 theme: abc module identity: __name__, __package__, __spec__, __loader__, __file__ class names; abc.__name__.__eq__('abc')==True (cross-check); abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (cross-check); abc.__loader__.__class__.__name__.__eq__('type')==True (cross-check); abc.__file__.__class__.__name__.__eq__('str')==True (cross-check); abc.__package__.__eq__('')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmoduleid85c

  columns: [id, function, args, expected, description]
  rows:
    - [name_cross,       __name__.__eq__,                    ["abc"],        true, "abc.__name__ == 'abc' — cross-check; verified with Python 3.14.3"]
    - [spec_cls_cross,   __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' — cross-check; verified with Python 3.14.3"]
    - [loader_cls_cross, __loader__.__class__.__name__.__eq__, ["type"],     true, "abc.__loader__.__class__.__name__ == 'type' — cross-check; verified with Python 3.14.3"]
    - [file_cls_cross,   __file__.__class__.__name__.__eq__, ["str"],        true, "abc.__file__.__class__.__name__ == 'str' — cross-check; verified with Python 3.14.3"]
    - [package_cross,    __package__.__eq__,                 [""],           true, "abc.__package__ == '' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra85
# ---------------------------------------------------------------------------

invariant abc_extra85.module_name_is_abc:
  description: "abc.__name__.__eq__('abc') returns True — the module's __name__ attribute is 'abc', the canonical dotted name of the module; NEW in extra85: first standalone __name__ equality invariant for the abc module itself in abcmoduleid85 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra85.module_package_is_empty:
  description: "abc.__package__.__eq__('') returns True — abc is a top-level module with no parent package, so __package__ is the empty string; this distinguishes top-level modules from submodules like asyncio.locks; NEW in extra85: first standalone __package__ equality invariant for abc in abcmoduleid85 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant abc_extra85.module_spec_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — the module's __spec__ is a ModuleSpec instance from importlib._bootstrap; this is the standard module specification object; NEW in extra85: first standalone __spec__ class name invariant for abc in abcmoduleid85 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra85.module_loader_class_is_type:
  description: "abc.__loader__.__class__.__name__.__eq__('type') returns True — abc is a frozen module in Python 3.14.3; its __loader__ is the FrozenImporter class itself (not an instance), so its __class__ is 'type' (the metaclass); NEW in extra85: first standalone __loader__ class name invariant for abc in abcmoduleid85 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra85.module_spec_name_is_abc:
  description: "abc.__spec__.name.__eq__('abc') returns True — the ModuleSpec's name field equals the module name 'abc'; this is the fully qualified module name stored in the spec, distinct from __name__ on the module object itself; NEW in extra85: first standalone __spec__.name equality invariant for abc in abcmoduleid85 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["abc"]
  expected: true
