# ---------------------------------------------------------------------------
# Table 1: functools.total_ordering function identity
#
# Wave 291 theme: functools.total_ordering decorator identity — it is a
# function, not a class.
#
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__module__ == 'functools'
# functools.total_ordering.__code__.co_argcount == 1
# functools.total_ordering.__name__ == 'total_ordering'
#
# functools.total_ordering is a class decorator implemented as a plain Python
# function in Lib/functools.py. Given a class that defines at least one rich
# comparison method (__lt__, __le__, __gt__, __ge__) and __eq__, it fills in
# the missing comparison methods. Unlike many decorators in functools
# (e.g., singledispatchmethod) it is NOT a class; its __class__.__name__ is
# 'function'. It takes 1 argument (the class to decorate), so co_argcount is 1.
# New to extra167.
# ---------------------------------------------------------------------------

table functools_extra167.total_ordering_function_identity:
  description: "functools.total_ordering: __class__.__name__ 'function', __module__ 'functools', co_argcount 1, co_name 'total_ordering', __name__ 'total_ordering'; wave 291; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: functoolstoi167

  columns: [id, function, args, expected, description]
  rows:
    - [to_class_name_eq_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a plain Python function in Lib/functools.py that fills in missing comparison methods on a class; it is NOT a class itself; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra167"]
    - [to_module_eq_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra167"]
    - [to_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering(cls) takes 1 positional-or-keyword argument (the class being decorated with missing comparison methods); co_argcount is 1; int.__eq__(1) returns True; new to extra167"]
    - [to_co_name_eq,
       "total_ordering.__code__.co_name.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a Python function in Lib/functools.py; its code object co_name is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 2: functools.cmp_to_key C built-in identity and total_ordering __name__
#
# Wave 291 theme: functools.cmp_to_key C built-in identity — name, module,
# and class — and total_ordering __name__ attribute.
#
# functools.total_ordering.__name__ == 'total_ordering'
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__module__ == '_functools'
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
#
# functools.cmp_to_key converts an old-style comparison function (that returns
# negative/zero/positive) into a key function suitable for sort(). It is
# implemented as a C built-in in Modules/_functoolsmodule.c; its __module__
# is '_functools' (the underlying C extension), its __name__ is 'cmp_to_key',
# and its __class__.__name__ is 'builtin_function_or_method'. New to extra167.
# ---------------------------------------------------------------------------

table functools_extra167.cmp_to_key_builtin_identity:
  description: "functools: total_ordering.__name__ 'total_ordering'; cmp_to_key.__name__ 'cmp_to_key', cmp_to_key.__module__ '_functools', cmp_to_key.__class__.__name__ 'builtin_function_or_method'; wave 291; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsctki167

  columns: [id, function, args, expected, description]
  rows:
    - [to_name_eq_total_ordering,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a Python function (class decorator) in Lib/functools.py; its __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra167"]
    - [ctk_name_eq_cmp_to_key,
       "cmp_to_key.__name__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — cmp_to_key is a C built-in function in Modules/_functoolsmodule.c that converts an old-style comparison function into a key function for sorted() and min()/max(); its __name__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra167"]
    - [ctk_module_eq_functools_c,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in the _functools C extension module (Modules/_functoolsmodule.c); its __module__ is '_functools' (not 'functools'); str.__eq__('_functools') returns True; new to extra167"]
    - [ctk_class_name_eq_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C built-in function object; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra167"]

