spec: itertools_extra328
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.pairwise — identity (Python 3.10+, C type)
# ---------------------------------------------------------------------------

invariant itertools_extra328.pairwise.__name__:
  description: "itertools.pairwise.__name__ == 'pairwise'"
  category: identity
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra328.pairwise.__module__:
  description: "itertools.pairwise.__module__ == 'itertools'"
  category: identity
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra328.pairwise.__bases__0.__name__:
  description: "itertools.pairwise.__bases__[0].__name__ == 'object' — pairwise is a C type"
  category: identity
  kind: python_call_eq
  function: pairwise.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra328.pairwise.__doc__.__len__:
  description: "itertools.pairwise.__doc__.__len__() == 112"
  category: identity
  kind: python_call_eq
  function: pairwise.__doc__.__len__
  args: []
  expected: 112

# ---------------------------------------------------------------------------
# itertools.batched — identity (Python 3.12+, C type)
# ---------------------------------------------------------------------------

invariant itertools_extra328.batched.__name__:
  description: "itertools.batched.__name__ == 'batched'"
  category: identity
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra328.batched.__module__:
  description: "itertools.batched.__module__ == 'itertools'"
  category: identity
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra328.batched.__bases__0.__name__:
  description: "itertools.batched.__bases__[0].__name__ == 'object' — batched is a C type"
  category: identity
  kind: python_call_eq
  function: batched.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra328.batched.__doc__.__len__:
  description: "itertools.batched.__doc__.__len__() == 511"
  category: identity
  kind: python_call_eq
  function: batched.__doc__.__len__
  args: []
  expected: 511

# ---------------------------------------------------------------------------
# itertools.accumulate — doc length
# ---------------------------------------------------------------------------

invariant itertools_extra328.accumulate.__doc__.__len__:
  description: "itertools.accumulate.__doc__.__len__() == 69"
  category: identity
  kind: python_call_eq
  function: accumulate.__doc__.__len__
  args: []
  expected: 69

# ---------------------------------------------------------------------------
# itertools.batched — error: n must be at least one
# ---------------------------------------------------------------------------

invariant itertools_extra328.batched.zero_n_raises:
  description: "itertools.batched('hello', 0) raises ValueError — n must be at least one"
  category: error
  kind: python_call_raises
  function: batched
  args: ["hello", 0]
  raises: ValueError

# ---------------------------------------------------------------------------
# Table: module affiliation for pairwise and batched
# ---------------------------------------------------------------------------

table itertools_extra328.function_modules:
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [pairwise,    pairwise.__module__.__eq__,    ["itertools"], true]
    - [batched,     batched.__module__.__eq__,     ["itertools"], true]
    - [accumulate,  accumulate.__module__.__eq__,  ["itertools"], true]
