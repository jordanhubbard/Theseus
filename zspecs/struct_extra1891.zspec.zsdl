spec: struct_extra1891
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and struct module public API membership"
    - "struct.Struct is a C extension type for binary packing; it does not implement numeric protocols"
    - "struct.error is an exception class and does not implement numeric protocols"
    - "struct module dict contains pack, unpack, pack_into, unpack_from, iter_unpack, calcsize, Struct, error"
    - "struct.Struct.__dict__ contains __new__ and __doc__ as standard C extension type entries"
  created_at: "2026-04-12"

table struct_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["st1891-ua-001", "struct.Struct.__dict__.__contains__", ["__abs__"], false]
    - ["st1891-ua-002", "struct.Struct.__dict__.__contains__", ["__neg__"], false]
    - ["st1891-ua-003", "struct.Struct.__dict__.__contains__", ["__pos__"], false]
    - ["st1891-ua-004", "struct.Struct.__dict__.__contains__", ["__round__"], false]
    - ["st1891-ua-005", "struct.error.__dict__.__contains__", ["__abs__"], false]
    - ["st1891-ua-006", "struct.__dict__.__contains__", ["__abs__"], false]
    - ["st1891-ua-007", "struct.__dict__.__contains__", ["__neg__"], false]
    - ["st1891-ua-008", "struct.__dict__.__contains__", ["__pos__"], false]

table struct_extra1891.fspath_aiter_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1891-fa-001", "struct.Struct.__dict__.__contains__", ["__fspath__"], false]
    - ["st1891-fa-002", "struct.Struct.__dict__.__contains__", ["__aiter__"], false]
    - ["st1891-fa-003", "struct.Struct.__dict__.__contains__", ["__anext__"], false]
    - ["st1891-fa-004", "struct.error.__dict__.__contains__", ["__fspath__"], false]
    - ["st1891-fa-005", "struct.__dict__.__contains__", ["__fspath__"], false]
    - ["st1891-fa-006", "struct.__dict__.__contains__", ["__aiter__"], false]
    - ["st1891-fa-007", "struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st1891-fa-008", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]

table struct_extra1891.struct_pack_format_chars:
  columns: [id, function, args, expected]
  rows:
    - ["st1891-pk-001", "struct.__dict__.__contains__", ["pack"], true]
    - ["st1891-pk-002", "struct.__dict__.__contains__", ["unpack"], true]
    - ["st1891-pk-003", "struct.__dict__.__contains__", ["pack_into"], true]
    - ["st1891-pk-004", "struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1891-pk-005", "struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1891-pk-006", "struct.__dict__.__contains__", ["calcsize"], true]
    - ["st1891-pk-007", "struct.__dict__.__contains__", ["Struct"], true]
    - ["st1891-pk-008", "struct.__dict__.__contains__", ["error"], true]
    - ["st1891-pk-009", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st1891-pk-010", "struct.Struct.__dict__.__contains__", ["__doc__"], true]
