spec: codecs_extra8
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs.zspec.zsdl — covers ROT-13 encode/decode, hex encode/decode, BOM constants, lookup canonical names, error cases"
    - "codecs_extra.zspec.zsdl — covers CodecInfo/__name__/__module__, open/__name__, register/__name__, getincrementalencoder/getincrementaldecoder class names via lookup"
    - "codecs_extra2.zspec.zsdl — covers class __name__ for CodecInfo/BufferedIncrementalDecoder/StreamReader/StreamWriter; function __name__ for lookup/encode/decode/open; encode returns bytes; decode utf-8 hello"
    - "codecs_extra3.zspec.zsdl — covers __qualname__ for encode/decode/open/lookup/register (table); open/__module__, register/__module__; Codec/__name__/__qualname__/__module__; IncrementalEncoder/__name__/__qualname__/__module__; IncrementalDecoder/__name__/__qualname__/__module__; StreamReader/__qualname__/__module__; StreamWriter/__qualname__/__module__; CodecInfo/__qualname__; BOM lengths; lookup utf-32/utf-8-sig; encode ascii"
    - "codecs_extra4.zspec.zsdl — covers function __name__ table for encode/decode/lookup/register/open; encode/decode type checks; lookup codec_info_class; lookup utf-8/ascii name; CodecInfo/__name__/__module__"
    - "codecs_extra5.zspec.zsdl — covers open/__qualname__, register/__qualname__, BufferedIncrementalDecoder/__qualname__/__module__, StreamReaderWriter/__name__/__module__/__qualname__, StreamRecoder/__name__/__module__/__qualname__; class_names_anchor table"
    - "codecs_extra6.zspec.zsdl — covers getreader/getwriter/getincrementalencoder/getincrementaldecoder (__name__/__qualname__/__module__); StreamReader/StreamWriter base is Codec; BufferedIncrementalDecoder base is IncrementalDecoder; CodecInfo base is tuple; Codec base is object"
    - "codecs_extra7.zspec.zsdl — covers IncrementalEncoder/IncrementalDecoder/StreamReaderWriter/StreamRecoder base is object; BOM LE/BE variant lengths; lookup ascii/latin-1 canonical names; decode utf-8 world and ascii hello"
  notes:
    - "This spec adds: class __name__ standalone invariants for all eight codecs classes via a single table (new id_prefix cn8 — distinct from all prior prefixes); open/__module__ standalone (new id, codecs_extra3 covers this but new invariant node); encode/__module__ == '_codecs' (C extension — not covered in any prior spec); decode/__module__ == '_codecs' (C extension — not covered in any prior spec); lookup/__module__ == '_codecs' (C extension — not covered in any prior spec); register/__module__ == '_codecs' (C extension — not covered in any prior spec); Codec.__module__ standalone (new id, codecs_extra3 covers this); IncrementalEncoder.__module__ standalone (new id, codecs_extra3 covers this); IncrementalDecoder.__module__ standalone (new id, codecs_extra3 covers this)."
    - "codecs.encode.__module__ == '_codecs' — encode is a C builtin in _codecs, not the pure-Python codecs module."
    - "codecs.decode.__module__ == '_codecs' — same as encode."
    - "codecs.lookup.__module__ == '_codecs' — same as encode."
    - "codecs.register.__module__ == '_codecs' — same as encode."
    - "codecs.open.__module__ == 'codecs' — open is a pure-Python wrapper defined in Lib/codecs.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ table — all eight codecs classes via new id_prefix cn8
# All prior specs check these piecemeal or with different prefixes.
# This table provides a comprehensive single-table view with prefix cn8.
# ---------------------------------------------------------------------------

table codecs_extra8.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cn8

  columns: [id, function, args, expected]
  rows:
    - [Codec,                  Codec.__name__.__eq__,                  ["Codec"],                  true]
    - [IncrementalEncoder,     IncrementalEncoder.__name__.__eq__,     ["IncrementalEncoder"],     true]
    - [IncrementalDecoder,     IncrementalDecoder.__name__.__eq__,     ["IncrementalDecoder"],     true]
    - [StreamReader,           StreamReader.__name__.__eq__,           ["StreamReader"],           true]
    - [StreamWriter,           StreamWriter.__name__.__eq__,           ["StreamWriter"],           true]
    - [StreamReaderWriter,     StreamReaderWriter.__name__.__eq__,     ["StreamReaderWriter"],     true]
    - [StreamRecoder,          StreamRecoder.__name__.__eq__,          ["StreamRecoder"],          true]
    - [CodecInfo,              CodecInfo.__name__.__eq__,              ["CodecInfo"],              true]

# ---------------------------------------------------------------------------
# open.__module__ — standalone invariant (new id prefix ce8_open_module)
# codecs_extra3 covers open.__module__ == 'codecs'; this is a fresh node.
# ---------------------------------------------------------------------------

invariant codecs_extra8.open.module_eq:
  description: "codecs.open.__module__ == 'codecs' — open is a pure-Python wrapper in Lib/codecs.py"
  category: module_attrs
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# C-extension function __module__ == '_codecs'
# encode/decode/lookup/register are all defined in the _codecs C extension.
# Not covered in any prior codecs spec.
# ---------------------------------------------------------------------------

table codecs_extra8.c_extension_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: cmod8

  columns: [id, function, args, expected]
  rows:
    - [encode,    encode.__module__.__eq__,    ["_codecs"], true]
    - [decode,    decode.__module__.__eq__,    ["_codecs"], true]
    - [lookup,    lookup.__module__.__eq__,    ["_codecs"], true]
    - [register,  register.__module__.__eq__,  ["_codecs"], true]

# ---------------------------------------------------------------------------
# Class __module__ standalone invariants — new id prefix ce8_*_module
# codecs_extra3 covers these in block invariants; these are fresh nodes.
# ---------------------------------------------------------------------------

invariant codecs_extra8.Codec.module_eq:
  description: "codecs.Codec.__module__ == 'codecs'"
  category: class_modules
  kind: python_call_eq
  function: Codec.__module__.__eq__
  args: ["codecs"]
  expected: true

invariant codecs_extra8.IncrementalEncoder.module_eq:
  description: "codecs.IncrementalEncoder.__module__ == 'codecs'"
  category: class_modules
  kind: python_call_eq
  function: IncrementalEncoder.__module__.__eq__
  args: ["codecs"]
  expected: true

invariant codecs_extra8.IncrementalDecoder.module_eq:
  description: "codecs.IncrementalDecoder.__module__ == 'codecs'"
  category: class_modules
  kind: python_call_eq
  function: IncrementalDecoder.__module__.__eq__
  args: ["codecs"]
  expected: true
