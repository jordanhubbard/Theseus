spec: duckdb_rust
version: ">=3.9"
backend: rust_module(duckdb_rust)

docs: https://duckdb.org/docs/api/python/

provenance:
  derived_from:
    - "https://duckdb.org/docs/api/python/ — DuckDB Python API"
  notes:
    - "DuckDB is an in-process SQL OLAP database."
    - "duckdb.connect() returns a connection."
    - "duckdb.sql('SELECT 42').fetchone()[0] == 42."
    - "duckdb.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant duckdb_rust.sql_select_42:
  description: "duckdb.sql('SELECT 42').fetchone()[0] == 42"
  category: sql
  kind: python_call_eq
  function: duckdb_sql_select_42
  args: []
  expected: 42

invariant duckdb_rust.has_connect:
  description: "duckdb.connect is callable"
  category: presence
  kind: python_call_eq
  function: duckdb_has_connect
  args: []
  expected: true

invariant duckdb_rust.version_nonempty:
  description: "duckdb.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: duckdb_version_nonempty
  args: []
  expected: true

