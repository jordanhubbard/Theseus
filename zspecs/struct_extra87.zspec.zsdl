spec: struct_extra87
version: ">=3.9"
extends: struct_extra86
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra86.zspec.zsdl — covers struct.Struct dunder method class names (__init__/__new__/__repr__ wrapper_descriptor/builtin_function_or_method) / struct.error MRO chain / Struct.__dict__ dunder membership (table + invariants)."
    - "struct_extra85.zspec.zsdl — covers struct.Struct/__class__.__name__=='type' / Struct/__doc__/__class__.__name__=='str' / Struct pack/unpack method_descriptor class names / module-level pack/unpack/calcsize builtin_function_or_method class names / error class identity (table + invariants)."
    - "struct_extra84.zspec.zsdl — covers Struct method __qualname__ string lengths / module-level function __qualname__ string lengths (table + invariants)."
    - "struct_extra83.zspec.zsdl — covers module-level function __qualname__.__eq__ / Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__[0].__name__/__mro__.__len__() (table + invariants)."
    - "struct_extra81.zspec.zsdl — covers struct.__spec__/__loader__ identity / struct.__doc__.__class__.__name__=='str' / struct.__package__.__eq__('') / struct.error.__bases__[0].__name__.__eq__('Exception') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra86; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: struct module identity (__name__, __package__) cross-checks + module-level function __module__ values + struct.Struct class identity (__module__, __bases__, __mro__)."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct')
# struct.__package__.__eq__('')
# struct.__doc__.__class__.__name__.__eq__('str') (cross-check)
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec') (cross-check)
#
# Wave 256 theme: struct module string identity cross-checks.
#
# struct.__name__ is 'struct' and __package__ is '' (empty string).
# struct_extra81 first anchors these; this table repeats them under
# structmoduleid87 as cross-checks alongside doc and spec class name
# confirmations. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra87.struct_module_string_identity:
  description: "struct.__name__.__eq__('struct')==True / struct.__package__.__eq__('')==True / struct.__doc__/__class__.__name__.__eq__('str')==True / struct.__spec__/__class__.__name__.__eq__('ModuleSpec')==True — struct module identity: __name__ is 'struct', __package__ is empty string, docstring is str, spec is ModuleSpec; struct_extra81 first anchors __name__/__package__/__spec__; this table cross-checks under structmoduleid87; first structmoduleid87 anchor for struct module string identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmoduleid87

  columns: [id, function, args, expected]
  rows:
    - [struct_name_eq,       __name__.__eq__,                       ["struct"],      true]
    - [struct_package_eq,    __package__.__eq__,                    [""],             true]
    - [struct_doc_class_eq,  __doc__.__class__.__name__.__eq__,     ["str"],          true]
    - [struct_spec_class_eq, __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],   true]

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# struct.__doc__.__class__.__name__.__eq__('str') (cross-check)
# struct.__name__.__eq__('struct') (cross-check)
#
# Wave 256 theme: struct.__spec__ and __loader__ class names.
#
# struct.__spec__ is a ModuleSpec instance and struct.__loader__ is a
# SourceFileLoader (struct.py wraps the _struct C extension). struct_extra81
# first anchors these; this table cross-checks under structmoduleid87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra87.struct_spec_loader_class_names:
  description: "struct.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / struct.__loader__/__class__.__name__.__eq__('SourceFileLoader')==True / struct.__doc__/__class__.__name__.__eq__('str')==True / struct.__name__.__eq__('struct')==True — struct.py is a Python wrapper loaded by SourceFileLoader; its spec is a ModuleSpec instance; struct_extra81 first anchors these; this table cross-checks under structmoduleid87; first structmoduleid87 anchor for spec/loader class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmoduleid87

  columns: [id, function, args, expected]
  rows:
    - [struct_spec_modulespec,     __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [struct_loader_sourceloader, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [struct_doc_str_xchk,        __doc__.__class__.__name__.__eq__,     ["str"],              true]
    - [struct_name_xchk,           __name__.__eq__,                       ["struct"],           true]

# ---------------------------------------------------------------------------
# struct.pack/__class__.__name__.__eq__('builtin_function_or_method') (cross-check)
# struct.unpack/__class__.__name__.__eq__('builtin_function_or_method') (cross-check)
# struct.calcsize/__class__.__name__.__eq__('builtin_function_or_method') (cross-check)
# struct.pack_into/__class__.__name__.__eq__('builtin_function_or_method') (cross-check)
# struct.iter_unpack/__class__.__name__.__eq__('builtin_function_or_method') (cross-check)
# struct.unpack_from/__class__.__name__.__eq__('builtin_function_or_method') (cross-check)
#
# Wave 256 theme: module-level function __class__.__name__ cross-checks.
#
# All six module-level struct functions (pack, pack_into, unpack, unpack_from,
# iter_unpack, calcsize) are C-level builtin_function_or_method objects sourced
# from _struct. struct_extra85 first anchors their class names; this table
# cross-checks three of them under structmoduleid87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra87.struct_func_class_names:
  description: "struct.pack/__class__.__name__.__eq__('builtin_function_or_method')==True / unpack/__class__.__name__.__eq__('builtin_function_or_method')==True / calcsize/__class__.__name__.__eq__('builtin_function_or_method')==True / pack_into/__class__.__name__.__eq__('builtin_function_or_method')==True — pack/unpack/calcsize/pack_into are C-level builtin_function_or_method objects from the _struct extension; struct_extra85 first anchors class names; this table cross-checks under structmoduleid87; first structmoduleid87 anchor for module-level function class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmoduleid87

  columns: [id, function, args, expected]
  rows:
    - [pack_class_builtin,      pack.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [unpack_class_builtin,    unpack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [calcsize_class_builtin,  calcsize.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [pack_into_class_builtin, pack_into.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct.Struct/__module__.__eq__('_struct')
# struct.Struct/__bases__[0]/__name__.__eq__('object')
# struct.Struct/__mro__/__len__()==2
# struct.__name__.__eq__('struct') (cross-check)
#
# Wave 256 theme: struct.Struct class identity.
#
# struct.Struct.__module__ is '_struct' (the C extension), __bases__[0].__name__
# is 'object', and __mro__.__len__() is 2. struct_extra82 anchors __bases__ and
# __mro__ length; struct_extra11 anchors __module__; this table cross-checks
# all three together under structmoduleid87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra87.struct_Struct_class_identity:
  description: "struct.Struct/__module__.__eq__('_struct')==True / Struct/__bases__[0]/__name__.__eq__('object')==True / Struct/__mro__/__len__()==2 / struct.__name__.__eq__('struct')==True — Struct is a C type defined in _struct; it inherits directly from object giving a two-entry MRO; struct_extra82 anchors __bases__/__mro__.__len__; struct_extra11 anchors __module__; this table cross-checks all three under structmoduleid87; first structmoduleid87 anchor for Struct class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: structmoduleid87

  columns: [id, function, args, expected]
  rows:
    - [struct_Struct_module_eq,       Struct.__module__.__eq__,               ["_struct"],  true]
    - ["struct_Struct_bases0_name_eq", "Struct.__bases__[0].__name__.__eq__", ["object"],   true]
    - [struct_Struct_mro_len,         Struct.__mro__.__len__,                 [],            2]
    - [struct_name_xchk2,             __name__.__eq__,                        ["struct"],   true]

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct') — standalone
#
# struct.__name__ is 'struct'. struct_extra81 first anchors this via a table row;
# this standalone re-anchors it under structmoduleid87. First standalone for
# struct.__name__ under structmoduleid87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra87.struct_name_eq:
  description: "struct.__name__.__eq__('struct') == True — the struct module's __name__ attribute is 'struct'; struct_extra81 first anchors this; this standalone re-anchors under structmoduleid87 as a cross-check; first standalone for struct.__name__ under structmoduleid87"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# struct.__loader__.__class__.__name__ is 'SourceFileLoader'. struct.py is a
# Python wrapper that imports the _struct C extension; it is loaded by
# importlib.machinery.SourceFileLoader. struct_extra81 first anchors this;
# this standalone re-anchors under structmoduleid87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra87.struct_loader_sourcefileloader:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — struct.py is a Python wrapper loaded by importlib.machinery.SourceFileLoader; __class__.__name__ is 'SourceFileLoader'; struct_extra81 first anchors this; first standalone for struct.__loader__ class identity under structmoduleid87"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack/__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack is a C-level builtin_function_or_method from the _struct extension.
# struct_extra85 first anchors its class name; this standalone re-anchors under
# structmoduleid87. First standalone for struct.pack class identity under
# structmoduleid87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra87.pack_class_builtin:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — struct.pack is a C-level function from the _struct extension; its __class__.__name__ is 'builtin_function_or_method'; struct_extra85 first anchors this; first standalone for struct.pack class identity under structmoduleid87"
  category: module_identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct/__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct'. The Struct class is defined in the
# _struct C extension. struct_extra11 first anchors this; this standalone
# re-anchors under structmoduleid87. First standalone for Struct.__module__
# under structmoduleid87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra87.struct_Struct_module_eq:
  description: "struct.Struct.__module__.__eq__('_struct') == True — struct.Struct is a C type defined in the _struct extension module; its __module__ is '_struct'; struct_extra11 first anchors this; first standalone for Struct.__module__ under structmoduleid87"
  category: module_identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct/__mro__/__len__()==2 — standalone
#
# struct.Struct.__mro__.__len__() is 2 ([Struct, object]). struct_extra82 first
# anchors this; this standalone re-anchors under structmoduleid87. First standalone
# for Struct.__mro__.__len__ under structmoduleid87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra87.struct_Struct_mro_len:
  description: "struct.Struct.__mro__.__len__() == 2 — Struct inherits only from object; its MRO is [Struct, object] with length 2; struct_extra82 first anchors this; first standalone for Struct.__mro__.__len__ under structmoduleid87"
  category: module_identity
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2
