spec: cgi_extra2
version: ">=3.9,<3.13"
backend: python_module(cgi)

docs: https://docs.python.org/3/library/cgi.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cgi.html — Python cgi module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cgi.py"
  notes:
    - "The cgi module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec extends cgi.zspec.zsdl and cgi_extra.zspec.zsdl."
    - "cgi.zspec.zsdl covers: FieldStorage.__name__, MiniFieldStorage.__name__, parse.__name__, parse_header.__name__, escape.__name__, and parse_header/escape behavioral vectors."
    - "cgi_extra.zspec.zsdl covers: FieldStorage.__module__, MiniFieldStorage.__module__, and print_exception.__name__."
    - "This spec adds: parse_multipart.__name__, parse_qs.__name__, parse_qsl.__name__, class __bases__ checks, and parse_header return-type checks."
    - "cgi.parse_multipart parses multipart/form-data POST data; its __name__ is 'parse_multipart'."
    - "cgi.parse_qs and cgi.parse_qsl delegate to urllib.parse equivalents in Python 3.x."
    - "FieldStorage.__bases__[0].__name__ == 'object' in Python 3 (pure-Python class, no CGI base)."
    - "MiniFieldStorage.__bases__[0].__name__ == 'object' — similarly a pure-Python class."
    - "parse_header returns a 2-tuple; the second element is a plain dict."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks
# (cgi.zspec.zsdl covers FieldStorage and MiniFieldStorage __name__ already;
#  these are retained here as anchors for the extra2 family for completeness.)
# ---------------------------------------------------------------------------

invariant cgi_extra2.FieldStorage.name:
  description: "cgi.FieldStorage.__name__ == 'FieldStorage'"
  category: classnames
  kind: python_call_eq
  function: FieldStorage.__name__.__eq__
  args: ["FieldStorage"]
  expected: true

invariant cgi_extra2.FieldStorage.module:
  description: "cgi.FieldStorage.__module__ == 'cgi'"
  category: classnames
  kind: python_call_eq
  function: FieldStorage.__module__.__eq__
  args: ["cgi"]
  expected: true

invariant cgi_extra2.MiniFieldStorage.name:
  description: "cgi.MiniFieldStorage.__name__ == 'MiniFieldStorage'"
  category: classnames
  kind: python_call_eq
  function: MiniFieldStorage.__name__.__eq__
  args: ["MiniFieldStorage"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

invariant cgi_extra2.parse_header.name:
  description: "cgi.parse_header.__name__ == 'parse_header'"
  category: functions
  kind: python_call_eq
  function: parse_header.__name__.__eq__
  args: ["parse_header"]
  expected: true

invariant cgi_extra2.parse_multipart.name:
  description: "cgi.parse_multipart.__name__ == 'parse_multipart'"
  category: functions
  kind: python_call_eq
  function: parse_multipart.__name__.__eq__
  args: ["parse_multipart"]
  expected: true

invariant cgi_extra2.parse.name:
  description: "cgi.parse.__name__ == 'parse'"
  category: functions
  kind: python_call_eq
  function: parse.__name__.__eq__
  args: ["parse"]
  expected: true

invariant cgi_extra2.parse_qs.name:
  description: "cgi.parse_qs.__name__ == 'parse_qs'"
  category: functions
  kind: python_call_eq
  function: parse_qs.__name__.__eq__
  args: ["parse_qs"]
  expected: true

invariant cgi_extra2.parse_qsl.name:
  description: "cgi.parse_qsl.__name__ == 'parse_qsl'"
  category: functions
  kind: python_call_eq
  function: parse_qsl.__name__.__eq__
  args: ["parse_qsl"]
  expected: true

# ---------------------------------------------------------------------------
# parse_header return type — second element is a dict
# ---------------------------------------------------------------------------

invariant cgi_extra2.parse_header.params_is_dict:
  description: "parse_header('text/plain; charset=utf-8')[1].__class__.__name__ == 'dict'"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["text/plain; charset=utf-8"]
  method: __getitem__
  method_args: [1]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["dict"]
  expected: true

invariant cgi_extra2.parse_header.returns_tuple:
  description: "parse_header('text/plain')[0] == 'text/plain' — tuple first element"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["text/plain"]
  method: __getitem__
  method_args: [0]
  expected: "text/plain"

invariant cgi_extra2.parse_header.boundary_param:
  description: "parse_header('multipart/form-data; boundary=abc123')[1]['boundary'] == 'abc123'"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["multipart/form-data; boundary=abc123"]
  method: __getitem__
  method_args: [1]
  method_chain: __getitem__
  method_chain_args: ["boundary"]
  expected: "abc123"

# ---------------------------------------------------------------------------
# Class __bases__ checks
# ---------------------------------------------------------------------------

invariant cgi_extra2.FieldStorage.base_is_object:
  description: "cgi.FieldStorage.__bases__[0].__name__ == 'object' — FieldStorage inherits from object"
  category: classnames
  kind: python_call_eq
  function: FieldStorage.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant cgi_extra2.MiniFieldStorage.base_is_object:
  description: "cgi.MiniFieldStorage.__bases__[0].__name__ == 'object' — MiniFieldStorage inherits from object"
  category: classnames
  kind: python_call_eq
  function: MiniFieldStorage.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
