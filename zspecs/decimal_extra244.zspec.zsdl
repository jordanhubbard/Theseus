spec: decimal_extra244
version: ">=3.3"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context default values (precision, rounding) and rounding constant string identity."
    - "decimal.DefaultContext.prec == 28 — the default precision for the DefaultContext is 28 significant digits; verified Python 3.14.3 macOS."
    - "decimal.DefaultContext.rounding == 'ROUND_HALF_EVEN' — default rounding mode; verified Python 3.14.3 macOS."
    - "decimal.BasicContext.prec == 9, rounding == 'ROUND_HALF_UP' — BasicContext matches IBM General Decimal Arithmetic specification; verified Python 3.14.3 macOS."
    - "decimal.ExtendedContext.prec == 9, rounding == 'ROUND_HALF_EVEN' — ExtendedContext precision is 9; verified Python 3.14.3 macOS."
    - "decimal.getcontext().prec == 28 — the thread-local default context has precision 28; verified Python 3.14.3 macOS."
    - "Rounding constants (ROUND_HALF_EVEN, ROUND_UP, etc.) are plain string objects, not enum members; verified Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN', decimal.ROUND_UP == 'ROUND_UP', decimal.ROUND_DOWN == 'ROUND_DOWN'; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context default precision and rounding — 5-column table
# ---------------------------------------------------------------------------

table decimal_extra244.context_defaults:
  description: "decimal Context prec and rounding defaults for DefaultContext, BasicContext, ExtendedContext; verified Python 3.14.3"
  kind: python_call_eq
  category: context
  id_prefix: decctx244

  columns: [id, function, args, expected, description]
  rows:
    - [default_prec,      "decimal.DefaultContext.prec.__eq__",       [28],                true, "decimal.DefaultContext.prec == 28"]
    - [default_rounding,  "decimal.DefaultContext.rounding.__eq__",   ["ROUND_HALF_EVEN"], true, "decimal.DefaultContext.rounding == 'ROUND_HALF_EVEN'"]
    - [basic_prec,        "decimal.BasicContext.prec.__eq__",         [9],                 true, "decimal.BasicContext.prec == 9"]
    - [basic_rounding,    "decimal.BasicContext.rounding.__eq__",     ["ROUND_HALF_UP"],   true, "decimal.BasicContext.rounding == 'ROUND_HALF_UP'"]
    - [extended_prec,     "decimal.ExtendedContext.prec.__eq__",      [9],                 true, "decimal.ExtendedContext.prec == 9"]
    - [extended_rounding, "decimal.ExtendedContext.rounding.__eq__",  ["ROUND_HALF_EVEN"], true, "decimal.ExtendedContext.rounding == 'ROUND_HALF_EVEN'"]

# ---------------------------------------------------------------------------
# Rounding constant string identity — 5-column table
# Rounding constants are plain Python str objects; __eq__ compares by value.
# ---------------------------------------------------------------------------

table decimal_extra244.rounding_constants:
  description: "decimal rounding constants are string objects with specific values; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround244

  columns: [id, function, args, expected, description]
  rows:
    - [half_even,  "decimal.ROUND_HALF_EVEN.__eq__",  ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'"]
    - [up,         "decimal.ROUND_UP.__eq__",          ["ROUND_UP"],         true, "decimal.ROUND_UP == 'ROUND_UP'"]
    - [down,       "decimal.ROUND_DOWN.__eq__",        ["ROUND_DOWN"],       true, "decimal.ROUND_DOWN == 'ROUND_DOWN'"]
    - [ceiling,    "decimal.ROUND_CEILING.__eq__",     ["ROUND_CEILING"],    true, "decimal.ROUND_CEILING == 'ROUND_CEILING'"]
    - [floor,      "decimal.ROUND_FLOOR.__eq__",       ["ROUND_FLOOR"],      true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR'"]
    - [half_up,    "decimal.ROUND_HALF_UP.__eq__",     ["ROUND_HALF_UP"],    true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"]
    - [half_down,  "decimal.ROUND_HALF_DOWN.__eq__",   ["ROUND_HALF_DOWN"],  true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'"]
    - [zero_five,  "decimal.ROUND_05UP.__eq__",        ["ROUND_05UP"],       true, "decimal.ROUND_05UP == 'ROUND_05UP'"]

# ---------------------------------------------------------------------------
# Standalone invariants — getcontext thread-local defaults
# ---------------------------------------------------------------------------

invariant decimal_extra244.getcontext.prec:
  description: "decimal.getcontext().prec == 28 — the thread-local default context precision is 28; verified Python 3.14.3 macOS"
  category: context
  kind: python_call_eq
  function: decimal.getcontext().prec.__eq__
  args: [28]
  expected: true

invariant decimal_extra244.getcontext.rounding:
  description: "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' — the thread-local default context rounding mode; verified Python 3.14.3 macOS"
  category: context
  kind: python_call_eq
  function: decimal.getcontext().rounding.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — Context class identity
# ---------------------------------------------------------------------------

invariant decimal_extra244.Context.classname:
  description: "decimal.Context.__name__ == 'Context' — verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra244.Context.module:
  description: "decimal.Context.__module__ == 'decimal' — Context class is defined in the decimal module; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra244.Decimal.classname:
  description: "decimal.Decimal.__name__ == 'Decimal' — verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — rounding constant string identity
# ---------------------------------------------------------------------------

invariant decimal_extra244.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — rounding constants are plain string objects; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra244.ROUND_UP.value:
  description: "decimal.ROUND_UP == 'ROUND_UP' — verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra244.ROUND_DOWN.value:
  description: "decimal.ROUND_DOWN == 'ROUND_DOWN' — verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

invariant decimal_extra244.ROUND_CEILING.value:
  description: "decimal.ROUND_CEILING == 'ROUND_CEILING' — verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_CEILING.__eq__
  args: ["ROUND_CEILING"]
  expected: true

invariant decimal_extra244.ROUND_FLOOR.value:
  description: "decimal.ROUND_FLOOR == 'ROUND_FLOOR' — verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_FLOOR.__eq__
  args: ["ROUND_FLOOR"]
  expected: true

invariant decimal_extra244.ROUND_HALF_UP.value:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra244.ROUND_HALF_DOWN.value:
  description: "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' — verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_DOWN.__eq__
  args: ["ROUND_HALF_DOWN"]
  expected: true

invariant decimal_extra244.ROUND_05UP.value:
  description: "decimal.ROUND_05UP == 'ROUND_05UP' — rounds toward zero unless last digit is 0 or 5; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_05UP.__eq__
  args: ["ROUND_05UP"]
  expected: true
