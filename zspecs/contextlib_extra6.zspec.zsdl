spec: contextlib_extra6
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl, contextlib_extra.zspec.zsdl, contextlib_extra2.zspec.zsdl, contextlib_extra3.zspec.zsdl, contextlib_extra4.zspec.zsdl, contextlib_extra5.zspec.zsdl, and contextlib_suppress.zspec.zsdl."
    - "Focus: __name__ and __module__ for abstract base classes, and __qualname__ for functions and classes."
    - "contextlib.AbstractContextManager and AbstractAsyncContextManager are ABCs defined in contextlib."
    - "contextmanager and asynccontextmanager are decorator functions; closing, suppress, redirect_stdout, redirect_stderr, ExitStack, AsyncExitStack are context manager classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AbstractContextManager — __name__ and __module__
# ---------------------------------------------------------------------------

invariant contextlib_extra6.AbstractContextManager.name:
  description: "contextlib.AbstractContextManager.__name__ == 'AbstractContextManager'"
  category: class_names
  kind: python_call_eq
  function: AbstractContextManager.__name__.__eq__
  args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra6.AbstractContextManager.module:
  description: "contextlib.AbstractContextManager.__module__ == 'contextlib'"
  category: class_names
  kind: python_call_eq
  function: AbstractContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra6.AbstractAsyncContextManager.name:
  description: "contextlib.AbstractAsyncContextManager.__name__ == 'AbstractAsyncContextManager'"
  category: class_names
  kind: python_call_eq
  function: AbstractAsyncContextManager.__name__.__eq__
  args: ["AbstractAsyncContextManager"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — functions: contextmanager, asynccontextmanager
# ---------------------------------------------------------------------------

invariant contextlib_extra6.contextmanager.qualname:
  description: "contextlib.contextmanager.__qualname__ == 'contextmanager'"
  category: qualnames
  kind: python_call_eq
  function: contextmanager.__qualname__.__eq__
  args: ["contextmanager"]
  expected: true

invariant contextlib_extra6.asynccontextmanager.qualname:
  description: "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager'"
  category: qualnames
  kind: python_call_eq
  function: asynccontextmanager.__qualname__.__eq__
  args: ["asynccontextmanager"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — classes: closing, suppress, redirect_stdout,
#                                redirect_stderr, ExitStack, AsyncExitStack
# ---------------------------------------------------------------------------

invariant contextlib_extra6.redirect_stdout.qualname:
  description: "contextlib.redirect_stdout.__qualname__ == 'redirect_stdout'"
  category: qualnames
  kind: python_call_eq
  function: redirect_stdout.__qualname__.__eq__
  args: ["redirect_stdout"]
  expected: true

invariant contextlib_extra6.redirect_stderr.qualname:
  description: "contextlib.redirect_stderr.__qualname__ == 'redirect_stderr'"
  category: qualnames
  kind: python_call_eq
  function: redirect_stderr.__qualname__.__eq__
  args: ["redirect_stderr"]
  expected: true

# ---------------------------------------------------------------------------
# Table: qualname checks for closing, suppress, ExitStack, AsyncExitStack
# (contextmanager and asynccontextmanager already have individual invariants above)
# ---------------------------------------------------------------------------

table contextlib_extra6.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,       contextmanager.__qualname__.__eq__,       ["contextmanager"],       true]
    - [asynccontextmanager,  asynccontextmanager.__qualname__.__eq__,  ["asynccontextmanager"],  true]
    - [closing,              closing.__qualname__.__eq__,              ["closing"],              true]
    - [suppress,             suppress.__qualname__.__eq__,             ["suppress"],             true]
    - [ExitStack,            ExitStack.__qualname__.__eq__,            ["ExitStack"],            true]

invariant contextlib_extra6.AsyncExitStack.qualname:
  description: "contextlib.AsyncExitStack.__qualname__ == 'AsyncExitStack'"
  category: qualnames
  kind: python_call_eq
  function: AsyncExitStack.__qualname__.__eq__
  args: ["AsyncExitStack"]
  expected: true
