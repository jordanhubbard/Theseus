spec: theseus_site_cr
version: ">=3.0"
backend: python_cleanroom(theseus_site_cr)
blocks: site

docs: https://docs.python.org/3/library/site.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/site.html"
  not_derived_from:
    - "CPython source: Lib/site.py"
  notes:
    - "Clean-room site module. Do NOT import site."

error_model: python_exceptions

invariant theseus_site_cr.site2_prefixes:
  description: "PREFIXES list contains sys.prefix"
  category: behavior
  kind: python_call_eq
  function: site2_prefixes
  args: []
  expected: true

invariant theseus_site_cr.site2_user_site:
  description: "USER_SITE path contains site-packages"
  category: behavior
  kind: python_call_eq
  function: site2_user_site
  args: []
  expected: true

invariant theseus_site_cr.site2_addsitedir:
  description: "addsitedir() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: site2_addsitedir
  args: []
  expected: true
