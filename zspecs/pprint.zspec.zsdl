spec: pprint
version: ">=3.0"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "Python pprint documentation — https://docs.python.org/3/library/pprint.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "pformat(obj) returns a string representation equivalent to pprint output."
    - "saferepr(obj) returns a safe string representation that truncates recursive structures."
    - "isreadable(obj) returns True for any object that can be reconstructed from its repr."
    - "isrecursive(obj) returns True only for objects containing a recursive reference."
    - "pformat of simple types (int, str, None, bool, list, dict) is deterministic."
    - "pformat(dict) key order follows insertion order in Python 3.7+; simple dicts are deterministic."
    - "pformat([1,2,3]) == '[1, 2, 3]' — list items are separated by ', ' with spaces."
    - "pformat({'a':1,'b':2}) == \"{'a': 1, 'b': 2}\" on Python 3.8+ (insertion order preserved)."
    - "pformat of a tuple uses parentheses: '(1, 2, 3)'."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pformat — returns string representation of objects
# ---------------------------------------------------------------------------

table pprint.pformat.primitives:
  description: "pformat() returns correct string for primitive types"
  kind: python_call_eq
  category: pformat
  id_prefix: pformat
  function: pformat

  columns: [id, args, expected]
  rows:
    - [int,       [42],      "42"]
    - [str,       ["hello"], "'hello'"]
    - [none,      [null],    "None"]
    - [bool_true, [true],    "True"]
    - [bool_false,[false],   "False"]
    - [float,     [3.14],    "3.14"]
    - [zero,      [0],       "0"]
    - [empty_str, [""],      "''"]

table pprint.pformat.containers:
  description: "pformat() returns correct string for container types"
  kind: python_call_eq
  category: pformat
  id_prefix: pformat
  function: pformat

  columns: [id, args, expected]
  rows:
    - [empty_list, [[]], "[]"]
    - [empty_dict, [{}], "{}"]
    - [list_123,   [[1, 2, 3]], "[1, 2, 3]"]

# ---------------------------------------------------------------------------
# isreadable — True for all standard Python objects
# ---------------------------------------------------------------------------

table pprint.isreadable:
  description: "isreadable() returns True for common Python objects"
  kind: python_call_eq
  category: isreadable
  id_prefix: isreadable
  function: isreadable

  columns: [id, args, expected]
  rows:
    - [int,     [42],      true]
    - [str,     ["hello"], true]
    - [none,    [null],    true]
    - [bool,    [true],    true]
    - [list,    [[1, 2, 3]], true]
    - [dict,    [{"a": 1}], true]
    - [empty,   [[]], true]

# ---------------------------------------------------------------------------
# isrecursive — False for all non-recursive objects
# ---------------------------------------------------------------------------

table pprint.isrecursive:
  description: "isrecursive() returns False for non-recursive objects"
  kind: python_call_eq
  category: isrecursive
  id_prefix: isrecursive
  function: isrecursive

  columns: [id, args, expected]
  rows:
    - [int,  [42],        false]
    - [str,  ["hello"],   false]
    - [none, [null],      false]
    - [list, [[1, 2, 3]], false]
    - [dict, [{"a": 1}],  false]
    - [empty_list, [[]], false]
    - [empty_dict, [{}], false]

# ---------------------------------------------------------------------------
# saferepr — returns safe string representations
# ---------------------------------------------------------------------------

table pprint.saferepr:
  description: "saferepr() returns safe string representation"
  kind: python_call_eq
  category: saferepr
  id_prefix: saferepr
  function: saferepr

  columns: [id, args, expected]
  rows:
    - [int,     [42],        "42"]
    - [str,     ["hello"],   "'hello'"]
    - [none,    [null],      "None"]
    - [bool_t,  [true],      "True"]
    - [float,   [3.14],      "3.14"]
    - [list,    [[1, 2, 3]], "[1, 2, 3]"]
    - [empty_list, [[]], "[]"]

# ---------------------------------------------------------------------------
# function types — pformat, isreadable, isrecursive, saferepr are functions
# ---------------------------------------------------------------------------

invariant pprint.types.pformat_is_function:
  description: "type(pprint.pformat).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: pformat.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pprint.types.isreadable_is_function:
  description: "type(pprint.isreadable).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: isreadable.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pprint.types.isrecursive_is_function:
  description: "type(pprint.isrecursive).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: isrecursive.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pprint.types.saferepr_is_function:
  description: "type(pprint.saferepr).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: saferepr.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter class — class name attribute
# ---------------------------------------------------------------------------

invariant pprint.PrettyPrinter.class_name:
  description: "pprint.PrettyPrinter.__name__ == 'PrettyPrinter'"
  category: classes
  kind: python_call_eq
  function: PrettyPrinter.__name__.__eq__
  args: ["PrettyPrinter"]
  expected: true
