spec: hashlib_extra39
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra38.zspec.zsdl — covers pbkdf2_hmac.__name__.__len__()==11; sha3_256/sha3_224/sha3_384/blake2b/blake2s hexdigest lengths via method_chain."
    - "hashlib_extra37.zspec.zsdl — covers blake2b/blake2s instance method __qualname__.__len__() for update/digest/hexdigest/copy."
    - "hashlib_extra36.zspec.zsdl — covers sha3_224/sha3_384 __name__.__len__()==16 and __module__.__len__()==8; shake_128/shake_256 __qualname__.__len__()==17."
    - "hashlib_extra34.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__len__()==5; hashlib.new.__class__.__name__.__len__()==8 ('function'); algorithms_available.__len__()==19; pbkdf2_hmac.__qualname__.__len__()==11; pbkdf2_hmac.__module__.__len__()==8."
    - "hashlib_extra33.zspec.zsdl — covers HASH method __qualname__.__len__(); sha3_512/shake_128/shake_256 __name__.__len__(); algorithms_guaranteed/__class__/__name__.__len__()==3."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__()."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends hashlib through hashlib_extra38; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: hashlib.new.__class__.__name__.__len__()==8 (extra34); pbkdf2_hmac.__name__.__len__()==11 (extra38); sha3_256/sha3_224/sha3_384/blake2b/blake2s hexdigest lengths (extra38); sha3_512.__name__.__len__()==16 (extra33); sha3_512.__qualname__.__len__()==16 (extra28)."
    - "This spec covers: sha3_512 hexdigest length (NOVEL — extra38 covers sha3_256/sha3_224/sha3_384/blake2b/blake2s hexdigest lengths via method_chain but NOT sha3_512; SHA3-512 produces 512-bit/64-byte digest, hex-encoded to 128 chars); hashlib.__class__.__name__.__len__() (NOVEL — hashlib is a module object; its metaclass is 'module'; extra34 covers new.__class__.__name__.__len__()==8 but not the module object's own __class__.__name__.__len__()==6; 'module' has 6 chars); sha256.__doc__.__class__.__name__.__len__() (NOVEL — sha256 is a C builtin_function_or_method; its __doc__ is a str; 'str' has 3 chars; no prior spec checks the class name length of sha256.__doc__); scrypt.__name__.__len__() (NOVEL — 'scrypt' has 6 chars; no prior spec checks scrypt at all; scrypt is available on macOS via OpenSSL)."
    - "sha3_512(b'').hexdigest().__len__() == 128. SHA3-512 produces a 512-bit (64-byte) digest; hex-encoding gives 128 chars. extra38 covers sha3_256(64)/sha3_224(56)/sha3_384(96)/blake2b(128)/blake2s(64) but does NOT include sha3_512. Expressed via sha3_512 constructor + method_chain matching extra38 style. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__class__.__name__ == 'module' (len 6). The hashlib module object's metaclass is the builtin 'module' type. extra34 covers hashlib.new.__class__.__name__.__len__()==8 (the wrapper function 'function') but not the module object itself. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str' (len 3). sha256 is a C-level builtin_function_or_method; its __doc__ attribute is a Python str. 'str' has 3 chars. No prior spec checks the __class__.__name__.__len__() of sha256.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__ == 'scrypt' (len 6). scrypt is an OpenSSL-backed password-based KDF available in hashlib on platforms with OpenSSL support. No prior hashlib spec checks scrypt at all. 'scrypt' has 6 chars. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_512 hexdigest length
#
# extra38 covers sha3_256/sha3_224/sha3_384/blake2b/blake2s hexdigest lengths.
# SHA3-512 produces a 512-bit (64-byte) digest; hex-encoding gives 128 chars.
# No prior spec checks sha3_512 hexdigest length.
# Expressed using the direct sha3_512 constructor + method_chain (matching
# the pattern in extra38 for sha3_256/sha3_224/sha3_384).
# ---------------------------------------------------------------------------

invariant hashlib_extra39.sha3_512.hexdigest_len:
  description: "hashlib.sha3_512(b'').hexdigest().__len__() == 128 — SHA3-512 produces 128-char hex; novel: extra38 covers sha3_256/224/384/blake2b/blake2s but NOT sha3_512"
  category: hexdigest_lengths
  kind: python_call_eq
  function: sha3_512
  args: [!b64 ""]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# hashlib module object __class__.__name__.__len__()
#
# The hashlib module is a Python module object; its metaclass is 'module'
# (len 6). extra34 covers hashlib.new.__class__.__name__.__len__()==8 for the
# 'function' type of the new() wrapper, but no prior spec checks the module
# object's own __class__.__name__.__len__(). The __len__() on __class__.__name__
# of the module object is a distinct axis not yet covered.
# ---------------------------------------------------------------------------

invariant hashlib_extra39.hashlib_module.class_name_len:
  description: "hashlib.__class__.__name__.__len__() == 6 — 'module' has 6 chars; novel: extra34 covers new.__class__.__name__.__len__==8 but not the module object's metaclass name length"
  category: module_metadata
  kind: python_call_eq
  function: __class__.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# sha256.__doc__.__class__.__name__.__len__()
#
# hashlib.sha256 is a C-level builtin_function_or_method. Its __doc__
# attribute is a Python str. The class name of a str object is 'str' (len 3).
# No prior hashlib spec checks the class name length of sha256.__doc__.
# This provides a novel cross-axis invariant: __doc__ attribute type name.
# ---------------------------------------------------------------------------

invariant hashlib_extra39.sha256_doc.class_name_len:
  description: "hashlib.sha256.__doc__.__class__.__name__.__len__() == 3 — sha256 docstring is a str; 'str' has 3 chars; novel: no prior spec checks __doc__.__class__.__name__.__len__() for any hashlib constructor"
  category: module_metadata
  kind: python_call_eq
  function: sha256.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# scrypt.__name__.__len__()
#
# hashlib.scrypt is an OpenSSL-backed password-based key derivation function.
# scrypt.__name__ == 'scrypt' (len 6).
# No prior hashlib spec checks scrypt in any capacity (no __name__, no
# __qualname__, no behavioral test). This is a completely novel invariant.
# ---------------------------------------------------------------------------

invariant hashlib_extra39.scrypt.name_len:
  description: "hashlib.scrypt.__name__.__len__() == 6 — 'scrypt' has 6 chars; novel: no prior hashlib spec covers scrypt; OpenSSL-backed KDF available on macOS"
  category: function_names
  kind: python_call_eq
  function: scrypt.__name__.__len__
  args: []
  expected: 6
