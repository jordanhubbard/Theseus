spec: urllib_parse_extra7
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl and prior extras through urllib_parse_extra6.zspec.zsdl."
    - "urllib_parse.zspec.zsdl covers: urlparse components, quoting table, urljoin, urlencode, parse_qs."
    - "urllib_parse_extra.zspec.zsdl covers: ParseResult/SplitResult __name__, __bases__, and __module__; urlparse/urlsplit/urljoin/urlencode function names."
    - "urllib_parse_extra2.zspec.zsdl covers: DefragResult __name__/base; urldefrag name; urlunparse/urlunsplit names; quote/unquote/quote_plus/unquote_plus __name__; parse_qs/parse_qsl __name__."
    - "urllib_parse_extra3.zspec.zsdl covers: ParseResult/SplitResult __name__; urlparse scheme/netloc/path; urlencode({'a': 1}) == 'a=1'; quote/unquote correctness vectors."
    - "urllib_parse_extra4.zspec.zsdl covers: ParseResult/SplitResult/DefragResult __qualname__; urldefrag qualname; urlparse/urlsplit/urljoin/urlencode/quote/unquote qualnames; quote/unquote value vectors."
    - "urllib_parse_extra5.zspec.zsdl covers: quote_plus/unquote_plus/parse_qs/parse_qsl qualnames; urlparse.__module__; urlencode({'key': 'val'}) == 'key=val'."
    - "urllib_parse_extra6.zspec.zsdl covers: ParseResult/SplitResult/DefragResult __module__; urlsplit/urljoin/urlencode/quote/unquote/urlunparse/urlunsplit __module__; urlparse query/fragment/empty_query."
    - "Focus: urlsplit behavioral checks (scheme/netloc/path/query/fragment/port fields — only urlparse components have been tested behaviorally); urldefrag behavioral output (url/fragment fields); quote_plus/unquote_plus/parse_qs/parse_qsl __module__ (extra5 adds qualnames but extra6 only covers some __module__s); parse_qsl behavioral output; urlencode with a list of pairs."
    - "urllib.parse.urlsplit('http://example.com:9000/p?q=1').scheme == 'http' — urlsplit behavioral not yet tested."
    - "urllib.parse.urldefrag('http://x.com/p#s').fragment == 's' — urldefrag behavioral not yet tested."
    - "urllib.parse.parse_qsl('a=1&b=2') == [('a','1'),('b','2')] — parse_qsl output not yet tested."
    - "urllib.parse.urlencode([('a','1'),('a','2')]) == 'a=1&a=2' — list-of-pairs form not yet tested."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — quote_plus, unquote_plus, parse_qs, parse_qsl, urldefrag
# urllib_parse_extra5 adds qualnames for these four but not __module__.
# urllib_parse_extra6 adds __module__ for urlsplit/urljoin/urlencode/quote/unquote/
# urlunparse/urlunsplit but NOT quote_plus/unquote_plus/parse_qs/parse_qsl/urldefrag.
# ---------------------------------------------------------------------------

table urllib_parse_extra7.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [quote_plus,   quote_plus.__module__.__eq__,   ["urllib.parse"], true]
    - [unquote_plus, unquote_plus.__module__.__eq__, ["urllib.parse"], true]
    - [parse_qs,     parse_qs.__module__.__eq__,     ["urllib.parse"], true]
    - [parse_qsl,    parse_qsl.__module__.__eq__,    ["urllib.parse"], true]
    - [urldefrag,    urldefrag.__module__.__eq__,    ["urllib.parse"], true]

# ---------------------------------------------------------------------------
# urlsplit behavioral — scheme, netloc, path, query, fragment, port
# urllib_parse.zspec.zsdl tests urlparse components in a table.
# urllib_parse_extra6 tests urlparse query/fragment/empty_query.
# urlsplit behavioral checks are entirely new.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra7.urlsplit.scheme:
  description: "urllib.parse.urlsplit('http://example.com:9000/p?q=1').scheme == 'http'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com:9000/p?q=1"]
  method: scheme.__eq__
  method_args: ["http"]
  expected: true

invariant urllib_parse_extra7.urlsplit.netloc:
  description: "urllib.parse.urlsplit('http://example.com:9000/p?q=1').netloc == 'example.com:9000'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com:9000/p?q=1"]
  method: netloc.__eq__
  method_args: ["example.com:9000"]
  expected: true

invariant urllib_parse_extra7.urlsplit.path:
  description: "urllib.parse.urlsplit('http://example.com:9000/p?q=1').path == '/p'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com:9000/p?q=1"]
  method: path.__eq__
  method_args: ["/p"]
  expected: true

invariant urllib_parse_extra7.urlsplit.query:
  description: "urllib.parse.urlsplit('http://example.com:9000/p?q=1').query == 'q=1'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com:9000/p?q=1"]
  method: query.__eq__
  method_args: ["q=1"]
  expected: true

# ---------------------------------------------------------------------------
# urldefrag behavioral — url and fragment fields
# urllib_parse_extra4 checks urldefrag.__qualname__.
# No prior spec tests urldefrag's behavioral output fields.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra7.urldefrag.url:
  description: "urllib.parse.urldefrag('http://example.com/page#section1').url == 'http://example.com/page'"
  category: urldefrag
  kind: python_call_eq
  function: urldefrag
  args: ["http://example.com/page#section1"]
  method: url.__eq__
  method_args: ["http://example.com/page"]
  expected: true

invariant urllib_parse_extra7.urldefrag.fragment:
  description: "urllib.parse.urldefrag('http://example.com/page#section1').fragment == 'section1'"
  category: urldefrag
  kind: python_call_eq
  function: urldefrag
  args: ["http://example.com/page#section1"]
  method: fragment.__eq__
  method_args: ["section1"]
  expected: true

# ---------------------------------------------------------------------------
# parse_qsl behavioral — returns list of (key, value) pairs
# urllib_parse.zspec.zsdl tests parse_qs (returns dict of lists).
# parse_qsl returns a list of tuples; no prior spec tests its output.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra7.parse_qsl.two_pairs:
  description: "urllib.parse.parse_qsl('a=1&b=2') == [('a', '1'), ('b', '2')]"
  category: parse_qsl
  kind: python_call_eq
  function: parse_qsl
  args: ["a=1&b=2"]
  expected: [["a", "1"], ["b", "2"]]

# ---------------------------------------------------------------------------
# urlencode with list-of-pairs — supports duplicate keys
# urllib_parse.zspec.zsdl tests urlencode({'a': '1', 'b': '2'}).
# urllib_parse_extra5 tests urlencode({'key': 'val'}).
# The list-of-pairs form (for duplicate keys) is a distinct input form.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra7.urlencode.list_of_pairs:
  description: "urllib.parse.urlencode([('a', '1'), ('a', '2')]) == 'a=1&a=2'"
  category: urlencode
  kind: python_call_eq
  function: urlencode
  args: [[["a", "1"], ["a", "2"]]]
  expected: "a=1&a=2"
