spec: concurrent_futures_extra2
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Extends concurrent_futures.zspec.zsdl and concurrent_futures_extra.zspec.zsdl."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in the thread sub-module."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in the process sub-module."
    - "Future.__module__ == 'concurrent.futures._base' — defined in the private _base sub-module."
    - "wait.__module__ == 'concurrent.futures._base' — top-level function from _base."
    - "as_completed.__module__ == 'concurrent.futures._base' — top-level function from _base."
    - "FIRST_COMPLETED == 'FIRST_COMPLETED' — string sentinel constant for use with wait()."
    - "FIRST_EXCEPTION == 'FIRST_EXCEPTION' — string sentinel constant for use with wait()."
    - "ALL_COMPLETED == 'ALL_COMPLETED' — string sentinel constant for use with wait()."
    - "Future.__bases__[0].__name__ == 'object' — Future inherits directly from object."
    - "ThreadPoolExecutor.submit.__name__ == 'submit' — method name verified via class attribute."
    - "All expected values verified by running Python 3.12 concurrent.futures on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor — name and module
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra2.ThreadPoolExecutor.name:
  description: "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra2.ThreadPoolExecutor.module:
  description: "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: class_modules
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessPoolExecutor — name and module
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra2.ProcessPoolExecutor.name:
  description: "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__name__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra2.ProcessPoolExecutor.module:
  description: "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"
  category: class_modules
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

# ---------------------------------------------------------------------------
# Future — name and module
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra2.Future.name:
  description: "concurrent.futures.Future.__name__ == 'Future'"
  category: class_names
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra2.Future.module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"
  category: class_modules
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra2.Future.base_class:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Future.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# wait — function name and module
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra2.wait.name:
  description: "concurrent.futures.wait.__name__ == 'wait'"
  category: function_names
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra2.wait.module:
  description: "concurrent.futures.wait.__module__ == 'concurrent.futures._base'"
  category: function_modules
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# as_completed — function name and module
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra2.as_completed.name:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed'"
  category: function_names
  kind: python_call_eq
  function: as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra2.as_completed.module:
  description: "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'"
  category: function_modules
  kind: python_call_eq
  function: as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# String sentinel constants — FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED
#
# These string constants are passed as the return_when argument to wait().
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra2.FIRST_COMPLETED.value:
  description: "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra2.FIRST_EXCEPTION.value:
  description: "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures_extra2.ALL_COMPLETED.value:
  description: "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

