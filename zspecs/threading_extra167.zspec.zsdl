error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Event class identity — __name__, __module__, __bases__
#
# Wave 295 theme: threading.Event Python class identity — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# threading.Event.__name__ == 'Event'
# threading.Event.__module__ == 'threading'
# threading.Event.__bases__[0].__name__ == 'object'
# threading.Event.__class__.__name__ == 'type'
#
# threading.Event is a simple synchronization primitive defined in
# Lib/threading.py. An event object manages an internal flag that can be set
# to True with set() or cleared with clear(). Threads can wait for the flag
# to become True using wait(). It is a Python class that inherits directly
# from object, so its metaclass __class__.__name__ is 'type'. New to extra167.
# ---------------------------------------------------------------------------

table threading_extra167.event_class_identity:
  description: "threading.Event: __name__ 'Event', __module__ 'threading', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 295; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: threadingeci167

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_event,
       "Event.__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — threading.Event is a Python class defined in Lib/threading.py implementing an event synchronization primitive (set/clear/wait/is_set); its class __name__ attribute is 'Event'; str.__eq__('Event') returns True; new to extra167"]
    - [event_module_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — threading.Event is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra167"]
    - ["event_bases_0_object",
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — threading.Event is a Python class that inherits directly from object; its __bases__ tuple has a single element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [event_class_name_type,
       "Event.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Event.__class__.__name__.__eq__('type') == True — threading.Event is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition class identity — __name__, __module__, __bases__
#
# Wave 295 theme: threading.Condition Python class identity — __name__,
# __module__, __bases__[0], and __class__.__name__.
#
# threading.Condition.__name__ == 'Condition'
# threading.Condition.__module__ == 'threading'
# threading.Condition.__bases__[0].__name__ == 'object'
# threading.Condition.__class__.__name__ == 'type'
#
# threading.Condition is a condition variable synchronization primitive defined
# in Lib/threading.py. It allows one or more threads to wait until they are
# notified by another thread. It wraps a lock (default: RLock) and provides
# wait(), notify(), notify_all() methods. It is a Python class that inherits
# directly from object. New to extra167.
# ---------------------------------------------------------------------------

table threading_extra167.condition_class_identity:
  description: "threading.Condition: __name__ 'Condition', __module__ 'threading', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 295; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcoci167

  columns: [id, function, args, expected, description]
  rows:
    - [condition_name_condition,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — threading.Condition is a Python class defined in Lib/threading.py implementing a condition variable (allows threads to wait for notification); its class __name__ attribute is 'Condition'; str.__eq__('Condition') returns True; new to extra167"]
    - [condition_module_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — threading.Condition is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra167"]
    - ["condition_bases_0_object",
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — threading.Condition is a Python class that inherits directly from object; its __bases__ tuple has a single element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [condition_class_name_type,
       "Condition.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Condition.__class__.__name__.__eq__('type') == True — threading.Condition is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore class identity — __name__, __module__, __bases__
#
# Wave 295 theme: threading.Semaphore Python class identity — __name__,
# __module__, __bases__[0], and __class__.__name__.
#
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Semaphore.__module__ == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.Semaphore.__class__.__name__ == 'type'
#
# threading.Semaphore is a counting semaphore synchronization primitive defined
# in Lib/threading.py. It maintains an internal counter initialized to a given
# value. acquire() decrements the counter (blocking if zero) and release()
# increments it. It is a Python class that inherits directly from object.
# New to extra167.
# ---------------------------------------------------------------------------

table threading_extra167.semaphore_class_identity:
  description: "threading.Semaphore: __name__ 'Semaphore', __module__ 'threading', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 295; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsci167

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_semaphore,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — threading.Semaphore is a Python class defined in Lib/threading.py implementing a counting semaphore (acquire/release with internal counter); its class __name__ attribute is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra167"]
    - [semaphore_module_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — threading.Semaphore is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra167"]
    - ["semaphore_bases_0_object",
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — threading.Semaphore is a Python class that inherits directly from object; its __bases__ tuple has a single element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [semaphore_class_name_type,
       "Semaphore.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Semaphore.__class__.__name__.__eq__('type') == True — threading.Semaphore is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — Event, Condition, Semaphore are all distinct classes
#
# Wave 295 theme: cross-checks between the three synchronization primitive
# classes to confirm their __name__ values are distinct and all share
# __module__ 'threading'.
#
# threading.Event.__name__ != 'Condition'
# threading.Condition.__name__ != 'Semaphore'
# threading.Semaphore.__name__ != 'Event'
# threading.Event.__qualname__ == 'Event'
#
# All three synchronization primitives are Python classes defined in
# Lib/threading.py with __module__ 'threading'. Their __name__ values are
# distinct: 'Event', 'Condition', 'Semaphore'. Each inherits from object.
# New to extra167.
# ---------------------------------------------------------------------------

table threading_extra167.event_condition_semaphore_cross_checks:
  description: "threading: Event.__name__ != 'Condition', Condition.__name__ != 'Semaphore', Semaphore.__name__ != 'Event', Event.__qualname__ 'Event'; wave 295; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: threadingecsc167

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_ne_condition,
       "Event.__name__.__eq__",
       ["Condition"],
       false,
       "threading.Event.__name__.__eq__('Condition') == False — Event.__name__ is 'Event', not 'Condition'; these are two distinct synchronization primitive classes in Lib/threading.py; str.__eq__('Condition') returns False; new to extra167"]
    - [condition_name_ne_semaphore,
       "Condition.__name__.__eq__",
       ["Semaphore"],
       false,
       "threading.Condition.__name__.__eq__('Semaphore') == False — Condition.__name__ is 'Condition', not 'Semaphore'; these are two distinct synchronization primitive classes in Lib/threading.py; str.__eq__('Semaphore') returns False; new to extra167"]
    - [semaphore_name_ne_event,
       "Semaphore.__name__.__eq__",
       ["Event"],
       false,
       "threading.Semaphore.__name__.__eq__('Event') == False — Semaphore.__name__ is 'Semaphore', not 'Event'; these are two distinct synchronization primitive classes in Lib/threading.py; str.__eq__('Event') returns False; new to extra167"]
    - [event_qualname_event,
       "Event.__qualname__.__eq__",
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — threading.Event is a top-level class in Lib/threading.py; its __qualname__ is 'Event' (same as __name__ for a top-level class); str.__eq__('Event') returns True; new to extra167"]

