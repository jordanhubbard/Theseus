spec: functools_extra520
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All functools callable docstrings are str type"
    - "WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are tuples"
    - "functools.reduce is a builtin_function_or_method (C implementation)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra520.doc_class_identity:
  description: "functools callable __doc__.__class__.__name__ == 'str' — all major functools callables have string docstrings"
  kind: python_call_eq
  category: doc_class
  id_prefix: ft520dc

  columns: [id, function, args, expected]
  rows:
    - [ft520dc001, reduce.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [ft520dc002, partial.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [ft520dc003, lru_cache.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [ft520dc004, singledispatch.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [ft520dc005, cached_property.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft520dc006, total_ordering.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [ft520dc007, wraps.__doc__.__class__.__name__.__eq__,           ["str"], true]
    - [ft520dc008, cmp_to_key.__doc__.__class__.__name__.__eq__,      ["str"], true]

table functools_extra520.wrapper_constants_class:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are tuple instances"
  kind: python_call_eq
  category: constants
  id_prefix: ft520wc

  columns: [id, function, args, expected]
  rows:
    - [ft520wc001, WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"], true]
    - [ft520wc002, WRAPPER_UPDATES.__class__.__name__.__eq__,     ["tuple"], true]

invariant functools_extra520.reduce_class_name:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin"
  category: class_identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
