spec: asyncio_extra537
version: ">=3.9"
backend: python_module(asyncio)
docs: "Asyncio coroutine and task function identity checks"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table asyncio_extra537.function_names:
  description: "Asyncio task function __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aioname
  columns: [id, function, args, expected]
  rows:
    - [aioname001, asyncio.create_task.__name__.__eq__, ["create_task"], true]
    - [aioname002, asyncio.ensure_future.__name__.__eq__, ["ensure_future"], true]
    - [aioname003, asyncio.gather.__name__.__eq__, ["gather"], true]
    - [aioname004, asyncio.shield.__name__.__eq__, ["shield"], true]
    - [aioname005, asyncio.wait.__name__.__eq__, ["wait"], true]
    - [aioname006, asyncio.wait_for.__name__.__eq__, ["wait_for"], true]
    - [aioname007, asyncio.sleep.__name__.__eq__, ["sleep"], true]

table asyncio_extra537.function_modules:
  description: "Asyncio task function __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aiomod
  columns: [id, function, args, expected]
  rows:
    - [aiomod001, asyncio.create_task.__module__.__eq__, ["asyncio.tasks"], true]
    - [aiomod002, asyncio.ensure_future.__module__.__eq__, ["asyncio.tasks"], true]
    - [aiomod003, asyncio.gather.__module__.__eq__, ["asyncio.tasks"], true]
    - [aiomod004, asyncio.shield.__module__.__eq__, ["asyncio.tasks"], true]
    - [aiomod005, asyncio.wait.__module__.__eq__, ["asyncio.tasks"], true]
    - [aiomod006, asyncio.wait_for.__module__.__eq__, ["asyncio.tasks"], true]
    - [aiomod007, asyncio.sleep.__module__.__eq__, ["asyncio.tasks"], true]
