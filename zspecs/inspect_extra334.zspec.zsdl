spec: inspect_extra334
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.currentframe.__name__ == 'currentframe' — C-level built-in."
    - "inspect.currentframe.__module__ == 'inspect' — exposed via the inspect module namespace."
    - "inspect.stack.__name__ == 'stack' — Python function defined in inspect."
    - "inspect.stack.__module__ == 'inspect'."
    - "inspect.getframeinfo.__name__ == 'getframeinfo' — Python function."
    - "inspect.getframeinfo.__module__ == 'inspect'."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' — named tuple class."
    - "inspect.FrameInfo._fields has 6 elements: frame, filename, lineno, function, code_context, index."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks for currentframe, stack, getframeinfo, FrameInfo
# ---------------------------------------------------------------------------

table inspect_extra334.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [currentframe,  currentframe.__name__.__eq__,  ["currentframe"],  true]
    - [stack,         stack.__name__.__eq__,         ["stack"],         true]
    - [getframeinfo,  getframeinfo.__name__.__eq__,  ["getframeinfo"],  true]
    - [FrameInfo,     FrameInfo.__name__.__eq__,     ["FrameInfo"],     true]

# ---------------------------------------------------------------------------
# __module__ checks — all belong to 'inspect'
# ---------------------------------------------------------------------------

table inspect_extra334.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [currentframe,  currentframe.__module__.__eq__,  ["inspect"], true]
    - [stack,         stack.__module__.__eq__,         ["inspect"], true]
    - [getframeinfo,  getframeinfo.__module__.__eq__,  ["inspect"], true]

# ---------------------------------------------------------------------------
# FrameInfo — _fields length
#
# On Python 3.14: _fields == ('frame', 'filename', 'lineno', 'function',
#                              'code_context', 'index') → length 6
# ---------------------------------------------------------------------------

invariant inspect_extra334.FrameInfo.fields_length:
  description: "inspect.FrameInfo._fields has 6 elements: frame, filename, lineno, function, code_context, index"
  category: FrameInfo
  kind: python_call_eq
  function: FrameInfo._fields.__len__
  args: []
  expected: 6
