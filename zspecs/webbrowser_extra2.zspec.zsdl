spec: webbrowser_extra2
version: ">=3.9"
backend: python_module(webbrowser)

docs: https://docs.python.org/3/library/webbrowser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/webbrowser.html — Python webbrowser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/webbrowser.py"
  notes:
    - "This spec covers invariants not in webbrowser.zspec.zsdl or webbrowser_extra.zspec.zsdl."
    - "BaseBrowser.__name__ == 'BaseBrowser' — the abstract base class for all browser controllers."
    - "GenericBrowser.__name__ == 'GenericBrowser' — wraps a named system command; subclass of BaseBrowser."
    - "BackgroundBrowser.__name__ == 'BackgroundBrowser' — launches the browser in the background; subclass of GenericBrowser."
    - "BaseBrowser.__module__ == 'webbrowser' — all three classes are defined in the webbrowser module."
    - "_tryorder.__class__.__name__ == 'list' — the module-level browser preference order list."
    - "_browsers.__class__.__name__ == 'dict' — the module-level registry mapping names to browser classes/instances."
    - "GenericBrowser.__module__ == 'webbrowser' and BackgroundBrowser.__module__ == 'webbrowser'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseBrowser — __name__ and __module__
# ---------------------------------------------------------------------------

invariant webbrowser_extra2.BaseBrowser.name:
  description: "BaseBrowser.__name__ == 'BaseBrowser'"
  category: classes
  kind: python_call_eq
  function: BaseBrowser.__name__.__eq__
  args: ["BaseBrowser"]
  expected: true

invariant webbrowser_extra2.BaseBrowser.module:
  description: "BaseBrowser.__module__ == 'webbrowser'"
  category: module
  kind: python_call_eq
  function: BaseBrowser.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# GenericBrowser — __name__ and __module__
# ---------------------------------------------------------------------------

invariant webbrowser_extra2.GenericBrowser.name:
  description: "GenericBrowser.__name__ == 'GenericBrowser'"
  category: classes
  kind: python_call_eq
  function: GenericBrowser.__name__.__eq__
  args: ["GenericBrowser"]
  expected: true

invariant webbrowser_extra2.GenericBrowser.module:
  description: "GenericBrowser.__module__ == 'webbrowser'"
  category: module
  kind: python_call_eq
  function: GenericBrowser.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# BackgroundBrowser — __name__ and __module__
# ---------------------------------------------------------------------------

invariant webbrowser_extra2.BackgroundBrowser.name:
  description: "BackgroundBrowser.__name__ == 'BackgroundBrowser'"
  category: classes
  kind: python_call_eq
  function: BackgroundBrowser.__name__.__eq__
  args: ["BackgroundBrowser"]
  expected: true

invariant webbrowser_extra2.BackgroundBrowser.module:
  description: "BackgroundBrowser.__module__ == 'webbrowser'"
  category: module
  kind: python_call_eq
  function: BackgroundBrowser.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# Class type identity — all three classes are plain Python types
# ---------------------------------------------------------------------------

table webbrowser_extra2.classes.type_identity:
  kind: python_call_eq
  category: class_types
  id_prefix: is_type

  columns: [id, function, args, expected]
  rows:
    - [BaseBrowser,       BaseBrowser.__class__.__name__.__eq__,       ["type"], true]
    - [GenericBrowser,    GenericBrowser.__class__.__name__.__eq__,    ["type"], true]
    - [BackgroundBrowser, BackgroundBrowser.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# _tryorder — module-level list of browser preference order
# ---------------------------------------------------------------------------

invariant webbrowser_extra2._tryorder.is_list:
  description: "_tryorder.__class__.__name__ == 'list' — browser preference order is a plain list"
  category: internals
  kind: python_call_eq
  function: _tryorder.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# _browsers — module-level dict of registered browser names/instances
# ---------------------------------------------------------------------------

invariant webbrowser_extra2._browsers.is_dict:
  description: "_browsers.__class__.__name__ == 'dict' — browser registry is a plain dict"
  category: internals
  kind: python_call_eq
  function: _browsers.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for browser classes
# ---------------------------------------------------------------------------

table webbrowser_extra2.classes.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [BaseBrowser,       BaseBrowser.__qualname__.__eq__,       ["BaseBrowser"],       true]
    - [GenericBrowser,    GenericBrowser.__qualname__.__eq__,    ["GenericBrowser"],    true]
    - [BackgroundBrowser, BackgroundBrowser.__qualname__.__eq__, ["BackgroundBrowser"], true]
