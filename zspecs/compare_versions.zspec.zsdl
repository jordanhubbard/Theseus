spec: compare_versions
version: ">=6.0.0"
backend: node(compare-versions)

docs: https://github.com/nicktindall/cycjimmy-compare-versions#readme

provenance:
  derived_from:
    - "compare-versions README — https://github.com/nicktindall/cycjimmy-compare-versions#readme"
    - "Test vectors verified with compare-versions@6.1.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compare-versions source: src/index.js"
  notes:
    - "compare-versions exports { compare, satisfies, compareVersions } as named exports."
    - "compare(v1, v2, op) returns boolean: true if v1 op v2 (e.g. v1 < v2)."
    - "satisfies(v, range) returns boolean: true if v satisfies the version range."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean. No errors for valid version strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compare_versions.compare:
  kind: node_module_call_eq
  function: compare
  category: compare
  id_prefix: cv_cmp

  columns: [id, args, expected]
  rows:
    - [less_than,    ["1.2.3", "1.2.4", "<"],  true]
    - [greater_than, ["2.0.0", "1.0.0", ">"],  true]
    - [equal,        ["1.0.0", "1.0.0", "="],  true]
    - [not_less,     ["1.2.4", "1.2.3", "<"],  false]

table compare_versions.satisfies:
  kind: node_module_call_eq
  function: satisfies
  category: satisfies
  id_prefix: cv_sat

  columns: [id, args, expected]
  rows:
    - [gte_pass,  ["1.2.3", ">=1.0.0"],  true]
    - [gte_fail,  ["0.9.0", ">=1.0.0"],  false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:35:03Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
