spec: abc_extra50
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra49.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42 — all six covered)."
    - "This spec covers: abc class __init__.__class__.__name__ — no prior abc spec captured any __init__.__class__ attribute. abstractproperty/abstractclassmethod/abstractstaticmethod.__init__ are wrapper_descriptor objects (C slots from property/classmethod/staticmethod parents); ABC.__init__ is also a wrapper_descriptor (object slot); abstractmethod.__init__ is a method-wrapper (C-level). All of these have __class__.__module__ == 'builtins'. Novel dimension: __init__.__class__.__name__ for abc exports. Also: __class__.__module__.__len__()==8 cross-checks for abstractproperty/ABCMeta/abstractmethod — 'builtins' has 8 characters; ABC/__class__.__module__.__len__()==3 — 'abc' has 3 characters. These __len__() cross-checks complement the string equality checks from extra42."
    - "abc.abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'. abstractproperty is a subclass of the built-in property type. Property's __init__ is a C slot wrapper (wrapper_descriptor). Therefore abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'. The 'wrapper_descriptor' type is defined in the builtins module. No prior abc spec has captured any __init__.__class__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__init__.__class__.__name__ == 'method-wrapper'. abstractmethod is a plain Python function. A function's __init__ is a C-level method-wrapper (the slot wrapper for __init__ of the function type). Therefore abstractmethod.__init__.__class__.__name__ == 'method-wrapper'. The 'method-wrapper' type is defined in the builtins module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__class__.__module__.__len__() == 8. Prior extra42 captured abstractproperty.__class__.__module__ == 'builtins' (the string equality). Extra50 captures the complementary __len__()==8 cross-check — 'builtins' has 8 characters: b-u-i-l-t-i-n-s = 8. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__class__.__module__.__len__() == 8. Prior extra42 captured ABCMeta.__class__.__module__ == 'builtins'. Extra50 captures the complementary __len__()==8 cross-check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__class__.__module__.__len__() == 8. Prior extra42 captured abstractmethod.__class__.__module__ == 'builtins'. Extra50 captures the complementary __len__()==8 cross-check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__class__.__module__.__len__() == 3. Prior extra42 captured ABC.__class__.__module__ == 'abc'. Extra50 captures the complementary __len__()==3 cross-check — 'abc' has 3 characters: a-b-c = 3. ABC is the only abc export whose __class__.__module__ is not 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc object __init__.__class__.__name__ string equality — extra50
#
# No prior abc spec has captured any __init__.__class__ attribute.
# The __init__ method type depends on whether the class is pure Python
# or C-implemented:
#
#   abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'
#     (inherits property.__init__, which is a C slot)
#   abstractmethod.__init__.__class__.__name__   == 'method-wrapper'
#     (abstractmethod is a function; function.__init__ is a C method-wrapper)
#
# Both 'wrapper_descriptor' and 'method-wrapper' are built-in types from
# the builtins module. Extra50 introduces the __init__.__class__.__name__
# dimension for abc exports in the abcmod50 namespace.
# ---------------------------------------------------------------------------

table abc_extra50.init_class_name_eq:
  description: "abc object __init__.__class__.__name__ string equality in abcmod50 namespace — no prior abc spec captured any __init__.__class__ attribute; abstractproperty uses wrapper_descriptor (C slot from property); abstractmethod uses method-wrapper (C slot from function type)"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmod50initclsname

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty, abstractproperty.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor' — abstractproperty subclasses property; property.__init__ is a C slot; __class__.__name__ == 'wrapper_descriptor'; first __init__.__class__.__name__ check in any abc spec"]
    - [abstractmethod,   abstractmethod.__init__.__class__.__name__.__eq__,   ["method-wrapper"],    true, "abstractmethod.__init__.__class__.__name__ == 'method-wrapper' — abstractmethod is a function object; function.__init__ is a C-level method-wrapper; __class__.__name__ == 'method-wrapper'"]

# ---------------------------------------------------------------------------
# abc object __class__.__module__.__len__() cross-checks — extra50
#
# Prior extra42 captured the full string equality for all abc exports:
#   abstractproperty.__class__.__module__ == 'builtins'  (8 chars)
#   ABCMeta.__class__.__module__          == 'builtins'  (8 chars)
#   abstractmethod.__class__.__module__   == 'builtins'  (8 chars)
#   ABC.__class__.__module__              == 'abc'        (3 chars)
#
# Extra50 captures the complementary __len__() cross-checks in the
# abcmod50 namespace:
#   abstractproperty.__class__.__module__.__len__() == 8
#   ABCMeta.__class__.__module__.__len__()          == 8
#   abstractmethod.__class__.__module__.__len__()   == 8
#   ABC.__class__.__module__.__len__()              == 3  (unique: 'abc' not 'builtins')
# ---------------------------------------------------------------------------

table abc_extra50.class_module_len:
  description: "abc object __class__.__module__.__len__() cross-check in abcmod50 namespace — 'builtins'==8 for most abc exports; ABC.__class__.__module__=='abc' (3 chars) is unique; complements string equality from extra42"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmod50clsmodulelen

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty, abstractproperty.__class__.__module__.__len__, [], 8, "abstractproperty.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters; cross-check for abstractproperty.__class__.__module__=='builtins' from extra42"]
    - [ABCMeta,          ABCMeta.__class__.__module__.__len__,          [], 8, "ABCMeta.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters; cross-check for ABCMeta.__class__.__module__=='builtins' from extra42"]
    - [abstractmethod,   abstractmethod.__class__.__module__.__len__,   [], 8, "abstractmethod.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters; cross-check for abstractmethod.__class__.__module__=='builtins' from extra42"]
    - [ABC,              ABC.__class__.__module__.__len__,              [], 3, "ABC.__class__.__module__.__len__() == 3 — 'abc' has 3 characters: a-b-c; ABC is the only abc export whose __class__.__module__ is 'abc' (not 'builtins'); cross-check for ABC.__class__.__module__=='abc' from extra42"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra50
# ---------------------------------------------------------------------------

invariant abc_extra50.abstractproperty_init_class_name_eq:
  description: "abc.abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor' — abstractproperty subclasses property; property.__init__ is a C slot wrapper; the 'wrapper_descriptor' type is a built-in type; first __init__.__class__.__name__ check in any abc spec"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra50.abstractmethod_init_class_name_eq:
  description: "abc.abstractmethod.__init__.__class__.__name__ == 'method-wrapper' — abstractmethod is a function object; function.__init__ is a C-level method-wrapper; the 'method-wrapper' type is a built-in type from builtins"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__init__.__class__.__name__.__eq__
  args: ["method-wrapper"]
  expected: true

invariant abc_extra50.abstractproperty_class_module_len:
  description: "abc.abstractproperty.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters; cross-check for abstractproperty.__class__.__module__=='builtins' from extra42; ABCMeta (the metaclass of abstractproperty's metaclass) is 'type' from builtins"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__class__.__module__.__len__
  args: []
  expected: 8

invariant abc_extra50.ABC_class_module_len:
  description: "abc.ABC.__class__.__module__.__len__() == 3 — 'abc' has 3 characters: a-b-c; ABC is the only abc export whose __class__ (ABCMeta) is defined in the abc module rather than builtins; cross-check for ABC.__class__.__module__=='abc' from extra42"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__module__.__len__
  args: []
  expected: 3
