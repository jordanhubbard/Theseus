spec: unicodedata_extra20
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra19.zspec.zsdl."
    - "unicodedata_extra16 covers: module-level lookup/name/decimal/digit/numeric/category/normalize/bidirectional __qualname__ attributes (all flat, e.g. 'decimal')."
    - "unicodedata_extra17 covers: combining/east_asian_width/mirrored/decomposition/is_normalized __qualname__ attributes."
    - "unicodedata_extra19 covers: ucd_3_2_0.__class__.__module__; ucd_3_2_0 method qualnames for lookup/name/category/normalize/bidirectional/combining."
    - "No prior spec verifies unicodedata.lookup.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.name.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.category.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.normalize.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.decimal.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.digit.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.numeric.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.east_asian_width.__module__ as a standalone invariant."
    - "No prior spec verifies unicodedata.is_normalized.__module__ as a standalone invariant."
    - "No prior spec verifies ucd_3_2_0.decimal/__qualname__, ucd_3_2_0.digit/__qualname__, ucd_3_2_0.numeric/__qualname__, ucd_3_2_0.east_asian_width/__qualname__, or ucd_3_2_0.is_normalized/__qualname__ as standalone invariants."
    - "All module-level unicodedata functions are C builtins whose __module__ == 'unicodedata'. Verified at runtime."
    - "unicodedata.decimal.__qualname__ == 'decimal' — flat qualname as a module-level builtin. Verified at runtime."
    - "unicodedata.digit.__qualname__ == 'digit' — flat qualname as a module-level builtin. Verified at runtime."
    - "unicodedata.numeric.__qualname__ == 'numeric' — flat qualname as a module-level builtin. Verified at runtime."
    - "unicodedata.east_asian_width.__qualname__ == 'east_asian_width' — flat qualname as a module-level builtin. Verified at runtime."
    - "unicodedata.is_normalized.__qualname__ == 'is_normalized' — flat qualname as a module-level builtin. Verified at runtime."
    - "unicodedata.ucd_3_2_0.decimal.__qualname__ == 'UCD.decimal' — UCD bound method qualname includes class prefix. Verified at runtime."
    - "unicodedata.ucd_3_2_0.digit.__qualname__ == 'UCD.digit' — UCD bound method qualname includes class prefix. Verified at runtime."
    - "unicodedata.ucd_3_2_0.numeric.__qualname__ == 'UCD.numeric' — UCD bound method qualname includes class prefix. Verified at runtime."
    - "unicodedata.ucd_3_2_0.east_asian_width.__qualname__ == 'UCD.east_asian_width' — UCD bound method qualname includes class prefix. Verified at runtime."
    - "unicodedata.ucd_3_2_0.is_normalized.__qualname__ == 'UCD.is_normalized' — UCD bound method qualname includes class prefix. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __module__ attributes
#
# unicodedata_extra16/17 cover __qualname__ for all module-level functions.
# No prior spec verifies __module__ for any of these functions as standalone
# invariants. All module-level unicodedata functions are C builtins defined
# in the unicodedata extension; their __module__ == 'unicodedata'.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra20.lookup.module:
  description: "unicodedata.lookup.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: lookup.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.name.module:
  description: "unicodedata.name.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: name.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.category.module:
  description: "unicodedata.category.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: category.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.normalize.module:
  description: "unicodedata.normalize.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: normalize.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.decimal.module:
  description: "unicodedata.decimal.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: decimal.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.digit.module:
  description: "unicodedata.digit.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: digit.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.numeric.module:
  description: "unicodedata.numeric.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: numeric.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.east_asian_width.module:
  description: "unicodedata.east_asian_width.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: east_asian_width.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra20.is_normalized.module:
  description: "unicodedata.is_normalized.__module__ == 'unicodedata' — module-level C builtin defined in unicodedata"
  category: function_identity
  kind: python_call_eq
  function: is_normalized.__module__.__eq__
  args: ["unicodedata"]
  expected: true

# ---------------------------------------------------------------------------
# ucd_3_2_0 additional method __qualname__ attributes
#
# unicodedata_extra19 covers ucd_3_2_0 method qualnames for
# lookup/name/category/normalize/bidirectional/combining.
# No prior spec verifies ucd_3_2_0.decimal, .digit, .numeric,
# .east_asian_width, or .is_normalized __qualname__ as standalone invariants.
# All carry the 'UCD.' prefix. Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra20.ucd_3_2_0.decimal_qualname:
  description: "unicodedata.ucd_3_2_0.decimal.__qualname__ == 'UCD.decimal' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.decimal.__qualname__.__eq__
  args: ["UCD.decimal"]
  expected: true

invariant unicodedata_extra20.ucd_3_2_0.digit_qualname:
  description: "unicodedata.ucd_3_2_0.digit.__qualname__ == 'UCD.digit' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.digit.__qualname__.__eq__
  args: ["UCD.digit"]
  expected: true

invariant unicodedata_extra20.ucd_3_2_0.numeric_qualname:
  description: "unicodedata.ucd_3_2_0.numeric.__qualname__ == 'UCD.numeric' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.numeric.__qualname__.__eq__
  args: ["UCD.numeric"]
  expected: true

invariant unicodedata_extra20.ucd_3_2_0.east_asian_width_qualname:
  description: "unicodedata.ucd_3_2_0.east_asian_width.__qualname__ == 'UCD.east_asian_width' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.east_asian_width.__qualname__.__eq__
  args: ["UCD.east_asian_width"]
  expected: true

invariant unicodedata_extra20.ucd_3_2_0.is_normalized_qualname:
  description: "unicodedata.ucd_3_2_0.is_normalized.__qualname__ == 'UCD.is_normalized' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.is_normalized.__qualname__.__eq__
  args: ["UCD.is_normalized"]
  expected: true

# ---------------------------------------------------------------------------
# Table: module-level function __module__ attributes
#
# Groups all nine __module__ checks in one indexed table.
# No prior table covers __module__ for any unicodedata module-level function.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra20.module_level_function_modules:
  description: "unicodedata module-level function __module__ attributes — all equal 'unicodedata'"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud20lfm

  columns: [id, function, args, expected]
  rows:
    - [lookup,           lookup.__module__.__eq__,           ["unicodedata"], true]
    - [name,             name.__module__.__eq__,             ["unicodedata"], true]
    - [category,         category.__module__.__eq__,         ["unicodedata"], true]
    - [normalize,        normalize.__module__.__eq__,        ["unicodedata"], true]
    - [decimal,          decimal.__module__.__eq__,          ["unicodedata"], true]
    - [digit,            digit.__module__.__eq__,            ["unicodedata"], true]
    - [numeric,          numeric.__module__.__eq__,          ["unicodedata"], true]
    - [east_asian_width, east_asian_width.__module__.__eq__, ["unicodedata"], true]
    - [is_normalized,    is_normalized.__module__.__eq__,    ["unicodedata"], true]

# ---------------------------------------------------------------------------
# Table: ucd_3_2_0 additional method __qualname__ attributes
#
# Groups decimal, digit, numeric, east_asian_width, and is_normalized
# ucd_3_2_0 method qualname checks in one indexed table.
# unicodedata_extra19 covered lookup/name/category/normalize/bidirectional/combining;
# no prior table covers these five additional UCD methods.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra20.ucd_3_2_0_additional_method_qualnames:
  description: "unicodedata.ucd_3_2_0 additional UCD bound-method __qualname__ attributes — decimal, digit, numeric, east_asian_width, is_normalized"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud20amq

  columns: [id, function, args, expected]
  rows:
    - [decimal,          ucd_3_2_0.decimal.__qualname__.__eq__,          ["UCD.decimal"],          true]
    - [digit,            ucd_3_2_0.digit.__qualname__.__eq__,            ["UCD.digit"],            true]
    - [numeric,          ucd_3_2_0.numeric.__qualname__.__eq__,          ["UCD.numeric"],          true]
    - [east_asian_width, ucd_3_2_0.east_asian_width.__qualname__.__eq__, ["UCD.east_asian_width"], true]
    - [is_normalized,    ucd_3_2_0.is_normalized.__qualname__.__eq__,    ["UCD.is_normalized"],    true]
