spec: inspect_extra1021
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect predicate functions __module__ == 'inspect' for all major predicate helpers"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1021.predicate_modules_a:
  description: "inspect predicate functions __module__ identity (set A)"
  kind: python_call_eq
  category: predicate_modules
  id_prefix: ip1021pa
  columns: [id, function, args, expected]
  rows:
    - [ip1021pa001, inspect.isframe.__module__.__eq__,            ["inspect"], true]
    - [ip1021pa002, inspect.iscode.__module__.__eq__,             ["inspect"], true]
    - [ip1021pa003, inspect.isbuiltin.__module__.__eq__,          ["inspect"], true]
    - [ip1021pa004, inspect.ismethodwrapper.__module__.__eq__,    ["inspect"], true]
    - [ip1021pa005, inspect.isroutine.__module__.__eq__,          ["inspect"], true]
    - [ip1021pa006, inspect.isabstract.__module__.__eq__,         ["inspect"], true]
    - [ip1021pa007, inspect.ismethoddescriptor.__module__.__eq__, ["inspect"], true]

table inspect_extra1021.predicate_modules_b:
  description: "inspect predicate functions __module__ identity (set B)"
  kind: python_call_eq
  category: predicate_modules
  id_prefix: ip1021pb
  columns: [id, function, args, expected]
  rows:
    - [ip1021pb001, inspect.isdatadescriptor.__module__.__eq__,   ["inspect"], true]
    - [ip1021pb002, inspect.isgetsetdescriptor.__module__.__eq__,  ["inspect"], true]
    - [ip1021pb003, inspect.ismemberdescriptor.__module__.__eq__,  ["inspect"], true]
    - [ip1021pb004, inspect.isfunction.__module__.__eq__,          ["inspect"], true]
    - [ip1021pb005, inspect.ismethod.__module__.__eq__,            ["inspect"], true]
    - [ip1021pb006, inspect.isclass.__module__.__eq__,             ["inspect"], true]
    - [ip1021pb007, inspect.ismodule.__module__.__eq__,            ["inspect"], true]

table inspect_extra1021.predicate_qualnames:
  description: "inspect predicate functions __qualname__ identity"
  kind: python_call_eq
  category: predicate_qualnames
  id_prefix: ip1021pq
  columns: [id, function, args, expected]
  rows:
    - [ip1021pq001, inspect.isframe.__qualname__.__eq__,            ["isframe"],            true]
    - [ip1021pq002, inspect.iscode.__qualname__.__eq__,             ["iscode"],             true]
    - [ip1021pq003, inspect.isbuiltin.__qualname__.__eq__,          ["isbuiltin"],          true]
    - [ip1021pq004, inspect.ismethodwrapper.__qualname__.__eq__,    ["ismethodwrapper"],    true]
    - [ip1021pq005, inspect.isroutine.__qualname__.__eq__,          ["isroutine"],          true]
    - [ip1021pq006, inspect.isabstract.__qualname__.__eq__,         ["isabstract"],         true]
    - [ip1021pq007, inspect.ismethoddescriptor.__qualname__.__eq__, ["ismethoddescriptor"], true]
    - [ip1021pq008, inspect.isdatadescriptor.__qualname__.__eq__,   ["isdatadescriptor"],   true]
