spec: it2866
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (it2866): __rand__, __ror__, __rxor__ dict-presence checks for itertools types."
    - "itertools classes are iterator/combinator types — none define reflected bitwise AND, OR, or XOR operators."
    - "Verified types: chain, cycle, count, islice, product, permutations, combinations, groupby, starmap, zip_longest, takewhile, dropwhile, filterfalse, compress, accumulate, repeat, combinations_with_replacement, pairwise."
    - "All values verified as False with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table it2866.rand:
  description: "itertools types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2866
  columns: [id, function, args, expected]
  rows:
