    - [cache_module_eq_functools,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is a pure-Python function defined in Lib/functools.py; its __module__ attribute records 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks cache.__module__ via functoolsextra87; new to extra87"]
    - [cache_code_co_name_eq_cache,
