table functools_extra87.cmp_to_key_name_and_cache_qualname:
  description: "cmp_to_key.__name__ len==10; cache.__qualname__ len==5; cache.__module__=='functools'; cache.__code__.co_name=='cache'; wave 246 C-builtin and cache attrs; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra87

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_name_len_eq_10,
       "cmp_to_key.__name__.__len__",
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — cmp_to_key is a C builtin function; its __name__ attribute is the string 'cmp_to_key' (10 chars: 'c','m','p','_','t','o','_','k','e','y'); str.__len__() returns 10; no prior functools spec checks cmp_to_key.__name__.__len__() via functoolsextra87; new to extra87"]
    - [cache_qualname_len_eq_5,
