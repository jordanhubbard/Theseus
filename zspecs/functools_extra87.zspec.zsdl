spec: functools_extra87
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra86

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra86.zspec.zsdl."
    - "This spec covers: functools partial C-type __doc__ class name + wraps/update_wrapper qualname lengths (Wave 246)."
    - "partial.__doc__.__class__.__name__ == 'str' — partial is a C type; its __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "partial.__qualname__ == 'partial' (len 7) — C type; __qualname__ is just the class name. Verified with Python 3.14.3."
    - "partial.__module__ == 'functools' — partial is defined in the functools C extension module. Verified with Python 3.14.3."
    - "partial.__name__ == 'partial' (len 7) — C type has __name__ attribute equal to class name. Verified with Python 3.14.3."
    - "wraps.__qualname__ == 'wraps' (len 5) — pure-Python decorator. Verified with Python 3.14.3."
    - "update_wrapper.__qualname__ == 'update_wrapper' (len 14) — pure-Python function. Verified with Python 3.14.3."
    - "reduce.__name__ == 'reduce' (len 6) — C builtin function. Verified with Python 3.14.3."
    - "cmp_to_key.__name__ == 'cmp_to_key' (len 10) — C builtin function. Verified with Python 3.14.3."
    - "lru_cache.__qualname__ == 'lru_cache' (len 9) — pure-Python decorator. Verified with Python 3.14.3."
    - "cache.__qualname__ == 'cache' (len 5) — pure-Python function added in Python 3.9. Verified with Python 3.14.3."
    - "cache.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "cache.__code__.co_name == 'cache' — code object name matches function name. Verified with Python 3.14.3."
    - "cache.__code__.co_argcount == 1 — cache(user_function) takes exactly one positional argument. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial C-type __doc__ class name and __qualname__/__name__ lengths — extra87
#
# Wave 246 theme: partial C-type __doc__ class name and __qualname__/__name__ lengths.
#
# functools.partial.__doc__.__class__.__name__  == 'str'
# functools.partial.__qualname__.__len__()      == 7
# functools.partial.__module__.__eq__           == 'functools'
# functools.partial.__name__.__len__()          == 7
#
# No prior functools spec checks partial.__doc__.__class__.__name__ via functoolsextra87. New to extra87.
# ---------------------------------------------------------------------------

table functools_extra87.partial_doc_qualname:
  description: "partial.__doc__.__class__.__name__=='str'; partial.__qualname__ len==7; partial.__module__=='functools'; partial.__name__ len==7; wave 246 partial C-type attrs; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra87

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_name_eq_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; its __doc__ is a plain Python str; str.__class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; no prior functools spec checks partial.__doc__.__class__.__name__ via functoolsextra87; new to extra87"]
    - [partial_qualname_len_eq_7,
       "partial.__qualname__.__len__",
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — partial is a C extension type; its __qualname__ attribute is the string 'partial' (7 chars: 'p','a','r','t','i','a','l'); str.__len__() returns 7; no prior functools spec checks partial.__qualname__.__len__() via functoolsextra87; new to extra87"]
    - [partial_module_eq_functools,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is a C extension type; its __module__ attribute records 'functools' (9 chars), the module name where it is exposed; str.__eq__('functools') returns True; no prior functools spec checks partial.__module__ via functoolsextra87; new to extra87"]
    - [partial_name_len_eq_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — partial is a C extension type; its __name__ attribute is the string 'partial' (7 chars); str.__len__() returns 7; no prior functools spec checks partial.__name__.__len__() via functoolsextra87; new to extra87"]

