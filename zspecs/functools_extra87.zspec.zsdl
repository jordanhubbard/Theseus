table functools_extra87.cache_argcount_and_qualname_eq:
  description: "cache.__code__.co_argcount==1; partial.__qualname__.__eq__('partial')==True; wraps.__qualname__.__eq__('wraps')==True; update_wrapper.__qualname__.__eq__('update_wrapper')==True; wave 246; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra87

  columns: [id, function, args, expected, description]
  rows:
    - [cache_code_co_argcount_eq_1,
       cache.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — cache(user_function) is a pure-Python function in Lib/functools.py that takes exactly one positional argument: user_function; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior functools spec checks cache.__code__.co_argcount via functoolsextra87; new to extra87"]
    - [partial_qualname_eq_partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a C extension type; its __qualname__ attribute is the string 'partial' (7 chars); str.__eq__('partial') returns True; no prior functools spec checks partial.__qualname__.__eq__ via functoolsextra87; new to extra87"]
    - [wraps_qualname_eq_wraps,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a pure-Python decorator in Lib/functools.py; its __qualname__ attribute is the string 'wraps' (5 chars); str.__eq__('wraps') returns True; no prior functools spec checks wraps.__qualname__.__eq__ via functoolsextra87; new to extra87"]
    - [update_wrapper_qualname_eq_update_wrapper,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function in Lib/functools.py; its __qualname__ attribute is the string 'update_wrapper' (14 chars); str.__eq__('update_wrapper') returns True; no prior functools spec checks update_wrapper.__qualname__.__eq__ via functoolsextra87; new to extra87"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra87
# ---------------------------------------------------------------------------

invariant functools_extra87.partial_doc_class_name:
  description: "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial C-type __doc__ is a str; wave 246 partial C-type __doc__ class name; new to extra87"
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra87.partial_qualname_len:
  description: "functools.partial.__qualname__.__len__() == 7 — partial.__qualname__ is 'partial' (7 chars); wave 246 partial C-type __qualname__ length; new to extra87"
  kind: python_call_eq
  function: "partial.__qualname__.__len__"
  args: []
  expected: 7

invariant functools_extra87.wraps_qualname_len:
  description: "functools.wraps.__qualname__.__len__() == 5 — wraps.__qualname__ is 'wraps' (5 chars); wave 246 pure-Python decorator __qualname__ length; new to extra87"
  kind: python_call_eq
  function: "wraps.__qualname__.__len__"
  args: []
  expected: 5

invariant functools_extra87.cache_module:
  description: "functools.cache.__module__.__eq__('functools') == True — cache is defined in Lib/functools.py; wave 246 cache module; new to extra87"
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra87.cache_code_co_argcount:
  description: "functools.cache.__code__.co_argcount.__eq__(1) == True — cache(user_function) has 1 positional arg; wave 246 cache code argcount; new to extra87"
  kind: python_call_eq
  function: cache.__code__.co_argcount.__eq__
  args: [1]
  expected: true
