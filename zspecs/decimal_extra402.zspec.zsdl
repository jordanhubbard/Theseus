spec: decimal_extra402
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.localcontext.__name__ == 'localcontext' and __module__ == '_decimal' (the C accelerator module)"
    - "decimal.Decimal methods compare, to_integral_value, to_integral_exact, normalize, quantize each report __name__ matching their Python-level name"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.localcontext identity — __name__ and __module__
# ---------------------------------------------------------------------------

table decimal_extra402.localcontext_identity:
  description: "decimal.localcontext identity — __name__ == 'localcontext', __module__ == '_decimal'; localcontext is a context manager that temporarily changes the active decimal context; its __module__ reflects the C accelerator _decimal; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: declocalctx402

  columns: [id, function, args, expected]
  rows:
    - [name_val,   decimal.localcontext.__name__.__eq__,   ["localcontext"], true]
    - [module_val, decimal.localcontext.__module__.__eq__, ["_decimal"],     true]

# ---------------------------------------------------------------------------
# decimal.Decimal method __name__ identity
# ---------------------------------------------------------------------------

table decimal_extra402.decimal_method_names:
  description: "decimal.Decimal method __name__ identity — compare, to_integral_value, to_integral_exact, normalize, quantize; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decdecmeth402

  columns: [id, function, args, expected]
  rows:
    - [compare_name,            decimal.Decimal.compare.__name__.__eq__,            ["compare"],            true]
    - [to_integral_value_name,  decimal.Decimal.to_integral_value.__name__.__eq__,  ["to_integral_value"],  true]
    - [to_integral_exact_name,  decimal.Decimal.to_integral_exact.__name__.__eq__,  ["to_integral_exact"],  true]
    - [normalize_name,          decimal.Decimal.normalize.__name__.__eq__,          ["normalize"],          true]
    - [quantize_name,           decimal.Decimal.quantize.__name__.__eq__,           ["quantize"],           true]
