spec: ft3076
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (ft3076): __get__, __set__, __delete__ dict-presence checks for functools types."
    - "functools.partial defines __get__ in its own __dict__ (non-data descriptor; enables method binding)."
    - "functools.partialmethod defines __get__ in its own __dict__ (non-data descriptor for method wrapping)."
    - "functools.cached_property defines __get__ in its own __dict__; __set__ is NOT present on Python 3.14 (verified)."
    - "functools._lru_cache_wrapper (type(functools.lru_cache(lambda: None))) defines __get__ in its own __dict__."
    - "None of the four functools types define __set__ or __delete__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3076.get:
  description: "functools types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3076
  columns: [id, function, args, expected]
  rows:
    - ["ft3076001", operator.contains, [functools.partial.__dict__,             "__get__"], true]
    - ["ft3076002", operator.contains, [functools.partialmethod.__dict__,       "__get__"], true]
    - ["ft3076003", operator.contains, [functools.cached_property.__dict__,     "__get__"], true]
    - ["ft3076004", operator.contains, [functools._lru_cache_wrapper.__dict__,  "__get__"], true]

