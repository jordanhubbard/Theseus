spec: asyncio_extra44
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "This spec extends asyncio_extra43.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths (extra39), Semaphore acquire/release __qualname__ string values and lengths (extra39/extra40), BoundedSemaphore/__name__/__module__/inherited acquire qualname (extra40), Condition/__name__/__module__/wait qualname (extra40), TaskGroup/__name__/__module__/__bases__[0].__name__, Runner/__name__/__module__, shield/ensure_future/create_task __name__/__module__ (extra41), get_event_loop/__name__/__module__, get_running_loop/__name__/__module__, new_event_loop/__name__/__module__, run/__name__/__module__, iscoroutine/__name__/__module__, iscoroutinefunction/__name__/__module__ (extra42), get_event_loop/__qualname__=='get_event_loop', get_running_loop/__qualname__=='get_running_loop', run/__qualname__=='run', sleep/__qualname__=='sleep', gather/__qualname__=='gather', wait/__qualname__=='wait', Queue/__qualname__=='Queue', Lock/__qualname__=='Lock', Event/__qualname__=='Event' (extra43)."
    - "This spec covers: Queue/__qualname__.__len__()==5; Lock/__qualname__.__len__()==4; Event/__qualname__.__len__()==5; Semaphore/__qualname__.__len__()==9; BoundedSemaphore/__qualname__.__len__()==16; Condition/__qualname__.__len__()==9; TaskGroup/__qualname__.__len__()==9; CancelledError/__qualname__=='CancelledError' (14 chars); TimeoutError/__qualname__=='TimeoutError' (12 chars)."
    - "asyncio.Queue.__qualname__.__len__() == 5. Queue.__qualname__ == 'Queue' (verified in extra43); len('Queue') == 5. Extra44 captures the __len__() measurement."
    - "asyncio.Lock.__qualname__.__len__() == 4. Lock.__qualname__ == 'Lock' (verified in extra43); len('Lock') == 4. Extra44 captures the __len__() measurement."
    - "asyncio.Event.__qualname__.__len__() == 5. Event.__qualname__ == 'Event' (verified in extra43); len('Event') == 5. Extra44 captures the __len__() measurement. Note: Queue and Event share the same __qualname__ length of 5."
    - "asyncio.Semaphore.__qualname__.__len__() == 9. Semaphore is a top-level class in asyncio.locks; __qualname__ == 'Semaphore'; len('Semaphore') == 9: S-e-m-a-p-h-o-r-e = 9."
    - "asyncio.BoundedSemaphore.__qualname__.__len__() == 16. BoundedSemaphore is a top-level class in asyncio.locks; __qualname__ == 'BoundedSemaphore'; len('BoundedSemaphore') == 16: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e = 16."
    - "asyncio.Condition.__qualname__.__len__() == 9. Condition is a top-level class in asyncio.locks; __qualname__ == 'Condition'; len('Condition') == 9: C-o-n-d-i-t-i-o-n = 9. Note: Semaphore and Condition share the same __qualname__ length of 9."
    - "asyncio.TaskGroup.__qualname__.__len__() == 9. TaskGroup is a top-level class in asyncio.taskgroups; __qualname__ == 'TaskGroup'; len('TaskGroup') == 9: T-a-s-k-G-r-o-u-p = 9. Note: Semaphore, Condition, and TaskGroup all share __qualname__ length 9."
    - "asyncio.CancelledError.__qualname__ == 'CancelledError' (14 chars). CancelledError is a top-level exception alias in asyncio; __qualname__ equals __name__ for top-level classes. len('CancelledError') == 14."
    - "asyncio.TimeoutError.__qualname__ == 'TimeoutError' (12 chars). TimeoutError is a top-level exception alias in asyncio; __qualname__ equals __name__ for top-level classes. len('TimeoutError') == 12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio synchronization class __qualname__ lengths — extra44 namespace
#
# Six synchronization primitive classes and their __qualname__.__len__():
#   Queue.__qualname__.__len__()           ==  5  ('Queue')
#   Lock.__qualname__.__len__()            ==  4  ('Lock')
#   Event.__qualname__.__len__()           ==  5  ('Event')
#   Semaphore.__qualname__.__len__()       ==  9  ('Semaphore')
#   BoundedSemaphore.__qualname__.__len__()== 16  ('BoundedSemaphore')
#   Condition.__qualname__.__len__()       ==  9  ('Condition')
# All are top-level classes so __qualname__ equals __name__ for each.
# Notable: Semaphore/Condition/TaskGroup all share length 9.
# ---------------------------------------------------------------------------

table asyncio_extra44.sync_class_qualname_lengths:
  description: "asyncio synchronization class __qualname__.__len__() in extra44 namespace — Queue, Lock, Event, Semaphore, BoundedSemaphore, Condition"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncsyncclsqnlen44

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,            Queue.__qualname__.__len__,            [],  5, "Queue.__qualname__.__len__() == 5 — 'Queue' has 5 characters"]
    - [Lock,             Lock.__qualname__.__len__,             [],  4, "Lock.__qualname__.__len__() == 4 — 'Lock' has 4 characters"]
    - [Event,            Event.__qualname__.__len__,            [],  5, "Event.__qualname__.__len__() == 5 — 'Event' has 5 characters; same length as Queue"]
    - [Semaphore,        Semaphore.__qualname__.__len__,        [],  9, "Semaphore.__qualname__.__len__() == 9 — 'Semaphore' has 9 characters"]
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__len__, [], 16, "BoundedSemaphore.__qualname__.__len__() == 16 — 'BoundedSemaphore' has 16 characters"]
    - [Condition,        Condition.__qualname__.__len__,        [],  9, "Condition.__qualname__.__len__() == 9 — 'Condition' has 9 characters; same length as Semaphore"]

# ---------------------------------------------------------------------------
# asyncio.TaskGroup __qualname__ length — extra44 namespace
#
# TaskGroup.__qualname__.__len__() == 9
# TaskGroup is defined in asyncio.taskgroups (added in Python 3.11); its
# __qualname__ == 'TaskGroup'. len('TaskGroup') == 9.
# It shares the qualname length 9 with Semaphore and Condition.
# ---------------------------------------------------------------------------

invariant asyncio_extra44.TaskGroup_qualname_len:
  description: "asyncio.TaskGroup.__qualname__.__len__() == 9 — 'TaskGroup' has 9 characters; same length as Semaphore and Condition"
  category: class_names
  kind: python_call_eq
  function: TaskGroup.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# asyncio exception class __qualname__ — extra44 namespace
#
# Two exception classes exposed at the asyncio module level:
#   CancelledError.__qualname__ == 'CancelledError'  (14 chars)
#   TimeoutError.__qualname__   == 'TimeoutError'    (12 chars)
# Both are top-level exception classes; __qualname__ equals __name__.
# CancelledError is asyncio's own exception (subclass of BaseException);
# TimeoutError is an alias for the builtin TimeoutError re-exported from asyncio.
# ---------------------------------------------------------------------------

table asyncio_extra44.exception_qualnames:
  description: "asyncio exception class __qualname__ string equality in extra44 namespace — CancelledError, TimeoutError"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncexcqn44

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError, CancelledError.__qualname__.__eq__, ["CancelledError"], true, "CancelledError.__qualname__ == 'CancelledError' — top-level exception; qualname equals name (14 chars)"]
    - [TimeoutError,   TimeoutError.__qualname__.__eq__,   ["TimeoutError"],   true, "TimeoutError.__qualname__ == 'TimeoutError' — top-level exception alias; qualname equals name (12 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra44
# ---------------------------------------------------------------------------

invariant asyncio_extra44.Queue_qualname_len:
  description: "asyncio.Queue.__qualname__.__len__() == 5 — 'Queue' has 5 characters"
  category: class_names
  kind: python_call_eq
  function: Queue.__qualname__.__len__
  args: []
  expected: 5

invariant asyncio_extra44.Lock_qualname_len:
  description: "asyncio.Lock.__qualname__.__len__() == 4 — 'Lock' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: Lock.__qualname__.__len__
  args: []
  expected: 4

invariant asyncio_extra44.Event_qualname_len:
  description: "asyncio.Event.__qualname__.__len__() == 5 — 'Event' has 5 characters; same length as Queue"
  category: class_names
  kind: python_call_eq
  function: Event.__qualname__.__len__
  args: []
  expected: 5

invariant asyncio_extra44.Semaphore_qualname_len:
  description: "asyncio.Semaphore.__qualname__.__len__() == 9 — 'Semaphore' has 9 characters"
  category: class_names
  kind: python_call_eq
  function: Semaphore.__qualname__.__len__
  args: []
  expected: 9

invariant asyncio_extra44.BoundedSemaphore_qualname_len:
  description: "asyncio.BoundedSemaphore.__qualname__.__len__() == 16 — 'BoundedSemaphore' has 16 characters"
  category: class_names
  kind: python_call_eq
  function: BoundedSemaphore.__qualname__.__len__
  args: []
  expected: 16

invariant asyncio_extra44.Condition_qualname_len:
  description: "asyncio.Condition.__qualname__.__len__() == 9 — 'Condition' has 9 characters; same length as Semaphore"
  category: class_names
  kind: python_call_eq
  function: Condition.__qualname__.__len__
  args: []
  expected: 9

invariant asyncio_extra44.CancelledError_qualname_eq:
  description: "asyncio.CancelledError.__qualname__ == 'CancelledError' — top-level exception; qualname equals name (14 chars)"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__qualname__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra44.TimeoutError_qualname_eq:
  description: "asyncio.TimeoutError.__qualname__ == 'TimeoutError' — top-level exception alias; qualname equals name (12 chars)"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true
