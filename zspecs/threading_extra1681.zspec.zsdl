spec: threading_extra1681
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "Python threading documentation — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers class __name__ checks (Barrier, BoundedSemaphore, Condition), function names, TIMEOUT_MAX, active_count, Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers class_modules table, threading.local name/module, current_thread class name, get_ident, TIMEOUT_MAX type, stack_size"
    - "threading_extra1666.zspec.zsdl — covers __new__/__init__ presence for all threading classes"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which types define __call__ in their own __dict__."
    - "threading.Thread is a pure Python class — it is not callable (you instantiate it, then call start()) → __call__ not in __dict__ → False."
    - "threading.Event is a pure Python class — not callable → __call__ not in __dict__ → False."
    - "threading.Condition is a pure Python class — not callable → __call__ not in __dict__ → False."
    - "threading.Semaphore is a pure Python class — not callable → __call__ not in __dict__ → False."
    - "threading.Timer is a pure Python class (Thread subclass) — not callable → __call__ not in __dict__ → False."
    - "threading.local is a C extension type (_thread.local) — C type, no tp_call → __call__ not in __dict__ → False."
    - "threading.Thread.__dict__ DOES define run and start — the thread execution interface."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: callable_protocol
#
# Confirms that the public threading classes do NOT define __call__ in
# their own __dict__.  None of the threading synchronization or thread
# management classes are callable types.
# ---------------------------------------------------------------------------

table threading_extra1681.callable_protocol:
  description: "threading classes do not define __call__ in their own __dict__"
  kind: python_call_eq
  category: callable_protocol
  id_prefix: th1681

  columns: [id, function, args, expected]
  rows:
    - ["th1681001", "threading.Thread.__dict__.__contains__",          ["__call__"], false]
    - ["th1681002", "threading.Event.__dict__.__contains__",           ["__call__"], false]
    - ["th1681003", "threading.Condition.__dict__.__contains__",       ["__call__"], false]
    - ["th1681004", "threading.Semaphore.__dict__.__contains__",       ["__call__"], false]
    - ["th1681005", "threading.Timer.__dict__.__contains__",           ["__call__"], false]
    - ["th1681006", "threading.local.__dict__.__contains__",           ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: thread_execution_interface
#
# Verifies the key methods that threading.Thread defines in its own
# __dict__ — the execution and lifecycle interface (run, start, join,
# is_alive, etc.).  Contrasts with the absent __call__.
# ---------------------------------------------------------------------------

table threading_extra1681.thread_execution_interface:
  description: "threading.Thread execution interface method presence checks"
  kind: python_call_eq
  category: thread_execution_interface
  id_prefix: th1681

  columns: [id, function, args, expected]
  rows:
    - ["th1681010", "threading.Thread.__dict__.__contains__", ["__call__"],    false]
    - ["th1681011", "threading.Thread.__dict__.__contains__", ["run"],         true]
    - ["th1681012", "threading.Thread.__dict__.__contains__", ["start"],       true]
    - ["th1681013", "threading.Thread.__dict__.__contains__", ["join"],        true]
    - ["th1681014", "threading.Thread.__dict__.__contains__", ["is_alive"],    true]
    - ["th1681015", "threading.Thread.__dict__.__contains__", ["__init__"],    true]
    - ["th1681016", "threading.Thread.__dict__.__contains__", ["__repr__"],    true]
    - ["th1681017", "threading.Event.__dict__.__contains__",  ["__call__"],    false]
    - ["th1681018", "threading.Event.__dict__.__contains__",  ["set"],         true]
    - ["th1681019", "threading.Event.__dict__.__contains__",  ["clear"],       true]
    - ["th1681020", "threading.Event.__dict__.__contains__",  ["wait"],        true]
    - ["th1681021", "threading.Event.__dict__.__contains__",  ["is_set"],      true]
    - ["th1681022", "threading.Condition.__dict__.__contains__", ["__call__"], false]
    - ["th1681023", "threading.Condition.__dict__.__contains__", ["acquire"],  true]
    - ["th1681024", "threading.Condition.__dict__.__contains__", ["release"],  true]
    - ["th1681025", "threading.Condition.__dict__.__contains__", ["wait"],     true]
    - ["th1681026", "threading.Condition.__dict__.__contains__", ["notify"],   true]
    - ["th1681027", "threading.Condition.__dict__.__contains__", ["notify_all"], true]
    - ["th1681028", "threading.Semaphore.__dict__.__contains__", ["__call__"], false]
    - ["th1681029", "threading.Semaphore.__dict__.__contains__", ["acquire"],  true]
    - ["th1681030", "threading.Semaphore.__dict__.__contains__", ["release"],  true]

# ---------------------------------------------------------------------------
# Table 3: module_and_type_identity
#
# Verifies __module__, __name__, and metatype for the threading classes.
# threading.local is from _thread (C module); all others are from threading.
# ---------------------------------------------------------------------------

table threading_extra1681.module_and_type_identity:
  description: "Module and metatype identity for threading classes"
  kind: python_call_eq
  category: module_and_type_identity
  id_prefix: th1681

  columns: [id, function, args, expected]
  rows:
    - ["th1681040", "threading.Thread.__module__.__eq__",              ["threading"], true]
    - ["th1681041", "threading.Thread.__name__.__eq__",                ["Thread"],    true]
    - ["th1681042", "threading.Thread.__class__.__name__.__eq__",      ["type"],      true]
    - ["th1681043", "threading.Event.__module__.__eq__",               ["threading"], true]
    - ["th1681044", "threading.Event.__name__.__eq__",                 ["Event"],     true]
    - ["th1681045", "threading.Condition.__module__.__eq__",           ["threading"], true]
    - ["th1681046", "threading.Condition.__name__.__eq__",             ["Condition"], true]
    - ["th1681047", "threading.Semaphore.__module__.__eq__",           ["threading"], true]
    - ["th1681048", "threading.Semaphore.__name__.__eq__",             ["Semaphore"], true]
    - ["th1681049", "threading.Timer.__module__.__eq__",               ["threading"], true]
    - ["th1681050", "threading.Timer.__name__.__eq__",                 ["Timer"],     true]
    - ["th1681051", "threading.local.__module__.__eq__",               ["_thread"],   true]
    - ["th1681052", "threading.local.__name__.__eq__",                 ["local"],     true]
    - ["th1681053", "threading.local.__class__.__name__.__eq__",       ["type"],      true]
