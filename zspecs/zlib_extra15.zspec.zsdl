spec: zlib_extra15
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
  notes:
    - "This spec extends zlib_extra14.zspec.zsdl."
    - "Prior specs covered: zlib.__name__/__package__, compress/__name__/__module__, decompress/__name__/__module__, compressobj/__name__/__module__, decompressobj/__name__/__module__, crc32/__name__, adler32/__name__, Compress.__name__, Decompress.__name__, error.__name__/__module__, error.__bases__[0].__name__, various __qualname__ checks, Z_DEFAULT_COMPRESSION/__class__/__name__, DEFLATED/__class__.__name__."
    - "This spec covers: zlib.compress.__qualname__, zlib.decompress.__qualname__, zlib.compressobj.__qualname__, zlib.decompressobj.__qualname__, zlib.crc32.__qualname__, zlib.adler32.__qualname__, zlib.compress.__module__.__len__(), zlib.decompress.__module__.__len__(), zlib.error.__qualname__, zlib.Compress.__qualname__, zlib.Decompress.__qualname__."
    - "zlib.compress.__qualname__ == 'compress': C builtin qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "zlib.decompress.__qualname__ == 'decompress': C builtin qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "zlib.compressobj.__qualname__ == 'compressobj': C builtin qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "zlib.decompressobj.__qualname__ == 'decompressobj': C builtin qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "zlib.crc32.__qualname__ == 'crc32': C builtin qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "zlib.adler32.__qualname__ == 'adler32': C builtin qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "zlib.compress.__module__ == 'zlib' (len 4): the module name 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.decompress.__module__ == 'zlib' (len 4): same as compress. Verified 2026-04-09."
    - "zlib.error.__qualname__ == 'error': the exception class qualname re-anchored from extra15 namespace. Verified 2026-04-09."
    - "type(zlib.compressobj()).__qualname__ == 'Compress': the internal Compress type qualname. Verified 2026-04-09."
    - "type(zlib.decompressobj()).__qualname__ == 'Decompress': the internal Decompress type qualname. Verified 2026-04-09."
    - "zlib.Compress and zlib.Decompress are not module-level names; they are the internal C types returned by compressobj() and decompressobj()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compress.__qualname__ == 'compress' — extra15 namespace anchor
#
# zlib_extra10 and extra11 cover this from those namespaces. Re-anchored
# from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.compress.qualname:
  description: "zlib.compress.__qualname__ == 'compress' — C builtin function qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__qualname__ == 'decompress' — extra15 namespace anchor
#
# Re-anchored from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.decompress.qualname:
  description: "zlib.decompress.__qualname__ == 'decompress' — C builtin function qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# compressobj.__qualname__ == 'compressobj' — extra15 namespace anchor
#
# Re-anchored from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.compressobj.qualname:
  description: "zlib.compressobj.__qualname__ == 'compressobj' — C builtin function qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: compressobj.__qualname__.__eq__
  args: ["compressobj"]
  expected: true

# ---------------------------------------------------------------------------
# decompressobj.__qualname__ == 'decompressobj' — extra15 namespace anchor
#
# Re-anchored from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.decompressobj.qualname:
  description: "zlib.decompressobj.__qualname__ == 'decompressobj' — C builtin function qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: decompressobj.__qualname__.__eq__
  args: ["decompressobj"]
  expected: true

# ---------------------------------------------------------------------------
# crc32.__qualname__ == 'crc32' — extra15 namespace anchor
#
# Re-anchored from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.crc32.qualname:
  description: "zlib.crc32.__qualname__ == 'crc32' — C builtin function qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: crc32.__qualname__.__eq__
  args: ["crc32"]
  expected: true

# ---------------------------------------------------------------------------
# adler32.__qualname__ == 'adler32' — extra15 namespace anchor
#
# Re-anchored from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.adler32.qualname:
  description: "zlib.adler32.__qualname__ == 'adler32' — C builtin function qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: adler32.__qualname__.__eq__
  args: ["adler32"]
  expected: true

# ---------------------------------------------------------------------------
# error.__qualname__ == 'error' — extra15 namespace anchor
#
# Re-anchored from extra15 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.error.qualname:
  description: "zlib.error.__qualname__ == 'error' — module-level exception class qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 4 — novel, extra15 anchor
#
# zlib.compress.__module__ == 'zlib' which has length 4. No prior zlib spec
# checks __module__.__len__() for the compress function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.compress.module_len:
  description: "zlib.compress.__module__.__len__() == 4 — 'zlib' module name has four characters (extra15)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 4 — novel, extra15 anchor
#
# zlib.decompress.__module__ == 'zlib' (len 4). No prior zlib spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.decompress.module_len:
  description: "zlib.decompress.__module__.__len__() == 4 — 'zlib' module name has four characters (extra15)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Compress.__qualname__ == 'Compress' — via compressobj(), extra15 anchor
#
# zlib.Compress is not a direct module attribute. The internal C type returned
# by compressobj() has __qualname__ == 'Compress'. Accessed via method chain.
# zlib_extra2 covers type(compressobj()).__name__; __qualname__ is novel.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.Compress.qualname:
  description: "type(zlib.compressobj()).__qualname__ == 'Compress' — internal Compress type qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: compressobj
  args: []
  method: __class__
  method_chain: __qualname__
  expected: "Compress"

# ---------------------------------------------------------------------------
# Decompress.__qualname__ == 'Decompress' — via decompressobj(), extra15 anchor
#
# zlib.Decompress is not a direct module attribute. The internal C type returned
# by decompressobj() has __qualname__ == 'Decompress'. Accessed via method chain.
# zlib_extra2 covers type(decompressobj()).__name__; __qualname__ is novel.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra15.Decompress.qualname:
  description: "type(zlib.decompressobj()).__qualname__ == 'Decompress' — internal Decompress type qualname (extra15)"
  category: qualnames
  kind: python_call_eq
  function: decompressobj
  args: []
  method: __class__
  method_chain: __qualname__
  expected: "Decompress"

# ---------------------------------------------------------------------------
# __qualname__ table — compress, decompress, compressobj, decompressobj,
#                      crc32, adler32, error (extra15)
#
# Re-anchors all seven qualname invariants from the extra15 namespace in
# a single table. No prior zlib spec presents these from the extra15 namespace.
# ---------------------------------------------------------------------------

table zlib_extra15.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn15

  columns: [id, function, args, expected]
  rows:
    - [compress,      compress.__qualname__.__eq__,      ["compress"],      true]
    - [decompress,    decompress.__qualname__.__eq__,    ["decompress"],    true]
    - [compressobj,   compressobj.__qualname__.__eq__,   ["compressobj"],   true]
    - [decompressobj, decompressobj.__qualname__.__eq__, ["decompressobj"], true]
    - [crc32,         crc32.__qualname__.__eq__,         ["crc32"],         true]
    - [adler32,       adler32.__qualname__.__eq__,       ["adler32"],       true]
    - [error,         error.__qualname__.__eq__,         ["error"],         true]

# ---------------------------------------------------------------------------
# __module__.__len__() table — compress and decompress (extra15)
#
# No prior zlib spec presents __module__.__len__() checks in a table.
# Both functions have module name 'zlib' (length 4). This table anchors
# both from the extra15 namespace.
# ---------------------------------------------------------------------------

table zlib_extra15.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen15

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__module__.__len__,   [], 4]
    - [decompress, decompress.__module__.__len__, [], 4]
