spec: theseus_dataclasses_cr
version: ">=3.8"
backend: python_cleanroom(theseus_dataclasses_cr)
blocks: dataclasses

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dataclasses.html"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py (internal implementation)"
  notes:
    - "Clean-room dataclasses module. Do NOT import dataclasses."
    - "dataclass decorator: auto-generates __init__, __repr__, __eq__."
    - "field(): customize field behavior (default, default_factory, etc.)."
    - "fields(): return tuple of Field objects."
    - "asdict(), astuple(): convert dataclass to dict/tuple."

error_model: python_exceptions

invariant theseus_dataclasses_cr.dataclasses2_init:
  description: "dataclass auto-generates __init__ from fields"
  category: dataclass
  kind: python_call_eq
  function: dataclasses2_init
  args: []
  expected: true

invariant theseus_dataclasses_cr.dataclasses2_repr:
  description: "dataclass auto-generates __repr__"
  category: dataclass
  kind: python_call_eq
  function: dataclasses2_repr
  args: []
  expected: true

invariant theseus_dataclasses_cr.dataclasses2_eq:
  description: "dataclass auto-generates __eq__ based on fields"
  category: dataclass
  kind: python_call_eq
  function: dataclasses2_eq
  args: []
  expected: true
