spec: abc_extra81
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra80.zspec.zsdl."
    - "This spec covers: wave 246 theme — abc abstractmethod code object attributes. NEW in extra81: abstractmethod.__code__.co_name=='abstractmethod'; abstractmethod.__code__.co_argcount==1 (funcobj); abstractmethod.__code__.co_varnames.__len__()==1 (only 'funcobj'); abstractmethod.__code__.co_varnames.__class__.__name__=='tuple'; abstractmethod.__qualname__.__eq__('abstractmethod')==True; abstractmethod.__module__.__eq__('abc')==True; abstractmethod.__name__.__eq__('abstractmethod')==True; update_abstractmethods.__code__.co_name=='update_abstractmethods'; update_abstractmethods.__code__.co_argcount==1 (cls); update_abstractmethods.__code__.co_varnames.__len__()==5 (cls, abstracts, scls, name, value); get_cache_token.__qualname__.__eq__('get_cache_token')==True; get_cache_token.__module__.__eq__('_abc')==True (C extension). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_name == 'abstractmethod'. The code object function name matches the function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_argcount == 1. abstractmethod takes exactly 1 positional argument: funcobj. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_varnames.__len__() == 1. co_varnames contains only ('funcobj',). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod'. Simple unqualified function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__module__ == 'abc'. abstractmethod is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__name__ == 'abstractmethod'. The function __name__ attribute matches the function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_argcount == 1. update_abstractmethods takes exactly 1 positional argument: cls. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5. co_varnames contains (cls, abstracts, scls, name, value). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token'. get_cache_token is a C extension function; its __qualname__ is 'get_cache_token'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__module__ == '_abc'. get_cache_token is implemented in the C extension _abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstractmethod code object attributes — extra81
#
# Wave 246 theme: abc abstractmethod code object attributes.
#
# abstractmethod.__code__.co_name == 'abstractmethod'
# abstractmethod.__code__.co_argcount == 1
# abstractmethod.__code__.co_varnames.__len__() == 1
# abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table abc_extra81.abstractmethod_code_attrs:
  description: "abc abstractmethod code object attribute checks in abcextra81 namespace — wave 246 theme: abc abstractmethod code object attributes; abstractmethod.__code__.co_name=='abstractmethod'; abstractmethod.__code__.co_argcount==1 (takes exactly 1 arg: funcobj); abstractmethod.__code__.co_varnames.__len__()==1 (co_varnames contains only 'funcobj'); abstractmethod.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra81

  columns: [id, function, args, expected, description]
  rows:
    - [am_co_name,           abstractmethod.__code__.co_name.__eq__,                    ["abstractmethod"], true, "abstractmethod.__code__.co_name == 'abstractmethod' — code object function name; verified with Python 3.14.3"]
    - [am_co_argcount,       "abstractmethod.__code__.co_argcount.__eq__",              [1],                true, "abstractmethod.__code__.co_argcount == 1 — takes exactly 1 positional arg: funcobj; verified with Python 3.14.3"]
    - [am_co_varnames_len,   "abstractmethod.__code__.co_varnames.__len__",             [],                 1,    "abstractmethod.__code__.co_varnames.__len__() == 1 — co_varnames contains only ('funcobj',); verified with Python 3.14.3"]
    - [am_co_varnames_class, "abstractmethod.__code__.co_varnames.__class__.__name__.__eq__", ["tuple"],   true, "abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
