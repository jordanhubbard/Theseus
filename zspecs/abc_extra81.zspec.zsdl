table abc_extra81.update_abstractmethods_code_attrs:
  description: "abc update_abstractmethods code object attribute checks in abcextra81 namespace — wave 246 theme: abc abstractmethod code object attributes; update_abstractmethods.__code__.co_name=='update_abstractmethods'; update_abstractmethods.__code__.co_argcount==1 (takes exactly 1 positional arg: cls); update_abstractmethods.__code__.co_varnames.__len__()==5 (cls, abstracts, scls, name, value); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra81b

  columns: [id, function, args, expected, description]
  rows:
    - [uam_co_name,         update_abstractmethods.__code__.co_name.__eq__,       ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_name == 'update_abstractmethods' — code object function name; verified with Python 3.14.3"]
    - [uam_co_argcount,     "update_abstractmethods.__code__.co_argcount.__eq__", [1],                        true, "update_abstractmethods.__code__.co_argcount == 1 — takes exactly 1 positional arg: cls; verified with Python 3.14.3"]
    - [uam_co_varnames_len, "update_abstractmethods.__code__.co_varnames.__len__", [],                        5,    "update_abstractmethods.__code__.co_varnames.__len__() == 5 — includes cls, abstracts, scls, name, value; verified with Python 3.14.3"]

