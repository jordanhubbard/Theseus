# abstractmethod.__name__.__eq__('abstractmethod') == True
# ---------------------------------------------------------------------------

table abc_extra81.abstractmethod_name_attrs:
  description: "abc abstractmethod __qualname__, __module__, and __name__ attribute checks in abcextra81 namespace — wave 246 theme: abc abstractmethod code object attributes; abstractmethod.__qualname__.__eq__('abstractmethod')==True (simple unqualified function name); abstractmethod.__module__.__eq__('abc')==True (defined in abc module); abstractmethod.__name__.__eq__('abstractmethod')==True (__name__ matches function name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra81a

  columns: [id, function, args, expected, description]
  rows:
    - [am_qualname,  abstractmethod.__qualname__.__eq__, ["abstractmethod"], true, "abstractmethod.__qualname__ == 'abstractmethod' — simple unqualified function name; verified with Python 3.14.3"]
    - [am_module,    abstractmethod.__module__.__eq__,   ["abc"],            true, "abstractmethod.__module__ == 'abc' — defined in the abc module; verified with Python 3.14.3"]
    - [am_name,      abstractmethod.__name__.__eq__,     ["abstractmethod"], true, "abstractmethod.__name__ == 'abstractmethod' — function __name__ attribute; verified with Python 3.14.3"]

