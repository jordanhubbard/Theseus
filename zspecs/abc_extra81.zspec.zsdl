# ---------------------------------------------------------------------------

table abc_extra81.get_cache_token_and_cross_checks:
  description: "abc get_cache_token identity and cross-check table in abcextra81 namespace — wave 246 theme: abc abstractmethod code object attributes; get_cache_token.__qualname__.__eq__('get_cache_token')==True; get_cache_token.__module__.__eq__('_abc')==True (C extension implemented in _abc module); abstractmethod.__code__.co_name=='abstractmethod' (cross-check); abstractmethod.__code__.co_argcount==1 (cross-check); update_abstractmethods.__code__.co_argcount==1 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra81c

  columns: [id, function, args, expected, description]
  rows:
    - [gct_qualname,         get_cache_token.__qualname__.__eq__,              ["get_cache_token"],      true, "get_cache_token.__qualname__ == 'get_cache_token' — C extension function; verified with Python 3.14.3"]
    - [gct_module,           get_cache_token.__module__.__eq__,                ["_abc"],                 true, "get_cache_token.__module__ == '_abc' — implemented in C extension _abc module; verified with Python 3.14.3"]
    - [am_co_name_cross,     abstractmethod.__code__.co_name.__eq__,           ["abstractmethod"],       true, "abstractmethod.__code__.co_name == 'abstractmethod' — cross-check; verified with Python 3.14.3"]
    - [am_co_argcount_cross, "abstractmethod.__code__.co_argcount.__eq__",     [1],                      true, "abstractmethod.__code__.co_argcount == 1 — cross-check; verified with Python 3.14.3"]
    - [uam_co_argcount_cross, "update_abstractmethods.__code__.co_argcount.__eq__", [1],                 true, "update_abstractmethods.__code__.co_argcount == 1 — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra81
# ---------------------------------------------------------------------------

invariant abc_extra81.abstractmethod_co_name:
  description: "abc.abstractmethod.__code__.co_name.__eq__('abstractmethod') returns True — the code object function name matches the function name; NEW in extra81: first standalone co_name invariant for abstractmethod in abcextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_name.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra81.abstractmethod_co_argcount:
  description: "abc.abstractmethod.__code__.co_argcount == 1 — abstractmethod takes exactly 1 positional argument: funcobj; NEW in extra81: first standalone co_argcount invariant for abstractmethod in abcextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant abc_extra81.abstractmethod_co_varnames_len:
  description: "abc.abstractmethod.__code__.co_varnames.__len__() == 1 — co_varnames contains only ('funcobj',); abstractmethod has a single local variable; NEW in extra81: first standalone co_varnames.__len__ invariant for abstractmethod in abcextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant abc_extra81.get_cache_token_qualname:
  description: "abc.get_cache_token.__qualname__.__eq__('get_cache_token') returns True — get_cache_token is a C extension function in the _abc module; its __qualname__ is the simple function name; NEW in extra81: first standalone __qualname__ invariant for get_cache_token in abcextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra81.get_cache_token_module:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — get_cache_token is implemented in the C extension _abc module, not in the pure Python abc module; NEW in extra81: first standalone __module__ invariant for get_cache_token in abcextra81 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true
