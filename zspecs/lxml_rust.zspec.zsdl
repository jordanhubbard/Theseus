spec: lxml_rust
version: ">=3.9"
backend: rust_module(lxml_rust)

docs: https://lxml.de/apidoc/

provenance:
  derived_from:
    - "https://lxml.de/apidoc/ — lxml API documentation"
  not_derived_from:
    - "lxml source: src/lxml/etree.pyx"
  notes:
    - "lxml provides XML/HTML processing."
    - "from lxml import etree; root = etree.fromstring('<root><a>1</a></root>'); root.tag == 'root'."
    - "root.find('a').text == '1'."
    - "etree.tostring(root) == b'<root><a>1</a></root>'."
    - "Expose lxml_root_tag(xml) -> str: etree.fromstring(xml).tag."
    - "Expose lxml_find_text(xml, path) -> str: etree.fromstring(xml).find(path).text."
    - "Expose lxml_tostring(xml) -> str: etree.tostring(etree.fromstring(xml)).decode()."
    - "All test vectors verified against lxml 5.3.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# lxml_root_tag — root element tag name
table lxml_rust.parse.root_tag:
  kind: python_call_eq
  category: root_tag
  id_prefix: lxml_rt
  function: lxml_root_tag

  columns: [id, args, expected]
  rows:
    - [root,  ["<root><a>1</a></root>"], "root"]
    - [data,  ["<data/>"],               "data"]
    - [items, ["<items><item/></items>"], "items"]

# lxml_find_text — text content of subelement
table lxml_rust.parse.find_text:
  kind: python_call_eq
  category: find_text
  id_prefix: lxml_ft
  function: lxml_find_text

  columns: [id, args, expected]
  rows:
    - [a_one,   ["<root><a>1</a></root>", "a"], "1"]
    - [b_hello, ["<root><b>hello</b></root>", "b"], "hello"]

# lxml_tostring — roundtrip via tostring
invariant lxml_rust.serialize.tostring:
  description: "tostring(fromstring(xml)) == xml"
  category: serialize
  kind: python_call_eq
  function: lxml_tostring
  args: ["<root><a>1</a></root>"]
  expected: "<root><a>1</a></root>"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:32:15Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
