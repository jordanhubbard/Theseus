spec: csv_extra24
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra23.zspec.zsdl."
    - "csv_extra23 covers: DictReader/__init__/__qualname__; DictWriter/__init__/__qualname__; register_dialect/__qualname__; register_dialect/__module__; unregister_dialect/__qualname__; unregister_dialect/__module__; list_dialects/__qualname__; field_size_limit/__qualname__; field_size_limit/__module__; QUOTE_NONNUMERIC/__class__/__module__; QUOTE_NONE/__class__/__module__."
    - "csv_extra16 covers: reader/__module__; writer/__module__; QUOTE_ALL/__class__/__name__; QUOTE_MINIMAL/__class__/__name__; QUOTE_NONNUMERIC/__class__/__name__; QUOTE_NONE/__class__/__name__."
    - "csv_extra18 covers: list_dialects/__module__; get_dialect/__module__; DictReader/DictWriter/Sniffer/excel/excel_tab/Dialect __qualname__."
    - "Focus: __name__ for DictReader.__init__ and DictWriter.__init__; reader/__qualname__ and writer/__qualname__; __name__ for register_dialect, unregister_dialect, list_dialects, field_size_limit, and get_dialect; __class__/__module__ for QUOTE_ALL and QUOTE_MINIMAL."
    - "No prior csv spec checks DictReader.__init__.__name__."
    - "No prior csv spec checks DictWriter.__init__.__name__."
    - "No prior csv spec checks reader.__qualname__."
    - "No prior csv spec checks writer.__qualname__."
    - "No prior csv spec checks register_dialect.__name__."
    - "No prior csv spec checks unregister_dialect.__name__."
    - "No prior csv spec checks list_dialects.__name__."
    - "No prior csv spec checks field_size_limit.__name__."
    - "No prior csv spec checks get_dialect.__name__."
    - "No prior csv spec checks QUOTE_ALL.__class__.__module__."
    - "No prior csv spec checks QUOTE_MINIMAL.__class__.__module__."
    - "csv.DictReader.__init__.__name__ == '__init__' — bare method name without class prefix."
    - "csv.DictWriter.__init__.__name__ == '__init__' — bare method name without class prefix."
    - "csv.reader.__qualname__ == 'reader' — C builtin type qualname equals bare name."
    - "csv.writer.__qualname__ == 'writer' — C builtin type qualname equals bare name."
    - "csv.register_dialect.__name__ == 'register_dialect' — C builtin function __name__ equals bare name."
    - "csv.unregister_dialect.__name__ == 'unregister_dialect' — C builtin function __name__ equals bare name."
    - "csv.list_dialects.__name__ == 'list_dialects' — C builtin function __name__ equals bare name."
    - "csv.field_size_limit.__name__ == 'field_size_limit' — C builtin function __name__ equals bare name."
    - "csv.get_dialect.__name__ == 'get_dialect' — C builtin function __name__ equals bare name."
    - "csv.QUOTE_ALL.__class__.__module__ == 'builtins' — int type is defined in the builtins module."
    - "csv.QUOTE_MINIMAL.__class__.__module__ == 'builtins' — int type is defined in the builtins module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DictReader.__init__ and DictWriter.__init__ — __name__
#
# csv_extra23 checks __qualname__ for both __init__ methods.  No prior csv spec
# checks the bare __name__ of either.  For all Python methods, __name__ is the
# plain identifier without any class-prefix qualification.
# ---------------------------------------------------------------------------

invariant csv_extra24.DictReader.__init__.name:
  description: "csv.DictReader.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: "DictReader.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant csv_extra24.DictWriter.__init__.name:
  description: "csv.DictWriter.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: "DictWriter.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# reader.__qualname__ and writer.__qualname__
#
# csv_extra16 checks reader.__module__ and writer.__module__.  csv_extra18 checks
# __qualname__ for DictReader, DictWriter, Sniffer, excel, excel_tab, and Dialect,
# but not for reader or writer.  The reader and writer objects are C builtin
# types exposed directly in the csv namespace; their __qualname__ equals the
# bare type name, matching __name__.
# ---------------------------------------------------------------------------

invariant csv_extra24.reader.qualname:
  description: "csv.reader.__qualname__ == 'reader' — C builtin type qualname equals bare name"
  category: type_attrs
  kind: python_call_eq
  function: reader.__qualname__.__eq__
  args: ["reader"]
  expected: true

invariant csv_extra24.writer.qualname:
  description: "csv.writer.__qualname__ == 'writer' — C builtin type qualname equals bare name"
  category: type_attrs
  kind: python_call_eq
  function: writer.__qualname__.__eq__
  args: ["writer"]
  expected: true

# ---------------------------------------------------------------------------
# register_dialect, unregister_dialect, list_dialects, field_size_limit,
# get_dialect — __name__
#
# csv_extra23 checks __qualname__ (and for some, __module__) for register_dialect,
# unregister_dialect, list_dialects, and field_size_limit.  csv_extra18 checks
# get_dialect.__module__.  No prior csv spec checks the bare __name__ of any of
# these five C extension functions.  For C builtins, __name__ equals the bare
# function name, identical to __qualname__.
# ---------------------------------------------------------------------------

invariant csv_extra24.register_dialect.name:
  description: "csv.register_dialect.__name__ == 'register_dialect' — C builtin function __name__ equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: register_dialect.__name__.__eq__
  args: ["register_dialect"]
  expected: true

invariant csv_extra24.unregister_dialect.name:
  description: "csv.unregister_dialect.__name__ == 'unregister_dialect' — C builtin function __name__ equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: unregister_dialect.__name__.__eq__
  args: ["unregister_dialect"]
  expected: true

invariant csv_extra24.list_dialects.name:
  description: "csv.list_dialects.__name__ == 'list_dialects' — C builtin function __name__ equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: list_dialects.__name__.__eq__
  args: ["list_dialects"]
  expected: true

invariant csv_extra24.field_size_limit.name:
  description: "csv.field_size_limit.__name__ == 'field_size_limit' — C builtin function __name__ equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: field_size_limit.__name__.__eq__
  args: ["field_size_limit"]
  expected: true

invariant csv_extra24.get_dialect.name:
  description: "csv.get_dialect.__name__ == 'get_dialect' — C builtin function __name__ equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: get_dialect.__name__.__eq__
  args: ["get_dialect"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_ALL and QUOTE_MINIMAL — __class__.__module__
#
# csv_extra16 checks __class__.__name__ == 'int' for both constants.
# csv_extra23 checks __class__.__module__ for QUOTE_NONNUMERIC and QUOTE_NONE.
# No prior csv spec checks __class__.__module__ for QUOTE_ALL or QUOTE_MINIMAL.
# The int type is defined in the 'builtins' module.
# ---------------------------------------------------------------------------

invariant csv_extra24.QUOTE_ALL.class_module:
  description: "csv.QUOTE_ALL.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: QUOTE_ALL.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant csv_extra24.QUOTE_MINIMAL.class_module:
  description: "csv.QUOTE_MINIMAL.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: QUOTE_MINIMAL.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all eleven new invariants
#
# All eleven are first covered in this spec (csv_extra24).
# ---------------------------------------------------------------------------

table csv_extra24.init_names_qualnames_func_names_and_constant_modules:
  description: "csv DictReader/DictWriter __init__.__name__, reader/writer __qualname__, dialect func __name__, QUOTE_ALL/QUOTE_MINIMAL class modules"
  kind: python_call_eq
  category: method_attrs
  id_prefix: cfa24

  columns: [id, function, args, expected]
  rows:
    - [DictReader_init_name,   "DictReader.__init__.__name__.__eq__",   ["__init__"],         true]
    - [DictWriter_init_name,   "DictWriter.__init__.__name__.__eq__",   ["__init__"],         true]
    - [reader_qn,              reader.__qualname__.__eq__,               ["reader"],           true]
    - [writer_qn,              writer.__qualname__.__eq__,               ["writer"],           true]
    - [register_dialect_name,  register_dialect.__name__.__eq__,        ["register_dialect"], true]
    - [unregister_dial_name,   unregister_dialect.__name__.__eq__,      ["unregister_dialect"], true]
    - [list_dialects_name,     list_dialects.__name__.__eq__,           ["list_dialects"],    true]
    - [field_size_limit_name,  field_size_limit.__name__.__eq__,        ["field_size_limit"], true]
    - [get_dialect_name,       get_dialect.__name__.__eq__,             ["get_dialect"],      true]
    - [QUOTE_ALL_class_mod,    QUOTE_ALL.__class__.__module__.__eq__,   ["builtins"],         true]
    - [QUOTE_MINIMAL_class_mod, QUOTE_MINIMAL.__class__.__module__.__eq__, ["builtins"],      true]
