spec: theseus_importlib_util_cr
version: ">=3.0"
backend: python_cleanroom(theseus_importlib_util_cr)
blocks: importlib.util

docs: https://docs.python.org/3/library/importlib.html#importlib.util

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.html"
  not_derived_from:
    - "CPython source: Lib/importlib/util.py"
  notes:
    - "Clean-room importlib.util module. Do NOT import importlib.util."

error_model: python_exceptions

invariant theseus_importlib_util_cr.imputil2_find_spec:
  description: "find_spec() locates a module by name"
  category: behavior
  kind: python_call_eq
  function: imputil2_find_spec
  args: []
  expected: true

invariant theseus_importlib_util_cr.imputil2_module_from_spec:
  description: "module_from_spec() creates a module from a spec"
  category: behavior
  kind: python_call_eq
  function: imputil2_module_from_spec
  args: []
  expected: true

invariant theseus_importlib_util_cr.imputil2_spec_from_file:
  description: "spec_from_file_location() creates a spec from a file path"
  category: behavior
  kind: python_call_eq
  function: imputil2_spec_from_file
  args: []
  expected: true
