spec: warnings_extra4
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/warnings.c"
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends prior warnings specs."
    - "Focus: __module__ and __name__ for warnings functions and classes not yet covered."
    - "warnings.warn.__name__ == 'warn'."
    - "warnings.warn_explicit.__name__ == 'warn_explicit'."
    - "warnings.filterwarnings.__name__ == 'filterwarnings'."
    - "warnings.simplefilter.__name__ == 'simplefilter'."
    - "warnings.resetwarnings.__name__ == 'resetwarnings'."
    - "warnings.catch_warnings.__name__ == 'catch_warnings'."
    - "warnings.DeprecationWarning == builtins.DeprecationWarning (same object)."
    - "warnings.WarningMessage.__name__ == 'WarningMessage'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table warnings_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [warn,             warn.__name__.__eq__,             ["warn"],             true]
    - [warn_explicit,    warn_explicit.__name__.__eq__,    ["warn_explicit"],    true]
    - [filterwarnings,   filterwarnings.__name__.__eq__,   ["filterwarnings"],   true]
    - [simplefilter,     simplefilter.__name__.__eq__,     ["simplefilter"],     true]
    - [resetwarnings,    resetwarnings.__name__.__eq__,    ["resetwarnings"],    true]
    - [showwarning,      showwarning.__name__.__eq__,      ["showwarning"],      true]
    - [formatwarning,    formatwarning.__name__.__eq__,    ["formatwarning"],    true]

table warnings_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [catch_warnings,  catch_warnings.__name__.__eq__,  ["catch_warnings"],  true]
    - [WarningMessage,  WarningMessage.__name__.__eq__,  ["WarningMessage"],  true]

invariant warnings_extra4.catch_warnings.module:
  description: "warnings.catch_warnings.__module__ == 'warnings'"
  category: module
  kind: python_call_eq
  function: catch_warnings.__module__.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra4.WarningMessage.module:
  description: "warnings.WarningMessage.__module__ == 'warnings'"
  category: module
  kind: python_call_eq
  function: WarningMessage.__module__.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra4.catch_warnings.instance_class:
  description: "warnings.catch_warnings().__class__.__name__ == 'catch_warnings'"
  category: catch_warnings
  kind: python_call_eq
  function: catch_warnings
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["catch_warnings"]
  expected: true

invariant warnings_extra4.filters.is_list:
  description: "warnings.filters.__class__.__name__ == 'list'"
  category: filters
  kind: python_call_eq
  function: filters.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant warnings_extra4.defaultaction.is_str:
  description: "warnings.defaultaction.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: defaultaction.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant warnings_extra4.warn.module:
  description: "warnings.warn.__module__ == 'warnings'"
  category: module
  kind: python_call_eq
  function: warn.__module__.__eq__
  args: ["warnings"]
  expected: true
