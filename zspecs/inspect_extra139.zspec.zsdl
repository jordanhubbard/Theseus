table inspect_extra139.boundarguments_method_qualnames:
  description: "inspect.BoundArguments: __init__ qualname len 23, apply_defaults len 29, __eq__ len 21; wave 267; new to extra139"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectbaq139

  columns: [id, function, args, expected, description]
  rows:
    - [ba_init_qualname_eq,
       "BoundArguments.__init__.__qualname__.__eq__",
       ["BoundArguments.__init__"],
       true,
       "inspect.BoundArguments.__init__.__qualname__.__eq__('BoundArguments.__init__') == True — __init__ is a Python function defined on BoundArguments; its qualname is 'BoundArguments.__init__'; str.__eq__ returns True; new to extra139"]
    - [ba_init_qualname_len_eq_23,
       "BoundArguments.__init__.__qualname__.__len__",
       [],
       23,
       "inspect.BoundArguments.__init__.__qualname__.__len__() == 23 — __qualname__ is 'BoundArguments.__init__' which has 23 characters; len() == 23; new to extra139"]
    - [ba_init_co_argcount_eq_3,
       "BoundArguments.__init__.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.BoundArguments.__init__.__code__.co_argcount.__eq__(3) == True — __init__ takes 3 positional-or-keyword arguments: self, signature, arguments; co_argcount is 3; int.__eq__(3) returns True; new to extra139"]
    - [ba_apply_defaults_qualname_eq,
       "BoundArguments.apply_defaults.__qualname__.__eq__",
       ["BoundArguments.apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — apply_defaults is a Python function defined on BoundArguments; its qualname is 'BoundArguments.apply_defaults'; str.__eq__ returns True; new to extra139"]
    - [ba_apply_defaults_qualname_len_eq_29,
       "BoundArguments.apply_defaults.__qualname__.__len__",
       [],
       29,
       "inspect.BoundArguments.apply_defaults.__qualname__.__len__() == 29 — __qualname__ is 'BoundArguments.apply_defaults' which has 29 characters; len() == 29; new to extra139"]
    - [ba_eq_qualname_eq,
       "BoundArguments.__eq__.__qualname__.__eq__",
       ["BoundArguments.__eq__"],
       true,
       "inspect.BoundArguments.__eq__.__qualname__.__eq__('BoundArguments.__eq__') == True — __eq__ is a Python function defined on BoundArguments; its qualname is 'BoundArguments.__eq__'; str.__eq__ returns True; new to extra139"]
    - [ba_eq_qualname_len_eq_21,
       "BoundArguments.__eq__.__qualname__.__len__",
       [],
       21,
       "inspect.BoundArguments.__eq__.__qualname__.__len__() == 21 — __qualname__ is 'BoundArguments.__eq__' which has 21 characters; len() == 21; new to extra139"]

