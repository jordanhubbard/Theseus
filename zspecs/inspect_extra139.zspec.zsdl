spec: inspect_extra139
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter.empty (a class sentinel), inspect.BoundArguments (Python class) — class identity, __name__, __module__, __bases__, MRO, method qualnames (Wave 267)."
    - "inspect.Parameter.empty is itself a class (type), not an instance — isinstance(inspect.Parameter.empty, type) is True. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__name__ == '_empty' (len 6) — the sentinel class's actual name. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__module__ == 'inspect' (len 7). Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__qualname__ == '_empty' (len 6). Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__bases__[0].__name__ == 'object' — _empty directly inherits object. Verified with Python 3.14.3."
    - "len(inspect.Parameter.empty.__mro__) == 2 — MRO is [_empty, object]. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' (len 14). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' (len 7). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — directly inherits object. Verified with Python 3.14.3."
    - "len(inspect.BoundArguments.__mro__) == 2 — MRO is [BoundArguments, object]. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__' (len 23). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__code__.co_argcount == 3 (self, signature, arguments). Verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' (len 29). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__eq__.__qualname__ == 'BoundArguments.__eq__' (len 21). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter.empty — sentinel class identity
#
# Wave 267 theme: inspect.Parameter.empty is a class, not an instance.
#
# inspect.Parameter.empty.__class__.__name__ == 'type'
# inspect.Parameter.empty.__name__ == '_empty' (len 6)
# inspect.Parameter.empty.__module__ == 'inspect' (len 7)
# inspect.Parameter.empty.__qualname__ == '_empty' (len 6)
# inspect.Parameter.empty.__bases__[0].__name__ == 'object'
# len(inspect.Parameter.empty.__mro__) == 2
#
# The Parameter.empty sentinel is implemented as a class object, not an
# instance of some sentinel class. New to extra139.
# ---------------------------------------------------------------------------

table inspect_extra139.parameter_empty_identity:
  description: "inspect.Parameter.empty: is a class (type), __name__=='_empty' len 6, __module__ len 7, MRO len 2; wave 267; new to extra139"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpe139

  columns: [id, function, args, expected, description]
  rows:
    - [pe_class_eq_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a class object (isinstance(empty, type) is True), not an instance; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra139"]
    - [pe_class_len_eq_4,
       "Parameter.empty.__class__.__name__.__len__",
       [],
       4,
       "inspect.Parameter.empty.__class__.__name__.__len__() == 4 — __class__.__name__ is 'type' which has 4 characters; len('type') == 4; new to extra139"]
    - [pe_name_eq__empty,
       "Parameter.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — the sentinel class's __name__ is '_empty' (with underscore prefix, a private implementation detail); str.__eq__('_empty') returns True; new to extra139"]
    - [pe_name_len_eq_6,
       "Parameter.empty.__name__.__len__",
       [],
       6,
       "inspect.Parameter.empty.__name__.__len__() == 6 — __name__ is '_empty' which has 6 characters; len('_empty') == 6; new to extra139"]
    - [pe_module_eq_inspect,
       "Parameter.empty.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.empty.__module__.__eq__('inspect') == True — _empty is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra139"]
    - [pe_module_len_eq_7,
       "Parameter.empty.__module__.__len__",
       [],
       7,
       "inspect.Parameter.empty.__module__.__len__() == 7 — __module__ is 'inspect' which has 7 characters; len('inspect') == 7; new to extra139"]
    - [pe_qualname_eq__empty,
       "Parameter.empty.__qualname__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__qualname__.__eq__('_empty') == True — _empty is a module-level class; its __qualname__ matches __name__ exactly: '_empty'; str.__eq__('_empty') returns True; new to extra139"]
    - [pe_bases_0_eq_object,
       "Parameter.empty.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.empty.__bases__[0].__name__.__eq__('object') == True — _empty directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra139"]
    - [pe_mro_len_eq_2,
       "Parameter.empty.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.empty.__mro__.__len__() == 2 — _empty's MRO is [_empty, object]; len(__mro__) is 2; new to extra139"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments — class identity
#
# Wave 267 theme: inspect.BoundArguments — Python class identity.
#
# inspect.BoundArguments.__class__.__name__ == 'type'
# inspect.BoundArguments.__name__ == 'BoundArguments' (len 14)
# inspect.BoundArguments.__module__ == 'inspect' (len 7)
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
# len(inspect.BoundArguments.__mro__) == 2
#
# BoundArguments is a Python class used to represent the arguments bound
# by Signature.bind() and Signature.bind_partial(). New to extra139.
# ---------------------------------------------------------------------------

table inspect_extra139.boundarguments_class_identity:
  description: "inspect.BoundArguments: Python class (type), __name__ len 14, __module__ len 7, MRO len 2; wave 267; new to extra139"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectba139

  columns: [id, function, args, expected, description]
  rows:
    - [ba_class_eq_type,
       "BoundArguments.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a Python class defined in Lib/inspect.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra139"]
    - [ba_name_eq,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — the class __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra139"]
    - [ba_name_len_eq_14,
       "BoundArguments.__name__.__len__",
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — __name__ is 'BoundArguments' which has 14 characters; len('BoundArguments') == 14; new to extra139"]
    - [ba_module_eq_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra139"]
    - [ba_module_len_eq_7,
       "BoundArguments.__module__.__len__",
       [],
       7,
       "inspect.BoundArguments.__module__.__len__() == 7 — __module__ is 'inspect' which has 7 characters; len('inspect') == 7; new to extra139"]
    - [ba_bases_0_eq_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra139"]
    - [ba_mro_len_eq_2,
       "BoundArguments.__mro__.__len__",
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — BoundArguments's MRO is [BoundArguments, object]; len(__mro__) is 2; new to extra139"]

# ---------------------------------------------------------------------------
