table inspect_extra139.module_doc:
  description: "inspect.__doc__: class str, len 1299; wave 267; new to extra139"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectdoc139

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_eq_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.__doc__.__class__.__name__.__eq__('str') == True — the inspect module docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra139"]
    - [doc_len_eq_1299,
       "__doc__.__len__",
       [],
       1299,
       "inspect.__doc__.__len__() == 1299 — the inspect module docstring has 1299 characters; len(__doc__) == 1299; verified with Python 3.14.3; new to extra139"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra139
# ---------------------------------------------------------------------------

invariant inspect_extra139.parameter_empty_is_class:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — the empty sentinel is itself a class object; wave 267; new to extra139"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra139.parameter_empty_name:
  description: "inspect.Parameter.empty.__name__ == '_empty' — the sentinel class is named '_empty' in Lib/inspect.py; wave 267; new to extra139"
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra139.parameter_empty_mro_len:
  description: "len(inspect.Parameter.empty.__mro__) == 2 — MRO is [_empty, object]; wave 267; new to extra139"
  kind: python_call_eq
  function: Parameter.empty.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra139.boundarguments_name_len:
  description: "len(inspect.BoundArguments.__name__) == 14 — __name__ is 'BoundArguments'; wave 267; new to extra139"
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra139.boundarguments_init_argcount:
  description: "inspect.BoundArguments.__init__.__code__.co_argcount == 3 — takes self, signature, arguments; wave 267; new to extra139"
  kind: python_call_eq
  function: BoundArguments.__init__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

