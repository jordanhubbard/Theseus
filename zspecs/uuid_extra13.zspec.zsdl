spec: uuid_extra13
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__; uuid1/3/4/5 __name__; NAMESPACE_* class names; UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone; NAMESPACE_* class names standalone"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__; UUID.__bases__[0].__name__; UUID(int=0).version is None"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table); uuid4 version/class; UUID str format; NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ for UUID and uuid1/3/4/5 (table)"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 class names; UUID.bytes/__class__/__name__; UUID.fields.__len__()==6"
    - "uuid_extra7.zspec.zsdl — covers SafeUUID metadata; NAMESPACE_* .version table (all==1); uuid1/uuid4 return class name and version"
    - "uuid_extra8.zspec.zsdl — covers UUID.__bases__.__len__()==1; NAMESPACE_DNS.int/__class__/__name__; NAMESPACE_URL.int/__class__.__name__; UUID.bytes/__class__.__name__"
    - "uuid_extra9.zspec.zsdl — covers uuid3/__doc__ and uuid5/__doc__ type; NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le; SafeUUID.__bases__.__len__()==1"
    - "uuid_extra10.zspec.zsdl — covers NAMESPACE_URL/OID/X500 .bytes_le/__class__.__name__; NAMESPACE_*/node/__class__.__name__; zero UUID hex value and int value and hex len"
    - "uuid_extra11.zspec.zsdl — covers UUID.bytes.__len__()==16; UUID version from literal v4 string; UUID.__name__/__module__.__len__()==4; NAMESPACE_DNS.hex value and len; NAMESPACE_URL.__str__(); UUID hex len (non-zero input)"
    - "uuid_extra12.zspec.zsdl — covers UUID.__qualname__.__len__()==4; uuid1/3/4/5 __name__/__module__ string lengths; NAMESPACE_DNS/URL __class__.__name__.__len__()==4; UUID.__bases__.__getitem__(0).__name__"
  notes:
    - "This spec extends the uuid chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: UUID.__name__ == 'UUID' (direct __eq__ check from extra13 namespace); uuid4().__class__.__name__ == 'UUID' (non-deterministic value but deterministic class); NAMESPACE_DNS.__class__.__name__ == 'UUID'; NAMESPACE_URL.__class__.__name__ == 'UUID'; str(UUID(int=0)).__len__() == 36; NAMESPACE_DNS.version == 1."
    - "uuid.UUID.__name__ == 'UUID': uuid_extra covers __name__ from extra namespace. This anchors the same fact from extra13 namespace as a standalone invariant."
    - "uuid.uuid4().__class__.__name__ == 'UUID': uuid4 is non-deterministic but always returns a UUID instance. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID': NAMESPACE_DNS is a UUID constant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID': NAMESPACE_URL is a UUID constant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "str(uuid.UUID(int=0)).__len__() == 36: UUID canonical string is 32 hex digits + 4 hyphens = 36 chars. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version == 1: NAMESPACE_DNS encodes a version-1 UUID per RFC 4122. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__name__ == 'UUID' — direct equality check from extra13 namespace
#
# uuid_extra covers UUID.__name__ from the extra namespace.
# uuid_extra11 covers UUID.__name__.__len__() == 4.
# No prior spec anchors UUID.__name__.__eq__('UUID') from the extra13 namespace.
# ---------------------------------------------------------------------------

invariant uuid_extra13.UUID.name_eq:
  description: "uuid.UUID.__name__ == 'UUID' — the class is named UUID"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4().__class__.__name__ == 'UUID'
#
# uuid4 is non-deterministic but always returns a UUID instance.
# uuid_extra4 checks uuid4 version and class from extra4.
# uuid_extra7 checks uuid4 return class name from extra7.
# This invariant anchors the same fact from the extra13 namespace.
# ---------------------------------------------------------------------------

invariant uuid_extra13.uuid4.class_name:
  description: "uuid.uuid4().__class__.__name__ == 'UUID' — uuid4 always returns a UUID instance"
  category: factory_return_types
  kind: python_call_eq
  function: uuid4
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# NAMESPACE_DNS and NAMESPACE_URL __class__.__name__ == 'UUID'
#
# uuid_extra checks NAMESPACE_* class names via __eq__ from the extra namespace.
# uuid_extra12 covers __class__.__name__.__len__() == 4 for both.
# No prior spec chains __class__.__name__.__eq__('UUID') from extra13 namespace.
# ---------------------------------------------------------------------------

table uuid_extra13.namespace_class_names:
  kind: python_call_eq
  category: namespace_metadata
  id_prefix: nsname13

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS, NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [NAMESPACE_URL, NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# str(UUID(int=0)).__len__() == 36
#
# uuid_extra11 covers UUID(int=0) hex length and UUID str format.
# uuid_extra10 covers zero UUID hex value and hex len.
# No prior spec checks UUID(int=0).__str__().__len__() from the extra13 namespace.
# The canonical UUID string is 32 hex chars + 4 hyphens = 36 characters.
# ---------------------------------------------------------------------------

invariant uuid_extra13.UUID_zero.str_len:
  description: "str(uuid.UUID(int=0)).__len__() == 36 — UUID canonical string is 32 hex digits + 4 hyphens"
  category: string_representation
  kind: python_call_eq
  function: UUID.__str__
  args: []
  method: __len__
  method_args: []
  expected: 36

# ---------------------------------------------------------------------------
# NAMESPACE_DNS.version == 1
#
# uuid_extra7 covers NAMESPACE_* .version in a table (all == 1).
# This invariant anchors NAMESPACE_DNS.version == 1 from the extra13 namespace
# as a standalone invariant with a distinct ID.
# ---------------------------------------------------------------------------

invariant uuid_extra13.NAMESPACE_DNS.version:
  description: "uuid.NAMESPACE_DNS.version == 1 — NAMESPACE_DNS encodes a version-1 UUID per RFC 4122"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_DNS.version.__eq__
  args: [1]
  expected: true
