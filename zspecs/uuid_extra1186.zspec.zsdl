spec: uuid_extra1186
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID.__dict__/__mro__/__bases__ class names (mappingproxy/tuple/tuple), uuid.SafeUUID.__dict__/__mro__/__bases__ class names (mappingproxy/tuple/tuple), uuid.NAMESPACE_OID/X500 __class__.__name__/__module__/__qualname__, and MRO/bases lengths for UUID and SafeUUID"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1186.uuid_class_dict_mro_bases:
  description: "uuid.UUID __dict__/__mro__/__bases__ class names confirming mappingproxy and tuple types"
  kind: python_call_eq
  category: uuid_class_dict_mro_bases
  id_prefix: uu1186dm
  columns: [id, function, args, expected]
  rows:
    - [uu1186dm001, uuid.UUID.__dict__.__class__.__name__.__eq__,                 ["mappingproxy"],  true]
    - [uu1186dm002, uuid.UUID.__dict__.__class__.__qualname__.__eq__,             ["mappingproxy"],  true]
    - [uu1186dm003, uuid.UUID.__dict__.__class__.__module__.__eq__,               ["builtins"],      true]
    - [uu1186dm004, uuid.UUID.__mro__.__class__.__name__.__eq__,                  ["tuple"],         true]
    - [uu1186dm005, uuid.UUID.__mro__.__class__.__qualname__.__eq__,              ["tuple"],         true]
    - [uu1186dm006, uuid.UUID.__mro__.__class__.__module__.__eq__,                ["builtins"],      true]
    - [uu1186dm007, uuid.UUID.__bases__.__class__.__name__.__eq__,                ["tuple"],         true]
    - [uu1186dm008, uuid.UUID.__bases__.__class__.__module__.__eq__,              ["builtins"],      true]
    - [uu1186dm009, uuid.UUID.__mro__.__len__,                                    [],                2]
    - [uu1186dm010, uuid.UUID.__bases__.__len__,                                  [],                1]

table uuid_extra1186.safeuuid_class_dict_mro_bases:
  description: "uuid.SafeUUID __dict__/__mro__/__bases__ class names and lengths"
  kind: python_call_eq
  category: safeuuid_class_dict_mro_bases
  id_prefix: uu1186sm
  columns: [id, function, args, expected]
  rows:
    - [uu1186sm001, uuid.SafeUUID.__dict__.__class__.__name__.__eq__,             ["mappingproxy"],  true]
    - [uu1186sm002, uuid.SafeUUID.__dict__.__class__.__qualname__.__eq__,         ["mappingproxy"],  true]
    - [uu1186sm003, uuid.SafeUUID.__dict__.__class__.__module__.__eq__,           ["builtins"],      true]
    - [uu1186sm004, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,              ["tuple"],         true]
    - [uu1186sm005, uuid.SafeUUID.__mro__.__class__.__qualname__.__eq__,          ["tuple"],         true]
    - [uu1186sm006, uuid.SafeUUID.__mro__.__class__.__module__.__eq__,            ["builtins"],      true]
    - [uu1186sm007, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,            ["tuple"],         true]
    - [uu1186sm008, uuid.SafeUUID.__bases__.__class__.__module__.__eq__,          ["builtins"],      true]
    - [uu1186sm009, uuid.SafeUUID.__mro__.__len__,                                [],                3]
    - [uu1186sm010, uuid.SafeUUID.__bases__.__len__,                              [],                1]

table uuid_extra1186.namespace_oid_x500_class_attrs:
  description: "uuid.NAMESPACE_OID and uuid.NAMESPACE_X500 __class__.__name__/__qualname__/__module__ identity"
  kind: python_call_eq
  category: namespace_oid_x500_class_attrs
  id_prefix: uu1186nx
  columns: [id, function, args, expected]
  rows:
    - [uu1186nx001, uuid.NAMESPACE_OID.__class__.__name__.__eq__,                 ["UUID"],   true]
    - [uu1186nx002, uuid.NAMESPACE_OID.__class__.__qualname__.__eq__,             ["UUID"],   true]
    - [uu1186nx003, uuid.NAMESPACE_OID.__class__.__module__.__eq__,               ["uuid"],   true]
    - [uu1186nx004, uuid.NAMESPACE_X500.__class__.__name__.__eq__,                ["UUID"],   true]
    - [uu1186nx005, uuid.NAMESPACE_X500.__class__.__qualname__.__eq__,            ["UUID"],   true]
    - [uu1186nx006, uuid.NAMESPACE_X500.__class__.__module__.__eq__,              ["uuid"],   true]
    - [uu1186nx007, uuid.NAMESPACE_OID.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [uu1186nx008, uuid.NAMESPACE_X500.__class__.__module__.__class__.__name__.__eq__, ["str"], true]
    - [uu1186nx009, uuid.UUID.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],  true]
