spec: uuid_extra402
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID.fields.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__name__ == 'fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__name__ == 'bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__name__ == 'time'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__name__ == 'clock_seq'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID is a pure-Python class. Its computed attributes (fields, bytes_le, time, clock_seq, etc.) are all Python property objects. Accessing them on the class (not an instance) returns the property descriptor. The fget attribute of each property is the underlying getter function, whose __name__ matches the property name. This is the standard pattern for Python properties defined with @property in a class body."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID property descriptors: fields, bytes_le, time, clock_seq
#
# Wave 402 theme: uuid.UUID property identity — descriptor type and fget name.
#
# uuid.UUID is a pure-Python class. Its computed read-only attributes are
# implemented as Python property objects using the @property decorator.
# When accessed on the class (not an instance), Python returns the property
# descriptor itself rather than invoking the getter. The descriptor's
# __class__.__name__ is 'property', and its .fget attribute holds the
# getter function whose __name__ matches the property's attribute name.
#
# Covered attributes:
#   fields    — returns a tuple of the six UUID field integers
#   bytes_le  — returns the UUID as bytes in little-endian order
#   time      — returns the 60-bit timestamp field
#   clock_seq — returns the 14-bit clock sequence field
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra402.property_class_names:
  description: "uuid.UUID.fields, bytes_le, time, clock_seq are property objects — accessing computed UUID attributes on the class returns the property descriptor; __class__.__name__ == 'property' for all four; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidpc402

  columns: [id, function, args, expected]
  rows:
    - [fields_class,    UUID.fields.__class__.__name__.__eq__,    ["property"],  true]
    - [bytes_le_class,  UUID.bytes_le.__class__.__name__.__eq__,  ["property"],  true]
    - [time_class,      UUID.time.__class__.__name__.__eq__,      ["property"],  true]
    - [clock_seq_class, UUID.clock_seq.__class__.__name__.__eq__, ["property"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID property fget names
#
# Each property's .fget is the getter function. Its __name__ matches the
# attribute name used to define the property in the class body.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra402.property_fget_names:
  description: "uuid.UUID property fget.__name__ matches the property attribute name — fget is the getter function defined with @property; __name__ is the bare function name matching the attribute; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfg402

  columns: [id, function, args, expected]
  rows:
    - [fields_fget_name,    UUID.fields.fget.__name__.__eq__,    ["fields"],    true]
    - [bytes_le_fget_name,  UUID.bytes_le.fget.__name__.__eq__,  ["bytes_le"],  true]
    - [time_fget_name,      UUID.time.fget.__name__.__eq__,      ["time"],      true]
    - [clock_seq_fget_name, UUID.clock_seq.fget.__name__.__eq__, ["clock_seq"], true]
