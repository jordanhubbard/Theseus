spec: abc_extra217
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — verified with Python 3.14.3."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — verified with Python 3.14.3."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — verified with Python 3.14.3."
    - "abc.ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' — defined on ABCMeta itself (not inherited from type); verified with Python 3.14.3."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — verified with Python 3.14.3."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — verified with Python 3.14.3."
    - "abc.ABC.__qualname__ == 'ABC' — verified with Python 3.14.3."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' — verified with Python 3.14.3."
    - "abc.abstractmethod.__name__.__startswith__('abstract') == True — verified with Python 3.14.3."
    - "abc.ABCMeta.__name__.__endswith__('Meta') == True — verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method __qualname__ contracts — extra217 namespace
#
# register, __instancecheck__, __subclasscheck__, __prepare__ all have
# __qualname__ of the form 'ABCMeta.<method>'.
# ---------------------------------------------------------------------------

table abc_extra217.abcmeta_method_qualnames:
  description: "abc.ABCMeta method __qualname__.__eq__() checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc217abcmetamethqualname

  columns: [id, function, args, expected, description]
  rows:
    - [register_qualname,         ABCMeta.register.__qualname__.__eq__,         ["ABCMeta.register"],         true, "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'; verified with Python 3.14.3"]
    - [instancecheck_qualname,    ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true, "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'; verified with Python 3.14.3"]
    - [subclasscheck_qualname,    ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true, "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'; verified with Python 3.14.3"]
    - [prepare_qualname,          ABCMeta.__prepare__.__qualname__.__eq__,       ["ABCMeta.__prepare__"],       true, "abc.ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (defined on ABCMeta, not inherited from type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module-level class and function __qualname__ — extra217 namespace
#
# abstractmethod, get_cache_token, ABC, ABCMeta all have __qualname__ equal
# to their simple names.
# ---------------------------------------------------------------------------

table abc_extra217.module_level_qualnames:
  description: "abc module-level class and function __qualname__.__eq__() checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc217modlevelqualname

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_qualname,  abstractmethod.__qualname__.__eq__,  ["abstractmethod"],  true, "abc.abstractmethod.__qualname__ == 'abstractmethod'; verified with Python 3.14.3"]
    - [get_cache_token_qualname, get_cache_token.__qualname__.__eq__,  ["get_cache_token"], true, "abc.get_cache_token.__qualname__ == 'get_cache_token'; verified with Python 3.14.3"]
    - [abc_qualname,             ABC.__qualname__.__eq__,             ["ABC"],             true, "abc.ABC.__qualname__ == 'ABC'; verified with Python 3.14.3"]
    - [abcmeta_qualname,         ABCMeta.__qualname__.__eq__,         ["ABCMeta"],         true, "abc.ABCMeta.__qualname__ == 'ABCMeta'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc name predicate checks — extra217 namespace
#
# abstractmethod.__name__ starts with 'abstract'; ABCMeta.__name__ ends with 'Meta'.
# ---------------------------------------------------------------------------

invariant abc_extra217.abstractmethod_name_startswith_abstract:
  description: "abc.abstractmethod.__name__.__startswith__('abstract') == True; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__name__.__startswith__
  args: ["abstract"]
  expected: true

invariant abc_extra217.abcmeta_name_endswith_meta:
  description: "abc.ABCMeta.__name__.__endswith__('Meta') == True; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__endswith__
  args: ["Meta"]
  expected: true

