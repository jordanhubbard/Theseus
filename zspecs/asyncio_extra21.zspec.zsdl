spec: asyncio_extra21
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl and prior extras through asyncio_extra20.zspec.zsdl."
    - "asyncio_extra19 covers: exception base class __getitem__ path; exception __module__ table."
    - "asyncio_extra20 covers: coroutine/utility function __module__ table; synchronisation class __module__ table; Task/BoundedSemaphore/AbstractEventLoop base class standalone invariants."
    - "NOT yet covered in any prior spec: asyncio exception base name table via __getitem__ for CancelledError/TimeoutError/InvalidStateError/SendfileNotAvailableError/IncompleteReadError/LimitOverrunError in extra21 namespace."
    - "NOT yet covered: asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError' as standalone extra21-namespace invariant."
    - "NOT yet covered: asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception' as standalone extra21-namespace invariant."
    - "NOT yet covered: asyncio exception __name__ length table in extra21 namespace."
    - "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' — CancelledError is a direct BaseException subclass since Python 3.8."
    - "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' — TimeoutError is a built-in OSError alias."
    - "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception' — inherits directly from Exception."
    - "asyncio.SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError' — raised when os.sendfile is not available."
    - "asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError' — raised when end-of-stream is reached before reading enough bytes."
    - "asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception' — raised when the buffer limit is exceeded during stream reads."
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py."
    - "asyncio.TimeoutError.__module__ == 'builtins' — TimeoutError is a built-in type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception base name table — __getitem__ path in extra21 namespace
#
# asyncio_extra19 checks some exception base class names. This table provides
# a unified extra21-namespace view of all six public asyncio exception base
# classes using the __bases__.__getitem__ path. The base hierarchy is varied:
# CancelledError -> BaseException, TimeoutError -> OSError (via builtins),
# InvalidStateError/LimitOverrunError -> Exception, and
# SendfileNotAvailableError -> RuntimeError, IncompleteReadError -> EOFError.
# ---------------------------------------------------------------------------

table asyncio_extra21.exception_base_names:
  description: "Direct base class __name__ for asyncio exception types"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excbase21

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,             CancelledError.__bases__.__getitem__,             [0], "BaseException"]
    - [TimeoutError,               TimeoutError.__bases__.__getitem__,               [0], "OSError"]
    - [InvalidStateError,          InvalidStateError.__bases__.__getitem__,          [0], "Exception"]
    - [SendfileNotAvailableError,  SendfileNotAvailableError.__bases__.__getitem__,  [0], "RuntimeError"]
    - [IncompleteReadError,        IncompleteReadError.__bases__.__getitem__,        [0], "EOFError"]
    - [LimitOverrunError,          LimitOverrunError.__bases__.__getitem__,          [0], "Exception"]

# ---------------------------------------------------------------------------
# IncompleteReadError.__bases__[0].__name__ == 'EOFError' — standalone
#
# asyncio.IncompleteReadError is raised by asyncio.StreamReader when EOF is
# reached before the requested number of bytes are available. Its base class
# EOFError (a built-in) makes it semantically distinct from the other asyncio
# exceptions. No prior spec confirms this base class name as a standalone
# extra21-namespace invariant.
# ---------------------------------------------------------------------------

invariant asyncio_extra21.IncompleteReadError.base_is_EOFError:
  description: "asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError' — stream EOF exception"
  category: class_hierarchy
  kind: python_call_eq
  function: IncompleteReadError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["EOFError"]
  expected: true

# ---------------------------------------------------------------------------
# LimitOverrunError.__bases__[0].__name__ == 'Exception' — standalone
#
# asyncio.LimitOverrunError is raised when the buffer limit is exceeded while
# reading from a StreamReader. It inherits directly from Exception, placing it
# alongside InvalidStateError in the asyncio exception hierarchy. No prior spec
# checks LimitOverrunError's base class name as a standalone invariant.
# ---------------------------------------------------------------------------

invariant asyncio_extra21.LimitOverrunError.base_is_Exception:
  description: "asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception' — stream buffer overflow"
  category: class_hierarchy
  kind: python_call_eq
  function: LimitOverrunError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError.__module__ — standalone extra21-namespace invariant
#
# asyncio_extra19 covers exception __module__ in a table. This standalone
# invariant provides an independent extra21-namespace anchor confirming that
# CancelledError is defined in asyncio.exceptions rather than builtins,
# even though CancelledError ultimately inherits from BaseException.
# ---------------------------------------------------------------------------

invariant asyncio_extra21.CancelledError.module_eq:
  description: "asyncio.CancelledError.__module__ == 'asyncio.exceptions'"
  category: class_modules
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

# ---------------------------------------------------------------------------
# SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError' — standalone
#
# asyncio.SendfileNotAvailableError is raised when os.sendfile is not
# available for the given socket type. It inherits from RuntimeError, making
# it distinct from the stream-related exceptions. This standalone invariant
# provides an independent extra21-namespace anchor for this base class.
# ---------------------------------------------------------------------------

invariant asyncio_extra21.SendfileNotAvailableError.base_is_RuntimeError:
  description: "asyncio.SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError' — sendfile platform fallback"
  category: class_hierarchy
  kind: python_call_eq
  function: SendfileNotAvailableError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["RuntimeError"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError.__bases__[0].__name__ == 'BaseException' — standalone
#
# Since Python 3.8, asyncio.CancelledError was changed to inherit directly
# from BaseException rather than Exception. This is a notable design decision
# that allows cancellation to propagate through exception handlers that only
# catch Exception. This standalone invariant confirms that behavioural contract.
# ---------------------------------------------------------------------------

invariant asyncio_extra21.CancelledError.base_is_BaseException:
  description: "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' — cancellation propagates past except Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: CancelledError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseException"]
  expected: true
