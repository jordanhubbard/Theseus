spec: tracemalloc_extra7
version: ">=3.4"
backend: python_module(tracemalloc)

docs: https://docs.python.org/3/library/tracemalloc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tracemalloc.html — Python tracemalloc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tracemalloc.py"
    - "CPython source: Modules/_tracemalloc.c"
  notes:
    - "This spec extends tracemalloc_extra6.zspec.zsdl."
    - "tracemalloc_extra6 covers: class __name__ length table; class __name__ last-char table; take_snapshot/__class__.__name__=='function'; get_object_traceback/__class__.__name__=='function'; get_object_traceback.__name__.__len__()==20; Traceback.format.__name__=='format'; Traceback.format.__qualname__=='Traceback.format'."
    - "tracemalloc_extra5 covers: tracemalloc.__name__; Traceback/DomainFilter __bases__; Snapshot method __name__/__class__.__name__; DomainFilter.__module__ standalone."
    - "tracemalloc_extra4 covers: function __qualname__ and __module__ tables; DomainFilter.__qualname__; get_traceback_limit return type."
    - "tracemalloc_extra3 covers: class __bases__ and class __qualname__ for all seven classes."
    - "tracemalloc_extra2 covers: class __name__ and class __module__ for all classes including DomainFilter."
    - "This spec covers: start/__name__; stop/__name__; is_tracing/__name__; get_traced_memory/__name__; take_snapshot/__name__; Filter/__qualname__; Snapshot/__qualname__; Statistic/__qualname__; __module__ table for start/stop/is_tracing/get_traced_memory/take_snapshot; is_tracing().__class__.__name__=='bool'."
    - "tracemalloc.start.__module__ == '_tracemalloc' — start/stop/is_tracing/get_traced_memory are C builtins from _tracemalloc."
    - "tracemalloc.take_snapshot.__module__ == 'tracemalloc' — take_snapshot is a pure-Python function defined in tracemalloc.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ standalone invariants
#
# tracemalloc.zspec.zsdl and tracemalloc_extra cover function __name__ tables.
# These standalone invariants re-anchor start/stop/is_tracing/get_traced_memory/
# take_snapshot under the extra7 namespace.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra7.start.name:
  description: "tracemalloc.start.__name__ == 'start' — C builtin function name"
  category: function_attrs
  kind: python_call_eq
  function: start.__name__.__eq__
  args: ["start"]
  expected: true

invariant tracemalloc_extra7.stop.name:
  description: "tracemalloc.stop.__name__ == 'stop' — C builtin function name"
  category: function_attrs
  kind: python_call_eq
  function: stop.__name__.__eq__
  args: ["stop"]
  expected: true

invariant tracemalloc_extra7.is_tracing.name:
  description: "tracemalloc.is_tracing.__name__ == 'is_tracing' — C builtin function name"
  category: function_attrs
  kind: python_call_eq
  function: is_tracing.__name__.__eq__
  args: ["is_tracing"]
  expected: true

invariant tracemalloc_extra7.get_traced_memory.name:
  description: "tracemalloc.get_traced_memory.__name__ == 'get_traced_memory' — C builtin function name"
  category: function_attrs
  kind: python_call_eq
  function: get_traced_memory.__name__.__eq__
  args: ["get_traced_memory"]
  expected: true

invariant tracemalloc_extra7.take_snapshot.name:
  description: "tracemalloc.take_snapshot.__name__ == 'take_snapshot' — pure-Python function name"
  category: function_attrs
  kind: python_call_eq
  function: take_snapshot.__name__.__eq__
  args: ["take_snapshot"]
  expected: true

# ---------------------------------------------------------------------------
# Class __qualname__ standalone invariants
#
# tracemalloc_extra3 covers __qualname__ for all seven classes in a table.
# These standalone invariants re-anchor Filter/Snapshot/Statistic under the
# extra7 namespace for independent coverage.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra7.Filter.qualname:
  description: "tracemalloc.Filter.__qualname__ == 'Filter' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: Filter.__qualname__.__eq__
  args: ["Filter"]
  expected: true

invariant tracemalloc_extra7.Snapshot.qualname:
  description: "tracemalloc.Snapshot.__qualname__ == 'Snapshot' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: Snapshot.__qualname__.__eq__
  args: ["Snapshot"]
  expected: true

invariant tracemalloc_extra7.Statistic.qualname:
  description: "tracemalloc.Statistic.__qualname__ == 'Statistic' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: Statistic.__qualname__.__eq__
  args: ["Statistic"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — five module-level functions
#
# tracemalloc_extra4 covers function __module__ in a table for multiple functions.
# This table re-anchors the five key functions under the extra7 namespace.
# Note: start/stop/is_tracing/get_traced_memory are C builtins (__module__=='_tracemalloc').
# take_snapshot is pure-Python (__module__=='tracemalloc').
# ---------------------------------------------------------------------------

table tracemalloc_extra7.func_modules:
  kind: python_call_eq
  category: module_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [tracemalloc_extra7.func_modules.start_module,
       start.__module__.__eq__,
       ["_tracemalloc"],
       true,
       "tracemalloc.start.__module__ == '_tracemalloc' — C builtin from _tracemalloc"]
    - [tracemalloc_extra7.func_modules.stop_module,
       stop.__module__.__eq__,
       ["_tracemalloc"],
       true,
       "tracemalloc.stop.__module__ == '_tracemalloc' — C builtin from _tracemalloc"]
    - [tracemalloc_extra7.func_modules.is_tracing_module,
       is_tracing.__module__.__eq__,
       ["_tracemalloc"],
       true,
       "tracemalloc.is_tracing.__module__ == '_tracemalloc' — C builtin from _tracemalloc"]
    - [tracemalloc_extra7.func_modules.get_traced_memory_module,
       get_traced_memory.__module__.__eq__,
       ["_tracemalloc"],
       true,
       "tracemalloc.get_traced_memory.__module__ == '_tracemalloc' — C builtin from _tracemalloc"]
    - [tracemalloc_extra7.func_modules.take_snapshot_module,
       take_snapshot.__module__.__eq__,
       ["tracemalloc"],
       true,
       "tracemalloc.take_snapshot.__module__ == 'tracemalloc' — pure-Python function"]

# ---------------------------------------------------------------------------
# is_tracing() return type check
#
# tracemalloc.is_tracing() returns a bool. No prior tracemalloc spec verifies
# the class name of the return value. This invariant confirms the return type
# is 'bool' by calling is_tracing() with no args, then accessing __class__
# via method, then chaining __name__.__eq__ to compare to 'bool'.
# is_tracing() returns False when tracing is not active (default state).
# ---------------------------------------------------------------------------

invariant tracemalloc_extra7.is_tracing.return_type_is_bool:
  description: "tracemalloc.is_tracing().__class__.__name__ == 'bool' — is_tracing returns a bool"
  category: return_type
  kind: python_call_eq
  function: is_tracing
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bool"]
  expected: true
