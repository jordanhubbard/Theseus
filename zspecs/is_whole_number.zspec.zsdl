spec: is_whole_number
version: ">=1.1.0"
backend: node(is-whole-number)

docs: https://www.npmjs.com/package/is-whole-number

provenance:
  derived_from:
    - "is-whole-number README — https://www.npmjs.com/package/is-whole-number"
    - "Test vectors verified with is-whole-number via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-whole-number source"
  notes:
    - "is-whole-number is an npm package. Install: npm install is-whole-number"
    - "Returns true if the input is a whole number (integer >= 0), false otherwise."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_whole_number.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: iswhole

  columns: [id, args, expected]
  rows:
    - [integer,  [3],   true]
    - [float,    [3.5], false]
    - [zero,     [0],   true]
    - [neg,      [-1],  false]
