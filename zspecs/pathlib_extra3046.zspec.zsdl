spec: pp3046
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (pp3046): __enter__, __exit__, __aenter__ dict-presence for pathlib types."
    - "pathlib path objects represent filesystem paths; none define __enter__ or __exit__ in their own __dict__."
    - "pathlib.Path supports use as a context manager at runtime (via inheritance), but defines no __enter__ in its own __dict__."
    - "None of the pathlib path classes define __aenter__ in their own __dict__; async context manager support is absent."
    - "pathlib.PosixPath is available on macOS/Darwin 25.4.0."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# pathlib path types do not define __enter__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table pp3046.enter:
  description: "pathlib types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp3046
  columns: [id, function, args, expected]
  rows:
    - ["pp3046001", operator.contains, [pathlib.PurePath.__dict__,        "__enter__"], false]
    - ["pp3046002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__enter__"], false]
    - ["pp3046003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__enter__"], false]
    - ["pp3046004", operator.contains, [pathlib.Path.__dict__,            "__enter__"], false]
    - ["pp3046005", operator.contains, [pathlib.PosixPath.__dict__,       "__enter__"], false]

