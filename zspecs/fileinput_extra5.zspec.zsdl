spec: fileinput_extra5
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
    - "fileinput_extra4.zspec.zsdl — covers __name__ length checks; __name__ is-str checks; __name__ first-character checks for input/filename/FileInput/hook_compressed"
  notes:
    - "This spec extends fileinput.zspec.zsdl and all prior fileinput_extra specs through fileinput_extra4.zspec.zsdl."
    - "fileinput_extra2 covers __module__ for all module-level functions and FileInput.__qualname__/__bases__[0].__name__ via standalone invariants."
    - "This spec adds new axes: __qualname__ equality table for input/filename/lineno/filelineno/fileno/isfirstline/isstdin/nextfile/close; __qualname__ length standalone checks; FileInput.__bases__[0].__name__ anchored in the extra5 namespace."
    - "fileinput.input.__qualname__ == 'input'; fileinput.filename.__qualname__ == 'filename'; fileinput.lineno.__qualname__ == 'lineno'."
    - "fileinput.filelineno.__qualname__ == 'filelineno'; fileinput.fileno.__qualname__ == 'fileno'; fileinput.isfirstline.__qualname__ == 'isfirstline'."
    - "fileinput.isstdin.__qualname__ == 'isstdin'; fileinput.nextfile.__qualname__ == 'nextfile'; fileinput.close.__qualname__ == 'close'."
    - "fileinput.FileInput.__bases__[0].__name__ == 'object' — FileInput is a plain class with no base other than object; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ equality table
#
# All module-level fileinput functions have __qualname__ equal to their plain
# name. fileinput_extra2 covers __qualname__ for hook_compressed and
# hook_encoded as standalone invariants; no prior spec covers the nine
# functions in this table via a grouped equality table.
# ---------------------------------------------------------------------------

table fileinput_extra5.function_qualnames:
  description: "__qualname__ equals the plain function name for fileinput module-level functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname5

  columns: [id, function, args, expected]
  rows:
    - [input,       input.__qualname__.__eq__,       ["input"],       true]
    - [filename,    filename.__qualname__.__eq__,    ["filename"],    true]
    - [lineno,      lineno.__qualname__.__eq__,      ["lineno"],      true]
    - [filelineno,  filelineno.__qualname__.__eq__,  ["filelineno"],  true]
    - [fileno,      fileno.__qualname__.__eq__,      ["fileno"],      true]
    - [isfirstline, isfirstline.__qualname__.__eq__, ["isfirstline"], true]
    - [isstdin,     isstdin.__qualname__.__eq__,     ["isstdin"],     true]
    - [nextfile,    nextfile.__qualname__.__eq__,    ["nextfile"],    true]
    - [close,       close.__qualname__.__eq__,       ["close"],       true]

# ---------------------------------------------------------------------------
# Function __module__ equality table
#
# fileinput_extra2 covers __module__ as standalone invariants for each
# function. This table provides a grouped cross-check in the extra5 namespace
# confirming all nine functions are defined in the fileinput module.
# ---------------------------------------------------------------------------

table fileinput_extra5.function_modules:
  description: "__module__ == 'fileinput' for module-level functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod5

  columns: [id, function, args, expected]
  rows:
    - [input,       input.__module__.__eq__,       ["fileinput"], true]
    - [filename,    filename.__module__.__eq__,    ["fileinput"], true]
    - [lineno,      lineno.__module__.__eq__,      ["fileinput"], true]
    - [filelineno,  filelineno.__module__.__eq__,  ["fileinput"], true]
    - [fileno,      fileno.__module__.__eq__,      ["fileinput"], true]
    - [isfirstline, isfirstline.__module__.__eq__, ["fileinput"], true]
    - [isstdin,     isstdin.__module__.__eq__,     ["fileinput"], true]
    - [nextfile,    nextfile.__module__.__eq__,    ["fileinput"], true]
    - [close,       close.__module__.__eq__,       ["fileinput"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — FileInput class and selected function qualnames
# ---------------------------------------------------------------------------

invariant fileinput_extra5.FileInput.base_is_object:
  description: "fileinput.FileInput.__bases__[0].__name__ == 'object' — FileInput has no explicit base; inherits object"
  category: class_hierarchy
  kind: python_call_eq
  function: "FileInput.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant fileinput_extra5.lineno.qualname_length:
  description: "fileinput.lineno.__qualname__.__len__() == 6 — 'lineno' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: lineno.__qualname__.__len__
  args: []
  expected: 6

invariant fileinput_extra5.filelineno.qualname_length:
  description: "fileinput.filelineno.__qualname__.__len__() == 10 — 'filelineno' has 10 characters"
  category: function_identity
  kind: python_call_eq
  function: filelineno.__qualname__.__len__
  args: []
  expected: 10

invariant fileinput_extra5.isfirstline.qualname_length:
  description: "fileinput.isfirstline.__qualname__.__len__() == 11 — 'isfirstline' has 11 characters"
  category: function_identity
  kind: python_call_eq
  function: isfirstline.__qualname__.__len__
  args: []
  expected: 11

invariant fileinput_extra5.isstdin.qualname_length:
  description: "fileinput.isstdin.__qualname__.__len__() == 7 — 'isstdin' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: isstdin.__qualname__.__len__
  args: []
  expected: 7

invariant fileinput_extra5.nextfile.qualname_length:
  description: "fileinput.nextfile.__qualname__.__len__() == 8 — 'nextfile' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: nextfile.__qualname__.__len__
  args: []
  expected: 8
