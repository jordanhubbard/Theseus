spec: decimal_extra150
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal class method __qualname__ values for mathematical and predicate methods: quantize, to_integral, sqrt, exp, ln, log10, fma, is_nan."
    - "All Decimal method qualnames follow the 'Decimal.<method>' pattern. The 'Decimal.' prefix is 8 characters."
    - "Qualname lengths: Decimal.exp (11), Decimal.fma (11), Decimal.ln (10), Decimal.sqrt (12), Decimal.log10 (13), Decimal.is_nan (14), Decimal.quantize (16), Decimal.to_integral (20)."
    - "Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16; 'Decimal.' (8) + 'quantize' (8) = 16). Decimal.to_integral.__qualname__ == 'Decimal.to_integral' (len=20; 'Decimal.' (8) + 'to_integral' (11) = 19... 'to_integral' has 11 chars? t-o-_-i-n-t-e-g-r-a-l = 11 chars; so len=8+11=19. Wait: verified string 'Decimal.to_integral' — D-e-c-i-m-a-l-.-t-o-_-i-n-t-e-g-r-a-l = 19 chars)."
    - "Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12). Decimal.exp.__qualname__ == 'Decimal.exp' (len=11). Decimal.ln.__qualname__ == 'Decimal.ln' (len=10). Decimal.log10.__qualname__ == 'Decimal.log10' (len=13). Decimal.fma.__qualname__ == 'Decimal.fma' (len=11). Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (len=14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal mathematical method __qualname__ values (group 1)
# Transcendental and rounding methods: quantize, to_integral, sqrt, exp, ln, log10
# 'Decimal.' prefix = 8 chars.
# ln = 10, exp = 11, sqrt = 12, log10 = 13, is_nan = 14, quantize = 16, to_integral = 19
# ---------------------------------------------------------------------------

table decimal_extra150.Decimal_math_method_qualnames:
  description: "decimal.Decimal mathematical method __qualname__ values: ln=10, exp=11, sqrt=12, log10=13, quantize=16, to_integral=19; all 'Decimal.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: decmathq150

  columns: [id, function, args, expected, description]
  rows:
    - [ln_qeq,          Decimal.ln.__qualname__.__eq__,          ["Decimal.ln"],          true, "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (len=10; 'Decimal.' (8) + 'ln' (2) = 10; the shortest qualname of the mathematical Decimal methods covered here; ln() computes the natural logarithm of the Decimal to the precision of the current context; raises InvalidOperation for negative numbers and zero)"]
    - [exp_qeq,         Decimal.exp.__qualname__.__eq__,         ["Decimal.exp"],         true, "decimal.Decimal.exp.__qualname__ == 'Decimal.exp' (len=11; 'Decimal.' (8) + 'exp' (3) = 11; exp() computes e raised to the power of this Decimal value using the current context precision; tied with Decimal.fma at qualname length 11; for exact results with integer powers use ** operator instead)"]
    - [fma_qeq,         Decimal.fma.__qualname__.__eq__,         ["Decimal.fma"],         true, "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' (len=11; 'Decimal.' (8) + 'fma' (3) = 11; fma() is the fused multiply-add operation: self*other+third rounded only once at the end; this single rounding makes fma() more accurate than computing the multiply and add separately; tied with Decimal.exp at length 11)"]
    - [sqrt_qeq,        Decimal.sqrt.__qualname__.__eq__,        ["Decimal.sqrt"],        true, "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12; 'Decimal.' (8) + 'sqrt' (4) = 12; sqrt() computes the square root to the current context precision; returns a correctly-rounded result per the General Decimal Arithmetic specification; raises InvalidOperation for negative numbers)"]
    - [log10_qeq,       Decimal.log10.__qualname__.__eq__,       ["Decimal.log10"],       true, "decimal.Decimal.log10.__qualname__ == 'Decimal.log10' (len=13; 'Decimal.' (8) + 'log10' (5) = 13; log10() computes the base-10 logarithm to the current context precision; for exact integer results (e.g. Decimal(100).log10() == 2), the result is exact; raises InvalidOperation for negative numbers and zero)"]
    - [quantize_qeq,    Decimal.quantize.__qualname__.__eq__,    ["Decimal.quantize"],    true, "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16; 'Decimal.' (8) + 'quantize' (8) = 16; quantize() rounds a Decimal to the same number of decimal places as the exponent argument (e.g. Decimal('1.456').quantize(Decimal('0.01')) == Decimal('1.46')); the rounding mode from the context or kwarg is applied)"]
    - [to_integral_qeq, Decimal.to_integral.__qualname__.__eq__, ["Decimal.to_integral"], true, "decimal.Decimal.to_integral.__qualname__ == 'Decimal.to_integral' (len=19; 'Decimal.' (8) + 'to_integral' (11) = 19; to_integral() rounds to the nearest integer using the context rounding mode; equivalent to quantize(Decimal('1')); the longest qualname of the mathematical Decimal methods covered in this spec)"]

# ---------------------------------------------------------------------------
# decimal.Decimal predicate and rounding method __qualname__ values (group 2)
# is_nan, quantize, to_integral qualname equality checks
# ---------------------------------------------------------------------------

table decimal_extra150.Decimal_predicate_and_rounding_qualnames:
  description: "decimal.Decimal predicate method __qualname__ values: is_nan=14; also verifies quantize/to_integral __eq__ calls return True; all follow 'Decimal.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: decmathq150

  columns: [id, function, args, expected, description]
  rows:
    - [is_nan_qeq,       Decimal.is_nan.__qualname__.__eq__,     ["Decimal.is_nan"],     true, "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (len=14; 'Decimal.' (8) + 'is_nan' (6) = 14; is_nan() returns True if the Decimal is NaN or sNaN (signaling NaN); NaN propagates through arithmetic operations; is_nan() is one of several Decimal predicate methods whose qualnames use the 'is_' prefix pattern)"]
    - [is_nan_qlen,      Decimal.is_nan.__qualname__.__len__,    [],                     14,   "decimal.Decimal.is_nan.__qualname__.__len__() == 14 ('Decimal.is_nan' has 14 characters; 'Decimal.' (8) + 'is_nan' (6) = 14; longer than Decimal.log10 (13) and shorter than Decimal.quantize (16); the 'is_' prefix (3 chars) and NaN suffix (3 chars) give 'is_nan' 6 characters total)"]
    - [quantize_qlen,    Decimal.quantize.__qualname__.__len__,  [],                     16,   "decimal.Decimal.quantize.__qualname__.__len__() == 16 ('Decimal.quantize' has 16 characters; 'Decimal.' (8) + 'quantize' (8) = 16; 'quantize' (8 chars) equals the prefix 'Decimal.' (8 chars) in length — an interesting symmetry; quantize() is the primary rounding method for fixed-precision decimal arithmetic)"]
    - [to_integral_qlen, Decimal.to_integral.__qualname__.__len__,[],                   19,   "decimal.Decimal.to_integral.__qualname__.__len__() == 19 ('Decimal.to_integral' has 19 characters; 'Decimal.' (8) + 'to_integral' (11) = 19; the longest Decimal method qualname covered in this spec; 'to_integral' conveys rounding to the nearest integer, more descriptive than alternatives like 'round' or 'ceil')"]
    - [ln_qlen,          Decimal.ln.__qualname__.__len__,        [],                     10,   "decimal.Decimal.ln.__qualname__.__len__() == 10 ('Decimal.ln' has 10 characters; the shortest Decimal method qualname in this spec; 'Decimal.' (8) + 'ln' (2) = 10; 'ln' uses the traditional mathematical abbreviation for natural logarithm (from Latin 'logarithmus naturalis'); contrast with log10 (13) which spells out the base)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra150.Decimal_quantize_qualname_eq:
  description: "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' — quantize() is the primary method for rounding Decimal values to a specific number of decimal places; its qualname has length 16 ('Decimal.' (8) + 'quantize' (8) = 16); note the elegant symmetry where the prefix and method name are equal length (both 8 chars); quantize() is essential in financial applications for rounding to cents: Decimal('1.2345').quantize(Decimal('0.01'))"
  category: qualname
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

invariant decimal_extra150.Decimal_sqrt_qualname_eq:
  description: "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' — sqrt() computes the square root of a Decimal to the current context precision; its qualname length is 12 ('Decimal.' (8) + 'sqrt' (4) = 12); Decimal.sqrt() is more precise than float(d) ** 0.5 for decimal values because it operates in exact decimal arithmetic up to the context precision; returns a correctly-rounded result per the GDA spec"
  category: qualname
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__eq__
  args: ["Decimal.sqrt"]
  expected: true

invariant decimal_extra150.Decimal_fma_qualname_eq:
  description: "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' — fma() is the fused multiply-add operation computing self*other+third with a single rounding at the end (no intermediate rounding after the multiplication); its qualname length is 11 ('Decimal.' (8) + 'fma' (3) = 11); fma() avoids double-rounding errors and is specified by the IEEE 754-2008 and General Decimal Arithmetic standards; tied with Decimal.exp at qualname length 11"
  category: qualname
  kind: python_call_eq
  function: Decimal.fma.__qualname__.__eq__
  args: ["Decimal.fma"]
  expected: true

invariant decimal_extra150.Decimal_is_nan_qualname_eq:
  description: "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' — is_nan() returns True if the value is NaN or sNaN (signaling NaN); the qualname length is 14 ('Decimal.' (8) + 'is_nan' (6) = 14); Decimal has several 'is_*' predicate methods (is_nan, is_infinite, is_zero, is_signed, etc.) — all follow the 'Decimal.is_<predicate>' qualname pattern; is_nan() is critical for safe decimal arithmetic where NaN propagation must be checked"
  category: qualname
  kind: python_call_eq
  function: Decimal.is_nan.__qualname__.__eq__
  args: ["Decimal.is_nan"]
  expected: true

invariant decimal_extra150.Decimal_to_integral_qualname_len_19:
  description: "decimal.Decimal.to_integral.__qualname__.__len__() == 19 — 'Decimal.to_integral' is 19 characters ('Decimal.' (8) + 'to_integral' (11) = 19); the longest Decimal method qualname covered in this spec; compare with Decimal.quantize (16), Decimal.is_nan (14), Decimal.log10 (13), Decimal.sqrt (12), Decimal.exp (11), Decimal.fma (11), Decimal.ln (10) — to_integral has the longest name; to_integral() rounds to the nearest integer using the current context rounding mode"
  category: qualname
  kind: python_call_eq
  function: Decimal.to_integral.__qualname__.__len__
  args: []
  expected: 19
