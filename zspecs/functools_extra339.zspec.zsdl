spec: functools_extra339
version: ">=3.0"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.reduce(lambda a, b: a+b, [1,2,3]) == 6 — left fold over integers."
    - "functools.reduce(lambda a, b: a+b, [1,2,3], 10) == 16 — initial value is prepended."
    - "functools.reduce(lambda a, b: a*b, [1,2,3,4]) == 24 — product via left fold."
    - "functools.reduce(lambda a, b: a+b, [], 0) == 0 — empty iterable with initial returns initial."
    - "reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C-level built-in."
    - "reduce.__doc__.__class__.__name__ == 'str' — docstring is a plain Python string."
    - "cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — C-level built-in."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reduce — behavioral results (lambdas resolved by the harness via eval)
#
# These invariants confirm the computed values from functools.reduce directly
# using __eq__ on the integer result.
# ---------------------------------------------------------------------------

invariant functools_extra339.reduce.sum_three:
  description: "functools.reduce(lambda a, b: a + b, [1, 2, 3]) == 6"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda a, b: a + b", [1, 2, 3]]
  method: __eq__
  method_args: [6]
  expected: true

invariant functools_extra339.reduce.sum_three_with_initial:
  description: "functools.reduce(lambda a, b: a + b, [1, 2, 3], 10) == 16"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda a, b: a + b", [1, 2, 3], 10]
  method: __eq__
  method_args: [16]
  expected: true

invariant functools_extra339.reduce.product_four:
  description: "functools.reduce(lambda a, b: a * b, [1, 2, 3, 4]) == 24"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda a, b: a * b", [1, 2, 3, 4]]
  method: __eq__
  method_args: [24]
  expected: true

invariant functools_extra339.reduce.empty_with_initial:
  description: "functools.reduce(lambda a, b: a + b, [], 0) == 0 — empty iterable returns initial"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda a, b: a + b", [], 0]
  method: __eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# reduce — type and doc checks
# ---------------------------------------------------------------------------

invariant functools_extra339.reduce.class_name:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method'"
  category: reduce
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra339.reduce.doc_class_name:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str'"
  category: reduce
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# cmp_to_key — type check
# ---------------------------------------------------------------------------

invariant functools_extra339.cmp_to_key.class_name:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'"
  category: cmp_to_key
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
