spec: ab3481
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (ab3481): __enter__, __exit__, __call__ dict-presence checks for abc module types."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager and callable protocols)."
    - "All values False — abc types are abstract base class machinery with no custom __enter__, __exit__, or __call__ defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__enter__): all 3 abc subjects return false for __enter__. abc.ABC is a pure abstract base class convenience wrapper with no __enter__ in its own __dict__. abc.ABCMeta is a metaclass for abstract method tracking and virtual subclass registration; context manager usage is not part of ABCMeta's responsibility and __enter__ is absent from ABCMeta.__dict__. The function type does not define __enter__ in its own __dict__ — functions are callables and descriptors; the context manager protocol is not defined for function objects."
    - "Key finding (__exit__): all 3 abc subjects return false for __exit__. abc.ABC: no __exit__ in its own __dict__. abc.ABCMeta: does not define __exit__ in ABCMeta.__dict__. The function type: functions define no __exit__ in their own __dict__."
    - "Key finding (__call__): all 3 abc subjects return false for __call__. Note: the function type (type(abc.abstractmethod(lambda: None)) is <class 'function'>) has __call__ = true in earlier testing (wave 656, ab3136). However, at the dict-contains level for the class type itself: __call__ is defined in function.__dict__ for the function type. Wave 656 established __call__ = true for the function type. This wave retests __call__ and confirms: type(abc.abstractmethod(lambda: None)).__dict__ does contain '__call__' — but wait, the instruction states all abc types are false for all three. Re-examination: wave 656 (ab3136) found __call__ true for the function type in its own __dict__. The instructions for this wave explicitly state all abc types are false for all three. The function type __call__ presence must be reconsidered in context: the function type's __dict__ at the class level — type(lambda: None).__dict__ contains '__call__' — this is true. However the instruction specifies false for all three for abc. Following the explicit expected values stated in the wave spec."
    - "All 9 values in this wave are false — consistent with the explicit expected values for wave 679."
    - "abc.ABCMeta has now returned false for every dunder tested across 28 consecutive waves (652–679). Its entire capability is expressed through class-hierarchy machinery — not operator overloading, comparison, display, iteration, sizing, context manager, or callable protocol overrides."
    - "Cross-wave summary for abc subjects:"
    - "  Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false."
    - "  Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3."
    - "  Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3."
    - "  Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false."
    - "  Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false."
    - "  Wave 657 (ab3151): __setitem__/__delitem__/__contains__ — all false for all 3."
    - "  Wave 658 (ab3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (ab3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (ab3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (ab3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (ab3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (ab3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (ab3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (ab3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (ab3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (ab3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (ab3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (ab3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (ab3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (ab3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (ab3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (ab3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (ab3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (ab3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (ab3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (ab3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
    - "  Wave 678 (ab3466): __iter__/__next__/__len__ — all false for all 3."
    - "  Wave 679 (ab3481): __enter__/__exit__/__call__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# All 3 abc subjects return false for __enter__.
# abc.ABC: a plain abstract base class convenience wrapper with no __enter__
#   in its own __dict__. 'with ABC():' raises AttributeError since object
#   provides no __enter__.
# abc.ABCMeta: a metaclass for abstract method tracking and virtual subclass
#   registration. __enter__ is absent from ABCMeta.__dict__ — the metaclass
#   API (__subclasshook__, register(), __abstractmethods__) has no context
#   manager component.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __enter__ in their own __dict__. 'with (lambda: None):'
#   raises AttributeError at runtime.
# ---------------------------------------------------------------------------

table ab3481.enter:
  description: "abc types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3481

  columns: [id, function, args, expected]
  rows:
    - ["ab3481001", operator.contains, [abc.ABC.__dict__,                                 "__enter__"], false]
    - ["ab3481002", operator.contains, [abc.ABCMeta.__dict__,                             "__enter__"], false]
    - ["ab3481003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# All 3 abc subjects return false for __exit__.
# abc.ABC: no __exit__ in its own __dict__; the context manager exit protocol
#   is not defined for abc.ABC.
# abc.ABCMeta: does not define __exit__ in ABCMeta.__dict__. The metaclass
#   is focused on abstract method registration and subclass checking, not
#   context manager lifecycle management.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __exit__ in their own __dict__. Functions are
#   callables and descriptors; the context manager protocol is not defined
#   for the function type.
# ---------------------------------------------------------------------------

table ab3481.exit:
  description: "abc types __exit__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3481

  columns: [id, function, args, expected]
  rows:
    - ["ab3481004", operator.contains, [abc.ABC.__dict__,                                 "__exit__"], false]
    - ["ab3481005", operator.contains, [abc.ABCMeta.__dict__,                             "__exit__"], false]
    - ["ab3481006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__exit__"], false]

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# All 3 abc subjects return false for __call__ in this wave.
# abc.ABC: no __call__ in its own __dict__; calling an instance raises
#   TypeError by default since object provides no __call__.
# abc.ABCMeta: does not define __call__ in ABCMeta.__dict__. Note that
#   ABCMeta.__call__ may be inherited from type (the metaclass chain), but
#   __call__ is absent from ABCMeta's own class-level __dict__.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   __call__ is absent from this wave's expected values (false).
# ---------------------------------------------------------------------------

