    - ["ab3481008", operator.contains, [abc.ABCMeta.__dict__,                             "__call__"], false]
    - ["ab3481009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__call__"], false]

# ---------------------------------------------------------------------------
# combined — __enter__, __exit__, __call__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __enter__: false for all 3.
# __exit__:  false for all 3.
# __call__:  false for all 3.
# All 9 values are false.
# Continues the all-false pattern from wave 679 for abc types.
# abc.ABC note: ABC is a pure syntactic convenience for declaring abstract
#   base classes. It has no state of its own beyond what ABCMeta provides,
#   and defines no dunder of any kind in its own __dict__ across all tested waves.
# abc.ABCMeta note: ABCMeta has now returned false for every dunder tested
#   across 28 consecutive waves (652–679). Its power lies exclusively in
#   class-hierarchy machinery — not in operator overloading, comparison,
#   hashing, display, iteration, sizing, context manager, or callable protocol
#   overrides.
# The function type profile across all waves:
#   true:  __get__ (652), __repr__ (655), __call__ (656)
#   false: __set__, __delete__, __hash__, __eq__, __bool__, __lt__, __le__, __gt__,
#          __ge__, __str__, __len__, __getitem__, __setitem__, __delitem__,
#          __contains__, __add__, __sub__, __mul__, __truediv__, __floordiv__,
#          __mod__, __pow__, __lshift__, __rshift__, __and__, __or__, __xor__,
#          __radd__, __rsub__, __rmul__, __rtruediv__, __rfloordiv__, __rmod__,
#          __rpow__, __rlshift__, __rrshift__, __rand__, __ror__, __rxor__,
#          __iadd__, __isub__, __imul__, __itruediv__, __ifloordiv__, __imod__,
#          __ipow__, __ilshift__, __irshift__, __iand__, __ior__, __ixor__,
#          __neg__, __pos__, __abs__, __invert__, __floor__, __ceil__,
#          __trunc__, __round__, __index__, __int__, __float__, __complex__,
#          __bool__ (674), __str__ (674), __repr__ (674),
#          __hash__ (675), __eq__ (675), __lt__ (675),
#          __le__ (676), __gt__ (676), __ge__ (676),
#          __getitem__ (677), __setitem__ (677), __delitem__ (677),
#          __iter__ (678), __next__ (678), __len__ (678),
#          __enter__ (679), __exit__ (679), __call__ (679)
# ---------------------------------------------------------------------------

