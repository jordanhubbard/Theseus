spec: io_extra169
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.FileIO method __qualname__ values for read, readall, write, seek, tell, and FileIO class identity (__name__, __module__)."
    - "All FileIO method qualnames use the public class name 'FileIO' (6 characters) as the prefix, plus a dot separator."
    - "The 'FileIO.' prefix is 7 characters (6 chars for 'FileIO' + 1 for '.')."
    - "io.FileIO.read.__qualname__ == 'FileIO.read' (len=11; 'FileIO.' (7) + 'read' (4) = 11; tied with seek and tell at 11)."
    - "io.FileIO.seek.__qualname__ == 'FileIO.seek' (len=11; 'FileIO.' (7) + 'seek' (4) = 11; tied with read and tell at 11)."
    - "io.FileIO.tell.__qualname__ == 'FileIO.tell' (len=11; 'FileIO.' (7) + 'tell' (4) = 11; tied with read and seek at 11)."
    - "io.FileIO.write.__qualname__ == 'FileIO.write' (len=12; 'FileIO.' (7) + 'write' (5) = 12; sole occupant of length 12)."
    - "io.FileIO.readall.__qualname__ == 'FileIO.readall' (len=14; 'FileIO.' (7) + 'readall' (7) = 14; the longest FileIO method qualname in this spec)."
    - "Three-way tie at 11: read, seek, tell — all 4-character method names."
    - "write stands alone at 12 — the only 5-character method name in the shorter group."
    - "readall stands alone at 14 — a 7-character method name, the longest in this spec."
    - "Length ranking: read=seek=tell=11, write=12, readall=14."
    - "io.FileIO.__name__ == 'FileIO' (len=6; the class name itself, 6 characters)."
    - "io.FileIO.__module__ == '_io' (len=3; FileIO is implemented in the C extension module '_io', not the public 'io' module)."
    - "FileIO prefix 'FileIO.' (7 chars) is shorter than 'BytesIO.' (8), 'StringIO.' (9), 'BufferedWriter.' (15) — the shortest of all io class qualname prefixes in this spec series."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO method __qualname__ values (group 1)
# read, seek, tell — three-way tie at length 11 (4-character method names).
# write — sole occupant of length 12 (5-character method name).
# All use 'FileIO.' prefix (7 characters).
# ---------------------------------------------------------------------------

table io_extra169.FileIO_method_qualnames_group1:
  description: "io.FileIO method __qualname__ values: read=seek=tell='FileIO.*' (len=11), write='FileIO.write' (len=12); three-way tie at 11 for 4-char method names; write is the sole occupant at 12; 'FileIO.' prefix is 7 chars"
  kind: python_call_eq
  category: qualname
  id_prefix: fioq169

  columns: [id, function, args, expected, description]
  rows:
    - [fio_read_qeq,   FileIO.read.__qualname__.__eq__,   ["FileIO.read"],   true, "io.FileIO.read.__qualname__ == 'FileIO.read' (FileIO.read() reads at most size bytes from the underlying OS-level file; when size is -1 or omitted it reads the entire file by calling readall(); FileIO is a RawIOBase subclass performing unbuffered OS-level I/O; 'FileIO.read' has 11 characters: 'FileIO.' (7) + 'read' (4) = 11; part of the three-way tie at 11 with seek and tell — all three have 4-character method names; 'FileIO.' prefix (7 chars) is the shortest io class qualname prefix in this spec series: shorter than 'BytesIO.' (8), 'StringIO.' (9), 'BufferedWriter.' (15))"]
    - [fio_seek_qeq,   FileIO.seek.__qualname__.__eq__,   ["FileIO.seek"],   true, "io.FileIO.seek.__qualname__ == 'FileIO.seek' (FileIO.seek() changes the OS file position; accepts offset and whence=0 (absolute), 1 (relative to current), 2 (relative to end); for FileIO, seek() performs an lseek(2) system call directly; 'FileIO.seek' has 11 characters: 'FileIO.' (7) + 'seek' (4) = 11; tied with read and tell at length 11; all three are 4-character method names under the 7-character 'FileIO.' prefix; 'FileIO.seek' (11) is 1 shorter than 'BytesIO.seek' (12) because 'FileIO.' (7) is 1 shorter than 'BytesIO.' (8))"]
    - [fio_tell_qeq,   FileIO.tell.__qualname__.__eq__,   ["FileIO.tell"],   true, "io.FileIO.tell.__qualname__ == 'FileIO.tell' (FileIO.tell() returns the current OS file position as an integer byte offset from the file's beginning; for FileIO, tell() calls lseek(2) with offset=0 and SEEK_CUR; 'FileIO.tell' has 11 characters: 'FileIO.' (7) + 'tell' (4) = 11; tied with read and seek at length 11; the three-way tie at 11 is the minimum qualname length in this spec; compare with BytesIO.tell (12), StringIO.tell (13), BufferedWriter.tell (19) — FileIO method qualnames are the shortest because 'FileIO.' prefix (7 chars) is the shortest)"]
    - [fio_write_qeq,  FileIO.write.__qualname__.__eq__,  ["FileIO.write"],  true, "io.FileIO.write.__qualname__ == 'FileIO.write' (FileIO.write() writes the given bytes-like object to the underlying OS file and returns the number of bytes actually written; as a RawIOBase, FileIO.write() may write fewer bytes than requested — callers must check the return value; 'FileIO.write' has 12 characters: 'FileIO.' (7) + 'write' (5) = 12; write is the sole occupant of length 12 — the only 5-character method name in the shorter group; length 12 is between the three-way tie at 11 (read, seek, tell) and readall at 14; 'FileIO.write' (12) is 1 shorter than 'BytesIO.write' (13))"]

# ---------------------------------------------------------------------------
# io.FileIO readall qualname and FileIO class identity
# readall = 'FileIO.readall' (len=14), the longest FileIO method qualname.
# FileIO.__name__ == 'FileIO' (len=6), FileIO.__module__ == '_io' (len=3).
# ---------------------------------------------------------------------------

table io_extra169.FileIO_readall_and_class_identity:
  description: "io.FileIO readall qualname and class identity: readall='FileIO.readall' (len=14, longest in spec); FileIO.__name__='FileIO' (len=6); FileIO.__module__='_io' (len=3, C extension)"
  kind: python_call_eq
  category: identity
  id_prefix: fioq169

  columns: [id, function, args, expected, description]
  rows:
    - [fio_readall_qeq,  FileIO.readall.__qualname__.__eq__,  ["FileIO.readall"],  true, "io.FileIO.readall.__qualname__ == 'FileIO.readall' (FileIO.readall() reads and returns all remaining bytes from the OS file from the current position to end-of-file using a sequence of OS read calls; it is the method called internally by FileIO.read() when no size is given; 'FileIO.readall' has 14 characters: 'FileIO.' (7) + 'readall' (7) = 14; readall is the longest FileIO method qualname in this spec; uniquely, the method name 'readall' (7 chars) equals the prefix 'FileIO.' (7 chars) in length — a symmetry; length 14 = 11 (three-way tie) + 3 extra from the 'all' suffix)"]
    - [fio_readall_qlen, FileIO.readall.__qualname__.__len__, [],                  14,   "io.FileIO.readall.__qualname__.__len__() == 14 ('FileIO.readall' has 14 characters: 'FileIO.' (7) + 'readall' (7) = 14; readall stands alone at 14 — the maximum qualname length in this spec; complete length ranking: read=seek=tell=11, write=12, readall=14; the gap between write (12) and readall (14) is 2 characters — from the 5-character 'write' to the 7-character 'readall'; 'FileIO.readall' (14) has a symmetric structure: both the prefix 'FileIO.' and the method name 'readall' are exactly 7 characters long; compare with BytesIO.getvalue (16) and StringIO.getvalue (17) for similarly long method qualnames)"]
    - [fio_name_eq,      FileIO.__name__.__eq__,              ["FileIO"],          true, "io.FileIO.__name__ == 'FileIO' (the class name is 'FileIO' — 6 characters: 'File' (4) + 'IO' (2) = 6; FileIO is the concrete raw I/O class for OS-level file reading and writing; unlike BufferedWriter/BufferedReader, FileIO does not buffer — it passes reads and writes directly to the OS; 'FileIO' (6 chars) is shorter than 'BytesIO' (7), 'StringIO' (8), 'BufferedWriter' (14) — the shortest io class name in this spec series; __name__ == 'FileIO' (6) is 2 characters shorter than __module__ == 'decimal' (7) seen in other specs)"]
    - [fio_module_eq,    FileIO.__module__.__eq__,            ["_io"],             true, "io.FileIO.__module__ == '_io' (FileIO is implemented in the C extension module '_io', not in the public Python 'io' module; '_io' has 3 characters: '_' (1) + 'io' (2) = 3; the leading underscore signals a private/implementation module; the public 'io' module imports and re-exports FileIO from '_io'; __module__ == '_io' (3 chars) is shared by BytesIO, StringIO, and BufferedWriter — all C-implemented io classes; contrast with pathlib classes where __module__ == 'pathlib' (7 chars); '_io' (3 chars) is shorter than 're' (2 chars) is wrong — '_io' (3) > 're' (2); '_io' (3) vs 'io' (2): the underscore prefix adds 1 character to mark it as a private implementation)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra169.FileIO_read_seek_tell_three_way_tie_at_11:
  description: "io.FileIO.read.__qualname__.__len__() == 11 — 'FileIO.read' has 11 characters: 'FileIO.' (7) + 'read' (4) = 11; read is part of a three-way tie at 11 with seek (also 11: 'FileIO.' (7) + 'seek' (4) = 11) and tell (also 11: 'FileIO.' (7) + 'tell' (4) = 11); the three-way tie at 11 occurs because read, seek, and tell are all exactly 4-character method names under the 7-character 'FileIO.' prefix; length 11 is the minimum qualname length in this spec; compare: BytesIO.read/seek/tell are each 12 (one longer) because 'BytesIO.' (8) > 'FileIO.' (7) by 1; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: FileIO.read.__qualname__.__len__
  args: []
  expected: 11

invariant io_extra169.FileIO_write_sole_at_12:
  description: "io.FileIO.write.__qualname__.__len__() == 12 — 'FileIO.write' has 12 characters: 'FileIO.' (7) + 'write' (5) = 12; write is the sole occupant of length 12 in this spec — the only 5-character method name in the shorter group; it sits between the three-way tie at 11 (read, seek, tell) and readall at 14; 'FileIO.write' (12) is exactly 1 shorter than 'BytesIO.write' (13) because 'FileIO.' (7) < 'BytesIO.' (8) by 1; complete length ranking: read=seek=tell=11, write=12, readall=14; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: FileIO.write.__qualname__.__len__
  args: []
  expected: 12

invariant io_extra169.FileIO_readall_is_longest_at_14:
  description: "io.FileIO.readall.__qualname__.__len__() == 14 — 'FileIO.readall' has 14 characters: 'FileIO.' (7) + 'readall' (7) = 14; readall is the longest FileIO method qualname in this spec and stands alone at length 14; uniquely symmetric: both halves of the qualname are 7 characters long ('FileIO.' and 'readall'); the gap from write (12) to readall (14) is 2 characters; complete length ranking: read=seek=tell=11, write=12, readall=14; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: FileIO.readall.__qualname__.__len__
  args: []
  expected: 14

invariant io_extra169.FileIO_module_is_underscore_io:
  description: "io.FileIO.__module__ == '_io' — FileIO is implemented in '_io' (3 chars), the private C-extension module; the leading underscore marks it as an implementation detail; the public 'io' module re-exports FileIO from '_io'; '_io' (3 chars) is shared by BytesIO, StringIO, BufferedWriter, and other C-implemented io classes; FileIO's short class name 'FileIO' (6 chars) combined with the '_io' (3 chars) module gives it the smallest identifiers in the io class hierarchy; '__module__ == \"_io\"' contrasts with pathlib classes where __module__ == 'pathlib' (7 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

