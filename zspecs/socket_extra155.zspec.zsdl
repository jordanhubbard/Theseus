spec: socket_extra155
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra154.zspec.zsdl — covers socket.error/__name__.__eq__('OSError') / gaierror/__bases__[0].__name__ / herror/__name__/__module__ / timeout/__name__/__eq__('TimeoutError') / timeout/__module__.__eq__('builtins') / timeout/__bases__[0].__name__ (table + invariants)."
    - "socket_extra153.zspec.zsdl — covers socket.socket.send/__recv/__accept/__close/__fileno qualnames and qualname lengths (table + invariants)."
    - "socket_extra152.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ / socket.socket.connect/__bind/__listen qualnames / socket.error/__name__/__eq__('OSError') / socket.gaierror.__name__/__module__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra154."
    - "Wave 337 theme: socket module-level function identity — setdefaulttimeout/__class__.__name__/__module__ / getdefaulttimeout/__class__.__name__ / gethostname/__class__.__name__/__module__ / getaddrinfo/__class__.__name__/__module__ / socket.socket.__doc__/__class__.__name__."
    - "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method' and __module__ == '_socket'. setdefaulttimeout and getdefaulttimeout are both C extension callables from _socket. They control the default timeout for new socket objects. setdefaulttimeout(None) restores blocking mode; setdefaulttimeout(0.0) enables non-blocking mode. Both have __module__ == '_socket' (7 chars), indicating they come from the C extension."
    - "Note: socket.gethostname.__class__.__name__ == 'builtin_function_or_method' and __module__ == '_socket'. gethostname() is implemented in the _socket C extension module and returns the hostname of the machine. Its __module__ is '_socket' (7 chars), not 'socket' (6 chars). This means gethostname is a C builtin, not a Python wrapper."
    - "Note: socket.getaddrinfo.__class__.__name__ == 'function' and __module__ == 'socket'. CRITICAL CONTRAST: getaddrinfo is a Python function (not a builtin_function_or_method), and its __module__ is 'socket' (6 chars), not '_socket'. getaddrinfo() is defined in Lib/socket.py as a pure-Python wrapper. This contrasts with gethostname (builtin, _socket) and setdefaulttimeout (builtin, _socket)."
    - "Note: socket.socket.__doc__.__class__.__name__ == 'str'. The socket.socket class carries a docstring that is a Python str. This confirms the socket class has documentation. The __doc__ attribute's class name is 'str' (3 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__class__.__name__.__eq__('builtin_function_or_method')
# socket.setdefaulttimeout.__module__.__eq__('_socket')
# socket.getdefaulttimeout.__class__.__name__.__eq__('builtin_function_or_method')
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 337 theme: setdefaulttimeout/getdefaulttimeout/gethostname are C extension builtins.
#
# All three are builtin_function_or_method (26 chars) from _socket.
# setdefaulttimeout.__module__ == '_socket' (7 chars). gethostname also from '_socket'.
# No prior socket spec anchors setdefaulttimeout/__class__.__name__ or gethostname/__class__.__name__
# as a table under sockfn155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra155.timeout_and_gethostname_class_identity:
  description: "socket.setdefaulttimeout.__class__.__name__.__eq__('builtin_function_or_method')==True / setdefaulttimeout.__module__.__eq__('_socket')==True / getdefaulttimeout.__class__.__name__.__eq__('builtin_function_or_method')==True / gethostname.__class__.__name__.__eq__('builtin_function_or_method')==True — setdefaulttimeout/getdefaulttimeout/gethostname are all 'builtin_function_or_method' (26 chars; C extension callables from _socket); setdefaulttimeout.__module__ is '_socket' (7 chars); first sockfn155 anchor for timeout control function identity"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn155

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_class, "setdefaulttimeout.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method' (26 chars; C builtin from _socket)"]
    - [setdefaulttimeout_module,"setdefaulttimeout.__module__.__eq__",         ["_socket"],                    true, "socket.setdefaulttimeout.__module__ == '_socket' (7 chars; C extension module; sets default socket timeout)"]
    - [getdefaulttimeout_class, "getdefaulttimeout.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "socket.getdefaulttimeout.__class__.__name__ == 'builtin_function_or_method' (26 chars; C builtin from _socket)"]
    - [gethostname_class,       "gethostname.__class__.__name__.__eq__",       ["builtin_function_or_method"], true, "socket.gethostname.__class__.__name__ == 'builtin_function_or_method' (26 chars; C builtin from _socket)"]

# ---------------------------------------------------------------------------
# socket.gethostname.__module__.__eq__('_socket')
# socket.getaddrinfo.__class__.__name__.__eq__('function')
# socket.getaddrinfo.__module__.__eq__('socket')
# socket.socket.__doc__.__class__.__name__.__eq__('str')
#
# Wave 337 theme: gethostname module and getaddrinfo vs gethostname class contrast.
#
# gethostname.__module__ == '_socket' (7 chars; C extension).
# getaddrinfo.__class__.__name__ == 'function' (8 chars; NOT 'builtin_function_or_method').
# getaddrinfo.__module__ == 'socket' (6 chars; pure Python wrapper in Lib/socket.py).
# socket.socket.__doc__.__class__.__name__ == 'str' (3 chars; class has a docstring).
# No prior socket spec anchors gethostname.__module__ or getaddrinfo class/module as a
# table under sockfn155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra155.gethostname_module_and_getaddrinfo_identity:
  description: "socket.gethostname.__module__.__eq__('_socket')==True / getaddrinfo.__class__.__name__.__eq__('function')==True / getaddrinfo.__module__.__eq__('socket')==True / socket.__doc__.__class__.__name__.__eq__('str')==True — gethostname.__module__ is '_socket' (7 chars; C extension); getaddrinfo is a 'function' (8 chars; pure Python wrapper, NOT 'builtin_function_or_method'); getaddrinfo.__module__ is 'socket' (6 chars; defined in Lib/socket.py); socket class __doc__ is 'str' (3 chars); key contrast: getaddrinfo is Python while gethostname is C; first sockfn155 anchor for these identities"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn155

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_module,      "gethostname.__module__.__eq__",              ["_socket"], true, "socket.gethostname.__module__ == '_socket' (7 chars; C extension from _socket; returns machine hostname)"]
    - [getaddrinfo_class,       "getaddrinfo.__class__.__name__.__eq__",      ["function"], true, "socket.getaddrinfo.__class__.__name__ == 'function' (8 chars; pure Python function in Lib/socket.py; not a C builtin)"]
    - [getaddrinfo_module,      "getaddrinfo.__module__.__eq__",              ["socket"],   true, "socket.getaddrinfo.__module__ == 'socket' (6 chars; defined in Lib/socket.py; pure Python wrapper; not '_socket')"]
    - [socket_doc_class_str,    "socket.__doc__.__class__.__name__.__eq__",   ["str"],      true, "socket.socket.__doc__.__class__.__name__ == 'str' (3 chars; socket class carries str docstring)"]

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout vs getaddrinfo class name lengths
#
# Wave 337 theme: length contrasts between C builtin and Python function class names.
#
# 'builtin_function_or_method' is 26 chars; 'function' is 8 chars.
# setdefaulttimeout/__class__.__name__.__len__() == 26.
# getaddrinfo/__class__.__name__.__len__() == 8.
# gethostname/__module__.__len__() == 7 ('_socket').
# getaddrinfo/__module__.__len__() == 6 ('socket').
# No prior socket spec anchors these length values as a table under sockfn155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra155.function_class_name_lengths:
  description: "socket.setdefaulttimeout.__class__.__name__.__len__()==26 / getaddrinfo.__class__.__name__.__len__()==8 / gethostname.__module__.__len__()==7 / getaddrinfo.__module__.__len__()==6 — 'builtin_function_or_method' is 26 chars (C extension callable); 'function' is 8 chars (Python function); '_socket' is 7 chars (C extension module name); 'socket' is 6 chars (Python module name); class name contrast: 26 vs 8 (difference of 18); module name contrast: '_socket'(7) vs 'socket'(6) (underscore prefix adds 1 char); first sockfn155 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn155

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_class_len, "setdefaulttimeout.__class__.__name__.__len__", [], 26, "socket.setdefaulttimeout.__class__.__name__.__len__() is 26 ('builtin_function_or_method' = 26 chars; C extension callable)"]
    - [getaddrinfo_class_len,       "getaddrinfo.__class__.__name__.__len__",       [], 8,  "socket.getaddrinfo.__class__.__name__.__len__() is 8 ('function' = 8 chars; pure Python function)"]
    - [gethostname_module_len,      "gethostname.__module__.__len__",               [], 7,  "socket.gethostname.__module__.__len__() is 7 ('_socket' = 7 chars; underscore-prefixed C extension module)"]
    - [getaddrinfo_module_len,      "getaddrinfo.__module__.__len__",               [], 6,  "socket.getaddrinfo.__module__.__len__() is 6 ('socket' = 6 chars; public Python module name without underscore)"]

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__module__.__eq__('_socket') — standalone
#
# socket.setdefaulttimeout.__module__ is '_socket' (7 chars). setdefaulttimeout is
# a C extension function from the _socket module. It sets the default timeout value
# (in seconds, as a float) for all new socket objects created after the call.
# Passing None restores blocking mode (no timeout). Passing 0.0 sets non-blocking mode.
# Any positive float value sets a timeout — the socket will raise socket.timeout
# (TimeoutError) if the operation does not complete within that time. Its __module__
# is '_socket' (7 chars; underscore-prefixed C extension), not 'socket' (6 chars).
# No prior socket spec anchors setdefaulttimeout.__module__ as a standalone under
# sockfn155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra155.setdefaulttimeout_module_socket:
  description: "socket.setdefaulttimeout.__module__.__eq__('_socket') == True — '_socket' (7 chars); C extension from _socket; sets default timeout for new socket objects; None=blocking, 0.0=non-blocking, positive float=timed; raises socket.timeout (TimeoutError) on timeout; __class__.__name__=='builtin_function_or_method' (26 chars); paired with getdefaulttimeout (also '_socket'); no prior socket spec anchors this as a standalone; first standalone under sockfn155"
  category: identity
  kind: python_call_eq
  function: setdefaulttimeout.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__class__.__name__.__eq__('function') — standalone
#
# socket.getaddrinfo.__class__.__name__ is 'function' (8 chars). getaddrinfo() is
# defined in Lib/socket.py as a pure Python wrapper function. It resolves a host name
# and service name to a list of socket address structures. Unlike gethostname() which
# is a C builtin from _socket, getaddrinfo() is a Python-level function. This makes
# socket.getaddrinfo one of the notable socket module functions implemented in Python
# rather than C. getaddrinfo.__module__ == 'socket' (6 chars; pure Python module).
# Its __class__.__name__ == 'function' (8 chars) — the same type as hashlib.new
# (extra157 anchors hashlib.new.__class__.__name__ == 'function'). No prior socket spec
# anchors getaddrinfo.__class__.__name__ as a standalone under sockfn155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra155.getaddrinfo_class_function:
  description: "socket.getaddrinfo.__class__.__name__.__eq__('function') == True — 'function' (8 chars); pure Python function in Lib/socket.py; resolves host/service to address list; __module__=='socket' (6 chars; not '_socket'); contrasts with gethostname (builtin_function_or_method, _socket); same class type as hashlib.new (extra157); no prior socket spec anchors this as a standalone; first standalone under sockfn155"
  category: identity
  kind: python_call_eq
  function: getaddrinfo.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__module__.__eq__('_socket') — standalone
#
# socket.gethostname.__module__ is '_socket' (7 chars). gethostname() is a C extension
# function from the _socket module that returns the hostname of the machine (as configured
# in the OS). Unlike getaddrinfo() which is a Python wrapper (__module__=='socket'),
# gethostname() is implemented in C and has __module__ == '_socket'. This makes
# gethostname.__class__.__name__ == 'builtin_function_or_method' (26 chars) and
# __module__ == '_socket' (7 chars). The contrast between gethostname (C, _socket)
# and getaddrinfo (Python, socket) illustrates how some socket functions are
# C-level while others are Python-level wrappers. No prior socket spec anchors
# gethostname.__module__ as a standalone under sockfn155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra155.gethostname_module_socket:
  description: "socket.gethostname.__module__.__eq__('_socket') == True — '_socket' (7 chars); C extension from _socket; returns machine hostname from OS; __class__.__name__=='builtin_function_or_method' (26 chars); contrasts with getaddrinfo (__module__=='socket', 'function' class); both gethostname and setdefaulttimeout have __module__=='_socket'; '_socket' (7) vs 'socket' (6): underscore prefix distinguishes C extension from Python module; no prior socket spec anchors this as a standalone; first standalone under sockfn155"
  category: identity
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true
