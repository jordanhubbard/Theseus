spec: threading_extra2011
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "threading synchronization primitives are not arithmetic types — none define arithmetic operators."
    - "threading.Thread: Python class for managing OS threads — arithmetic dunders absent from __dict__."
    - "threading.Event: Python synchronization primitive — arithmetic dunders absent from __dict__."
    - "threading.Lock: C-level lock type — arithmetic dunders absent from __dict__."
    - "threading.Condition: Python synchronization primitive — arithmetic dunders absent from __dict__."
    - "threading.Semaphore: Python counting semaphore — arithmetic dunders absent from __dict__."
    - "threading.Barrier: Python reusable barrier — arithmetic dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for threading types
#
# threading.Thread, threading.Event, threading.Lock, threading.Condition,
# threading.Semaphore, threading.Barrier are concurrency primitives with no
# arithmetic semantics. None define addition operators in their __dict__.
# All checks expected False.
# ---------------------------------------------------------------------------

table threading_extra2011.add_protocol:
  description: "threading types __add__/__radd__/__iadd__ dict-presence checks — all False — wave 581 _extra2011"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2011

  columns: [id, function, args, expected]
  rows:
    - ["th2011001", "threading.Thread.__dict__.__contains__", ["__add__"], false]
    - ["th2011002", "threading.Thread.__dict__.__contains__", ["__radd__"], false]
    - ["th2011003", "threading.Thread.__dict__.__contains__", ["__iadd__"], false]
    - ["th2011004", "threading.Event.__dict__.__contains__", ["__add__"], false]
    - ["th2011005", "threading.Event.__dict__.__contains__", ["__radd__"], false]
    - ["th2011006", "threading.Event.__dict__.__contains__", ["__iadd__"], false]
    - ["th2011007", "threading.Condition.__dict__.__contains__", ["__add__"], false]
    - ["th2011008", "threading.Condition.__dict__.__contains__", ["__radd__"], false]
    - ["th2011009", "threading.Condition.__dict__.__contains__", ["__iadd__"], false]
    - ["th2011010", "threading.Semaphore.__dict__.__contains__", ["__add__"], false]
    - ["th2011011", "threading.Semaphore.__dict__.__contains__", ["__radd__"], false]
    - ["th2011012", "threading.Semaphore.__dict__.__contains__", ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Table 2: __mul__ / __rmul__ / __imul__ dict-presence for threading types
#
# threading.Lock, threading.Barrier, threading.Semaphore, threading.Thread
