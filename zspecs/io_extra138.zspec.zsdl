spec: io_extra138
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io.BufferedReader and io.BufferedWriter class hierarchy identity — __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()."
    - "io.BufferedReader.__name__ == 'BufferedReader' — the class name."
    - "io.BufferedReader.__module__ == '_io' — BufferedReader is a C extension type from the _io module, not the pure Python io wrapper."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — qualname equals __name__ for module-level C types."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader directly extends the private C base _BufferedIOBase."
    - "io.BufferedReader.__mro__.__len__() == 4 — MRO is [BufferedReader, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' — the class name."
    - "io.BufferedWriter.__module__ == '_io' — BufferedWriter is a C extension type from the _io module."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — qualname equals __name__ for module-level C types."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter directly extends _BufferedIOBase."
    - "io.BufferedWriter.__mro__.__len__() == 4 — MRO is [BufferedWriter, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedRandom.__module__ == '_io' — BufferedRandom is also a C extension type from _io."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom also extends _BufferedIOBase."
    - "io.BufferedRandom.__mro__.__len__() == 4 — MRO is [BufferedRandom, _BufferedIOBase, _IOBase, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader class hierarchy identity
# BufferedReader is a C extension type from _io. __name__ == 'BufferedReader',
# __module__ == '_io', __qualname__ == 'BufferedReader'.
# __bases__[0].__name__ == '_BufferedIOBase'. MRO length == 4.
# ---------------------------------------------------------------------------

table io_extra138.BufferedReader_identity:
  description: "io.BufferedReader class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobufrd138

