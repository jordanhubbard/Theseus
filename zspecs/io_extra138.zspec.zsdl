  rows:
    - [br_name_eq,      BufferedReader.__name__.__eq__,                 ["BufferedReader"],    true]
    - [br_name_not_rnd, BufferedReader.__name__.__eq__,                 ["BufferedRandom"],    false]
    - [br_module_eq,    BufferedReader.__module__.__eq__,               ["_io"],               true]
    - [br_module_not,   BufferedReader.__module__.__eq__,               ["io"],                false]
    - [br_qualname_eq,  BufferedReader.__qualname__.__eq__,             ["BufferedReader"],    true]
    - [br_base_eq,      "BufferedReader.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"],   true]
    - [br_base_not_raw, "BufferedReader.__bases__[0].__name__.__eq__",  ["_RawIOBase"],        false]
    - [br_mro_len,      BufferedReader.__mro__.__len__,                 [],                    4]

