invariant io_extra138.BufferedReader.name_is_BufferedReader:
  description: "io.BufferedReader.__name__ == 'BufferedReader' (the class name as defined in the _io C extension)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra138.BufferedReader.module_is_underscore_io:
  description: "io.BufferedReader.__module__ == '_io' (BufferedReader is a C extension type from the _io internal module, not the pure Python io wrapper)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra138.BufferedReader.mro_len_4:
  description: "io.BufferedReader.__mro__.__len__() == 4 (MRO is [BufferedReader, _BufferedIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__mro__.__len__
  args: []
  expected: 4

invariant io_extra138.BufferedWriter.name_is_BufferedWriter:
  description: "io.BufferedWriter.__name__ == 'BufferedWriter' (the class name as defined in the _io C extension)"
  category: class_identity
  kind: python_call_eq
