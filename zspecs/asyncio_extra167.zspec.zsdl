    - [th_name_len,      asyncio.TimerHandle.__name__.__len__,                [],                  11,    "TimerHandle.__name__.__len__() == 11 ('TimerHandle'=11; Handle=6 is the base-class suffix; 'Timer'=5 is the prefix); verified with Python 3.14.3"]
