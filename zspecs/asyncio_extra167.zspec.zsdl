    - [ael_base_name_eq,  "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__",  ["object"],  true,  "AbstractEventLoop.__bases__[0].__name__ == 'object' (inherits from object; no intermediate ABC); verified with Python 3.14.3"]
    - [ael_base_name_len, "asyncio.AbstractEventLoop.__bases__[0].__name__.__len__", [],          6,     "AbstractEventLoop.__bases__[0].__name__.__len__() == 6 ('object'=6; same as Handle name len=6); verified with Python 3.14.3"]
