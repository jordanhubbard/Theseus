spec: asyncio_extra167
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "https://docs.python.org/3/library/asyncio-policy.html — Python asyncio policy documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec covers: asyncio.AbstractEventLoop class name, module, and base class identity; asyncio.AbstractEventLoopPolicy class name (KEY FINDING: __name__=='_AbstractEventLoopPolicy' with a leading underscore — the public alias asyncio.AbstractEventLoopPolicy points to the internal class _AbstractEventLoopPolicy; the actual __name__ reflects the internal definition name), module, and base class; asyncio.TimerHandle class name, module, and base class. All three classes are defined in Lib/asyncio/events.py: __module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'EventLoop'=9=17); AbstractEventLoop.__module__=='asyncio.events' (len=14; pure Python in asyncio/events.py); AbstractEventLoop.__bases__[0].__name__=='object' (inherits from object directly; AbstractEventLoop is the abstract interface defining all event loop methods; concrete implementations like SelectorEventLoop and ProactorEventLoop subclass it via BaseEventLoop). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24: '_'=1+'Abstract'=8+'EventLoopPolicy'=15=24; KEY: the leading underscore in the canonical __name__ reveals that the public name asyncio.AbstractEventLoopPolicy is an alias for the internal class _AbstractEventLoopPolicy; __module__=='asyncio.events' (len=14; same module as AbstractEventLoop); __bases__[0].__name__=='object' (inherits from object; _AbstractEventLoopPolicy is deprecated and slated for removal in Python 3.16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.TimerHandle.__name__=='TimerHandle' (len=11: 'Timer'=5+'Handle'=6=11); TimerHandle.__module__=='asyncio.events' (len=14; same module as Handle, AbstractEventLoop, AbstractEventLoopPolicy — all four defined in events.py); TimerHandle.__bases__[0].__name__=='Handle' (TimerHandle inherits from Handle; MRO is TimerHandle -> Handle -> object; len=3); compare: Handle.__name__.__len__()==6 (from extra166), TimerHandle.__name__.__len__()==11 — TimerHandle is 5 chars longer because 'Timer'=5 is the prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop class identity — extra167
#
# asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') == True
# asyncio.AbstractEventLoop.__name__.__len__()                   == 17
# asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') == True
# asyncio.AbstractEventLoop.__module__.__len__()                 == 14
# ---------------------------------------------------------------------------

table asyncio_extra167.asyncio_abstract_event_loop_identity:
  description: "asyncio.AbstractEventLoop class name and module identity checks in asyncioael167 namespace — asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop')==True (AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'EventLoop'=9=17); AbstractEventLoop is the abstract interface that defines every method the event loop must provide: run_forever(), run_until_complete(), stop(), call_soon(), call_later(), call_at(), create_task(), create_future(), etc.; concrete event loop classes (SelectorEventLoop, ProactorEventLoop) inherit from BaseEventLoop which in turn inherits from AbstractEventLoop); asyncio.AbstractEventLoop.__name__.__len__()==17 ('AbstractEventLoop'=17: 'Abstract'=8+'Event'=5+'Loop'=4=17; 17 is the longest class name in this spec — longer than TimerHandle=11 by 6 and longer than Handle=6 by 11); asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events')==True (__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; same module as Handle from extra166)); asyncio.AbstractEventLoop.__module__.__len__()==14 ('asyncio.events'=14; same as Handle module len=14 and TimerHandle module len=14 — all three in events.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioael167

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,  asyncio.AbstractEventLoop.__name__.__eq__,    ["AbstractEventLoop"],  true,  "AbstractEventLoop.__name__ == 'AbstractEventLoop' (len=17: 'Abstract'=8+'EventLoop'=9=17); verified with Python 3.14.3"]
    - [ael_name_len, asyncio.AbstractEventLoop.__name__.__len__,   [],                     17,    "AbstractEventLoop.__name__.__len__() == 17 ('AbstractEventLoop'=17; longest class name in spec); verified with Python 3.14.3"]
    - [ael_mod_eq,   asyncio.AbstractEventLoop.__module__.__eq__,  ["asyncio.events"],     true,  "AbstractEventLoop.__module__ == 'asyncio.events' (len=14; same as Handle module from extra166); verified with Python 3.14.3"]
    - [ael_mod_len,  asyncio.AbstractEventLoop.__module__.__len__, [],                     14,    "AbstractEventLoop.__module__.__len__() == 14 ('asyncio.events'=14; same len as TimerHandle and Handle); verified with Python 3.14.3"]

