# ---------------------------------------------------------------------------
# Standalone invariants — extra167
# ---------------------------------------------------------------------------

invariant asyncio_extra167.asyncio_AbstractEventLoop_name_eq:
  description: "asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') returns True — asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17); AbstractEventLoop is the abstract base class that defines the event loop interface in asyncio; all concrete event loop implementations must inherit from AbstractEventLoop (via BaseEventLoop); AbstractEventLoop defines dozens of abstract methods including: run_forever(), run_until_complete(), stop(), close(), call_soon(), call_later(), call_at(), create_future(), create_task(), sock_recv(), sock_sendall(), getaddrinfo(), getnameinfo(), and many more; AbstractEventLoop.__module__=='asyncio.events' (len=14; same module as Handle from extra166); AbstractEventLoop.__bases__[0].__name__=='object' (inherits from object; the class itself provides no implementation — all methods raise NotImplementedError); compare: asyncio.Handle.__name__.__len__()==6 (from extra166) vs AbstractEventLoop.__name__.__len__()==17 — AbstractEventLoop is 11 chars longer than Handle; NEW in extra167: first standalone AbstractEventLoop.__name__ identity invariant in asyncioael167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra167.asyncio_AbstractEventLoop_module_eq:
  description: "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') returns True — asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); AbstractEventLoop is defined in Lib/asyncio/events.py — the same module that defines Handle (from extra166), TimerHandle, AbstractEventLoopPolicy, and AbstractChildWatcher; 'asyncio.events' module (len=14) is the hub of the asyncio architecture: it defines the public interface (AbstractEventLoop, AbstractEventLoopPolicy), the scheduling primitives (Handle, TimerHandle), and the global policy functions (get_event_loop, set_event_loop, new_event_loop); compare: asyncio.Future.__module__=='_asyncio' (len=8; from extra166) is 6 chars shorter than asyncio.events=14 because Future is C-accelerated; AbstractEventLoop is pure Python in asyncio.events — no C acceleration needed for an abstract interface; NEW in extra167: first standalone AbstractEventLoop.__module__ identity invariant in asyncioael167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra167.asyncio_AbstractEventLoop_base_is_object:
  description: "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object') returns True — asyncio.AbstractEventLoop.__bases__[0] is object; __bases__[0].__name__=='object' (len=6); AbstractEventLoop inherits from object directly with no intermediate ABC; all its methods are 'abstract' by convention (raise NotImplementedError or return NotImplemented) rather than via @abstractmethod and ABCMeta; the inheritance chain for a concrete loop is: SelectorEventLoop -> BaseSelectorEventLoop -> BaseEventLoop -> AbstractEventLoop -> object; compare: asyncio.Task.__bases__[0].__name__=='Future' (from extra166; Task inherits from Future, not object) vs AbstractEventLoop.__bases__[0].__name__=='object' (AbstractEventLoop IS the root — it has no asyncio parent class); NEW in extra167: first standalone AbstractEventLoop.__bases__[0].__name__ invariant in asyncioaelb167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra167.asyncio_AbstractEventLoopPolicy_name_eq:
  description: "asyncio.AbstractEventLoopPolicy.__name__.__eq__('_AbstractEventLoopPolicy') returns True — KEY FINDING: asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24: '_'=1+'Abstract'=8+'EventLoop'=9+'Policy'=6=24); the leading underscore in the canonical __name__ reveals that asyncio.AbstractEventLoopPolicy is a PUBLIC ALIAS pointing to the internal class _AbstractEventLoopPolicy; Python __name__ always reflects the name at class definition time, not any alias; _AbstractEventLoopPolicy is the actual class definition in Lib/asyncio/events.py while AbstractEventLoopPolicy is the public-facing alias; this pattern mirrors asyncio.AbstractEventLoopPolicy being deprecated and slated for removal in Python 3.16 — the leading underscore marks the class as private/internal even though it was historically exposed publicly; compare: asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (no leading underscore — AbstractEventLoop is not deprecated and is a proper public API); NEW in extra167: first standalone AbstractEventLoopPolicy.__name__ identity invariant in asyncioaelp167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoopPolicy.__name__.__eq__
  args: ["_AbstractEventLoopPolicy"]
  expected: true

invariant asyncio_extra167.asyncio_AbstractEventLoopPolicy_module_eq:
  description: "asyncio.AbstractEventLoopPolicy.__module__.__eq__('asyncio.events') returns True — asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (len=14: same module as AbstractEventLoop, Handle, TimerHandle); all four public asyncio classes in this spec are defined in the single file Lib/asyncio/events.py; AbstractEventLoopPolicy defines the policy interface: get_event_loop(), set_event_loop(), new_event_loop(), and (on Unix) get_child_watcher()/set_child_watcher(); the default policy implementation (DefaultEventLoopPolicy) is also defined in events.py; AbstractEventLoopPolicy.__module__.__len__()==14 == AbstractEventLoop.__module__.__len__()==14 == Handle.__module__.__len__()==14 — all three share the same 14-char module path; NEW in extra167: first standalone AbstractEventLoopPolicy.__module__ identity invariant in asyncioaelp167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoopPolicy.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra167.asyncio_TimerHandle_name_eq:
  description: "asyncio.TimerHandle.__name__.__eq__('TimerHandle') returns True — asyncio.TimerHandle.__name__=='TimerHandle' (len=11: 'Timer'=5+'Handle'=6=11); asyncio.TimerHandle is returned by loop.call_later(delay, callback, *args) and loop.call_at(when, callback, *args); unlike Handle (from call_soon()), TimerHandle stores the scheduled execution time and can be compared against other TimerHandles for ordering in the event loop's heap (TimerHandle implements __lt__ for heap ordering); TimerHandle.cancel() is overridden to also prevent stale handles from firing — setting a flag that the event loop checks when the timer fires; TimerHandle.__bases__[0].__name__=='Handle' (TimerHandle inherits from Handle; the 'Handle'=6 suffix in TimerHandle's name matches the parent class name length); compare: asyncio.Handle.__name__.__len__()==6 (from extra166) + 'Timer'=5 prefix = TimerHandle.__name__.__len__()==11; NEW in extra167: first standalone TimerHandle.__name__ identity invariant in asyncioth167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TimerHandle.__name__.__eq__
  args: ["TimerHandle"]
  expected: true

invariant asyncio_extra167.asyncio_TimerHandle_base_is_Handle:
  description: "asyncio.TimerHandle.__bases__[0].__name__.__eq__('Handle') returns True — asyncio.TimerHandle.__bases__[0] is asyncio.Handle; TimerHandle.__bases__[0].__name__=='Handle' (len=6: 'H'+'a'+'n'+'d'+'l'+'e'=6; established in extra166); the MRO is TimerHandle -> Handle -> object (len=3); TimerHandle IS a Handle — isinstance(timer_handle, asyncio.Handle) is True for any TimerHandle; TimerHandle extends Handle by adding: _when (the scheduled time as float), _scheduled (flag for whether the handle is in the heap), __lt__ (comparison for heap ordering), and an overridden cancel() that also removes from the heap; compare: asyncio.Task.__bases__[0].__name__=='Future' (Task inherits from Future — established in extra166); asyncio.TimerHandle.__bases__[0].__name__=='Handle' (TimerHandle inherits from Handle — same inheritance pattern of a specialized subclass inheriting from a generic handle/future parent); Handle(6) is the parent class name and its length equals 'Future'(6) — both base class names are 6 chars; NEW in extra167: first standalone TimerHandle.__bases__[0].__name__ invariant in asyncioth167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.TimerHandle.__bases__[0].__name__.__eq__"
  args: ["Handle"]
  expected: true

