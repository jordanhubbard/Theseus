table asyncio_extra167.asyncio_timer_handle_identity:
  description: "asyncio.TimerHandle class name, module, and base class identity checks in asyncioth167 namespace — asyncio.TimerHandle.__name__.__eq__('TimerHandle')==True (TimerHandle.__name__=='TimerHandle' (len=11: 'Timer'=5+'Handle'=6=11); asyncio.TimerHandle is the subclass of Handle returned by loop.call_later() and loop.call_at(); unlike Handle (from call_soon()), TimerHandle carries a scheduled execution time and implements cancellation with cancel() that also prevents stale handles from firing in the timer heap); asyncio.TimerHandle.__name__.__len__()==11 ('TimerHandle'=11: 'Timer'=5+'Handle'=6=11; Handle=6 is the suffix, so TimerHandle(11) = Handle(6) + 'Timer'(5)); asyncio.TimerHandle.__module__.__eq__('asyncio.events')==True (__module__=='asyncio.events' (len=14; same as Handle from extra166, AbstractEventLoop, and AbstractEventLoopPolicy — all four in events.py)); asyncio.TimerHandle.__bases__[0].__name__.__eq__('Handle')==True (__bases__[0].__name__=='Handle' (len=6: TimerHandle inherits from Handle; the MRO is TimerHandle -> Handle -> object (len=3))); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioth167

  columns: [id, function, args, expected, description]
  rows:
