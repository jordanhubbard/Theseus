spec: multiprocessing_extra1576
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "Tests cover __name__, __str__, __repr__ of multiprocessing exception classes, current_process() string properties, and cpu_count()."
    - "multiprocessing.ProcessError is the base class for all multiprocessing-specific exceptions."
    - "multiprocessing.AuthenticationError, BufferTooShort, ProcessError, and TimeoutError are all covered."
    - "current_process() returns the Process object for the main process; calling it in the main process gives name='MainProcess'."
    - "cpu_count() returns an int >= 1."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Exception class __name__ identity
# ---------------------------------------------------------------------------

table multiprocessing_extra1576.exception_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: mp1576

  columns: [id, function, args, expected]
  rows:
    - ["mp1576_001", "ProcessError.__name__.__eq__",        ["ProcessError"],        true]
    - ["mp1576_002", "AuthenticationError.__name__.__eq__", ["AuthenticationError"], true]
    - ["mp1576_003", "BufferTooShort.__name__.__eq__",      ["BufferTooShort"],      true]
    - ["mp1576_004", "TimeoutError.__name__.__eq__",        ["TimeoutError"],        true]

# ---------------------------------------------------------------------------
# __str__ of zero-argument exception instances — str(ExcClass()) == ""
# ---------------------------------------------------------------------------

table multiprocessing_extra1576.exception_str_empty:
  kind: python_call_eq
  category: str_repr
  id_prefix: mp1576

  columns: [id, function, args, expected]
  rows:
    - ["mp1576_010", "ProcessError.__str__",        [], ""]
    - ["mp1576_011", "AuthenticationError.__str__", [], ""]
    - ["mp1576_012", "BufferTooShort.__str__",      [], ""]
    - ["mp1576_013", "TimeoutError.__str__",        [], ""]

# ---------------------------------------------------------------------------
# __repr__ of zero-argument exception instances — repr(ExcClass()) == "ExcClass()"
# ---------------------------------------------------------------------------

table multiprocessing_extra1576.exception_repr:
  kind: python_call_eq
  category: str_repr
  id_prefix: mp1576

  columns: [id, function, args, expected]
  rows:
    - ["mp1576_020", "ProcessError.__repr__",        [], "ProcessError()"]
    - ["mp1576_021", "AuthenticationError.__repr__", [], "AuthenticationError()"]
    - ["mp1576_022", "BufferTooShort.__repr__",      [], "BufferTooShort()"]
    - ["mp1576_023", "TimeoutError.__repr__",        [], "TimeoutError()"]

# ---------------------------------------------------------------------------
# __str__ and __repr__ of exception instances with a message
# str(ExcClass("msg")) == "msg", repr(ExcClass("msg")) == "ExcClass('msg')"
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1576.authentication_error.str_with_msg:
  description: "str(multiprocessing.AuthenticationError('auth failed')) == 'auth failed'"
  category: str_repr
  kind: python_call_eq
  function: AuthenticationError
  args: ["auth failed"]
  method: __str__
  expected: "auth failed"

invariant multiprocessing_extra1576.authentication_error.repr_with_msg:
  description: "repr(multiprocessing.AuthenticationError('auth failed')) == \"AuthenticationError('auth failed')\""
  category: str_repr
  kind: python_call_eq
  function: AuthenticationError
  args: ["auth failed"]
  method: __repr__
  expected: "AuthenticationError('auth failed')"

invariant multiprocessing_extra1576.buffer_too_short.str_with_msg:
  description: "str(multiprocessing.BufferTooShort('too short')) == 'too short'"
  category: str_repr
  kind: python_call_eq
  function: BufferTooShort
  args: ["too short"]
  method: __str__
  expected: "too short"

invariant multiprocessing_extra1576.process_error.repr_with_msg:
  description: "repr(multiprocessing.ProcessError('oops')) == \"ProcessError('oops')\""
  category: str_repr
  kind: python_call_eq
  function: ProcessError
  args: ["oops"]
  method: __repr__
  expected: "ProcessError('oops')"

# ---------------------------------------------------------------------------
# Inheritance — exception parent class names
# AuthenticationError and BufferTooShort are both subclasses of ProcessError.
# ProcessError is a subclass of Exception.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1576.authentication_error.parent_is_process_error:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'"
  category: inheritance
  kind: python_call_eq
  function: AuthenticationError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ProcessError"

invariant multiprocessing_extra1576.buffer_too_short.parent_is_process_error:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'"
  category: inheritance
  kind: python_call_eq
  function: BufferTooShort.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ProcessError"

invariant multiprocessing_extra1576.process_error.parent_is_exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'"
  category: inheritance
  kind: python_call_eq
  function: ProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# current_process() — string representation of the main process object
# In the main process: name == 'MainProcess', daemon == False.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1576.current_process.name_is_main_process:
  description: "multiprocessing.current_process().name == 'MainProcess'"
  category: process
  kind: python_call_eq
  function: current_process
  args: []
  method: name
  expected: "MainProcess"

invariant multiprocessing_extra1576.current_process.name_is_str:
  description: "isinstance(multiprocessing.current_process().name, str) — name attribute is a string"
  category: process
  kind: python_call_eq
  function: current_process
  args: []
  method: name
  method_chain: __class__.__name__
  expected: "str"

invariant multiprocessing_extra1576.current_process.daemon_is_false:
  description: "multiprocessing.current_process().daemon == False — main process is not a daemon"
  category: process
  kind: python_call_eq
  function: current_process
  args: []
  method: daemon
  expected: false

invariant multiprocessing_extra1576.current_process.name_len:
  description: "len(multiprocessing.current_process().name) == 11 — 'MainProcess' has 11 chars"
  category: process
  kind: python_call_eq
  function: current_process
  args: []
  method: name
  method_chain: __len__
  expected: 11

# ---------------------------------------------------------------------------
# cpu_count() — returns an int >= 1
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1576.cpu_count.is_int:
  description: "type(multiprocessing.cpu_count()).__name__ == 'int'"
  category: system
  kind: python_call_eq
  function: cpu_count
  args: []
  method_chain: __class__.__name__
  expected: "int"

invariant multiprocessing_extra1576.cpu_count.str_is_numeric:
  description: "str(multiprocessing.cpu_count()).isnumeric() == True — cpu_count str is a number"
  category: system
  kind: python_call_eq
  function: cpu_count
  args: []
  method_chain: __str__.__call__
  expected: true

# ---------------------------------------------------------------------------
# Exception class __module__ — all multiprocessing exceptions belong to
# the multiprocessing package namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra1576.exception_modules:
  kind: python_call_eq
  category: module
  id_prefix: mp1576

  columns: [id, function, args, expected]
  rows:
    - ["mp1576_030", "ProcessError.__module__.__contains__",        ["multiprocessing"], true]
    - ["mp1576_031", "AuthenticationError.__module__.__contains__", ["multiprocessing"], true]
    - ["mp1576_032", "BufferTooShort.__module__.__contains__",      ["multiprocessing"], true]
