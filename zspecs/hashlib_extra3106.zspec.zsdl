spec: hl3106
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (hl3106): __lt__, __le__, __gt__ dict-presence checks for hashlib types."
    - "type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "type(hashlib.blake2s(b'')) is _blake2.blake2s — distinct from HASH and blake2b."
    - "None of these types define __lt__, __le__, or __gt__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3106.lt:
  description: "hashlib types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3106
  columns: [id, function, args, expected]
  rows:
    - ["hl3106001", operator.contains, [type(hashlib.md5()).__dict__,        "__lt__"], false]
    - ["hl3106002", operator.contains, [type(hashlib.sha256()).__dict__,     "__lt__"], false]
    - ["hl3106003", operator.contains, [type(hashlib.sha512()).__dict__,     "__lt__"], false]
    - ["hl3106004", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__lt__"], false]
    - ["hl3106005", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__lt__"], false]

