spec: xdrlib_extra3
version: ">=3.9,<3.13"
backend: python_module(xdrlib)

docs: https://docs.python.org/3/library/xdrlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xdrlib.html — Python xdrlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xdrlib.py"
  notes:
    - "This spec extends xdrlib.zspec.zsdl, xdrlib_extra.zspec.zsdl, and xdrlib_extra2.zspec.zsdl."
    - "Deprecated since Python 3.11; removed in Python 3.13. Version range is >=3.9,<3.13."
    - "xdrlib.zspec.zsdl covers: Packer/__name__/__module__; Unpacker/__name__; Error/__name__/__bases__; ConversionError/__name__/__bases__; Packer instantiation and method checks."
    - "xdrlib_extra.zspec.zsdl covers: Packer/__name__/__module__/__class__; Unpacker/__name__/__module__/__class__; Error/__name__/__bases__/__class__/__module__; ConversionError/__name__/__bases__/__class__/__module__."
    - "xdrlib_extra2.zspec.zsdl covers: Packer/__qualname__/qualname_no_dots; Unpacker/__qualname__/__module__/qualname_no_dots; ConversionError/__qualname__; Error/__qualname__."
    - "This spec adds: Packer.__bases__[0].__name__ == 'object'; Unpacker.__bases__[0].__name__ == 'object'; Error.__bases__.__len__ == 1; ConversionError.__bases__.__len__ == 1; xdrlib module __name__ attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Packer base class — Packer inherits directly from object
# Not covered in any prior xdrlib spec.
# ---------------------------------------------------------------------------

invariant xdrlib_extra3.Packer.base_is_object:
  description: "xdrlib.Packer.__bases__[0].__name__ == 'object' — Packer inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Packer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Unpacker base class — Unpacker inherits directly from object
# Not covered in any prior xdrlib spec.
# ---------------------------------------------------------------------------

invariant xdrlib_extra3.Unpacker.base_is_object:
  description: "xdrlib.Unpacker.__bases__[0].__name__ == 'object' — Unpacker inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Unpacker.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Error.__bases__ length — exactly one base class (Exception)
# Not covered in any prior xdrlib spec.
# ---------------------------------------------------------------------------

invariant xdrlib_extra3.Error.bases_len:
  description: "xdrlib.Error.__bases__.__len__() == 1 — Error has exactly one base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# ConversionError.__bases__ length — exactly one base class (Error)
# Not covered in any prior xdrlib spec.
# ---------------------------------------------------------------------------

invariant xdrlib_extra3.ConversionError.bases_len:
  description: "xdrlib.ConversionError.__bases__.__len__() == 1 — ConversionError has exactly one base class"
  category: class_hierarchy
  kind: python_call_eq
  function: ConversionError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Module __name__ attribute — xdrlib.__name__ == 'xdrlib'
# Not covered in any prior xdrlib spec.
# ---------------------------------------------------------------------------

table xdrlib_extra3.module_names:
  kind: python_call_eq
  category: module
  id_prefix: modname

  columns: [id, function, args, expected]
  rows:
    - [packer_name,           Packer.__name__.__eq__,           ["Packer"],           true]
    - [unpacker_name,         Unpacker.__name__.__eq__,         ["Unpacker"],         true]
    - [error_name,            Error.__name__.__eq__,            ["Error"],            true]
    - [conversion_error_name, ConversionError.__name__.__eq__,  ["ConversionError"],  true]
