spec: hashlib_extra191
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "hashlib.sha256.__doc__ is a str — OpenSSL-backed constructors expose docstrings; __class__.__name__ == 'str'."
    - "hashlib.md5.__doc__ is a str — OpenSSL-backed md5 constructor has a docstring."
    - "hashlib.blake2b.__doc__ is a str — blake2b constructor has a docstring."
    - "hashlib.algorithms_guaranteed is a set containing at minimum: sha256, sha512, sha3_512, shake_256, sha384, md5, sha1, blake2b."
    - "algorithms_guaranteed has len 14 on Python 3.14.3/macOS Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib hash constructor __doc__ class identity
#
# hashlib.sha256.__doc__.__class__.__name__ == 'str'
# hashlib.md5.__doc__.__class__.__name__    == 'str'
# hashlib.blake2b.__doc__.__class__.__name__ == 'str'
#
# OpenSSL-backed hash constructors (sha256, md5) and the built-in blake2b
# constructor all expose docstrings as Python str objects.  This table
# asserts that those docstrings exist and are of type str.
# ---------------------------------------------------------------------------

table hashlib_extra191.constructor_doc_class:
  description: "hashlib hash constructor __doc__ class is str; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc191

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_class_eq,
       hashlib.sha256.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "hashlib.sha256.__doc__.__class__.__name__.__eq__('str') == True — OpenSSL sha256 constructor has a docstring; new to extra191"]
    - [md5_doc_class_eq,
       hashlib.md5.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "hashlib.md5.__doc__.__class__.__name__.__eq__('str') == True — OpenSSL md5 constructor has a docstring; new to extra191"]
    - [blake2b_doc_class_eq,
       hashlib.blake2b.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "hashlib.blake2b.__doc__.__class__.__name__.__eq__('str') == True — blake2b constructor has a docstring; new to extra191"]
    - [sha256_doc_class_len,
       hashlib.sha256.__doc__.__class__.__name__.__len__,
       [],
       3,
       "hashlib.sha256.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to extra191"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.algorithms_guaranteed membership — core digest algorithms
#
# hashlib.algorithms_guaranteed.__contains__('sha256')  == True
# hashlib.algorithms_guaranteed.__contains__('sha512')  == True
# hashlib.algorithms_guaranteed.__contains__('sha384')  == True
# hashlib.algorithms_guaranteed.__contains__('md5')     == True
#
# algorithms_guaranteed is the frozenset of hash names that are available
# on ALL Python implementations.  The names here are guaranteed on every
# conforming 3.x installation.
# ---------------------------------------------------------------------------

table hashlib_extra191.algorithms_guaranteed_core:
  description: "hashlib.algorithms_guaranteed contains core digest algorithms; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc191

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_sha256,
       hashlib.algorithms_guaranteed.__contains__,
       ["sha256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all platforms; new to extra191"]
    - [guaranteed_sha512,
       hashlib.algorithms_guaranteed.__contains__,
       ["sha512"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha512') == True — sha512 is guaranteed on all platforms; new to extra191"]
    - [guaranteed_sha384,
       hashlib.algorithms_guaranteed.__contains__,
       ["sha384"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha384') == True — sha384 is guaranteed on all platforms; new to extra191"]
    - [guaranteed_md5,
       hashlib.algorithms_guaranteed.__contains__,
       ["md5"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed on all platforms; new to extra191"]

# ---------------------------------------------------------------------------
# Table 3: hashlib.algorithms_guaranteed membership — SHA-3 and SHAKE algorithms
#
# hashlib.algorithms_guaranteed.__contains__('sha3_512')   == True
# hashlib.algorithms_guaranteed.__contains__('shake_256')  == True
#
# SHA-3 family (sha3_256, sha3_512) and extendable output functions
# (shake_128, shake_256) were added to algorithms_guaranteed in Python 3.6
# when hashlib gained native SHA-3 support via OpenSSL 1.1+.
# ---------------------------------------------------------------------------

table hashlib_extra191.algorithms_guaranteed_sha3:
  description: "hashlib.algorithms_guaranteed contains SHA-3 and SHAKE algorithms; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc191

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_sha3_512,
       hashlib.algorithms_guaranteed.__contains__,
       ["sha3_512"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True — SHA-3 512-bit is guaranteed; Python 3.6+; new to extra191"]
    - [guaranteed_shake_256,
       hashlib.algorithms_guaranteed.__contains__,
       ["shake_256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('shake_256') == True — SHAKE-256 XOF is guaranteed; Python 3.6+; new to extra191"]
    - [guaranteed_blake2b,
       hashlib.algorithms_guaranteed.__contains__,
       ["blake2b"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed; Python 3.6+; new to extra191"]
    - [guaranteed_sha1,
       hashlib.algorithms_guaranteed.__contains__,
       ["sha1"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha1') == True — sha1 is guaranteed on all platforms; new to extra191"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra191
# ---------------------------------------------------------------------------

invariant hashlib_extra191.sha256_doc_is_str:
  description: "hashlib.sha256.__doc__.__class__.__name__ == 'str' — OpenSSL sha256 constructor has a str docstring; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.sha256.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra191.md5_doc_is_str:
  description: "hashlib.md5.__doc__.__class__.__name__ == 'str' — OpenSSL md5 constructor has a str docstring; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.md5.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra191.blake2b_doc_is_str:
  description: "hashlib.blake2b.__doc__.__class__.__name__ == 'str' — blake2b constructor has a str docstring; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.blake2b.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra191.algorithms_guaranteed_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 guaranteed on all platforms; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra191.algorithms_guaranteed_sha512:
  description: "hashlib.algorithms_guaranteed.__contains__('sha512') == True — sha512 guaranteed on all platforms; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha512"]
  expected: true

invariant hashlib_extra191.algorithms_guaranteed_sha3_512:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True — SHA-3 512-bit guaranteed; Python 3.6+; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha3_512"]
  expected: true

invariant hashlib_extra191.algorithms_guaranteed_shake_256:
  description: "hashlib.algorithms_guaranteed.__contains__('shake_256') == True — SHAKE-256 XOF guaranteed; Python 3.6+; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["shake_256"]
  expected: true

invariant hashlib_extra191.algorithms_guaranteed_sha384:
  description: "hashlib.algorithms_guaranteed.__contains__('sha384') == True — sha384 guaranteed on all platforms; new to extra191"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha384"]
  expected: true
