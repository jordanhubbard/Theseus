spec: wave_extra2
version: ">=3.9"
backend: python_module(wave)

docs: https://docs.python.org/3/library/wave.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/wave.html — Python wave module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/wave.py"
    - "wave.zspec.zsdl — covers Wave_read/Wave_write/Error __name__ (table), module checks (table), open __name__, Error base, type checks (table), Wave_read/Wave_write method names (tables)"
    - "wave_extra.zspec.zsdl — covers Wave_read/Wave_write/Error __name__ (table), open __name__, Wave_read.__module__, Error.__bases__[0].__name__"
  notes:
    - "This spec extends wave.zspec.zsdl and wave_extra.zspec.zsdl."
    - "wave.open.__name__ == 'open' — the module-level function for opening WAV files."
    - "wave.Wave_read.__name__ == 'Wave_read' — the class returned for read-mode opens."
    - "wave.Wave_read.__module__ == 'wave' — class is defined in the wave module."
    - "wave.Wave_write.__name__ == 'Wave_write' — the class returned for write-mode opens."
    - "wave.Wave_write.__module__ == 'wave' — class is defined in the wave module."
    - "wave.Error.__name__ == 'Error' — the module-level exception class."
    - "wave.Error.__bases__[0].__name__ == 'Exception' — Error is a direct subclass of Exception."
    - "wave.Error.__module__ == 'wave' — Error is defined directly in the wave module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# wave.open/__name__
# (wave.zspec.zsdl and wave_extra.zspec.zsdl both cover this; explicit here
#  for extra2 completeness as a standalone invariant)
# ---------------------------------------------------------------------------

invariant wave_extra2.open.name:
  description: "wave.open.__name__ == 'open'"
  category: function_identity
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Wave_read — class name and module
# ---------------------------------------------------------------------------

invariant wave_extra2.Wave_read.name:
  description: "wave.Wave_read.__name__ == 'Wave_read'"
  category: class_identity
  kind: python_call_eq
  function: Wave_read.__name__.__eq__
  args: ["Wave_read"]
  expected: true

invariant wave_extra2.Wave_read.module:
  description: "wave.Wave_read.__module__ == 'wave'"
  category: class_identity
  kind: python_call_eq
  function: Wave_read.__module__.__eq__
  args: ["wave"]
  expected: true

# ---------------------------------------------------------------------------
# Wave_write — class name and module
# ---------------------------------------------------------------------------

invariant wave_extra2.Wave_write.name:
  description: "wave.Wave_write.__name__ == 'Wave_write'"
  category: class_identity
  kind: python_call_eq
  function: Wave_write.__name__.__eq__
  args: ["Wave_write"]
  expected: true

invariant wave_extra2.Wave_write.module:
  description: "wave.Wave_write.__module__ == 'wave'"
  category: class_identity
  kind: python_call_eq
  function: Wave_write.__module__.__eq__
  args: ["wave"]
  expected: true

# ---------------------------------------------------------------------------
# Error — class name, hierarchy, and module affiliation
# ---------------------------------------------------------------------------

invariant wave_extra2.Error.name:
  description: "wave.Error.__name__ == 'Error'"
  category: exception_identity
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant wave_extra2.Error.base_is_Exception:
  description: "wave.Error.__bases__[0].__name__ == 'Exception' — Error is a direct subclass of Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant wave_extra2.Error.module:
  description: "wave.Error.__module__ == 'wave' — Error is defined in the wave module"
  category: exception_identity
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["wave"]
  expected: true

# ---------------------------------------------------------------------------
# Error is a type (class)
# ---------------------------------------------------------------------------

invariant wave_extra2.Error.is_type:
  description: "wave.Error.__class__.__name__ == 'type' — Error is a class object"
  category: exception_identity
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Wave_read and Wave_write are types (classes)
# (wave.zspec.zsdl covers this in a table; standalone invariants for extra2)
# ---------------------------------------------------------------------------

invariant wave_extra2.Wave_read.is_type:
  description: "wave.Wave_read.__class__.__name__ == 'type' — Wave_read is a class object"
  category: class_identity
  kind: python_call_eq
  function: Wave_read.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant wave_extra2.Wave_write.is_type:
  description: "wave.Wave_write.__class__.__name__ == 'type' — Wave_write is a class object"
  category: class_identity
  kind: python_call_eq
  function: Wave_write.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# wave.open is a plain Python function (not a type, not a builtin)
# ---------------------------------------------------------------------------

invariant wave_extra2.open.is_function:
  description: "wave.open.__class__.__name__ == 'function' — open is a plain Python function"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["function"]
  expected: true
