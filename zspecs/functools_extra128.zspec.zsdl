spec: functools_extra128
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra127.zspec.zsdl."
    - "This spec covers: functools.singledispatch __code__.co_varnames elements not previously covered — co_varnames[1]='weakref'(7), co_varnames[2]='wrapper'(7); co_varnames.__len__()==3; co_consts.__len__()==9; co_freevars.__len__()==0; wave 274."
    - "Prior spec extra120 covered singledispatch.__code__.co_varnames[0]=='func' and co_name=='singledispatch' and co_argcount==1. New here: co_varnames[1] and co_varnames[2], the total co_varnames length (3), the co_consts length (9), and the co_freevars length (0)."
    - "functools.singledispatch.__code__.co_varnames[1] == 'weakref' (len 7). Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_varnames[2] == 'wrapper' (len 7). Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_varnames.__len__() == 3. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_consts.__len__() == 9. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_freevars.__len__() == 0. Verified with Python 3.14.3."
    - "singledispatch is a pure-Python decorator: co_varnames = ('func', 'weakref', 'wrapper'). 'weakref' is a local used to hold a weak reference to the dispatch registry; 'wrapper' is the inner function returned by singledispatch. co_consts has 9 entries (docstring + nested code objects + string constants). co_freevars is empty because singledispatch is a module-level function with no enclosing scope."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch __code__.co_varnames[1] and [2]
#
# Wave 274 theme: functools.singledispatch(func) is a pure-Python decorator
# defined in Lib/functools.py. Its co_varnames tuple has 3 entries:
#   co_varnames[0] == 'func'    (4 chars) — the decorated function (extra120)
#   co_varnames[1] == 'weakref' (7 chars) — local holding a weakref to registry
#   co_varnames[2] == 'wrapper' (7 chars) — the inner wrapper function returned
#
# 'weakref' and 'wrapper' both have length 7. Prior extra120 covered [0]='func'.
# New here: [1]='weakref' and [2]='wrapper', their string equality and lengths.
#
# singledispatch.__code__.co_varnames[1] == 'weakref'  (len 7)
# singledispatch.__code__.co_varnames[2] == 'wrapper'  (len 7)
#
# New to extra128.
# ---------------------------------------------------------------------------

table functools_extra128.singledispatch_co_varnames_1_and_2:
  description: "functools.singledispatch co_varnames[1]='weakref'(7), [2]='wrapper'(7); both len=7; prior extra120 covered [0]='func'(4); 'weakref' is a local holding a weakref to dispatch registry; 'wrapper' is the returned inner function; wave 274; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssdcv128

  columns: [id, function, args, expected, description]
  rows:
    - [sd_cv1_eq,
       "singledispatch.__code__.co_varnames.__getitem__",
       [1],
       "weakref",
       "functools.singledispatch.__code__.co_varnames[1] == 'weakref' — internal local holding a weak reference to the dispatch cache/registry; used so that the cache is garbage-collectible; tuple.__getitem__(1) returns 'weakref'; prior extra120 covered co_varnames[0]='func'; new to extra128"]
    - [sd_cv1_len,
       "singledispatch.__code__.co_varnames.__getitem__(1).__len__",
       [],
       7,
       "functools.singledispatch.__code__.co_varnames[1].__len__() == 7 — 'weakref' has 7 chars: w-e-a-k-r-e-f; same length as co_varnames[2] 'wrapper' (7); str.__len__() returns 7; new to extra128"]
    - [sd_cv2_eq,
       "singledispatch.__code__.co_varnames.__getitem__",
       [2],
       "wrapper",
       "functools.singledispatch.__code__.co_varnames[2] == 'wrapper' — the inner generic-function wrapper returned by singledispatch; it carries the dispatch logic for calling the right registered implementation; tuple.__getitem__(2) returns 'wrapper'; new to extra128"]
    - [sd_cv2_len,
       "singledispatch.__code__.co_varnames.__getitem__(2).__len__",
       [],
       7,
       "functools.singledispatch.__code__.co_varnames[2].__len__() == 7 — 'wrapper' has 7 chars: w-r-a-p-p-e-r; same length as co_varnames[1] 'weakref' (7) and update_wrapper co_varnames[0] 'wrapper'; str.__len__() returns 7; new to extra128"]
    - [sd_cv1_ne_cv2,
       "singledispatch.__code__.co_varnames.__getitem__(1).__eq__",
       ["wrapper"],
       false,
       "functools.singledispatch.__code__.co_varnames[1].__eq__('wrapper') == False — 'weakref' is not 'wrapper'; distinct locals despite both having length 7; co_varnames[1]='weakref' vs co_varnames[2]='wrapper'; str.__eq__('wrapper') returns False; new to extra128"]
    - [sd_cv2_ne_cv1,
       "singledispatch.__code__.co_varnames.__getitem__(2).__eq__",
       ["weakref"],
       false,
       "functools.singledispatch.__code__.co_varnames[2].__eq__('weakref') == False — 'wrapper' is not 'weakref'; confirming both locals are distinct even though they share length 7; str.__eq__('weakref') returns False; new to extra128"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatch __code__.co_varnames total length
#
# Wave 274 theme: The co_varnames tuple for singledispatch has exactly 3 entries:
# ('func', 'weakref', 'wrapper'). This is more than a simple 1-parameter
# decorator like wraps (which has 3 after including the closure's locals) but
# reveals singledispatch's structure: 1 declared parameter ('func') and 2
# internal locals ('weakref', 'wrapper'). co_argcount is 1 (only 'func' is a
# declared positional parameter), confirming 'weakref' and 'wrapper' are purely
# local variables created inside the function body.
#
# singledispatch.__code__.co_varnames.__len__() == 3
# singledispatch.__code__.co_argcount == 1   (covered prior, confirming here)
#
# New to extra128.
# ---------------------------------------------------------------------------

table functools_extra128.singledispatch_co_varnames_len:
  description: "functools.singledispatch co_varnames len=3 (1 param 'func' + 2 locals 'weakref'+'wrapper'); co_argcount=1; co_freevars len=0 (module-level, no enclosing scope); wave 274; new to extra128"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolssdcvl128

  columns: [id, function, args, expected, description]
  rows:
    - [sd_cv_len,
       "singledispatch.__code__.co_varnames.__len__",
       [],
       3,
       "functools.singledispatch.__code__.co_varnames.__len__() == 3 — co_varnames has 3 entries: ('func', 'weakref', 'wrapper'); 1 declared positional parameter plus 2 internal locals; tuple.__len__() returns 3; new to extra128"]
    - [sd_freevars_len,
       "singledispatch.__code__.co_freevars.__len__",
       [],
       0,
       "functools.singledispatch.__code__.co_freevars.__len__() == 0 — singledispatch is a module-level function with no enclosing scope; therefore co_freevars is empty; its inner 'wrapper' closure captures locals via a different mechanism; tuple.__len__() returns 0; new to extra128"]
    - [sd_cv_len_eq_3,
       "singledispatch.__code__.co_varnames.__len__().__eq__",
       [3],
       true,
       "functools.singledispatch.__code__.co_varnames.__len__().__eq__(3) == True — the co_varnames tuple has exactly 3 entries; int.__eq__(3) returns True; new to extra128"]
    - [sd_freevars_len_eq_0,
       "singledispatch.__code__.co_freevars.__len__().__eq__",
       [0],
       true,
       "functools.singledispatch.__code__.co_freevars.__len__().__eq__(0) == True — co_freevars is empty (len 0) because singledispatch is module-level; int.__eq__(0) returns True; new to extra128"]
    - [sd_cv_class_name,
       "singledispatch.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.singledispatch.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple for any Python code object; str.__eq__('tuple') returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatch __code__.co_consts length
#
# Wave 274 theme: singledispatch.__code__.co_consts has 9 entries. This is many
# more than simpler decorators: update_wrapper has 1 (just the docstring),
# wraps has a small number. singledispatch's co_consts include:
#   - [0] the function docstring
#   - [1] None (used as a sentinel)
#   - [2..5] four nested code objects (dispatch, _is_valid_dispatch_type,
#             register, wrapper)
#   - [6] the string '__name__'
#   - [7] the string 'singledispatch function'
#   - [8] the tuple (None,)
# The large co_consts count reflects singledispatch's complexity as a decorator
# factory that creates nested functions and uses string constants for attribute
# manipulation.
#
# singledispatch.__code__.co_consts.__len__() == 9
#
# New to extra128.
# ---------------------------------------------------------------------------

table functools_extra128.singledispatch_co_consts_len:
  description: "functools.singledispatch co_consts len=9 (docstring + None + 4 nested code objects + '__name__' + 'singledispatch function' + (None,) tuple); far more than update_wrapper (1) or wraps (small); wave 274; new to extra128"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolssdcc128

  columns: [id, function, args, expected, description]
  rows:
    - [sd_co_consts_len,
       "singledispatch.__code__.co_consts.__len__",
       [],
       9,
       "functools.singledispatch.__code__.co_consts.__len__() == 9 — co_consts has 9 entries: docstring, None, 4 nested code objects (dispatch/_is_valid_dispatch_type/register/wrapper), '__name__', 'singledispatch function', (None,); tuple.__len__() returns 9; new to extra128"]
    - [sd_co_consts_len_eq_9,
       "singledispatch.__code__.co_consts.__len__().__eq__",
       [9],
       true,
       "functools.singledispatch.__code__.co_consts.__len__().__eq__(9) == True — 9 is the exact count; int.__eq__(9) returns True; new to extra128"]
    - [sd_co_consts_class,
       "singledispatch.__code__.co_consts.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.singledispatch.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple for any Python code object; str.__eq__('tuple') returns True; new to extra128"]
    - [sd_co_consts_len_gt_1,
       "singledispatch.__code__.co_consts.__len__().__gt__",
       [1],
       true,
       "functools.singledispatch.__code__.co_consts.__len__().__gt__(1) == True — singledispatch co_consts len (9) is greater than 1; more complex than update_wrapper whose co_consts has only the docstring (len=1); int.__gt__(1) returns True; new to extra128"]
    - [sd_co_consts_len_gt_cv_len,
       "singledispatch.__code__.co_consts.__len__().__gt__",
       [3],
       true,
       "functools.singledispatch.__code__.co_consts.__len__().__gt__(3) == True — co_consts len (9) exceeds co_varnames len (3); singledispatch stores more constants than it has local variable names; int.__gt__(3) returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra128
# ---------------------------------------------------------------------------

invariant functools_extra128.sd_cv1_weakref:
  description: "functools.singledispatch.__code__.co_varnames[1] == 'weakref' — internal local holding weakref to dispatch registry; 7 chars; prior extra120 covered cv[0]='func'; wave 274; new to extra128"
  kind: python_call_eq
  function: "singledispatch.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "weakref"

invariant functools_extra128.sd_cv2_wrapper:
  description: "functools.singledispatch.__code__.co_varnames[2] == 'wrapper' — the inner generic-function wrapper returned by singledispatch; 7 chars; same length as 'weakref'; wave 274; new to extra128"
  kind: python_call_eq
  function: "singledispatch.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "wrapper"

invariant functools_extra128.sd_cv_len:
  description: "functools.singledispatch.__code__.co_varnames.__len__() == 3 — 1 declared param 'func' + 2 locals 'weakref'+'wrapper'; total 3 entries; wave 274; new to extra128"
  kind: python_call_eq
  function: "singledispatch.__code__.co_varnames.__len__"
  args: []
  expected: 3

invariant functools_extra128.sd_co_consts_len:
  description: "functools.singledispatch.__code__.co_consts.__len__() == 9 — docstring + None + 4 nested code objects + 2 string constants + 1 tuple; largest co_consts among functools decorators; wave 274; new to extra128"
  kind: python_call_eq
  function: "singledispatch.__code__.co_consts.__len__"
  args: []
  expected: 9

invariant functools_extra128.sd_freevars_len:
  description: "functools.singledispatch.__code__.co_freevars.__len__() == 0 — module-level function; no enclosing scope; co_freevars is empty; wave 274; new to extra128"
  kind: python_call_eq
  function: "singledispatch.__code__.co_freevars.__len__"
  args: []
  expected: 0
