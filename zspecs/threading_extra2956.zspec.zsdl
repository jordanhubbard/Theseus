spec: th2956
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 644 (th2956): __invert__, __round__, __trunc__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define bitwise invert, round, or truncate operators."
    - "Verified types: threading.Thread, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th2956.invert:
  description: "threading types __invert__ dict-presence checks; wave 644"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2956
  columns: [id, function, args, expected]
  rows:
    - ["th2956001", operator.contains, [threading.Thread.__dict__,           "__invert__"], false]
    - ["th2956002", operator.contains, [threading.Condition.__dict__,        "__invert__"], false]
    - ["th2956003", operator.contains, [threading.Semaphore.__dict__,        "__invert__"], false]
    - ["th2956004", operator.contains, [threading.BoundedSemaphore.__dict__, "__invert__"], false]
    - ["th2956005", operator.contains, [threading.Event.__dict__,            "__invert__"], false]
    - ["th2956006", operator.contains, [threading.Barrier.__dict__,          "__invert__"], false]

