spec: pathlib_extra197
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib.PurePosixPath and pathlib.PureWindowsPath class identity."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13); confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits directly from PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15); confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath also inherits directly from PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS."
    - "Name length ordering: PurePath(8) < PurePosixPath(13) < PureWindowsPath(15); PureWindowsPath is the longest of the three pure path class names; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePosixPath and PureWindowsPath __name__ equality
# PurePosixPath(13), PureWindowsPath(15), PurePath(8)
# ---------------------------------------------------------------------------

table pathlib_extra197.purepath_class_names:
  description: "pathlib.PurePosixPath and PureWindowsPath __name__ values: PurePosixPath='PurePosixPath'(13), PureWindowsPath='PureWindowsPath'(15), PurePath.__name__='PurePath'(8)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurepath197

  columns: [id, function, args, expected, description]
  rows:
    - [posix_name_eq,   pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13); confirmed Python 3.14.3 macOS"]
    - [windows_name_eq, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15, longest); confirmed Python 3.14.3 macOS"]
    - [purepath_name_eq, pathlib.PurePath.__name__.__eq__,       ["PurePath"],        true, "pathlib.PurePath.__name__ == 'PurePath' (len=8, shortest base); confirmed Python 3.14.3 macOS"]
    - [posix_name_len,  pathlib.PurePosixPath.__name__.__len__,  [],                  13,   "pathlib.PurePosixPath.__name__.__len__() == 13 — Pure(4)+Posix(5)+Path(4)=13; confirmed Python 3.14.3 macOS"]
    - [windows_name_len, pathlib.PureWindowsPath.__name__.__len__, [],                15,   "pathlib.PureWindowsPath.__name__.__len__() == 15 — Pure(4)+Windows(7)+Path(4)=15, longest; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PurePosixPath and PureWindowsPath __module__ equality
# Both report 'pathlib' (len=7)
# ---------------------------------------------------------------------------

table pathlib_extra197.purepath_class_modules:
  description: "pathlib.PurePosixPath and PureWindowsPath __module__ values: both report 'pathlib' (len=7); PurePath also reports 'pathlib'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurepath197

  columns: [id, function, args, expected, description]
  rows:
    - [posix_module_eq,   pathlib.PurePosixPath.__module__.__eq__,   ["pathlib"], true, "pathlib.PurePosixPath.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS"]
    - [windows_module_eq, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true, "pathlib.PureWindowsPath.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS"]
    - [purepath_module_eq, pathlib.PurePath.__module__.__eq__,       ["pathlib"], true, "pathlib.PurePath.__module__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS"]
    - [posix_module_len,  pathlib.PurePosixPath.__module__.__len__,  [],          7,    "pathlib.PurePosixPath.__module__.__len__() == 7 — p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [windows_module_len, pathlib.PureWindowsPath.__module__.__len__, [],        7,    "pathlib.PureWindowsPath.__module__.__len__() == 7 — same module string as PurePosixPath; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePosixPath and PureWindowsPath class identity
# __bases__[0].__name__ (PurePath), __class__.__name__ (type)
# ---------------------------------------------------------------------------

table pathlib_extra197.purepath_class_identity:
  description: "pathlib.PurePosixPath and PureWindowsPath class-level identity: both inherit from PurePath and use plain type metaclass"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurepath197

  columns: [id, function, args, expected, description]
  rows:
    - [posix_base_eq,    "pathlib.PurePosixPath.__bases__[0].__name__.__eq__",   ["PurePath"], true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'; PurePosixPath directly subclasses PurePath; confirmed Python 3.14.3 macOS"]
    - [windows_base_eq,  "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath'; PureWindowsPath directly subclasses PurePath; confirmed Python 3.14.3 macOS"]
    - [posix_class_eq,   pathlib.PurePosixPath.__class__.__name__.__eq__,        ["type"],     true, "pathlib.PurePosixPath.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [windows_class_eq, pathlib.PureWindowsPath.__class__.__name__.__eq__,      ["type"],     true, "pathlib.PureWindowsPath.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [purepath_name_len, pathlib.PurePath.__name__.__len__,                     [],           8,    "pathlib.PurePath.__name__.__len__() == 8 — Pure(4)+Path(4)=8; shortest of the three pure path names; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra197.purepositxpath_name_eq:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath' — class name string length 13 ('Pure'=4+'Posix'=5+'Path'=4=13); PurePosixPath is the pure POSIX path flavour that can be instantiated on any OS; its __name__ is the plain class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra197.purewindowspath_name_eq:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' — class name string length 15 ('Pure'=4+'Windows'=7+'Path'=4=15); PureWindowsPath is the longest of the three pure path class names in this spec (PurePath=8, PurePosixPath=13, PureWindowsPath=15); PureWindowsPath is the pure Windows path flavour that can be instantiated on any OS; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra197.purepositxpath_module_eq:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib' — all pathlib pure path classes report their module as 'pathlib' (len=7); unlike io module classes which report '_io' for C-extension types, pathlib is a pure-Python module and all its classes correctly report 'pathlib'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra197.purewindowspath_module_eq:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib' — both PurePosixPath and PureWindowsPath report __module__=='pathlib' (len=7); they are both pure-Python classes defined in the pathlib package; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra197.purepositxpath_base_eq:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath directly inherits from PurePath (the abstract pure path base); PurePath has __name__ length 8, shorter than PurePosixPath (13); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "pathlib.PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra197.purewindowspath_base_eq:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath also directly inherits from PurePath (the abstract pure path base); both PurePosixPath and PureWindowsPath share PurePath as their single direct base class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra197.purepath_name_len_shortest:
  description: "pathlib.PurePath.__name__.__len__() == 8 — PurePath (len=8) is the shortest of the three pure path class names: PurePath=8 < PurePosixPath=13 < PureWindowsPath=15; PurePath is the abstract base, the two concrete pure path classes add 'Posix' or 'Windows' to the name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra197.purewindowspath_name_len_longest:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 — PureWindowsPath (len=15) is the longest of the three pure path class names: PurePath=8, PurePosixPath=13, PureWindowsPath=15; the extra 7 chars come from 'Windows' vs 'Posix' (5 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__name__.__len__
  args: []
  expected: 15
