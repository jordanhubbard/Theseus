spec: stringify_entities
version: ">=4.0.4"
backend: node(stringify-entities)

docs: https://www.npmjs.com/package/stringify-entities

provenance:
  derived_from:
    - "stringify-entities README — https://www.npmjs.com/package/stringify-entities"
    - "Test vectors verified with stringify-entities via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "stringify-entities source"
  notes:
    - "stringify-entities is an npm package. Install: npm install stringify-entities"
    - "Encodes characters to HTML character references."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table stringify_entities.stringifyEntities:
  kind: node_module_call_eq
  function: stringifyEntities
  category: encode
  id_prefix: strient

  columns: [id, args, expected]
  rows:
    - [amp,       ["&"],     "&#x26;"]
    - [lt_gt_amp, ["<>&"],   "&#x3C;&#x3E;&#x26;"]

table stringify_entities.stringifyEntitiesLight:
  kind: node_module_call_eq
  function: stringifyEntitiesLight
  category: encode
  id_prefix: strientl

  columns: [id, args, expected]
  rows:
    - [amp,       ["&"],     "&#x26;"]
    - [lt_gt_amp, ["<>&"],   "&#x3C;&#x3E;&#x26;"]
