spec: struct_extra46
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra45.zspec.zsdl — covers Struct/pack/error __doc__.__class__.__qualname__.__eq__('str'), module __doc__.__class__.__name__/__qualname__/__module__, and Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ via method call."
    - "struct_extra44.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str')."
    - "struct_extra18.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __module__.__eq__('_struct') and Struct.__module__.__eq__('_struct') and error.__module__.__eq__('struct')."
    - "struct_extra9.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__ and __name__.__eq__ as class method descriptors."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__.__eq__('Struct'), pack_into.__name__, all module-level function __qualname__.__eq__ and error.__qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra45; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior struct spec checks __module__.__class__.__name__.__eq__('str') for any struct callable. struct_extra18 covers the __module__ string VALUES for all struct callables ('_struct', 'struct'). struct_extra44 covers __doc__.__class__.__name__. But the TYPE of the __module__ attribute itself — accessed via __module__.__class__.__name__ — has never been checked. For every struct callable, __module__ is a Python str. This is an independent structural regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__module__.__class__.__name__ == 'str'. pack.__module__ is '_struct' (a str); its __class__.__name__ is 'str'. struct_extra18 covers __module__ string value but no prior spec checks pack.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__.__class__.__name__ == 'str'. unpack.__module__ is '_struct' (a str). No prior spec checks unpack.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__.__class__.__name__ == 'str'. calcsize.__module__ is '_struct' (a str). No prior spec checks calcsize.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__.__class__.__name__ == 'str'. Struct.__module__ is '_struct' (a str). No prior spec checks Struct.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__class__.__name__ == 'str'. error.__module__ is 'struct' (a str). No prior spec checks error.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks __module__.__class__.__qualname__.__eq__('str') for any struct callable. struct_extra45 covers __doc__.__class__.__qualname__ but not __module__.__class__.__qualname__. These are distinct attribute chains. For str, __qualname__ == __name__ == 'str', but accessing via __qualname__ provides an independent regression vector. Three representative objects confirm the pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__module__.__class__.__qualname__ == 'str'. pack.__module__ is a str; str.__qualname__ is 'str'. No prior spec checks pack.__module__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__.__class__.__qualname__ == 'str'. Struct.__module__ is '_struct' (a str); str.__qualname__ is 'str'. No prior spec checks Struct.__module__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__class__.__qualname__ == 'str'. error.__module__ is 'struct' (a str); str.__qualname__ is 'str'. No prior spec checks error.__module__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks __module__.__len__() for any struct callable. struct_extra18 covers __module__ string values ('_struct'=7 chars, 'struct'=6 chars) but no spec checks the string lengths of __module__. These lengths are an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__module__.__len__() == 7. '_struct' has 7 characters: '_','s','t','r','u','c','t'. No prior spec checks pack.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__.__len__() == 7. Struct.__module__ is '_struct' (7 chars). No prior spec checks Struct.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__len__() == 6. error.__module__ is 'struct' (6 chars: 's','t','r','u','c','t'). No prior spec checks error.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct callable __module__.__class__.__name__.__eq__('str')
#
# struct_extra18 covers the __module__ string VALUE for all struct callables
# and the Struct class ('_struct') and error ('struct'). No prior struct spec
# checks the TYPE of the __module__ attribute via __module__.__class__.__name__.
# For every struct callable, __module__ is a Python str. This axis provides
# an independent structural regression vector: if the C extension changes the
# type of __module__, this table detects it.
# ---------------------------------------------------------------------------

table struct_extra46.module_class_names:
  description: "struct pack/unpack/calcsize/Struct/error __module__.__class__.__name__.__eq__('str') — verifies each struct object's __module__ attribute is a Python str; novel __module__.__class__.__name__ axis; struct_extra18 covers __module__ string values (different axis); struct_extra44 covers __doc__.__class__.__name__ (different attribute); no prior struct spec checks __module__.__class__.__name__ for any struct object"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmod46

  columns: [id, function, args, expected]
  rows:
    - [pack_module_class_name_eq,     pack.__module__.__class__.__name__.__eq__,     ["str"], true]
    - [unpack_module_class_name_eq,   unpack.__module__.__class__.__name__.__eq__,   ["str"], true]
    - [calcsize_module_class_name_eq, calcsize.__module__.__class__.__name__.__eq__, ["str"], true]
    - [Struct_module_class_name_eq,   Struct.__module__.__class__.__name__.__eq__,   ["str"], true]
    - [error_module_class_name_eq,    error.__module__.__class__.__name__.__eq__,    ["str"], true]

# ---------------------------------------------------------------------------
# struct callable __module__.__class__.__qualname__.__eq__('str')
#
# A distinct attribute chain from __module__.__class__.__name__. For built-in
# str, __qualname__ == __name__ == 'str', but the .__qualname__ access path is
# independent of the .__name__ path. struct_extra45 covers __doc__.__class__.__qualname__
# (different attribute). Three representative objects confirm the pattern.
# ---------------------------------------------------------------------------

table struct_extra46.module_class_qualnames:
  description: "struct pack/Struct/error __module__.__class__.__qualname__.__eq__('str') — str.__qualname__ == 'str'; novel __module__.__class__.__qualname__ axis distinct from __module__.__class__.__name__; struct_extra45 covers __doc__.__class__.__qualname__ (different attribute); no prior struct spec checks __module__.__class__.__qualname__ for any struct object"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmodqual46

  columns: [id, function, args, expected]
  rows:
    - [pack_module_class_qualname_eq,   pack.__module__.__class__.__qualname__.__eq__,   ["str"], true]
    - [Struct_module_class_qualname_eq, Struct.__module__.__class__.__qualname__.__eq__, ["str"], true]
    - [error_module_class_qualname_eq,  error.__module__.__class__.__qualname__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# struct callable __module__.__len__()
#
# struct_extra18 covers __module__ string values ('_struct' and 'struct') but
# no prior spec checks the lengths of those strings. '_struct' has 7 characters;
# 'struct' has 6 characters. These lengths provide an independent regression
# vector: if any struct callable moves to a differently-named module, the
# length changes. pack and Struct both use '_struct' (7 chars); error uses
# 'struct' (6 chars).
# ---------------------------------------------------------------------------

table struct_extra46.module_lengths:
  description: "struct pack/Struct/error __module__.__len__() — '_struct'=7 chars, 'struct'=6 chars; independent length regression vector; struct_extra18 covers __module__ string values but no prior struct spec checks __module__.__len__() for any struct object"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmodlen46

  columns: [id, function, args, expected]
  rows:
    - [pack_module_len,   pack.__module__.__len__,   [], 7]
    - [Struct_module_len, Struct.__module__.__len__, [], 7]
    - [error_module_len,  error.__module__.__len__,  [], 6]
