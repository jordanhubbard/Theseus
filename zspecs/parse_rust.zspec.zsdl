spec: parse_rust
version: ">=3.9"
backend: rust_module(parse_rust)

docs: https://github.com/r1chardj0n3s/parse

provenance:
  derived_from:
    - "https://github.com/r1chardj0n3s/parse — parse library documentation"
  not_derived_from:
    - "parse source: parse.py"
  notes:
    - "parse is the opposite of format() — it parses structured strings."
    - "parse.parse('Hello, {}!', 'Hello, World!')[0] == 'World'."
    - "parse.parse('{} {}', 'foo bar')[0] == 'foo'."
    - "parse.parse('{name}', 'Alice')['name'] == 'Alice'."
    - "parse.parse('{:d}', '42')[0] == 42 — typed extraction."
    - "parse.parse('{:f}', '3.14')[0] == 3.14 — float extraction."
    - "Expose parse_first(fmt, s) -> any: parse.parse(fmt, s)[0]."
    - "Expose parse_named(fmt, s, key) -> any: parse.parse(fmt, s)[key]."
    - "Expose parse_int(fmt, s) -> int: parse.parse(fmt, s)[0] as int."
    - "parse.parse('Hello, {}!', 'Hello, World!')[0] == 'World'."
    - "All test vectors verified against parse 1.20.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# parse_first — extract first positional match
table parse_rust.positional.first:
  kind: python_call_eq
  category: positional
  id_prefix: pa_first
  function: parse_first

  columns: [id, args, expected]
  rows:
    - [greeting, ["Hello, {}!", "Hello, World!"], "World"]
    - [prefix,   ["{} {}",     "foo bar"],        "foo"]
    - [url_end,  ["/api/{}",   "/api/users"],     "users"]

# parse_int — extract integer value
table parse_rust.typed.int:
  kind: python_call_eq
  category: typed
  id_prefix: pa_int
  function: parse_int

  columns: [id, args, expected]
  rows:
    - [simple, ["{:d}", "42"],   42]
    - [zero,   ["{:d}", "0"],    0]
    - [large,  ["{:d}", "1000"], 1000]

# parse_named — extract named field
invariant parse_rust.named.name:
  description: "parse('{name}', 'Alice')['name'] == 'Alice'"
  category: named
  kind: python_call_eq
  function: parse_named
  args: ["{name}", "Alice", "name"]
  expected: "Alice"

invariant parse_rust.named.city:
  description: "parse('{city}', 'London')['city'] == 'London'"
  category: named
  kind: python_call_eq
  function: parse_named
  args: ["{city}", "London", "city"]
  expected: "London"

