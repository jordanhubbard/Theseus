spec: socket_extra2836
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra2821.zspec.zsdl — covers __radd__, __rsub__, and __rmul__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for socket.socket, AddressFamily, SocketKind."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "socket.socket.__dict__.__contains__('__rtruediv__') == False — socket.socket is a network I/O type; it does not define the reflected true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__rfloordiv__') == False — socket.socket does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__rmod__') == False — socket.socket does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__rtruediv__') == False — AddressFamily is an IntEnum subclass; it does not add a reflected true division operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__rfloordiv__') == False — AddressFamily does not add a reflected floor division operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__rmod__') == False — AddressFamily does not add a reflected modulo operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__rtruediv__') == False — SocketKind is an IntEnum subclass; it does not add a reflected true division operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__rfloordiv__') == False — SocketKind does not add a reflected floor division operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__rmod__') == False — SocketKind does not add a reflected modulo operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# socket.socket is the main socket class; it wraps a file descriptor and
# provides network I/O methods (connect, bind, send, recv, etc.). Reflected
# division/modulo operators (__rtruediv__, __rfloordiv__, __rmod__) have no
# meaning for a network socket and are not defined in socket.socket.__dict__.
# ---------------------------------------------------------------------------

table socket_extra2836.socket_dict_rtruediv_rfloordiv_rmod:
  description: "socket.socket.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — socket.socket is a network I/O type with no reflected division or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2836

  columns: [id, function, args, expected]
  rows:
    - ["sk2836-sock-rtruediv",  socket.socket.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["sk2836-sock-rfloordiv", socket.socket.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["sk2836-sock-rmod",      socket.socket.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# AddressFamily is an IntEnum subclass (AF_INET=2, AF_INET6=10, AF_UNIX=1, etc.).
# It inherits integer arithmetic from int/IntEnum but does not add reflected
# division or modulo operators to its own __dict__ (checked with
# 'in AddressFamily.__dict__', not MRO lookup).
# ---------------------------------------------------------------------------

table socket_extra2836.addressfamily_dict_rtruediv_rfloordiv_rmod:
  description: "socket.AddressFamily.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — AddressFamily (IntEnum subclass) adds no reflected division or modulo operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2836

  columns: [id, function, args, expected]
  rows:
    - ["sk2836-af-rtruediv",  socket.AddressFamily.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["sk2836-af-rfloordiv", socket.AddressFamily.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["sk2836-af-rmod",      socket.AddressFamily.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 3: socket.SocketKind.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# SocketKind is an IntEnum subclass (SOCK_STREAM=1, SOCK_DGRAM=2, etc.).
# Like AddressFamily, it does not add reflected division or modulo operators
# to its own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2836.socketkind_dict_rtruediv_rfloordiv_rmod:
  description: "socket.SocketKind.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — SocketKind (IntEnum subclass) adds no reflected division or modulo operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2836

  columns: [id, function, args, expected]
  rows:
    - ["sk2836-sk-rtruediv",  socket.SocketKind.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["sk2836-sk-rfloordiv", socket.SocketKind.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["sk2836-sk-rmod",      socket.SocketKind.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — socket, AddressFamily, SocketKind all absent
# ---------------------------------------------------------------------------

table socket_extra2836.all_types_all_dunders_absent:
  description: "socket.socket, socket.AddressFamily, and socket.SocketKind all lack __rtruediv__, __rfloordiv__, and __rmod__ in __dict__ — no socket type defines these reflected division or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2836

  columns: [id, function, args, expected]
  rows:
    - ["sk2836-x-sock-rtruediv",  socket.socket.__dict__.__contains__,        ["__rtruediv__"],  false]
    - ["sk2836-x-sock-rfloordiv", socket.socket.__dict__.__contains__,        ["__rfloordiv__"], false]
    - ["sk2836-x-sock-rmod",      socket.socket.__dict__.__contains__,        ["__rmod__"],      false]
    - ["sk2836-x-af-rtruediv",    socket.AddressFamily.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["sk2836-x-af-rfloordiv",   socket.AddressFamily.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["sk2836-x-af-rmod",        socket.AddressFamily.__dict__.__contains__, ["__rmod__"],      false]
    - ["sk2836-x-sk-rtruediv",    socket.SocketKind.__dict__.__contains__,   ["__rtruediv__"],  false]
    - ["sk2836-x-sk-rfloordiv",   socket.SocketKind.__dict__.__contains__,   ["__rfloordiv__"], false]
    - ["sk2836-x-sk-rmod",        socket.SocketKind.__dict__.__contains__,   ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra2836.socket_no_rtruediv:
  description: "socket.socket.__dict__.__contains__('__rtruediv__') == False — socket.socket is a network I/O object; it defines no reflected true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__rtruediv__"]
  expected: false

invariant socket_extra2836.socket_no_rfloordiv:
  description: "socket.socket.__dict__.__contains__('__rfloordiv__') == False — socket.socket defines no reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__rfloordiv__"]
  expected: false

