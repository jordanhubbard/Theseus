  description: "socket.socket.__dict__.__contains__('__rmod__') == False — socket.socket defines no reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__rmod__"]
  expected: false

