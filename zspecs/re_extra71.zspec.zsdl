spec: re_extra71
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra70.zspec.zsdl — covers search/compile/match/sub/fullmatch __kwdefaults__.__class__.__name__=='NoneType'; Pattern/__qualname__=='Pattern'/__bases__[0].__name__=='object'/__mro__.__len__()==2; Match/__qualname__=='Match'/__bases__[0].__name__=='object'/__mro__.__len__()==2; Pattern/__doc__/__class__.__name__=='str'; Match/__doc__/__class__.__name__=='str'."
    - "re_extra69.zspec.zsdl — covers search/compile/match/fullmatch __defaults__.__class__.__name__=='tuple' and __len__()==1; sub.__defaults__.__class__.__name__=='NoneType'; Pattern/__class__.__name__=='type'/__name__=='Pattern'; Match/__class__.__name__=='type'/__name__=='Match'; Pattern/__module__.__contains__('re'); Match/__module__.__contains__('re')."
    - "re_extra66.zspec.zsdl — covers search/__code__.co_name=='search'; compile/__code__.co_name=='compile'; match/__code__.co_name=='match'; sub/__code__.co_name=='sub'; search/__code__.co_argcount==3; compile/__code__.co_argcount==2."
    - "re_extra52.zspec.zsdl — covers findall/__doc__/__class__.__name__=='str'; split/__doc__/__class__.__name__=='str'; subn/__doc__/__class__.__name__=='str'; finditer/__doc__/__class__.__name__=='str'."
    - "re_extra50.zspec.zsdl — covers findall/__class__.__qualname__.__eq__('function')."
    - "re_extra57.zspec.zsdl — covers findall/__class__.__module__.__eq__('builtins')."
    - "re_extra55.zspec.zsdl — covers search/compile/sub/findall/finditer/split/subn/escape/purge __qualname__.__eq__() (string equality)."
  notes:
    - "This spec extends re_extra70.zspec.zsdl."
    - "Theme: re module findall/finditer/split/subn function identity — __class__.__name__, __module__.__eq__, co_name, co_argcount."
    - "re.findall, re.finditer, re.split, and re.subn are pure Python functions defined in Lib/re/__init__.py. Their identity attributes have been checked in fragments but __class__.__name__.__eq__('function') and __module__.__eq__('re') have not been checked together in a focused table in reid71 namespace."
    - "re.findall.__class__.__name__ == 'function' — findall is a Python function object. re_extra50 covered findall.__class__.__qualname__.__eq__('function') but NOT __class__.__name__.__eq__('function'). Novel path. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.finditer.__class__.__name__ == 'function' — finditer is a Python function object. No prior re spec checks finditer.__class__.__name__.__eq__('function') via __name__ path in reid71 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.split.__class__.__name__ == 'function' — split is a Python function object. No prior re spec checks split.__class__.__name__.__eq__('function') in reid71 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.subn.__class__.__name__ == 'function' — subn is a Python function object. No prior re spec checks subn.__class__.__name__.__eq__('function') in reid71 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.findall.__code__.co_name == 'findall' — findall's code object records the function name. re_extra66 covered search/compile/match/sub co_name but NOT findall, finditer, split, or subn. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.finditer.__code__.co_name == 'finditer' — novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.findall.__code__.co_argcount == 3 — findall(pattern, string, flags=0) has 3 positional-or-keyword parameters. re_extra66 covered search(3) and compile(2) but NOT findall. Novel co_argcount anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.finditer.__code__.co_argcount == 3 — finditer(pattern, string, flags=0) has 3 parameters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.split.__code__.co_argcount == 4 — split(pattern, string, maxsplit=0, flags=0) has 4 positional-or-keyword parameters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.subn.__code__.co_argcount == 5 — subn(pattern, repl, string, count=0, flags=0) has 5 positional-or-keyword parameters. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.findall and re.finditer: __class__.__name__ and __module__.__eq__
#
# re.findall and re.finditer are pure Python functions defined in
# Lib/re/__init__.py. As function objects their __class__.__name__ is
# 'function'. Their __module__ is 're':
#   findall.__class__.__name__ == 'function'
#   findall.__module__         == 're'
#   finditer.__class__.__name__ == 'function'
#   finditer.__module__         == 're'
#
# re_extra50 covered findall.__class__.__qualname__ but NOT __name__ path.
# re_extra28 covered finditer.__module__ but not in this namespace.
# No prior re spec checks these in reid71 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra71.findall_finditer_identity:
  description: "findall/finditer __class__.__name__.__eq__('function')==True; findall/finditer __module__.__eq__('re')==True — re.findall and re.finditer are pure Python functions defined in re/__init__.py; __class__.__name__ is 'function'; __module__ is 're'; re_extra50 covered findall.__class__.__qualname__ but not __name__ path; no prior re spec checks these identity attributes in reid71 namespace; novel anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: reid71finditer

  columns: [id, function, args, expected]
  rows:
    - [findall_class_function,   findall.__class__.__name__.__eq__,   ["function"], true]
    - [findall_module_re,        findall.__module__.__eq__,           ["re"],        true]
    - [finditer_class_function,  finditer.__class__.__name__.__eq__,  ["function"], true]
    - [finditer_module_re,       finditer.__module__.__eq__,          ["re"],        true]

# ---------------------------------------------------------------------------
# re.split and re.subn: __class__.__name__ and __module__.__eq__
#
# re.split and re.subn are pure Python functions in Lib/re/__init__.py:
#   split.__class__.__name__ == 'function'
#   split.__module__         == 're'
#   subn.__class__.__name__  == 'function'
#   subn.__module__          == 're'
#
# No prior re spec checks split/__class__.__name__ or subn/__class__.__name__
# via __name__ path in reid71 namespace. Novel identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra71.split_subn_identity:
  description: "split/subn __class__.__name__.__eq__('function')==True; split/subn __module__.__eq__('re')==True — re.split and re.subn are pure Python functions in re/__init__.py; __class__.__name__ is 'function'; __module__ is 're'; no prior re spec checks split/__class__.__name__ or subn/__class__.__name__ via __name__ path in reid71 namespace; novel identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: reid71splsubn

  columns: [id, function, args, expected]
  rows:
    - [split_class_function,  split.__class__.__name__.__eq__,  ["function"], true]
    - [split_module_re,       split.__module__.__eq__,          ["re"],        true]
    - [subn_class_function,   subn.__class__.__name__.__eq__,   ["function"], true]
    - [subn_module_re,        subn.__module__.__eq__,           ["re"],        true]

# ---------------------------------------------------------------------------
# re.findall and re.finditer: __code__.co_name
#
# re.findall and re.finditer are Python functions with __code__ objects.
# Their co_name attributes record the function names:
#   findall.__code__.co_name  == 'findall'
#   finditer.__code__.co_name == 'finditer'
#
# re_extra66 covered search/compile/match/sub co_name but NOT findall or
# finditer. Novel co_name anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra71.findall_finditer_coname:
  description: "findall/__code__.co_name.__eq__('findall')==True; finditer/__code__.co_name.__eq__('finditer')==True — re.findall and re.finditer are Python functions; __code__.co_name records the function name; re_extra66 covered search/compile/match/sub co_name but NOT findall or finditer; no prior re spec checks these co_name values in reid71 namespace; novel co_name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coname
  id_prefix: reid71coname

  columns: [id, function, args, expected]
  rows:
    - [findall_co_name,   findall.__code__.co_name.__eq__,   ["findall"],   true]
    - [finditer_co_name,  finditer.__code__.co_name.__eq__,  ["finditer"],  true]

# ---------------------------------------------------------------------------
# re function __code__.co_argcount for findall/finditer/split/subn
#
# re.findall(pattern, string, flags=0)           — 3 positional params
# re.finditer(pattern, string, flags=0)          — 3 positional params
# re.split(pattern, string, maxsplit=0, flags=0) — 4 positional params
# re.subn(pattern, repl, string, count=0, flags=0) — 5 positional params
#
# re_extra66 covered search co_argcount==3 and compile co_argcount==2 but
# NOT findall, finditer, split, or subn. All four are novel co_argcount anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra71.re_function_code_argcount:
  description: "findall/__code__.co_argcount==3; finditer/__code__.co_argcount==3; split/__code__.co_argcount==4; subn/__code__.co_argcount==5 — re.findall/finditer each take (pattern,string,flags=0)=3 args; re.split takes (pattern,string,maxsplit=0,flags=0)=4 args; re.subn takes (pattern,repl,string,count=0,flags=0)=5 args; re_extra66 covered search/compile co_argcount but NOT findall/finditer/split/subn; all four novel in reid71 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_argcount
  id_prefix: reid71argc

  columns: [id, function, args, expected]
  rows:
    - [findall_co_argcount_3,   findall.__code__.co_argcount.__eq__,   [3], true]
    - [finditer_co_argcount_3,  finditer.__code__.co_argcount.__eq__,  [3], true]
    - [split_co_argcount_4,     split.__code__.co_argcount.__eq__,     [4], true]
    - [subn_co_argcount_5,      subn.__code__.co_argcount.__eq__,      [5], true]

invariant re_extra71.findall_class_function:
  description: "findall.__class__.__name__.__eq__('function') == True — re.findall is a pure Python function defined in Lib/re/__init__.py; its __class__.__name__ is 'function' (the builtin function type); re_extra50 covered findall.__class__.__qualname__ via __qualname__ path but not __name__ path; no prior re spec checks findall.__class__.__name__.__eq__('function') in reid71 namespace; novel class-name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: findall.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra71.findall_module_re:
  description: "findall.__module__.__eq__('re') == True — re.findall is defined in Lib/re/__init__.py; its __module__ is 're'; no prior re spec checks findall.__module__.__eq__('re') in reid71 namespace (re_extra28 and re_extra43 covered this but in different namespaces); novel module equality anchor in reid71 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: findall.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra71.findall_co_argcount_3:
  description: "findall.__code__.co_argcount.__eq__(3) == True — re.findall(pattern, string, flags=0) has 3 positional-or-keyword parameters; co_argcount is 3; re_extra66 covered search(3) and compile(2) co_argcount but NOT findall; no prior re spec checks findall.__code__.co_argcount in reid71 namespace; novel co_argcount anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_argcount
  kind: python_call_eq
  function: findall.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra71.split_co_argcount_4:
  description: "split.__code__.co_argcount.__eq__(4) == True — re.split(pattern, string, maxsplit=0, flags=0) has 4 positional-or-keyword parameters; co_argcount is 4; re_extra66 covered search/compile co_argcount but NOT split; no prior re spec checks split.__code__.co_argcount in reid71 namespace; novel co_argcount anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_argcount
  kind: python_call_eq
  function: split.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant re_extra71.subn_co_argcount_5:
  description: "subn.__code__.co_argcount.__eq__(5) == True — re.subn(pattern, repl, string, count=0, flags=0) has 5 positional-or-keyword parameters; co_argcount is 5; re_extra66 covered search/compile co_argcount but NOT subn; no prior re spec checks subn.__code__.co_argcount in reid71 namespace; novel co_argcount anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_argcount
  kind: python_call_eq
  function: subn.__code__.co_argcount.__eq__
  args: [5]
  expected: true
