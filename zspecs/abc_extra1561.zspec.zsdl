# ---------------------------------------------------------------------------
# abc.ABCMeta — positive dict-presence checks (actual methods)
# ---------------------------------------------------------------------------

table abc_extra1561.abcmeta_method_presence:
  description: "abc.ABCMeta.__dict__ contains its defining methods and metaclass machinery"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab1561mp

  columns: [id, function, args, expected]
  rows:
    - [ab1561mp001, abc.ABCMeta.__dict__.__contains__, ["register"],            true]
    - [ab1561mp002, abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"],   true]
    - [ab1561mp003, abc.ABCMeta.__dict__.__contains__, ["__new__"],             true]
    - [ab1561mp004, abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"],   true]
    - [ab1561mp005, abc.ABCMeta.__dict__.__contains__, ["__module__"],          true]
    - [ab1561mp006, abc.ABCMeta.__dict__.__contains__, ["__doc__"],             true]

# ---------------------------------------------------------------------------
# abc.ABC — positive dict-presence checks (actual slots/attrs)
# ---------------------------------------------------------------------------

table abc_extra1561.abc_attr_presence:
  description: "abc.ABC.__dict__ contains its defining slots and implementation attributes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab1561ap

  columns: [id, function, args, expected]
  rows:
    - [ab1561ap001, abc.ABC.__dict__.__contains__, ["__slots__"],             true]
    - [ab1561ap002, abc.ABC.__dict__.__contains__, ["__abstractmethods__"],   true]
    - [ab1561ap003, abc.ABC.__dict__.__contains__, ["_abc_impl"],             true]
    - [ab1561ap004, abc.ABC.__dict__.__contains__, ["__module__"],            true]
    - [ab1561ap005, abc.ABC.__dict__.__contains__, ["__doc__"],               true]
    - [ab1561ap006, abc.ABC.__dict__.__contains__, ["__static_attributes__"], true]

# ---------------------------------------------------------------------------
# Cross-class spot-check: ABCMeta vs ABC — neither has numeric protocol
# ---------------------------------------------------------------------------

table abc_extra1561.abc_classes_no_numeric_spot:
  description: "Spot-check: neither abc.ABCMeta nor abc.ABC defines __int__, __float__, or __complex__ in their __dict__"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: ab1561sp

  columns: [id, function, args, expected]
  rows:
    - [ab1561sp001, abc.ABCMeta.__dict__.__contains__, ["__int__"],     false]
    - [ab1561sp002, abc.ABC.__dict__.__contains__,     ["__int__"],     false]
    - [ab1561sp003, abc.ABCMeta.__dict__.__contains__, ["__float__"],   false]
    - [ab1561sp004, abc.ABC.__dict__.__contains__,     ["__float__"],   false]
    - [ab1561sp005, abc.ABCMeta.__dict__.__contains__, ["__complex__"], false]
    - [ab1561sp006, abc.ABC.__dict__.__contains__,     ["__complex__"], false]
    - [ab1561sp007, abc.ABCMeta.__dict__.__contains__, ["__index__"],   false]
    - [ab1561sp008, abc.ABC.__dict__.__contains__,     ["__index__"],   false]
    - [ab1561sp009, abc.ABCMeta.__dict__.__contains__, ["__trunc__"],   false]
