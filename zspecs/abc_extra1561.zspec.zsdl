spec: abc_extra1561
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for abc classes."
    - "abc.ABCMeta and abc.ABC are abstract base class machinery, not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "abc.ABCMeta.__module__ == 'abc'; abc.ABC.__module__ == 'abc' on CPython 3.14."
    - "ABCMeta.__dict__ contains: __new__, register, __instancecheck__, __subclasscheck__."
    - "ABC.__dict__ contains: __slots__, __abstractmethods__, _abc_impl."
    - "abc.abstractmethod is a plain function (not a class), so abc.abstractmethod.__dict__ is an empty function attribute dict."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table abc_extra1561.abcmeta_numeric_protocol:
  description: "abc.ABCMeta.__dict__ does not contain any numeric type conversion protocol dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: ab1561am

  columns: [id, function, args, expected]
  rows:
    - [ab1561am001, abc.ABCMeta.__dict__.__contains__, ["__bool__"],    false]
    - [ab1561am002, abc.ABCMeta.__dict__.__contains__, ["__int__"],     false]
    - [ab1561am003, abc.ABCMeta.__dict__.__contains__, ["__float__"],   false]
    - [ab1561am004, abc.ABCMeta.__dict__.__contains__, ["__complex__"], false]
    - [ab1561am005, abc.ABCMeta.__dict__.__contains__, ["__index__"],   false]
    - [ab1561am006, abc.ABCMeta.__dict__.__contains__, ["__trunc__"],   false]
    - [ab1561am007, abc.ABCMeta.__dict__.__contains__, ["__floor__"],   false]
    - [ab1561am008, abc.ABCMeta.__dict__.__contains__, ["__ceil__"],    false]
    - [ab1561am009, abc.ABCMeta.__dict__.__contains__, ["__round__"],   false]

