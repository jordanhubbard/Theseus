    - [ab1561ab002, abc.ABC.__dict__.__contains__, ["__int__"],     false]
    - [ab1561ab003, abc.ABC.__dict__.__contains__, ["__float__"],   false]
    - [ab1561ab004, abc.ABC.__dict__.__contains__, ["__complex__"], false]
    - [ab1561ab005, abc.ABC.__dict__.__contains__, ["__index__"],   false]
    - [ab1561ab006, abc.ABC.__dict__.__contains__, ["__trunc__"],   false]
    - [ab1561ab007, abc.ABC.__dict__.__contains__, ["__floor__"],   false]
