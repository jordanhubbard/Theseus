invariant socket_extra77.gaierror_dict_has_weakref:
  description: "socket.gaierror.__dict__.__contains__('__weakref__') == True — gaierror's class __dict__ contains '__weakref__' (weakref slot); no prior socket spec checks gaierror.__dict__.__contains__('__weakref__'); first __weakref__ dict membership standalone for gaierror"
  category: class_dict
  kind: python_call_eq
  function: gaierror.__dict__.__contains__
