invariant socket_extra77.herror_dict_has_module:
  description: "socket.herror.__dict__.__contains__('__module__') == True — herror's class __dict__ contains '__module__'; no prior socket spec checks herror.__dict__.__contains__ for any key; first __module__ dict membership standalone for herror"
  category: class_dict
  kind: python_call_eq
  function: herror.__dict__.__contains__
  args: ["__module__"]
  expected: true

# ---------------------------------------------------------------------------
