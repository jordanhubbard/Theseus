spec: socket_extra77
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra76.zspec.zsdl — covers socket.socket/__dict__.__contains__('__enter__'/'__exit__'/'__repr__'/'family'/'type') / AddressFamily/SocketKind/__class__/__name__=='EnumType' / AddressFamily/SocketKind/__module__=='socket' (table + invariants)."
    - "socket_extra75.zspec.zsdl — covers socket.socket.__dict__.__contains__ close/detach/dup/sendfile/get_inheritable/set_inheritable / gethostname/gethostbyname/getnameinfo/setdefaulttimeout/__qualname__ (table + invariants)."
    - "socket_extra53.zspec.zsdl — covers socket.socket/herror/gaierror/timeout/__dict__/__class__/__qualname__.__eq__('mappingproxy') (table + invariants)."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind/__mro__.__len__()==6 (table + invariants)."
    - "socket_extra15.zspec.zsdl — covers AddressFamily/__mro__[1]/__name__=='IntEnum' / SocketKind/__mro__[1]/__name__=='IntEnum' (invariants)."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3 / gaierror/__mro__.__len__()==5 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra76; it does NOT duplicate invariants present in those files."
    - "Wave 244 theme: gaierror/herror __dict__ key membership + AddressFamily/SocketKind MRO element names at indices 0 and 5."
    - "socket.gaierror.__dict__.__contains__('__module__') == True — gaierror's class __dict__ contains exactly three keys: __module__, __weakref__, __doc__. No prior socket spec checks gaierror.__dict__.__contains__ for any of these keys. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__dict__.__contains__('__weakref__') == True — __weakref__ is a slot entry added to any non-slotted Python class. No prior socket spec checks gaierror.__dict__.__contains__('__weakref__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__dict__.__contains__('__module__') == True — herror's class __dict__ also contains exactly __module__/__weakref__/__doc__. No prior socket spec checks herror.__dict__.__contains__ for any key. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__mro__[0].__name__ == 'AddressFamily' — the first element of the MRO is the class itself. socket_extra15 covers __mro__[1].__name__=='IntEnum' but NOT __mro__[0] or __mro__[5]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__mro__[5].__name__ == 'object' — the last element of the 6-element MRO is object. No prior socket spec checks AddressFamily.__mro__[5].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__mro__[0].__name__ == 'SocketKind' — the first element of the SocketKind MRO is SocketKind itself. No prior socket spec checks SocketKind.__mro__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__mro__[5].__name__ == 'object' — the last element of the 6-element SocketKind MRO is object. No prior socket spec checks SocketKind.__mro__[5].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gaierror.__dict__.__contains__ for __module__, __weakref__, __doc__
#
# Wave 244 theme: gaierror class __dict__ key membership.
#
# socket.gaierror is a simple exception subclass whose class __dict__ contains
# exactly three keys: '__module__', '__weakref__', and '__doc__'. No prior
# socket spec checks gaierror.__dict__.__contains__ for any specific key.
# socket_extra31 and socket_extra53 cover gaierror.__dict__.__class__.__name__
# (i.e., that __dict__ is a mappingproxy) but not what keys it contains.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra77.gaierror_dict_contains:
  description: "socket.gaierror/__dict__.__contains__('__module__')==True / __contains__('__weakref__')==True / __contains__('__doc__')==True — gaierror's class __dict__ contains exactly __module__/__weakref__/__doc__; socket_extra31/extra53 cover __dict__.__class__.__name__=='mappingproxy' but NOT key membership; no prior socket spec checks gaierror.__dict__.__contains__ for any key; first __dict__ key membership anchor for gaierror"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmore77

  columns: [id, function, args, expected]
  rows:
    - [gaierror_dict_has_module,   gaierror.__dict__.__contains__, ["__module__"],   true]
    - [gaierror_dict_has_weakref,  gaierror.__dict__.__contains__, ["__weakref__"],  true]
    - [gaierror_dict_has_doc,      gaierror.__dict__.__contains__, ["__doc__"],      true]

# ---------------------------------------------------------------------------
# socket.herror.__dict__.__contains__ for __module__ and __weakref__
#
# Wave 244 theme: herror class __dict__ key membership.
#
# socket.herror's class __dict__ also contains '__module__', '__weakref__', and
# '__doc__'. No prior socket spec checks herror.__dict__.__contains__ for any key.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra77.herror_dict_contains:
  description: "socket.herror/__dict__.__contains__('__module__')==True / __contains__('__weakref__')==True — herror's class __dict__ contains __module__ and __weakref__ (and __doc__); no prior socket spec checks herror.__dict__.__contains__ for any key; first __dict__ key membership anchor for herror"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmore77

  columns: [id, function, args, expected]
  rows:
    - [herror_dict_has_module,  herror.__dict__.__contains__, ["__module__"],  true]
    - [herror_dict_has_weakref, herror.__dict__.__contains__, ["__weakref__"], true]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__mro__[0] and __mro__[5] __name__
#
# Wave 244 theme: AddressFamily MRO element names at indices 0 and 5.
#
# socket.AddressFamily.__mro__ has 6 entries:
#   (AddressFamily, IntEnum, int, ReprEnum, Enum, object)
# socket_extra15 covers __mro__[1].__name__ == 'IntEnum'. socket_extra35 covers
# __mro__.__len__() == 6. No prior socket spec checks __mro__[0].__name__ or
# __mro__[5].__name__ for AddressFamily. The [0] and [5] subscripts require
# double-quoting in table row function values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra77.AddressFamily_mro_endpoints:
  description: "socket.AddressFamily/__mro__[0]/__name__.__eq__('AddressFamily')==True / __mro__[5]/__name__.__eq__('object')==True — AddressFamily MRO is (AddressFamily, IntEnum, int, ReprEnum, Enum, object); extra15 covers __mro__[1].__name__=='IntEnum'; extra35 covers __mro__.__len__()==6; no prior socket spec checks AddressFamily.__mro__[0] or __mro__[5]; [N] subscript requires double-quoting; first MRO endpoint name anchor for AddressFamily"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketmore77

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily_mro0_name_AddressFamily, "AddressFamily.__mro__[0].__name__.__eq__", ["AddressFamily"], true]
    - [AddressFamily_mro5_name_object,        "AddressFamily.__mro__[5].__name__.__eq__", ["object"],        true]

# ---------------------------------------------------------------------------
# socket.SocketKind.__mro__[0] and __mro__[5] __name__
#
# Wave 244 theme: SocketKind MRO element names at indices 0 and 5.
#
# socket.SocketKind.__mro__ has 6 entries:
#   (SocketKind, IntEnum, int, ReprEnum, Enum, object)
# socket_extra15 covers __mro__[1].__name__ == 'IntEnum' for SocketKind.
# socket_extra35 covers SocketKind.__mro__.__len__() == 6. No prior socket spec
# checks SocketKind.__mro__[0].__name__ or SocketKind.__mro__[5].__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra77.SocketKind_mro_endpoints:
  description: "socket.SocketKind/__mro__[0]/__name__.__eq__('SocketKind')==True / __mro__[5]/__name__.__eq__('object')==True — SocketKind MRO is (SocketKind, IntEnum, int, ReprEnum, Enum, object); extra15 covers __mro__[1].__name__=='IntEnum'; extra35 covers __mro__.__len__()==6; no prior socket spec checks SocketKind.__mro__[0] or __mro__[5]; [N] subscript requires double-quoting; first MRO endpoint name anchor for SocketKind"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketmore77

  columns: [id, function, args, expected]
  rows:
    - [SocketKind_mro0_name_SocketKind, "SocketKind.__mro__[0].__name__.__eq__", ["SocketKind"], true]
    - [SocketKind_mro5_name_object,     "SocketKind.__mro__[5].__name__.__eq__", ["object"],     true]

# ---------------------------------------------------------------------------
# socket.gaierror.__dict__.__contains__('__module__') — standalone
#
# gaierror.__dict__ contains '__module__'. No prior socket spec checks
# gaierror.__dict__.__contains__ for any key. First __module__ dict membership
# standalone for gaierror. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra77.gaierror_dict_has_module:
  description: "socket.gaierror.__dict__.__contains__('__module__') == True — gaierror's class __dict__ contains '__module__'; socket_extra31/extra53 cover __dict__ type but NOT key membership; no prior socket spec checks gaierror.__dict__.__contains__ for any key; first __module__ dict membership standalone for gaierror"
  category: class_dict
  kind: python_call_eq
  function: gaierror.__dict__.__contains__
  args: ["__module__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__dict__.__contains__('__module__') — standalone
#
# herror.__dict__ contains '__module__'. No prior socket spec checks
