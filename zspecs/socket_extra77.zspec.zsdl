# covers __mro__[1].__name__=='IntEnum'; socket_extra35 covers __mro__.__len__()==6.
# No prior socket spec checks AddressFamily.__mro__[5].__name__. First MRO[5]
# name standalone for AddressFamily. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra77.AddressFamily_mro5_name_object:
  description: "socket.AddressFamily.__mro__[5].__name__.__eq__('object') == True — last element of AddressFamily 6-element MRO is object; extra15 covers mro[1]=='IntEnum'; extra35 covers mro len; no prior socket spec checks AddressFamily.__mro__[5].__name__; first MRO[5] name standalone for AddressFamily"
  category: class_attrs
  kind: python_call_eq
  function: "AddressFamily.__mro__[5].__name__.__eq__"
  args: ["object"]
  expected: true

