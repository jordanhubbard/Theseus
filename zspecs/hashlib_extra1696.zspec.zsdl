spec: hashlib_extra1696
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "hashlib hash objects (_hashlib.HASH) are not picklable — they hold internal C state (OpenSSL EVP context or similar) that cannot be serialized."
    - "_hashlib.HASH defines none of __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, or __deepcopy__ in its own __dict__."
    - "_hashlib.HASHXOF (the XOF variant for SHAKE algorithms) likewise defines none of the pickling or copy dunders."
    - "_hashlib.HASH does define the standard hash API methods: copy, digest, hexdigest, update, and the properties digest_size, block_size, name."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods absent from _hashlib.HASH.__dict__
#
# __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__
# are the five dunder hooks the pickle protocol consults.  _hashlib.HASH
# defines none of them — hash objects are not picklable.
# ---------------------------------------------------------------------------

table hashlib_extra1696.pickling_protocol:
  description: "_hashlib.HASH and _hashlib.HASHXOF pickling protocol dict-presence checks — neither type defines pickle dunders in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1696

  columns: [id, function, args, expected]
  rows:
    - ["hl1696001", "_hashlib.HASH.__dict__.__contains__",    ["__reduce__"],        false]
    - ["hl1696002", "_hashlib.HASH.__dict__.__contains__",    ["__getstate__"],      false]
    - ["hl1696003", "_hashlib.HASH.__dict__.__contains__",    ["__setstate__"],      false]
    - ["hl1696004", "_hashlib.HASH.__dict__.__contains__",    ["__getnewargs__"],    false]
    - ["hl1696005", "_hashlib.HASH.__dict__.__contains__",    ["__getnewargs_ex__"], false]
    - ["hl1696006", "_hashlib.HASHXOF.__dict__.__contains__", ["__reduce__"],        false]
    - ["hl1696007", "_hashlib.HASHXOF.__dict__.__contains__", ["__getstate__"],      false]
    - ["hl1696008", "_hashlib.HASHXOF.__dict__.__contains__", ["__setstate__"],      false]
    - ["hl1696009", "_hashlib.HASHXOF.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["hl1696010", "_hashlib.HASHXOF.__dict__.__contains__", ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol methods absent from _hashlib.HASH.__dict__
#
# __copy__ and __deepcopy__ are the hooks for copy.copy() and copy.deepcopy().
# _hashlib.HASH does not define __copy__ or __deepcopy__ in its own __dict__,
# even though it exposes a copy() method for incremental-hash use.
# ---------------------------------------------------------------------------

table hashlib_extra1696.copy_protocol:
  description: "_hashlib.HASH and _hashlib.HASHXOF copy protocol dict-presence checks — neither type defines __copy__ or __deepcopy__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1696

  columns: [id, function, args, expected]
  rows:
    - ["hl1696011", "_hashlib.HASH.__dict__.__contains__",    ["__copy__"],     false]
    - ["hl1696012", "_hashlib.HASH.__dict__.__contains__",    ["__deepcopy__"], false]
    - ["hl1696013", "_hashlib.HASHXOF.__dict__.__contains__", ["__copy__"],     false]
    - ["hl1696014", "_hashlib.HASHXOF.__dict__.__contains__", ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: Standard hash API methods present in _hashlib.HASH.__dict__
#
# Although hash objects cannot be pickled or copied via the copy module,
# _hashlib.HASH does define the standard hash API in its own __dict__:
# copy, digest, hexdigest, update, and the properties digest_size, block_size,
# name.  _hashlib.HASHXOF overrides digest and hexdigest (length-variable XOF
# variants) and digest_size, but not copy, update, block_size, or name.
# ---------------------------------------------------------------------------

table hashlib_extra1696.hash_api_dict_presence:
  description: "_hashlib.HASH and _hashlib.HASHXOF standard API method dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1696

  columns: [id, function, args, expected]
  rows:
    - ["hl1696015", "_hashlib.HASH.__dict__.__contains__",    ["copy"],        true]
    - ["hl1696016", "_hashlib.HASH.__dict__.__contains__",    ["digest"],      true]
    - ["hl1696017", "_hashlib.HASH.__dict__.__contains__",    ["hexdigest"],   true]
    - ["hl1696018", "_hashlib.HASH.__dict__.__contains__",    ["update"],      true]
    - ["hl1696019", "_hashlib.HASH.__dict__.__contains__",    ["digest_size"], true]
    - ["hl1696020", "_hashlib.HASH.__dict__.__contains__",    ["block_size"],  true]
    - ["hl1696021", "_hashlib.HASH.__dict__.__contains__",    ["name"],        true]
    - ["hl1696022", "_hashlib.HASHXOF.__dict__.__contains__", ["digest"],      true]
    - ["hl1696023", "_hashlib.HASHXOF.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl1696024", "_hashlib.HASHXOF.__dict__.__contains__", ["digest_size"], true]
    - ["hl1696025", "_hashlib.HASHXOF.__dict__.__contains__", ["copy"],        false]
    - ["hl1696026", "_hashlib.HASHXOF.__dict__.__contains__", ["update"],      false]
    - ["hl1696027", "_hashlib.HASHXOF.__dict__.__contains__", ["block_size"],  false]
