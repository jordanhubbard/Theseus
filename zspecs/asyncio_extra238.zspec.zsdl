spec: asyncio_extra238
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers asyncio.Queue class identity and method contracts."
    - "asyncio.Queue.__name__ == 'Queue' — the class carries its unqualified name."
    - "asyncio.Queue.__module__ == 'asyncio.queues' — Queue is defined in the asyncio.queues submodule."
    - "asyncio.Queue.__qualname__ == 'Queue' — top-level class so qualname equals __name__."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' — verified with Python 3.14.3; the direct base is the internal mixin not object."
    - "asyncio.Queue.__doc__ contains 'Queue', 'maxsize', and 'coroutine' — the docstring describes queue semantics."
    - "asyncio.Queue.__doc__.__len__() == 490 — docstring has exactly 490 characters; verified Python 3.14.3."
    - "put_nowait.__name__ == 'put_nowait' (len=10); put_nowait.__qualname__ == 'Queue.put_nowait' (len=16)."
    - "get_nowait.__name__ == 'get_nowait' (len=10); get_nowait.__qualname__ == 'Queue.get_nowait' (len=16)."
    - "qsize.__name__ == 'qsize' (len=5); qsize.__qualname__ == 'Queue.qsize' (len=11)."
    - "empty.__name__ == 'empty' (len=5); empty.__qualname__ == 'Queue.empty' (len=11)."
    - "full.__name__ == 'full' (len=4); full.__qualname__ == 'Queue.full' (len=10)."
    - "put.__name__ == 'put' (len=3); put.__qualname__ == 'Queue.put' (len=9)."
    - "get.__name__ == 'get' (len=3); get.__qualname__ == 'Queue.get' (len=9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue class identity contracts
#
# Queue.__name__, __module__, __qualname__, and __bases__[0].__name__
# confirm the class is defined in asyncio.queues and inherits from
# _LoopBoundMixin (the internal event-loop binding mixin in Python 3.14).
# ---------------------------------------------------------------------------

table asyncio_extra238.queue_class_identity:
  description: "asyncio.Queue class identity: name, module, qualname, and base class name; new to extra238"
  kind: python_call_eq
  category: class_identity
  id_prefix: aioqueue238

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name_eq,
       Queue.__name__.__eq__,
       ["Queue"],
       true,
       "asyncio.Queue.__name__.__eq__('Queue') == True — the class carries the unqualified name 'Queue'; new to extra238"]
    - [queue_module_eq,
       Queue.__module__.__eq__,
       ["asyncio.queues"],
       true,
       "asyncio.Queue.__module__.__eq__('asyncio.queues') == True — Queue is defined in the asyncio.queues submodule; new to extra238"]
    - [queue_qualname_eq,
       Queue.__qualname__.__eq__,
       ["Queue"],
       true,
       "asyncio.Queue.__qualname__.__eq__('Queue') == True — top-level class; qualname equals __name__; new to extra238"]
    - [queue_name_len_5,
       Queue.__name__.__len__,
       [],
       5,
       "asyncio.Queue.__name__.__len__() == 5 — 'Queue' has exactly 5 characters (Q-u-e-u-e); new to extra238"]
    - [queue_module_len_14,
       Queue.__module__.__len__,
       [],
       14,
       "asyncio.Queue.__module__.__len__() == 14 — 'asyncio.queues' has exactly 14 characters; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Queue __doc__ contracts
#
# Queue.__doc__ is a non-None str describing queue semantics.
# It contains 'Queue', 'maxsize', and 'coroutine'.
# Its length is 490 characters (verified Python 3.14.3).
# ---------------------------------------------------------------------------

table asyncio_extra238.queue_doc_contracts:
  description: "asyncio.Queue.__doc__ contracts: type is str, contains key words, len is 490; new to extra238"
  kind: python_call_eq
  category: doc
  id_prefix: aioqueue238doc

  columns: [id, function, args, expected, description]
  rows:
    - [queue_doc_class_is_str,
       Queue.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "asyncio.Queue.__doc__.__class__.__name__.__eq__('str') == True — Queue docstring is a plain Python str; new to extra238"]
    - [queue_doc_contains_Queue,
       Queue.__doc__.__contains__,
       ["Queue"],
       true,
       "asyncio.Queue.__doc__.__contains__('Queue') == True — docstring references 'Queue' by name; new to extra238"]
    - [queue_doc_contains_maxsize,
       Queue.__doc__.__contains__,
       ["maxsize"],
       true,
       "asyncio.Queue.__doc__.__contains__('maxsize') == True — docstring explains the maxsize parameter; new to extra238"]
    - [queue_doc_contains_coroutine,
       Queue.__doc__.__contains__,
       ["coroutine"],
       true,
       "asyncio.Queue.__doc__.__contains__('coroutine') == True — docstring mentions coroutines in the context of producer/consumer patterns; new to extra238"]
    - [queue_doc_len_490,
       Queue.__doc__.__len__,
       [],
       490,
       "asyncio.Queue.__doc__.__len__() == 490 — Queue docstring has exactly 490 characters; verified Python 3.14.3; new to extra238"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Queue method __name__ contracts
#
# Verifies the __name__ attribute for six Queue instance methods:
# put_nowait, get_nowait, qsize, empty, full, put, get.
# ---------------------------------------------------------------------------

table asyncio_extra238.queue_method_names:
  description: "asyncio.Queue method __name__ contracts; new to extra238"
  kind: python_call_eq
  category: method_names
  id_prefix: aioqueue238m

  columns: [id, function, args, expected, description]
  rows:
    - [put_nowait_name_eq,
       Queue.put_nowait.__name__.__eq__,
       ["put_nowait"],
       true,
       "asyncio.Queue.put_nowait.__name__.__eq__('put_nowait') == True — method name is 'put_nowait' (len=10); new to extra238"]
    - [get_nowait_name_eq,
       Queue.get_nowait.__name__.__eq__,
       ["get_nowait"],
       true,
       "asyncio.Queue.get_nowait.__name__.__eq__('get_nowait') == True — method name is 'get_nowait' (len=10); new to extra238"]
    - [qsize_name_eq,
       Queue.qsize.__name__.__eq__,
       ["qsize"],
       true,
       "asyncio.Queue.qsize.__name__.__eq__('qsize') == True — method name is 'qsize' (len=5); new to extra238"]
    - [empty_name_eq,
       Queue.empty.__name__.__eq__,
       ["empty"],
       true,
       "asyncio.Queue.empty.__name__.__eq__('empty') == True — method name is 'empty' (len=5); new to extra238"]
    - [full_name_eq,
       Queue.full.__name__.__eq__,
       ["full"],
       true,
       "asyncio.Queue.full.__name__.__eq__('full') == True — method name is 'full' (len=4); new to extra238"]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Queue method __qualname__ contracts
#
# For methods defined directly on Queue (not inherited), the __qualname__
# is 'Queue.<method>'. Verifies put_nowait, get_nowait, qsize, empty, full.
# ---------------------------------------------------------------------------

table asyncio_extra238.queue_method_qualnames:
  description: "asyncio.Queue method __qualname__ contracts; new to extra238"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aioqueue238mq

  columns: [id, function, args, expected, description]
  rows:
    - [put_nowait_qualname_eq,
       Queue.put_nowait.__qualname__.__eq__,
       ["Queue.put_nowait"],
       true,
       "asyncio.Queue.put_nowait.__qualname__.__eq__('Queue.put_nowait') == True — qualname is 'Queue.put_nowait' (len=16); new to extra238"]
    - [get_nowait_qualname_eq,
       Queue.get_nowait.__qualname__.__eq__,
       ["Queue.get_nowait"],
       true,
       "asyncio.Queue.get_nowait.__qualname__.__eq__('Queue.get_nowait') == True — qualname is 'Queue.get_nowait' (len=16); new to extra238"]
    - [qsize_qualname_eq,
       Queue.qsize.__qualname__.__eq__,
       ["Queue.qsize"],
       true,
       "asyncio.Queue.qsize.__qualname__.__eq__('Queue.qsize') == True — qualname is 'Queue.qsize' (len=11); new to extra238"]
    - [empty_qualname_eq,
       Queue.empty.__qualname__.__eq__,
       ["Queue.empty"],
       true,
       "asyncio.Queue.empty.__qualname__.__eq__('Queue.empty') == True — qualname is 'Queue.empty' (len=11); new to extra238"]
    - [full_qualname_eq,
       Queue.full.__qualname__.__eq__,
       ["Queue.full"],
       true,
       "asyncio.Queue.full.__qualname__.__eq__('Queue.full') == True — qualname is 'Queue.full' (len=10); new to extra238"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra238
# ---------------------------------------------------------------------------

invariant asyncio_extra238.Queue.name:
  description: "asyncio.Queue.__name__ == 'Queue'; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra238.Queue.module:
  description: "asyncio.Queue.__module__ == 'asyncio.queues'; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra238.Queue.qualname:
  description: "asyncio.Queue.__qualname__ == 'Queue' — top-level class; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Queue.__qualname__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra238.Queue.base_name:
  description: "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' — direct base in Python 3.14; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra238.Queue.put_nowait_name:
  description: "asyncio.Queue.put_nowait.__name__ == 'put_nowait'; new to extra238"
  category: method_names
  kind: python_call_eq
  function: Queue.put_nowait.__name__.__eq__
  args: ["put_nowait"]
  expected: true

invariant asyncio_extra238.Queue.put_nowait_qualname:
  description: "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait'; new to extra238"
  category: method_qualnames
  kind: python_call_eq
  function: Queue.put_nowait.__qualname__.__eq__
  args: ["Queue.put_nowait"]
  expected: true

invariant asyncio_extra238.Queue.get_nowait_name:
  description: "asyncio.Queue.get_nowait.__name__ == 'get_nowait'; new to extra238"
  category: method_names
  kind: python_call_eq
  function: Queue.get_nowait.__name__.__eq__
  args: ["get_nowait"]
  expected: true

invariant asyncio_extra238.Queue.get_nowait_qualname:
  description: "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait'; new to extra238"
  category: method_qualnames
  kind: python_call_eq
  function: Queue.get_nowait.__qualname__.__eq__
  args: ["Queue.get_nowait"]
  expected: true

invariant asyncio_extra238.Queue.qsize_name:
  description: "asyncio.Queue.qsize.__name__ == 'qsize'; new to extra238"
  category: method_names
  kind: python_call_eq
  function: Queue.qsize.__name__.__eq__
  args: ["qsize"]
  expected: true

invariant asyncio_extra238.Queue.qsize_qualname:
  description: "asyncio.Queue.qsize.__qualname__ == 'Queue.qsize'; new to extra238"
  category: method_qualnames
  kind: python_call_eq
  function: Queue.qsize.__qualname__.__eq__
  args: ["Queue.qsize"]
  expected: true
