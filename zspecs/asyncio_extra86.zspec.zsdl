spec: asyncio_extra86
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio Event Loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio_extra85.zspec.zsdl."
    - "This spec covers: wave 246 theme — asyncio Handle/TimerHandle class identity. NEW in extra86: Handle.__name__=='Handle'; Handle.__module__=='asyncio.events'; Handle.__bases__[0].__name__=='object'; Handle.__mro__.__len__()==2; Handle.__qualname__=='Handle'; TimerHandle.__name__=='TimerHandle'; TimerHandle.__module__=='asyncio.events'; TimerHandle.__bases__[0].__name__=='Handle'; TimerHandle.__mro__.__len__()==3; TimerHandle.__qualname__=='TimerHandle'; Handle.__dict__.__class__.__name__=='mappingproxy'; TimerHandle.__dict__.__class__.__name__=='mappingproxy'; Handle.__dict__.__contains__('cancel')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__name__ == 'Handle'. Handle is a top-level class in asyncio.events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__module__ == 'asyncio.events'. Handle is defined in the asyncio.events submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__bases__[0].__name__ == 'object'. Handle directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__mro__.__len__() == 2. MRO is [Handle, object], length 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__qualname__ == 'Handle'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__name__ == 'TimerHandle'. TimerHandle is a top-level class in asyncio.events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__module__ == 'asyncio.events'. TimerHandle is defined in the asyncio.events submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle'. TimerHandle directly subclasses Handle. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__mro__.__len__() == 3. MRO is [TimerHandle, Handle, object], length 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__qualname__ == 'TimerHandle'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__dict__.__contains__('cancel') == True. Handle defines a cancel method directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Handle class identity — extra86
#
# Wave 246 theme: asyncio Handle/TimerHandle class identity.
#
# Handle.__name__ == 'Handle'
# Handle.__module__ == 'asyncio.events'
# Handle.__bases__[0].__name__ == 'object'
# Handle.__mro__.__len__() == 2
# Handle.__qualname__ == 'Handle'
# ---------------------------------------------------------------------------

table asyncio_extra86.Handle_identity:
  description: "asyncio Handle class identity checks in asyncioextra86 namespace — wave 246 theme: asyncio Handle/TimerHandle class identity; Handle.__name__=='Handle'; Handle.__module__=='asyncio.events'; Handle.__bases__[0].__name__=='object' (Handle directly subclasses object); Handle.__mro__.__len__()==2 (MRO: [Handle, object]); Handle.__qualname__=='Handle'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra86

  columns: [id, function, args, expected, description]
  rows:
    - [handle_name,       Handle.__name__.__eq__,                ["Handle"],          true, "Handle.__name__ == 'Handle' — top-level class name in asyncio.events; verified with Python 3.14.3"]
    - [handle_module,     Handle.__module__.__eq__,              ["asyncio.events"],  true, "Handle.__module__ == 'asyncio.events' — defined in asyncio.events submodule; verified with Python 3.14.3"]
    - [handle_base_name,  "Handle.__bases__[0].__name__.__eq__", ["object"],          true, "Handle.__bases__[0].__name__ == 'object' — Handle directly subclasses object; verified with Python 3.14.3"]
    - [handle_mro_len,    "Handle.__mro__.__len__",              [],                  2,    "Handle.__mro__.__len__() == 2 — MRO is [Handle, object]; verified with Python 3.14.3"]
    - [handle_qualname,   Handle.__qualname__.__eq__,            ["Handle"],          true, "Handle.__qualname__ == 'Handle' — simple unqualified class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio TimerHandle class identity — extra86
#
# TimerHandle.__name__ == 'TimerHandle'
# TimerHandle.__module__ == 'asyncio.events'
# TimerHandle.__bases__[0].__name__ == 'Handle'
# TimerHandle.__mro__.__len__() == 3
# TimerHandle.__qualname__ == 'TimerHandle'
# ---------------------------------------------------------------------------

table asyncio_extra86.TimerHandle_identity:
  description: "asyncio TimerHandle class identity checks in asyncioextra86 namespace — wave 246 theme: asyncio Handle/TimerHandle class identity; TimerHandle.__name__=='TimerHandle'; TimerHandle.__module__=='asyncio.events'; TimerHandle.__bases__[0].__name__=='Handle' (TimerHandle directly subclasses Handle); TimerHandle.__mro__.__len__()==3 (MRO: [TimerHandle, Handle, object]); TimerHandle.__qualname__=='TimerHandle'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra86a

  columns: [id, function, args, expected, description]
  rows:
    - [th_name,       TimerHandle.__name__.__eq__,                ["TimerHandle"],     true, "TimerHandle.__name__ == 'TimerHandle' — top-level class name in asyncio.events; verified with Python 3.14.3"]
    - [th_module,     TimerHandle.__module__.__eq__,              ["asyncio.events"],  true, "TimerHandle.__module__ == 'asyncio.events' — defined in asyncio.events submodule; verified with Python 3.14.3"]
    - [th_base_name,  "TimerHandle.__bases__[0].__name__.__eq__", ["Handle"],          true, "TimerHandle.__bases__[0].__name__ == 'Handle' — TimerHandle directly subclasses Handle; verified with Python 3.14.3"]
    - [th_mro_len,    "TimerHandle.__mro__.__len__",              [],                  3,    "TimerHandle.__mro__.__len__() == 3 — MRO is [TimerHandle, Handle, object]; verified with Python 3.14.3"]
    - [th_qualname,   TimerHandle.__qualname__.__eq__,            ["TimerHandle"],     true, "TimerHandle.__qualname__ == 'TimerHandle' — simple unqualified class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Handle/TimerHandle __dict__ class identity — extra86
#
# Handle.__dict__.__class__.__name__ == 'mappingproxy'
# TimerHandle.__dict__.__class__.__name__ == 'mappingproxy'
# Handle.__dict__.__contains__('cancel') == True
# ---------------------------------------------------------------------------

table asyncio_extra86.Handle_dict_identity:
  description: "asyncio Handle and TimerHandle __dict__ class identity checks in asyncioextra86 namespace — wave 246 theme: asyncio Handle/TimerHandle class identity; Handle.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always a mappingproxy in CPython); TimerHandle.__dict__.__class__.__name__=='mappingproxy'; Handle.__dict__.__contains__('cancel')==True (Handle defines cancel method directly); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra86b

  columns: [id, function, args, expected, description]
  rows:
    - [handle_dict_cls_name,  "Handle.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true, "Handle.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [th_dict_cls_name,      "TimerHandle.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "TimerHandle.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [handle_has_cancel,     "Handle.__dict__.__contains__",                   ["cancel"],       true, "Handle.__dict__.__contains__('cancel') == True — Handle defines a cancel method directly; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Handle/TimerHandle cross-check table — extra86
# ---------------------------------------------------------------------------

table asyncio_extra86.handle_cross_checks:
  description: "asyncio Handle and TimerHandle class identity cross-check table in asyncioextra86 namespace — wave 246 theme: asyncio Handle/TimerHandle class identity cross-checks; Handle.__name__=='Handle' (cross-check); TimerHandle.__bases__[0].__name__=='Handle' (cross-check: confirms Handle→TimerHandle inheritance); Handle.__mro__.__len__()==2 (cross-check); TimerHandle.__mro__.__len__()==3 (cross-check); Handle.__module__=='asyncio.events' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra86c

  columns: [id, function, args, expected, description]
  rows:
    - [handle_name_cross,    Handle.__name__.__eq__,                ["Handle"],         true, "Handle.__name__ == 'Handle' — cross-check; verified with Python 3.14.3"]
    - [th_base_cross,        "TimerHandle.__bases__[0].__name__.__eq__", ["Handle"],    true, "TimerHandle.__bases__[0].__name__ == 'Handle' — cross-check: confirms Handle→TimerHandle inheritance; verified with Python 3.14.3"]
    - [handle_mro_cross,     "Handle.__mro__.__len__",              [],                 2,    "Handle.__mro__.__len__() == 2 — cross-check; verified with Python 3.14.3"]
    - [th_mro_cross,         "TimerHandle.__mro__.__len__",         [],                 3,    "TimerHandle.__mro__.__len__() == 3 — cross-check; verified with Python 3.14.3"]
    - [handle_module_cross,  Handle.__module__.__eq__,              ["asyncio.events"], true, "Handle.__module__ == 'asyncio.events' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant asyncio_extra86.Handle_name:
  description: "asyncio.Handle.__name__.__eq__('Handle') returns True — Handle is a top-level class defined in asyncio.events; NEW in extra86: first standalone __name__ invariant for Handle in asyncioextra86 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Handle.__name__.__eq__
  args: ["Handle"]
  expected: true

invariant asyncio_extra86.Handle_module:
  description: "asyncio.Handle.__module__.__eq__('asyncio.events') returns True — Handle is defined in the asyncio.events submodule; NEW in extra86: first standalone __module__ invariant for Handle in asyncioextra86 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Handle.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra86.Handle_mro_len:
  description: "asyncio.Handle.__mro__.__len__() == 2 — MRO is [Handle, object], so length is 2; Handle directly subclasses object with no intermediate bases; NEW in extra86: first standalone __mro__.__len__ invariant for Handle in asyncioextra86 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Handle.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra86.TimerHandle_base_name:
  description: "asyncio.TimerHandle.__bases__[0].__name__.__eq__('Handle') returns True — TimerHandle directly subclasses Handle, forming the timed callback variant; NEW in extra86: first standalone __bases__[0].__name__ invariant for TimerHandle in asyncioextra86 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimerHandle.__bases__[0].__name__.__eq__
  args: ["Handle"]
  expected: true

invariant asyncio_extra86.TimerHandle_mro_len:
  description: "asyncio.TimerHandle.__mro__.__len__() == 3 — MRO is [TimerHandle, Handle, object], so length is 3; TimerHandle subclasses Handle which subclasses object; NEW in extra86: first standalone __mro__.__len__ invariant for TimerHandle in asyncioextra86 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimerHandle.__mro__.__len__
  args: []
  expected: 3
