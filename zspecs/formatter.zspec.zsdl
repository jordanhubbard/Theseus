spec: formatter
version: ">=3.3,<3.13"
backend: python_module(formatter)

docs: https://docs.python.org/3/library/formatter.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/formatter.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "formatter source: Lib/formatter.py (PSF; source inspection permitted)"
  not_derived_from:
    - "formatter internal rendering and spacing heuristics"
  notes:
    - "Deprecated since Python 3.4 in documentation; removed in Python 3.13."
    - "The formatter module provides classes for formatting text output via a writer abstraction."
    - "NullFormatter and AbstractFormatter are the main formatter classes."
    - "NullWriter and DumbWriter are writer implementations; AbstractWriter is the base interface."
    - "DumbWriter.__bases__[0] is NullWriter — DumbWriter extends NullWriter."
    - "AbstractFormatter methods include: add_line_break, add_hor_rule, add_flowing_data, add_literal_data, add_label_data, flush_softspace, push_font, pop_font, push_margin, pop_margin, set_spacing, push_style, pop_style, assert_line_data."
    - "All expected values verified by running Python 3.12 formatter module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "formatter classes raise no module-specific exceptions. Writer errors propagate from the underlying I/O."
  stderr: "null"
  stickiness: "N/A — formatter and writer instances are independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant formatter.NullFormatter_name:
  description: "NullFormatter.__name__ == 'NullFormatter'"
  category: classnames
  kind: python_call_eq
  function: NullFormatter.__name__.__eq__
  args: ["NullFormatter"]
  expected: true

invariant formatter.NullFormatter_module:
  description: "NullFormatter.__module__ == 'formatter'"
  category: classnames
  kind: python_call_eq
  function: NullFormatter.__module__.__eq__
  args: ["formatter"]
  expected: true

invariant formatter.AbstractFormatter_name:
  description: "AbstractFormatter.__name__ == 'AbstractFormatter'"
  category: classnames
  kind: python_call_eq
  function: AbstractFormatter.__name__.__eq__
  args: ["AbstractFormatter"]
  expected: true

invariant formatter.AbstractFormatter_module:
  description: "AbstractFormatter.__module__ == 'formatter'"
  category: classnames
  kind: python_call_eq
  function: AbstractFormatter.__module__.__eq__
  args: ["formatter"]
  expected: true

invariant formatter.NullWriter_name:
  description: "NullWriter.__name__ == 'NullWriter'"
  category: classnames
  kind: python_call_eq
  function: NullWriter.__name__.__eq__
  args: ["NullWriter"]
  expected: true

invariant formatter.DumbWriter_name:
  description: "DumbWriter.__name__ == 'DumbWriter'"
  category: classnames
  kind: python_call_eq
  function: DumbWriter.__name__.__eq__
  args: ["DumbWriter"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy checks
# ---------------------------------------------------------------------------

invariant formatter.AbstractFormatter_base:
  description: "AbstractFormatter.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: AbstractFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant formatter.NullWriter_base:
  description: "NullWriter.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: NullWriter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant formatter.DumbWriter_base:
  description: "DumbWriter.__bases__[0].__name__ == 'NullWriter' — DumbWriter extends NullWriter"
  category: hierarchy
  kind: python_call_eq
  function: DumbWriter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "NullWriter"

# ---------------------------------------------------------------------------
# AbstractFormatter method presence checks
# ---------------------------------------------------------------------------

invariant formatter.AbstractFormatter_add_flowing_data_name:
  description: "AbstractFormatter.add_flowing_data.__name__ == 'add_flowing_data'"
  category: methods
  kind: python_call_eq
  function: AbstractFormatter.add_flowing_data.__name__.__eq__
  args: ["add_flowing_data"]
  expected: true

invariant formatter.AbstractFormatter_push_font_name:
  description: "AbstractFormatter.push_font.__name__ == 'push_font'"
  category: methods
  kind: python_call_eq
  function: AbstractFormatter.push_font.__name__.__eq__
  args: ["push_font"]
  expected: true

invariant formatter.AbstractFormatter_pop_font_name:
  description: "AbstractFormatter.pop_font.__name__ == 'pop_font'"
  category: methods
  kind: python_call_eq
  function: AbstractFormatter.pop_font.__name__.__eq__
  args: ["pop_font"]
  expected: true

invariant formatter.AbstractFormatter_add_line_break_name:
  description: "AbstractFormatter.add_line_break.__name__ == 'add_line_break'"
  category: methods
  kind: python_call_eq
  function: AbstractFormatter.add_line_break.__name__.__eq__
  args: ["add_line_break"]
  expected: true

invariant formatter.AbstractFormatter_flush_softspace_name:
  description: "AbstractFormatter.flush_softspace.__name__ == 'flush_softspace'"
  category: methods
  kind: python_call_eq
  function: AbstractFormatter.flush_softspace.__name__.__eq__
  args: ["flush_softspace"]
  expected: true
