spec: safe_stable_stringify
version: ">=2.0.0"
backend: node(safe-stable-stringify)

docs: https://github.com/nicolo-ribaudo/safe-stable-stringify#readme

provenance:
  derived_from:
    - "safe-stable-stringify README — https://github.com/nicolo-ribaudo/safe-stable-stringify#readme"
    - "Test vectors verified with safe-stable-stringify@2.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "safe-stable-stringify source: index.js"
  notes:
    - "safe-stable-stringify exports the function as the module default (CJS)."
    - "require('safe-stable-stringify') returns the stringify function directly; fn_name is null."
    - "Produces deterministic JSON by sorting object keys alphabetically."
    - "Returns undefined for non-serializable values (functions, symbols) — not specced here."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns JSON string. No errors for serializable inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table safe_stable_stringify.stringify:
  kind: node_module_call_eq
  function: ~
  category: stringify
  id_prefix: sss

  columns: [id, args, expected]
  rows:
    - [sorted_keys,  [{"b": 2, "a": 1}],   "{\"a\":1,\"b\":2}"]
    - [array,        [[1, 2, 3]],           "[1,2,3]"]
    - [number,       [42],                  "42"]
    - [string,       ["hello"],             "\"hello\""]
    - [nested,       [{"z": {"b": 2, "a": 1}}], "{\"z\":{\"a\":1,\"b\":2}}"]
