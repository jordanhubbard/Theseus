spec: threading_extra184
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Thread method name lengths — threading.Thread.start.__name__=='start' (len=5); threading.Thread.run.__name__=='run' (len=3); threading.Thread.join.__name__=='join' (len=4); threading.Thread.is_alive.__name__=='is_alive' (len=8); threading.Thread.getName.__name__=='getName' (len=7); threading.Thread.setName.__name__=='setName' (len=7); threading.Thread.isDaemon.__name__=='isDaemon' (len=8); threading.Thread.setDaemon.__name__=='setDaemon' (len=9)."
    - "threading.Thread.start.__name__ == 'start' — start is the method that initiates the thread's activity; it must be called at most once per Thread object and arranges for run() to be invoked in a separate thread of control; its __name__ is 'start', 5 characters. Verified with Python 3.14.3."
    - "threading.Thread.run.__name__ == 'run' — run is the method that represents the thread's activity; it may be overridden in a subclass and is called by start() in a separate thread; its __name__ is 'run', 3 characters. Verified with Python 3.14.3."
    - "threading.Thread.join.__name__ == 'join' — join blocks the calling thread until the thread whose join() is called terminates; its __name__ is 'join', 4 characters. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__name__ == 'is_alive' — is_alive returns True if the thread is alive (after start() and before or at termination); its __name__ is 'is_alive', 8 characters. Verified with Python 3.14.3."
    - "threading.Thread.getName.__name__ == 'getName' — getName is a deprecated alias for the name property getter; its __name__ is 'getName', 7 characters. Verified with Python 3.14.3."
    - "threading.Thread.setName.__name__ == 'setName' — setName is a deprecated alias for the name property setter; its __name__ is 'setName', 7 characters. Verified with Python 3.14.3."
    - "threading.Thread.isDaemon.__name__ == 'isDaemon' — isDaemon is a deprecated alias for the daemon property getter; its __name__ is 'isDaemon', 8 characters. Verified with Python 3.14.3."
    - "threading.Thread.setDaemon.__name__ == 'setDaemon' — setDaemon is a deprecated alias for the daemon property setter; its __name__ is 'setDaemon', 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.start, .run, .join method name lengths
#
# threading.Thread.start.__name__ == 'start'   (len=5)
# threading.Thread.run.__name__ == 'run'       (len=3)
# threading.Thread.join.__name__ == 'join'     (len=4)
#
# start initiates thread activity; run is overridable thread body;
# join blocks the caller until the thread terminates. These are the
# core lifecycle methods of threading.Thread. New to extra184.
# ---------------------------------------------------------------------------

table threading_extra184.thread_lifecycle_methods:
  description: "threading.Thread.start.__name__ 'start' len 5; .run.__name__ 'run' len 3; .join.__name__ 'join' len 4; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread184

  columns: [id, function, args, expected, description]
  rows:
    - [start_name_eq,
       Thread.start.__name__.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — start is the Thread method that initiates the thread's activity; it may be called at most once and arranges for run() to be invoked in a separate thread of control; its __name__ is 'start'; str.__eq__('start') returns True; new to extra184"]
    - [start_name_len_5,
       Thread.start.__name__.__len__,
       [],
       5,
       "threading.Thread.start.__name__.__len__() == 5 — the name 'start' has exactly 5 characters: s-t-a-r-t; str.__len__() returns 5; new to extra184"]
    - [run_name_eq,
       Thread.run.__name__.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — run is the method representing the thread's activity; it is called by start() in a new thread and may be overridden in a subclass; its __name__ is 'run'; str.__eq__('run') returns True; new to extra184"]
    - [run_name_len_3,
       Thread.run.__name__.__len__,
       [],
       3,
       "threading.Thread.run.__name__.__len__() == 3 — the name 'run' has exactly 3 characters: r-u-n; str.__len__() returns 3; new to extra184"]
    - [join_name_eq,
       Thread.join.__name__.__eq__,
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — join blocks the calling thread until the thread whose join() is called terminates or until the optional timeout occurs; its __name__ is 'join'; str.__eq__('join') returns True; new to extra184"]
    - [join_name_len_4,
       Thread.join.__name__.__len__,
       [],
       4,
       "threading.Thread.join.__name__.__len__() == 4 — the name 'join' has exactly 4 characters: j-o-i-n; str.__len__() returns 4; new to extra184"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.is_alive, .getName, .setName method names
#
# threading.Thread.is_alive.__name__ == 'is_alive'  (len=8)
# threading.Thread.getName.__name__ == 'getName'    (len=7)
# threading.Thread.setName.__name__ == 'setName'    (len=7)
#
# is_alive returns True while the thread is running.
# getName and setName are deprecated aliases for the .name property
# accessor and mutator. New to extra184.
# ---------------------------------------------------------------------------

table threading_extra184.thread_status_and_name_methods:
  description: "threading.Thread.is_alive.__name__ 'is_alive' len 8; .getName.__name__ 'getName' len 7; .setName.__name__ 'setName' len 7; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread184

  columns: [id, function, args, expected, description]
  rows:
    - [is_alive_name_eq,
       Thread.is_alive.__name__.__eq__,
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — is_alive returns True if the thread is alive (after start() is called and until just after the run() method terminates); its __name__ is 'is_alive'; str.__eq__('is_alive') returns True; new to extra184"]
    - [is_alive_name_len_8,
       Thread.is_alive.__name__.__len__,
       [],
       8,
       "threading.Thread.is_alive.__name__.__len__() == 8 — the name 'is_alive' has exactly 8 characters: i-s-_-a-l-i-v-e; str.__len__() returns 8; new to extra184"]
    - [getName_name_eq,
       Thread.getName.__name__.__eq__,
       ["getName"],
       true,
       "threading.Thread.getName.__name__.__eq__('getName') == True — getName is a deprecated method in Lib/threading.py that returns the thread's name (equivalent to accessing .name property); its __name__ is 'getName'; str.__eq__('getName') returns True; new to extra184"]
    - [getName_name_len_7,
       Thread.getName.__name__.__len__,
       [],
       7,
       "threading.Thread.getName.__name__.__len__() == 7 — the name 'getName' has exactly 7 characters: g-e-t-N-a-m-e; str.__len__() returns 7; same length as 'setName'; new to extra184"]
    - [setName_name_eq,
       Thread.setName.__name__.__eq__,
       ["setName"],
       true,
       "threading.Thread.setName.__name__.__eq__('setName') == True — setName is a deprecated method in Lib/threading.py that sets the thread's name (equivalent to assigning .name property); its __name__ is 'setName'; str.__eq__('setName') returns True; new to extra184"]
    - [setName_name_len_7,
       Thread.setName.__name__.__len__,
       [],
       7,
       "threading.Thread.setName.__name__.__len__() == 7 — the name 'setName' has exactly 7 characters: s-e-t-N-a-m-e; str.__len__() returns 7; same length as 'getName'; new to extra184"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.isDaemon and .setDaemon method names
#
# threading.Thread.isDaemon.__name__ == 'isDaemon'   (len=8)
# threading.Thread.setDaemon.__name__ == 'setDaemon' (len=9)
#
# isDaemon is a deprecated alias for the daemon property getter.
# setDaemon is a deprecated alias for the daemon property setter.
# A daemon thread is abruptly stopped at program exit without cleanup.
# New to extra184.
# ---------------------------------------------------------------------------

table threading_extra184.thread_daemon_methods:
  description: "threading.Thread.isDaemon.__name__ 'isDaemon' len 8; .setDaemon.__name__ 'setDaemon' len 9; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread184

  columns: [id, function, args, expected, description]
  rows:
    - [isDaemon_name_eq,
       Thread.isDaemon.__name__.__eq__,
       ["isDaemon"],
       true,
       "threading.Thread.isDaemon.__name__.__eq__('isDaemon') == True — isDaemon is a deprecated method in Lib/threading.py that returns the thread's daemon flag (equivalent to accessing .daemon property); daemon threads are abruptly stopped at program exit; its __name__ is 'isDaemon'; str.__eq__('isDaemon') returns True; new to extra184"]
    - [isDaemon_name_len_8,
       Thread.isDaemon.__name__.__len__,
       [],
       8,
       "threading.Thread.isDaemon.__name__.__len__() == 8 — the name 'isDaemon' has exactly 8 characters: i-s-D-a-e-m-o-n; str.__len__() returns 8; same length as 'is_alive'; new to extra184"]
    - [setDaemon_name_eq,
       Thread.setDaemon.__name__.__eq__,
       ["setDaemon"],
       true,
       "threading.Thread.setDaemon.__name__.__eq__('setDaemon') == True — setDaemon is a deprecated method in Lib/threading.py that sets the thread's daemon flag (equivalent to assigning .daemon property); it must be called before start(); its __name__ is 'setDaemon'; str.__eq__('setDaemon') returns True; new to extra184"]
    - [setDaemon_name_len_9,
       Thread.setDaemon.__name__.__len__,
       [],
       9,
       "threading.Thread.setDaemon.__name__.__len__() == 9 — the name 'setDaemon' has exactly 9 characters: s-e-t-D-a-e-m-o-n; str.__len__() returns 9; one character longer than 'isDaemon' (8); new to extra184"]

