  expected: true

invariant threading_extra184.thread_setName_name_is_setName:
  description: "threading.Thread.setName.__name__ == 'setName' — deprecated Thread method setting thread name; equivalent to assigning .name property; __name__ is 'setName' (7 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: Thread.setName.__name__.__eq__
  args: ["setName"]
  expected: true

invariant threading_extra184.thread_isDaemon_name_is_isDaemon:
  description: "threading.Thread.isDaemon.__name__ == 'isDaemon' — deprecated Thread method returning daemon flag; equivalent to accessing .daemon property; __name__ is 'isDaemon' (8 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: Thread.isDaemon.__name__.__eq__
  args: ["isDaemon"]
  expected: true

invariant threading_extra184.thread_setDaemon_name_is_setDaemon:
  description: "threading.Thread.setDaemon.__name__ == 'setDaemon' — deprecated Thread method setting daemon flag; must be called before start(); __name__ is 'setDaemon' (9 chars); new to extra184"
  category: identity
