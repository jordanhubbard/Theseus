  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra184.thread_run_name_is_run:
  description: "threading.Thread.run.__name__ == 'run' — overridable Thread method representing the thread's activity; called by start() in a new thread; __name__ is 'run' (3 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: Thread.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant threading_extra184.thread_join_name_is_join:
  description: "threading.Thread.join.__name__ == 'join' — Thread method blocking the caller until the thread terminates; __name__ is 'join' (4 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: Thread.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant threading_extra184.thread_is_alive_name_is_is_alive:
  description: "threading.Thread.is_alive.__name__ == 'is_alive' — Thread method returning True while thread is running; __name__ is 'is_alive' (8 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true

invariant threading_extra184.thread_getName_name_is_getName:
  description: "threading.Thread.getName.__name__ == 'getName' — deprecated Thread method returning thread name; equivalent to accessing .name property; __name__ is 'getName' (7 chars); new to extra184"
  category: identity
  kind: python_call_eq
  function: Thread.getName.__name__.__eq__
