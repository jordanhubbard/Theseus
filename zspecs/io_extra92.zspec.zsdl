spec: io_extra92
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra91."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__/__class__.__name__ and membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; FileIO.__dict__.__contains__ for read/readall/readinto/write/seek/tell/close/mode/closefd (all True) and name (False); FileIO.__qualname__, FileIO.__name__; BytesIO.__dict__.__contains__('read') == True; BytesIO.__dict__.__contains__('write') == True."
    - "This spec covers: io.BytesIO.__dict__.__contains__ for 'seek', 'tell', 'getvalue', 'getbuffer', 'readinto' (all True); io.StringIO.__dict__.__contains__ for 'read', 'write', 'getvalue', 'seek', 'tell' (all True); io.BytesIO.__qualname__.__eq__('BytesIO') == True; io.StringIO.__qualname__.__eq__('StringIO') == True."
    - "io.BytesIO.__dict__.__contains__('seek') == True — BytesIO defines seek."
    - "io.BytesIO.__dict__.__contains__('tell') == True — BytesIO defines tell."
    - "io.BytesIO.__dict__.__contains__('getvalue') == True — BytesIO defines getvalue."
    - "io.BytesIO.__dict__.__contains__('getbuffer') == True — BytesIO defines getbuffer."
    - "io.BytesIO.__dict__.__contains__('readinto') == True — BytesIO defines readinto."
    - "io.StringIO.__dict__.__contains__('read') == True — StringIO defines read."
    - "io.StringIO.__dict__.__contains__('write') == True — StringIO defines write."
    - "io.StringIO.__dict__.__contains__('getvalue') == True — StringIO defines getvalue."
    - "io.StringIO.__dict__.__contains__('seek') == True — StringIO defines seek."
    - "io.StringIO.__dict__.__contains__('tell') == True — StringIO defines tell."
    - "io.BytesIO.__qualname__.__eq__('BytesIO') == True — top-level class, qualname equals name."
    - "io.StringIO.__qualname__.__eq__('StringIO') == True — top-level class, qualname equals name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__.__contains__ for seek, tell, getvalue
# BytesIO implements these methods at the C level; they appear in its __dict__.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra92.BytesIO_dict_seek_tell_getvalue:
  description: "io.BytesIO.__dict__.__contains__ for 'seek', 'tell', 'getvalue' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra92

  columns: [id, function, args, expected]
  rows:
    - [bio_seek,     BytesIO.__dict__.__contains__, ["seek"],     true]
    - [bio_tell,     BytesIO.__dict__.__contains__, ["tell"],     true]
    - [bio_getvalue, BytesIO.__dict__.__contains__, ["getvalue"], true]

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__.__contains__ for getbuffer and readinto
# BytesIO defines getbuffer (returns a memoryview) and readinto at the C level.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra92.BytesIO_dict_getbuffer_readinto:
  description: "io.BytesIO.__dict__.__contains__ for 'getbuffer', 'readinto' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra92

  columns: [id, function, args, expected]
  rows:
    - [bio_getbuffer, BytesIO.__dict__.__contains__, ["getbuffer"], true]
    - [bio_readinto,  BytesIO.__dict__.__contains__, ["readinto"],  true]

# ---------------------------------------------------------------------------
# io.StringIO.__dict__.__contains__ for read, write, getvalue
# StringIO implements these methods at the C level; they appear in its __dict__.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra92.StringIO_dict_read_write_getvalue:
  description: "io.StringIO.__dict__.__contains__ for 'read', 'write', 'getvalue' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra92

  columns: [id, function, args, expected]
  rows:
    - [sio_read,     StringIO.__dict__.__contains__, ["read"],     true]
    - [sio_write,    StringIO.__dict__.__contains__, ["write"],    true]
    - [sio_getvalue, StringIO.__dict__.__contains__, ["getvalue"], true]

# ---------------------------------------------------------------------------
# io.StringIO.__dict__.__contains__ for seek, tell; BytesIO/StringIO __qualname__
# StringIO defines seek and tell at the C level.
# BytesIO and StringIO are top-level classes; __qualname__ equals __name__.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra92.StringIO_dict_seek_tell_and_qualnames:
  description: "io.StringIO dict seek/tell; BytesIO/StringIO __qualname__ equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra92

  columns: [id, function, args, expected]
  rows:
    - [sio_seek,         StringIO.__dict__.__contains__,  ["seek"],      true]
    - [sio_tell,         StringIO.__dict__.__contains__,  ["tell"],      true]
    - [bio_qualname,     BytesIO.__qualname__.__eq__,     ["BytesIO"],   true]
    - [sio_qualname,     StringIO.__qualname__.__eq__,    ["StringIO"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra92.BytesIO_dict.contains_seek:
  description: "io.BytesIO.__dict__.__contains__('seek') == True (BytesIO defines seek at C level)"
  category: dict_membership
  kind: python_call_eq
  function: BytesIO.__dict__.__contains__
  args: ["seek"]
  expected: true

invariant io_extra92.BytesIO_dict.contains_getvalue:
  description: "io.BytesIO.__dict__.__contains__('getvalue') == True (BytesIO defines getvalue at C level)"
  category: dict_membership
  kind: python_call_eq
  function: BytesIO.__dict__.__contains__
  args: ["getvalue"]
  expected: true

invariant io_extra92.BytesIO_dict.contains_getbuffer:
  description: "io.BytesIO.__dict__.__contains__('getbuffer') == True (BytesIO defines getbuffer at C level)"
  category: dict_membership
  kind: python_call_eq
  function: BytesIO.__dict__.__contains__
  args: ["getbuffer"]
  expected: true

invariant io_extra92.StringIO_dict.contains_getvalue:
  description: "io.StringIO.__dict__.__contains__('getvalue') == True (StringIO defines getvalue at C level)"
  category: dict_membership
  kind: python_call_eq
  function: StringIO.__dict__.__contains__
  args: ["getvalue"]
  expected: true

invariant io_extra92.BytesIO.qualname:
  description: "io.BytesIO.__qualname__.__eq__('BytesIO') == True (top-level class; qualname equals name)"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true
