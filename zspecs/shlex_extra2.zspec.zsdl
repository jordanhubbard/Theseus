spec: shlex_extra2
version: ">=3.8"
backend: python_module(shlex)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
  notes:
    - "This spec extends shlex.zspec.zsdl and shlex_extra.zspec.zsdl."
    - "shlex.zspec.zsdl covers: split/quote/join behavioral vectors and ValueError on unclosed quotes."
    - "shlex_extra.zspec.zsdl covers: shlex.__name__, shlex.__module__, split/join/quote __name__ checks, and selected split/quote vectors."
    - "This spec adds: split.__module__, shlex.whitespace type check, shlex.wordchars type check, shlex.__qualname__, and join/__qualname__."
    - "shlex.shlex.whitespace is a class-level str attribute listing characters treated as whitespace."
    - "shlex.shlex.wordchars is a class-level str attribute listing characters that form word tokens."
    - "shlex.split.__module__ == 'shlex' — split is defined directly in the shlex module."
    - "shlex.join.__module__ == 'shlex' — join is defined directly in the shlex module."
    - "shlex.quote.__module__ == 'shlex' — quote is defined directly in the shlex module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — shlex.shlex __name__ and __module__
# (shlex_extra covers these; repeated here as anchors for the extra2 family)
# ---------------------------------------------------------------------------

invariant shlex_extra2.shlex_class.name:
  description: "shlex.shlex.__name__ == 'shlex'"
  category: class_metadata
  kind: python_call_eq
  function: shlex.__name__.__eq__
  args: ["shlex"]
  expected: true

invariant shlex_extra2.shlex_class.module:
  description: "shlex.shlex.__module__ == 'shlex'"
  category: class_metadata
  kind: python_call_eq
  function: shlex.__module__.__eq__
  args: ["shlex"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table shlex_extra2.function_names:
  description: "shlex module-level functions have __name__ equal to their identifier"
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [split,  split.__name__.__eq__,  ["split"],  true]
    - [join,   join.__name__.__eq__,   ["join"],   true]
    - [quote,  quote.__name__.__eq__,  ["quote"],  true]

# ---------------------------------------------------------------------------
# Function __module__ checks
# ---------------------------------------------------------------------------

table shlex_extra2.function_modules:
  description: "shlex module-level functions have __module__ == 'shlex'"
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [split,  split.__module__.__eq__,  ["shlex"],  true]
    - [join,   join.__module__.__eq__,   ["shlex"],  true]
    - [quote,  quote.__module__.__eq__,  ["shlex"],  true]

# ---------------------------------------------------------------------------
# shlex.shlex class-level attribute type checks
# ---------------------------------------------------------------------------

invariant shlex_extra2.shlex_class.whitespace_is_str:
  description: "shlex.shlex.whitespace.__class__.__name__ == 'str' — whitespace is a class-level str"
  category: class_attributes
  kind: python_call_eq
  function: shlex.whitespace.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant shlex_extra2.shlex_class.wordchars_is_str:
  description: "shlex.shlex.wordchars.__class__.__name__ == 'str' — wordchars is a class-level str"
  category: class_attributes
  kind: python_call_eq
  function: shlex.wordchars.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant shlex_extra2.shlex_class.whitespace_contains_space:
  description: "' ' in shlex.shlex.whitespace — space character is a whitespace token"
  category: class_attributes
  kind: python_call_eq
  function: shlex.whitespace.__contains__
  args: [" "]
  expected: true

invariant shlex_extra2.shlex_class.whitespace_contains_tab:
  description: "'\\t' in shlex.shlex.whitespace — tab is a whitespace character"
  category: class_attributes
  kind: python_call_eq
  function: shlex.whitespace.__contains__
  args: ["\t"]
  expected: true

invariant shlex_extra2.shlex_class.whitespace_contains_newline:
  description: "'\\n' in shlex.shlex.whitespace — newline is a whitespace character"
  category: class_attributes
  kind: python_call_eq
  function: shlex.whitespace.__contains__
  args: ["\n"]
  expected: true

# ---------------------------------------------------------------------------
# shlex.shlex class inheritance
# ---------------------------------------------------------------------------

invariant shlex_extra2.shlex_class.base_is_object:
  description: "shlex.shlex.__bases__[0].__name__ == 'object' — shlex class inherits from object"
  category: class_metadata
  kind: python_call_eq
  function: shlex.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
