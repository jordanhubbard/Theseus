spec: concurrent_futures_extra1561
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for concurrent.futures classes."
    - "concurrent.futures classes (Future, ThreadPoolExecutor, ProcessPoolExecutor) are executor/future primitives, not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "concurrent.futures.Future.__module__=='concurrent.futures._base'."
    - "concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread'."
    - "concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table concurrent_futures_extra1561.future_numeric_protocol:
  description: "concurrent.futures.Future.__dict__ does not contain any numeric type conversion protocol dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: cf1561fu

  columns: [id, function, args, expected]
  rows:
    - [cf1561fu001, concurrent.futures.Future.__dict__.__contains__, ["__bool__"],    false]
    - [cf1561fu002, concurrent.futures.Future.__dict__.__contains__, ["__int__"],     false]
    - [cf1561fu003, concurrent.futures.Future.__dict__.__contains__, ["__float__"],   false]
    - [cf1561fu004, concurrent.futures.Future.__dict__.__contains__, ["__complex__"], false]
    - [cf1561fu005, concurrent.futures.Future.__dict__.__contains__, ["__index__"],   false]
    - [cf1561fu006, concurrent.futures.Future.__dict__.__contains__, ["__trunc__"],   false]
    - [cf1561fu007, concurrent.futures.Future.__dict__.__contains__, ["__floor__"],   false]
    - [cf1561fu008, concurrent.futures.Future.__dict__.__contains__, ["__ceil__"],    false]
    - [cf1561fu009, concurrent.futures.Future.__dict__.__contains__, ["__round__"],   false]

