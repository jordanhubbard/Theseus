spec: asyncio_extra164
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec covers: asyncio.StreamReader method qualnames and class name identity. asyncio.StreamReader.__name__=='StreamReader' (len=12: 'Stream'=6+'Reader'=6=12); asyncio.StreamReader.read.__qualname__=='StreamReader.read' (len=17: 'StreamReader'=12+'.'=1+'read'=4=17); asyncio.StreamReader.readline.__qualname__=='StreamReader.readline' (len=21: 'StreamReader'=12+'.'=1+'readline'=8=21); asyncio.StreamReader.readexactly.__qualname__=='StreamReader.readexactly' (len=24: 'StreamReader'=12+'.'=1+'readexactly'=11=24); asyncio.StreamReader.readuntil.__qualname__=='StreamReader.readuntil' (len=22: 'StreamReader'=12+'.'=1+'readuntil'=9=22); qualname length ordering: read(17) < readline(21) < readuntil(22) < readexactly(24). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.StreamReader.__name__=='StreamReader' (len=12: 'Stream'=6+'Reader'=6=12) — StreamReader is the asyncio coroutine-based stream reader class for reading data from a stream connection; StreamReader provides coroutine methods that can be awaited: read(n=-1) reads up to n bytes (or all available if n==-1); readline() reads until a newline or EOF; readexactly(n) reads exactly n bytes raising IncompleteReadError if fewer are available; readuntil(separator=b'\\n') reads until the separator byte sequence is found; StreamReader.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; 'streams'=7: 's'+'t'+'r'+'e'+'a'+'m'+'s'=7; compare: 'asyncio.events'=14 and 'asyncio.queues'=14 are 1 char shorter); all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.StreamReader method qualname length ordering: read(17) < readline(21) < readuntil(22) < readexactly(24); method name lengths: 'read'=4 < 'readline'=8 < 'readuntil'=9 < 'readexactly'=11; the constant 'StreamReader.'=13 prefix (12+1=13) is shared by all four; read(4) is the shortest method name and gives the shortest qualname read(17); readexactly(11) is the longest method name and gives the longest qualname readexactly(24); compare: readline(21) < readuntil(22) because 'readline'=8 < 'readuntil'=9; 'readuntil'=9 > 'readline'=8 because 'until'=5 > 'line'=4 by 1 char; all four method names start with 'read': 'read'=4 is the base, the others add suffixes 'line'=4, 'until'=5, 'exactly'=7; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.StreamReader.__name__ identity — extra164
#
# asyncio.StreamReader.__name__.__eq__('StreamReader')  == True
# asyncio.StreamReader.__name__.__len__()               == 12
# ---------------------------------------------------------------------------

table asyncio_extra164.asyncio_stream_reader_identity:
  description: "asyncio.StreamReader class name identity checks in asynciosr164 namespace — asyncio.StreamReader.__name__=='StreamReader' (len=12: 'Stream'=6+'Reader'=6=12; StreamReader is the asyncio coroutine-based stream reading class; it provides awaitable methods for reading byte data from a network connection or pipe established via asyncio.open_connection() or asyncio.start_server()); asyncio.StreamReader.__name__.__len__()==12 ('StreamReader'=12: 'Stream'=6+'Reader'=6=12); asyncio.StreamReader.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; 'streams'=7 chars: compare 'asyncio.events'=14 and 'asyncio.queues'=14 — both 1 shorter than 'asyncio.streams'=15 because 'events'=6 and 'queues'=6 are 1 char shorter than 'streams'=7); the 'StreamReader.'=13 qualname prefix (12+1=13) is shared by all four read method qualnames covered in this spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosr164

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,   asyncio.StreamReader.__name__.__eq__,   ["StreamReader"],  true,  "asyncio.StreamReader.__name__ == 'StreamReader' (len=12: 'Stream'=6+'Reader'=6=12); verified with Python 3.14.3"]
    - [sr_name_len,  asyncio.StreamReader.__name__.__len__,  [],                12,    "asyncio.StreamReader.__name__.__len__() == 12 ('StreamReader'; 'Stream'=6+'Reader'=6=12); verified with Python 3.14.3"]
    - [sr_mod_eq,    asyncio.StreamReader.__module__.__eq__,  ["asyncio.streams"],  true,  "asyncio.StreamReader.__module__ == 'asyncio.streams' (len=15; 'streams'=7 is 1 longer than 'events'=6 and 'queues'=6); verified with Python 3.14.3"]
    - [sr_mod_len,   asyncio.StreamReader.__module__.__len__, [],                   15,    "asyncio.StreamReader.__module__.__len__() == 15 ('asyncio.streams'; 'streams'=7 > 'events'=6 and 'queues'=6 by 1); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.StreamReader method qualnames — extra164
#
# asyncio.StreamReader.read.__qualname__.__eq__('StreamReader.read')             == True
# asyncio.StreamReader.readline.__qualname__.__eq__('StreamReader.readline')     == True
# asyncio.StreamReader.readexactly.__qualname__.__eq__('StreamReader.readexactly') == True
# asyncio.StreamReader.readuntil.__qualname__.__eq__('StreamReader.readuntil')   == True
# ---------------------------------------------------------------------------

table asyncio_extra164.asyncio_stream_reader_method_qualnames:
  description: "asyncio.StreamReader method qualname checks in asynciosrmq164 namespace — StreamReader.read.__qualname__=='StreamReader.read' (len=17: 'StreamReader'=12+'.'=1+'read'=4=17; read(n=-1) reads up to n bytes; if n==-1 reads all available bytes; is a coroutine); StreamReader.readline.__qualname__=='StreamReader.readline' (len=21: 'StreamReader'=12+'.'=1+'readline'=8=21; readline() reads until a newline or EOF; 'readline'=8 > 'read'=4 so readline qualname(21) > read qualname(17) by 4); StreamReader.readexactly.__qualname__=='StreamReader.readexactly' (len=24: 'StreamReader'=12+'.'=1+'readexactly'=11=24; readexactly(n) reads exactly n bytes raising asyncio.IncompleteReadError if EOF is reached before n bytes; 'readexactly'=11 is the longest method name giving qualname len=24 which is the longest in this spec); StreamReader.readuntil.__qualname__=='StreamReader.readuntil' (len=22: 'StreamReader'=12+'.'=1+'readuntil'=9=22; readuntil(separator=b'\\n') reads data from the stream until separator is found); qualname length ordering: read(17) < readline(21) < readuntil(22) < readexactly(24); 'StreamReader.'=13 prefix (12+1=13) is constant; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosrmq164

  columns: [id, function, args, expected, description]
  rows:
    - [sr_read_qn,        asyncio.StreamReader.read.__qualname__.__eq__,        ["StreamReader.read"],        true,  "StreamReader.read.__qualname__ == 'StreamReader.read' (len=17; 'read'=4; shortest qualname); verified with Python 3.14.3"]
    - [sr_readline_qn,    asyncio.StreamReader.readline.__qualname__.__eq__,    ["StreamReader.readline"],    true,  "StreamReader.readline.__qualname__ == 'StreamReader.readline' (len=21; 'readline'=8); verified with Python 3.14.3"]
    - [sr_readexactly_qn, asyncio.StreamReader.readexactly.__qualname__.__eq__, ["StreamReader.readexactly"], true,  "StreamReader.readexactly.__qualname__ == 'StreamReader.readexactly' (len=24; 'readexactly'=11; longest); verified with Python 3.14.3"]
    - [sr_readuntil_qn,   asyncio.StreamReader.readuntil.__qualname__.__eq__,   ["StreamReader.readuntil"],   true,  "StreamReader.readuntil.__qualname__ == 'StreamReader.readuntil' (len=22; 'readuntil'=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.StreamReader method qualname lengths — extra164
#
# read(17) < readline(21) < readuntil(22) < readexactly(24)
# ---------------------------------------------------------------------------

table asyncio_extra164.asyncio_stream_reader_qualname_lengths:
  description: "asyncio.StreamReader method qualname length cross-comparison in asynciosrql164 namespace — read qualname len==17 ('StreamReader.read'=17: 'StreamReader'=12+'.'=1+'read'=4=17; shortest qualname because 'read'=4 is the shortest method name); readline qualname len==21 ('StreamReader.readline'=21: 'readline'=8; 4 longer than read=17 because 'readline'=8='read'=4+'line'=4); readuntil qualname len==22 ('StreamReader.readuntil'=22: 'readuntil'=9; 1 longer than readline=21 because 'readuntil'=9='read'=4+'until'=5 and 'until'=5 > 'line'=4 by 1 char); readexactly qualname len==24 ('StreamReader.readexactly'=24: 'readexactly'=11; longest because 'readexactly'=11='read'=4+'exactly'=7 and 'exactly'=7 > 'until'=5 by 2; gives readexactly(24) > readuntil(22) by 2); qualname length ordering: read(17) < readline(21) < readuntil(22) < readexactly(24); the prefix 'StreamReader.'=13 is constant: 12+1=13; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosrql164

  columns: [id, function, args, expected, description]
  rows:
    - [sr_read_qn_len,        asyncio.StreamReader.read.__qualname__.__len__,        [],  17,  "StreamReader.read qualname len==17 (shortest; 'read'=4); verified with Python 3.14.3"]
    - [sr_readline_qn_len,    asyncio.StreamReader.readline.__qualname__.__len__,    [],  21,  "StreamReader.readline qualname len==21 ('readline'=8; 4 longer than read=17); verified with Python 3.14.3"]
    - [sr_readuntil_qn_len,   asyncio.StreamReader.readuntil.__qualname__.__len__,   [],  22,  "StreamReader.readuntil qualname len==22 ('readuntil'=9; 1 longer than readline=21); verified with Python 3.14.3"]
    - [sr_readexactly_qn_len, asyncio.StreamReader.readexactly.__qualname__.__len__, [],  24,  "StreamReader.readexactly qualname len==24 (longest; 'readexactly'=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant asyncio_extra164.asyncio_StreamReader_name_eq:
  description: "asyncio.StreamReader.__name__.__eq__('StreamReader') returns True — asyncio.StreamReader is the coroutine-based stream reading class; StreamReader.__name__=='StreamReader' (len=12: 'Stream'=6+'Reader'=6=12); StreamReader is created internally when asyncio.open_connection() or asyncio.start_server() establishes a connection; it provides a coroutine-based API for reading bytes from the connection in various ways: read(), readline(), readexactly(), readuntil(); StreamReader.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; the streams submodule; 'streams'=7 is 1 char longer than 'events'=6 and 'queues'=6 — 'asyncio.streams'=15 is 1 longer than 'asyncio.events'=14 and 'asyncio.queues'=14); compare: asyncio.Queue.__name__=='Queue' (len=5) and asyncio.Event.__name__=='Event' (len=5) — both are 7 chars shorter than StreamReader=12; NEW in extra164: first standalone asyncio.StreamReader.__name__ identity invariant in asynciosr164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.__name__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra164.asyncio_StreamReader_read_qualname_eq:
  description: "asyncio.StreamReader.read.__qualname__.__eq__('StreamReader.read') returns True — asyncio.StreamReader.read is the primary byte-reading coroutine; read.__qualname__=='StreamReader.read' (len=17: 'StreamReader'=12+'.'=1+'read'=4=17); read(n=-1) reads up to n bytes from the stream; if n is negative or omitted, reads all available data until EOF; read() is the base method name: all other StreamReader read methods (readline, readexactly, readuntil) are extensions of 'read' with suffixes; 'StreamReader.read' (len=17) is the shortest of the four qualnames: read(17) < readline(21) < readuntil(22) < readexactly(24); the 'StreamReader.'=13 prefix (12+1=13) is constant; compare: asyncio.Queue.put.__qualname__=='Queue.put' (len=9; established in extra163) — StreamReader.read qualname(17) is 8 longer than Queue.put qualname(9) because 'StreamReader'=12 > 'Queue'=5 by 7 chars; NEW in extra164: first standalone StreamReader.read.__qualname__ invariant in asynciosrmq164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.read.__qualname__.__eq__
  args: ["StreamReader.read"]
  expected: true

invariant asyncio_extra164.asyncio_StreamReader_readline_qualname_eq:
  description: "asyncio.StreamReader.readline.__qualname__.__eq__('StreamReader.readline') returns True — asyncio.StreamReader.readline reads data until a newline byte (b'\\n') or EOF; readline.__qualname__=='StreamReader.readline' (len=21: 'StreamReader'=12+'.'=1+'readline'=8=21); 'readline'=8='read'=4+'line'=4; readline qualname(21) = read qualname(17) + 4 (the 'line' suffix adds 4 chars); readline() returns the line including the trailing newline; if EOF is reached without a newline, returns the partial data; readline(21) is 4 longer than read(17) because the 'line' suffix is 4 chars; compare: readuntil(22) is 1 longer than readline(21) because 'until'=5 > 'line'=4 by 1; NEW in extra164: first standalone StreamReader.readline.__qualname__ invariant in asynciosrmq164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.readline.__qualname__.__eq__
  args: ["StreamReader.readline"]
  expected: true

invariant asyncio_extra164.asyncio_StreamReader_readexactly_qualname_eq:
  description: "asyncio.StreamReader.readexactly.__qualname__.__eq__('StreamReader.readexactly') returns True — asyncio.StreamReader.readexactly reads exactly n bytes; readexactly.__qualname__=='StreamReader.readexactly' (len=24: 'StreamReader'=12+'.'=1+'readexactly'=11=24); 'readexactly'=11='read'=4+'exactly'=7; readexactly qualname(24) is the longest among the four StreamReader read method qualnames: read(17) < readline(21) < readuntil(22) < readexactly(24); readexactly(n) blocks until exactly n bytes are available or EOF; if EOF is reached before n bytes, raises asyncio.IncompleteReadError with the partial data; compare: readuntil(22) < readexactly(24) by 2 chars because 'exactly'=7 > 'until'=5 by 2; NEW in extra164: first standalone StreamReader.readexactly.__qualname__ invariant in asynciosrmq164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.readexactly.__qualname__.__eq__
  args: ["StreamReader.readexactly"]
  expected: true

invariant asyncio_extra164.asyncio_StreamReader_readuntil_qualname_eq:
  description: "asyncio.StreamReader.readuntil.__qualname__.__eq__('StreamReader.readuntil') returns True — asyncio.StreamReader.readuntil reads data until a separator byte sequence is found; readuntil.__qualname__=='StreamReader.readuntil' (len=22: 'StreamReader'=12+'.'=1+'readuntil'=9=22); 'readuntil'=9='read'=4+'until'=5; readuntil qualname(22) is between readline(21) and readexactly(24): readline(21) < readuntil(22) < readexactly(24); readuntil(separator=b'\\n') reads data until the separator is found, returning data including the separator; raises asyncio.LimitOverrunError if the buffer limit is exceeded without finding the separator; compare: 'readuntil'=9 > 'readline'=8 by 1 char (because 'until'=5 > 'line'=4 by 1), explaining why readuntil qualname(22) > readline qualname(21) by 1; NEW in extra164: first standalone StreamReader.readuntil.__qualname__ invariant in asynciosrmq164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.readuntil.__qualname__.__eq__
  args: ["StreamReader.readuntil"]
  expected: true
