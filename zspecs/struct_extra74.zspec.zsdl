spec: struct_extra74
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra73.zspec.zsdl — covers Struct.__repr__/__class__/__name__=='wrapper_descriptor' / Struct.format/__qualname__.__len__()==13 / Struct.__bases__.__len__()==1 / calcsize+pack_into qualname cross-check (table + invariants)."
    - "struct_extra72.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__/__class__/__name__=='str' and __doc__.__contains__ (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct.__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct_extra39.zspec.zsdl — covers Struct/__mro__[1]/__name__.__eq__('object') / Struct.size/__qualname__.__len__()==11 (table + invariants)."
    - "struct_extra4.zspec.zsdl — covers struct.calcsize/__qualname__.__eq__('calcsize') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra73; it does NOT duplicate invariants present in those files."
    - "Wave 245 theme: struct.Struct method __qualname__ lengths + module-level function __qualname__ lengths."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' — len 11. struct_extra73 covers format.__qualname__.__len__()==13 and size.__qualname__.__len__()==11. No prior struct spec checks Struct.pack.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — len 13. No prior struct spec checks Struct.unpack.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' — len 16. No prior struct spec checks Struct.pack_into.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' — len 18. No prior struct spec checks Struct.unpack_from.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' — len 18. No prior struct spec checks Struct.iter_unpack.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct' — Struct is defined in the C extension. No prior struct spec checks Struct.__module__ as a standalone (struct_extra71 covers module-level functions, not the class). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack' — len 4. No prior struct spec checks struct.pack.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack' — len 6. No prior struct spec checks struct.unpack.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into' — len 9. No prior struct spec checks struct.pack_into.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from' — len 11. No prior struct spec checks struct.unpack_from.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack' — len 11. No prior struct spec checks struct.iter_unpack.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize' — len 8. No prior struct spec checks struct.calcsize.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct method __qualname__ lengths: pack and unpack
#
# Wave 245 theme: Struct method qualname lengths.
#
# struct.Struct.pack.__qualname__ == 'Struct.pack' (11 chars).
# struct.Struct.unpack.__qualname__ == 'Struct.unpack' (13 chars).
# struct_extra73 covers format (13) and size (11) qualname lengths but NOT
# pack or unpack. No prior struct spec checks pack or unpack __qualname__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra74.Struct_pack_unpack_qualname_len:
  description: "struct.Struct.pack/__qualname__/__len__()==11 / Struct.unpack/__qualname__/__len__()==13 — 'Struct.pack' is 11 chars; 'Struct.unpack' is 13 chars; struct_extra73 covers format (13) and size (11) qualname lengths; no prior struct spec checks Struct.pack or Struct.unpack __qualname__.__len__(); first qualname length anchor for Struct.pack/unpack"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra74

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_qualname_len_11,   Struct.pack.__qualname__.__len__,   [], 11]
    - [Struct_unpack_qualname_len_13, Struct.unpack.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# struct.Struct method __qualname__ lengths: pack_into, unpack_from, iter_unpack
#
# Wave 245 theme: Struct method qualname lengths (extended methods).
#
# struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' (16 chars).
# struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' (18 chars).
# struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (18 chars).
# No prior struct spec checks any of these __qualname__.__len__() values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra74.Struct_pack_into_unpack_from_iter_unpack_qualname_len:
  description: "struct.Struct.pack_into/__qualname__/__len__()==16 / Struct.unpack_from/__qualname__/__len__()==18 / Struct.iter_unpack/__qualname__/__len__()==18 — 'Struct.pack_into' is 16; 'Struct.unpack_from' and 'Struct.iter_unpack' are both 18; no prior struct spec checks these __qualname__.__len__() values; first qualname length anchor for Struct.pack_into/unpack_from/iter_unpack"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra74

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_into_qualname_len_16,   Struct.pack_into.__qualname__.__len__,   [], 16]
    - [Struct_unpack_from_qualname_len_18, Struct.unpack_from.__qualname__.__len__, [], 18]
    - [Struct_iter_unpack_qualname_len_18, Struct.iter_unpack.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# struct module-level function __qualname__ lengths: pack, unpack, pack_into
#
# Wave 245 theme: module-level function qualname lengths.
#
# struct.pack.__qualname__ == 'pack' (4 chars).
# struct.unpack.__qualname__ == 'unpack' (6 chars).
# struct.pack_into.__qualname__ == 'pack_into' (9 chars).
# struct_extra4/extra68/extra73 cover calcsize and pack_into qualname string eq;
# no prior struct spec checks __qualname__.__len__() for pack, unpack, or pack_into.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra74.module_pack_unpack_pack_into_qualname_len:
  description: "struct.pack/__qualname__/__len__()==4 / struct.unpack/__qualname__/__len__()==6 / struct.pack_into/__qualname__/__len__()==9 — module-level pack/unpack/pack_into are C builtins with simple qualnames; no prior struct spec checks these __qualname__.__len__() values; first qualname length anchor for module-level pack/unpack/pack_into"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra74

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname_len_4,      pack.__qualname__.__len__,      [], 4]
    - [unpack_qualname_len_6,    unpack.__qualname__.__len__,    [], 6]
    - [pack_into_qualname_len_9, pack_into.__qualname__.__len__, [], 9]

