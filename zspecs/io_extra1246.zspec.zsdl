spec: io_extra1246
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io __doc__ class checks for module, IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, TextIOWrapper, BufferedReader, BufferedWriter, UnsupportedOperation, open"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that io module and key classes have str __doc__ attributes; io.UnsupportedOperation.__doc__ is NoneType (no docstring defined); none of these __doc__ class checks were covered in prior io_extra specs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1246.module_doc_class:
  description: "io module and core abstract base classes have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: io1246md
  columns: [id, function, args, expected]
  rows:
    - [io1246md001, io.__doc__.__class__.__name__.__eq__,            ["str"],     true]
    - [io1246md002, io.__doc__.__class__.__name__.__eq__,            ["NoneType"], false]
    - [io1246md003, io.IOBase.__doc__.__class__.__name__.__eq__,     ["str"],     true]
    - [io1246md004, io.IOBase.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [io1246md005, io.RawIOBase.__doc__.__class__.__name__.__eq__,  ["str"],     true]
    - [io1246md006, io.RawIOBase.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [io1246md007, io.BufferedIOBase.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1246md008, io.BufferedIOBase.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [io1246md009, io.TextIOBase.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [io1246md010, io.TextIOBase.__doc__.__class__.__name__.__eq__, ["NoneType"], false]

table io_extra1246.concrete_classes_doc_class:
  description: "io concrete buffer and text classes have str __doc__; UnsupportedOperation has NoneType __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: io1246cc
  columns: [id, function, args, expected]
  rows:
    - [io1246cc001, io.FileIO.__doc__.__class__.__name__.__eq__,           ["str"],     true]
    - [io1246cc002, io.FileIO.__doc__.__class__.__name__.__eq__,           ["NoneType"], false]
    - [io1246cc003, io.BytesIO.__doc__.__class__.__name__.__eq__,          ["str"],     true]
    - [io1246cc004, io.BytesIO.__doc__.__class__.__name__.__eq__,          ["NoneType"], false]
    - [io1246cc005, io.StringIO.__doc__.__class__.__name__.__eq__,         ["str"],     true]
    - [io1246cc006, io.StringIO.__doc__.__class__.__name__.__eq__,         ["NoneType"], false]
    - [io1246cc007, io.TextIOWrapper.__doc__.__class__.__name__.__eq__,    ["str"],     true]
    - [io1246cc008, io.TextIOWrapper.__doc__.__class__.__name__.__eq__,    ["NoneType"], false]
    - [io1246cc009, io.BufferedReader.__doc__.__class__.__name__.__eq__,   ["str"],     true]
    - [io1246cc010, io.BufferedReader.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]

table io_extra1246.buffered_writer_and_exception_doc_class:
  description: "io.BufferedWriter has str __doc__; io.UnsupportedOperation has NoneType __doc__; io.open has str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: io1246bw
  columns: [id, function, args, expected]
  rows:
    - [io1246bw001, io.BufferedWriter.__doc__.__class__.__name__.__eq__,       ["str"],     true]
    - [io1246bw002, io.BufferedWriter.__doc__.__class__.__name__.__eq__,       ["NoneType"], false]
    - [io1246bw003, io.UnsupportedOperation.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
    - [io1246bw004, io.UnsupportedOperation.__doc__.__class__.__name__.__eq__, ["str"],     false]
    - [io1246bw005, io.open.__doc__.__class__.__name__.__eq__,                 ["str"],     true]
    - [io1246bw006, io.open.__doc__.__class__.__name__.__eq__,                 ["NoneType"], false]
    - [io1246bw007, io.BufferedReader.__doc__.__class__.__name__.__eq__,       ["str"],     true]
    - [io1246bw008, io.StringIO.__doc__.__class__.__name__.__eq__,             ["str"],     true]
    - [io1246bw009, io.BytesIO.__doc__.__class__.__name__.__eq__,              ["str"],     true]
    - [io1246bw010, io.FileIO.__doc__.__class__.__name__.__eq__,               ["str"],     true]
