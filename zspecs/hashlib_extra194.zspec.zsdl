  kind: python_call_eq
  function: hashlib.sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra194.md5_module_is_hashlib_c:
  description: "hashlib.md5.__module__ == '_hashlib' — private C extension backing OpenSSL; len=8; new to extra194"
  category: identity
  kind: python_call_eq
  function: hashlib.md5.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra194.sha256_module_is_hashlib_c:
  description: "hashlib.sha256.__module__ == '_hashlib' — private C extension backing OpenSSL; len=8; new to extra194"
  category: identity
  kind: python_call_eq
  function: hashlib.sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra194.md5_class_is_builtin:
  description: "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — C-level callable; len=26; new to extra194"
  category: identity
  kind: python_call_eq
  function: hashlib.md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra194.sha1_module_is_hashlib_c:
  description: "hashlib.sha1.__module__ == '_hashlib' — private C extension backing OpenSSL; len=8; new to extra194"
  category: identity
  kind: python_call_eq
  function: hashlib.sha1.__module__.__eq__
  args: ["_hashlib"]
  expected: true

