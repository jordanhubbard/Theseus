spec: hashlib_extra194
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "hashlib.md5.__name__ == 'openssl_md5' — OpenSSL-backed constructor; len=11."
    - "hashlib.sha1.__name__ == 'openssl_sha1' — OpenSSL-backed constructor; len=12."
    - "hashlib.sha256.__name__ == 'openssl_sha256' — OpenSSL-backed constructor; len=14."
    - "hashlib.sha512.__name__ == 'openssl_sha512' — OpenSSL-backed constructor; len=14."
    - "hashlib.md5.__module__ == '_hashlib' — private C extension module backing OpenSSL hashes; len=8."
    - "hashlib.sha1.__module__ == '_hashlib' — private C extension module backing OpenSSL hashes."
    - "hashlib.sha256.__module__ == '_hashlib' — private C extension module backing OpenSSL hashes."
    - "hashlib.sha512.__module__ == '_hashlib' — private C extension module backing OpenSSL hashes."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — C-level callable; len=26."
    - "Name length ordering: md5(11) < sha1(12) < sha256(14) == sha512(14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __name__ identity for md5, sha1, sha256, sha512
#
# hashlib.md5.__name__    == 'openssl_md5'    (len=11)
# hashlib.sha1.__name__   == 'openssl_sha1'   (len=12)
# hashlib.sha256.__name__ == 'openssl_sha256' (len=14)
# hashlib.sha512.__name__ == 'openssl_sha512' (len=14)
#
# On macOS/Darwin with OpenSSL, each hashlib constructor is a C builtin
# from the _hashlib extension whose __name__ is the OpenSSL symbol name.
# ---------------------------------------------------------------------------

table hashlib_extra194.hash_names:
  description: "hashlib md5/sha1/sha256/sha512 __name__ identity; new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash194

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_eq,
       hashlib.md5.__name__.__eq__,
       ["openssl_md5"],
       true,
       "hashlib.md5.__name__.__eq__('openssl_md5') == True — OpenSSL-backed constructor; len=11; new to extra194"]
    - [md5_name_len,
       hashlib.md5.__name__.__len__,
       [],
       11,
       "hashlib.md5.__name__.__len__() == 11 — 'openssl_md5' has 11 characters; new to extra194"]
    - [sha1_name_eq,
       hashlib.sha1.__name__.__eq__,
       ["openssl_sha1"],
       true,
       "hashlib.sha1.__name__.__eq__('openssl_sha1') == True — OpenSSL-backed constructor; len=12; new to extra194"]
    - [sha1_name_len,
       hashlib.sha1.__name__.__len__,
       [],
       12,
       "hashlib.sha1.__name__.__len__() == 12 — 'openssl_sha1' has 12 characters; new to extra194"]
    - [sha256_name_eq,
       hashlib.sha256.__name__.__eq__,
       ["openssl_sha256"],
       true,
       "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — OpenSSL-backed constructor; len=14; new to extra194"]
    - [sha256_name_len,
       hashlib.sha256.__name__.__len__,
       [],
       14,
       "hashlib.sha256.__name__.__len__() == 14 — 'openssl_sha256' has 14 characters; new to extra194"]
    - [sha512_name_eq,
       hashlib.sha512.__name__.__eq__,
       ["openssl_sha512"],
       true,
       "hashlib.sha512.__name__.__eq__('openssl_sha512') == True — OpenSSL-backed constructor; len=14; new to extra194"]
    - [sha512_name_len,
       hashlib.sha512.__name__.__len__,
       [],
       14,
       "hashlib.sha512.__name__.__len__() == 14 — 'openssl_sha512' has 14 characters; new to extra194"]

# ---------------------------------------------------------------------------
# Table 2: __module__ identity for md5, sha1, sha256, sha512
#
# All four constructors have __module__ == '_hashlib' (len=8).
# ---------------------------------------------------------------------------

table hashlib_extra194.hash_modules:
  description: "hashlib md5/sha1/sha256/sha512 __module__ all equal '_hashlib'; new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash194

  columns: [id, function, args, expected, description]
  rows:
    - [md5_module_eq,
       hashlib.md5.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.md5.__module__.__eq__('_hashlib') == True — private C extension backing OpenSSL; new to extra194"]
    - [md5_module_len,
       hashlib.md5.__module__.__len__,
       [],
       8,
       "hashlib.md5.__module__.__len__() == 8 — '_hashlib' has 8 characters; new to extra194"]
    - [sha1_module_eq,
       hashlib.sha1.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha1.__module__.__eq__('_hashlib') == True — private C extension backing OpenSSL; new to extra194"]
    - [sha256_module_eq,
       hashlib.sha256.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha256.__module__.__eq__('_hashlib') == True — private C extension backing OpenSSL; new to extra194"]
    - [sha512_module_eq,
       hashlib.sha512.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha512.__module__.__eq__('_hashlib') == True — private C extension backing OpenSSL; new to extra194"]

# ---------------------------------------------------------------------------
# Table 3: __class__.__name__ identity and name-length ordering
#
# hashlib.md5.__class__.__name__ == 'builtin_function_or_method' (len=26)
# Name lengths: md5(11) < sha1(12) < sha256(14) == sha512(14)
# Verified via __lt__/__eq__ on the len() int values (via __len__).
# ---------------------------------------------------------------------------

table hashlib_extra194.hash_class_and_ordering:
  description: "hashlib constructors are C builtins; name lengths ordered md5<sha1<sha256==sha512; new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash194

  columns: [id, function, args, expected, description]
  rows:
    - [md5_class_name_eq,
       hashlib.md5.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') == True — C-level callable; new to extra194"]
    - [md5_class_name_len,
       hashlib.md5.__class__.__name__.__len__,
       [],
       26,
       "hashlib.md5.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters; new to extra194"]
    - [md5_name_lt_sha1_name,
       hashlib.md5.__name__.__lt__,
       ["openssl_sha1"],
       true,
       "hashlib.md5.__name__ < hashlib.sha1.__name__ lexicographically — 'openssl_md5' < 'openssl_sha1'; new to extra194"]
    - [sha256_name_eq_sha512_name_len,
       hashlib.sha256.__name__.__len__.__eq__,
       [14],
       true,
       "hashlib.sha256.__name__.__len__() == 14 — same length as sha512 name; new to extra194"]
    - [sha512_name_len_eq,
       hashlib.sha512.__name__.__len__.__eq__,
       [14],
       true,
       "hashlib.sha512.__name__.__len__() == 14 — same length as sha256 name; new to extra194"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra194
# ---------------------------------------------------------------------------

invariant hashlib_extra194.md5_name_is_openssl_md5:
  description: "hashlib.md5.__name__ == 'openssl_md5' — OpenSSL-backed C builtin name; len=11; new to extra194"
  category: identity
  kind: python_call_eq
  function: hashlib.md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra194.sha1_name_is_openssl_sha1:
  description: "hashlib.sha1.__name__ == 'openssl_sha1' — OpenSSL-backed C builtin name; len=12; new to extra194"
