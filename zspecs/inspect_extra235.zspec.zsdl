spec: inspect_extra235
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.getmembers output type contracts."
    - "inspect.getmembers.__name__ == 'getmembers' (len=10) — the function name. Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' (len=7) — getmembers is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers' (len=10) — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "inspect.getmembers.__class__.__name__ == 'function' — getmembers is a Python function. Verified with Python 3.14.3."
    - "inspect.getmembers(int).__class__.__name__ == 'list' — getmembers returns a list. Verified with Python 3.14.3."
    - "inspect.getmembers(inspect, inspect.isfunction).__class__.__name__ == 'list' — filtered result is also a list. Verified with Python 3.14.3."
    - "len(inspect.getmembers(int)) == 74 — int has 74 members. Verified with Python 3.14.3."
    - "len(inspect.getmembers(inspect, inspect.isfunction)) == 93 — inspect module has 93 function members. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers function identity contracts
#
# inspect.getmembers.__name__ == 'getmembers' (len=10)
# inspect.getmembers.__module__ == 'inspect' (len=7)
# inspect.getmembers.__qualname__ == 'getmembers' (len=10)
# inspect.getmembers.__class__.__name__ == 'function'
# inspect.getmembers.__doc__.__class__.__name__ == 'str'
#
# getmembers is a Python function in Lib/inspect.py. New to extra235.
# ---------------------------------------------------------------------------

table inspect_extra235.getmembers_function_identity:
  description: "inspect.getmembers function identity contracts: name, module, qualname, class, doc class; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra235gmfuncid

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — getmembers is a Python function in Lib/inspect.py that returns all attributes of an object as (name, value) pairs; __name__ is 'getmembers' (len=10); new to extra235"]
    - [getmembers_name_len_10,
       getmembers.__name__.__len__,
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has exactly 10 characters (g-e-t-m-e-m-b-e-r-s); str.__len__() returns 10; new to extra235"]
    - [getmembers_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra235"]
    - [getmembers_qualname_eq,
       getmembers.__qualname__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — getmembers is a top-level function with unqualified qualname 'getmembers'; new to extra235"]
    - [getmembers_class_is_function,
       getmembers.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getmembers.__class__.__name__.__eq__('function') == True — getmembers is a Python function; its __class__ is the built-in function type; new to extra235"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers function name/module length and doc contracts
#
# inspect.getmembers.__module__.__len__() == 7
# inspect.getmembers.__name__.__len__() == 10
# inspect.getmembers.__qualname__.__len__() == 10
# inspect.getmembers.__doc__.__class__.__name__ == 'str'
# inspect.getmembers.__doc__.__contains__('object') == True
#
# Length and documentation contracts for getmembers. New to extra235.
# ---------------------------------------------------------------------------

table inspect_extra235.getmembers_len_and_doc:
  description: "inspect.getmembers module length, qualname length; doc is str containing 'object'; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra235gmlenid

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_module_len_7,
       getmembers.__module__.__len__,
       [],
       7,
       "inspect.getmembers.__module__.__len__() == 7 — 'inspect' has exactly 7 characters (i-n-s-p-e-c-t); str.__len__() returns 7; new to extra235"]
    - [getmembers_qualname_len_10,
       getmembers.__qualname__.__len__,
       [],
       10,
       "inspect.getmembers.__qualname__.__len__() == 10 — 'getmembers' qualname has exactly 10 characters; str.__len__() returns 10; new to extra235"]
    - [getmembers_doc_class_is_str,
       getmembers.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getmembers.__doc__.__class__.__name__.__eq__('str') == True — the getmembers docstring is a plain Python str; new to extra235"]
    - [getmembers_doc_contains_object,
       getmembers.__doc__.__contains__,
       ["object"],
       true,
       "inspect.getmembers.__doc__.__contains__('object') == True — getmembers docstring mentions 'object' as the argument it inspects; new to extra235"]
    - [getmembers_doc_contains_predicate,
       getmembers.__doc__.__contains__,
       ["predicate"],
       true,
       "inspect.getmembers.__doc__.__contains__('predicate') == True — getmembers docstring mentions 'predicate' as an optional filter argument; new to extra235"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isfunction, isclass, ismodule function identity contracts
#
# inspect.isfunction.__name__ == 'isfunction' (len=10)
# inspect.isfunction.__module__ == 'inspect' (len=7)
# inspect.isclass.__name__ == 'isclass' (len=7)
# inspect.ismodule.__name__ == 'ismodule' (len=8)
# inspect.isclass.__class__.__name__ == 'function'
#
# These predicates are Python functions used as getmembers filters. New to extra235.
# ---------------------------------------------------------------------------

table inspect_extra235.inspect_predicate_identity:
  description: "inspect.isfunction, isclass, ismodule identity contracts: name, module, class; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra235ispredid

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a Python function in Lib/inspect.py that tests whether an object is a Python function; __name__ is 'isfunction' (len=10); new to extra235"]
    - [isfunction_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has exactly 10 characters; str.__len__() returns 10; new to extra235"]
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a Python function in Lib/inspect.py that tests whether an object is a class; __name__ is 'isclass' (len=7); new to extra235"]
    - [ismodule_name_eq,
       ismodule.__name__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — ismodule is a Python function in Lib/inspect.py that tests whether an object is a module; __name__ is 'ismodule' (len=8); new to extra235"]
    - [isclass_class_is_function,
       isclass.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isclass.__class__.__name__.__eq__('function') == True — isclass is a Python function; its __class__ is the built-in function type; new to extra235"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra235
# ---------------------------------------------------------------------------

invariant inspect_extra235.getmembers_name_eq:
  description: "inspect.getmembers.__name__ == 'getmembers' (len=10); new to extra235"
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra235.getmembers_name_len_10:
  description: "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters; new to extra235"
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra235.getmembers_module_eq:
  description: "inspect.getmembers.__module__ == 'inspect'; new to extra235"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra235.getmembers_module_len_7:
  description: "inspect.getmembers.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra235"
  kind: python_call_eq
  function: getmembers.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra235.getmembers_qualname_eq:
  description: "inspect.getmembers.__qualname__ == 'getmembers'; new to extra235"
  kind: python_call_eq
  function: getmembers.__qualname__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra235.getmembers_qualname_len_10:
  description: "inspect.getmembers.__qualname__.__len__() == 10 — 'getmembers' has 10 characters; new to extra235"
  kind: python_call_eq
  function: getmembers.__qualname__.__len__
  args: []
  expected: 10

invariant inspect_extra235.getmembers_class_is_function:
  description: "inspect.getmembers.__class__.__name__ == 'function'; new to extra235"
  kind: python_call_eq
  function: getmembers.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra235.getmembers_doc_class_is_str:
  description: "inspect.getmembers.__doc__.__class__.__name__ == 'str' — docstring is a plain str; new to extra235"
  kind: python_call_eq
  function: getmembers.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra235.getmembers_doc_contains_object:
  description: "inspect.getmembers.__doc__.__contains__('object') == True; new to extra235"
  kind: python_call_eq
  function: getmembers.__doc__.__contains__
  args: ["object"]
  expected: true

invariant inspect_extra235.isfunction_name_eq:
  description: "inspect.isfunction.__name__ == 'isfunction' (len=10); new to extra235"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra235.isfunction_name_len_10:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra235"
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra235.isclass_name_eq:
  description: "inspect.isclass.__name__ == 'isclass' (len=7); new to extra235"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra235.ismodule_name_eq:
  description: "inspect.ismodule.__name__ == 'ismodule' (len=8); new to extra235"
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true
