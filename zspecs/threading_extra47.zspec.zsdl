spec: threading_extra47
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra46.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__/__module__; Thread/__qualname__.__len__()==6; Thread/__mro__.__len__()==2; Thread/__bases__[0].__name__=='object'; Thread/__bases__[0].__qualname__=='object'; Event/__qualname__=='Event'; Event/__qualname__.__len__()==5; Event/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__bases__[0].__qualname__=='object'; Semaphore/__name__/__qualname__/__module__; Semaphore/__qualname__.__len__()==9; Semaphore/__mro__.__len__()==2; Semaphore/__bases__[0].__qualname__=='object'; BoundedSemaphore/__name__/__qualname__/__module__; BoundedSemaphore/__qualname__.__len__()==16; BoundedSemaphore/__mro__.__len__()==3; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; BoundedSemaphore/__bases__[0].__qualname__=='Semaphore'; Condition/__name__/__module__; Condition/__mro__.__len__()==2; Condition/__bases__[0].__name__=='object'; Condition/__bases__[0].__qualname__=='object'; Barrier/__name__/__qualname__/__module__; Barrier/__mro__.__len__()==2; Barrier/__bases__[0].__name__=='object'; Barrier/__bases__[0].__qualname__=='object'; Timer/__name__/__qualname__/__module__; Timer/__mro__.__len__()==3; Timer/__bases__[0].__name__=='Thread'; Timer/__bases__[0].__qualname__=='Thread'; Lock/__name__=='lock'; Lock/__qualname__=='lock'; Lock/__qualname__.__len__()==4; local/__name__=='_local'; TIMEOUT_MAX; threading.__all__.__len__()==28; current_thread/__name__/__module__; main_thread/__name__/__module__; active_count/__name__/__module__; enumerate/__name__/__module__; settrace/__name__; setprofile/__name__; stack_size/__name__; RLock/__name__/__qualname__/__module__."
    - "This spec covers: threading.Condition.__qualname__ == 'Condition'; threading.Condition.__qualname__.__len__() == 9; threading.Lock.__module__ == '_thread'; threading.Lock.__module__.__len__() == 7; threading.main_thread.__qualname__ == 'main_thread'; threading.current_thread.__qualname__ == 'current_thread'; threading.active_count.__qualname__ == 'active_count'; threading.enumerate.__qualname__ == 'enumerate'; threading.settrace.__qualname__ == 'settrace'; threading.setprofile.__qualname__ == 'setprofile'; threading.stack_size.__qualname__ == 'stack_size'."
    - "Key findings: threading.Condition.__qualname__ is 'Condition' (9 chars) — prior specs recorded Condition/__name__=='Condition' and __module__=='threading' and __bases__[0].__qualname__=='object', but not __qualname__ string equality. threading.Lock.__module__ is '_thread' (7 chars) — Lock is the C-extension class from Modules/_threadmodule.c; its __module__ reflects the underlying C extension '_thread' (not the public 'threading' module name). threading.main_thread, current_thread, active_count, and enumerate all have __qualname__ == __name__: 'main_thread' (11), 'current_thread' (14), 'active_count' (12), 'enumerate' (9). Prior specs recorded __name__ and __module__ for all four but not __qualname__ string equality. threading.settrace, setprofile, and stack_size all have __qualname__ == __name__: 'settrace' (8), 'setprofile' (10), 'stack_size' (10). Prior specs recorded __name__ for all three but not __qualname__ string equality. All eleven invariants are new to extra47."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Condition __qualname__ — extra47 namespace
#
# threading.Condition.__qualname__ is 'Condition' (9 chars). Condition is a
# pure-Python class defined at module level in Lib/threading.py; top-level so
# __qualname__ == __name__. Prior specs recorded Condition.__name__ == 'Condition'
# and Condition.__module__ == 'threading' (string equality) and
# Condition.__bases__[0].__qualname__ == 'object' (extra46), and
# Condition.__mro__.__len__() == 2, but no prior spec recorded
# Condition.__qualname__ string equality. The string equality and __len__()
# invariants are both new to extra47.
# ---------------------------------------------------------------------------

table threading_extra47.Condition_qualname:
  description: "threading.Condition __qualname__ string equality and length — pure-Python class at module level; __qualname__ == __name__ == 'Condition'; 9 chars; same length as __module__ 'threading'"
  kind: python_call_eq
  category: identity
  id_prefix: condqn47

  columns: [id, function, args, expected, description]
  rows:
    - [condition_qualname,
       Condition.__qualname__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__qualname__ == 'Condition' — pure-Python class at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing class scope); 9 chars; wait/notify-based synchronization primitive"]
    - [condition_qualname_len,
       Condition.__qualname__.__len__,
       [],
       9,
       "len(threading.Condition.__qualname__) == 9 — 'Condition' is 9 chars; same length as 'threading' (__module__) and 'Semaphore' (__qualname__.__len__() == 9 per extra45); same length as threading.Semaphore.__qualname__.__len__()"]

# ---------------------------------------------------------------------------
# threading.Lock __module__ — extra47 namespace
#
# threading.Lock.__module__ is '_thread' (7 chars). threading.Lock is actually
# the C-extension lock type from Modules/_threadmodule.c exposed as
# _thread.lock; threading re-exports it as threading.Lock. Its __module__
# attribute reflects the underlying C extension '_thread' rather than the
# public 'threading' module name, analogous to how functools.reduce.__module__
# is '_functools'. Prior specs recorded Lock.__name__ == 'lock',
# Lock.__qualname__ == 'lock', and Lock.__qualname__.__len__() == 4, but no
# prior spec recorded Lock.__module__ string equality. New to extra47.
# ---------------------------------------------------------------------------

table threading_extra47.Lock_module:
  description: "threading.Lock __module__ string equality and length — C-extension type from _thread module; __module__ == '_thread' not 'threading'; 7-char C extension name"
  kind: python_call_eq
  category: module_metadata
  id_prefix: lkmod47

  columns: [id, function, args, expected, description]
  rows:
    - [lock_module,
       Lock.__module__.__eq__,
       ["_thread"],
       true,
       "threading.Lock.__module__ == '_thread' — C-extension lock type from Modules/_threadmodule.c; re-exported via threading module but __module__ reflects the underlying C extension '_thread'; same pattern as functools.reduce.__module__=='_functools'"]
    - [lock_module_len,
       Lock.__module__.__len__,
       [],
       7,
       "len(threading.Lock.__module__) == 7 — '_thread' is 7 chars; C extension module name; shorter than 'threading' (9 chars) because the private C module uses a shorter underscore-prefixed name"]

# ---------------------------------------------------------------------------
# threading module-level functions __qualname__ — extra47 namespace
#
# threading.main_thread, current_thread, active_count, and enumerate are
# pure-Python functions defined at module level in Lib/threading.py. Their
# __qualname__ values equal their __name__ values (top-level functions, no
# enclosing class scope): 'main_thread' (11 chars), 'current_thread' (14 chars),
# 'active_count' (12 chars), and 'enumerate' (9 chars). Prior specs recorded
# __name__ and __module__ for all four (extra45 notes) but not __qualname__
# string equality. All four invariants are new to extra47.
# ---------------------------------------------------------------------------

table threading_extra47.thread_functions_qualnames:
  description: "threading main_thread/current_thread/active_count/enumerate __qualname__ string equality — pure-Python module-level functions; __qualname__ == __name__ in each case"
  kind: python_call_eq
  category: identity
  id_prefix: tfqn47

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_qualname,
       main_thread.__qualname__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__qualname__ == 'main_thread' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing class); 11 chars; returns the Thread object for the main thread"]
    - [current_thread_qualname,
       current_thread.__qualname__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__qualname__ == 'current_thread' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__; 14 chars; returns the Thread object for the current thread of execution"]
    - [active_count_qualname,
       active_count.__qualname__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__qualname__ == 'active_count' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__; 12 chars; returns the number of currently alive Thread objects"]
    - [enumerate_qualname,
       enumerate.__qualname__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__qualname__ == 'enumerate' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__; 9 chars; returns a list of all currently alive Thread objects; shadows the built-in enumerate within threading module scope"]

# ---------------------------------------------------------------------------
# threading utility functions __qualname__ — extra47 namespace
#
# threading.settrace, setprofile, and stack_size are pure-Python functions
# defined at module level in Lib/threading.py. Their __qualname__ values equal
# their __name__ values: 'settrace' (8 chars), 'setprofile' (10 chars), and
# 'stack_size' (10 chars). Prior specs recorded __name__ for all three
# (extra45 notes: 'settrace/__name__=='settrace'; setprofile/__name__=='setprofile';
# stack_size/__name__=='stack_size'') but not __qualname__ string equality.
# All three invariants are new to extra47.
# ---------------------------------------------------------------------------

table threading_extra47.utility_functions_qualnames:
  description: "threading settrace/setprofile/stack_size __qualname__ string equality — pure-Python module-level utility functions; __qualname__ == __name__ in each case"
  kind: python_call_eq
  category: identity
  id_prefix: ufqn47

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_qualname,
       settrace.__qualname__.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__qualname__ == 'settrace' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__; 8 chars; sets a trace function for all threads started after the call"]
    - [setprofile_qualname,
       setprofile.__qualname__.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__qualname__ == 'setprofile' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__; 10 chars; sets a profile function for all threads started after the call; same length as 'stack_size'"]
    - [stack_size_qualname,
       stack_size.__qualname__.__eq__,
       ["stack_size"],
       true,
       "threading.stack_size.__qualname__ == 'stack_size' — pure-Python function at module level in Lib/threading.py; __qualname__ == __name__; 10 chars; returns or sets the stack size used when creating new threads; same length as 'setprofile'"]
