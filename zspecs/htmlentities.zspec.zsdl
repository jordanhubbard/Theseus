spec: htmlentities
version: ">=1.0.0"
backend: node(htmlentities)

docs: https://www.npmjs.com/package/htmlentities

provenance:
  derived_from:
    - "htmlentities README — https://www.npmjs.com/package/htmlentities"
    - "Test vectors verified with htmlentities via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "htmlentities source"
  notes:
    - "htmlentities is an npm package. Install: npm install htmlentities"
    - "entities.encode(str) encodes special characters to HTML entities (spaces become &nbsp;)."
    - "entities.decode(str) decodes HTML entities back to characters."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns encoded or decoded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table htmlentities.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: hte_enc

  columns: [id, args, expected]
  rows:
    - [html_tags,  ["<p>Hello</p>"],  "&lt;p&gt;Hello&lt;/p&gt;"]
    - [ampersand,  ["Tom & Jerry"],   "Tom&nbsp;&amp;&nbsp;Jerry"]

table htmlentities.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: hte_dec

  columns: [id, args, expected]
  rows:
    - [html_tags,  ["&lt;p&gt;Hello&lt;/p&gt;"], "<p>Hello</p>"]
    - [ampersand,  ["Tom &amp; Jerry"],           "Tom & Jerry"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:00:39Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
