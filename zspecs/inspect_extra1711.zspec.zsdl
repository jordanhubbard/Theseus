spec: inspect_extra1711
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "inspect.Parameter is a pure Python class with __slots__ that defines __init__ in its own __dict__ → True."
    - "inspect.Signature is a pure Python class that defines __init__ in its own __dict__ → True."
    - "inspect.BoundArguments is a pure Python class that defines __init__ in its own __dict__ → True."
    - "inspect._ParameterKind is an IntEnum subclass; enum metaclass manages __init__ generically; presence in own __dict__ depends on whether _ParameterKind overrides it → covered in table with expected False (inherits from enum machinery)."
    - "Cross-checks between __init__ and __new__ presence, and __init_subclass__ / __class_getitem__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init__ dict-presence checks
#
# Wave 561 theme: which inspect types define __init__ in their own __dict__.
#
# inspect.Parameter: pure Python class with __slots__; defines __init__(self,
# name, kind, *, default=..., annotation=...) → True.
#
# inspect.Signature: pure Python class; defines __init__(self, parameters=None,
# *, return_annotation=...) → True.
#
# inspect.BoundArguments: pure Python class; defines __init__(self, signature,
# arguments) → True.
#
# inspect._ParameterKind: an IntEnum subclass; the enum metaclass provides
# __init__ at the enum level; _ParameterKind does not override it in its own
# class body → False.
# ---------------------------------------------------------------------------

table inspect_extra1711.init_protocol:
  description: "inspect types: __init__ dict-presence via __dict__.__contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1711

  columns: [id, function, args, expected]
  rows:
    - ["in1711001", "inspect.Parameter.__dict__.__contains__", ["__init__"], true]
    - ["in1711002", "inspect.Signature.__dict__.__contains__", ["__init__"], true]
    - ["in1711003", "inspect.BoundArguments.__dict__.__contains__", ["__init__"], true]
    - ["in1711004", "inspect._ParameterKind.__dict__.__contains__", ["__init__"], false]

# ---------------------------------------------------------------------------
# Table 2: __new__ dict-presence cross-checks
#
# Wave 561 cross-check: pure Python classes that define __init__ in their own
# __dict__ typically do NOT also define __new__ (they inherit it from object).
#
# inspect.Parameter: __new__ inherited from object → False.
# inspect.Signature: __new__ inherited from object → False.
# inspect.BoundArguments: __new__ inherited from object → False.
# inspect._ParameterKind: enum metaclass may provide __new__ for member
# construction; _ParameterKind inherits it via enum machinery, not its own
# __dict__ → False.
# ---------------------------------------------------------------------------

table inspect_extra1711.new_protocol:
  description: "inspect types: __new__ dict-presence cross-check (pure Python classes inherit __new__ from object)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1711

  columns: [id, function, args, expected]
  rows:
    - ["in1711005", "inspect.Parameter.__dict__.__contains__", ["__new__"], false]
    - ["in1711006", "inspect.Signature.__dict__.__contains__", ["__new__"], false]
    - ["in1711007", "inspect.BoundArguments.__dict__.__contains__", ["__new__"], false]
    - ["in1711008", "inspect._ParameterKind.__dict__.__contains__", ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 3: related dunder protocol cross-checks
#
# Wave 561 extension: __init_subclass__ is inherited from object and is not
# overridden by Parameter, Signature, or BoundArguments. __class_getitem__ is
# also not expected in their own __dict__ (they do not support generic syntax).
# ---------------------------------------------------------------------------

table inspect_extra1711.related_dunder_protocol:
  description: "inspect types: __init_subclass__ and __class_getitem__ dict-presence cross-checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1711

  columns: [id, function, args, expected]
  rows:
    - ["in1711009",  "inspect.Parameter.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in1711010",  "inspect.Signature.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in1711011",  "inspect.BoundArguments.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in1711012",  "inspect._ParameterKind.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in1711013",  "inspect.Parameter.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in1711014",  "inspect.Signature.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in1711015",  "inspect.BoundArguments.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in1711016",  "inspect._ParameterKind.__dict__.__contains__", ["__class_getitem__"], false]
