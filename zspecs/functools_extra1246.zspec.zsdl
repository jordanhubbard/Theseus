spec: functools_extra1246
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 530 (_extra1246): checks that functools module, functions, and classes have str __doc__ attributes."
    - "functools.__doc__.__class__.__name__ == 'str' — module docstring is a str; verified Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C built-in with a str docstring; verified Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial is a C type with a str docstring; verified Python 3.14.3."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str' — lru_cache is a Python function with a str docstring; verified Python 3.14.3."
    - "functools.cache.__doc__.__class__.__name__ == 'str' — cache is a Python function with a str docstring; verified Python 3.14.3."
    - "functools.cached_property.__doc__ is None — cached_property is a C type with no Python-level docstring; verified Python 3.14.3."
    - "functools.wraps.__doc__.__class__.__name__ == 'str' — wraps is a Python function with a str docstring; verified Python 3.14.3."
    - "functools.total_ordering.__doc__.__class__.__name__ == 'str' — total_ordering is a Python function with a str docstring; verified Python 3.14.3."
    - "functools.singledispatch.__doc__.__class__.__name__ == 'str' — singledispatch is a Python function with a str docstring; verified Python 3.14.3."
    - "functools.update_wrapper.__doc__.__class__.__name__ == 'str' — update_wrapper is a Python function with a str docstring; verified Python 3.14.3."
    - "functools.cmp_to_key.__doc__.__class__.__name__ == 'str' — cmp_to_key is a C built-in with a str docstring; verified Python 3.14.3."
    - "functools.__doc__.__len__.__class__.__name__ == 'method-wrapper' — __len__ on a str is a C method-wrapper; verified Python 3.14.3."
    - "functools.__doc__.__class__.__name__.__eq__('NoneType') == False — module docstring is not NoneType; verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

