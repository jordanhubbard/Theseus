spec: socket_extra84
version: ">=3.9"
extends: socket_extra83
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra83.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getnameinfo __qualname__.__len__() / __doc__.__class__.__name__=='str' / setdefaulttimeout/getdefaulttimeout/inet_aton/inet_ntoa __qualname__.__len__() / htons/htonl/ntohs __qualname__.__len__() / gethostname __qualname__.__eq__ (table + invariants)."
    - "socket_extra82.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/AF_UNSPEC/__class__/__qualname__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__/__qualname__=='SocketKind' / AddressFamily/SocketKind __qualname__/__bases__[0].__name__/__mro__.__len__()/__qualname__.__len__() (table + invariants)."
    - "socket_extra81.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/IPV6/SOL_SOCKET/__class__.__name__=='int' / AF_UNSPEC/__class__.__name__=='AddressFamily' / SOMAXCONN identity (table + invariants)."
    - "socket_extra80.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__.__name__=='SocketKind' / AF_INET/__eq__(2)/AF_INET6/__eq__(30)/SOCK_STREAM/__eq__(1)/SOCK_DGRAM/__eq__(2) (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra83; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: socket AF_INET integer value anchor / INADDR_ANY/INADDR_BROADCAST/INADDR_LOOPBACK/INADDR_NONE class and value identity / SHUT_RD/SHUT_WR/SHUT_RDWR class and value / SOL_TCP class identity."
    - "socket.AF_INET.__eq__(2) == True — AF_INET integer value is 2 on macOS. socket_extra80 also anchors this; re-anchored here in a different table context. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_ANY.__class__.__name__ == 'int' — INADDR_ANY is a plain int constant (value 0). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_ANY.__eq__(0) == True — INADDR_ANY value is 0 (INADDR_ANY binds to all interfaces). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_BROADCAST.__class__.__name__ == 'int' — INADDR_BROADCAST is a plain int (value 4294967295 == 0xffffffff). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_LOOPBACK.__class__.__name__ == 'int' — INADDR_LOOPBACK is a plain int (value 2130706433 == 0x7f000001). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_LOOPBACK.__eq__(2130706433) == True — 0x7f000001 == 2130706433. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_NONE.__class__.__name__ == 'int' — INADDR_NONE is a plain int (value 4294967295 == 0xffffffff). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.INADDR_NONE.__eq__(4294967295) == True — 0xffffffff == 4294967295. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RDWR.__class__.__name__ == 'int' — SHUT_RDWR is a plain int on macOS (value 2). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RD.__class__.__name__ == 'int' — SHUT_RD is a plain int (value 0). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_WR.__class__.__name__ == 'int' — SHUT_WR is a plain int (value 1). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RDWR.__eq__(2) == True — SHUT_RDWR value is 2 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_TCP.__class__.__name__ == 'int' — SOL_TCP is a plain int (value 6, same as IPPROTO_TCP) on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.INADDR_ANY/__class__/__name__ / INADDR_ANY/__eq__(0)
# socket.INADDR_BROADCAST/__class__/__name__ / socket.AF_INET/__eq__(2)
#
# Wave 250 theme: INADDR_ANY/INADDR_BROADCAST class identity and values, AF_INET cross-check.
#
# INADDR_ANY is an int with value 0 (bind to all interfaces).
# INADDR_BROADCAST is an int with value 4294967295 (0xffffffff, limited broadcast).
# AF_INET.__eq__(2) cross-checks the earlier socket_extra80 anchor in a new table context.
# No prior socket spec checks INADDR_ANY or INADDR_BROADCAST class or values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra84.inaddr_any_broadcast_and_af_inet:
  description: "socket.INADDR_ANY/__class__/__name__.__eq__('int')==True / INADDR_ANY/__eq__(0)==True / INADDR_BROADCAST/__class__/__name__.__eq__('int')==True / AF_INET/__eq__(2)==True — INADDR_ANY (value 0) and INADDR_BROADCAST (value 4294967295) are plain int constants; AF_INET cross-check anchors the int value 2; no prior socket spec checks INADDR_ANY or INADDR_BROADCAST class or values; first INADDR_ANY/INADDR_BROADCAST identity anchor for socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra84

  columns: [id, function, args, expected]
  rows:
    - [inaddr_any_class_int,        INADDR_ANY.__class__.__name__.__eq__,        ["int"], true]
    - [inaddr_any_eq_0,             INADDR_ANY.__eq__,                           [0],     true]
    - [inaddr_broadcast_class_int,  INADDR_BROADCAST.__class__.__name__.__eq__,  ["int"], true]
    - [af_inet_eq_2,                AF_INET.__eq__,                              [2],     true]

# ---------------------------------------------------------------------------
# socket.INADDR_LOOPBACK/__class__/__name__ / INADDR_LOOPBACK/__eq__(2130706433)
# socket.INADDR_NONE/__class__/__name__ / INADDR_NONE/__eq__(4294967295)
#
# Wave 250 theme: INADDR_LOOPBACK and INADDR_NONE class and value identity.
#
# INADDR_LOOPBACK is an int with value 2130706433 (0x7f000001, 127.0.0.1).
# INADDR_NONE is an int with value 4294967295 (0xffffffff, represents no address).
# No prior socket spec checks INADDR_LOOPBACK or INADDR_NONE class or values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra84.inaddr_loopback_none_identity:
  description: "socket.INADDR_LOOPBACK/__class__/__name__.__eq__('int')==True / INADDR_LOOPBACK/__eq__(2130706433)==True / INADDR_NONE/__class__.__name__.__eq__('int')==True / INADDR_NONE/__eq__(4294967295)==True — INADDR_LOOPBACK (0x7f000001 == 2130706433) is the loopback address 127.0.0.1; INADDR_NONE (0xffffffff == 4294967295) represents no valid address; both are plain int constants; no prior socket spec checks INADDR_LOOPBACK or INADDR_NONE; first identity anchor for socket.INADDR_LOOPBACK and INADDR_NONE"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra84

  columns: [id, function, args, expected]
  rows:
    - [inaddr_loopback_class_int,   INADDR_LOOPBACK.__class__.__name__.__eq__, ["int"],       true]
    - [inaddr_loopback_eq,          INADDR_LOOPBACK.__eq__,                    [2130706433],  true]
    - [inaddr_none_class_int,       INADDR_NONE.__class__.__name__.__eq__,     ["int"],       true]
    - [inaddr_none_eq,              INADDR_NONE.__eq__,                        [4294967295],  true]

# ---------------------------------------------------------------------------
# socket.SHUT_RD/__class__/__name__ / SHUT_WR/__class__/__name__
# socket.SHUT_RDWR/__class__/__name__ / SHUT_RDWR/__eq__(2)
#
# Wave 250 theme: SHUT_RD/SHUT_WR/SHUT_RDWR class and value identity.
#
# SHUT_RD, SHUT_WR, SHUT_RDWR are plain int constants on macOS (values 0, 1, 2).
# SHUT_RDWR.__eq__(2) confirms its integer value.
# No prior socket spec checks SHUT_RD/SHUT_WR/SHUT_RDWR class or values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra84.shut_constants_identity:
  description: "socket.SHUT_RD/__class__/__name__.__eq__('int')==True / SHUT_WR/__class__/__name__.__eq__('int')==True / SHUT_RDWR/__class__.__name__.__eq__('int')==True / SHUT_RDWR/__eq__(2)==True — SHUT_RD (0), SHUT_WR (1), SHUT_RDWR (2) are all plain int constants on macOS; they are used as arguments to socket.shutdown(); no prior socket spec checks SHUT_RD/SHUT_WR/SHUT_RDWR class or value; first SHUT constant identity anchor for socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra84

  columns: [id, function, args, expected]
  rows:
    - [shut_rd_class_int,    SHUT_RD.__class__.__name__.__eq__,   ["int"], true]
    - [shut_wr_class_int,    SHUT_WR.__class__.__name__.__eq__,   ["int"], true]
    - [shut_rdwr_class_int,  SHUT_RDWR.__class__.__name__.__eq__, ["int"], true]
    - [shut_rdwr_eq_2,       SHUT_RDWR.__eq__,                    [2],     true]

# ---------------------------------------------------------------------------
# socket.SOL_TCP/__class__/__name__ / INADDR_ANY/__class__.__name__ (cross-check)
# socket.SHUT_RD/__eq__(0) / SHUT_WR/__eq__(1)
#
# Wave 250 theme: SOL_TCP class identity and SHUT_RD/SHUT_WR value cross-checks.
#
# SOL_TCP is a plain int on macOS (value 6, same as IPPROTO_TCP).
# SHUT_RD.__eq__(0) and SHUT_WR.__eq__(1) confirm their values.
# No prior socket spec checks SOL_TCP class or SHUT_RD/SHUT_WR values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra84.sol_tcp_and_shut_values:
  description: "socket.SOL_TCP/__class__/__name__.__eq__('int')==True / INADDR_ANY/__class__.__name__.__eq__('int')==True / SHUT_RD/__eq__(0)==True / SHUT_WR/__eq__(1)==True — SOL_TCP (value 6, same as IPPROTO_TCP) is a plain int; SHUT_RD value is 0 (shutdown receiving); SHUT_WR value is 1 (shutdown sending); no prior socket spec checks SOL_TCP class or SHUT_RD/SHUT_WR values; first SOL_TCP identity anchor and first SHUT_RD/SHUT_WR value anchor for socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra84

  columns: [id, function, args, expected]
  rows:
    - [sol_tcp_class_int,      SOL_TCP.__class__.__name__.__eq__,   ["int"], true]
    - [inaddr_any_class_int2,  INADDR_ANY.__class__.__name__.__eq__, ["int"], true]
    - [shut_rd_eq_0,           SHUT_RD.__eq__,                      [0],     true]
    - [shut_wr_eq_1,           SHUT_WR.__eq__,                      [1],     true]

# ---------------------------------------------------------------------------
# socket.INADDR_ANY.__class__.__name__.__eq__('int') — standalone
#
# INADDR_ANY.__class__.__name__ is 'int'. No prior socket spec checks
# INADDR_ANY.__class__.__name__. First __class__.__name__ standalone for
# socket.INADDR_ANY. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra84.inaddr_any_class_int:
  description: "socket.INADDR_ANY.__class__.__name__.__eq__('int') == True — INADDR_ANY (value 0) is a plain int constant used to bind to all network interfaces; no prior socket spec checks INADDR_ANY.__class__.__name__; first __class__.__name__ standalone for socket.INADDR_ANY"
  category: class_attrs
  kind: python_call_eq
  function: INADDR_ANY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.INADDR_LOOPBACK.__eq__(2130706433) — standalone
#
# INADDR_LOOPBACK.__eq__(2130706433) is True. No prior socket spec checks
# INADDR_LOOPBACK value. First value standalone for socket.INADDR_LOOPBACK.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra84.inaddr_loopback_eq:
  description: "socket.INADDR_LOOPBACK.__eq__(2130706433) == True — INADDR_LOOPBACK (0x7f000001 == 2130706433) is the loopback address 127.0.0.1; no prior socket spec checks INADDR_LOOPBACK value; first value standalone for socket.INADDR_LOOPBACK"
  category: class_attrs
  kind: python_call_eq
  function: INADDR_LOOPBACK.__eq__
  args: [2130706433]
  expected: true

# ---------------------------------------------------------------------------
# socket.SHUT_RDWR.__eq__(2) — standalone
#
# SHUT_RDWR.__eq__(2) is True. No prior socket spec checks SHUT_RDWR value.
# First value standalone for socket.SHUT_RDWR.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra84.shut_rdwr_eq_2:
  description: "socket.SHUT_RDWR.__eq__(2) == True — SHUT_RDWR value is 2 on macOS; it shuts down both reading and writing on a socket; no prior socket spec checks SHUT_RDWR value; first value standalone for socket.SHUT_RDWR"
  category: class_attrs
  kind: python_call_eq
  function: SHUT_RDWR.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_TCP.__class__.__name__.__eq__('int') — standalone
#
# SOL_TCP.__class__.__name__ is 'int'. No prior socket spec checks
# SOL_TCP.__class__.__name__. First __class__.__name__ standalone for
# socket.SOL_TCP. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra84.sol_tcp_class_int:
  description: "socket.SOL_TCP.__class__.__name__.__eq__('int') == True — SOL_TCP (value 6) is a plain int constant representing the TCP protocol level for setsockopt/getsockopt; no prior socket spec checks SOL_TCP.__class__.__name__; first __class__.__name__ standalone for socket.SOL_TCP"
  category: class_attrs
  kind: python_call_eq
  function: SOL_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.INADDR_NONE.__eq__(4294967295) — standalone
#
# INADDR_NONE.__eq__(4294967295) is True. No prior socket spec checks
# INADDR_NONE value. First value standalone for socket.INADDR_NONE.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra84.inaddr_none_eq:
  description: "socket.INADDR_NONE.__eq__(4294967295) == True — INADDR_NONE (0xffffffff == 4294967295) is returned by inet_addr() when the address is invalid; no prior socket spec checks INADDR_NONE value; first value standalone for socket.INADDR_NONE"
  category: class_attrs
  kind: python_call_eq
  function: INADDR_NONE.__eq__
  args: [4294967295]
  expected: true
