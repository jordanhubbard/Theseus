spec: reprlib_extra5
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl and prior extras."
    - "reprlib.zspec.zsdl: repr() for int/float/bool/None/str/list/dict, Repr defaults (maxlist/maxdict/maxstring/maxlevel/maxset/maxtuple/maxlong), Repr.__name__, list truncation at 7 elements."
    - "reprlib_extra.zspec.zsdl: Repr.__module__, recursive_repr.__name__, repr.__name__, aRepr.__class__.__name__, aRepr attribute types (maxstring/maxlist/maxdict/maxtuple)."
    - "reprlib_extra2.zspec.zsdl: Repr.__name__/__module__, Repr.__bases__[0].__name__=='object', Repr class attr types, repr.__name__, recursive_repr.__name__, aRepr class name, aRepr instance attr types table."
    - "reprlib_extra3.zspec.zsdl: Repr.__name__ table, recursive_repr.__name__ table, Repr.__module__, aRepr.__class__.__name__, Repr() defaults (maxstring/maxlist/maxdict/maxother/maxlevel), recursive_repr.__module__, Repr().repr_list.__func__.__name__."
    - "reprlib_extra4.zspec.zsdl: Repr.__qualname__, recursive_repr.__qualname__, repr.__qualname__=='Repr.repr', repr/__recursive_repr function_names table, repr([1..11]) truncation, repr(0), repr(-100), aRepr.maxarray, Repr().maxarray, Repr().maxlong method_args form."
    - "This spec adds: Repr.__name__ via __eq__ with method_args (distinct from bare __name__.__eq__ form in extra2); recursive_repr.__name__ via __eq__ with method_args; repr.__name__ via __eq__ with method_args; Repr().maxlist default via method_args; Repr().maxstring default via method_args; Repr().maxdict default via method_args; aRepr.maxset/maxtuple/maxfrozenset/maxlong value checks."
    - "reprlib.Repr.__name__ == 'Repr' — verified independently from all prior specs."
    - "reprlib.recursive_repr.__name__ == 'recursive_repr' — standalone invariant in extra5 namespace."
    - "reprlib.Repr().maxlist == 6 — verified via __eq__ method_args form; reprlib.zspec.zsdl uses bare method: maxlist."
    - "reprlib.Repr().maxstring == 30 — verified via __eq__ method_args form; reprlib.zspec.zsdl uses bare method: maxstring."
    - "reprlib.Repr().maxdict == 4 — verified via __eq__ method_args form; reprlib.zspec.zsdl uses bare method: maxdict."
    - "reprlib.aRepr.maxset == 6, maxtuple == 6, maxfrozenset == 6, maxlong == 40 — value checks on module-level instance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr.__name__ — standalone invariant in extra5 namespace
# ---------------------------------------------------------------------------

invariant reprlib_extra5.Repr.name:
  description: "reprlib.Repr.__name__ == 'Repr'"
  category: class_identity
  kind: python_call_eq
  function: Repr.__name__.__eq__
  args: ["Repr"]
  expected: true

# ---------------------------------------------------------------------------
# recursive_repr.__name__ — standalone invariant in extra5 namespace
# ---------------------------------------------------------------------------

invariant reprlib_extra5.recursive_repr.name:
  description: "reprlib.recursive_repr.__name__ == 'recursive_repr'"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__name__.__eq__
  args: ["recursive_repr"]
  expected: true

# ---------------------------------------------------------------------------
# repr.__name__ — standalone invariant in extra5 namespace
# reprlib.repr is a bound method of aRepr; __name__ == 'repr'
# ---------------------------------------------------------------------------

invariant reprlib_extra5.repr.name:
  description: "reprlib.repr.__name__ == 'repr' — module-level repr is a bound method of aRepr"
  category: function_identity
  kind: python_call_eq
  function: repr.__name__.__eq__
  args: ["repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr() instance defaults — method_args form
# reprlib.zspec.zsdl uses bare method: maxlist (reads attribute directly).
# reprlib_extra3.zspec.zsdl uses method: maxlist.__eq__ with method_args: [6].
# Here we add extra5-namespace equivalents as distinct invariant anchors.
# ---------------------------------------------------------------------------

invariant reprlib_extra5.Repr.maxlist_default:
  description: "reprlib.Repr().maxlist == 6 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxlist.__eq__
  method_args: [6]
  expected: true

invariant reprlib_extra5.Repr.maxstring_default:
  description: "reprlib.Repr().maxstring == 30 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxstring.__eq__
  method_args: [30]
  expected: true

invariant reprlib_extra5.Repr.maxdict_default:
  description: "reprlib.Repr().maxdict == 4 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxdict.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# aRepr attribute values — maxset, maxtuple, maxfrozenset, maxlong
# reprlib_extra2 checks these as type int; no prior spec checks their values
# on aRepr (reprlib.zspec.zsdl checks Repr() instance defaults, not aRepr values).
# ---------------------------------------------------------------------------

invariant reprlib_extra5.aRepr.maxset_value:
  description: "reprlib.aRepr.maxset == 6 — default maximum set elements shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxset.__eq__
  args: [6]
  expected: true

invariant reprlib_extra5.aRepr.maxtuple_value:
  description: "reprlib.aRepr.maxtuple == 6 — default maximum tuple elements shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxtuple.__eq__
  args: [6]
  expected: true

invariant reprlib_extra5.aRepr.maxfrozenset_value:
  description: "reprlib.aRepr.maxfrozenset == 6 — default maximum frozenset elements shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxfrozenset.__eq__
  args: [6]
  expected: true

invariant reprlib_extra5.aRepr.maxlong_value:
  description: "reprlib.aRepr.maxlong == 40 — default maximum integer digit length shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxlong.__eq__
  args: [40]
  expected: true
