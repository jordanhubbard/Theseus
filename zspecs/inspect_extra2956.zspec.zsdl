spec: in2956
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 644 (in2956): __invert__, __round__, __trunc__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define bitwise invert, round, or truncate operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in2956.invert:
  description: "inspect types __invert__ dict-presence checks; wave 644"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2956
  columns: [id, function, args, expected]
  rows:
    - ["in2956001", operator.contains, [inspect.Parameter.__dict__,       "__invert__"], false]
    - ["in2956002", operator.contains, [inspect.BoundArguments.__dict__,  "__invert__"], false]
    - ["in2956003", operator.contains, [inspect.Signature.__dict__,       "__invert__"], false]
    - ["in2956004", operator.contains, [inspect.FullArgSpec.__dict__,     "__invert__"], false]
    - ["in2956005", operator.contains, [inspect.FrameInfo.__dict__,       "__invert__"], false]
    - ["in2956006", operator.contains, [inspect.ArgInfo.__dict__,         "__invert__"], false]

