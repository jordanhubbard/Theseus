spec: colorama
version: ">=0.4"
backend: python_module(colorama)

docs: https://github.com/tartley/colorama#readme

provenance:
  derived_from:
    - "colorama README — https://github.com/tartley/colorama#readme"
    - "ANSI escape code reference — https://en.wikipedia.org/wiki/ANSI_escape_code"
    - "Test vectors verified with colorama 0.4.6 on Python 3 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "colorama source: colorama/ansi.py"
    - "colorama source: colorama/ansitowin32.py"
    - "colorama source: colorama/initialise.py"
    - "colorama source: colorama/win32.py"
  notes:
    - "colorama provides ANSI escape sequences for terminal colors on Windows and Unix."
    - "Fore, Back, and Style are classes with class-level string attributes (ANSI codes)."
    - "ESC = \\u001b (0x1B = 27); ANSI format is \\u001b[<code>m"
    - "Fore codes: 30-37 foreground colors, 39 reset foreground."
    - "Back codes: 40-47 background colors, 49 reset background."
    - "Style codes: 1=BRIGHT, 2=DIM, 22=NORMAL, 0=RESET_ALL."
    - "init() and deinit() configure Windows console wrapping; callable on all platforms."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ contains a dot; is a string
# ---------------------------------------------------------------------------

invariant colorama.version.contains_dot:
  description: "__version__ contains a dot (e.g. '0.4.6')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# fore — Fore foreground color constants
#
# ANSI foreground: ESC[31m = red, ESC[32m = green, ESC[34m = blue, ESC[39m = reset
# ---------------------------------------------------------------------------

invariant colorama.fore.red:
  description: "Fore.RED == ESC[31m"
  category: fore
  kind: python_call_eq
  function: Fore.RED.__eq__
  args: ["\u001b[31m"]
  expected: true

invariant colorama.fore.green:
  description: "Fore.GREEN == ESC[32m"
  category: fore
  kind: python_call_eq
  function: Fore.GREEN.__eq__
  args: ["\u001b[32m"]
  expected: true

invariant colorama.fore.blue:
  description: "Fore.BLUE == ESC[34m"
  category: fore
  kind: python_call_eq
  function: Fore.BLUE.__eq__
  args: ["\u001b[34m"]
  expected: true

invariant colorama.fore.reset:
  description: "Fore.RESET == ESC[39m"
  category: fore
  kind: python_call_eq
  function: Fore.RESET.__eq__
  args: ["\u001b[39m"]
  expected: true

# ---------------------------------------------------------------------------
# back — Back background color constants
#
# ANSI background: ESC[41m = red, ESC[42m = green, ESC[49m = reset
# ---------------------------------------------------------------------------

invariant colorama.back.red:
  description: "Back.RED == ESC[41m"
  category: back
  kind: python_call_eq
  function: Back.RED.__eq__
  args: ["\u001b[41m"]
  expected: true

invariant colorama.back.green:
  description: "Back.GREEN == ESC[42m"
  category: back
  kind: python_call_eq
  function: Back.GREEN.__eq__
  args: ["\u001b[42m"]
  expected: true

invariant colorama.back.reset:
  description: "Back.RESET == ESC[49m"
  category: back
  kind: python_call_eq
  function: Back.RESET.__eq__
  args: ["\u001b[49m"]
  expected: true

# ---------------------------------------------------------------------------
# style — Style text-attribute constants
#
# ANSI styles: ESC[1m = BRIGHT, ESC[2m = DIM, ESC[22m = NORMAL, ESC[0m = RESET_ALL
# ---------------------------------------------------------------------------

invariant colorama.style.bright:
  description: "Style.BRIGHT == ESC[1m"
  category: style
  kind: python_call_eq
  function: Style.BRIGHT.__eq__
  args: ["\u001b[1m"]
  expected: true

invariant colorama.style.dim:
  description: "Style.DIM == ESC[2m"
  category: style
  kind: python_call_eq
  function: Style.DIM.__eq__
  args: ["\u001b[2m"]
  expected: true

invariant colorama.style.normal:
  description: "Style.NORMAL == ESC[22m"
  category: style
  kind: python_call_eq
  function: Style.NORMAL.__eq__
  args: ["\u001b[22m"]
  expected: true

invariant colorama.style.reset_all:
  description: "Style.RESET_ALL == ESC[0m"
  category: style
  kind: python_call_eq
  function: Style.RESET_ALL.__eq__
  args: ["\u001b[0m"]
  expected: true
