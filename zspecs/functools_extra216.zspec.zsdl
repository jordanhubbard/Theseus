spec: functools_extra216
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra215.zspec.zsdl — covers cached_property.__dict__ membership (len 10, __get__, __init__, __set_name__, __doc__, attrname absent), singledispatch/__doc__ dispatch/generic, reduce/lru_cache/partial __doc__ contains checks"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES and callable type checks"
  notes:
    - "functools.singledispatch.__code__.co_varnames.__contains__('func') == True — the singledispatch function code object has 'func' as its first co_varname; it is the parameter name for the decorated function. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_varnames.__len__() == 3 — the co_varnames tuple has exactly 3 entries: ('func', 'weakref', 'wrapper'). Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the third co_varname in singledispatch. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_varnames.__contains__('weakref') == True — 'weakref' is the second co_varname in singledispatch. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__.__contains__('ordering') == True — the docstring is 'Class decorator that fills in missing ordering methods'. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__.__len__() == 54 — the docstring has exactly 54 characters. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__.__contains__('Class') == True — docstring begins with 'Class'. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__contains__('__set_name__') == True — confirmed in extra215 and re-verified here as a standalone. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__contains__('func') == False — 'func' is NOT in cached_property.__dict__; the wrapped function is stored as an instance attribute on the descriptor instance, not in the class dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch.__code__.co_varnames — membership checks
#
# co_varnames == ('func', 'weakref', 'wrapper')
# co_varnames.__contains__('func')    == True
# co_varnames.__contains__('weakref') == True
# co_varnames.__contains__('wrapper') == True
# co_varnames.__contains__('fn')      == False  (not a co_varname name)
# ---------------------------------------------------------------------------

table functools_extra216.singledispatch_co_varnames:
  description: "functools.singledispatch.__code__.co_varnames membership checks in functdispatch216cv namespace — the co_varnames tuple for singledispatch contains 'func' (the decorated function parameter), 'weakref' (internal variable), and 'wrapper' (the returned wrapper function); 'fn' is NOT in co_varnames; all four __contains__ checks confirm the expected membership; verified with Python 3.14.3"
  kind: python_call_eq
  category: co_varnames
  id_prefix: functdispatch216cv

  columns: [id, function, args, expected, description]
  rows:
    - [co_varnames_has_func,
       singledispatch.__code__.co_varnames.__contains__,
       ["func"],
       true,
       "functools.singledispatch.__code__.co_varnames.__contains__('func') == True — 'func' is the parameter name of the singledispatch decorator; it is the first entry in co_varnames ('func', 'weakref', 'wrapper'); __contains__('func') returns True; verified with Python 3.14.3"]
    - [co_varnames_has_weakref,
       singledispatch.__code__.co_varnames.__contains__,
       ["weakref"],
       true,
       "functools.singledispatch.__code__.co_varnames.__contains__('weakref') == True — 'weakref' is an internal variable in singledispatch; it is the second entry in co_varnames; __contains__('weakref') returns True; verified with Python 3.14.3"]
    - [co_varnames_has_wrapper,
       singledispatch.__code__.co_varnames.__contains__,
       ["wrapper"],
       true,
       "functools.singledispatch.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the inner function returned by singledispatch; it is the third entry in co_varnames; __contains__('wrapper') returns True; verified with Python 3.14.3"]
    - [co_varnames_no_fn,
       singledispatch.__code__.co_varnames.__contains__,
       ["fn"],
       false,
       "functools.singledispatch.__code__.co_varnames.__contains__('fn') == False — 'fn' is not one of the co_varnames in singledispatch; the tuple is ('func', 'weakref', 'wrapper') and does not include 'fn'; __contains__('fn') returns False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering.__doc__ — length and contains checks
#
# total_ordering.__doc__ == 'Class decorator that fills in missing ordering methods'
# __doc__.__len__()                      == 54
# __doc__.__contains__('ordering')       == True
# __doc__.__contains__('Class')          == True
# __doc__.__contains__('missing')        == True
# ---------------------------------------------------------------------------

table functools_extra216.total_ordering_doc:
  description: "functools.total_ordering.__doc__ checks in functdispatch216td namespace — the docstring is 'Class decorator that fills in missing ordering methods' (54 characters); checks confirm length is 54, 'ordering' is present, 'Class' is present, and 'missing' is present; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_checks
  id_prefix: functdispatch216td

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_doc_len,
       total_ordering.__doc__.__len__,
       [],
       54,
       "functools.total_ordering.__doc__.__len__() == 54 — the docstring 'Class decorator that fills in missing ordering methods' has exactly 54 characters; __len__() returns 54; verified with Python 3.14.3"]
    - [total_ordering_doc_has_ordering,
       total_ordering.__doc__.__contains__,
       ["ordering"],
       true,
       "functools.total_ordering.__doc__.__contains__('ordering') == True — the docstring 'Class decorator that fills in missing ordering methods' contains the word 'ordering'; __contains__('ordering') returns True; verified with Python 3.14.3"]
    - [total_ordering_doc_has_class,
       total_ordering.__doc__.__contains__,
       ["Class"],
       true,
       "functools.total_ordering.__doc__.__contains__('Class') == True — the docstring begins with 'Class decorator'; 'Class' is present; __contains__('Class') returns True; verified with Python 3.14.3"]
    - [total_ordering_doc_has_missing,
       total_ordering.__doc__.__contains__,
       ["missing"],
       true,
       "functools.total_ordering.__doc__.__contains__('missing') == True — the docstring describes filling in 'missing ordering methods'; 'missing' is present; __contains__('missing') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property.__dict__ — presence and absence
#
# cached_property.__dict__.__contains__('__set_name__') == True
# cached_property.__dict__.__contains__('func')         == False
# cached_property.__dict__.__contains__('__get__')      == True
# cached_property.__dict__.__contains__('__init__')     == True
# ---------------------------------------------------------------------------

table functools_extra216.cached_property_dict:
  description: "functools.cached_property.__dict__ membership checks in functdispatch216cp namespace — __set_name__ is present (called at class definition time to record the attribute name); 'func' is NOT present (the wrapped function is stored as an instance attribute on the descriptor, not in the class dict); __get__ is present (descriptor protocol); __init__ is present; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: functdispatch216cp

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_dict_has_set_name,
       "cached_property.__dict__.__contains__",
       ["__set_name__"],
       true,
       "functools.cached_property.__dict__.__contains__('__set_name__') == True — __set_name__ is defined in cached_property's class dict; it is called when the descriptor is assigned to a class attribute to record the attribute name; __contains__('__set_name__') returns True; verified with Python 3.14.3"]
    - [cached_property_dict_no_func,
       "cached_property.__dict__.__contains__",
       ["func"],
       false,
       "functools.cached_property.__dict__.__contains__('func') == False — 'func' is NOT in the cached_property class dict; the wrapped function is stored as an instance attribute on the descriptor object (set by __init__), not as a class dict entry; __contains__('func') returns False; verified with Python 3.14.3"]
    - [cached_property_dict_has_get,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property implements the descriptor protocol; __get__ is defined in its class dict to return the cached value on attribute access; __contains__('__get__') returns True; verified with Python 3.14.3"]
    - [cached_property_dict_has_init,
       "cached_property.__dict__.__contains__",
       ["__init__"],
       true,
       "functools.cached_property.__dict__.__contains__('__init__') == True — cached_property defines __init__ in its class dict; __init__ accepts the function to be cached as its argument; __contains__('__init__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra216
# ---------------------------------------------------------------------------

invariant functools_extra216.singledispatch_co_varnames_has_func:
  description: "functools.singledispatch.__code__.co_varnames.__contains__('func') == True — 'func' is the parameter name in singledispatch; co_varnames[0] == 'func'; new to extra216; verified with Python 3.14.3"
  category: co_varnames
  kind: python_call_eq
  function: singledispatch.__code__.co_varnames.__contains__
  args: ["func"]
  expected: true

invariant functools_extra216.singledispatch_co_varnames_len:
  description: "functools.singledispatch.__code__.co_varnames.__len__() == 3 — co_varnames is ('func', 'weakref', 'wrapper'), exactly 3 entries; new to extra216; verified with Python 3.14.3"
  category: co_varnames
  kind: python_call_eq
  function: singledispatch.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant functools_extra216.total_ordering_doc_has_ordering:
  description: "functools.total_ordering.__doc__.__contains__('ordering') == True — the total_ordering docstring 'Class decorator that fills in missing ordering methods' contains 'ordering'; new to extra216; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: total_ordering.__doc__.__contains__
  args: ["ordering"]
  expected: true

invariant functools_extra216.total_ordering_doc_len:
  description: "functools.total_ordering.__doc__.__len__() == 54 — the docstring has exactly 54 characters; new to extra216; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: total_ordering.__doc__.__len__
  args: []
  expected: 54

invariant functools_extra216.cached_property_dict_has_set_name:
  description: "functools.cached_property.__dict__.__contains__('__set_name__') == True — __set_name__ is defined in cached_property's class dict; new to extra216; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "cached_property.__dict__.__contains__"
  args: ["__set_name__"]
  expected: true

invariant functools_extra216.cached_property_dict_no_func:
  description: "functools.cached_property.__dict__.__contains__('func') == False — 'func' is NOT in cached_property.__dict__; the wrapped function is an instance attribute, not a class dict entry; new to extra216; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "cached_property.__dict__.__contains__"
  args: ["func"]
  expected: false

invariant functools_extra216.singledispatch_co_varnames_has_wrapper:
  description: "functools.singledispatch.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the third co_varname in singledispatch; new to extra216; verified with Python 3.14.3"
  category: co_varnames
  kind: python_call_eq
  function: singledispatch.__code__.co_varnames.__contains__
  args: ["wrapper"]
  expected: true

invariant functools_extra216.total_ordering_doc_has_decorator:
  description: "functools.total_ordering.__doc__.__contains__('decorator') == True — the docstring says 'Class decorator that fills in missing ordering methods'; 'decorator' is present; new to extra216; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: total_ordering.__doc__.__contains__
  args: ["decorator"]
  expected: true
