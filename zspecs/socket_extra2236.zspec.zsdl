  rows:
    - ["sk2236015", socket.timeout.__dict__.__contains__, ["__slots__"], false]
    - ["sk2236016", socket.timeout.__dict__.__contains__, ["__weakref__"], false]
    - ["sk2236017", socket.timeout.__dict__.__contains__, ["__init__"], false]
    - ["sk2236018", socket.timeout.__dict__.__contains__, ["__new__"], false]
    - ["sk2236019", socket.gaierror.__dict__.__contains__, ["__slots__"], false]
    - ["sk2236020", socket.gaierror.__dict__.__contains__, ["__weakref__"], true]
    - ["sk2236021", socket.gaierror.__dict__.__contains__, ["__init__"], false]
    - ["sk2236022", socket.gaierror.__dict__.__contains__, ["__new__"], false]

table socket_extra2236.enum_types_slots:
  description: "socket.AddressFamily and socket.SocketKind IntEnum types — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: sk2236
  columns: [id, function, args, expected]
  rows:
    - ["sk2236023", socket.AddressFamily.__dict__.__contains__, ["__slots__"], false]
    - ["sk2236024", socket.AddressFamily.__dict__.__contains__, ["__new__"], true]
    - ["sk2236025", socket.SocketKind.__dict__.__contains__, ["__slots__"], false]
