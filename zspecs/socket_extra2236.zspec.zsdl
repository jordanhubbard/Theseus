spec: socket_extra2236
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Theme: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in class __dict__."
    - "socket.socket is a pure-Python class that defines __slots__ = ['__weakref__', '_io_refs', '_closed']."
    - "__slots__ IS in socket.socket.__dict__ — the class explicitly declares it."
    - "__weakref__ IS in socket.socket.__dict__ — it appears as a named slot creating a weakref descriptor."
    - "__dict__ is NOT in socket.socket.__dict__ — __slots__ suppresses the instance __dict__ slot."
    - "__init__ IS in socket.socket.__dict__ — socket defines its own __init__."
    - "__new__ is NOT in socket.socket.__dict__ — socket does not override __new__."
    - "socket.error is an alias for OSError; socket.error.__name__ == 'OSError', __module__ == 'builtins'."
    - "socket.error defines __init__ and __new__ in its __dict__ (OSError defines both)."
    - "socket.timeout is an alias for TimeoutError; does NOT define __slots__, __weakref__, __init__, or __new__ in its own __dict__."
    - "socket.gaierror is a concrete subclass of OSError; its __dict__ contains __weakref__ but not __slots__, __init__, or __new__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; both have __new__ in their __dict__ from Enum metaclass."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table socket_extra2236.socket_slots:
  description: "socket.socket pure-Python class — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: sk2236
  columns: [id, function, args, expected]
  rows:
    - ["sk2236001", socket.socket.__dict__.__contains__, ["__slots__"], true]
    - ["sk2236002", socket.socket.__dict__.__contains__, ["__weakref__"], true]
    - ["sk2236003", socket.socket.__dict__.__contains__, ["__dict__"], false]
    - ["sk2236004", socket.socket.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["sk2236005", socket.socket.__dict__.__contains__, ["__init__"], true]
    - ["sk2236006", socket.socket.__dict__.__contains__, ["__new__"], false]
    - ["sk2236007", socket.socket.__dict__.__contains__, ["__subclasshook__"], false]

table socket_extra2236.error_slots:
  description: "socket.error (OSError alias) — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: sk2236
  columns: [id, function, args, expected]
  rows:
    - ["sk2236008", socket.error.__dict__.__contains__, ["__slots__"], false]
    - ["sk2236009", socket.error.__dict__.__contains__, ["__weakref__"], false]
    - ["sk2236010", socket.error.__dict__.__contains__, ["__dict__"], false]
    - ["sk2236011", socket.error.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["sk2236012", socket.error.__dict__.__contains__, ["__init__"], true]
    - ["sk2236013", socket.error.__dict__.__contains__, ["__new__"], true]
    - ["sk2236014", socket.error.__dict__.__contains__, ["__subclasshook__"], false]

table socket_extra2236.timeout_gaierror_slots:
