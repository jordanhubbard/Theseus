spec: asyncio_extra7
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio Exceptions"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio Event Loop"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/base_events.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl, asyncio_extra2.zspec.zsdl, asyncio_extra3.zspec.zsdl, asyncio_extra4.zspec.zsdl, asyncio_extra5.zspec.zsdl, asyncio_extra6.zspec.zsdl."
    - "asyncio_extra3 covers __qualname__ for Task/Future/Queue/Lock/Event/Semaphore/Condition/gather/sleep/create_task."
    - "asyncio_extra6 covers __qualname__ for Barrier/TaskGroup/Runner/timeout/BoundedSemaphore/Condition/QueueEmpty/QueueFull/to_thread/wait_for/wait/shield/run."
    - "asyncio_extra4 covers __module__ for CancelledError/TimeoutError."
    - "asyncio_extra2 covers __name__ for CancelledError/TimeoutError and __module__ for AbstractEventLoop/BaseEventLoop."
    - "asyncio_events covers __name__ for AbstractEventLoop/BaseEventLoop."
    - "This spec adds: __qualname__ for CancelledError, TimeoutError, BaseEventLoop, AbstractEventLoop — not covered in any prior asyncio spec."
    - "Also adds: __qualname__ for InvalidStateError and IncompleteReadError; __module__ for CancelledError via qualname attribute chain."
    - "asyncio.CancelledError.__qualname__ == 'CancelledError' — top-level exception class."
    - "asyncio.TimeoutError.__qualname__ == 'TimeoutError' — top-level exception class."
    - "asyncio.BaseEventLoop.__qualname__ == 'BaseEventLoop' — top-level abstract base class."
    - "asyncio.AbstractEventLoop.__qualname__ == 'AbstractEventLoop' — top-level ABC."
    - "asyncio.InvalidStateError.__qualname__ == 'InvalidStateError' — top-level exception class."
    - "asyncio.IncompleteReadError.__qualname__ == 'IncompleteReadError' — top-level exception class."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for asyncio exception classes
#
# asyncio_extra2 covers __name__ for CancelledError/TimeoutError.
# asyncio_extra4 covers __module__ for CancelledError/TimeoutError.
# asyncio_extra5 covers __name__ for TimeoutError (via invariant).
# This spec adds __qualname__ for these and related exceptions — a new
# dimension not yet covered in any prior asyncio spec.
# ---------------------------------------------------------------------------

table asyncio_extra7.exception_qualnames:
  kind: python_call_eq
  category: exception_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,       CancelledError.__qualname__.__eq__,       ["CancelledError"],       true]
    - [TimeoutError,         TimeoutError.__qualname__.__eq__,         ["TimeoutError"],         true]
    - [InvalidStateError,    InvalidStateError.__qualname__.__eq__,    ["InvalidStateError"],    true]
    - [IncompleteReadError,  IncompleteReadError.__qualname__.__eq__,  ["IncompleteReadError"],  true]

# ---------------------------------------------------------------------------
# __qualname__ for event loop abstract base classes
#
# asyncio_events covers __name__ for AbstractEventLoop/BaseEventLoop.
# asyncio_extra2 covers __name__ and __module__ for both.
# This spec adds __qualname__ — a new vector for both classes.
# ---------------------------------------------------------------------------

invariant asyncio_extra7.AbstractEventLoop.qualname:
  description: "asyncio.AbstractEventLoop.__qualname__ == 'AbstractEventLoop'"
  category: event_loop_qualnames
  kind: python_call_eq
  function: AbstractEventLoop.__qualname__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra7.BaseEventLoop.qualname:
  description: "asyncio.BaseEventLoop.__qualname__ == 'BaseEventLoop'"
  category: event_loop_qualnames
  kind: python_call_eq
  function: BaseEventLoop.__qualname__.__eq__
  args: ["BaseEventLoop"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for AbstractEventLoopPolicy
#
# asyncio_events covers __name__ for AbstractEventLoopPolicy.
# This spec adds the __qualname__ check — not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant asyncio_extra7.AbstractEventLoopPolicy.qualname:
  description: "asyncio.AbstractEventLoopPolicy.__qualname__ == 'AbstractEventLoopPolicy'"
  category: event_loop_qualnames
  kind: python_call_eq
  function: AbstractEventLoopPolicy.__qualname__.__eq__
  args: ["AbstractEventLoopPolicy"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError and InvalidStateError — __name__ checks
#
# asyncio.InvalidStateError and asyncio.IncompleteReadError have not had
# their __name__ checked individually in any prior asyncio spec.
# (asyncio_extra2 covers CancelledError/__name__ and TimeoutError/__name__.)
# ---------------------------------------------------------------------------

invariant asyncio_extra7.InvalidStateError.name:
  description: "asyncio.InvalidStateError.__name__ == 'InvalidStateError'"
  category: exception_names
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant asyncio_extra7.IncompleteReadError.name:
  description: "asyncio.IncompleteReadError.__name__ == 'IncompleteReadError'"
  category: exception_names
  kind: python_call_eq
  function: IncompleteReadError.__name__.__eq__
  args: ["IncompleteReadError"]
  expected: true

# ---------------------------------------------------------------------------
# ensure_future — __qualname__ check
#
# asyncio_extra4 covers ensure_future.__module__.
# No prior spec covers ensure_future.__qualname__.
# ---------------------------------------------------------------------------

invariant asyncio_extra7.ensure_future.qualname:
  description: "asyncio.ensure_future.__qualname__ == 'ensure_future'"
  category: function_qualnames
  kind: python_call_eq
  function: ensure_future.__qualname__.__eq__
  args: ["ensure_future"]
  expected: true
