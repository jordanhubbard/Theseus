spec: re_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - re module CPython source
    - Python standard library documentation for regular expression operations
  not_derived_from:
    - regex third-party library
    - re2 or other alternate regex engines
  notes:
    - Covers function qualname and module identity checks for top-level re functions
    - Verifies that module-level function metadata is consistent with the re namespace
  created_at: "2026-04-12"

table re_extra811.function_qualnames:
  description: re module function qualnames and module identities
  kind: python_call_eq
  category: function_metadata
  id_prefix: re811fq
  columns: [id, function, args, expected]
  rows:
    - [re811fq001, re.compile.__qualname__.__eq__, ["compile"], true]
    - [re811fq002, re.compile.__module__.__eq__, ["re"], true]
    - [re811fq003, re.match.__qualname__.__eq__, ["match"], true]
    - [re811fq004, re.match.__module__.__eq__, ["re"], true]
    - [re811fq005, re.search.__qualname__.__eq__, ["search"], true]
    - [re811fq006, re.search.__module__.__eq__, ["re"], true]
    - [re811fq007, re.fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [re811fq008, re.fullmatch.__module__.__eq__, ["re"], true]
    - [re811fq009, re.sub.__qualname__.__eq__, ["sub"], true]
    - [re811fq010, re.sub.__module__.__eq__, ["re"], true]
    - [re811fq011, re.split.__qualname__.__eq__, ["split"], true]
    - [re811fq012, re.findall.__qualname__.__eq__, ["findall"], true]
