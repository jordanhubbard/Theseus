invariant multiprocessing_extra126.Pool_map_varnames_len_4:
  description: "multiprocessing.pool.Pool.map.__code__.co_varnames.__len__() == 4 — Pool.map.__code__.co_varnames is ('self', 'func', 'iterable', 'chunksize'); the 4 entries exactly match the 4 positional parameters; there are no additional local variables beyond the positional params because map delegates immediately to map_async and waits for the result (using only parameter names in the function body); compare co_varnames lengths: map=4 (tied with apply=4 and starmap=4), imap=6 (adds 'result' and 'task_batches' locals), map_async=6 (tied with imap), apply_async=7; Pool.map.__code__.co_argcount is 4 (equals co_varnames len for map — all co_varnames are positional params); Pool.map.__qualname__ is 'Pool.map' (len=8); NEW in extra126: first standalone Pool.map co_varnames length invariant in mppoolvarnames126 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.map.__code__.co_varnames.__len__"
  args: []
  expected: 4

invariant multiprocessing_extra126.Pool_imap_varnames_len_6:
  description: "multiprocessing.pool.Pool.imap.__code__.co_varnames.__len__() == 6 — Pool.imap.__code__.co_varnames is ('self', 'func', 'iterable', 'chunksize', 'result', 'task_batches'); the 6 entries include 4 positional params plus 2 internal local variables; 'result' is the IMapIterator object created, and 'task_batches' holds the pre-chunked work items; imap lazily yields results in order (unlike map_async which collects all results first); imap.__code__.co_argcount is 4 (only the positional params are counted; 'result' and 'task_batches' are locals not counted in co_argcount); imap.__qualname__ is 'Pool.imap' (len=9: 'Pool.'=5+'imap'=4=9); compare: map=4 co_varnames (no locals), imap=6 (2 locals); NEW in extra126: first standalone Pool.imap co_varnames length invariant in mppoolvarnames126 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
