  expected: 6

invariant multiprocessing_extra126.Pool_map_var1_is_func:
  description: "multiprocessing.pool.Pool.map.__code__.co_varnames.__getitem__(1) == 'func' — Pool.map.__code__.co_varnames[1] is 'func' (the callable parameter); all four Pool mapping methods (map, apply, imap, starmap) use 'func' as their second co_varname[1]; this consistent naming contrasts with concurrent.futures.ThreadPoolExecutor.submit where co_varnames[1] is 'fn' (2 chars) and concurrent.futures.Future where co_varnames[1] is 'result', 'fn', or 'timeout' depending on the method; Pool.map.__code__.co_argcount is 4 and co_varnames.__len__() is 4 (all co_varnames are positional params for map); Pool.map.__qualname__ is 'Pool.map' (len=8); NEW in extra126: first standalone Pool.map co_varnames[1] invariant in mppoolvarnames126 namespace; wave 256; verified with Python 3.14.3"
