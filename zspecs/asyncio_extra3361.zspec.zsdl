    - ["as3361009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__invert__"], false]
    - ["as3361010", operator.contains, [asyncio.LifoQueue.__dict__,        "__invert__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# All 10 asyncio classes return false for __floor__.
# math.floor() delegates to __floor__ (numbers.Real protocol). asyncio types
#   define no numeric protocol — confirmed false across waves 658–670 for all
#   arithmetic, bitwise, reflected arithmetic, reflected bitwise, in-place
#   augmented assignment, and unary numeric operators.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no numeric rounding semantics; math.floor(primitive) is not
#   a defined Python expression for these types.
# asyncio.Task/Future: coroutine result handles; math.floor(task) and
#   math.floor(future) are not valid Python expressions. Results are obtained
#   via await or result(), not numeric rounding.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; math.floor(queue) is
#   not defined. Queue length is obtained via qsize(), not floor().
# ---------------------------------------------------------------------------

