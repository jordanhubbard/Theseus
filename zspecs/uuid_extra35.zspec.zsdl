spec: uuid_extra35
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra34.zspec.zsdl — covers UUID.time/node/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__eq__ string values."
    - "uuid_extra33.zspec.zsdl — covers UUID.__repr__/__hash__/__eq__/__int__ __qualname__.__eq__; UUID.hex.fget.__qualname__.__eq__('UUID.hex')."
    - "uuid_extra32.zspec.zsdl — covers UUID.__str__.__name__.__eq__('__str__') and UUID.__str__.__module__.__eq__('uuid')."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__le__/__gt__/__ge__ __qualname__.__eq__ and __qualname__.__len__()."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra34; it does NOT duplicate invariants present in those files."
    - "Coverage gap: uuid_extra32 covers UUID.__str__.__name__.__eq__('__str__') (the bare unqualified method name, __name__ axis). But NO prior spec checks UUID.__name__.__eq__ for any of the remaining UUID dunder methods: __init__, __repr__, __hash__, __eq__, __int__, __lt__, __le__, __gt__, __ge__. The __name__ attribute gives the bare unqualified name (e.g., '__repr__') while __qualname__ gives the class-prefixed form ('UUID.__repr__'). These are distinct attribute chains providing independent regression vectors. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__name__ == '__init__'. The bare unqualified name of the UUID constructor. uuid_extra16 covers __qualname__.__eq__('UUID.__init__') and uuid_extra21 covers __qualname__.__len__()==13. No prior spec checks __name__.__eq__('__init__') for UUID.__init__ (the __name__ axis, not __qualname__). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__name__ == '__repr__'. The bare unqualified name. uuid_extra16 covers __qualname__.__eq__('UUID.__repr__') and __qualname__.__len__()==13. No prior spec checks __name__.__eq__('__repr__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__name__ == '__hash__'. uuid_extra16 covers __qualname__.__eq__('UUID.__hash__') and __qualname__.__len__()==13. No prior spec checks __name__.__eq__('__hash__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__name__ == '__eq__'. uuid_extra16 covers __qualname__.__eq__('UUID.__eq__') and __qualname__.__len__()==11. No prior spec checks __name__.__eq__('__eq__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__name__ == '__int__'. uuid_extra16 covers __qualname__.__eq__('UUID.__int__') and __qualname__.__len__()==12. No prior spec checks __name__.__eq__('__int__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__name__ == '__lt__'. uuid_extra17 covers __qualname__.__eq__('UUID.__lt__') and __qualname__.__len__()==11. No prior spec checks __name__.__eq__('__lt__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__name__ == '__le__'. uuid_extra17 covers __qualname__.__eq__('UUID.__le__') and __qualname__.__len__()==11. No prior spec checks __name__.__eq__('__le__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__name__ == '__gt__'. uuid_extra17 covers __qualname__.__eq__('UUID.__gt__') and __qualname__.__len__()==11. No prior spec checks __name__.__eq__('__gt__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__name__ == '__ge__'. uuid_extra17 covers __qualname__.__eq__('UUID.__ge__') and __qualname__.__len__()==11. No prior spec checks __name__.__eq__('__ge__'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID dunder method __name__.__eq__ string values
#
# uuid_extra32 covers UUID.__str__.__name__.__eq__('__str__') (__name__ axis).
# uuid_extra16 covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__
#   __qualname__.__eq__ and __qualname__.__len__() (__qualname__ axis).
# uuid_extra17 covers UUID.__lt__/__le__/__gt__/__ge__ __qualname__.__eq__
#   and __qualname__.__len__() (__qualname__ axis).
# No prior spec checks __name__.__eq__ for any of:
#   UUID.__init__, UUID.__repr__, UUID.__hash__, UUID.__eq__, UUID.__int__,
#   UUID.__lt__, UUID.__le__, UUID.__gt__, UUID.__ge__.
# The __name__ attribute gives the bare unqualified name (e.g., '__repr__')
# while __qualname__ gives the class-prefixed form ('UUID.__repr__').
# These are distinct attribute chains and provide independent regression vectors.
# ---------------------------------------------------------------------------

table uuid_extra35.UUID_dunder_name_eq:
  description: "uuid.UUID dunder method __name__.__eq__ string values — novel: extra32 covers UUID.__str__.__name__.__eq__; extra16/17 cover __qualname__.__eq__ for these methods; no prior spec checks __name__.__eq__ (bare name, not class-prefixed) for UUID.__init__/__repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__"
  kind: python_call_eq
  category: function_names
  id_prefix: udne35

  columns: [id, function, args, expected]
  rows:
    - [init_name_eq, "UUID.__init__.__name__.__eq__", ["__init__"], true]
    - [repr_name_eq, "UUID.__repr__.__name__.__eq__", ["__repr__"], true]
    - [hash_name_eq, "UUID.__hash__.__name__.__eq__", ["__hash__"], true]
    - [eq_name_eq,   "UUID.__eq__.__name__.__eq__",   ["__eq__"],   true]
    - [int_name_eq,  "UUID.__int__.__name__.__eq__",  ["__int__"],  true]
    - [lt_name_eq,   "UUID.__lt__.__name__.__eq__",   ["__lt__"],   true]
    - [le_name_eq,   "UUID.__le__.__name__.__eq__",   ["__le__"],   true]
    - [gt_name_eq,   "UUID.__gt__.__name__.__eq__",   ["__gt__"],   true]
    - [ge_name_eq,   "UUID.__ge__.__name__.__eq__",   ["__ge__"],   true]
