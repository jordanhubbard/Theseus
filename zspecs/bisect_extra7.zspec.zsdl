spec: bisect_extra7
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras."
    - "bisect.zspec.zsdl covers: bisect_left/bisect_right tables on [1,3,5,7,9]; duplicates on [1,3,5,5,5,7]; bisect alias; lo/hi args; function __name__ identity."
    - "bisect_extra.zspec.zsdl covers: bisect_left/__name__/__module__=='_bisect'; bisect_right/__name__; insort_left/insort_right/__name__; bisect/__name__=='bisect_right'; insort/__name__=='insort_right'; behavioral on [1,2,3,4,5] and [1,2,3,3,3,4]."
    - "bisect_extra2.zspec.zsdl covers: insort/__name__; insort_left/__name__; insort_right/__name__; bisect/__name__; bisect_left([1,3,5,7], 4)==2."
    - "bisect_extra3.zspec.zsdl covers: __module__ for bisect/bisect_right/insort/insort_left/insort_right; __name__ for bisect_left/bisect_right/insort_left/insort_right; behavioral on [1,2,3,4,5]."
    - "bisect_extra4.zspec.zsdl covers: bisect module __name__; behavioral on [1,2,3,3,4] and [2,4,6,8,10]."
    - "bisect_extra5.zspec.zsdl covers: __qualname__ for all bisect functions; behavioral on [1,3,5,7] (multiple search values)."
    - "bisect_extra6.zspec.zsdl covers: __name__ table (id_prefix bname); module identity table; behavioral on [10,20,30,40,50]."
    - "This spec adds: __module__ standalone for bisect_left/bisect_right (extra7 namespace); __qualname__ standalone for bisect_left/bisect_right/insort_left/insort_right (extra7 namespace); behavioral on [5,10,15,20,25] (multiples of 5, not used in any prior spec)."
    - "bisect.bisect_left.__module__ == '_bisect' — C extension; covered in bisect_extra but not as standalone extra7 IDs."
    - "bisect.bisect_right.__module__ == '_bisect' — C extension; bisect_extra3 covers bisect/__module__, not bisect_right/__module__ standalone."
    - "bisect_left.__qualname__ == 'bisect_left' — bisect_extra5 covers in a combined table; extra7 adds standalone."
    - "bisect_right.__qualname__ == 'bisect_right' — bisect_extra5 covers in a combined table; extra7 adds standalone."
    - "insort_left.__qualname__ == 'insort_left' — bisect_extra5 covers in a combined table; extra7 adds standalone."
    - "insort_right.__qualname__ == 'insort_right' — bisect_extra5 covers in a combined table; extra7 adds standalone."
    - "bisect_left([5,10,15,20,25], 12) == 2 — 12 falls between 10 (index 1) and 15 (index 2)."
    - "bisect_right([5,10,15,20,25], 15) == 3 — 15 at index 2; right insertion point is 3."
    - "bisect_left([5,10,15,20,25], 15) == 2 — 15 at index 2; left insertion point is 2."
    - "bisect([5,10,15,20,25], 5) == 1 — 5 at index 0; bisect (alias bisect_right) returns 1."
    - "bisect_left([5,10,15,20,25], 25) == 4 — 25 at index 4; left insertion point is 4."
    - "bisect_right([5,10,15,20,25], 26) == 5 — 26 is after all elements."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ standalone invariants — extra7 namespace
# bisect_extra covers bisect_left.__module__; bisect_extra3 covers the module
# attrs for bisect/bisect_right/insort/insort_left/insort_right but NOT a
# standalone bisect_right.__module__ invariant.
# ---------------------------------------------------------------------------

invariant bisect_extra7.bisect_left.module:
  description: "bisect_left.__module__ == '_bisect' — C extension (extra7 namespace)"
  category: module_identity
  kind: python_call_eq
  function: bisect_left.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra7.bisect_right.module:
  description: "bisect_right.__module__ == '_bisect' — C extension (extra7 namespace)"
  category: module_identity
  kind: python_call_eq
  function: bisect_right.__module__.__eq__
  args: ["_bisect"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ standalone invariants — extra7 namespace
# bisect_extra5 covers all six qualnames in a combined table (id_prefix qualname).
# This spec adds standalone invariants with extra7 IDs for individual traceability.
# ---------------------------------------------------------------------------

invariant bisect_extra7.bisect_left.qualname:
  description: "bisect_left.__qualname__ == 'bisect_left'"
  category: function_qualnames
  kind: python_call_eq
  function: bisect_left.__qualname__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect_extra7.bisect_right.qualname:
  description: "bisect_right.__qualname__ == 'bisect_right'"
  category: function_qualnames
  kind: python_call_eq
  function: bisect_right.__qualname__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra7.insort_left.qualname:
  description: "insort_left.__qualname__ == 'insort_left'"
  category: function_qualnames
  kind: python_call_eq
  function: insort_left.__qualname__.__eq__
  args: ["insort_left"]
  expected: true

invariant bisect_extra7.insort_right.qualname:
  description: "insort_right.__qualname__ == 'insort_right'"
  category: function_qualnames
  kind: python_call_eq
  function: insort_right.__qualname__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — [5, 10, 15, 20, 25] (multiples of 5)
#
# This input is distinct from all prior spec inputs:
#   bisect        uses [1,3,5,7,9] and [1,3,5,5,5,7]
#   bisect_extra  uses [1,2,3,4,5] and [1,2,3,3,3,4]
#   bisect_extra2 uses [1,3,5,7] (single value)
#   bisect_extra3 uses [1,2,3,4,5]
#   bisect_extra4 uses [1,2,3,3,4] and [2,4,6,8,10]
#   bisect_extra5 uses [1,3,5,7] (multiple values)
#   bisect_extra6 uses [10,20,30,40,50]
# ---------------------------------------------------------------------------

invariant bisect_extra7.bisect_left.fives_gap:
  description: "bisect_left([5,10,15,20,25], 12) == 2 — 12 falls between 10 and 15"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[5, 10, 15, 20, 25], 12]
  expected: 2

invariant bisect_extra7.bisect_right.fives_gap:
  description: "bisect_right([5,10,15,20,25], 12) == 2 — 12 absent; left and right agree"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[5, 10, 15, 20, 25], 12]
  expected: 2

invariant bisect_extra7.bisect_left.fives_present_fifteen:
  description: "bisect_left([5,10,15,20,25], 15) == 2 — 15 at index 2; left insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[5, 10, 15, 20, 25], 15]
  expected: 2

invariant bisect_extra7.bisect_right.fives_present_fifteen:
  description: "bisect_right([5,10,15,20,25], 15) == 3 — 15 at index 2; right insertion point is 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[5, 10, 15, 20, 25], 15]
  expected: 3

invariant bisect_extra7.bisect.fives_first:
  description: "bisect([5,10,15,20,25], 5) == 1 — 5 at index 0; bisect (alias bisect_right) returns 1"
  category: behavior
  kind: python_call_eq
  function: bisect
  args: [[5, 10, 15, 20, 25], 5]
  expected: 1

invariant bisect_extra7.bisect_left.fives_last:
  description: "bisect_left([5,10,15,20,25], 25) == 4 — 25 at index 4; left insertion point is 4"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[5, 10, 15, 20, 25], 25]
  expected: 4

invariant bisect_extra7.bisect_right.fives_after_all:
  description: "bisect_right([5,10,15,20,25], 26) == 5 — 26 is after all elements"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[5, 10, 15, 20, 25], 26]
  expected: 5
