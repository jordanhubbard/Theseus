    - ["sk2356005", "socket.gaierror.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["sk2356006", "socket.timeout.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

