spec: socket_extra2356
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket is a pure-Python subclass of C type _socket.socket; socket.__init__.__class__.__name__ == 'function' (Python defines custom __init__)."
    - "socket.socket.__new__.__class__.__name__ == 'builtin_function_or_method' (inherits from C base type)."
    - "socket.error (OSError), socket.herror, socket.gaierror, socket.timeout — all pure-Python exception aliases; __init__.__class__.__name__ == 'wrapper_descriptor' (inherited from BaseException C __init__)."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; __init__.__class__.__name__ == 'wrapper_descriptor' (from int/Enum C layer)."
    - "socket.AddressFamily.__new__.__class__.__name__ == 'function' and socket.SocketKind.__new__.__class__.__name__ == 'function' (Enum meta defines a Python __new__)."
    - "socket.herror.__new__, socket.gaierror.__new__, socket.timeout.__new__ — all 'builtin_function_or_method' (inherited from object)."
    - "socket.create_connection and socket.getfqdn are pure-Python functions: __class__.__name__ == 'function'."
    - "socket.gethostname, socket.inet_aton, socket.inet_ntoa, socket.setdefaulttimeout — C builtins: __class__.__name__ == 'builtin_function_or_method'."
    - "The key distinction for socket.socket: Python subclasses of C types that define their own __init__ in Python yield 'function', not 'wrapper_descriptor'."
  created_at: "2026-04-12"

table socket_extra2356.socket_class_init_type:
  description: "socket.socket is a Python subclass of a C type with a custom Python __init__ — classified as 'function'"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: sk2356
  columns: [id, function, args, expected]
  rows:
    - ["sk2356001", "socket.socket.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["sk2356002", "socket.socket.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table socket_extra2356.exception_classes_init_type:
  description: "socket exception subclasses inherit BaseException C __init__ — all are wrapper_descriptor"
  kind: python_call_eq
