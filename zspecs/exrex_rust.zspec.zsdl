spec: exrex_rust
version: ">=3.9"
backend: rust_module(exrex_rust)

docs: https://github.com/asciimoo/exrex

provenance:
  derived_from:
    - "https://github.com/asciimoo/exrex — exrex documentation"
  not_derived_from:
    - "exrex source: exrex.py"
  notes:
    - "exrex generates all matching strings for a given regular expression."
    - "exrex.generate('[01]') yields '0', '1'."
    - "exrex.generate('a[bc]') yields 'ab', 'ac'."
    - "exrex.count('[01]') == 2."
    - "exrex.count('a[bc]') == 2."
    - "exrex.count('[0-9]') == 10."
    - "exrex.getone('[01]') returns '0' or '1' (one valid string)."
    - "Expose exrex_count(pattern) -> int: exrex.count(pattern)."
    - "Expose exrex_list(pattern) -> list: list(exrex.generate(pattern))."
    - "Expose exrex_getone_matches(pattern) -> bool: re.match(pattern, exrex.getone(pattern)) is not None."
    - "All test vectors verified against exrex 0.10.5."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# exrex_count — count matching strings
table exrex_rust.count.vectors:
  kind: python_call_eq
  category: count
  id_prefix: ex_cnt
  function: exrex_count

  columns: [id, args, expected]
  rows:
    - [binary,  ["[01]"],    2]
    - [ab,      ["a[bc]"],   2]
    - [digits,  ["[0-9]"],   10]

# exrex_list — enumerate all matches
table exrex_rust.list.vectors:
  kind: python_call_eq
  category: list
  id_prefix: ex_list
  function: exrex_list

  columns: [id, args, expected]
  rows:
    - [binary,  ["[01]"],  ["0", "1"]]
    - [ab,      ["a[bc]"], ["ab", "ac"]]

# exrex_getone_matches — generated string matches the pattern
invariant exrex_rust.getone.binary_matches:
  description: "exrex.getone('[01]') matches '[01]'"
  category: getone
  kind: python_call_eq
  function: exrex_getone_matches
  args: ["[01]"]
  expected: true

invariant exrex_rust.getone.digit_matches:
  description: "exrex.getone('[0-9]') matches '[0-9]'"
  category: getone
  kind: python_call_eq
  function: exrex_getone_matches
  args: ["[0-9]"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:54:30Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
