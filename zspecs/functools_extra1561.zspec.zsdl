spec: functools_extra1561
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 551 theme: numeric type conversion protocol dict-presence checks via __dict__.__contains__ for functools classes."
    - "functools.partial.__dict__.__contains__ returns False for all numeric dunder methods. partial is a C extension type; it is a callable wrapper, not a numeric type, and defines no numeric conversion protocol methods. Verified with Python 3.14."
    - "functools.cached_property.__dict__.__contains__ returns False for all numeric dunder methods. cached_property is a Python descriptor class defined in Lib/functools.py; it defines no numeric conversion operators. Verified with Python 3.14."
    - "functools.partialmethod.__dict__.__contains__ returns False for all numeric dunder methods. partialmethod is a Python descriptor class; numeric type conversion protocol is not applicable. Verified with Python 3.14."
    - "Numeric dunders checked: __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — numeric type conversion protocol dict-presence checks
#
# Wave 551 theme: partial is a C extension type (Modules/_functoolsmodule.c).
# Its own __dict__ does not contain any numeric conversion dunder methods.
# partial wraps callables; it is not a numeric type and has no conversion semantics.
# ---------------------------------------------------------------------------

table functools_extra1561.partial_numeric_dict_contains:
  description: "functools.partial.__dict__.__contains__ returns False for all numeric type conversion dunders; wave 551; new to extra1561"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1561pa

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1561pa001",
       "partial.__dict__.__contains__",
       ["__bool__"],
       false,
       "functools.partial.__dict__.__contains__('__bool__') == False — partial is a C extension type; its __dict__ does not define __bool__; wave 551; new to extra1561"]
    - ["fu1561pa002",
       "partial.__dict__.__contains__",
       ["__int__"],
       false,
       "functools.partial.__dict__.__contains__('__int__') == False — partial does not define __int__ in its own class __dict__; wave 551; new to extra1561"]
    - ["fu1561pa003",
       "partial.__dict__.__contains__",
       ["__float__"],
       false,
       "functools.partial.__dict__.__contains__('__float__') == False — partial does not define __float__ in its own class __dict__; wave 551; new to extra1561"]
    - ["fu1561pa004",
       "partial.__dict__.__contains__",
       ["__complex__"],
       false,
       "functools.partial.__dict__.__contains__('__complex__') == False — partial does not define __complex__ in its own class __dict__; wave 551; new to extra1561"]
    - ["fu1561pa005",
       "partial.__dict__.__contains__",
       ["__index__"],
       false,
       "functools.partial.__dict__.__contains__('__index__') == False — partial does not define __index__ in its own class __dict__; wave 551; new to extra1561"]
    - ["fu1561pa006",
       "partial.__dict__.__contains__",
       ["__trunc__"],
       false,
       "functools.partial.__dict__.__contains__('__trunc__') == False — partial does not define __trunc__ in its own class __dict__; wave 551; new to extra1561"]
    - ["fu1561pa007",
       "partial.__dict__.__contains__",
       ["__floor__"],
       false,
       "functools.partial.__dict__.__contains__('__floor__') == False — partial does not define __floor__ in its own class __dict__; wave 551; new to extra1561"]
    - ["fu1561pa008",
       "partial.__dict__.__contains__",
