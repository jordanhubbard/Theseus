spec: functools_extra134
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial method slot qualnames and __class__.__name__ for __init__, __call__, __reduce__, __setstate__, __repr__, __new__ (Wave 261)."
    - "functools.partial.__init__.__qualname__ == 'object.__init__' (len 15) — partial.__init__ is inherited from object; the qualname reflects the defining class. Verified with Python 3.14.3."
    - "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ accessed on the C extension type is a wrapper_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16) — __call__ is defined directly on the partial C type. Verified with Python 3.14.3."
    - "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18) — __reduce__ is defined on partial as a method_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__qualname__ == 'partial.__setstate__' (len 20). Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16). Verified with Python 3.14.3."
    - "functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15) — __new__ on C extension types is a builtin_function_or_method. Verified with Python 3.14.3."
    - "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial'; functools.partial.__module__ == 'functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial.__init__ and __call__ slot qualnames and class names
#
# Wave 261 theme: functools.partial slot qualnames for __init__ and __call__.
#
# functools.partial.__init__.__qualname__.__eq__('object.__init__') == True
# functools.partial.__init__.__qualname__.__len__() == 15
# functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True
# functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True
# functools.partial.__call__.__qualname__.__len__() == 16
# functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True
#
# partial is a C extension type (Modules/_functoolsmodule.c).
# __init__ is inherited from object (qualname prefix is 'object');
# __call__ is defined on partial itself (qualname prefix is 'partial').
# New to extra134.
# ---------------------------------------------------------------------------

table functools_extra134.partial_init_call_qualnames:
  description: "functools.partial.__init__ qualname=='object.__init__' (len 15), class 'wrapper_descriptor'; __call__ qualname=='partial.__call__' (len 16), class 'wrapper_descriptor'; wave 261; new to extra134"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial134

  columns: [id, function, args, expected, description]
  rows:
    - [partial_init_qualname_eq,
       "partial.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "functools.partial.__init__.__qualname__.__eq__('object.__init__') == True — partial is a C extension type; its __init__ slot is inherited from object; when accessed on partial, the __qualname__ of the wrapper_descriptor reflects the defining class 'object', giving 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra134"]
    - [partial_init_qualname_len_eq_15,
       "partial.__init__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__init__.__qualname__.__len__() == 15 — __qualname__ is 'object.__init__' which has 15 characters; len('object.__init__') == 15; new to extra134"]
    - [partial_init_class_name_eq_wrapper_descriptor,
       "partial.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — __init__ accessed on the C extension type is a wrapper_descriptor (CPython internal type for C-level tp_init slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra134"]
    - [partial_call_qualname_eq,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — __call__ is defined directly on the partial C extension type in _functoolsmodule.c; its __qualname__ has the defining type as prefix, giving 'partial.__call__'; str.__eq__('partial.__call__') returns True; new to extra134"]
    - [partial_call_qualname_len_eq_16,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__call__' which has 16 characters; len('partial.__call__') == 16; new to extra134"]
    - [partial_call_class_name_eq_wrapper_descriptor,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — __call__ accessed on the C extension type is a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra134"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial.__reduce__ and __setstate__ slot qualnames
#
# Wave 261 theme: functools.partial.__reduce__ and __setstate__ method_descriptor qualnames.
#
# functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True
# functools.partial.__reduce__.__qualname__.__len__() == 18
# functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True
# functools.partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True
# functools.partial.__setstate__.__qualname__.__len__() == 20
# functools.partial.__setstate__.__class__.__name__.__eq__('method_descriptor') == True
#
# __reduce__ and __setstate__ are defined on partial as method_descriptors
# (unlike __call__ and __init__ which are wrapper_descriptors).
# New to extra134.
# ---------------------------------------------------------------------------

