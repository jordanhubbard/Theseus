    - [partial_setstate_qualname_len_eq_20,
       "partial.__setstate__.__qualname__.__len__",
       [],
       20,
       "functools.partial.__setstate__.__qualname__.__len__() == 20 — __qualname__ is 'partial.__setstate__' which has 20 characters; len('partial.__setstate__') == 20; new to extra134"]
    - [partial_setstate_class_name_eq_method_descriptor,
       "partial.__setstate__.__class__.__name__.__eq__",
