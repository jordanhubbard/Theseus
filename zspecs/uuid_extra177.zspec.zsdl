table uuid_extra177.namespace_str_values:
  description: "uuid namespace constant __str__ values (RFC 4122 canonical forms); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: uuidnamespace177

  columns: [id, function, args, expected, description]
  rows:
    - [dns_str_eq,
