spec: uuid_extra177
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.NAMESPACE_DNS  == UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 DNS namespace."
    - "uuid.NAMESPACE_URL  == UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 URL namespace."
    - "uuid.NAMESPACE_OID  == UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 OID namespace."
    - "uuid.NAMESPACE_X500 == UUID('6ba7b814-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 X.500 namespace."
    - "All four namespace UUIDs are version 1 (time-based), as defined by RFC 4122."
    - "All four namespace constants have __class__.__name__ == 'UUID'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid namespace constant __class__.__name__ values
#
# uuid.NAMESPACE_DNS.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_URL.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_OID.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'
#
# All four RFC 4122 namespace constants are instances of uuid.UUID.
# ---------------------------------------------------------------------------

table uuid_extra177.namespace_class_names:
  description: "uuid namespace constant __class__.__name__ values; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: uuidnamespace177

  columns: [id, function, args, expected, description]
  rows:
    - [dns_class_eq,
       uuid.NAMESPACE_DNS.__class__.__name__.__eq__,
       ["UUID"],
       true,
       "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a UUID instance; new to extra177"]
    - [url_class_eq,
       uuid.NAMESPACE_URL.__class__.__name__.__eq__,
       ["UUID"],
       true,
       "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — NAMESPACE_URL is a UUID instance; new to extra177"]
    - [oid_class_eq,
       uuid.NAMESPACE_OID.__class__.__name__.__eq__,
       ["UUID"],
       true,
       "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') == True — NAMESPACE_OID is a UUID instance; new to extra177"]
    - [x500_class_eq,
       uuid.NAMESPACE_X500.__class__.__name__.__eq__,
       ["UUID"],
       true,
       "uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID') == True — NAMESPACE_X500 is a UUID instance; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: uuid namespace constant version values
#
# uuid.NAMESPACE_DNS.version  == 1
# uuid.NAMESPACE_URL.version  == 1
# uuid.NAMESPACE_OID.version  == 1
# uuid.NAMESPACE_X500.version == 1
#
# All four RFC 4122 namespace UUIDs are version 1 (time-based).
# ---------------------------------------------------------------------------

table uuid_extra177.namespace_versions:
  description: "uuid namespace constant .version values; all are version 1; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: uuidnamespace177

  columns: [id, function, args, expected, description]
  rows:
    - [dns_version_eq,
       uuid.NAMESPACE_DNS.version.__eq__,
       [1],
       true,
       "uuid.NAMESPACE_DNS.version.__eq__(1) == True — NAMESPACE_DNS is a version-1 UUID; new to extra177"]
    - [url_version_eq,
       uuid.NAMESPACE_URL.version.__eq__,
       [1],
       true,
       "uuid.NAMESPACE_URL.version.__eq__(1) == True — NAMESPACE_URL is a version-1 UUID; new to extra177"]
    - [oid_version_eq,
       uuid.NAMESPACE_OID.version.__eq__,
       [1],
       true,
       "uuid.NAMESPACE_OID.version.__eq__(1) == True — NAMESPACE_OID is a version-1 UUID; new to extra177"]
    - [x500_version_eq,
       uuid.NAMESPACE_X500.version.__eq__,
       [1],
       true,
       "uuid.NAMESPACE_X500.version.__eq__(1) == True — NAMESPACE_X500 is a version-1 UUID; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: uuid namespace constant string representations
#
# str(uuid.NAMESPACE_DNS)  == '6ba7b810-9dad-11d1-80b4-00c04fd430c8'
# str(uuid.NAMESPACE_URL)  == '6ba7b811-9dad-11d1-80b4-00c04fd430c8'
