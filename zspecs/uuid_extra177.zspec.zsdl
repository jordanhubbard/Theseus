       [],
       "6ba7b810-9dad-11d1-80b4-00c04fd430c8",
       "uuid.NAMESPACE_DNS.__str__() == '6ba7b810-9dad-11d1-80b4-00c04fd430c8' — RFC 4122 DNS namespace UUID; new to extra177"]
    - [url_str_eq,
       uuid.NAMESPACE_URL.__str__,
       [],
       "6ba7b811-9dad-11d1-80b4-00c04fd430c8",
       "uuid.NAMESPACE_URL.__str__() == '6ba7b811-9dad-11d1-80b4-00c04fd430c8' — RFC 4122 URL namespace UUID; new to extra177"]
    - [oid_str_eq,
       uuid.NAMESPACE_OID.__str__,
       [],
       "6ba7b812-9dad-11d1-80b4-00c04fd430c8",
       "uuid.NAMESPACE_OID.__str__() == '6ba7b812-9dad-11d1-80b4-00c04fd430c8' — RFC 4122 OID namespace UUID; new to extra177"]
    - [x500_str_eq,
