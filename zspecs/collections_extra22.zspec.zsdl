spec: collections_extra22
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra21.zspec.zsdl."
    - "collections_extra21 covers: deque([1,2,3]).__len__()==3; deque.__bases__[0].__name__=='object'; Counter('aabbc') key counts; OrderedDict.__bases__[0].__name__=='dict'; __qualname__.__eq__ table for five classes."
    - "collections_extra20 covers: __qualname__.__len__ and __module__.__len__ for ChainMap/Counter/UserDict/UserList/UserString."
    - "No prior collections spec records __name__.__eq__ for OrderedDict/defaultdict/Counter/deque/ChainMap/UserDict/UserList/UserString in the extra22 namespace."
    - "All eight collections classes have __name__ equal to their simple class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__eq__ table — all eight collections classes
#
# Verifies that each class's __name__ attribute equals its simple string name.
# collections_extra21 covers __qualname__.__eq__ for five classes.
# No prior spec records __name__.__eq__ for all eight classes together in
# the extra22 namespace.
# ---------------------------------------------------------------------------

table collections_extra22.names:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra22.names.OrderedDict,
       OrderedDict.__name__.__eq__,
       ["OrderedDict"],
       true,
       "collections.OrderedDict.__name__ == 'OrderedDict'"]
    - [collections_extra22.names.defaultdict,
       defaultdict.__name__.__eq__,
       ["defaultdict"],
       true,
       "collections.defaultdict.__name__ == 'defaultdict'"]
    - [collections_extra22.names.Counter,
       Counter.__name__.__eq__,
       ["Counter"],
       true,
       "collections.Counter.__name__ == 'Counter'"]
    - [collections_extra22.names.deque,
       deque.__name__.__eq__,
       ["deque"],
       true,
       "collections.deque.__name__ == 'deque'"]
    - [collections_extra22.names.ChainMap,
       ChainMap.__name__.__eq__,
       ["ChainMap"],
       true,
       "collections.ChainMap.__name__ == 'ChainMap'"]
    - [collections_extra22.names.UserDict,
       UserDict.__name__.__eq__,
       ["UserDict"],
       true,
       "collections.UserDict.__name__ == 'UserDict'"]
    - [collections_extra22.names.UserList,
       UserList.__name__.__eq__,
       ["UserList"],
       true,
       "collections.UserList.__name__ == 'UserList'"]
    - [collections_extra22.names.UserString,
       UserString.__name__.__eq__,
       ["UserString"],
       true,
       "collections.UserString.__name__ == 'UserString'"]

# ---------------------------------------------------------------------------
# defaultdict behavioral: missing key returns default, not KeyError
#
# defaultdict(int) returns 0 for any missing key via __missing__.
# __getitem__ on a missing key triggers __missing__ and returns the default.
# No prior collections spec records defaultdict(int).__getitem__('x')==0
# in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra22.defaultdict.missing_int_default:
  description: "collections.defaultdict(int).__getitem__('x') == 0 — missing key returns int() default"
  category: behavioral
  kind: python_call_eq
  function: defaultdict
  args: [int]
  method: __getitem__
  method_args: ["x"]
  expected: 0

# ---------------------------------------------------------------------------
# UserDict behavioral: wrapping a plain dict
#
# UserDict({'a': 1}) wraps the mapping and exposes it via .data.
# UserDict.__len__() reflects the number of items in the underlying dict.
# No prior collections spec records UserDict({'a':1}).__len__()==1
# in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra22.UserDict.len_one:
  description: "collections.UserDict({'a': 1}).__len__() == 1 — UserDict wrapping single-item dict has length 1"
  category: behavioral
  kind: python_call_eq
  function: UserDict
  args: [{"a": 1}]
  method: __len__
  expected: 1

# ---------------------------------------------------------------------------
# UserList behavioral: wrapping a plain list
#
# UserList([10, 20, 30]) wraps the list and supports standard sequence ops.
# __len__() reflects the number of elements.
# No prior collections spec records UserList([10,20,30]).__len__()==3
# in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra22.UserList.len_three:
  description: "collections.UserList([10, 20, 30]).__len__() == 3 — UserList wrapping three-element list has length 3"
  category: behavioral
  kind: python_call_eq
  function: UserList
  args: [[10, 20, 30]]
  method: __len__
  expected: 3
