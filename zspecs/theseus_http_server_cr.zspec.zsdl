spec: theseus_http_server_cr
version: ">=3.8"
backend: python_cleanroom(theseus_http_server_cr)
blocks: http.server

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.server.html"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
  notes:
    - "Clean-room http.server module. Do NOT import http.server."

error_model: python_exceptions

invariant theseus_http_server_cr.http_server2_responses:
  description: "responses dict has entries for common status codes"
  category: constants
  kind: python_call_eq
  function: http_server2_responses
  args: []
  expected: true

invariant theseus_http_server_cr.http_server2_handler_exists:
  description: "BaseHTTPRequestHandler class exists and is a type"
  category: presence
  kind: python_call_eq
  function: http_server2_handler_exists
  args: []
  expected: true

invariant theseus_http_server_cr.http_server2_parse_request:
  description: "parse_request_line splits HTTP request correctly"
  category: behavior
  kind: python_call_eq
  function: http_server2_parse_request
  args: []
  expected: true
