spec: copyreg_extra3
version: ">=3.9"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copyreg.html — Python copyreg module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
  notes:
    - "This spec extends copyreg.zspec.zsdl, copyreg_extra.zspec.zsdl, and copyreg_extra2.zspec.zsdl."
    - "copyreg covers: dispatch_table type check; pickle/__name__/__module__; constructor/add_extension/remove_extension/clear_extension_cache __name__."
    - "copyreg_extra covers: dispatch_table is dict; pickle/constructor/add_extension/remove_extension/clear_extension_cache __name__; __newobj__/__newobj_ex__ __name__."
    - "copyreg_extra2 covers: pickle/add_extension/remove_extension/clear_extension_cache __name__ and __module__; pickle/add_extension/remove_extension/clear_extension_cache __class__.__name__ == 'function'; dispatch_table is_dict and class_is_type."
    - "This spec adds: __qualname__ checks for pickle, constructor, add_extension, remove_extension, clear_extension_cache, __newobj__, __newobj_ex__ — not covered in any prior copyreg spec."
    - "For module-level Python functions, __qualname__ == __name__."
    - "copyreg.pickle.__qualname__ == 'pickle' — top-level function, no enclosing class or function."
    - "copyreg.constructor.__qualname__ == 'constructor' — top-level function."
    - "copyreg.add_extension.__qualname__ == 'add_extension' — top-level function."
    - "copyreg.remove_extension.__qualname__ == 'remove_extension' — top-level function."
    - "copyreg.clear_extension_cache.__qualname__ == 'clear_extension_cache' — top-level function."
    - "copyreg.__newobj__.__qualname__ == '__newobj__' — top-level function used by pickle protocol 2+."
    - "copyreg.__newobj_ex__.__qualname__ == '__newobj_ex__' — top-level function used by pickle protocol 4+."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — all public copyreg functions
# __qualname__ == __name__ for top-level (non-nested) Python functions.
# copyreg_extra/__extra2 cover only __name__ and __module__; __qualname__ is new.
# ---------------------------------------------------------------------------

table copyreg_extra3.qualname_checks:
  kind: python_call_eq
  category: qualname
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [pickle,               pickle.__qualname__.__eq__,               ["pickle"],               true]
    - [constructor,          constructor.__qualname__.__eq__,          ["constructor"],          true]
    - [add_extension,        add_extension.__qualname__.__eq__,        ["add_extension"],        true]
    - [remove_extension,     remove_extension.__qualname__.__eq__,     ["remove_extension"],     true]
    - [clear_extension_cache, clear_extension_cache.__qualname__.__eq__, ["clear_extension_cache"], true]
    - [newobj,               __newobj__.__qualname__.__eq__,           ["__newobj__"],           true]
    - [newobj_ex,            __newobj_ex__.__qualname__.__eq__,        ["__newobj_ex__"],        true]
