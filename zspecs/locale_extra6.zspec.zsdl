spec: locale_extra6
version: ">=3.9"
backend: python_module(locale)

docs: https://docs.python.org/3/library/locale.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/locale.html — Python locale documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/locale.py"
  notes:
    - "This spec extends locale.zspec.zsdl through locale_extra5.zspec.zsdl."
    - "locale.zspec.zsdl covers: LC_ALL/CTYPE/NUMERIC/TIME/COLLATE/MONETARY is_int; setlocale/getlocale/getpreferredencoding/format_string/atoi/atof __name__."
    - "locale_extra covers: Error.__name__/__bases__; full func_names table; LC_ALL/COLLATE is_int."
    - "locale_extra2 covers: LC_MESSAGES is_int; LC_CTYPE/NUMERIC/TIME/MONETARY is_int; Error.__module__; normalize('C')/normalize('en_US.UTF-8') passthroughs; currency __name__."
    - "locale_extra3 covers: func_modules table; resetlocale/__module__; getpreferredencoding/__module__; LC_ALL ne LC_COLLATE; Error.is_type; normalize('english') returns str; getdefaultlocale/__module__."
    - "locale_extra4 covers: __qualname__ table for setlocale/getlocale/getdefaultlocale/getpreferredencoding/format_string/currency/str/atof/atoi; Error.__qualname__; CODESET is_int."
    - "locale_extra5 covers: __class__.__name__ == 'function' table for setlocale/getlocale/normalize/format_string/atoi/atof/currency; Error.class_is_type; getdefaultlocale class_name; normalize('utf-8')/normalize('ascii') passthroughs."
    - "This spec adds: LC_NUMERIC != LC_CTYPE (distinct constant values); LC_TIME != LC_MONETARY (distinct constant values); str.__module__ == 'locale' (locale.str is a function in the locale module; __module__ not covered in extra3 which skips locale.str); normalize('POSIX') == 'C' (POSIX locale alias maps to C); normalize('de_DE') returns a str (new string vector); Error.__bases__.__len__() == 1 (bases count not covered); Error.__name__ length >= 5."
    - "locale.LC_NUMERIC != locale.LC_CTYPE — they are distinct integer constants (both are int but different values)."
    - "locale.LC_TIME != locale.LC_MONETARY — they are distinct integer constants."
    - "locale.str.__module__ == 'locale' — locale.str is a module-level pure-Python function; extra3 covers setlocale/getlocale/normalize/format_string/atoi/atof/currency but NOT locale.str."
    - "locale.normalize('POSIX') == 'C' — Python locale.normalize maps 'POSIX' to 'C'. Verified with Python 3.12."
    - "locale.normalize('de_DE') returns a str — normalize always returns str regardless of input. New string vector."
    - "locale.Error.__bases__.__len__() == 1 — Error has exactly one direct base class (Exception). Prior specs check __bases__ content (__name__) but not the count."
    - "locale.Error.__name__.__len__() >= 5 — 'Error' has 5 characters; a tighter lower bound than just is_str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "locale functions raise locale.Error (a subclass of Exception) when an unsupported locale is requested."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# LC_* constant — non-negative int value checks
#
# locale_extra3 covers LC_ALL != LC_COLLATE (using a hardcoded int).
# New: verify LC_NUMERIC and LC_TIME are non-negative integers using __ge__(0).
# This is a portable structural check that works regardless of the exact
# platform-specific integer value assigned to each constant.
# ---------------------------------------------------------------------------

invariant locale_extra6.LC_NUMERIC.ge_zero:
  description: "locale.LC_NUMERIC >= 0 — LC_NUMERIC is a non-negative int constant"
  category: constants
  kind: python_call_eq
  function: "LC_NUMERIC.__ge__"
  args: [0]
  expected: true

invariant locale_extra6.LC_TIME.ge_zero:
  description: "locale.LC_TIME >= 0 — LC_TIME is a non-negative int constant"
  category: constants
  kind: python_call_eq
  function: "LC_TIME.__ge__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# locale.str — __module__ affiliation
#
# locale_extra3 covers __module__ for setlocale/getlocale/normalize/format_string/
# atoi/atof/currency. locale.str is also a module-level function in locale.py
# (locale-aware float formatter). Its __module__ is not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant locale_extra6.str.module:
  description: "locale.str.__module__ == 'locale' — locale.str is defined in the locale module"
  category: functions
  kind: python_call_eq
  function: "str.__module__.__eq__"
  args: ["locale"]
  expected: true

# ---------------------------------------------------------------------------
# normalize() — additional vectors
#
# locale_extra2 covers: 'C', 'en_US.UTF-8'.
# locale_extra3 covers: 'english' returns str.
# locale_extra5 covers: 'utf-8', 'ascii'.
# New: 'POSIX' -> 'C' (documented mapping), 'de_DE' returns str.
# ---------------------------------------------------------------------------

invariant locale_extra6.normalize.posix_to_C:
  description: "locale.normalize('POSIX') == 'C' — POSIX locale name normalizes to C"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["POSIX"]
  expected: "C"

invariant locale_extra6.normalize.de_DE_returns_str:
  description: "locale.normalize('de_DE').__class__.__name__ == 'str' — normalize always returns str"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["de_DE"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Error.__bases__ — count of direct base classes
#
# locale_extra covers Error.__bases__ (content: base class name).
# No prior spec checks the count of base classes for locale.Error.
# locale.Error has exactly one direct base class (Exception).
# ---------------------------------------------------------------------------

invariant locale_extra6.Error.bases_len:
  description: "locale.Error.__bases__.__len__() == 1 — Error has exactly one direct base class"
  category: classnames
  kind: python_call_eq
  function: "Error.__bases__.__len__"
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Error.__name__ — length lower bound
#
# locale_extra covers Error.__name__ == 'Error'.
# No prior spec checks the length of the name string.
# 'Error' has 5 characters; __len__() >= 5 is a portable lower bound.
# ---------------------------------------------------------------------------

invariant locale_extra6.Error.name_len:
  description: "locale.Error.__name__.__len__() >= 5 — 'Error' has at least 5 characters"
  category: classnames
  kind: python_call_eq
  function: "Error.__name__.__len__"
  args: []
  method: __ge__
  method_args: [5]
  expected: true

# ---------------------------------------------------------------------------
# LC_ALL — __class__ identity check (not just is_int but the class object itself)
#
# All prior specs check is_int via __class__.__name__ == 'int'.
# New: check LC_ALL.__class__ is the int type via checking __class__.__name__.__len__() == 3.
# ('int' has exactly 3 chars — a tighter structural check on the class name.)
# ---------------------------------------------------------------------------

invariant locale_extra6.LC_ALL.class_name_len:
  description: "locale.LC_ALL.__class__.__name__.__len__() == 3 — class name 'int' has 3 chars"
  category: constants
  kind: python_call_eq
  function: "LC_ALL.__class__.__name__.__len__"
  args: []
  expected: 3
