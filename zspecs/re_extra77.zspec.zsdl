spec: re_extra77
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra76."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error.__name__ == 'PatternError'; re module-level function __code__ co_name and co_argcount."
    - "re_extra76 covers re.compile/match/search/fullmatch/findall/finditer/sub/subn/split __code__.co_name and co_argcount."
    - "This spec covers: Pattern method __qualname__ string lengths; Match method __qualname__ string lengths; re.error.__qualname__ == 'PatternError'; re.PatternError.__name__ == 'PatternError'."
    - "re.Pattern.match.__qualname__.__len__() == 13 — 'Pattern.match' has 13 characters (P-a-t-t-e-r-n-.-m-a-t-c-h)."
    - "re.Pattern.search.__qualname__.__len__() == 14 — 'Pattern.search' has 14 characters."
    - "re.Pattern.findall.__qualname__.__len__() == 15 — 'Pattern.findall' has 15 characters."
    - "re.Pattern.sub.__qualname__.__len__() == 11 — 'Pattern.sub' has 11 characters."
    - "re.Match.group.__qualname__.__len__() == 11 — 'Match.group' has 11 characters."
    - "re.Match.groups.__qualname__.__len__() == 12 — 'Match.groups' has 12 characters."
    - "re.Match.span.__qualname__.__len__() == 10 — 'Match.span' has 10 characters."
    - "re.error.__qualname__ == 'PatternError' — re.error is an alias for PatternError since Python 3.13; its __qualname__ is 'PatternError'."
    - "re.PatternError.__name__ == 'PatternError' — PatternError is the canonical name introduced in Python 3.13."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern method __qualname__ lengths
# Pattern.match, Pattern.search, Pattern.findall, Pattern.sub are C extension
# methods whose __qualname__ values follow the 'ClassName.method_name' pattern.
# Lengths verified character-by-character against Python 3.14.3.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra77.Pattern_qualname_lengths:
  description: "Pattern method __qualname__ string lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: remore77

  columns: [id, function, args, expected]
  rows:
    - [match_qname_len,   Pattern.match.__qualname__.__len__,   [], 13]
    - [search_qname_len,  Pattern.search.__qualname__.__len__,  [], 14]
    - [findall_qname_len, Pattern.findall.__qualname__.__len__, [], 15]
    - [sub_qname_len,     Pattern.sub.__qualname__.__len__,     [], 11]

# ---------------------------------------------------------------------------
# Match method __qualname__ lengths
# Match.group, Match.groups, Match.span are C extension methods.
# Lengths verified against Python 3.14.3.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra77.Match_qualname_lengths:
  description: "Match method __qualname__ string lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: remore77

  columns: [id, function, args, expected]
  rows:
    - [group_qname_len,  Match.group.__qualname__.__len__,  [], 11]
    - [groups_qname_len, Match.groups.__qualname__.__len__, [], 12]
    - [span_qname_len,   Match.span.__qualname__.__len__,   [], 10]

# ---------------------------------------------------------------------------
# re.error and re.PatternError identity
# In Python 3.13+, re.error is an alias for re.PatternError.
# re.error.__qualname__ == 'PatternError' — the class __qualname__ reflects
# the canonical name PatternError, not the alias name 'error'.
# re.PatternError.__name__ == 'PatternError' — canonical name introduced 3.13.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra77.error_PatternError_identity:
  description: "re.error.__qualname__ == 'PatternError' and re.PatternError.__name__ == 'PatternError'"
  kind: python_call_eq
  category: class_names
  id_prefix: remore77

  columns: [id, function, args, expected]
  rows:
    - [error_qualname,       error.__qualname__.__eq__,       ["PatternError"], true]
    - [patternerror_name,    PatternError.__name__.__eq__,    ["PatternError"], true]
    - [patternerror_qualname,PatternError.__qualname__.__eq__, ["PatternError"], true]

# ---------------------------------------------------------------------------
# Pattern qualname string values for match and findall
# Confirming the exact __qualname__ string values (not just lengths) for two
# representative Pattern methods.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra77.Pattern_qualname_values:
  description: "Pattern.match and Pattern.findall __qualname__ string values"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: remore77

  columns: [id, function, args, expected]
  rows:
    - [match_qname_val,   Pattern.match.__qualname__.__eq__,   ["Pattern.match"],   true]
    - [findall_qname_val, Pattern.findall.__qualname__.__eq__, ["Pattern.findall"], true]
    - [span_qname_val,    Match.span.__qualname__.__eq__,      ["Match.span"],      true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra77.Pattern_match.qualname_len:
  description: "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' = 13 chars)"
  category: qualname_lengths
  kind: python_call_eq
  function: Pattern.match.__qualname__.__len__
  args: []
  expected: 13

invariant re_extra77.Pattern_search.qualname_len:
  description: "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.search' = 14 chars)"
  category: qualname_lengths
  kind: python_call_eq
  function: Pattern.search.__qualname__.__len__
  args: []
  expected: 14

invariant re_extra77.Match_span.qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 ('Match.span' = 10 chars)"
  category: qualname_lengths
  kind: python_call_eq
  function: Match.span.__qualname__.__len__
  args: []
  expected: 10

invariant re_extra77.error.qualname_is_PatternError:
  description: "re.error.__qualname__ == 'PatternError' (re.error is alias for PatternError since Python 3.13)"
  category: class_names
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra77.PatternError.name:
  description: "re.PatternError.__name__ == 'PatternError'"
  category: class_names
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true
