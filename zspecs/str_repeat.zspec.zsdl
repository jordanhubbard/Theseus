spec: str_repeat
version: ">=1.0.1"
backend: node(str-repeat)

docs: https://www.npmjs.com/package/str-repeat

provenance:
  derived_from:
    - "str-repeat README — https://www.npmjs.com/package/str-repeat"
    - "Test vectors verified with str-repeat via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "str-repeat source"
  notes:
    - "str-repeat is an npm package. Install: npm install str-repeat"
    - "Repeats a string n times."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table str_repeat.repeat:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: strep

  columns: [id, args, expected]
  rows:
    - [twice,   ["ab", 3], "ababab"]
    - [five_x,  ["x",  5], "xxxxx"]
    - [zero,    ["-",  0], ""]
