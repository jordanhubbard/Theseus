spec: inspect_extra435
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module function and class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect functions are pure Python; __module__ is reliably 'inspect' across all supported versions"
    - "inspect.Parameter is a class defined in the inspect module itself"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra435.function_names:
  description: "inspect module functions report correct __name__"
  kind: python_call_eq
  category: identity
  id_prefix: fn

  columns: [id, function, args, expected]
  rows:
    - [fn001, inspect.isfunction.__name__.__eq__, ["isfunction"], true]
    - [fn002, inspect.isclass.__name__.__eq__, ["isclass"], true]
    - [fn003, inspect.ismethod.__name__.__eq__, ["ismethod"], true]
    - [fn004, inspect.getmembers.__name__.__eq__, ["getmembers"], true]
    - [fn005, inspect.signature.__name__.__eq__, ["signature"], true]

table inspect_extra435.function_modules:
  description: "inspect module functions report correct __module__"
  kind: python_call_eq
  category: identity
  id_prefix: fm

  columns: [id, function, args, expected]
  rows:
    - [fm001, inspect.isfunction.__module__.__eq__, ["inspect"], true]
    - [fm002, inspect.isclass.__module__.__eq__, ["inspect"], true]
    - [fm003, inspect.ismethod.__module__.__eq__, ["inspect"], true]
    - [fm004, inspect.getmembers.__module__.__eq__, ["inspect"], true]
    - [fm005, inspect.signature.__module__.__eq__, ["inspect"], true]

table inspect_extra435.class_identity:
  description: "inspect.Parameter class identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: ci

  columns: [id, function, args, expected]
  rows:
    - [ci001, inspect.Parameter.__name__.__eq__, ["Parameter"], true]
    - [ci002, inspect.Parameter.__module__.__eq__, ["inspect"], true]
