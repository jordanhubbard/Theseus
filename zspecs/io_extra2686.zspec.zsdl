spec: io_extra2686
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2671.zspec.zsdl — covers __sub__/__floordiv__/__mod__ dict-presence"
  notes:
    - "Wave 626 (io_extra2686) theme: __and__, __or__, and __xor__ dict-presence checks."
    - "None of the io classes define __and__, __or__, or __xor__ in their own __dict__."
    - "__and__ is the bitwise AND operator; io stream classes are sequential I/O objects, not integers or sets."
    - "__or__ is the bitwise OR operator; io stream classes do not implement bitwise OR semantics."
    - "__xor__ is the bitwise XOR operator; io stream classes do not implement bitwise XOR semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2686.no_and_in_io_classes:
  description: "__and__ is absent from all io class __dict__s — io stream classes do not implement the bitwise AND protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2686

  columns: [id, function, args, expected]
  rows:
    - ["io2686001", "io.IOBase.__dict__.__contains__",         ["__and__"], false]
    - ["io2686002", "io.RawIOBase.__dict__.__contains__",      ["__and__"], false]
    - ["io2686003", "io.BufferedIOBase.__dict__.__contains__", ["__and__"], false]
    - ["io2686004", "io.TextIOBase.__dict__.__contains__",     ["__and__"], false]
    - ["io2686005", "io.BytesIO.__dict__.__contains__",        ["__and__"], false]
    - ["io2686006", "io.StringIO.__dict__.__contains__",       ["__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2686.no_or_in_io_classes:
  description: "__or__ is absent from all io class __dict__s — io stream classes do not implement the bitwise OR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2686

  columns: [id, function, args, expected]
  rows:
    - ["io2686007", "io.IOBase.__dict__.__contains__",          ["__or__"], false]
    - ["io2686008", "io.FileIO.__dict__.__contains__",          ["__or__"], false]
    - ["io2686009", "io.BufferedReader.__dict__.__contains__",  ["__or__"], false]
    - ["io2686010", "io.BufferedWriter.__dict__.__contains__",  ["__or__"], false]
    - ["io2686011", "io.BufferedRandom.__dict__.__contains__",  ["__or__"], false]
    - ["io2686012", "io.TextIOWrapper.__dict__.__contains__",   ["__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2686.no_xor_in_io_classes:
  description: "__xor__ is absent from all io class __dict__s — io stream classes do not implement the bitwise XOR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2686

  columns: [id, function, args, expected]
  rows:
    - ["io2686013", "io.IOBase.__dict__.__contains__",         ["__xor__"], false]
    - ["io2686014", "io.BytesIO.__dict__.__contains__",        ["__xor__"], false]
    - ["io2686015", "io.StringIO.__dict__.__contains__",       ["__xor__"], false]
    - ["io2686016", "io.FileIO.__dict__.__contains__",         ["__xor__"], false]
    - ["io2686017", "io.BufferedReader.__dict__.__contains__", ["__xor__"], false]
    - ["io2686018", "io.BufferedWriter.__dict__.__contains__", ["__xor__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not bitwise operator hooks
# Confirms that io classes are sequential I/O objects, not integer or set types
# ---------------------------------------------------------------------------

table io_extra2686.io_has_stream_methods_not_bitwise_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __and__/__or__/__xor__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2686

  columns: [id, function, args, expected]
  rows:
    - ["io2686019", "io.BytesIO.__dict__.__contains__",  ["read"],    true]
    - ["io2686020", "io.BytesIO.__dict__.__contains__",  ["write"],   true]
    - ["io2686021", "io.BytesIO.__dict__.__contains__",  ["seek"],    true]
    - ["io2686022", "io.BytesIO.__dict__.__contains__",  ["tell"],    true]
    - ["io2686023", "io.BytesIO.__dict__.__contains__",  ["__and__"], false]
    - ["io2686024", "io.BytesIO.__dict__.__contains__",  ["__or__"],  false]
    - ["io2686025", "io.BytesIO.__dict__.__contains__",  ["__xor__"], false]
    - ["io2686026", "io.StringIO.__dict__.__contains__", ["read"],    true]
    - ["io2686027", "io.StringIO.__dict__.__contains__", ["write"],   true]
    - ["io2686028", "io.StringIO.__dict__.__contains__", ["seek"],    true]
    - ["io2686029", "io.StringIO.__dict__.__contains__", ["tell"],    true]
    - ["io2686030", "io.StringIO.__dict__.__contains__", ["__and__"], false]
    - ["io2686031", "io.StringIO.__dict__.__contains__", ["__or__"],  false]
    - ["io2686032", "io.StringIO.__dict__.__contains__", ["__xor__"], false]
