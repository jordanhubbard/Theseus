spec: hashlib_extra961
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib builtin function class names and module identity attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra961.hash_function_class_names:
  description: "hashlib hash constructor __class__.__name__ identity"
  kind: python_call_eq
  category: function_class_names
  id_prefix: hl961fn
  columns: [id, function, args, expected]
  rows:
    - [hl961fn001, hashlib.md5.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [hl961fn002, hashlib.sha1.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [hl961fn003, hashlib.sha256.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [hl961fn004, hashlib.sha512.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [hl961fn005, hashlib.new.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [hl961fn006, hashlib.pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table hashlib_extra961.module_identity:
  description: "hashlib module __name__ and __spec__.name identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl961mi
  columns: [id, function, args, expected]
  rows:
    - [hl961mi001, hashlib.__name__.__eq__,       ["hashlib"], true]
    - [hl961mi002, hashlib.__spec__.name.__eq__,  ["hashlib"], true]
    - [hl961mi003, hashlib.__name__.__class__.__name__.__eq__, ["str"], true]
    - [hl961mi004, hashlib.__spec__.name.__class__.__name__.__eq__, ["str"], true]
    - [hl961mi005, hashlib.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]

table hashlib_extra961.function_module_attrs:
  description: "hashlib function __module__ attribute checks"
  kind: python_call_eq
  category: function_module_attrs
  id_prefix: hl961ma
  columns: [id, function, args, expected]
  rows:
    - [hl961ma001, hashlib.md5.__module__.__eq__,         ["_hashlib"], true]
    - [hl961ma002, hashlib.sha256.__module__.__eq__,      ["_hashlib"], true]
    - [hl961ma003, hashlib.new.__module__.__eq__,         ["_hashlib"], true]
    - [hl961ma004, hashlib.pbkdf2_hmac.__module__.__eq__, ["_hashlib"], true]
    - [hl961ma005, hashlib.md5.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
