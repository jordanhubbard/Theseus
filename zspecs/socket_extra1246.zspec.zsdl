spec: socket_extra1246
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that socket module, socket.socket, error, timeout, gethostname, getaddrinfo, create_connection have str __doc__; socket.herror and socket.gaierror __doc__ are NoneType; verifies __doc__.__class__.__name__ comparisons"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1246.module_doc_class:
  description: "socket module and key objects with str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: sk1246md
  columns: [id, function, args, expected]
  rows:
    - [sk1246md001, socket.__doc__.__class__.__name__.__eq__,                    ["str"], true]
    - [sk1246md002, socket.socket.__doc__.__class__.__name__.__eq__,             ["str"], true]
    - [sk1246md003, socket.error.__doc__.__class__.__name__.__eq__,              ["str"], true]
    - [sk1246md004, socket.timeout.__doc__.__class__.__name__.__eq__,            ["str"], true]
    - [sk1246md005, socket.gethostname.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [sk1246md006, socket.getaddrinfo.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [sk1246md007, socket.create_connection.__doc__.__class__.__name__.__eq__,  ["str"], true]

table socket_extra1246.herror_gaierror_doc_nonetype:
  description: "socket.herror and socket.gaierror __doc__ are NoneType"
  kind: python_call_eq
  category: doc_nonetype
  id_prefix: sk1246hn
  columns: [id, function, args, expected]
  rows:
    - [sk1246hn001, socket.herror.__doc__.__class__.__name__.__eq__,             ["NoneType"], true]
    - [sk1246hn002, socket.herror.__doc__.__class__.__name__.__eq__,             ["str"],      false]
    - [sk1246hn003, socket.gaierror.__doc__.__class__.__name__.__eq__,           ["NoneType"], true]
    - [sk1246hn004, socket.gaierror.__doc__.__class__.__name__.__eq__,           ["str"],      false]
    - [sk1246hn005, socket.herror.__doc__.__class__.__name__.__class__.__name__.__eq__,  ["str"], true]
    - [sk1246hn006, socket.gaierror.__doc__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]

table socket_extra1246.module_doc_not_nonetype:
  description: "socket module and key objects with str __doc__ are not NoneType"
