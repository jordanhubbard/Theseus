    - [sk1246mn002, socket.socket.__doc__.__class__.__name__.__eq__,             ["NoneType"], false]
    - [sk1246mn003, socket.error.__doc__.__class__.__name__.__eq__,              ["NoneType"], false]
    - [sk1246mn004, socket.timeout.__doc__.__class__.__name__.__eq__,            ["NoneType"], false]
    - [sk1246mn005, socket.gethostname.__doc__.__class__.__name__.__eq__,        ["NoneType"], false]
    - [sk1246mn006, socket.getaddrinfo.__doc__.__class__.__name__.__eq__,        ["NoneType"], false]
    - [sk1246mn007, socket.create_connection.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]

