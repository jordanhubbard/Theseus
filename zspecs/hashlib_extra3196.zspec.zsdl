spec: hl3196
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (hl3196): __pow__, __lshift__, __rshift__ dict-presence checks for hashlib types."
    - "type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __pow__, __lshift__, or __rshift__ in their own __dict__."
    - "Hash objects are digest machines — they expose an update/digest API only and do not support numeric or bitwise operations."
    - "All values are False — none of these types are numeric types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3196.pow:
  description: "hashlib types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3196
  columns: [id, function, args, expected]
  rows:
    - ["hl3196001", operator.contains, [type(hashlib.md5()).__dict__,        "__pow__"], false]
    - ["hl3196002", operator.contains, [type(hashlib.sha1()).__dict__,       "__pow__"], false]
    - ["hl3196003", operator.contains, [type(hashlib.sha256()).__dict__,     "__pow__"], false]
    - ["hl3196004", operator.contains, [type(hashlib.sha512()).__dict__,     "__pow__"], false]
    - ["hl3196005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__pow__"], false]

