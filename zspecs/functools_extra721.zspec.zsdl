spec: functools_extra721
version: ">=3.9"
backend: python_module(functools)
docs: "Behavioral specs for functools.partial and WRAPPER attributes identity"
error_model: python_exceptions
provenance:
  derived_from: "python stdlib functools module"
  not_derived_from: "any third-party library"
  notes: "Covers functools.partial attribute identity, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, update_wrapper, and singledispatch qualname/module"
  created_at: "2026-04-12"

table functools_extra721.partial_identity:
  description: "Identity checks for functools.partial class attributes"
  kind: python_call_eq
  category: identity
  id_prefix: ft721pa
  columns: [id, function, args, expected]
  rows:
    - [ft721pa001, functools.partial.__qualname__.__eq__, ["partial"], true]
    - [ft721pa002, functools.partial.__module__.__eq__, ["functools"], true]
    - [ft721pa003, functools.partial.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft721pa004, functools.partial.func.__class__.__name__.__eq__, ["member_descriptor"], true]
    - [ft721pa005, functools.partial.args.__class__.__name__.__eq__, ["member_descriptor"], true]
    - [ft721pa006, functools.partial.keywords.__class__.__name__.__eq__, ["member_descriptor"], true]

