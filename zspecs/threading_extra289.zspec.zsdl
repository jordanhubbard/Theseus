spec: threading_extra289
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading Semaphore, BoundedSemaphore, Barrier, and Timer method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "BoundedSemaphore.acquire inherits from Semaphore, so its qualname is 'Semaphore.acquire'"
    - "BoundedSemaphore.release is overridden and has qualname 'BoundedSemaphore.release'"
    - "Timer.start is inherited from Thread, so its qualname is 'Thread.start'"
    - "Timer.cancel and Timer.run are defined on Timer itself"
    - "Barrier.parties, n_waiting, and broken are Python property descriptors"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra289.semaphore_qualnames:
  description: "Semaphore and BoundedSemaphore method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: thex289s

  columns: [id, function, args, expected, description]
  rows:
    - [thex289s_001, threading.Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true, "Semaphore.acquire qualname is 'Semaphore.acquire'"]
    - [thex289s_002, threading.Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true, "Semaphore.release qualname is 'Semaphore.release'"]
    - [thex289s_003, threading.BoundedSemaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true, "BoundedSemaphore.acquire inherits from Semaphore — qualname is 'Semaphore.acquire'"]
    - [thex289s_004, threading.BoundedSemaphore.release.__qualname__.__eq__, ["BoundedSemaphore.release"], true, "BoundedSemaphore.release is overridden — qualname is 'BoundedSemaphore.release'"]

table threading_extra289.barrier_identity:
  description: "Barrier method qualnames and property descriptor class names"
  kind: python_call_eq
  category: identity
  id_prefix: thex289b

  columns: [id, function, args, expected, description]
  rows:
    - [thex289b_001, threading.Barrier.wait.__qualname__.__eq__, ["Barrier.wait"], true, "Barrier.wait qualname is 'Barrier.wait'"]
    - [thex289b_002, threading.Barrier.reset.__qualname__.__eq__, ["Barrier.reset"], true, "Barrier.reset qualname is 'Barrier.reset'"]
    - [thex289b_003, threading.Barrier.abort.__qualname__.__eq__, ["Barrier.abort"], true, "Barrier.abort qualname is 'Barrier.abort'"]
    - [thex289b_004, threading.Barrier.parties.__class__.__name__.__eq__, ["property"], true, "Barrier.parties is a property descriptor"]
    - [thex289b_005, threading.Barrier.n_waiting.__class__.__name__.__eq__, ["property"], true, "Barrier.n_waiting is a property descriptor"]
    - [thex289b_006, threading.Barrier.broken.__class__.__name__.__eq__, ["property"], true, "Barrier.broken is a property descriptor"]

invariant threading_extra289.inv_timer_start_qualname:
  description: "Timer.start is inherited from Thread — qualname is 'Thread.start'"
  category: identity
  kind: python_call_eq
  function: threading.Timer.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra289.inv_timer_cancel_qualname:
  description: "Timer.cancel is defined on Timer — qualname is 'Timer.cancel'"
  category: identity
  kind: python_call_eq
  function: threading.Timer.cancel.__qualname__.__eq__
  args: ["Timer.cancel"]
  expected: true

invariant threading_extra289.inv_timer_run_qualname:
  description: "Timer.run is defined on Timer — qualname is 'Timer.run'"
  category: identity
  kind: python_call_eq
  function: threading.Timer.run.__qualname__.__eq__
  args: ["Timer.run"]
  expected: true

invariant threading_extra289.inv_barrier_parties_is_property:
  description: "Barrier.parties is a property descriptor"
  category: identity
  kind: python_call_eq
  function: threading.Barrier.parties.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra289.inv_boundedsemaphore_acquire_inherits:
  description: "BoundedSemaphore.acquire inherits from Semaphore — qualname is 'Semaphore.acquire' not 'BoundedSemaphore.acquire'"
  category: identity
  kind: python_call_eq
  function: threading.BoundedSemaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true
