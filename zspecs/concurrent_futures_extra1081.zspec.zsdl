spec: concurrent_futures_extra1081
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures ProcessPoolExecutor, ThreadPoolExecutor, and InvalidStateError documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks ProcessPoolExecutor submit/map/shutdown qualnames, ThreadPoolExecutor submit/map/shutdown qualnames, BrokenExecutor/InvalidStateError module and qualname — behaviors not covered by extra1051 or extra1066"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1081.process_pool_method_qualnames:
  description: "concurrent.futures.ProcessPoolExecutor submit, map, and shutdown __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf1081pp
  columns: [id, function, args, expected]
  rows:
    - [cf1081pp001, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__,              ["ProcessPoolExecutor"],              true]
    - [cf1081pp002, concurrent.futures.ProcessPoolExecutor.__name__.__eq__,                  ["ProcessPoolExecutor"],              true]
    - [cf1081pp003, concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__,       ["ProcessPoolExecutor.submit"],       true]
    - [cf1081pp004, concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__,          ["Executor.map"],                    true]
    - [cf1081pp005, concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__,     ["ProcessPoolExecutor.shutdown"],     true]
    - [cf1081pp006, concurrent.futures.ProcessPoolExecutor.submit.__class__.__name__.__eq__, ["function"],                         true]
    - [cf1081pp007, concurrent.futures.ProcessPoolExecutor.shutdown.__class__.__name__.__eq__, ["function"],                       true]

table concurrent_futures_extra1081.thread_pool_method_qualnames:
  description: "concurrent.futures.ThreadPoolExecutor submit, map, and shutdown __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf1081tp
  columns: [id, function, args, expected]
  rows:
    - [cf1081tp001, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__,              ["ThreadPoolExecutor"],              true]
    - [cf1081tp002, concurrent.futures.ThreadPoolExecutor.__name__.__eq__,                  ["ThreadPoolExecutor"],              true]
    - [cf1081tp003, concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__,       ["ThreadPoolExecutor.submit"],       true]
    - [cf1081tp004, concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__,          ["Executor.map"],                   true]
    - [cf1081tp005, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__,     ["ThreadPoolExecutor.shutdown"],     true]
    - [cf1081tp006, concurrent.futures.ThreadPoolExecutor.submit.__class__.__name__.__eq__, ["function"],                        true]
    - [cf1081tp007, concurrent.futures.ThreadPoolExecutor.__module__.__eq__,               ["concurrent.futures.thread"],       true]

table concurrent_futures_extra1081.broken_and_invalid_state_identity:
  description: "concurrent.futures.BrokenExecutor and InvalidStateError module and qualname identity"
  kind: python_call_eq
  category: exception_identity
  id_prefix: cf1081bi
  columns: [id, function, args, expected]
  rows:
    - [cf1081bi001, concurrent.futures.BrokenExecutor.__module__.__eq__,          ["concurrent.futures._base"],  true]
    - [cf1081bi002, concurrent.futures.BrokenExecutor.__qualname__.__eq__,        ["BrokenExecutor"],            true]
    - [cf1081bi003, concurrent.futures.BrokenExecutor.__name__.__eq__,            ["BrokenExecutor"],            true]
    - [cf1081bi004, concurrent.futures.BrokenExecutor.__class__.__name__.__eq__,  ["type"],                      true]
    - [cf1081bi005, concurrent.futures.InvalidStateError.__module__.__eq__,        ["concurrent.futures._base"], true]
    - [cf1081bi006, concurrent.futures.InvalidStateError.__qualname__.__eq__,      ["InvalidStateError"],         true]
    - [cf1081bi007, concurrent.futures.InvalidStateError.__name__.__eq__,          ["InvalidStateError"],         true]
