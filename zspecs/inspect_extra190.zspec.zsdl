spec: inspect_extra190
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Parameter.empty is inspect._empty is inspect.Signature.empty — all three names reference the same sentinel class; verified with Python 3.14.3."
    - "inspect.Parameter.empty.__name__ == '_empty' (len=6); verified with Python 3.14.3."
    - "inspect.Parameter.empty.__module__ == 'inspect'; the sentinel is defined in the inspect module; verified with Python 3.14.3."
    - "inspect.Signature.empty.__name__ == '_empty' (len=6); same object as Parameter.empty; verified with Python 3.14.3."
    - "inspect.Signature.empty.__module__ == 'inspect'; verified with Python 3.14.3."
    - "inspect._empty.__name__ == '_empty' (len=6); verified with Python 3.14.3."
    - "inspect._empty.__module__ == 'inspect'; verified with Python 3.14.3."
    - "inspect._empty.__bases__[0].__name__ == 'object'; _empty inherits directly from object; verified with Python 3.14.3."
    - "inspect._empty.__qualname__ == '_empty'; top-level class so __qualname__ equals __name__; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter.empty sentinel identity
#
# inspect.Parameter.empty.__name__    == '_empty' (len=6)
# inspect.Parameter.empty.__module__  == 'inspect'
#
# Parameter.empty is the sentinel class used to indicate that a parameter
# has no default value and no annotation. It is the same object as
# inspect._empty. New to extra190.
# ---------------------------------------------------------------------------

table inspect_extra190.parameter_empty_identity:
  description: "inspect.Parameter.empty sentinel: __name__=='_empty'(len=6); __module__=='inspect'; same object as inspect._empty; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsentinel190

  columns: [id, function, args, expected, description]
  rows:
    - [param_empty_name,
       Parameter.empty.__name__.__eq__,
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is the _empty sentinel class; __name__ is '_empty' (len=6: _-e-m-p-t-y); str.__eq__('_empty') returns True; verified with Python 3.14.3; new to extra190"]
    - [param_empty_name_len,
       Parameter.empty.__name__.__len__,
       [],
       6,
       "inspect.Parameter.empty.__name__.__len__() == 6 — '_empty' has 6 characters: _-e-m-p-t-y; str.__len__() returns 6; verified with Python 3.14.3; new to extra190"]
    - [param_empty_module,
       Parameter.empty.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.empty.__module__.__eq__('inspect') == True — the _empty sentinel is defined in the inspect module; str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra190"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature.empty sentinel identity
#
# inspect.Signature.empty.__name__    == '_empty' (len=6)
# inspect.Signature.empty.__module__  == 'inspect'
#
# Signature.empty is the same sentinel object as Parameter.empty and
# inspect._empty. It signals that a Signature has no return annotation.
# New to extra190.
# ---------------------------------------------------------------------------

table inspect_extra190.signature_empty_identity:
  description: "inspect.Signature.empty sentinel: __name__=='_empty'(len=6); __module__=='inspect'; same object as Parameter.empty and inspect._empty; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsentinel190

  columns: [id, function, args, expected, description]
  rows:
    - [sig_empty_name,
       Signature.empty.__name__.__eq__,
       ["_empty"],
       true,
       "inspect.Signature.empty.__name__.__eq__('_empty') == True — Signature.empty is the same _empty sentinel as Parameter.empty; __name__ is '_empty' (len=6); str.__eq__('_empty') returns True; verified with Python 3.14.3; new to extra190"]
    - [sig_empty_name_len,
       Signature.empty.__name__.__len__,
       [],
       6,
       "inspect.Signature.empty.__name__.__len__() == 6 — '_empty' has 6 characters: _-e-m-p-t-y; str.__len__() returns 6; verified with Python 3.14.3; new to extra190"]
    - [sig_empty_module,
       Signature.empty.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.empty.__module__.__eq__('inspect') == True — the _empty sentinel is defined in the inspect module; str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra190"]

# ---------------------------------------------------------------------------
# Table 3: inspect._empty class identity — __name__, __module__, __bases__, __qualname__
#
# inspect._empty.__name__             == '_empty' (len=6)
# inspect._empty.__module__           == 'inspect'
# inspect._empty.__bases__[0].__name__ == 'object'
# inspect._empty.__qualname__         == '_empty'
#
# _empty is the canonical name for the sentinel. It is a plain class with
# object as its sole base. __qualname__ equals __name__ because it is
# defined at module top level. New to extra190.
# ---------------------------------------------------------------------------

table inspect_extra190.empty_class_identity:
  description: "inspect._empty class identity: __name__=='_empty'(len=6); __module__=='inspect'; __bases__[0].__name__=='object'; __qualname__=='_empty'; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsentinel190

  columns: [id, function, args, expected, description]
  rows:
    - [empty_name,
       _empty.__name__.__eq__,
       ["_empty"],
       true,
       "inspect._empty.__name__.__eq__('_empty') == True — _empty is the sentinel class defined at module top level; __name__ is '_empty' (len=6); str.__eq__('_empty') returns True; verified with Python 3.14.3; new to extra190"]
    - [empty_module,
       _empty.__module__.__eq__,
       ["inspect"],
       true,
       "inspect._empty.__module__.__eq__('inspect') == True — _empty is defined in the inspect module; str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra190"]
    - [empty_base,
       "_empty.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect._empty.__bases__[0].__name__.__eq__('object') == True — _empty inherits directly from object with no intermediary; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]
    - [empty_qualname,
       _empty.__qualname__.__eq__,
       ["_empty"],
       true,
       "inspect._empty.__qualname__.__eq__('_empty') == True — _empty is a top-level class so __qualname__ equals __name__ ('_empty'); str.__eq__('_empty') returns True; verified with Python 3.14.3; new to extra190"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra190
# ---------------------------------------------------------------------------

invariant inspect_extra190.parameter_empty_name_eq:
  description: "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is the _empty sentinel class used to flag missing defaults/annotations; __name__ is '_empty' (len=6); verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra190.parameter_empty_module_eq:
  description: "inspect.Parameter.empty.__module__.__eq__('inspect') == True — the _empty sentinel is defined in the inspect module; verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: Parameter.empty.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra190.signature_empty_name_eq:
  description: "inspect.Signature.empty.__name__.__eq__('_empty') == True — Signature.empty references the same _empty sentinel as Parameter.empty; __name__ is '_empty' (len=6); verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: Signature.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra190.signature_empty_module_eq:
  description: "inspect.Signature.empty.__module__.__eq__('inspect') == True — the _empty sentinel is defined in the inspect module; Signature.empty and Parameter.empty are the same object; verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: Signature.empty.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra190.empty_name_eq:
  description: "inspect._empty.__name__.__eq__('_empty') == True — _empty is the canonical sentinel class name; __name__ is '_empty' (len=6: _-e-m-p-t-y); verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: _empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra190.empty_module_eq:
  description: "inspect._empty.__module__.__eq__('inspect') == True — _empty is defined at the top level of the inspect module; verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: _empty.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra190.empty_bases_object:
  description: "inspect._empty.__bases__[0].__name__.__eq__('object') == True — _empty inherits directly from object; no intermediary base class; verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: "_empty.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra190.empty_qualname_eq:
  description: "inspect._empty.__qualname__.__eq__('_empty') == True — _empty is a top-level class so __qualname__ equals __name__; both are '_empty'; verified with Python 3.14.3; new to extra190"
  category: identity
  kind: python_call_eq
  function: _empty.__qualname__.__eq__
  args: ["_empty"]
  expected: true

