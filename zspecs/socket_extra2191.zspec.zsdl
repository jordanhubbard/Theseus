spec: socket_extra2191
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2191: context manager protocol dict-presence — __enter__, __exit__ (sync context manager); __aenter__, __aexit__ (async context manager); acquire, release (lock-like protocol); __wrapped__ (decorator wrapper); __closure__ (function closure attribute)."
    - "socket.socket IS a sync context manager: both __enter__ and __exit__ appear in socket.socket.__dict__ (verified: True, True)."
    - "socket.socket is NOT an async context manager: __aenter__ and __aexit__ are absent from socket.socket.__dict__ (verified: False, False)."
    - "socket.socket is NOT a lock-like object: acquire and release are absent from socket.socket.__dict__."
    - "socket.socket is NOT a decorated wrapper: __wrapped__ and __closure__ are absent from socket.socket.__dict__."
    - "socket.error is an alias for OSError; socket.timeout, socket.gaierror, and socket.herror are plain exception subclasses — none defines context manager protocol dunders in their own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntFlag/IntEnum subclasses — not context managers, not lock-like."
    - "socket.socket.__dict__ also contains: __init__, __repr__, __slots__, __getstate__, accept, close, dup, makefile, sendfile, detach, family, type, get_inheritable, set_inheritable, _closed, _io_refs."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2191.socket_context_manager_protocol:
  description: "socket.socket context manager protocol dict-presence — socket IS a sync context manager (__enter__/__exit__ present), but NOT async, not lock-like, not wrapped"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2191

  columns: [id, function, args, expected]
  rows:
    - ["sk2191001", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk2191002", "socket.socket.__dict__.__contains__", ["__exit__"], true]
    - ["sk2191003", "socket.socket.__dict__.__contains__", ["__aenter__"], false]
    - ["sk2191004", "socket.socket.__dict__.__contains__", ["__aexit__"], false]
    - ["sk2191005", "socket.socket.__dict__.__contains__", ["acquire"], false]
    - ["sk2191006", "socket.socket.__dict__.__contains__", ["release"], false]
    - ["sk2191007", "socket.socket.__dict__.__contains__", ["__wrapped__"], false]
    - ["sk2191008", "socket.socket.__dict__.__contains__", ["__closure__"], false]

