    - ["sk2191010", "socket.error.__dict__.__contains__", ["__exit__"], false]
    - ["sk2191011", "socket.error.__dict__.__contains__", ["__aenter__"], false]
    - ["sk2191012", "socket.error.__dict__.__contains__", ["__aexit__"], false]
    - ["sk2191013", "socket.error.__dict__.__contains__", ["acquire"], false]
    - ["sk2191014", "socket.error.__dict__.__contains__", ["release"], false]
    - ["sk2191015", "socket.error.__dict__.__contains__", ["__wrapped__"], false]

