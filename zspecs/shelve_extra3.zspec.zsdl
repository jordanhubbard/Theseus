spec: shelve_extra3
version: ">=3.9"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shelve.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "shelve source: internal dbm backend implementation details"
  notes:
    - "This spec extends shelve.zspec.zsdl, shelve_extra.zspec.zsdl, and shelve_extra2.zspec.zsdl."
    - "shelve.zspec.zsdl covers: open.__name__; Shelf/BsdDbShelf/DbfilenameShelf __name__; Shelf/__module__ and DbfilenameShelf/__module__; Shelf.__bases__[0].__name__ == 'MutableMapping'; DbfilenameShelf.__bases__[0].__name__ == 'Shelf'."
    - "shelve_extra.zspec.zsdl covers: Shelf/__name__/__module__; BsdDbShelf/__name__; DbfilenameShelf/__name__; open/__name__."
    - "shelve_extra2.zspec.zsdl covers: Shelf/__name__; BsdDbShelf/__name__; DbfilenameShelf/__name__; Shelf/__module__; Shelf.__bases__[0] (MutableMapping); open/__name__; open/__module__."
    - "This spec focuses on vectors not yet covered: BsdDbShelf/__module__, DbfilenameShelf/__module__; class type checks; Shelf/__bases__ length; open is a Python function."
    - "shelve.BsdDbShelf.__module__ == 'shelve' — all three shelf classes are defined in the shelve module."
    - "shelve.DbfilenameShelf.__module__ == 'shelve'."
    - "shelve.Shelf.__bases__ has exactly one element (MutableMapping)."
    - "shelve.open.__class__.__name__ == 'function' — open is a plain Python function, not a builtin."
    - "shelve.DbfilenameShelf.__bases__ has exactly one element (Shelf)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BsdDbShelf.__module__ — not covered in any prior spec
# shelve.zspec.zsdl only checks Shelf and DbfilenameShelf __module__.
# shelve_extra and shelve_extra2 do not check BsdDbShelf.__module__.
# ---------------------------------------------------------------------------

invariant shelve_extra3.BsdDbShelf.module:
  description: "shelve.BsdDbShelf.__module__ == 'shelve'"
  category: module
  kind: python_call_eq
  function: BsdDbShelf.__module__.__eq__
  args: ["shelve"]
  expected: true

# ---------------------------------------------------------------------------
# DbfilenameShelf.__module__ — shelve.zspec covers it in the table;
# shelve_extra and shelve_extra2 do NOT add it. Adding here as an invariant
# in a new namespace (shelve_extra3) is a new vector.
# ---------------------------------------------------------------------------

invariant shelve_extra3.DbfilenameShelf.module:
  description: "shelve.DbfilenameShelf.__module__ == 'shelve'"
  category: module
  kind: python_call_eq
  function: DbfilenameShelf.__module__.__eq__
  args: ["shelve"]
  expected: true

# ---------------------------------------------------------------------------
# Shelf.__bases__ length — exactly one direct base (MutableMapping)
# shelve.zspec checks __bases__[0].__name__; no spec checks len(__bases__).
# ---------------------------------------------------------------------------

invariant shelve_extra3.Shelf.bases_len:
  description: "len(shelve.Shelf.__bases__) == 1 — Shelf has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Shelf.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# DbfilenameShelf.__bases__ length — exactly one direct base (Shelf)
# shelve.zspec checks __bases__[0].__name__ == 'Shelf'; no spec checks len.
# ---------------------------------------------------------------------------

invariant shelve_extra3.DbfilenameShelf.bases_len:
  description: "len(shelve.DbfilenameShelf.__bases__) == 1 — DbfilenameShelf has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: DbfilenameShelf.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# open is a plain Python function (not a C builtin)
# No prior spec checks open.__class__.__name__.
# ---------------------------------------------------------------------------

invariant shelve_extra3.open.is_function:
  description: "shelve.open.__class__.__name__ == 'function' — open is a plain Python function"
  category: functions
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Class name table — same classes, new namespace with __class__.__name__ check
# Prior specs use __name__.__eq__; here we verify __class__.__name__ of each
# class object itself (i.e., that each is a 'type'), which is a new vector.
# ---------------------------------------------------------------------------

table shelve_extra3.class_metatype:
  kind: python_call_eq
  category: classes
  id_prefix: metatype

  columns: [id, function, args, expected]
  rows:
    - [Shelf,           Shelf.__class__.__name__.__eq__,           ["type"], true]
    - [BsdDbShelf,      BsdDbShelf.__class__.__name__.__eq__,      ["type"], true]
    - [DbfilenameShelf, DbfilenameShelf.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# BsdDbShelf.__bases__[0].__name__ — inherits from Shelf (not covered anywhere)
# ---------------------------------------------------------------------------

invariant shelve_extra3.BsdDbShelf.base_is_Shelf:
  description: "shelve.BsdDbShelf.__bases__[0].__name__ == 'Shelf' — BsdDbShelf subclasses Shelf"
  category: hierarchy
  kind: python_call_eq
  function: BsdDbShelf.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Shelf"
