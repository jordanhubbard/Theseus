spec: lodash_isequal
version: ">=4.0.0"
backend: node(lodash.isequal)

docs: https://lodash.com/docs/#isEqual

provenance:
  derived_from:
    - "lodash.isequal README — https://www.npmjs.com/package/lodash.isequal"
    - "Test vectors verified with lodash.isequal@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isequal exports the _.isEqual function directly as module.exports."
    - "isEqual performs deep comparison between two values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isequal.isequal:
  kind: node_module_call_eq
  function: ~
  category: isequal
  id_prefix: lieq

  columns: [id, args, expected]
  rows:
    - [obj_eq,     [{"a": 1, "b": 2}, {"a": 1, "b": 2}],   true]
    - [obj_neq,    [{"a": 1}, {"a": 2}],                    false]
    - [arr_eq,     [[1, 2, 3], [1, 2, 3]],                  true]
    - [arr_neq,    [[1, 2], [1, 3]],                        false]
    - [nested_eq,  [{"a": {"b": 1}}, {"a": {"b": 1}}],      true]
    - [nested_neq, [{"a": {"b": 1}}, {"a": {"b": 2}}],      false]
