# ---------------------------------------------------------------------------

table concurrent_futures_extra65.ProcessPoolExecutor_identity:
  description: "concurrent.futures ProcessPoolExecutor class identity checks in cfkw65 namespace — wave 234 theme: ProcessPoolExecutor identity; ProcessPoolExecutor.__name__=='ProcessPoolExecutor'; ProcessPoolExecutor.__module__=='concurrent.futures.process' (defined in Lib/concurrent/futures/process.py); ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor'; NEW in extra65: first __name__/__module__/__qualname__ string equality checks for ProcessPoolExecutor in the cfkw65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfkw65b

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name,     ProcessPoolExecutor.__name__.__eq__,     ["ProcessPoolExecutor"],        true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — ProcessPoolExecutor is a top-level class; its __name__ attribute is the simple class name 'ProcessPoolExecutor'; NEW in extra65: first __name__.__eq__ check for ProcessPoolExecutor in the cfkw65 namespace; verified with Python 3.14.3"]
    - [ppe_module,   ProcessPoolExecutor.__module__.__eq__,   ["concurrent.futures.process"], true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; the module sets its __name__ to 'concurrent.futures.process'; ProcessPoolExecutor.__module__ is 'concurrent.futures.process'; NEW in extra65: first __module__.__eq__ check for ProcessPoolExecutor in the cfkw65 namespace; verified with Python 3.14.3"]
    - [ppe_qualname, ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"],        true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — ProcessPoolExecutor is a top-level class in concurrent.futures.process; its qualified name is simply 'ProcessPoolExecutor'; __qualname__.__eq__('ProcessPoolExecutor') returns True; NEW in extra65: first __qualname__.__eq__ check for ProcessPoolExecutor in the cfkw65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Executor and Future identity checks — extra65
#
# Wave 234 theme: Executor and Future class identity.
#
# Executor.__name__ == 'Executor'
# Executor.__module__ == 'concurrent.futures._base'
# Future.__name__ == 'Future'
# Future.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra65.Executor_Future_identity:
  description: "concurrent.futures Executor/__name__/__module__ and Future/__name__/__module__ string equality checks in cfkw65 namespace — wave 234 theme: Executor and Future identity; Executor.__name__=='Executor'; Executor.__module__=='concurrent.futures._base'; Future.__name__=='Future'; Future.__module__=='concurrent.futures._base'; both are defined in Lib/concurrent/futures/_base.py; NEW in extra65: first __name__/__module__ string equality checks for Executor and __name__/__module__ equality checks for Future in the cfkw65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfkw65c

  columns: [id, function, args, expected, description]
  rows:
    - [executor_name,   Executor.__name__.__eq__,   ["Executor"],                    true, "Executor.__name__ == 'Executor' — Executor is a top-level abstract base class; its __name__ attribute is the simple class name 'Executor'; NEW in extra65: first __name__.__eq__ check for Executor in the cfkw65 namespace; verified with Python 3.14.3"]
    - [executor_module, Executor.__module__.__eq__,  ["concurrent.futures._base"],   true, "Executor.__module__ == 'concurrent.futures._base' — Executor is defined in Lib/concurrent/futures/_base.py; the module sets its __name__ to 'concurrent.futures._base'; Executor.__module__ is 'concurrent.futures._base'; NEW in extra65: first __module__.__eq__ check for Executor in the cfkw65 namespace; verified with Python 3.14.3"]
    - [future_name,     Future.__name__.__eq__,     ["Future"],                      true, "Future.__name__ == 'Future' — Future is a top-level class; its __name__ attribute is the simple class name 'Future'; NEW in extra65: first __name__.__eq__ check for Future in the cfkw65 namespace; verified with Python 3.14.3"]
    - [future_module,   Future.__module__.__eq__,    ["concurrent.futures._base"],   true, "Future.__module__ == 'concurrent.futures._base' — Future is defined in Lib/concurrent/futures/_base.py; the module sets its __name__ to 'concurrent.futures._base'; Future.__module__ is 'concurrent.futures._base'; NEW in extra65: first __module__.__eq__ check for Future in the cfkw65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra65.wait_kwdefaults_NoneType:
  description: "concurrent.futures.wait.__kwdefaults__.__class__.__name__.__eq__('NoneType') returns True — wait(fs, timeout=None, return_when=ALL_COMPLETED) has all positional-or-keyword parameters with no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra65: first standalone __kwdefaults__.__class__.__name__.__eq__('NoneType') invariant for wait in the cfkw65 namespace; wave 234 first __kwdefaults__ NoneType identity invariant for wait; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: wait.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant concurrent_futures_extra65.ThreadPoolExecutor_module_cf_thread:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; the module sets its __name__ to 'concurrent.futures.thread'; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread'; NEW in extra65: first standalone __module__.__eq__ invariant for ThreadPoolExecutor in the cfkw65 namespace; wave 234 first module identity invariant for ThreadPoolExecutor; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra65.ProcessPoolExecutor_module_cf_process:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; the module sets its __name__ to 'concurrent.futures.process'; ProcessPoolExecutor.__module__ is 'concurrent.futures.process'; NEW in extra65: first standalone __module__.__eq__ invariant for ProcessPoolExecutor in the cfkw65 namespace; wave 234 first module identity invariant for ProcessPoolExecutor; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra65.Executor_module_cf_base:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — Executor is defined in Lib/concurrent/futures/_base.py; the module sets its __name__ to 'concurrent.futures._base'; Executor.__module__ is 'concurrent.futures._base'; NEW in extra65: first standalone __module__.__eq__ invariant for Executor in the cfkw65 namespace; wave 234 first module identity invariant for Executor; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra65.Future_module_cf_base:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — Future is defined in Lib/concurrent/futures/_base.py; the module sets its __name__ to 'concurrent.futures._base'; Future.__module__ is 'concurrent.futures._base'; NEW in extra65: first standalone __module__.__eq__ invariant for Future in the cfkw65 namespace; wave 234 first module identity invariant for Future; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
