spec: d3_geo
version: ">=3.0.0"
backend: node(d3-geo)

docs: https://d3js.org/d3-geo/

provenance:
  derived_from:
    - "d3-geo documentation — https://d3js.org/d3-geo/"
    - "Test vectors verified with d3-geo via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "d3-geo source"
  notes:
    - "Spherical geometry primitives + Mercator/Albers/etc. projections (Mike Bostock)."
    - "Install: npm install d3-geo"
    - "Areas and lengths are returned in steradians and radians respectively (unit-sphere geodesics) — multiply by Earth radius squared/once for SI units."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on valid GeoJSON-like inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# geoArea — full sphere area in steradians
invariant d3_geo.area_full_sphere:
  description: "Area of the full sphere is 4π steradians (≈ 12.566370614)"
  category: area
  kind: node_chain_eq
  entry: named
  function: geoArea
  entry_args: [{type: "Sphere"}]
  chain:
    - {method: toFixed, args: [9]}
  expected: "12.566370614"

# geoLength — equator from 0 to 180° E is π radians (half a great circle)
invariant d3_geo.length_half_equator_is_pi:
  description: "Great-circle length from (0,0) to (180,0) is π radians (half-circumference)"
  category: length
  kind: node_chain_eq
  entry: named
  function: geoLength
  entry_args: [{type: "LineString", coordinates: [[0, 0], [180, 0]]}]
  chain:
    - {method: toFixed, args: [9]}
  expected: "3.141592654"

invariant d3_geo.length_quarter_equator:
  description: "Great-circle length from (0,0) to (90,0) is π/2"
  category: length
  kind: node_chain_eq
  entry: named
  function: geoLength
  entry_args: [{type: "LineString", coordinates: [[0, 0], [90, 0]]}]
  chain:
    - {method: toFixed, args: [9]}
  expected: "1.570796327"

# geoCentroid — single point is its own centroid
invariant d3_geo.centroid_single_point:
  description: "Centroid of a single Point is itself"
  category: centroid
  kind: node_chain_eq
  entry: named
  function: geoCentroid
  entry_args: [{type: "Point", coordinates: [10, 20]}]
  chain: []
  expected: [10, 20]

# Mercator projection at origin — center of default 960×500 viewport
invariant d3_geo.mercator_origin_x:
  description: "Default Mercator at origin (0,0) projects to viewport center x=480"
  category: mercator
  kind: node_chain_eq
  entry: named
  function: geoMercator
  entry_args: []
  chain:
    - {call: [[0, 0]]}
    - {method: at, args: [0]}
  expected: 480

invariant d3_geo.mercator_origin_y:
  description: "Default Mercator at origin (0,0) projects to viewport center y=250"
  category: mercator
  kind: node_chain_eq
  entry: named
  function: geoMercator
  entry_args: []
  chain:
    - {call: [[0, 0]]}
    - {method: at, args: [1]}
  expected: 250

# geoDistance — spherical distance in radians (point-to-point)
invariant d3_geo.distance_quarter_equator:
  description: "Distance from (0,0) to (90,0) is π/2 radians"
  category: distance
  kind: node_chain_eq
  entry: named
  function: geoDistance
  entry_args: [[0, 0], [90, 0]]
  chain:
    - {method: toFixed, args: [9]}
  expected: "1.570796327"

invariant d3_geo.distance_pole_to_equator:
  description: "Distance from (0,90) to (0,0) is π/2 radians"
  category: distance
  kind: node_chain_eq
  entry: named
  function: geoDistance
  entry_args: [[0, 90], [0, 0]]
  chain:
    - {method: toFixed, args: [9]}
  expected: "1.570796327"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T16:51:53Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
