spec: ejs
version: ">=3.0.0"
backend: node(ejs)

docs: https://ejs.co/

provenance:
  derived_from:
    - "EJS documentation — https://ejs.co/"
    - "Test vectors verified with ejs via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ejs source"
  notes:
    - "ejs is an npm package. Install: npm install ejs"
    - "ejs.render(template, data) renders an EJS template string with the given data."
    - "<%= val %> outputs HTML-escaped value; <%- val %> outputs raw unescaped value."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns rendered string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ejs.render:
  kind: node_module_call_eq
  function: render
  category: render
  id_prefix: ejsr

  columns: [id, args, expected]
  rows:
    - [basic,    ["Hello <%= name %>!", {"name": "World"}],    "Hello World!"]
    - [expr,     ["<%= 2 + 2 %>", {}],                         "4"]
    - [escaped,  ["<%= val %>", {"val": "<b>"}],               "&lt;b&gt;"]
    - [raw,      ["<%- val %>", {"val": "<b>"}],               "<b>"]
    - [cond,     ["<% if (x > 0) { %>pos<% } else { %>neg<% } %>", {"x": 1}], "pos"]
