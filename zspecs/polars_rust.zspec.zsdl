spec: polars_rust
version: ">=3.9"
backend: rust_module(polars_rust)

docs: https://docs.pola.rs/

provenance:
  derived_from:
    - "https://docs.pola.rs/ — Polars documentation"
  not_derived_from:
    - "polars source: polars/frame/frame.py"
  notes:
    - "Polars is a fast DataFrame library implemented in Rust."
    - "pl.Series([1, 2, 3]).sum() == 6."
    - "pl.Series([1, 2, 3]).mean() == 2.0."
    - "pl.Series([1, 2, 3]).len() == 3."
    - "pl.Series([1, 2, 3]).max() == 3, pl.Series([1, 2, 3]).min() == 1."
    - "Expose series_sum(lst) -> int/float: pl.Series(lst).sum()."
    - "Expose series_mean(lst) -> float: pl.Series(lst).mean()."
    - "Expose series_len(lst) -> int: pl.Series(lst).len()."
    - "Expose series_max(lst) -> any: pl.Series(lst).max()."
    - "Expose series_min(lst) -> any: pl.Series(lst).min()."
    - "All test vectors verified against polars 1.26.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# series_sum — sum of series elements
table polars_rust.series.sum:
  kind: python_call_eq
  category: sum
  id_prefix: pl_sum
  function: series_sum

  columns: [id, args, expected]
  rows:
    - [three,  [[1, 2, 3]], 6]
    - [zero,   [[0, 0, 0]], 0]
    - [single, [[42]],      42]

# series_len — length of series
table polars_rust.series.length:
  kind: python_call_eq
  category: length
  id_prefix: pl_len
  function: series_len

  columns: [id, args, expected]
  rows:
    - [three, [[1, 2, 3]], 3]
    - [empty, [[]],        0]
    - [five,  [[1, 2, 3, 4, 5]], 5]

# series_mean — mean of series
invariant polars_rust.series.mean_three:
  description: "pl.Series([1,2,3]).mean() == 2.0"
  category: mean
  kind: python_call_eq
  function: series_mean
  args: [[1, 2, 3]]
  expected: 2.0

# series_max/min — extremes
invariant polars_rust.series.max:
  description: "pl.Series([1,2,3]).max() == 3"
  category: extremes
  kind: python_call_eq
  function: series_max
  args: [[1, 2, 3]]
  expected: 3

invariant polars_rust.series.min:
  description: "pl.Series([1,2,3]).min() == 1"
  category: extremes
  kind: python_call_eq
  function: series_min
  args: [[1, 2, 3]]
  expected: 1

