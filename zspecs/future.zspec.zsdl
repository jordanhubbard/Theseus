spec: future
version: ">=3.0"
backend: python_module(__future__)

docs: https://docs.python.org/3/library/__future__.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/__future__.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "__future__ source: Lib/__future__.py (PSF; source inspection permitted)"
  not_derived_from:
    - "__future__: compiler integration internals (handled by the CPython parser)"
  notes:
    - "__future__ provides definitions for optional compiler features enabled via 'from __future__ import' statements."
    - "_Feature is the class representing each future feature; instances carry compiler_flag and optional_release."
    - "all_feature_names is a list of str naming every feature exported by the module."
    - "Features in all_feature_names include: 'generators', 'division', 'absolute_import', 'with_statement',"
    - "  'print_function', 'unicode_literals', 'barry_as_FLUFL', 'generator_stop', 'annotations'."
    - "Each feature name is also a module-level attribute bound to a _Feature instance."
    - "annotations enables PEP 563 postponed evaluation of annotations (Py 3.7+)."
    - "All expected values verified by running Python 3.12 __future__ module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "No public functions. All invariants are attribute accesses on module-level data."
  stderr: "null"
  stickiness: "N/A — module-level attribute reads are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# _Feature class name and module checks
# ---------------------------------------------------------------------------

invariant future._Feature_name:
  description: "_Feature.__name__ == '_Feature'"
  category: classnames
  kind: python_call_eq
  function: _Feature.__name__.__eq__
  args: ["_Feature"]
  expected: true

invariant future._Feature_module:
  description: "_Feature.__module__ == '__future__'"
  category: classnames
  kind: python_call_eq
  function: _Feature.__module__.__eq__
  args: ["__future__"]
  expected: true

# ---------------------------------------------------------------------------
# all_feature_names type and content checks
# ---------------------------------------------------------------------------

invariant future.all_feature_names_is_list:
  description: "all_feature_names.__class__.__name__ == 'list'"
  category: attributes
  kind: python_call_eq
  function: all_feature_names.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant future.all_feature_names_nonempty:
  description: "all_feature_names is non-empty"
  category: attributes
  kind: python_call_eq
  function: all_feature_names.__len__
  args: []
  expected_gt: 0

table future.all_feature_names.contains:
  kind: python_call_eq
  category: feature_names
  id_prefix: contains

  columns: [id, function, args, expected]
  rows:
    - [print_function,  all_feature_names.__contains__, ["print_function"],  true]
    - [division,        all_feature_names.__contains__, ["division"],        true]
    - [generators,      all_feature_names.__contains__, ["generators"],      true]
    - [annotations,     all_feature_names.__contains__, ["annotations"],     true]

# ---------------------------------------------------------------------------
# Individual _Feature instance checks
# ---------------------------------------------------------------------------

invariant future.annotations_is_Feature:
  description: "annotations.__class__.__name__ == '_Feature'"
  category: instances
  kind: python_call_eq
  function: annotations.__class__.__name__.__eq__
  args: ["_Feature"]
  expected: true

invariant future.division_is_Feature:
  description: "division.__class__.__name__ == '_Feature'"
  category: instances
  kind: python_call_eq
  function: division.__class__.__name__.__eq__
  args: ["_Feature"]
  expected: true

invariant future.print_function_is_Feature:
  description: "print_function.__class__.__name__ == '_Feature'"
  category: instances
  kind: python_call_eq
  function: print_function.__class__.__name__.__eq__
  args: ["_Feature"]
  expected: true
