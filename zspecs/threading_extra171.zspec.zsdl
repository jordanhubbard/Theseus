spec: threading_extra171
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread.__name__ 'Thread'; threading.Thread.__module__ 'threading'; threading.Thread.__bases__[0].__name__ 'object'; threading.Thread.__dict__.__contains__('start') True; threading.Thread.__dict__.__contains__('run') True; threading.Thread.__dict__.__contains__('join') True; threading.Thread.__dict__.__contains__('is_alive') True; threading.Thread.__dict__.__class__.__name__ 'mappingproxy' (Wave 299)."
    - "threading.Thread.__name__ == 'Thread' — threading.Thread is a Python class defined in Lib/threading.py that represents a thread of control; its class __name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' — Thread is defined in Lib/threading.py; its __module__ attribute is 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object' — threading.Thread inherits directly from object; its __bases__ tuple has one element whose __name__ is 'object'. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('start') == True — Thread defines its own 'start' method in its class dict; __dict__.__contains__('start') returns True. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('run') == True — Thread defines its own 'run' method in its class dict; __dict__.__contains__('run') returns True. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('join') == True — Thread defines its own 'join' method in its class dict; __dict__.__contains__('join') returns True. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('is_alive') == True — Thread defines its own 'is_alive' method in its class dict; __dict__.__contains__('is_alive') returns True. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__class__.__name__ == 'mappingproxy' — Thread.__dict__ is a mappingproxy (the read-only view of a class's namespace), not a plain dict; its __class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread Python class identity — __name__, __module__,
# __bases__[0].__name__, __class__.__name__
#
# Wave 299 theme: threading.Thread Python class identity — __name__, __module__,
# __bases__[0].__name__, and __class__.__name__.
#
# threading.Thread.__name__ == 'Thread'
# threading.Thread.__module__ == 'threading'
# threading.Thread.__bases__[0].__name__ == 'object'
# threading.Thread.__class__.__name__ == 'type'
#
# threading.Thread is the primary class in the threading module. It represents
# a thread of control. Each Thread object has start(), run(), join(), and
# is_alive() methods. It is a Python class defined in Lib/threading.py that
# inherits directly from object. New to extra171.
# ---------------------------------------------------------------------------

table threading_extra171.thread_class_identity:
  description: "threading.Thread: __name__ 'Thread', __module__ 'threading', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 299; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtci171

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_Thread,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — threading.Thread is a Python class defined in Lib/threading.py that represents a thread of control; its class __name__ attribute is 'Thread'; str.__eq__('Thread') returns True; new to extra171"]
    - [thread_module_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — threading.Thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra171"]
    - ["thread_bases_0_object",
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — threading.Thread is a Python class that inherits directly from object; its __bases__ tuple has exactly one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra171"]
    - [thread_class_name_type,
       "Thread.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Thread.__class__.__name__.__eq__('type') == True — threading.Thread is a class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.__dict__ contains core lifecycle methods — start,
# run, join, is_alive
#
# Wave 299 theme: threading.Thread defines its own 'start', 'run', 'join', and
# 'is_alive' methods in its class __dict__.
#
# threading.Thread.__dict__.__contains__('start') == True
# threading.Thread.__dict__.__contains__('run') == True
# threading.Thread.__dict__.__contains__('join') == True
# threading.Thread.__dict__.__contains__('is_alive') == True
#
# Thread.__dict__ is the mappingproxy of Thread's own namespace. These four
# methods — start(), run(), join(), and is_alive() — are all defined directly
# in the Thread class body in Lib/threading.py (not inherited). Each is present
# as a key in Thread.__dict__. New to extra171.
# ---------------------------------------------------------------------------

table threading_extra171.thread_dict_lifecycle_methods:
  description: "threading.Thread.__dict__: contains 'start', 'run', 'join', 'is_alive'; wave 299; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdlm171

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_has_start,
       "Thread.__dict__.__contains__",
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — Thread defines its own 'start' method in Lib/threading.py; 'start' is present as a key in Thread.__dict__ (the mappingproxy of Thread's own namespace); __contains__('start') returns True; new to extra171"]
    - [thread_dict_has_run,
       "Thread.__dict__.__contains__",
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — Thread defines its own 'run' method in Lib/threading.py; 'run' is the method that gets called when the thread starts; it is present as a key in Thread.__dict__; __contains__('run') returns True; new to extra171"]
    - [thread_dict_has_join,
       "Thread.__dict__.__contains__",
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — Thread defines its own 'join' method in Lib/threading.py; 'join' blocks the calling thread until the thread whose join() method is called terminates; it is present as a key in Thread.__dict__; __contains__('join') returns True; new to extra171"]
    - [thread_dict_has_is_alive,
       "Thread.__dict__.__contains__",
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — Thread defines its own 'is_alive' method in Lib/threading.py; 'is_alive' returns whether the thread is alive (started and not yet terminated); it is present as a key in Thread.__dict__; __contains__('is_alive') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'
#
# Wave 299 theme: threading.Thread.__dict__ is a mappingproxy, not a plain dict.
#
# threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'
# threading.Thread.__dict__.__class__.__name__ != 'dict'
# threading.Thread.__dict__.__class__.__name__ != 'function'
# threading.Thread.__name__.__class__.__name__ == 'str'
#
# Class objects in Python store their namespace in a read-only mappingproxy
# rather than a plain mutable dict. Thread.__dict__ is this mappingproxy.
# Its __class__.__name__ is 'mappingproxy', not 'dict'. New to extra171.
# ---------------------------------------------------------------------------

table threading_extra171.thread_dict_mappingproxy:
  description: "threading.Thread.__dict__: __class__.__name__ 'mappingproxy' (not 'dict'); wave 299; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdmp171

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_class_mappingproxy,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Thread.__dict__ is the read-only view of Thread's class namespace; Python exposes class __dict__ as a mappingproxy (not a plain mutable dict) to prevent direct modification; its __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra171"]
    - [thread_dict_not_dict,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "threading.Thread.__dict__.__class__.__name__.__eq__('dict') == False — Thread.__dict__ is a mappingproxy, NOT a plain dict; class namespaces are intentionally read-only (mappingproxy) to prevent accidental modification via the __dict__ attribute; str.__eq__('dict') returns False; new to extra171"]
    - [thread_dict_not_function,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["function"],
       false,
       "threading.Thread.__dict__.__class__.__name__.__eq__('function') == False — Thread.__dict__ is a mappingproxy (a mapping type), NOT a function; str.__eq__('function') returns False; new to extra171"]
    - [thread_name_class_str,
       "Thread.__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Thread.__name__.__class__.__name__.__eq__('str') == True — Thread.__name__ is the string 'Thread'; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.__dict__ does NOT contain inherited or unrelated names
#
# Wave 299 theme: negative checks confirming that Thread.__dict__ does not
# contain names that are not defined directly on Thread (inherited from object)
# or that are simply not Thread attributes.
#
# threading.Thread.__dict__.__contains__('__reduce__') == ?
# threading.Thread.__dict__.__contains__('nonexistent_method') == False
# threading.Thread.__dict__.__contains__('append') == False
# threading.Thread.__dict__.__contains__('is_alive') == True  (cross-check)
#
# 'append' is a list method and has no relation to Thread. 'nonexistent_method'
# is not defined anywhere on Thread. These negative checks confirm that
# Thread.__dict__.__contains__() correctly returns False for absent keys. New to
# extra171.
# ---------------------------------------------------------------------------

table threading_extra171.thread_dict_negative_checks:
  description: "threading.Thread.__dict__: does not contain 'append' or 'nonexistent_method'; is_alive cross-check; wave 299; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdnc171

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_no_append,
       "Thread.__dict__.__contains__",
       ["append"],
       false,
       "threading.Thread.__dict__.__contains__('append') == False — 'append' is a list method and is not defined on threading.Thread; Thread.__dict__ does not contain 'append'; __contains__('append') returns False; new to extra171"]
    - [thread_dict_no_nonexistent,
       "Thread.__dict__.__contains__",
       ["nonexistent_method"],
       false,
       "threading.Thread.__dict__.__contains__('nonexistent_method') == False — 'nonexistent_method' is not defined anywhere on threading.Thread; Thread.__dict__ does not contain 'nonexistent_method'; __contains__('nonexistent_method') returns False; new to extra171"]
    - [thread_dict_is_alive_xcheck,
       "Thread.__dict__.__contains__",
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — cross-check confirming 'is_alive' is present in Thread.__dict__; Thread defines is_alive() directly to test whether the thread is alive; __contains__('is_alive') returns True; new to extra171"]
    - [thread_module_threading_xcheck,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — cross-check confirming Thread.__module__ is 'threading'; Thread is a Python class defined in Lib/threading.py; str.__eq__('threading') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 5: threading.Thread.__name__ and __module__ negative checks;
# cross-check __dict__ proxy vs dict
#
# Wave 299 theme: negative identity checks for Thread — its __name__ is not
# 'thread' (lowercase) or 'Thread_' (with suffix); its __module__ is not
# '_thread' (the C module); and its __dict__ is not a plain dict.
#
# threading.Thread.__name__ != 'thread'
# threading.Thread.__module__ != '_thread'
# threading.Thread.__dict__.__class__.__name__ != 'dict'
# threading.Thread.__bases__[0].__name__ != 'BaseThread'
#
# Thread.__name__ is 'Thread' (capital T), not 'thread'. Thread.__module__ is
# 'threading' (the Python high-level module), not '_thread' (the C extension
# low-level module). Thread.__dict__ is a mappingproxy, not a plain dict.
# Thread.__bases__[0].__name__ is 'object' (no 'BaseThread' base class). New to
# extra171.
# ---------------------------------------------------------------------------

table threading_extra171.thread_negative_identity_checks:
  description: "threading.Thread: __name__ != 'thread', __module__ != '_thread', __dict__ not 'dict', __bases__[0] not 'BaseThread'; wave 299; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtnic171

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_not_lowercase,
       "Thread.__name__.__eq__",
       ["thread"],
       false,
       "threading.Thread.__name__.__eq__('thread') == False — Thread.__name__ is 'Thread' (capital T), not 'thread' (lowercase); the class name is capitalized per Python convention for classes; str.__eq__('thread') returns False; new to extra171"]
    - [thread_module_not_cthread,
       "Thread.__module__.__eq__",
       ["_thread"],
       false,
       "threading.Thread.__module__.__eq__('_thread') == False — Thread.__module__ is 'threading' (the high-level Python module), NOT '_thread' (the low-level C extension module); str.__eq__('_thread') returns False; new to extra171"]
    - [thread_dict_class_not_dict,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "threading.Thread.__dict__.__class__.__name__.__eq__('dict') == False — Thread.__dict__ is a mappingproxy, not a plain mutable dict; Python makes class __dict__ a read-only mappingproxy; str.__eq__('dict') returns False; new to extra171"]
    - ["thread_bases_0_not_basethread",
       "Thread.__bases__[0].__name__.__eq__",
       ["BaseThread"],
       false,
       "threading.Thread.__bases__[0].__name__.__eq__('BaseThread') == False — Thread inherits directly from object, not from any 'BaseThread' class; there is no 'BaseThread' in threading's inheritance chain; str.__eq__('BaseThread') returns False; new to extra171"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant threading_extra171.thread_name_eq:
  description: "threading.Thread.__name__ == 'Thread' — Python class representing a thread of control in the threading module; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra171.thread_module_threading:
  description: "threading.Thread.__module__ == 'threading' — Thread is defined in Lib/threading.py; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra171.thread_bases_0_object:
  description: "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object; wave 299; new to extra171"
  kind: python_call_eq
  function: "Thread.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra171.thread_dict_has_start:
  description: "threading.Thread.__dict__.__contains__('start') == True — Thread defines its own 'start' method; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["start"]
  expected: true

invariant threading_extra171.thread_dict_has_run:
  description: "threading.Thread.__dict__.__contains__('run') == True — Thread defines its own 'run' method; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["run"]
  expected: true

invariant threading_extra171.thread_dict_has_join:
  description: "threading.Thread.__dict__.__contains__('join') == True — Thread defines its own 'join' method; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["join"]
  expected: true

invariant threading_extra171.thread_dict_has_is_alive:
  description: "threading.Thread.__dict__.__contains__('is_alive') == True — Thread defines its own 'is_alive' method; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["is_alive"]
  expected: true

invariant threading_extra171.thread_dict_mappingproxy:
  description: "threading.Thread.__dict__.__class__.__name__ == 'mappingproxy' — Thread's class namespace is exposed as a read-only mappingproxy, not a plain dict; wave 299; new to extra171"
  kind: python_call_eq
  function: Thread.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

