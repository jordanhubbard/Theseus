spec: hashlib_extra1171
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.__all__ __contains__ for 'new'/'md5'/'sha1'/'sha256'/'sha512', hashlib.__all__ __len__, HASH instance name property values for md5/sha256/sha512, hashlib.md5/sha256/sha512 block_size values, and hashlib.__all__ class name"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1171.all_contains_and_len:
  description: "hashlib.__all__ __contains__ membership checks for expected names and __len__ count"
  kind: python_call_eq
  category: all_contains_len
  id_prefix: hl1171al
  columns: [id, function, args, expected]
  rows:
    - [hl1171al001, hashlib.__all__.__contains__,                              ["new"],       true]
    - [hl1171al002, hashlib.__all__.__contains__,                              ["md5"],       true]
    - [hl1171al003, hashlib.__all__.__contains__,                              ["sha1"],      true]
    - [hl1171al004, hashlib.__all__.__contains__,                              ["sha256"],    true]
    - [hl1171al005, hashlib.__all__.__contains__,                              ["sha512"],    true]
    - [hl1171al006, hashlib.__all__.__len__,                                   [],            4]
    - [hl1171al007, hashlib.__all__.__class__.__name__.__eq__,                 ["list"],      true]
    - [hl1171al008, hashlib.__all__.__class__.__qualname__.__eq__,             ["list"],      true]
    - [hl1171al009, hashlib.__all__.__class__.__module__.__eq__,               ["builtins"],  true]
    - [hl1171al010, hashlib.__all__.__class__.__name__.__class__.__name__.__eq__, ["str"],    true]

table hashlib_extra1171.hash_instance_name_property:
  description: "HASH instance name property values for md5, sha256, sha512 and name property class attrs"
  kind: python_call_eq
  category: hash_instance_name_property
  id_prefix: hl1171nm
  columns: [id, function, args, expected]
  rows:
    - [hl1171nm001, hashlib.md5().name.__eq__,                                 ["md5"],       true]
    - [hl1171nm002, hashlib.sha256().name.__eq__,                              ["sha256"],    true]
    - [hl1171nm003, hashlib.sha512().name.__eq__,                              ["sha512"],    true]
    - [hl1171nm004, hashlib.md5().name.__class__.__name__.__eq__,              ["str"],       true]
    - [hl1171nm005, hashlib.sha256().name.__class__.__name__.__eq__,           ["str"],       true]
    - [hl1171nm006, hashlib.sha512().name.__class__.__name__.__eq__,           ["str"],       true]
    - [hl1171nm007, hashlib.md5().name.__class__.__qualname__.__eq__,          ["str"],       true]
    - [hl1171nm008, hashlib.sha256().name.__class__.__module__.__eq__,         ["builtins"],  true]
    - [hl1171nm009, hashlib.sha512().name.__class__.__module__.__eq__,         ["builtins"],  true]

table hashlib_extra1171.hash_block_size_values:
  description: "HASH instance block_size values for md5, sha256, sha512 and class name of block_size"
  kind: python_call_eq
  category: hash_block_size_values
  id_prefix: hl1171bs
  columns: [id, function, args, expected]
  rows:
    - [hl1171bs001, hashlib.md5().block_size.__eq__,                           [64],          true]
    - [hl1171bs002, hashlib.sha256().block_size.__eq__,                        [64],          true]
    - [hl1171bs003, hashlib.sha512().block_size.__eq__,                        [128],         true]
    - [hl1171bs004, hashlib.md5().block_size.__class__.__name__.__eq__,        ["int"],       true]
    - [hl1171bs005, hashlib.sha256().block_size.__class__.__name__.__eq__,     ["int"],       true]
    - [hl1171bs006, hashlib.sha512().block_size.__class__.__name__.__eq__,     ["int"],       true]
    - [hl1171bs007, hashlib.md5().block_size.__class__.__qualname__.__eq__,    ["int"],       true]
    - [hl1171bs008, hashlib.sha256().block_size.__class__.__module__.__eq__,   ["builtins"],  true]
    - [hl1171bs009, hashlib.sha512().block_size.__class__.__module__.__eq__,   ["builtins"],  true]
