spec: coverage_rust
version: ">=3.9"
backend: rust_module(coverage_rust)

docs: https://coverage.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://coverage.readthedocs.io/en/latest/ — coverage.py documentation"
  not_derived_from:
    - "coverage source: coverage/__init__.py"
  notes:
    - "coverage.py measures code coverage for Python."
    - "coverage.__version__ is a non-empty string."
    - "coverage.Coverage is available."
    - "coverage.Coverage.__name__ == 'Coverage'."
    - "int(coverage.__version__.split('.')[0]) >= 7."
    - "Expose coverage_version_nonempty() -> bool: len(coverage.__version__) > 0."
    - "Expose coverage_class_name() -> str: coverage.Coverage.__name__."
    - "Expose coverage_version_major() -> int: int(coverage.__version__.split('.')[0])."
    - "All test vectors verified against coverage 7.8.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# coverage_version_nonempty — version non-empty
invariant coverage_rust.version.nonempty:
  description: "coverage.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: coverage_version_nonempty
  args: []
  expected: true

# coverage_class_name — Coverage class name
invariant coverage_rust.class.name:
  description: "coverage.Coverage.__name__ == 'Coverage'"
  category: class
  kind: python_call_eq
  function: coverage_class_name
  args: []
  expected: "Coverage"

# coverage_version_major — major version >= 7
invariant coverage_rust.version.major_ge7:
  description: "coverage major version >= 7"
  category: version
  kind: python_call_eq
  function: coverage_version_major
  args: []
  expected: 7

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:09:35Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
