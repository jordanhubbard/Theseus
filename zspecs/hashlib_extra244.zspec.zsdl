spec: hashlib_extra244
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra27.zspec.zsdl — covers HASH instance method __qualname__ for update/digest/hexdigest/copy via md5() and sha256(); sha256().block_size/__class__.__name__; sha256().digest_size/__class__.__name__."
    - "hashlib_extra243.zspec.zsdl — covers sha512 hexdigest/digest_size/block_size via python_call_eq; hashlib.new() constructor variants."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name."
    - "hashlib_extra14.zspec.zsdl — covers sha256().copy() name/digest_size/block_size."
  notes:
    - "This spec covers sha256 hash object method __name__ identity contracts via python_call_eq."
    - "hashlib_extra27 covers __qualname__ for update/digest/hexdigest/copy via method: chains; this spec covers __name__ (not __qualname__) as the orthogonal dimension."
    - "sha256().update.__name__ == 'update' — HASH instance methods have plain names matching their identifier. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().digest.__name__ == 'digest' — verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().hexdigest.__name__ == 'hexdigest' — verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().copy.__name__ == 'copy' — verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().update.__qualname__ == 'HASH.update' — len 11. hashlib_extra27 covers this via sha256(); this spec provides a grouped table in the extra244 namespace."
    - "sha256().digest.__qualname__ == 'HASH.digest' — len 11."
    - "sha256().hexdigest.__qualname__ == 'HASH.hexdigest' — len 14."
    - "sha256().copy.__qualname__ == 'HASH.copy' — len 9."
    - "sha256().digest_size == 32 — FIPS 180-4: SHA-256 produces a 256-bit (32-byte) digest."
    - "sha256().block_size == 64 — FIPS 180-4: SHA-256 uses a 512-bit (64-byte) block."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names. Hash object method name attributes are read-only and never raise."
  stderr: "null"
  stickiness: "N/A — hash object method identity attributes are read-only."
  codes: {}

# ---------------------------------------------------------------------------
# sha256 hash object method __name__ identity
# hashlib_extra27 covers __qualname__ via method: chains; this table covers
# the __name__ attribute (plain short name) for each HASH instance method.
# All four core HASH methods — update, digest, hexdigest, copy — have
# __name__ equal to the bare method name (no class prefix).
# ---------------------------------------------------------------------------

table hashlib_extra244.sha256.method_names:
  description: "sha256() HASH instance method __name__ values — update/digest/hexdigest/copy; novel __name__ dimension (extra27 covers __qualname__)"
  kind: python_call_eq
  category: method_identity
  id_prefix: hl244obj
  function: sha256

  columns: [id, args, method, method_args, expected]
  rows:
    - [update_name,    [], update.__name__.__eq__,    ["update"],    true]
    - [digest_name,    [], digest.__name__.__eq__,    ["digest"],    true]
    - [hexdigest_name, [], hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [copy_name,      [], copy.__name__.__eq__,      ["copy"],      true]

# ---------------------------------------------------------------------------
# sha256 hash object method __qualname__ — grouped in extra244 namespace
# hashlib_extra27 covers these individually as standalone invariants;
# this table groups them in the extra244 namespace for co-location with
# __name__ checks above.
# ---------------------------------------------------------------------------

table hashlib_extra244.sha256.method_qualnames:
  description: "sha256() HASH instance method __qualname__ values — grouped table in extra244 namespace; extra27 covers individually"
  kind: python_call_eq
  category: method_identity
  id_prefix: hl244obj
  function: sha256

  columns: [id, args, method, method_args, expected]
  rows:
    - [update_qualname,    [], update.__qualname__.__eq__,    ["HASH.update"],    true]
    - [digest_qualname,    [], digest.__qualname__.__eq__,    ["HASH.digest"],    true]
    - [hexdigest_qualname, [], hexdigest.__qualname__.__eq__, ["HASH.hexdigest"], true]
    - [copy_qualname,      [], copy.__qualname__.__eq__,      ["HASH.copy"],      true]

# ---------------------------------------------------------------------------
# sha256 hash object method __qualname__ lengths
# Lengths: 'HASH.update'=11, 'HASH.digest'=11, 'HASH.hexdigest'=14, 'HASH.copy'=9
# ---------------------------------------------------------------------------

table hashlib_extra244.sha256.method_qualname_lengths:
  description: "sha256() HASH instance method __qualname__.__len__() — 'HASH.update'=11, 'HASH.digest'=11, 'HASH.hexdigest'=14, 'HASH.copy'=9"
  kind: python_call_eq
  category: method_identity
  id_prefix: hl244obj
  function: sha256

  columns: [id, args, method, method_args, expected]
  rows:
    - [update_qualname_len,    [], update.__qualname__.__len__,    [], 11]
    - [digest_qualname_len,    [], digest.__qualname__.__len__,    [], 11]
    - [hexdigest_qualname_len, [], hexdigest.__qualname__.__len__, [], 14]
    - [copy_qualname_len,      [], copy.__qualname__.__len__,      [], 9]

# ---------------------------------------------------------------------------
# sha256 digest_size == 32 and block_size == 64
# FIPS 180-4: SHA-256 produces 256 bits = 32 bytes; block size is 512 bits = 64 bytes.
# hashlib_extra17 covers sha256 block_size value as standalone invariant;
# this spec groups both in the extra244 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra244.sha256.digest_size:
  description: "hashlib.sha256().digest_size == 32 — FIPS 180-4: SHA-256 produces 256 bits = 32 bytes"
  category: hash_properties
  kind: python_call_eq
  function: sha256
  args: []
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra244.sha256.block_size:
  description: "hashlib.sha256().block_size == 64 — FIPS 180-4: SHA-256 processes 512-bit (64-byte) blocks"
  category: hash_properties
  kind: python_call_eq
  function: sha256
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# sha256 name attribute
# sha256().name == 'sha256' — the canonical algorithm name string on this platform.
# ---------------------------------------------------------------------------

invariant hashlib_extra244.sha256.name_attr:
  description: "hashlib.sha256().name == 'sha256' — the canonical algorithm name attribute on this HASH instance"
  category: hash_properties
  kind: python_call_eq
  function: sha256
  args: []
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 method __name__ lengths
# 'update'=6, 'digest'=6, 'hexdigest'=9, 'copy'=4
# ---------------------------------------------------------------------------

invariant hashlib_extra244.sha256.update.name_len:
  description: "hashlib.sha256().update.__name__.__len__() == 6 — len('update') == 6"
  category: method_identity
  kind: python_call_eq
  function: sha256
  args: []
  method: update.__name__.__len__
  method_args: []
  expected: 6

invariant hashlib_extra244.sha256.digest.name_len:
  description: "hashlib.sha256().digest.__name__.__len__() == 6 — len('digest') == 6"
  category: method_identity
  kind: python_call_eq
  function: sha256
  args: []
  method: digest.__name__.__len__
  method_args: []
  expected: 6

invariant hashlib_extra244.sha256.hexdigest.name_len:
  description: "hashlib.sha256().hexdigest.__name__.__len__() == 9 — len('hexdigest') == 9"
  category: method_identity
  kind: python_call_eq
  function: sha256
  args: []
  method: hexdigest.__name__.__len__
  method_args: []
  expected: 9

invariant hashlib_extra244.sha256.copy.name_len:
  description: "hashlib.sha256().copy.__name__.__len__() == 4 — len('copy') == 4"
  category: method_identity
  kind: python_call_eq
  function: sha256
  args: []
  method: copy.__name__.__len__
  method_args: []
  expected: 4
