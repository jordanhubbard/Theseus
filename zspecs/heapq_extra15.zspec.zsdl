spec: heapq_extra15
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
    - "heapq.zspec.zsdl — basic heapq invariants."
    - "heapq_extra.zspec.zsdl through heapq_extra14.zspec.zsdl — prior extras."
  notes:
    - "This spec extends heapq.zspec.zsdl through heapq_extra14.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for all 7 heapq functions; behavioral vectors; name lengths."
    - "This spec adds NEW axes:"
    - "  (1) __module__ invariants distinguishing C-extension (_heapq) vs pure-Python (heapq) functions."
    - "  (2) __qualname__ invariants for the pure-Python functions merge/nlargest/nsmallest."
    - "  (3) Table: __module__ for all 7 functions — C vs Python origin."
    - "heapq.heappush.__module__ == '_heapq' — C extension. Verified Python 3.12 macOS."
    - "heapq.heappop.__module__ == '_heapq' — C extension. Verified."
    - "heapq.heapify.__module__ == '_heapq' — C extension. Verified."
    - "heapq.heapreplace.__module__ == '_heapq' — C extension. Verified."
    - "heapq.heappushpop.__module__ == '_heapq' — C extension. Verified."
    - "heapq.merge.__module__ == 'heapq' — pure Python. Verified."
    - "heapq.nlargest.__module__ == 'heapq' — pure Python. Verified."
    - "heapq.nsmallest.__module__ == 'heapq' — pure Python. Verified."
    - "heapq.merge.__qualname__ == 'merge' — Verified."
    - "heapq.nlargest.__qualname__ == 'nlargest' — Verified."
    - "heapq.nsmallest.__qualname__ == 'nsmallest' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for C-extension functions
#
# heappush, heappop, heapify, heapreplace, and heappushpop are implemented in
# C (_heapqmodule.c) and their __module__ is '_heapq', not 'heapq'.
# Prior specs (extra8) cover __module__ checks; this spec anchors standalone
# invariants for the C-extension subset from the extra15 namespace.
# ---------------------------------------------------------------------------

invariant heapq_extra15.module.heappush_c:
  description: "heapq.heappush.__module__ == '_heapq' — C-extension function"
  category: function_modules
  kind: python_call_eq
  function: heappush.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra15.module.heappop_c:
  description: "heapq.heappop.__module__ == '_heapq' — C-extension function"
  category: function_modules
  kind: python_call_eq
  function: heappop.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra15.module.heapify_c:
  description: "heapq.heapify.__module__ == '_heapq' — C-extension function"
  category: function_modules
  kind: python_call_eq
  function: heapify.__module__.__eq__
  args: ["_heapq"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ and __qualname__ for pure-Python functions
#
# merge, nlargest, and nsmallest are implemented in Lib/heapq.py.
# Their __module__ is 'heapq' (not '_heapq'). __qualname__ equals __name__
# for these top-level functions.
# ---------------------------------------------------------------------------

invariant heapq_extra15.module.merge_python:
  description: "heapq.merge.__module__ == 'heapq' — pure-Python function"
  category: function_modules
  kind: python_call_eq
  function: merge.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra15.module.nlargest_python:
  description: "heapq.nlargest.__module__ == 'heapq' — pure-Python function"
  category: function_modules
  kind: python_call_eq
  function: nlargest.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra15.module.nsmallest_python:
  description: "heapq.nsmallest.__module__ == 'heapq' — pure-Python function"
  category: function_modules
  kind: python_call_eq
  function: nsmallest.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra15.qualname.merge:
  description: "heapq.merge.__qualname__ == 'merge' — top-level function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: merge.__qualname__.__eq__
  args: ["merge"]
  expected: true

invariant heapq_extra15.qualname.nlargest:
  description: "heapq.nlargest.__qualname__ == 'nlargest' — top-level function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: nlargest.__qualname__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra15.qualname.nsmallest:
  description: "heapq.nsmallest.__qualname__ == 'nsmallest' — top-level function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: nsmallest.__qualname__.__eq__
  args: ["nsmallest"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — all 7 heapq functions
#
# Distinguishes C-extension functions (__module__ == '_heapq') from
# pure-Python functions (__module__ == 'heapq'). This table is the first
# in the heapq spec series to capture all 7 functions in a single module view.
# id_prefix hql15 does not conflict with any prior heapq spec.
# ---------------------------------------------------------------------------

table heapq_extra15.module.all_functions:
  description: "__module__ for all 7 heapq functions — C-extension vs pure-Python"
  kind: python_call_eq
  category: function_modules
  id_prefix: hql15

  columns: [id, function, args, expected]
  rows:
    - [heappush_mod,    heappush.__module__.__eq__,    ["_heapq"], true]
    - [heappop_mod,     heappop.__module__.__eq__,     ["_heapq"], true]
    - [heapify_mod,     heapify.__module__.__eq__,     ["_heapq"], true]
    - [heapreplace_mod, heapreplace.__module__.__eq__, ["_heapq"], true]
    - [heappushpop_mod, heappushpop.__module__.__eq__, ["_heapq"], true]
    - [merge_mod,       merge.__module__.__eq__,       ["heapq"],  true]
    - [nlargest_mod,    nlargest.__module__.__eq__,    ["heapq"],  true]
    - [nsmallest_mod,   nsmallest.__module__.__eq__,   ["heapq"],  true]
