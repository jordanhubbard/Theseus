spec: itertools_extra274
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "combinations, permutations, product are all C-level types; __class__.__name__ == 'type'."
    - "combinations.__module__ == 'itertools'; combinations.__name__ == 'combinations' (12 chars)."
    - "permutations.__name__ == 'permutations' (12 chars); product.__name__ == 'product' (7 chars)."
    - "itertools has no __all__; dir(itertools) yields 20 public names on Python 3.14.3."
    - "combinations_with_replacement.__name__ len == 29 — longest name in itertools."
    - "tee.__class__.__name__ == 'builtin_function_or_method' (C function, not a type like combinations)."
    - "filterfalse.__module__ == 'itertools'; groupby.__module__ == 'itertools'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.combinations, permutations, product — class identity
#
# All three are C-level types: __class__.__name__ == 'type'.
# __module__ == 'itertools' for all.
# combinations.__name__ len == 12; permutations.__name__ len == 12; product len == 7.
# ---------------------------------------------------------------------------

table itertools_extra274.combo_perm_product_identity:
  description: "itertools.combinations, permutations, product class identity — __name__, __module__, __class__.__name__; all C-level types; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex274cp

  columns: [id, function, args, expected, description]
  rows:
    - [cb_name_eq,   combinations.__name__.__eq__,            ["combinations"],  true, "itertools.combinations.__name__ == 'combinations' (12 chars); verified with Python 3.14.3"]
    - [cb_name_len,  combinations.__name__.__len__,           [],                12,   "itertools.combinations.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [cb_mod_eq,    combinations.__module__.__eq__,          ["itertools"],     true, "itertools.combinations.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cb_cls_eq,    combinations.__class__.__name__.__eq__,  ["type"],          true, "itertools.combinations.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [pm_name_eq,   permutations.__name__.__eq__,            ["permutations"],  true, "itertools.permutations.__name__ == 'permutations' (12 chars); verified with Python 3.14.3"]
    - [pm_name_len,  permutations.__name__.__len__,           [],                12,   "itertools.permutations.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [pm_mod_eq,    permutations.__module__.__eq__,          ["itertools"],     true, "itertools.permutations.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pm_cls_eq,    permutations.__class__.__name__.__eq__,  ["type"],          true, "itertools.permutations.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [pr_name_eq,   product.__name__.__eq__,                 ["product"],       true, "itertools.product.__name__ == 'product' (7 chars); verified with Python 3.14.3"]
    - [pr_name_len,  product.__name__.__len__,                [],                7,    "itertools.product.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [pr_mod_eq,    product.__module__.__eq__,               ["itertools"],     true, "itertools.product.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pr_cls_eq,    product.__class__.__name__.__eq__,       ["type"],          true, "itertools.product.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools public name count and combinations_with_replacement identity
#
# itertools has no __all__; dir() yields 20 public names on Python 3.14.3.
# combinations_with_replacement.__name__ has 29 chars — longest in itertools.
# filterfalse and groupby are C-level types; tee is a builtin_function_or_method.
# ---------------------------------------------------------------------------

table itertools_extra274.misc_identity:
  description: "itertools.combinations_with_replacement, filterfalse, groupby identity; tee is builtin_function_or_method; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex274mi

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_name_eq,  combinations_with_replacement.__name__.__eq__,           ["combinations_with_replacement"], true, "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (29 chars); verified with Python 3.14.3"]
    - [cwr_name_len, combinations_with_replacement.__name__.__len__,          [],                                 29,   "itertools.combinations_with_replacement.__name__.__len__() == 29 — longest name in itertools; verified with Python 3.14.3"]
    - [cwr_mod_eq,   combinations_with_replacement.__module__.__eq__,         ["itertools"],                      true, "itertools.combinations_with_replacement.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cwr_cls_eq,   combinations_with_replacement.__class__.__name__.__eq__, ["type"],                           true, "itertools.combinations_with_replacement.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ff_name_eq,   filterfalse.__name__.__eq__,                             ["filterfalse"],                    true, "itertools.filterfalse.__name__ == 'filterfalse'; verified with Python 3.14.3"]
    - [ff_mod_eq,    filterfalse.__module__.__eq__,                           ["itertools"],                      true, "itertools.filterfalse.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [gb_name_eq,   groupby.__name__.__eq__,                                 ["groupby"],                        true, "itertools.groupby.__name__ == 'groupby'; verified with Python 3.14.3"]
    - [gb_mod_eq,    groupby.__module__.__eq__,                               ["itertools"],                      true, "itertools.groupby.__module__ == 'itertools'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra274
# ---------------------------------------------------------------------------

invariant itertools_extra274.combinations_class_name_is_combinations:
  description: "itertools.combinations.__name__ == 'combinations' — C-level type name matches its export symbol"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra274.combinations_module_is_itertools:
  description: "itertools.combinations.__module__ == 'itertools' — C-level type is registered under the itertools module"
  category: identity
  kind: python_call_eq
  function: combinations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra274.combinations_class_is_type:
  description: "itertools.combinations.__class__.__name__ == 'type' — combinations is a C-level type, not a Python function"
  category: identity
  kind: python_call_eq
  function: combinations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra274.permutations_class_is_type:
  description: "itertools.permutations.__class__.__name__ == 'type' — permutations is a C-level type"
  category: identity
  kind: python_call_eq
  function: permutations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra274.product_class_is_type:
  description: "itertools.product.__class__.__name__ == 'type' — product is a C-level type"
  category: identity
  kind: python_call_eq
  function: product.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra274.combinations_name_and_permutations_name_same_length:
  description: "itertools.combinations.__name__.__len__() == itertools.permutations.__name__.__len__() == 12 — both names share the same character count"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra274.cwr_name_length_is_29:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — longest name in itertools"
  category: identity
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

invariant itertools_extra274.permutations_first_element:
  description: "itertools.permutations([1,2,3], 2).__next__() == (1,2) — first 2-permutation; tuple normalized to list"
  category: behavior
  kind: python_call_eq
  function: permutations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]
