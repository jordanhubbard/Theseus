spec: to_dot_case
version: ">=1.0.0"
backend: node(to-dot-case)

docs: https://www.npmjs.com/package/to-dot-case

provenance:
  derived_from:
    - "to-dot-case README — https://www.npmjs.com/package/to-dot-case"
    - "Test vectors verified with to-dot-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-dot-case source"
  notes:
    - "to-dot-case is an npm package. Install: npm install to-dot-case"
    - "Converts a string to dot.case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_dot_case.toDotCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: dotcase

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "hello.world"]
    - [camel,   ["fooBar"],       "foo.bar"]
    - [hyphen,  ["foo-bar"],      "foo.bar"]
