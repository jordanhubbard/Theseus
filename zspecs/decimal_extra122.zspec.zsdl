spec: decimal_extra122
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal and decimal.Context class hierarchy and module identity."
    - "decimal.Decimal.__name__ == 'Decimal' (length 7); __qualname__ == 'Decimal'; __module__ == 'decimal' (length 7)."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal extends object directly."
    - "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]."
    - "decimal.Context.__name__ == 'Context' (length 7); __qualname__ == 'Context'; __module__ == 'decimal'."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context also extends object directly."
    - "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]."
    - "decimal.DecimalTuple.__name__ == 'DecimalTuple'; __module__ == 'decimal'; MRO length == 3 (DecimalTuple, tuple, object)."
    - "decimal.DecimalTuple.__bases__[0].__name__ == 'tuple' — DecimalTuple is a named tuple extending tuple."
    - "For Decimal and Context, __name__ == __qualname__ (module-level classes have no enclosing scope prefix)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal class hierarchy and module identity
# Decimal.__name__ == 'Decimal' (len 7); __qualname__ == 'Decimal'.
# __module__ == 'decimal' (len 7).
# __bases__[0].__name__ == 'object'. __mro__.__len__() == 2.
# ---------------------------------------------------------------------------

table decimal_extra122.Decimal_class_identity:
  description: "decimal.Decimal class hierarchy and module identity: __name__, __qualname__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: dechierarchy122

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name_eq,      Decimal.__name__.__eq__,                 ["Decimal"],          true,  "decimal.Decimal.__name__ == 'Decimal'"]
    - [dec_name_len,     Decimal.__name__.__len__,                [],                   7,     "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters)"]
    - [dec_qname_eq,     Decimal.__qualname__.__eq__,             ["Decimal"],          true,  "decimal.Decimal.__qualname__ == 'Decimal' (equals __name__ for module-level class)"]
    - [dec_mod_eq,       Decimal.__module__.__eq__,               ["decimal"],          true,  "decimal.Decimal.__module__ == 'decimal'"]
    - [dec_mod_len,      Decimal.__module__.__len__,              [],                   7,     "decimal.Decimal.__module__.__len__() == 7 ('decimal' has 7 characters)"]
    - [dec_base_eq,      "Decimal.__bases__[0].__name__.__eq__",  ["object"],           true,  "decimal.Decimal.__bases__[0].__name__ == 'object' (Decimal extends object directly)"]
    - [dec_mro_len,      Decimal.__mro__.__len__,                 [],                   2,     "decimal.Decimal.__mro__.__len__() == 2 (MRO is [Decimal, object])"]
    - [dec_mod_not_cdec, Decimal.__module__.__eq__,               ["_decimal"],         false, "decimal.Decimal.__module__ != '_decimal' (the public module name is 'decimal')"]
    - [dec_mro_not_3,    Decimal.__mro__.__len__,                 [],                   3,     false]

