# ---------------------------------------------------------------------------

table decimal_extra122.DecimalTuple_class_identity:
  description: "decimal.DecimalTuple class hierarchy: __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: dechierarchy122

  columns: [id, function, args, expected, description]
