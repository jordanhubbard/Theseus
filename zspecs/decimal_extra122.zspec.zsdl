    - [dt_name_eq,      DecimalTuple.__name__.__eq__,                ["DecimalTuple"], true,  "decimal.DecimalTuple.__name__ == 'DecimalTuple'"]
    - [dt_mod_eq,       DecimalTuple.__module__.__eq__,              ["decimal"],      true,  "decimal.DecimalTuple.__module__ == 'decimal'"]
    - [dt_base_eq,      "DecimalTuple.__bases__[0].__name__.__eq__", ["tuple"],        true,  "decimal.DecimalTuple.__bases__[0].__name__ == 'tuple' (it is a named tuple)"]
