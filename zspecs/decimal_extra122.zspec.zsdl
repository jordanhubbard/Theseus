# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra122.Decimal.name_is_Decimal:
  description: "decimal.Decimal.__name__ == 'Decimal' (length 7; the canonical C-extension decimal class name is the bare word 'Decimal')"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra122.Decimal.mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 (MRO is [Decimal, object]; Decimal is a flat C extension type with no intermediate bases)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra122.Context.base_is_object:
  description: "decimal.Context.__bases__[0].__name__ == 'object' (Context extends object directly, just like Decimal)"
  category: class_identity
  kind: python_call_eq
  function: Context.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant decimal_extra122.Context.module_is_decimal:
  description: "decimal.Context.__module__ == 'decimal' (Context is exposed through the public decimal module, not the private _decimal C extension)"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra122.DecimalTuple.base_is_tuple:
  description: "decimal.DecimalTuple.__bases__[0].__name__ == 'tuple' (DecimalTuple is a named tuple; it extends Python's built-in tuple class, giving it MRO length 3)"
  category: class_identity
  kind: python_call_eq
  function: DecimalTuple.__bases__[0].__name__.__eq__
  args: ["tuple"]
  expected: true

