    - [ctx_qname_eq,     Context.__qualname__.__eq__,            ["Context"],  true,  "decimal.Context.__qualname__ == 'Context' (equals __name__ for module-level class)"]
    - [ctx_mod_eq,       Context.__module__.__eq__,              ["decimal"],  true,  "decimal.Context.__module__ == 'decimal'"]
