spec: human_id
version: ">=4.0.0"
backend: node(human-id)

docs: https://github.com/RienNeVaPlus/human-id#readme

provenance:
  derived_from:
    - "human-id README — https://github.com/RienNeVaPlus/human-id#readme"
    - "Test vectors verified with human-id via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "human-id source"
  notes:
    - "Generates human-readable identifiers (Adjective-Noun-Verb-Adverb) — useful for room codes."
    - "Install: npm install human-id"
    - "v4 CJS; named exports humanId / adjectives / nouns / verbs / adverbs."
    - "Test focuses on the static word-list sizes — humanId() output is non-deterministic."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — random output each call."
  codes: {}

invariant human_id.adjectives_count:
  description: "Adjectives word list has 200 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "adjectives.length"}
  expected: 200

invariant human_id.nouns_count:
  description: "Nouns word list has 300 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "nouns.length"}
  expected: 300

invariant human_id.verbs_count:
  description: "Verbs word list has 250 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "verbs.length"}
  expected: 250

invariant human_id.adverbs_count:
  description: "Adverbs word list has 20 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "adverbs.length"}
  expected: 20

invariant human_id.first_adjective:
  description: "First adjective is 'afraid' (alphabetic, lowercase in word list)"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: adjectives}
    - {method: at, args: [0]}
  expected: "afraid"

invariant human_id.adjectives_contains_eager:
  description: "Adjectives contains 'eager'"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: adjectives}
    - {method: includes, args: ["eager"]}
  expected: true

invariant human_id.humanId_returns_string:
  description: "humanId() returns a String"
  category: shape
  kind: node_chain_eq
  entry: named
  function: humanId
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant human_id.humanId_with_separator_contains_dash:
  description: "humanId({separator:'-'}) output contains '-'"
  category: options
  kind: node_chain_eq
  entry: named
  function: humanId
  entry_args: [{separator: "-"}]
  chain:
    - {method: includes, args: ["-"]}
  expected: true
