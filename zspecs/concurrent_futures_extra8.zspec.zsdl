spec: concurrent_futures_extra8
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra7.zspec.zsdl."
    - "extra5 covers: __name__ for all classes + functions; wait-constant __eq__ values; ThreadPoolExecutor/Future/Executor __module__; BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'."
    - "extra6 covers: __qualname__ for all major classes and functions; FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__ == 'str'."
    - "extra7 covers: ProcessPoolExecutor/CancelledError/BrokenExecutor __module__; as_completed/wait __module__; Executor/__bases__[0]=='object'; ProcessPoolExecutor/__bases__[0]=='Executor'; ThreadPoolExecutor/__bases__[0]=='Executor'; CancelledError/__bases__[0]=='Error'; TimeoutError/__bases__[0]=='OSError'."
    - "This spec adds NEW axes:"
    - "  (1) Future.__bases__[0].__name__ == 'object' — not covered by any prior spec (extra7 checked executor bases but not Future)."
    - "  (2) MRO[1] for CancelledError and BrokenExecutor — __bases__ covered but MRO index 1 not checked independently."
    - "  (3) MRO[2] for CancelledError and BrokenExecutor — a deeper MRO entry not covered in any prior spec."
    - "  (4) Future.__mro__[1].__name__ == 'object' — Future is a direct subclass of object."
    - "  (5) as_completed and wait __class__.__name__ == 'function' — type checks not yet covered."
    - "  (6) FIRST_COMPLETED/__len__() == 15 and ALL_COMPLETED/__len__() == 13 — string length checks not yet covered."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object."
    - "concurrent.futures.Future.__mro__[1].__name__ == 'object' — consistent with single-level inheritance."
    - "concurrent.futures.CancelledError.__mro__[1].__name__ == 'Error' — Error is _base.Error (intermediate class)."
    - "concurrent.futures.CancelledError.__mro__[2].__name__ == 'Exception' — Error inherits from Exception."
    - "concurrent.futures.BrokenExecutor.__mro__[1].__name__ == 'RuntimeError' — same as __bases__[0] via MRO."
    - "concurrent.futures.BrokenExecutor.__mro__[2].__name__ == 'Exception' — RuntimeError inherits from Exception."
    - "concurrent.futures.as_completed.__class__.__name__ == 'function' — plain Python function."
    - "concurrent.futures.wait.__class__.__name__ == 'function' — plain Python function."
    - "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — len('FIRST_COMPLETED') == 15."
    - "concurrent.futures.ALL_COMPLETED.__len__() == 13 — len('ALL_COMPLETED') == 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future class hierarchy — __bases__[0] and MRO[1]
#
# extra7 checked Executor, ProcessPoolExecutor, and ThreadPoolExecutor bases.
# Future's direct base class has never been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra8.Future.base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object' — direct object subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: Future.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant concurrent_futures_extra8.Future.mro_index1:
  description: "concurrent.futures.Future.__mro__[1].__name__ == 'object' — MRO confirms single-level inheritance"
  category: class_hierarchy
  kind: python_call_eq
  function: Future.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# CancelledError MRO — index 1 and index 2
#
# extra7 checked __bases__[0].__name__ == 'Error' for CancelledError.
# This spec adds MRO[1] (same value, independent check) and MRO[2]
# (Exception — the class that _base.Error inherits from).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra8.CancelledError.mro_index1:
  description: "concurrent.futures.CancelledError.__mro__[1].__name__ == 'Error' — intermediate _base.Error"
  category: exception_hierarchy
  kind: python_call_eq
  function: CancelledError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Error"

invariant concurrent_futures_extra8.CancelledError.mro_index2:
  description: "concurrent.futures.CancelledError.__mro__[2].__name__ == 'Exception' — Error inherits from Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: CancelledError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# BrokenExecutor MRO — index 1 and index 2
#
# extra5 checked __bases__[0].__name__ == 'RuntimeError' for BrokenExecutor.
# This spec adds MRO[1] (same value, orthogonal check) and MRO[2]
# (Exception — the class that RuntimeError inherits from).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra8.BrokenExecutor.mro_index1:
  description: "concurrent.futures.BrokenExecutor.__mro__[1].__name__ == 'RuntimeError' — direct base class"
  category: exception_hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "RuntimeError"

invariant concurrent_futures_extra8.BrokenExecutor.mro_index2:
  description: "concurrent.futures.BrokenExecutor.__mro__[2].__name__ == 'Exception' — RuntimeError inherits from Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function type checks — as_completed and wait
#
# Prior specs checked __name__, __qualname__, and __module__ for these
# functions. No prior spec has checked __class__.__name__ (function type).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra8.as_completed.class_name:
  description: "concurrent.futures.as_completed.__class__.__name__ == 'function' — plain Python function"
  category: function_types
  kind: python_call_eq
  function: as_completed.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra8.wait.class_name:
  description: "concurrent.futures.wait.__class__.__name__ == 'function' — plain Python function"
  category: function_types
  kind: python_call_eq
  function: wait.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Wait-return-when constants — string length checks
#
# extra5 verified the string values via __eq__; extra6 verified __class__.__name__.
# This spec adds string length as a new orthogonal property:
#   FIRST_COMPLETED: 15 characters
#   FIRST_EXCEPTION: 15 characters
#   ALL_COMPLETED: 13 characters
# ---------------------------------------------------------------------------

table concurrent_futures_extra8.constant_lengths:
  description: "concurrent.futures wait constants have correct string lengths"
  kind: python_call_eq
  category: constant_lengths
  id_prefix: clen

  columns: [id, function, args, expected]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__len__, [], 15]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__len__, [], 15]
    - [ALL_COMPLETED,   ALL_COMPLETED.__len__,   [], 13]
