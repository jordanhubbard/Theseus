spec: inspect_extra976
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ identity for inspect module utility functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra976.class_attr_qualnames:
  description: "inspect functions for class attribute inspection __qualname__ identity"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ip976ca
  columns: [id, function, args, expected]
  rows:
    - [ip976ca001, inspect.classify_class_attrs.__qualname__.__eq__, ["classify_class_attrs"], true]
    - [ip976ca002, inspect.getattr_static.__qualname__.__eq__,       ["getattr_static"],       true]
    - [ip976ca003, inspect.getmro.__qualname__.__eq__,               ["getmro"],               true]

table inspect_extra976.string_util_qualnames:
  description: "inspect string/annotation utility functions __qualname__ identity"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ip976su
  columns: [id, function, args, expected]
  rows:
    - [ip976su001, inspect.indentsize.__qualname__.__eq__,        ["indentsize"],        true]
    - [ip976su002, inspect.cleandoc.__qualname__.__eq__,          ["cleandoc"],          true]
    - [ip976su003, inspect.formatannotation.__qualname__.__eq__,  ["formatannotation"],  true]
    - [ip976su004, inspect.formatargvalues.__qualname__.__eq__,   ["formatargvalues"],   true]
    - [ip976su005, inspect.getsourcelines.__qualname__.__eq__,    ["getsourcelines"],    true]
    - [ip976su006, inspect.getsource.__qualname__.__eq__,         ["getsource"],         true]

table inspect_extra976.introspection_qualnames:
  description: "inspect introspection and signature functions __qualname__ identity"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ip976iq
  columns: [id, function, args, expected]
  rows:
    - [ip976iq001, inspect.signature.__qualname__.__eq__,         ["signature"],         true]
    - [ip976iq002, inspect.isfunction.__qualname__.__eq__,        ["isfunction"],        true]
    - [ip976iq003, inspect.isclass.__qualname__.__eq__,           ["isclass"],           true]
    - [ip976iq004, inspect.ismethod.__qualname__.__eq__,          ["ismethod"],          true]
    - [ip976iq005, inspect.isbuiltin.__qualname__.__eq__,         ["isbuiltin"],         true]
    - [ip976iq006, inspect.ismodule.__qualname__.__eq__,          ["ismodule"],          true]
    - [ip976iq007, inspect.getmodule.__qualname__.__eq__,         ["getmodule"],         true]
