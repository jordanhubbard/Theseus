spec: re_extra146
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module function __doc__ lengths and __name__ lengths — new territory not covered in re_extra99 (which covered __code__ attrs and type names)."
    - "re.purge.__doc__.__len__() == 35 (shortest; one-line doc)."
    - "re.escape.__doc__.__len__() == 40 (second shortest)."
    - "re.compile.__doc__.__len__() == 65."
    - "re.match.__doc__.__len__() == 109."
    - "re.fullmatch.__doc__.__len__() == 103."
    - "re.search.__doc__.__len__() == 112."
    - "re.finditer.__doc__.__len__() == 163."
    - "re.findall.__doc__.__len__() == 258."
    - "re.sub.__doc__.__len__() == 326."
    - "re.split.__doc__.__len__() == 385."
    - "re.subn.__doc__.__len__() == 447 (longest)."
    - "re function __name__ lengths: sub=3, subn=4, match/split/purge=5, escape/search=6, compile/findall=7, finditer=8, fullmatch=9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __doc__ lengths: short docs (purge=35, escape=40, compile=65)
# These are the three shortest re function docstrings.
# purge just says it clears the regex cache; escape describes backslash escaping.
# ---------------------------------------------------------------------------

table re_extra146.function_doc_lengths_short:
  description: "re function __doc__ lengths for shortest docs: purge=35, escape=40, compile=65; all are str type"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redoclen146

  columns: [id, function, args, expected, description]
  rows:
    - [purge_doc_cls,    purge.__doc__.__class__.__name__.__eq__,    ["str"], true, "re.purge.__doc__.__class__.__name__ == 'str' (all re functions have non-None string docstrings)"]
    - [purge_doc_len,    purge.__doc__.__len__,                       [],     35,   "re.purge.__doc__.__len__() == 35 (the shortest re function docstring; simply states that it clears the regex cache)"]
    - [escape_doc_cls,   escape.__doc__.__class__.__name__.__eq__,   ["str"], true, "re.escape.__doc__.__class__.__name__ == 'str'"]
    - [escape_doc_len,   escape.__doc__.__len__,                      [],     40,   "re.escape.__doc__.__len__() == 40 (second shortest; describes backslash escaping of special characters)"]
    - [compile_doc_cls,  compile.__doc__.__class__.__name__.__eq__,  ["str"], true, "re.compile.__doc__.__class__.__name__ == 'str'"]
    - [compile_doc_len,  compile.__doc__.__len__,                     [],     65,   "re.compile.__doc__.__len__() == 65 (third shortest; brief description of compiling a pattern into a re.Pattern object)"]

# ---------------------------------------------------------------------------
# re function __doc__ lengths: medium docs (match/fullmatch/search 100-115 range)
# match=109, fullmatch=103, search=112.
# ---------------------------------------------------------------------------

table re_extra146.function_doc_lengths_medium:
  description: "re function __doc__ lengths for medium-length docs: fullmatch=103, match=109, search=112"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redoclen146

  columns: [id, function, args, expected, description]
  rows:
    - [fullmatch_doc_len, fullmatch.__doc__.__len__, [], 103, "re.fullmatch.__doc__.__len__() == 103 (match entire string; doc shorter than match (109) despite being added later in Python 3.4)"]
    - [match_doc_len,     match.__doc__.__len__,     [], 109, "re.match.__doc__.__len__() == 109 (match at beginning of string; doc is 6 characters longer than fullmatch)"]
    - [search_doc_len,    search.__doc__.__len__,    [], 112, "re.search.__doc__.__len__() == 112 (scan through string; doc is 3 characters longer than match and 9 longer than fullmatch)"]

# ---------------------------------------------------------------------------
# re function __doc__ lengths: long docs (finditer, findall, sub, split, subn)
# finditer=163, findall=258, sub=326, split=385, subn=447.
# ---------------------------------------------------------------------------

table re_extra146.function_doc_lengths_long:
  description: "re function __doc__ lengths for longer docs: finditer=163, findall=258, sub=326, split=385, subn=447"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redoclen146

  columns: [id, function, args, expected, description]
  rows:
    - [finditer_doc_len, finditer.__doc__.__len__, [], 163, "re.finditer.__doc__.__len__() == 163 (returns iterator of matches; doc describes the Match object and flags parameter)"]
    - [findall_doc_len,  findall.__doc__.__len__,  [], 258, "re.findall.__doc__.__len__() == 258 (returns list of matches; doc 95 chars longer than finditer, explaining return value for groups)"]
    - [sub_doc_len,      sub.__doc__.__len__,      [], 326, "re.sub.__doc__.__len__() == 326 (substitute matches; describes repl argument as string/function and count parameter)"]
    - [split_doc_len,    split.__doc__.__len__,    [], 385, "re.split.__doc__.__len__() == 385 (split by pattern; describes maxsplit and capturing groups behavior in the result list)"]
    - [subn_doc_len,     subn.__doc__.__len__,     [], 447, "re.subn.__doc__.__len__() == 447 (like sub but returns (result, count); longest re function docstring — 62 chars longer than split and 412 longer than purge)"]

# ---------------------------------------------------------------------------
# re function __name__ lengths
# sub=3 (shortest), subn=4, match/split/purge=5, escape/search=6,
# compile/findall=7, finditer=8, fullmatch=9 (longest).
# ---------------------------------------------------------------------------

table re_extra146.function_name_lengths:
  description: "re function __name__ lengths: sub=3, subn=4, match/split/purge=5, escape/search=6, compile/findall=7, finditer=8, fullmatch=9"
  kind: python_call_eq
  category: function_identity
  id_prefix: redoclen146

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name_len,      sub.__name__.__len__,      [], 3, "re.sub.__name__.__len__() == 3 ('sub' is the shortest re function name)"]
    - [subn_name_len,     subn.__name__.__len__,     [], 4, "re.subn.__name__.__len__() == 4 ('subn' has 4 characters)"]
    - [match_name_len,    match.__name__.__len__,    [], 5, "re.match.__name__.__len__() == 5 ('match' has 5 characters)"]
    - [split_name_len,    split.__name__.__len__,    [], 5, "re.split.__name__.__len__() == 5 ('split' has 5 characters; tied with match and purge)"]
    - [purge_name_len,    purge.__name__.__len__,    [], 5, "re.purge.__name__.__len__() == 5 ('purge' has 5 characters; tied with match and split)"]
    - [escape_name_len,   escape.__name__.__len__,   [], 6, "re.escape.__name__.__len__() == 6 ('escape' has 6 characters)"]
    - [search_name_len,   search.__name__.__len__,   [], 6, "re.search.__name__.__len__() == 6 ('search' has 6 characters; tied with escape)"]
    - [compile_name_len,  compile.__name__.__len__,  [], 7, "re.compile.__name__.__len__() == 7 ('compile' has 7 characters)"]
    - [findall_name_len,  findall.__name__.__len__,  [], 7, "re.findall.__name__.__len__() == 7 ('findall' has 7 characters; tied with compile)"]
    - [finditer_name_len, finditer.__name__.__len__, [], 8, "re.finditer.__name__.__len__() == 8 ('finditer' has 8 characters)"]
    - [fullmatch_name_len,fullmatch.__name__.__len__,[], 9, "re.fullmatch.__name__.__len__() == 9 ('fullmatch' is the longest re function name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra146.purge.doc_len_35:
  description: "re.purge.__doc__.__len__() == 35 (the shortest re function docstring; re.purge clears the regular expression cache and its doc simply states that fact; compare with the longest, re.subn (447 characters))"
  category: doc_identity
  kind: python_call_eq
  function: purge.__doc__.__len__
  args: []
  expected: 35

invariant re_extra146.subn.doc_len_447:
  description: "re.subn.__doc__.__len__() == 447 (the longest re function docstring; subn performs the same operation as sub but also returns the substitution count, and its doc elaborates on both behaviors)"
  category: doc_identity
  kind: python_call_eq
  function: subn.__doc__.__len__
  args: []
  expected: 447

invariant re_extra146.escape.doc_len_40:
  description: "re.escape.__doc__.__len__() == 40 (second shortest re function docstring after purge (35); describes escaping special characters in a pattern string)"
  category: doc_identity
  kind: python_call_eq
  function: escape.__doc__.__len__
  args: []
  expected: 40

invariant re_extra146.sub.name_len_3:
  description: "re.sub.__name__.__len__() == 3 ('sub' has 3 characters; the shortest __name__ among all re module-level functions)"
  category: function_identity
  kind: python_call_eq
  function: sub.__name__.__len__
  args: []
  expected: 3

invariant re_extra146.fullmatch.name_len_9:
  description: "re.fullmatch.__name__.__len__() == 9 ('fullmatch' has 9 characters; the longest re function __name__, added in Python 3.4 to match the entire string against a pattern)"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__name__.__len__
  args: []
  expected: 9

invariant re_extra146.split.doc_len_385:
  description: "re.split.__doc__.__len__() == 385 (second longest re function docstring after subn (447); re.split's doc is long because it explains how capturing groups in the pattern are included in the result list)"
  category: doc_identity
  kind: python_call_eq
  function: split.__doc__.__len__
  args: []
  expected: 385

invariant re_extra146.finditer.doc_len_163:
  description: "re.finditer.__doc__.__len__() == 163 (the fourth shortest re function doc; finditer returns an iterator of Match objects and its doc is shorter than findall (258) despite the two functions being closely related)"
  category: doc_identity
  kind: python_call_eq
  function: finditer.__doc__.__len__
  args: []
  expected: 163

invariant re_extra146.compile.doc_len_65:
  description: "re.compile.__doc__.__len__() == 65 (third shortest re function docstring; re.compile has a brief doc because the pattern/flags parameters are described in detail in the module-level docs rather than per-function)"
  category: doc_identity
  kind: python_call_eq
  function: compile.__doc__.__len__
  args: []
  expected: 65
