spec: functools_extra394
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is defined as a plain Python function in functools.py that returns a decorator; it is not a class or C type. Verified with Python 3.14.4."
    - "functools.cache.__class__.__name__ == 'function' — cache is defined as a plain Python function in functools.py (essentially lru_cache(maxsize=None)); it is not a class or C type. Verified with Python 3.14.4."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str' — lru_cache carries a plain string docstring. Verified with Python 3.14.4."
    - "functools.cache.__doc__.__class__.__name__ == 'str' — cache carries a plain string docstring. Verified with Python 3.14.4."
    - "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property is a C type whose __doc__ is None (no docstring in C). Verified with Python 3.14.4."
    - "functools.total_ordering.__doc__.__class__.__name__ == 'str' — total_ordering is a Python function that carries a plain string docstring. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools decorator __class__.__name__ — lru_cache and cache
#
# functools.lru_cache and functools.cache are both plain Python functions,
# so their __class__.__name__ is 'function'. This is notable because
# lru_cache is often thought of as a class-based decorator, but in CPython
# it is implemented as a Python function returning a wrapper.
# ---------------------------------------------------------------------------

table functools_extra394.decorator_class_name:
  description: "functools.lru_cache and functools.cache __class__.__name__ — both are plain Python functions; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsdc394

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_class_name_eq,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a plain Python function in functools.py that returns a decorator; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra394"]
    - [cache_class_name_eq,
       "cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — cache is a plain Python function in functools.py (lru_cache(maxsize=None)); __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Table 2: functools decorator __doc__ class names
#
# lru_cache and cache each carry a plain string docstring (str).
# cached_property is a C type; its __doc__ is None (NoneType).
# total_ordering is a Python function with a plain string docstring (str).
# ---------------------------------------------------------------------------

table functools_extra394.decorator_doc_class_name:
  description: "functools decorator __doc__.__class__.__name__ — str for Python functions, NoneType for C types; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsdd394

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_doc_class_name_eq,
       "lru_cache.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__.__eq__('str') == True — lru_cache is a Python function with a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra394"]
    - [cache_doc_class_name_eq,
       "cache.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.cache.__doc__.__class__.__name__.__eq__('str') == True — cache is a Python function with a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra394"]
    - [cached_property_doc_class_name_eq,
       "cached_property.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.cached_property.__doc__.__class__.__name__.__eq__('NoneType') == True — cached_property is a C type; its __doc__ is None; __class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra394"]
    - [total_ordering_doc_class_name_eq,
       "total_ordering.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.total_ordering.__doc__.__class__.__name__.__eq__('str') == True — total_ordering is a Python decorator function with a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra394
# ---------------------------------------------------------------------------

invariant functools_extra394.lru_cache_class_name:
  description: "functools.lru_cache.__class__.__name__ == 'function' — plain Python function in functools.py; new to extra394"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra394.cache_class_name:
  description: "functools.cache.__class__.__name__ == 'function' — plain Python function (lru_cache(maxsize=None)); new to extra394"
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra394.lru_cache_doc_class_name:
  description: "functools.lru_cache.__doc__.__class__.__name__ == 'str' — Python function with plain string docstring; new to extra394"
  kind: python_call_eq
  function: lru_cache.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra394.cache_doc_class_name:
  description: "functools.cache.__doc__.__class__.__name__ == 'str' — Python function with plain string docstring; new to extra394"
  kind: python_call_eq
  function: cache.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra394.cached_property_doc_class_name:
  description: "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — C type with __doc__ == None; new to extra394"
  kind: python_call_eq
  function: cached_property.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra394.total_ordering_doc_class_name:
  description: "functools.total_ordering.__doc__.__class__.__name__ == 'str' — Python decorator function with plain string docstring; new to extra394"
  kind: python_call_eq
  function: total_ordering.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
