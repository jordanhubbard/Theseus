spec: clone_deep
version: ">=4.0.0"
backend: node(clone-deep)

docs: https://github.com/jonschlinkert/clone-deep#readme

provenance:
  derived_from:
    - "clone-deep README — https://github.com/jonschlinkert/clone-deep#readme"
    - "Test vectors verified with clone-deep via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "clone-deep source"
  notes:
    - "Recursive deep-clone for plain objects, arrays, and primitives."
    - "Install: npm install clone-deep"
    - "Module export IS the cloning function. Returns a structurally-equal but reference-distinct copy."
    - "Identity-disjointness (cloned !== original at all levels) is exercised here via JSON-equality round-trips and shallow-property tests after mutation."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on JSON-shaped input."
  stderr: "null"
  stickiness: "N/A — each call returns an independent copy."
  codes: {}

table clone_deep.equality:
  kind: node_module_call_eq
  category: equality
  function: ~
  id_prefix: eq

  columns: [id, args, expected]
  rows:
    - [primitive_number,
       [42],
       42]

    - [primitive_string,
       ["hello"],
       "hello"]

    - [primitive_null,
       [~],
       ~]

    - [primitive_true,
       [true],
       true]

    - [empty_object,
       [{}],
       {}]

    - [empty_array,
       [[]],
       []]

    - [shallow_object,
       [{a: 1, b: 2}],
       {a: 1, b: 2}]

    - [shallow_array,
       [[1, 2, 3]],
       [1, 2, 3]]

    - [nested_object,
       [{a: 1, b: {c: 2, d: [3, 4]}}],
       {a: 1, b: {c: 2, d: [3, 4]}}]

    - [array_of_objects,
       [[{a: 1}, {b: 2}]],
       [{a: 1}, {b: 2}]]

    - [deeply_nested,
       [{x: {y: {z: {w: "deep"}}}}],
       {x: {y: {z: {w: "deep"}}}}]
