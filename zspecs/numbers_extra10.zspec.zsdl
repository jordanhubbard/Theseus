spec: numbers_extra10
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl and prior extras (numbers_extra through numbers_extra9)."
    - "numbers_extra5 covers: MRO lengths for all five tower classes (Number=2, Complex=3, Real=4, Rational=5, Integral=6)."
    - "numbers_extra6 covers: MRO[0].__name__ == class name for all five classes."
    - "numbers_extra8 covers: Integral MRO[1]-[4] names; Number.__dict__ and Complex.__dict__ as mappingproxy."
    - "numbers_extra2 covers: Number.__module__/Complex.__module__/Real.__module__ == 'numbers'."
    - "numbers_extra3 covers: Rational.__module__/Integral.__module__ == 'numbers'."
    - "numbers_extra7 covers: all five __module__ == 'numbers' as __eq__ style invariants."
    - "No prior spec covers MRO base class names indexed at non-zero positions in a unified table."
    - "No prior spec covers Number.__mro__[1].__name__ == 'object' (the only non-self MRO entry for Number)."
    - "No prior spec covers Complex.__mro__[2].__name__ == 'object' (the terminal MRO entry for Complex)."
    - "No prior spec covers Real.__mro__[3].__name__ == 'object' (the terminal MRO entry for Real)."
    - "No prior spec covers Rational.__mro__[4].__name__ == 'object' (the terminal MRO entry for Rational)."
    - "No prior spec covers Number.__abstractmethods__.__class__.__name__ == 'frozenset'."
    - "numbers_extra9 covers __abstractmethods__.__len__ values but not the __class__.__name__ of the frozenset."
    - "Number.__mro__[1].__name__ == 'object' — Number's only base is object."
    - "Complex.__mro__[2].__name__ == 'object' — terminal entry in Complex MRO."
    - "Real.__mro__[3].__name__ == 'object' — terminal entry in Real MRO."
    - "Rational.__mro__[4].__name__ == 'object' — terminal entry in Rational MRO."
    - "Integral.__mro__[5].__name__ == 'object' — terminal entry in Integral MRO (numbers_extra8 already covers [1]-[4])."
    - "Number.__abstractmethods__.__class__.__name__ == 'frozenset' — __abstractmethods__ is always a frozenset."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Terminal MRO entry (__name__ == 'object') for each tower class
#
# numbers_extra5 covers MRO lengths; numbers_extra6 covers MRO[0] names.
# numbers_extra8 covers Integral MRO[1]-[4] (Rational/Real/Complex/Number).
# No prior spec covers the last (terminal) MRO entry for each class.
# The last entry is always object, since every Python class inherits from it.
# ---------------------------------------------------------------------------

table numbers_extra10.mro_terminal_entry:
  kind: python_call_eq
  category: mro
  id_prefix: mro_last

  columns: [id, function, args, method, expected]
  rows:
    - [Number,   Number.__mro__.__getitem__,   [1], __name__, "object"]
    - [Complex,  Complex.__mro__.__getitem__,  [2], __name__, "object"]
    - [Real,     Real.__mro__.__getitem__,     [3], __name__, "object"]
    - [Rational, Rational.__mro__.__getitem__, [4], __name__, "object"]
    - [Integral, Integral.__mro__.__getitem__, [5], __name__, "object"]

# ---------------------------------------------------------------------------
# Second MRO entry for Complex, Real, and Rational
#
# numbers_extra6 covers MRO[0] (self). numbers_extra8 covers Integral MRO[1]-[4].
# No prior spec covers MRO[1] for Complex (Number), Real (Complex), or Rational (Real).
# Number.__mro__[1] is already covered by the mro_terminal_entry table above.
# The table below checks the __name__ of MRO[1] for Complex, Real, and Rational.
# ---------------------------------------------------------------------------

table numbers_extra10.mro_second_entry:
  kind: python_call_eq
  category: mro
  id_prefix: mro_second

  columns: [id, function, args, method, expected]
  rows:
    - [Complex,  Complex.__mro__.__getitem__,  [1], __name__, "Number"]
    - [Real,     Real.__mro__.__getitem__,     [1], __name__, "Complex"]
    - [Rational, Rational.__mro__.__getitem__, [1], __name__, "Real"]

# ---------------------------------------------------------------------------
# Number.__abstractmethods__.__class__.__name__ == 'frozenset'
#
# numbers_extra9 covers __abstractmethods__.__len__ for all five classes.
# No prior spec checks the type (__class__.__name__) of the frozenset itself.
# The abc machinery always stores abstract method names in a frozenset.
# ---------------------------------------------------------------------------

invariant numbers_extra10.Number.abstractmethods_class_name:
  description: "numbers.Number.__abstractmethods__.__class__.__name__ == 'frozenset' — __abstractmethods__ is a frozenset"
  category: abstract_methods
  kind: python_call_eq
  function: Number.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for all five tower classes via __eq__ check in a table
#
# numbers_extra2, numbers_extra3, and numbers_extra7 cover __module__ == 'numbers'
# as individual invariants. This table captures all five in one place for
# completeness. The table form is distinct from any prior single-invariant form.
# ---------------------------------------------------------------------------

table numbers_extra10.class_module:
  kind: python_call_eq
  category: class_identity
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Number,   Number.__module__.__eq__,   ["numbers"], true]
    - [Complex,  Complex.__module__.__eq__,  ["numbers"], true]
    - [Real,     Real.__module__.__eq__,     ["numbers"], true]
    - [Rational, Rational.__module__.__eq__, ["numbers"], true]
    - [Integral, Integral.__module__.__eq__, ["numbers"], true]
