spec: inspect_extra113
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra112.zspec.zsdl."
    - "This spec covers: inspect module top-level function code attributes not covered in prior specs: isfunction, ismodule, isbuiltin, getmembers, signature, isclass, iscoroutinefunction co_name and co_argcount; wave 264."
    - "inspect.isfunction.__code__.co_name == 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction' (len 10). Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_name == 'ismodule'. Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.ismodule.__qualname__ == 'ismodule' (len 8). Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_name == 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_name == 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_name == 'signature'. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction'. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__qualname__ == 'iscoroutinefunction' (len 19). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect predicate function co_name and co_argcount
#
# Wave 264 theme: inspect.isfunction, inspect.ismodule, inspect.isbuiltin,
# and inspect.isclass are single-argument predicate functions defined in
# Lib/inspect.py. All have co_argcount == 1 (one parameter: the object to
# test). Their co_name matches their __qualname__ exactly (module-level
# functions). Qualname lengths: isfunction(10), ismodule(8), isbuiltin(9),
# isclass(7). The 'is' prefix functions each take exactly 1 argument.
#
# inspect.isfunction.__code__.co_name == 'isfunction'
# inspect.isfunction.__code__.co_argcount == 1
# inspect.ismodule.__code__.co_name == 'ismodule'
# inspect.ismodule.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_name == 'isbuiltin'
# inspect.isbuiltin.__code__.co_argcount == 1
# inspect.isclass.__code__.co_argcount == 1
#
# New to extra113.
# ---------------------------------------------------------------------------

table inspect_extra113.predicate_co_attrs:
  description: "inspect predicate co_name/co_argcount: isfunction('isfunction'/1), ismodule('ismodule'/1), isbuiltin('isbuiltin'/1), isclass('isclass'/1); all single-argument predicates; wave 264; new to extra113"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectpca113

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_co_name,
       "isfunction.__code__.co_name.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — inspect.isfunction is a pure-Python function in Lib/inspect.py; its __code__.co_name is 'isfunction' (the def-statement name); str.__eq__('isfunction') returns True; new to extra113"]
    - [isfunction_co_argcount_1,
       "isfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — inspect.isfunction(object) takes exactly 1 positional argument (the object to test); co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [ismodule_co_name,
       "ismodule.__code__.co_name.__eq__",
       ["ismodule"],
       true,
       "inspect.ismodule.__code__.co_name.__eq__('ismodule') == True — inspect.ismodule is a pure-Python function in Lib/inspect.py; its __code__.co_name is 'ismodule'; str.__eq__('ismodule') returns True; new to extra113"]
    - [ismodule_co_argcount_1,
       "ismodule.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — inspect.ismodule(object) takes 1 argument; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [isbuiltin_co_name,
       "isbuiltin.__code__.co_name.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — inspect.isbuiltin is a pure-Python function in Lib/inspect.py; its __code__.co_name is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra113"]
    - [isbuiltin_co_argcount_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — inspect.isbuiltin(object) takes 1 argument; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [isclass_co_name,
       "isclass.__code__.co_name.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__code__.co_name.__eq__('isclass') == True — inspect.isclass is a pure-Python function; its __code__.co_name is 'isclass'; str.__eq__('isclass') returns True; new to extra113"]
    - [isclass_co_argcount_1,
       "isclass.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — inspect.isclass(object) takes 1 argument; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers, inspect.signature, inspect.iscoroutinefunction co_attrs
#
# Wave 264 theme: inspect.getmembers is the only inspected function in this
# spec with co_argcount > 1: getmembers(object, predicate=None) has
# co_argcount 2. inspect.signature(obj, ...) has co_argcount 1 (the
# follow_wrapped and other params are keyword-only). inspect.iscoroutinefunction
# has co_argcount 1 and its qualname 'iscoroutinefunction' is 19 characters —
# the longest of all the is-predicate qualnames in this spec.
#
# inspect.getmembers.__code__.co_name == 'getmembers'
# inspect.getmembers.__code__.co_argcount == 2
# inspect.signature.__code__.co_name == 'signature'
# inspect.signature.__code__.co_argcount == 1
# inspect.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction'
# inspect.iscoroutinefunction.__code__.co_argcount == 1
# len(inspect.iscoroutinefunction.__qualname__) == 19
#
# New to extra113.
# ---------------------------------------------------------------------------

table inspect_extra113.getmembers_signature_coro_co_attrs:
  description: "inspect getmembers co_argcount=2 (object+predicate); signature co_name='signature'/co_argcount=1; iscoroutinefunction qualname(19)/co_argcount=1; wave 264; new to extra113"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectgsc113

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_name,
       "getmembers.__code__.co_name.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — inspect.getmembers is a pure-Python function in Lib/inspect.py; its __code__.co_name is 'getmembers'; str.__eq__('getmembers') returns True; new to extra113"]
    - [getmembers_co_argcount_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — inspect.getmembers(object, predicate=None) has 2 positional-or-keyword parameters: object and predicate; unlike the single-argument is-predicates, getmembers takes 2; co_argcount is 2; int.__eq__(2) returns True; new to extra113"]
    - [signature_co_name,
       "signature.__code__.co_name.__eq__",
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — inspect.signature is a pure-Python function in Lib/inspect.py; its __code__.co_name is 'signature'; str.__eq__('signature') returns True; new to extra113"]
    - [signature_co_argcount_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — inspect.signature(obj, ...) has 1 positional-or-keyword parameter (obj); follow_wrapped and globals and locals are keyword-only; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [iscoroutinefunction_co_name,
       "iscoroutinefunction.__code__.co_name.__eq__",
       ["iscoroutinefunction"],
       true,
       "inspect.iscoroutinefunction.__code__.co_name.__eq__('iscoroutinefunction') == True — inspect.iscoroutinefunction is a pure-Python function; its __code__.co_name is 'iscoroutinefunction' (19 characters); str.__eq__('iscoroutinefunction') returns True; new to extra113"]
    - [iscoroutinefunction_co_argcount_1,
       "iscoroutinefunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutinefunction.__code__.co_argcount.__eq__(1) == True — inspect.iscoroutinefunction(object) takes 1 argument; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [iscoroutinefunction_qualname_len_19,
       "iscoroutinefunction.__qualname__.__len__",
       [],
       19,
       "inspect.iscoroutinefunction.__qualname__.__len__() == 19 — 'iscoroutinefunction' has 19 characters: i-s-c-o-r-o-u-t-i-n-e-f-u-n-c-t-i-o-n; the longest qualname among the is-predicate functions inspected in this spec; str.__len__() returns 19; int.__eq__(19) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Table 3: inspect predicate qualname lengths comparison
#
# Wave 264 theme: The qualname lengths of the inspect predicates differ by
# the name length: isfunction(10), ismodule(8), isbuiltin(9), isclass(7),
# iscoroutinefunction(19). All have qualname == co_name (top-level module
# functions). inspect.ismodule.__qualname__ and inspect.signature.__qualname__
# are both 8 and 9 characters respectively. getmembers.__qualname__ is 10,
# the same as isfunction.__qualname__. The co_name always matches __qualname__
# for top-level functions.
#
# len(inspect.isfunction.__qualname__) == 10
# len(inspect.ismodule.__qualname__) == 8
# len(inspect.isbuiltin.__qualname__) == 9
# len(inspect.isclass.__qualname__) == 7
# len(inspect.getmembers.__qualname__) == 10
# len(inspect.signature.__qualname__) == 9
#
# New to extra113.
# ---------------------------------------------------------------------------

table inspect_extra113.predicate_qualname_lengths:
  description: "inspect predicate qualname lengths: isfunction(10), ismodule(8), isbuiltin(9), isclass(7), getmembers(10), signature(9); qualname==co_name for all top-level functions; wave 264; new to extra113"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpql113

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_qualname_eq,
       "isfunction.__qualname__.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — inspect.isfunction is defined at module scope in Lib/inspect.py; its __qualname__ is 'isfunction' (same as __name__ and co_name); str.__eq__('isfunction') returns True; new to extra113"]
    - [isfunction_qualname_len_10,
       "isfunction.__qualname__.__len__",
       [],
       10,
       "inspect.isfunction.__qualname__.__len__() == 10 — 'isfunction' has 10 characters: i-s-f-u-n-c-t-i-o-n; the same length as 'getmembers' (10); str.__len__() returns 10; int.__eq__(10) returns True; new to extra113"]
    - [ismodule_qualname_len_8,
       "ismodule.__qualname__.__len__",
       [],
       8,
       "inspect.ismodule.__qualname__.__len__() == 8 — 'ismodule' has 8 characters: i-s-m-o-d-u-l-e; str.__len__() returns 8; int.__eq__(8) returns True; new to extra113"]
    - [isbuiltin_qualname_len_9,
       "isbuiltin.__qualname__.__len__",
       [],
       9,
       "inspect.isbuiltin.__qualname__.__len__() == 9 — 'isbuiltin' has 9 characters: i-s-b-u-i-l-t-i-n; the same length as 'signature' (9); str.__len__() returns 9; int.__eq__(9) returns True; new to extra113"]
    - [isclass_qualname_len_7,
       "isclass.__qualname__.__len__",
       [],
       7,
       "inspect.isclass.__qualname__.__len__() == 7 — 'isclass' has 7 characters: i-s-c-l-a-s-s; the shortest qualname among the predicates in this spec; str.__len__() returns 7; int.__eq__(7) returns True; new to extra113"]
    - [getmembers_qualname_len_10,
       "getmembers.__qualname__.__len__",
       [],
       10,
       "inspect.getmembers.__qualname__.__len__() == 10 — 'getmembers' has 10 characters: g-e-t-m-e-m-b-e-r-s; the same length as 'isfunction' (10); str.__len__() returns 10; int.__eq__(10) returns True; new to extra113"]
    - [signature_qualname_len_9,
       "signature.__qualname__.__len__",
       [],
       9,
       "inspect.signature.__qualname__.__len__() == 9 — 'signature' has 9 characters: s-i-g-n-a-t-u-r-e; the same length as 'isbuiltin' (9); str.__len__() returns 9; int.__eq__(9) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra113
# ---------------------------------------------------------------------------

invariant inspect_extra113.isfunction_co_name:
  description: "inspect.isfunction.__code__.co_name == 'isfunction' — module-level predicate; co_name matches qualname; wave 264; new to extra113"
  kind: python_call_eq
  function: isfunction.__code__.co_name.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra113.ismodule_co_argcount:
  description: "inspect.ismodule.__code__.co_argcount == 1 — single-argument predicate; all is-predicates take exactly 1 argument; wave 264; new to extra113"
  kind: python_call_eq
  function: ismodule.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra113.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount == 2 — object and predicate args; more than the single-argument is-predicates; wave 264; new to extra113"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra113.iscoroutinefunction_qualname_len:
  description: "len(inspect.iscoroutinefunction.__qualname__) == 19 — longest predicate qualname in this spec; 'iscoroutinefunction' is 19 characters; wave 264; new to extra113"
  kind: python_call_eq
  function: iscoroutinefunction.__qualname__.__len__
  args: []
  expected: 19

invariant inspect_extra113.isclass_qualname_len:
  description: "len(inspect.isclass.__qualname__) == 7 — shortest is-predicate qualname in this spec; 'isclass' is 7 characters; wave 264; new to extra113"
  kind: python_call_eq
  function: isclass.__qualname__.__len__
  args: []
  expected: 7
