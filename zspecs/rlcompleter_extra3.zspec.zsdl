spec: rlcompleter_extra3
version: ">=3.9"
backend: python_module(rlcompleter)

docs: https://docs.python.org/3/library/rlcompleter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/rlcompleter.html — Python rlcompleter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/rlcompleter.py"
  notes:
    - "Extends rlcompleter.zspec.zsdl, rlcompleter_extra.zspec.zsdl, and rlcompleter_extra2.zspec.zsdl."
    - "rlcompleter (base) covers: Completer/__name__/__module__, complete/__name__/global_matches/__name__/attr_matches/__name__, complete('str',0)=='str(', complete('str',1)==None, global_matches returns list, global_matches('str') nonempty, Completer instantiable."
    - "rlcompleter_extra covers: Completer/__name__/__module__, __bases__[0].__name__=='object', __bases__.__len__()==1, complete/global_matches/attr_matches __name__ and is_function, module.__name__, Completer.__init__.__name__."
    - "rlcompleter_extra2 covers: Completer is type, Completer/__qualname__, complete/global_matches/attr_matches __qualname__, get_class_members/__name__/__module__/is_function, complete('int',0)=='int(', complete('print',0)=='print(', complete('int',1)==None, namespace-scoped completion."
    - "This spec adds: Completer.__init__.__qualname__ == 'Completer.__init__' (not in any prior spec); Completer.attr_matches.__qualname__ already in extra2 — this spec instead adds get_class_members/__qualname__; Completer.__bases__[0].__module__ == 'builtins'; Completer().complete('list',0) == 'list(' (new prefix); __name__ string lengths for Completer, complete, global_matches; rlcompleter module __name__ length."
    - "rlcompleter.Completer.__init__.__qualname__ == 'Completer.__init__' — constructor qualname encodes class scoping."
    - "rlcompleter.get_class_members.__qualname__ == 'get_class_members' — module-level helper; qualname equals name."
    - "rlcompleter.Completer.__bases__[0].__module__ == 'builtins' — the base class (object) is defined in builtins."
    - "Completer().complete('list', 0) == 'list(' — 'list' is a builtin callable, paren appended."
    - "len('Completer') == 9, len('complete') == 8, len('global_matches') == 14."
    - "len('rlcompleter') == 11 — the module name has 11 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Completer.__init__ qualified name
# rlcompleter_extra checks Completer.__init__.__name__ == '__init__'.
# No prior spec checks Completer.__init__.__qualname__.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra3.Completer.init_qualname:
  description: "rlcompleter.Completer.__init__.__qualname__ == 'Completer.__init__' — qualname encodes class scope"
  category: class_methods
  kind: python_call_eq
  function: Completer.__init__.__qualname__.__eq__
  args: ["Completer.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# get_class_members __qualname__
# rlcompleter_extra2 checks get_class_members/__name__/__module__/is_function.
# No prior spec checks get_class_members.__qualname__.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra3.get_class_members.qualname:
  description: "rlcompleter.get_class_members.__qualname__ == 'get_class_members' — module-level function qualname equals name"
  category: module_functions
  kind: python_call_eq
  function: get_class_members.__qualname__.__eq__
  args: ["get_class_members"]
  expected: true

# ---------------------------------------------------------------------------
# Completer.__bases__[0].__module__ — the base class (object) is in builtins
# rlcompleter_extra confirms __bases__[0].__name__ == 'object'.
# No prior spec checks __bases__[0].__module__ for rlcompleter.Completer.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra3.Completer.base_module:
  description: "rlcompleter.Completer.__bases__[0].__module__ == 'builtins' — base class object is in builtins"
  category: classes
  kind: python_call_eq
  function: Completer.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "builtins"

# ---------------------------------------------------------------------------
# Behavioral — Completer().complete() with 'list' prefix
# Base spec covers 'str'; extra2 adds 'int' and 'print'.
# This spec adds 'list' as a further distinct builtin callable.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra3.complete.list_state0:
  description: "Completer().complete('list', 0) == 'list(' — 'list' is a builtin callable, paren appended"
  category: complete
  kind: python_call_eq
  function: Completer
  args: []
  method: complete
  method_args: ["list", 0]
  expected: "list("

invariant rlcompleter_extra3.complete.list_state1:
  description: "Completer().complete('list', 1) == None — no second completion for bare 'list'"
  category: complete
  kind: python_call_eq
  function: Completer
  args: []
  method: complete
  method_args: ["list", 1]
  expected: null

# ---------------------------------------------------------------------------
# __name__ string lengths for key rlcompleter identifiers
# No prior spec checks the length of any __name__ string for rlcompleter symbols.
# These complement the equality checks in prior specs with numeric assertions.
# ---------------------------------------------------------------------------

table rlcompleter_extra3.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [Completer,      Completer.__name__.__len__,              [], 9]
    - [complete,       Completer.complete.__name__.__len__,     [], 8]
    - [global_matches, Completer.global_matches.__name__.__len__, [], 14]

# ---------------------------------------------------------------------------
# rlcompleter module __name__ string length
# rlcompleter_extra checks module.__name__ == 'rlcompleter' via __eq__.
# This adds the complementary length check: len('rlcompleter') == 11.
# ---------------------------------------------------------------------------

invariant rlcompleter_extra3.module.name_len:
  description: "len(rlcompleter.__name__) == 11 — 'rlcompleter' has 11 characters"
  category: module
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 11
