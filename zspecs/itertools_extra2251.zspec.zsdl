spec: itertools_extra2251
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave extra2251: callable protocol and function-attribute dict-presence checks — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in itertools class __dict__."
    - "All itertools iterator types (count, cycle, repeat, chain, compress, dropwhile, filterfalse, groupby, islice, pairwise, starmap, takewhile, zip_longest, product, permutations, combinations, combinations_with_replacement, accumulate) are C extension types."
    - "None of these C extension iterator types define __call__ in their class __dict__ — they are iterators, not callable factories in the sense that their instances are not themselves callable."
    - "__code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ are function-object attributes; C extension types never define them in their class __dict__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2251.call_protocol_count_cycle_repeat:
  description: "itertools.count, itertools.cycle, itertools.repeat do NOT define __call__ in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2251

  columns: [id, function, args, expected]
  rows:
    - ["it2251001", "itertools.count.__dict__.__contains__", ["__call__"], false]
    - ["it2251002", "itertools.cycle.__dict__.__contains__", ["__call__"], false]
    - ["it2251003", "itertools.repeat.__dict__.__contains__", ["__call__"], false]

