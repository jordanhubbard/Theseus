spec: datetime_timedelta_rust
version: ">=3.9"
backend: rust_module(datetime_timedelta_rust)

docs: https://docs.python.org/3/library/datetime.html#datetime.timedelta

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime documentation"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
  notes:
    - "Python datetime.timedelta class methods and properties."
    - "timedelta(1).total_seconds() == 86400.0 — 1 day in seconds."
    - "timedelta(0, 3600).total_seconds() == 3600.0 — 1 hour in seconds."
    - "timedelta(7).days == 7 — access days property."
    - "timedelta(0, 90).seconds == 90 — access seconds property."
    - "timedelta(1).__str__() == '1 day, 0:00:00'."
    - "timedelta(7).__str__() == '7 days, 0:00:00'."
    - "All test vectors verified against Python 3.14.3 datetime module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# timedelta.total_seconds — total duration in seconds
table datetime_timedelta_rust.total_seconds.vectors:
  kind: python_call_eq
  category: total_seconds
  id_prefix: td_ts
  function: timedelta
  method: total_seconds
  method_args: []

  columns: [id, args, expected]
  rows:
    - [one_day,     [1],       86400.0]
    - [one_hour,    [0, 3600], 3600.0]
    - [one_week,    [7],       604800.0]
    - [zero,        [0],       0.0]
    - [half_minute, [0, 30],   30.0]

# timedelta.days and .seconds properties
table datetime_timedelta_rust.properties.vectors:
  kind: python_call_eq
  category: properties
  id_prefix: td_prop

  columns: [id, function, args, method, expected]
  rows:
    - [days_7,    timedelta, [7],       days,    7]
    - [days_0,    timedelta, [0],       days,    0]
    - [seconds_90, timedelta, [0, 90],  seconds, 90]
    - [seconds_0,  timedelta, [1],      seconds, 0]

# timedelta.__str__ representation
table datetime_timedelta_rust.str.vectors:
  kind: python_call_eq
  category: str
  id_prefix: td_str
  function: timedelta
  method: __str__
  method_args: []

  columns: [id, args, expected]
  rows:
    - [one_day,  [1], "1 day, 0:00:00"]
    - [seven,    [7], "7 days, 0:00:00"]
    - [zero,     [0], "0:00:00"]
    - [one_hour, [0, 3600], "1:00:00"]

