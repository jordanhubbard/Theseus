spec: textwrap_extra29
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
    - "textwrap_extra28.zspec.zsdl — covers indent.__name__.__len__()==6; wrap/fill/dedent/shorten/indent __qualname__.__len__() as standalones; TextWrapper.fill/_split/_wrap_chunks/_handle_long_word/_munge_whitespace __qualname__.__len__() as standalones; module-level and TextWrapper method qualname length tables."
    - "textwrap_extra27.zspec.zsdl — covers TextWrapper __module__/__name__/__qualname__ __len__()==8/11/11; wrap/fill/shorten/dedent/indent __module__.__len__()==8; wrap/fill/shorten/dedent __name__.__len__()==4/4/7/6; TextWrapper.wrap.__qualname__.__len__()==16."
  notes:
    - "This spec extends textwrap_extra28.zspec.zsdl."
    - "This spec covers NEW angles not in any prior textwrap spec: textwrap.__all__.__len__()==6; textwrap.__all__.__class__.__name__.__len__()==4 ('list'); textwrap.__name__.__len__()==8; textwrap.__doc__.__class__.__name__.__len__()==3 ('str'); TextWrapper.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'); TextWrapper.__mro__.__len__()==2; TextWrapper.__bases__[0].__name__.__len__()==6 ('object'); TextWrapper.__qualname__.__len__()==11; TextWrapper._split_chunks/__qualname__.__len__()==25; TextWrapper.__init__/__qualname__.__len__()==20; TextWrapper._fix_sentence_endings/__qualname__.__len__()==33; TextWrapper.__init_subclass__/__qualname__.__len__()==29; textwrap.__all__ element name lengths table."
    - "textwrap.__all__ == ['TextWrapper', 'wrap', 'fill', 'dedent', 'indent', 'shorten'] — 6 entries (list). Verified Python 3.12."
    - "textwrap.__all__.__class__.__name__ == 'list' (len 4). Verified Python 3.12."
    - "textwrap.__name__ == 'textwrap' (len 8). Verified Python 3.12."
    - "textwrap.__doc__.__class__.__name__ == 'str' (len 3). Verified Python 3.12."
    - "textwrap.TextWrapper.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified Python 3.12."
    - "textwrap.TextWrapper.__mro__ = [TextWrapper, object] — len 2. Verified Python 3.12."
    - "textwrap.TextWrapper.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12."
    - "textwrap.TextWrapper.__qualname__ == 'TextWrapper' (len 11). Verified Python 3.12."
    - "textwrap.TextWrapper._split_chunks.__qualname__ == 'TextWrapper._split_chunks' (len 25). Verified Python 3.12."
    - "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' (len 20). Verified Python 3.12."
    - "textwrap.TextWrapper._fix_sentence_endings.__qualname__ == 'TextWrapper._fix_sentence_endings' (len 33). Verified Python 3.12."
    - "textwrap.TextWrapper.__init_subclass__.__qualname__ == 'TextWrapper.__init_subclass__' (len 29). Verified Python 3.12."
    - "textwrap.__all__ element lengths: 'TextWrapper'(11), 'wrap'(4), 'fill'(4), 'dedent'(6), 'indent'(6), 'shorten'(7). Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# textwrap.__all__ == ['TextWrapper', 'wrap', 'fill', 'dedent', 'indent', 'shorten']
# — exactly 6 entries; it is a list. No prior textwrap spec checks either
# __all__.__len__() or __all__.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant textwrap_extra29.all.len:
  description: "textwrap.__all__.__len__() == 6 — six public names: TextWrapper, wrap, fill, dedent, indent, shorten"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 6

invariant textwrap_extra29.all.class_name_len:
  description: "textwrap.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_all
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# textwrap.__name__.__len__() and __doc__.__class__.__name__.__len__()
#
# textwrap.__name__ == 'textwrap' (len 8). textwrap.__doc__ is a str (len 3).
# No prior textwrap spec checks __name__.__len__() for the module itself
# or the class name of the module docstring.
# ---------------------------------------------------------------------------

invariant textwrap_extra29.module_name_len:
  description: "textwrap.__name__.__len__() == 8 — module name 'textwrap' has 8 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 8

invariant textwrap_extra29.doc_class_name_len:
  description: "textwrap.__doc__.__class__.__name__.__len__() == 3 — module docstring is a 'str'"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# TextWrapper.__dict__.__class__.__name__.__len__() == 12
#
# TextWrapper's class namespace is a types.MappingProxyType;
# __class__.__name__ == 'mappingproxy' (len 12). No prior textwrap spec
# checks __dict__.__class__.__name__.__len__() for TextWrapper.
# ---------------------------------------------------------------------------

invariant textwrap_extra29.TextWrapper.dict_class_name_len:
  description: "textwrap.TextWrapper.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_introspection
  kind: python_call_eq
  function: TextWrapper.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# TextWrapper.__mro__.__len__() == 2 and __bases__[0].__name__.__len__() == 6
#
# TextWrapper has no base class beyond object; MRO = [TextWrapper, object] (len 2).
# __bases__[0].__name__ == 'object' (len 6). No prior textwrap spec checks
# __mro__.__len__() for TextWrapper (extra27 covered __qualname__ length only).
# ---------------------------------------------------------------------------

invariant textwrap_extra29.TextWrapper.mro_len:
  description: "textwrap.TextWrapper.__mro__.__len__() == 2 — MRO: [TextWrapper, object]"
  category: class_introspection
  kind: python_call_eq
  function: TextWrapper.__mro__.__len__
  args: []
  expected: 2

invariant textwrap_extra29.TextWrapper.bases_name_len:
  description: "textwrap.TextWrapper.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_introspection
  kind: python_call_eq
  function: "TextWrapper.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# TextWrapper internal method __qualname__.__len__() — _split_chunks, __init__,
# _fix_sentence_endings, __init_subclass__
#
# TextWrapper._split_chunks.__qualname__ == 'TextWrapper._split_chunks' (25).
# TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' (20).
# TextWrapper._fix_sentence_endings.__qualname__ == 'TextWrapper._fix_sentence_endings' (33).
# TextWrapper.__init_subclass__.__qualname__ == 'TextWrapper.__init_subclass__' (29).
# No prior textwrap spec checks __qualname__.__len__() for any of these.
# ---------------------------------------------------------------------------

invariant textwrap_extra29.TextWrapper._split_chunks.qualname_len:
  description: "textwrap.TextWrapper._split_chunks.__qualname__.__len__() == 25 — 'TextWrapper._split_chunks' has 25 characters"
  category: class_introspection
  kind: python_call_eq
  function: TextWrapper._split_chunks.__qualname__.__len__
  args: []
  expected: 25

invariant textwrap_extra29.TextWrapper.__init__.qualname_len:
  description: "textwrap.TextWrapper.__init__.__qualname__.__len__() == 20 — 'TextWrapper.__init__' has 20 characters"
  category: class_introspection
  kind: python_call_eq
  function: TextWrapper.__init__.__qualname__.__len__
  args: []
  expected: 20

invariant textwrap_extra29.TextWrapper._fix_sentence_endings.qualname_len:
  description: "textwrap.TextWrapper._fix_sentence_endings.__qualname__.__len__() == 33 — 'TextWrapper._fix_sentence_endings' has 33 characters"
  category: class_introspection
  kind: python_call_eq
  function: TextWrapper._fix_sentence_endings.__qualname__.__len__
  args: []
  expected: 33

invariant textwrap_extra29.TextWrapper.__init_subclass__.qualname_len:
  description: "textwrap.TextWrapper.__init_subclass__.__qualname__.__len__() == 29 — 'TextWrapper.__init_subclass__' has 29 characters"
  category: class_introspection
  kind: python_call_eq
  function: TextWrapper.__init_subclass__.__qualname__.__len__
  args: []
  expected: 29

# ---------------------------------------------------------------------------
# Table: textwrap.__all__ element name lengths
#
# Each element of textwrap.__all__ is a string with a measurable length.
# 'TextWrapper'(11), 'wrap'(4), 'fill'(4), 'dedent'(6), 'indent'(6), 'shorten'(7).
# This indexes the __all__ list directly and checks each element's string length.
# No prior textwrap spec checks individual __all__ element lengths.
# id_prefix tw29al is novel.
# ---------------------------------------------------------------------------

table textwrap_extra29.all_element_lens:
  description: "Length of each name string in textwrap.__all__ — TextWrapper=11, wrap=4, fill=4, dedent=6, indent=6, shorten=7"
  kind: python_call_eq
  category: module_all
  id_prefix: tw29al

  columns: [id, function, method, method_args, expected]
  rows:
    - [all0_len, "__all__[0]", __len__, [], 11]
    - [all1_len, "__all__[1]", __len__, [], 4]
    - [all2_len, "__all__[2]", __len__, [], 4]
    - [all3_len, "__all__[3]", __len__, [], 6]
    - [all4_len, "__all__[4]", __len__, [], 6]
    - [all5_len, "__all__[5]", __len__, [], 7]
