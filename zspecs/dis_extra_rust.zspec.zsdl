spec: dis_extra_rust
version: ">=3.9"
backend: rust_module(dis_extra_rust)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — dis stdlib"
  notes:
    - "dis disassembles Python bytecode."
    - "dis.dis is callable."
    - "dis.get_instructions is callable."
    - "dis.opname is a list."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant dis_extra_rust.has_dis_function:
  description: "dis.dis is callable"
  category: presence
  kind: python_call_eq
  function: dis_extra_has_dis
  args: []
  expected: true

invariant dis_extra_rust.opname_nonempty:
  description: "dis.opname is a non-empty list"
  category: opname
  kind: python_call_eq
  function: dis_extra_opname_nonempty
  args: []
  expected: true

invariant dis_extra_rust.has_get_instructions:
  description: "dis.get_instructions is callable"
  category: presence
  kind: python_call_eq
  function: dis_extra_has_get_instructions
  args: []
  expected: true

