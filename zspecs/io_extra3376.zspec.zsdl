spec: io3376
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (io3376): __trunc__, __round__, __index__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __trunc__, __round__, __index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "No io class defines __trunc__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types; math.trunc() has no meaning for I/O stream objects."
    - "No io class defines __round__ in its own __dict__: stream I/O classes are not numeric types; round() has no meaning for I/O stream objects."
    - "No io class defines __index__ in its own __dict__: stream I/O classes are not integer types; operator.index() requires an exact integer type and is not defined for I/O stream objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all numeric truncation, rounding, and integer-conversion operators absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — operator.contains(Cls.__dict__, '__trunc__')
#
# No io class defines __trunc__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the truncation-toward-zero operator (math.trunc(x)).
# ---------------------------------------------------------------------------

table io3376.trunc:
  description: "io types __trunc__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3376

  columns: [id, function, args, expected]
  rows:
    - ["io3376001", operator.contains, [io.RawIOBase.__dict__,       "__trunc__"], false]
    - ["io3376002", operator.contains, [io.BufferedIOBase.__dict__,  "__trunc__"], false]
