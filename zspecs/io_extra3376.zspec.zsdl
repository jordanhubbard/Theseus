# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.contains(Cls.__dict__, '__index__')
#
# No io class defines __index__ in its own __dict__; all false.
# io stream classes are not integer types; operator.index() requires an exact
# integer type (__index__ signals lossless conversion to int) and is not
# meaningful for I/O stream objects.
# ---------------------------------------------------------------------------

