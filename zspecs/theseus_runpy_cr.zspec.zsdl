spec: theseus_runpy_cr
version: ">=3.0"
backend: python_cleanroom(theseus_runpy_cr)
blocks: runpy

docs: https://docs.python.org/3/library/runpy.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/runpy.html"
  not_derived_from:
    - "CPython source: Lib/runpy.py"
  notes:
    - "Clean-room runpy module. Do NOT import runpy."

error_model: python_exceptions

invariant theseus_runpy_cr.runpy2_run_module:
  description: "run_module() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: runpy2_run_module
  args: []
  expected: true

invariant theseus_runpy_cr.runpy2_run_path:
  description: "run_path() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: runpy2_run_path
  args: []
  expected: true

invariant theseus_runpy_cr.runpy2_run_code:
  description: "run_code() executes code in a namespace"
  category: behavior
  kind: python_call_eq
  function: runpy2_run_code
  args: []
  expected: true
