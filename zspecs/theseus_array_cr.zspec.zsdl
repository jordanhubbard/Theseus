spec: theseus_array_cr
version: ">=3.8"
backend: python_cleanroom(theseus_array_cr)
blocks: array

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/array.html"
  not_derived_from:
    - "CPython source: Lib/array.py (internal implementation)"
  notes:
    - "Clean-room array module. Do NOT import array."

error_model: python_exceptions

invariant theseus_array_cr.array2_typecode:
  description: "array('i', [1,2,3]).typecode == 'i'"
  category: array
  kind: python_call_eq
  function: array2_typecode
  args: []
  expected: "i"

invariant theseus_array_cr.array2_append:
  description: "array.append() increases length"
  category: array
  kind: python_call_eq
  function: array2_append
  args: []
  expected: 4

invariant theseus_array_cr.array2_tolist:
  description: "array.tolist() returns equivalent list"
  category: tolist
  kind: python_call_eq
  function: array2_tolist
  args: []
  expected: true
