spec: text_table
version: ">=0.2.0"
backend: node(text-table)

docs: https://www.npmjs.com/package/text-table

provenance:
  derived_from:
    - "text-table README — https://www.npmjs.com/package/text-table"
    - "Test vectors verified with text-table via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "text-table source"
  notes:
    - "text-table is an npm package. Install: npm install text-table"
    - "table(rows) formats an array of rows as an aligned plain-text table."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns formatted table string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table text_table.table:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: texttbl

  columns: [id, args, expected]
  rows:
    - [basic, [[["name", "age"], ["Alice", "30"], ["Bob", "25"]]],
       "name   age\nAlice  30\nBob    25"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:35:50Z
  iterations: 1
  pass_count: 1
  fail_count: 0
  total_invariants: 1
  notes: Synthesis succeeded in 1 iteration(s). 1 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
