spec: socket_extra166
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra165.zspec.zsdl — covers socket.error/__module__/'OSError'/'builtins'; socket.timeout/__module__/'TimeoutError'/'builtins'; socket.gaierror/__module__/'gaierror'/'socket'; socket.herror/__module__/'herror'/'socket' (table + invariants)."
    - "socket_extra164.zspec.zsdl — covers socket.socket.__dict__ method membership (accept/close/detach/makefile/sendfile/dup/get_inheritable/set_inheritable) and meta-attributes (__len__()==28/__class__.__name__=='mappingproxy') (table + invariants)."
    - "socket_extra163.zspec.zsdl — covers socket.__spec__.origin type and content / submodule_search_locations NoneType (table + invariants)."
    - "socket_extra162.zspec.zsdl — covers socket.socket.__repr__/__str__/__enter__/__exit__ qualname strings and lengths (table + invariants)."
    - "socket_extra161.zspec.zsdl — covers socket.socket.send/__recv/__sendto/__recvfrom qualname strings (table + invariants)."
    - "socket_extra160.zspec.zsdl — covers socket.socket.bind/__listen/__accept/__close qualname strings (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__/__init__.__qualname__/connect.__qualname__ (table + invariants)."
    - "socket_extra156.zspec.zsdl — covers socket.__spec__.__class__.__name__=='ModuleSpec' / socket.__spec__.name == 'socket' (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra165."
    - "Wave 348 theme: socket enum constant identity — socket.AF_INET.__class__.__name__=='AddressFamily' / SOCK_STREAM.__class__.__name__=='SocketKind' / AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True / AF_INET6.__eq__(30)==True (macOS/Darwin) / SOCK_DGRAM.__eq__(2)==True / IPPROTO_TCP.__eq__(6)==True / IPPROTO_UDP.__eq__(17)==True."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__eq__(2) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__eq__(1) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__eq__(30) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0 (macOS-specific value; Linux uses 10)."
    - "socket.SOCK_DGRAM.__eq__(2) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__eq__(6) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__eq__(17) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.AF_INET.__class__.__name__ == 'AddressFamily' (13 chars). On Python 3.4+, socket address families are IntEnum members of the AddressFamily enum. AF_INET has integer value 2. socket.AF_INET.__eq__(2) == True because AddressFamily inherits from int. 'AddressFamily' = 'Address'=7 + 'Family'=6 = 13 chars."
    - "Note: socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars). On Python 3.4+, socket types are IntEnum members of the SocketKind enum. SOCK_STREAM has integer value 1. 'SocketKind' = 'Socket'=6 + 'Kind'=4 = 10 chars. 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars."
    - "Note: socket.AF_INET6.__eq__(30) == True on macOS/Darwin. AF_INET6 value is 30 on macOS (PF_INET6 = 30 in sys/socket.h). On Linux, AF_INET6 == 10. This spec targets macOS/Darwin 25.4.0."
    - "Note: socket.IPPROTO_TCP.__class__.__name__ == 'int' (3 chars) and IPPROTO_UDP.__class__.__name__ == 'int' (3 chars). Unlike AF_INET (AddressFamily enum) and SOCK_STREAM (SocketKind enum), the IPPROTO_* constants are plain Python int values, not IntEnum members. IPPROTO_TCP == 6 and IPPROTO_UDP == 17 are IANA-assigned protocol numbers."
    - "Note: socket.SOCK_DGRAM.__eq__(2) == True. SOCK_DGRAM has value 2 — the same integer as AF_INET (value 2). This is a coincidence: AF_INET is in the AddressFamily namespace (value=2 means IPv4) and SOCK_DGRAM is in the SocketKind namespace (value=2 means datagram/UDP socket). Same integer value, different enum namespaces."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily')
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind')
# socket.AF_INET.__eq__(2)
# socket.SOCK_STREAM.__eq__(1)
#
# Wave 348 theme: socket enum constant class names and integer values.
#
# AF_INET.__class__.__name__ == 'AddressFamily' (13 chars; IntEnum).
# SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars; IntEnum).
# AF_INET.__eq__(2) == True (integer value 2 for IPv4).
# SOCK_STREAM.__eq__(1) == True (integer value 1 for stream socket).
# No prior socket spec anchors AF_INET.__class__.__name__ or SOCK_STREAM class names as a
# table under sockconst166. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra166.af_inet_sock_stream_class_and_values:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily')==True / SOCK_STREAM.__class__.__name__.__eq__('SocketKind')==True / AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True — AF_INET.__class__.__name__ is 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6; socket.AF_INET is an IntEnum member of the AddressFamily enum; introduced in Python 3.4 (PEP 3151 ecosystem, socket enum additions in Python 3.4); AF_INET is the IPv4 address family constant used for TCP/IP sockets; 'AddressFamily'(13) is the longest enum class name in this spec); SOCK_STREAM.__class__.__name__ is 'SocketKind' (10 chars = 'Socket'=6 + 'Kind'=4; socket.SOCK_STREAM is an IntEnum member of the SocketKind enum; SOCK_STREAM represents reliable stream-oriented connections (TCP); 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars); AF_INET.__eq__(2) is True (AF_INET's integer value is 2; AF_INET == 2 because AddressFamily inherits from int; value 2 = PF_INET = AF_INET in POSIX socket.h; SOCK_DGRAM also has value 2 (different namespace, same integer — coincidence)); SOCK_STREAM.__eq__(1) is True (SOCK_STREAM's integer value is 1; SOCK_STREAM == 1 is the lowest-numbered socket kind; stream socket for connection-oriented reliable transport, e.g., TCP); first sockconst166 anchor for AF_INET and SOCK_STREAM class names and integer values"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst166

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class,       "AF_INET.__class__.__name__.__eq__",     ["AddressFamily"], true, "socket.AF_INET.__class__.__name__ == 'AddressFamily' (13 chars; IntEnum; IPv4 address family; Python 3.4+)"]
    - [sock_stream_class,   "SOCK_STREAM.__class__.__name__.__eq__", ["SocketKind"],    true, "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars; IntEnum; stream socket; 'SocketKind'(10) < 'AddressFamily'(13) by 3)"]
    - [af_inet_eq_2,        "AF_INET.__eq__",                        [2],               true, "socket.AF_INET.__eq__(2) == True (integer value 2; IPv4 address family; AddressFamily inherits from int; AF_INET==SOCK_DGRAM==2 is coincidental)"]
    - [sock_stream_eq_1,    "SOCK_STREAM.__eq__",                    [1],               true, "socket.SOCK_STREAM.__eq__(1) == True (integer value 1; stream socket for TCP; lowest-numbered socket kind)"]

# ---------------------------------------------------------------------------
# socket.AF_INET6.__eq__(30) and SOCK_DGRAM.__eq__(2)
#
# Wave 348 theme: AF_INET6 and SOCK_DGRAM integer values.
#
# AF_INET6.__eq__(30) == True (value 30 on macOS/Darwin; 10 on Linux).
# SOCK_DGRAM.__eq__(2) == True (value 2; datagram socket for UDP).
# AF_INET.__eq__(2) (confirmed; value 2).
# SOCK_STREAM.__eq__(1) (confirmed; value 1).
# No prior socket spec anchors AF_INET6.__eq__ or SOCK_DGRAM.__eq__ as a table under
# sockconst166. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra166.af_inet6_sock_dgram_values:
  description: "socket.AF_INET6.__eq__(30)==True / SOCK_DGRAM.__eq__(2)==True / AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True — AF_INET6.__eq__(30) is True (AF_INET6 has integer value 30 on macOS/Darwin; this is macOS-specific: on macOS, PF_INET6 = 30 in /usr/include/sys/socket.h; on Linux AF_INET6 = 10; this spec targets macOS/Darwin 25.4.0; AF_INET6 is the IPv6 address family constant for AF_INET6-family TCP/IP sockets; AF_INET6.__class__.__name__=='AddressFamily' (13 chars; same enum as AF_INET)); SOCK_DGRAM.__eq__(2) is True (SOCK_DGRAM has integer value 2; datagram socket for connectionless unreliable transport, e.g., UDP; SOCK_DGRAM==2 == AF_INET==2 is a numerical coincidence: same integer 2 appears in both AddressFamily (AF_INET) and SocketKind (SOCK_DGRAM) enums with different semantic meaning; SOCK_DGRAM.__class__.__name__=='SocketKind' (10 chars; same enum as SOCK_STREAM)); AF_INET.__eq__(2) is True (confirmed; IPv4 = value 2; same integer as SOCK_DGRAM=2 — coincidence, different namespaces); SOCK_STREAM.__eq__(1) is True (confirmed; value 1; 1 < 2; stream before datagram in numbering); first sockconst166 anchor for AF_INET6 and SOCK_DGRAM values"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst166

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet6_eq_30,   "AF_INET6.__eq__",   [30], true, "socket.AF_INET6.__eq__(30) == True (value 30 on macOS/Darwin; macOS-specific: PF_INET6=30 in sys/socket.h; Linux uses 10; IPv6 address family)"]
    - [sock_dgram_eq_2,  "SOCK_DGRAM.__eq__", [2],  true, "socket.SOCK_DGRAM.__eq__(2) == True (value 2; datagram socket for UDP; SOCK_DGRAM==2==AF_INET==2 is coincidental: different enum namespaces, same integer)"]
    - [af_inet_eq_2_b,   "AF_INET.__eq__",    [2],  true, "socket.AF_INET.__eq__(2) == True (confirmed; IPv4=2; AddressFamily enum; same integer as SOCK_DGRAM=2 in SocketKind enum — coincidence)"]
    - [sock_stream_eq_1_b, "SOCK_STREAM.__eq__", [1], true, "socket.SOCK_STREAM.__eq__(1) == True (confirmed; value 1; SocketKind enum; 1 < 2 (SOCK_DGRAM))"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) and IPPROTO_UDP.__eq__(17)
#
# Wave 348 theme: IPPROTO_TCP and IPPROTO_UDP are plain int protocol numbers.
#
# IPPROTO_TCP.__eq__(6) == True (TCP protocol number 6; IANA-assigned).
# IPPROTO_UDP.__eq__(17) == True (UDP protocol number 17; IANA-assigned).
# IPPROTO_TCP.__class__.__name__ == 'int' (plain int, not IntEnum).
# IPPROTO_UDP.__class__.__name__ == 'int' (plain int, not IntEnum).
# No prior socket spec anchors IPPROTO_TCP or IPPROTO_UDP as a table under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra166.ipproto_tcp_udp_values_and_class:
  description: "socket.IPPROTO_TCP.__eq__(6)==True / IPPROTO_UDP.__eq__(17)==True / IPPROTO_TCP.__class__.__name__.__eq__('int')==True / IPPROTO_UDP.__class__.__name__.__eq__('int')==True — IPPROTO_TCP.__eq__(6) is True (IPPROTO_TCP has integer value 6; TCP protocol number 6 is assigned by IANA in RFC 793; IPPROTO_TCP is used as the protocol argument to socket.socket() for explicit TCP: socket.socket(AF_INET, SOCK_STREAM, IPPROTO_TCP)); IPPROTO_UDP.__eq__(17) is True (IPPROTO_UDP has integer value 17; UDP protocol number 17 is assigned by IANA in RFC 768; 17 = 0x11; used as protocol argument: socket.socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP)); IPPROTO_TCP.__class__.__name__ is 'int' (3 chars; unlike AF_INET which is an AddressFamily IntEnum member (13 chars) and SOCK_STREAM which is a SocketKind IntEnum member (10 chars), the IPPROTO_* constants are plain Python int values — not IntEnum; 'int'(3) << 'SocketKind'(10) << 'AddressFamily'(13)); IPPROTO_UDP.__class__.__name__ is 'int' (3 chars; same as IPPROTO_TCP; both IPPROTO_* constants are plain int, not IntEnum; this is a deliberate design choice — address families and socket kinds were enumified in Python 3.4 but protocol constants remain plain ints); first sockconst166 anchor for IPPROTO_TCP and IPPROTO_UDP values and class names"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst166

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_tcp_eq_6,    "IPPROTO_TCP.__eq__",                   [6],     true, "socket.IPPROTO_TCP.__eq__(6) == True (TCP protocol number 6; IANA RFC 793; used as protocol arg to socket())"]
    - [ipproto_udp_eq_17,   "IPPROTO_UDP.__eq__",                   [17],    true, "socket.IPPROTO_UDP.__eq__(17) == True (UDP protocol number 17; IANA RFC 768; 17=0x11; used as protocol arg to socket())"]
    - [ipproto_tcp_int,     "IPPROTO_TCP.__class__.__name__.__eq__", ["int"], true, "socket.IPPROTO_TCP.__class__.__name__ == 'int' (3 chars; plain int, not IntEnum; contrasts with AF_INET='AddressFamily'(13) and SOCK_STREAM='SocketKind'(10))"]
    - [ipproto_udp_int,     "IPPROTO_UDP.__class__.__name__.__eq__", ["int"], true, "socket.IPPROTO_UDP.__class__.__name__ == 'int' (3 chars; plain int, not IntEnum; both IPPROTO_* remain plain ints unlike AF_* and SOCK_* which are IntEnum)"]

# ---------------------------------------------------------------------------
# enum class name lengths and constant value comparison
#
# Wave 348 theme: enum type name lengths and protocol number ordering.
#
# AF_INET.__class__.__name__.__len__() == 13 ('AddressFamily' = 13 chars).
# SOCK_STREAM.__class__.__name__.__len__() == 10 ('SocketKind' = 10 chars).
# IPPROTO_TCP.__eq__(6) (confirmed; 6 < 17 = IPPROTO_UDP).
# AF_INET6.__eq__(30) (confirmed; 30 > AF_INET=2 by 28).
# No prior socket spec anchors these enum class name lengths as a table under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra166.enum_class_name_lengths_and_ordering:
  description: "socket.AF_INET.__class__.__name__.__len__()==13 / SOCK_STREAM.__class__.__name__.__len__()==10 / IPPROTO_TCP.__eq__(6)==True / AF_INET6.__eq__(30)==True — AF_INET.__class__.__name__.__len__() is 13 ('AddressFamily' = 'Address'=7 + 'Family'=6 = 13 chars; IntEnum type for address families; 'AddressFamily'(13) is the longest enum type name in this spec); SOCK_STREAM.__class__.__name__.__len__() is 10 ('SocketKind' = 'Socket'=6 + 'Kind'=4 = 10 chars; IntEnum type for socket kinds; 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars; enum name length ordering: 'int'(3) < 'SocketKind'(10) < 'AddressFamily'(13)); IPPROTO_TCP.__eq__(6) is True (confirmed; IANA TCP protocol = 6; 6 < 17 = UDP in protocol number ordering: TCP(6) < UDP(17)); AF_INET6.__eq__(30) is True (confirmed; macOS value 30; integer ordering: SOCK_STREAM(1) < AF_INET(2)==SOCK_DGRAM(2) < IPPROTO_TCP(6) < IPPROTO_UDP(17) < AF_INET6(30) on macOS); first sockconst166 anchor for enum class name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst166

  columns: [id, function, args, expected, description]
  rows:
    - [af_class_len_13,     "AF_INET.__class__.__name__.__len__",     [], 13,   "socket.AF_INET.__class__.__name__.__len__() is 13 ('AddressFamily' = 'Address'=7 + 'Family'=6 = 13; IntEnum for address families; longest enum type name)"]
    - [sock_class_len_10,   "SOCK_STREAM.__class__.__name__.__len__", [], 10,   "socket.SOCK_STREAM.__class__.__name__.__len__() is 10 ('SocketKind' = 'Socket'=6 + 'Kind'=4 = 10; IntEnum for socket kinds; 3 chars shorter than 'AddressFamily')"]
    - [ipproto_tcp_eq_6_b,  "IPPROTO_TCP.__eq__",                    [6],  true, "socket.IPPROTO_TCP.__eq__(6) == True (confirmed; IANA TCP=6; TCP(6) < UDP(17) in protocol numbering)"]
    - [af_inet6_eq_30_b,    "AF_INET6.__eq__",                       [30], true, "socket.AF_INET6.__eq__(30) == True (confirmed; macOS-specific value 30; integer ordering on macOS: 1<2<6<17<30)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET.__class__.__name__ is 'AddressFamily' (13 chars). On Python 3.4+,
# socket address families are members of the socket.AddressFamily IntEnum. AF_INET is
# the IPv4 address family with integer value 2. AddressFamily inherits from int so
# AF_INET.__eq__(2) == True. 'AddressFamily' (13 chars) = 'Address'=7 + 'Family'=6.
# AF_INET6 is also an AddressFamily member (value 30 on macOS). The AddressFamily enum
# was introduced alongside SocketKind in Python 3.4 to make socket constants self-documenting.
# No prior socket spec anchors AF_INET.__class__.__name__ as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.af_inet_class_AddressFamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6; IntEnum for socket address families; Python 3.4+); AF_INET is IPv4 address family with integer value 2; AF_INET.__eq__(2)==True (inherits from int); 'AddressFamily'(13) > 'SocketKind'(10) by 3 chars; AF_INET6.__class__.__name__=='AddressFamily' too (all AF_* constants are AddressFamily members); first sockconst166 standalone for AF_INET.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_STREAM.__class__.__name__ is 'SocketKind' (10 chars). On Python 3.4+, socket
# types are members of the socket.SocketKind IntEnum. SOCK_STREAM is the stream socket type
# with integer value 1 (used for TCP connections). SocketKind inherits from int so
# SOCK_STREAM.__eq__(1) == True. 'SocketKind' (10 chars) = 'Socket'=6 + 'Kind'=4.
# SOCK_DGRAM is also a SocketKind member (value 2, used for UDP).
# No prior socket spec anchors SOCK_STREAM.__class__.__name__ as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.sock_stream_class_SocketKind:
  description: "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — 'SocketKind' (10 chars = 'Socket'=6 + 'Kind'=4; IntEnum for socket types; Python 3.4+); SOCK_STREAM is stream socket type for reliable connection-oriented transport (TCP); integer value 1; SOCK_STREAM.__eq__(1)==True (inherits from int); SOCK_DGRAM.__class__.__name__=='SocketKind' too (all SOCK_* constants are SocketKind members); 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars; first sockconst166 standalone for SOCK_STREAM.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET.__eq__(2) is True. AF_INET has integer value 2. It is the IPv4 address
# family constant. In POSIX systems, AF_INET is defined as 2 in <sys/socket.h> (same as
# PF_INET). AF_INET is the most commonly used address family for TCP/IP networking.
# AF_INET.__eq__(2) works because AddressFamily inherits from int, so IntEnum members
# support direct integer comparison via __eq__. Note: SOCK_DGRAM also has value 2 (but in
# the SocketKind enum, not AddressFamily) — same integer, different semantic meaning.
# No prior socket spec anchors AF_INET.__eq__(2) as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.af_inet_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET has integer value 2 (POSIX AF_INET=PF_INET=2 in sys/socket.h; IPv4 address family; most common address family for TCP/IP); AddressFamily inherits from int so __eq__(2) works directly; AF_INET.__class__.__name__=='AddressFamily'(13 chars); coincidental: SOCK_DGRAM also equals 2 (SocketKind enum value 2) — same integer, different enum namespace; first sockconst166 standalone for AF_INET.__eq__(2)"
  category: identity
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__eq__(1) — standalone
#
# socket.SOCK_STREAM.__eq__(1) is True. SOCK_STREAM has integer value 1. It is the stream
# socket type used for reliable, connection-oriented, ordered, bi-directional byte-stream
# transport (TCP uses SOCK_STREAM). In POSIX, SOCK_STREAM = 1. SOCK_STREAM is the most
# commonly used socket type for TCP networking (socket.socket(AF_INET, SOCK_STREAM) creates
# a TCP socket). SOCK_STREAM.__eq__(1) works because SocketKind inherits from int.
# No prior socket spec anchors SOCK_STREAM.__eq__(1) as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.sock_stream_eq_1:
  description: "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM has integer value 1 (POSIX SOCK_STREAM=1; stream socket for reliable ordered byte-stream transport; TCP uses SOCK_STREAM; lowest-numbered socket type); SocketKind inherits from int so __eq__(1) works; SOCK_STREAM.__class__.__name__=='SocketKind'(10 chars); integer ordering: SOCK_STREAM(1) < AF_INET(2)==SOCK_DGRAM(2) < IPPROTO_TCP(6) < IPPROTO_UDP(17) < AF_INET6(30); first sockconst166 standalone for SOCK_STREAM.__eq__(1)"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET6.__eq__(30) — standalone
#
# socket.AF_INET6.__eq__(30) is True. On macOS/Darwin, AF_INET6 has integer value 30.
# This is a platform-specific value: macOS defines PF_INET6 = 30 in /usr/include/sys/socket.h.
# On Linux, AF_INET6 = 10. This spec targets macOS/Darwin 25.4.0. AF_INET6 is the IPv6
# address family constant. AF_INET6.__class__.__name__ == 'AddressFamily' (same enum as AF_INET).
# AF_INET6.__eq__(30) works because AddressFamily inherits from int.
# No prior socket spec anchors AF_INET6.__eq__(30) as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.af_inet6_eq_30:
  description: "socket.AF_INET6.__eq__(30) == True — AF_INET6 has integer value 30 on macOS/Darwin (macOS: PF_INET6=30 in /usr/include/sys/socket.h; Linux: AF_INET6=10; this spec targets macOS/Darwin 25.4.0); AF_INET6 is the IPv6 address family; AF_INET6.__class__.__name__=='AddressFamily'(13 chars; same enum as AF_INET); AF_INET==2 vs AF_INET6==30: differ by 28; integer ordering on macOS: SOCK_STREAM(1) < AF_INET(2) < IPPROTO_TCP(6) < IPPROTO_UDP(17) < AF_INET6(30); first sockconst166 standalone for AF_INET6.__eq__(30)"
  category: identity
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_DGRAM.__eq__(2) — standalone
#
# socket.SOCK_DGRAM.__eq__(2) is True. SOCK_DGRAM has integer value 2. It is the datagram
# socket type for connectionless, unreliable, unordered packet delivery (UDP uses SOCK_DGRAM).
# SOCK_DGRAM.__class__.__name__ == 'SocketKind' (IntEnum). The integer value 2 is a
# coincidence shared with AF_INET (also value 2 in the AddressFamily enum). In POSIX,
# SOCK_DGRAM = 2 and AF_INET = 2 — same integer, completely different semantics.
# socket.socket(AF_INET, SOCK_DGRAM) creates a UDP socket.
# No prior socket spec anchors SOCK_DGRAM.__eq__(2) as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.sock_dgram_eq_2:
  description: "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM has integer value 2 (datagram socket for connectionless unreliable unordered transport; UDP uses SOCK_DGRAM; socket.socket(AF_INET, SOCK_DGRAM) creates a UDP socket); SOCK_DGRAM.__class__.__name__=='SocketKind'(10 chars); SOCK_DGRAM==2==AF_INET==2 is a numerical coincidence (same integer, different enum namespaces: SocketKind vs AddressFamily); SOCK_DGRAM(2) > SOCK_STREAM(1) by 1; first sockconst166 standalone for SOCK_DGRAM.__eq__(2)"
  category: identity
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) — standalone
#
# socket.IPPROTO_TCP.__eq__(6) is True. IPPROTO_TCP has integer value 6. TCP (Transmission
# Control Protocol) is assigned protocol number 6 by IANA (defined in RFC 793, 1981).
# IPPROTO_TCP is a plain Python int (not IntEnum), unlike AF_INET and SOCK_STREAM which are
# IntEnum members. IPPROTO_TCP == 6 is the protocol number used in IP headers to identify TCP
# packets. socket.socket(AF_INET, SOCK_STREAM, IPPROTO_TCP) explicitly creates a TCP socket
# (the protocol=6 is normally implicit when using SOCK_STREAM).
# No prior socket spec anchors IPPROTO_TCP.__eq__(6) as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.ipproto_tcp_eq_6:
  description: "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP has integer value 6 (IANA TCP protocol number; RFC 793, 1981; used in IP headers; socket.socket(AF_INET, SOCK_STREAM, IPPROTO_TCP) explicitly creates TCP socket); IPPROTO_TCP.__class__.__name__=='int'(3 chars; plain int, not IntEnum — unlike AF_INET='AddressFamily' and SOCK_STREAM='SocketKind'); TCP(6) < UDP(17) in protocol number ordering; integer ordering: SOCK_STREAM(1) < AF_INET(2) < IPPROTO_TCP(6) < IPPROTO_UDP(17); first sockconst166 standalone for IPPROTO_TCP.__eq__(6)"
  category: identity
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_UDP.__eq__(17) — standalone
#
# socket.IPPROTO_UDP.__eq__(17) is True. IPPROTO_UDP has integer value 17. UDP (User
# Datagram Protocol) is assigned protocol number 17 by IANA (defined in RFC 768, 1980).
# 17 = 0x11 in hexadecimal. Like IPPROTO_TCP, IPPROTO_UDP is a plain Python int (not
# IntEnum). IPPROTO_UDP == 17 is the protocol number used in IP headers to identify UDP
# packets. socket.socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP) explicitly creates a UDP socket.
# IPPROTO_UDP (17) > IPPROTO_TCP (6) by 11.
# No prior socket spec anchors IPPROTO_UDP.__eq__(17) as a standalone under sockconst166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra166.ipproto_udp_eq_17:
