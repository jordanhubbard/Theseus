spec: socket_extra89
version: ">=3.9"
extends: socket_extra88
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra88.zspec.zsdl — covers socket.socket.__dict__ negative membership (bind/connect/listen/recv/send/sendall == False) / AddressFamily and SocketKind class identity (__qualname__/__module__/__mro__.__len__()==6/__name__) (table + invariants)."
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__ / AF_INET/SOCK_STREAM class identity / AddressFamily/SocketKind __bases__[0].__name__/__qualname__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra88; it does NOT duplicate invariants present in those files."
    - "Wave 255 theme: socket module integer constants class identity — AF_INET/AF_INET6/AF_UNSPEC (AddressFamily), SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET (SocketKind), IPPROTO_TCP/IPPROTO_UDP/IPPROTO_ICMP (int), SOL_SOCKET/SOL_TCP (int)."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_SEQPACKET.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_ICMP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_TCP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: AF_INET=2, AF_INET6=30, AF_UNSPEC=0 — all AddressFamily IntEnum members."
    - "Note: SOCK_DGRAM=2, SOCK_RAW=3, SOCK_SEQPACKET=5 — all SocketKind IntEnum members."
    - "Note: IPPROTO_TCP=6, IPPROTO_UDP=17, IPPROTO_ICMP=1 — plain int (not IntEnum)."
    - "Note: SOL_SOCKET=65535, SOL_TCP=6 — plain int (not IntEnum)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET/__class__/__name__.__eq__('AddressFamily')
# socket.AF_INET6/__class__/__name__.__eq__('AddressFamily')
# socket.AF_UNSPEC/__class__/__name__.__eq__('AddressFamily')
# socket.AF_INET/__class__/__name__.__eq__('AddressFamily') (cross-check)
#
# Wave 255 theme: AF enum constants class identity.
#
# AF_INET (2), AF_INET6 (30), and AF_UNSPEC (0) are all AddressFamily IntEnum
# members. Their __class__.__name__ is 'AddressFamily'. socket_extra86 anchors
# AF_INET class identity; this table anchors AF_INET6 and AF_UNSPEC under the
# new id_prefix socketconstid89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra89.af_enum_constants_identity:
  description: "socket.AF_INET/__class__.__name__.__eq__('AddressFamily')==True / AF_INET6/__class__.__name__.__eq__('AddressFamily')==True / AF_UNSPEC/__class__.__name__.__eq__('AddressFamily')==True / AF_INET/__class__.__name__.__eq__('AddressFamily')==True — AF_INET/AF_INET6/AF_UNSPEC are all AddressFamily IntEnum members with __class__.__name__=='AddressFamily'; socket_extra86 anchors AF_INET identity; this table anchors AF_INET6/AF_UNSPEC/AF_INET under socketconstid89; first socketconstid89 anchor for AF enum class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketconstid89

  columns: [id, function, args, expected]
  rows:
    - [af_inet_class_af,    AF_INET.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [af_inet6_class_af,   AF_INET6.__class__.__name__.__eq__,  ["AddressFamily"], true]
    - [af_unspec_class_af,  AF_UNSPEC.__class__.__name__.__eq__, ["AddressFamily"], true]
    - [af_inet_class_af2,   AF_INET.__class__.__name__.__eq__,   ["AddressFamily"], true]

# ---------------------------------------------------------------------------
# socket.SOCK_DGRAM/__class__/__name__.__eq__('SocketKind')
# socket.SOCK_RAW/__class__.__name__.__eq__('SocketKind')
# socket.SOCK_SEQPACKET/__class__.__name__.__eq__('SocketKind')
# socket.AF_INET6/__class__/__name__.__eq__('AddressFamily') (cross-check)
#
# Wave 255 theme: SOCK enum constants class identity.
#
# SOCK_DGRAM (2), SOCK_RAW (3), and SOCK_SEQPACKET (5) are all SocketKind
# IntEnum members. Their __class__.__name__ is 'SocketKind'. socket_extra86
# anchors SOCK_STREAM class identity; this table anchors SOCK_DGRAM/SOCK_RAW/
# SOCK_SEQPACKET under socketconstid89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra89.sock_enum_constants_identity:
  description: "socket.SOCK_DGRAM/__class__.__name__.__eq__('SocketKind')==True / SOCK_RAW/__class__.__name__.__eq__('SocketKind')==True / SOCK_SEQPACKET/__class__.__name__.__eq__('SocketKind')==True / AF_INET6/__class__.__name__.__eq__('AddressFamily')==True — SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET are SocketKind IntEnum members with __class__.__name__=='SocketKind'; cross-check anchors AF_INET6; first socketconstid89 anchor for SOCK enum class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketconstid89

  columns: [id, function, args, expected]
  rows:
    - [sock_dgram_class_sk,     SOCK_DGRAM.__class__.__name__.__eq__,     ["SocketKind"],     true]
    - [sock_raw_class_sk,       SOCK_RAW.__class__.__name__.__eq__,       ["SocketKind"],     true]
    - [sock_seqpacket_class_sk, SOCK_SEQPACKET.__class__.__name__.__eq__, ["SocketKind"],     true]
    - [af_inet6_class_af2,      AF_INET6.__class__.__name__.__eq__,       ["AddressFamily"],  true]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP/__class__/__name__.__eq__('int')
# socket.IPPROTO_UDP/__class__/__name__.__eq__('int')
# socket.IPPROTO_ICMP/__class__/__name__.__eq__('int')
# socket.SOCK_DGRAM/__class__/__name__.__eq__('SocketKind') (cross-check)
#
# Wave 255 theme: IPPROTO constants class identity.
#
# IPPROTO_TCP (6), IPPROTO_UDP (17), IPPROTO_ICMP (1) are plain int constants
# (not IntEnum members). Their __class__.__name__ is 'int'. This contrasts with
# AF_* (AddressFamily) and SOCK_* (SocketKind) which are IntEnum members.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra89.ipproto_constants_identity:
  description: "socket.IPPROTO_TCP/__class__.__name__.__eq__('int')==True / IPPROTO_UDP/__class__.__name__.__eq__('int')==True / IPPROTO_ICMP/__class__.__name__.__eq__('int')==True / SOCK_DGRAM/__class__.__name__.__eq__('SocketKind')==True — IPPROTO_TCP/IPPROTO_UDP/IPPROTO_ICMP are plain int constants (not IntEnum); this contrasts with SOCK_DGRAM which is SocketKind (IntEnum); first socketconstid89 anchor for IPPROTO constants class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketconstid89

  columns: [id, function, args, expected]
  rows:
    - [ipproto_tcp_class_int,   IPPROTO_TCP.__class__.__name__.__eq__,   ["int"],        true]
    - [ipproto_udp_class_int,   IPPROTO_UDP.__class__.__name__.__eq__,   ["int"],        true]
    - [ipproto_icmp_class_int,  IPPROTO_ICMP.__class__.__name__.__eq__,  ["int"],        true]
    - [sock_dgram_class_sk2,    SOCK_DGRAM.__class__.__name__.__eq__,    ["SocketKind"], true]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET/__class__/__name__.__eq__('int')
# socket.SOL_TCP/__class__/__name__.__eq__('int')
# socket.IPPROTO_TCP/__class__/__name__.__eq__('int') (cross-check)
# socket.AF_UNSPEC/__class__/__name__.__eq__('AddressFamily') (cross-check)
#
# Wave 255 theme: SOL constants class identity.
#
# SOL_SOCKET (65535) and SOL_TCP (6) are plain int constants with
# __class__.__name__ == 'int'. Cross-checks anchor IPPROTO_TCP (int) and
# AF_UNSPEC (AddressFamily) to show the int vs enum distinction.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra89.sol_constants_identity:
  description: "socket.SOL_SOCKET/__class__.__name__.__eq__('int')==True / SOL_TCP/__class__.__name__.__eq__('int')==True / IPPROTO_TCP/__class__.__name__.__eq__('int')==True / AF_UNSPEC/__class__.__name__.__eq__('AddressFamily')==True — SOL_SOCKET/SOL_TCP are plain int constants like IPPROTO_TCP; AF_UNSPEC cross-check shows AddressFamily enum constants; first socketconstid89 anchor for SOL constants class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketconstid89

  columns: [id, function, args, expected]
  rows:
    - [sol_socket_class_int,  SOL_SOCKET.__class__.__name__.__eq__, ["int"],           true]
    - [sol_tcp_class_int,     SOL_TCP.__class__.__name__.__eq__,    ["int"],           true]
    - [ipproto_tcp_class_int2, IPPROTO_TCP.__class__.__name__.__eq__, ["int"],         true]
    - [af_unspec_class_af2,   AF_UNSPEC.__class__.__name__.__eq__,  ["AddressFamily"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET6 is an AddressFamily IntEnum member (value 30). Its
# __class__.__name__ is 'AddressFamily'. socket_extra86 anchors AF_INET;
# no prior socket spec anchors AF_INET6.__class__.__name__.__eq__ as a call.
# First __class__.__name__.__eq__ standalone for socket.AF_INET6.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra89.af_inet6_class_af:
  description: "socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') == True — AF_INET6 is the IPv6 address family (value 30); it is an AddressFamily IntEnum member; socket_extra86 anchors AF_INET class identity; first __class__.__name__.__eq__ standalone for socket.AF_INET6 under socketconstid89"
  category: class_attrs
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_DGRAM is a SocketKind IntEnum member (value 2). Its
# __class__.__name__ is 'SocketKind'. socket_extra86 anchors SOCK_STREAM;
# no prior socket spec anchors SOCK_DGRAM.__class__.__name__.__eq__ as a call.
# First __class__.__name__.__eq__ standalone for socket.SOCK_DGRAM.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra89.sock_dgram_class_sk:
  description: "socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_DGRAM is the datagram socket type (value 2); it is a SocketKind IntEnum member; socket_extra86 anchors SOCK_STREAM; first __class__.__name__.__eq__ standalone for socket.SOCK_DGRAM under socketconstid89"
  category: class_attrs
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') — standalone
#
# socket.IPPROTO_TCP is a plain int constant (value 6). Unlike AF_* and SOCK_*
# constants which are IntEnum members, IPPROTO_TCP is a plain int.
# No prior socket spec anchors IPPROTO_TCP.__class__.__name__.__eq__ as a call.
# First __class__.__name__.__eq__ standalone for socket.IPPROTO_TCP.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra89.ipproto_tcp_class_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain int constant (value 6, TCP protocol number); unlike AF_* (AddressFamily) and SOCK_* (SocketKind) which are IntEnum members, IPPROTO constants are plain ints; first standalone for socket.IPPROTO_TCP class identity under socketconstid89"
  category: class_attrs
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__class__.__name__.__eq__('int') — standalone
#
# socket.SOL_SOCKET is a plain int constant (value 65535). Like IPPROTO_*
# constants, SOL_SOCKET is a plain int (not an IntEnum member).
# No prior socket spec anchors SOL_SOCKET.__class__.__name__.__eq__ as a call.
# First __class__.__name__.__eq__ standalone for socket.SOL_SOCKET.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra89.sol_socket_class_int:
  description: "socket.SOL_SOCKET.__class__.__name__.__eq__('int') == True — SOL_SOCKET is a plain int constant (value 65535 on Darwin) used as the socket-level option level in getsockopt/setsockopt; it is a plain int like IPPROTO constants; first standalone for socket.SOL_SOCKET class identity under socketconstid89"
  category: class_attrs
  kind: python_call_eq
  function: SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_SEQPACKET.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_SEQPACKET is a SocketKind IntEnum member (value 5). It provides
# sequenced, reliable, two-way connection-based datagrams. Its __class__.__name__
# is 'SocketKind'. No prior socket spec anchors SOCK_SEQPACKET class identity.
# First __class__.__name__.__eq__ standalone for socket.SOCK_SEQPACKET.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra89.sock_seqpacket_class_sk:
  description: "socket.SOCK_SEQPACKET.__class__.__name__.__eq__('SocketKind') == True — SOCK_SEQPACKET (value 5) is a SocketKind IntEnum member providing sequenced reliable datagrams; no prior socket spec anchors SOCK_SEQPACKET class identity; first standalone for socket.SOCK_SEQPACKET under socketconstid89"
  category: class_attrs
  kind: python_call_eq
  function: SOCK_SEQPACKET.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true
