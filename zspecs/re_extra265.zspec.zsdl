spec: re_extra265
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.split(r'\\s+', 'a b  c') == ['a', 'b', 'c'] — consecutive whitespace collapses into one separator."
    - "re.split(r'(\\s+)', 'a b c') keeps separator groups: ['a', ' ', 'b', ' ', 'c']."
    - "re.finditer returns a callable_iterator; calling next() on it yields match objects."
    - "match.group() on a digit match returns the matched string (e.g. '1', '2')."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.split behavioral contracts
# ---------------------------------------------------------------------------

invariant re_extra265.split.whitespace_collapse:
  description: "re.split(r'\\s+', 'a b  c') collapses double space — result is ['a', 'b', 'c']"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b  c"]
  expected: ["a", "b", "c"]

invariant re_extra265.split.single_space:
  description: "re.split(r'\\s+', 'a b c') == ['a', 'b', 'c']"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b c"]
  expected: ["a", "b", "c"]

invariant re_extra265.split.length_three:
  description: "len(re.split(r'\\s+', 'a b c')) == 3"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b c"]
  method: __len__
  expected: 3

invariant re_extra265.split.capturing_group_keeps_separators:
  description: "re.split(r'(\\s+)', 'a b c') keeps captured separators: ['a', ' ', 'b', ' ', 'c']"
  category: split
  kind: python_call_eq
  function: split
  args: ["(\\s+)", "a b c"]
  expected: ["a", " ", "b", " ", "c"]

# ---------------------------------------------------------------------------
# re.finditer — returns callable_iterator
# ---------------------------------------------------------------------------

invariant re_extra265.finditer.type_name:
  description: "type(re.finditer(r'\\d+', 'a1b2')).__name__ == 'callable_iterator'"
  category: finditer
  kind: python_call_eq
  function: finditer
  args: ["\\d+", "a1b2"]
  method: __class__.__name__.__eq__
  method_args: ["callable_iterator"]
  expected: true

invariant re_extra265.finditer.first_match_group:
  description: "next(re.finditer(r'\\d+', 'a1b2c3')).group() == '1'"
  category: finditer
  kind: python_call_eq
  function: finditer
  args: ["\\d+", "a1b2c3"]
  method: __next__
  method_chain: group
  expected: "1"
