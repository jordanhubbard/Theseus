    - ["dc2896010", "decimal.Context.__dict__.__contains__",          ["__ifloordiv__"], false]
    - ["dc2896011", "decimal.DecimalException.__dict__.__contains__", ["__ifloordiv__"], false]
    - ["dc2896012", "decimal.InvalidOperation.__dict__.__contains__", ["__ifloordiv__"], false]
    - ["dc2896013", "decimal.DivisionByZero.__dict__.__contains__",   ["__ifloordiv__"], false]
    - ["dc2896014", "decimal.Overflow.__dict__.__contains__",         ["__ifloordiv__"], false]
    - ["dc2896015", "decimal.Decimal.__dict__.__contains__",          ["__floordiv__"],  true]
    - ["dc2896016", "decimal.Context.__dict__.__contains__",          ["__floordiv__"],  false]

