  columns: [id, function, args, expected]
  rows:
    - ["dc2896017", "decimal.Decimal.__dict__.__contains__",          ["__imod__"], false]
    - ["dc2896018", "decimal.Context.__dict__.__contains__",          ["__imod__"], false]
    - ["dc2896019", "decimal.DecimalException.__dict__.__contains__", ["__imod__"], false]
    - ["dc2896020", "decimal.InvalidOperation.__dict__.__contains__", ["__imod__"], false]
    - ["dc2896021", "decimal.DivisionByZero.__dict__.__contains__",   ["__imod__"], false]
    - ["dc2896022", "decimal.Overflow.__dict__.__contains__",         ["__imod__"], false]
    - ["dc2896023", "decimal.Decimal.__dict__.__contains__",          ["__mod__"],  true]
    - ["dc2896024", "decimal.Context.__dict__.__contains__",          ["__mod__"],  false]

# ---------------------------------------------------------------------------
# Table: Decimal in-place division profile — all three absent despite non-inplace being present
# The truediv/floordiv/mod vs itruediv/ifloordiv/imod asymmetry is the key insight
# ---------------------------------------------------------------------------

table dc2896.combined:
  description: "decimal.Decimal defines __truediv__, __floordiv__, __mod__ but NOT their __i*__ in-place counterparts — immutability means augmented assignment rebinds, not mutates"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2896

  columns: [id, function, args, expected]
  rows:
    - ["dc2896025", "decimal.Decimal.__dict__.__contains__", ["__truediv__"],   true]
    - ["dc2896026", "decimal.Decimal.__dict__.__contains__", ["__floordiv__"],  true]
    - ["dc2896027", "decimal.Decimal.__dict__.__contains__", ["__mod__"],       true]
    - ["dc2896028", "decimal.Decimal.__dict__.__contains__", ["__itruediv__"],  false]
    - ["dc2896029", "decimal.Decimal.__dict__.__contains__", ["__ifloordiv__"], false]
    - ["dc2896030", "decimal.Decimal.__dict__.__contains__", ["__imod__"],      false]
    - ["dc2896031", "decimal.Clamped.__dict__.__contains__",        ["__itruediv__"],  false]
    - ["dc2896032", "decimal.Inexact.__dict__.__contains__",        ["__ifloordiv__"], false]
    - ["dc2896033", "decimal.Rounded.__dict__.__contains__",        ["__imod__"],      false]
    - ["dc2896034", "decimal.Subnormal.__dict__.__contains__",      ["__itruediv__"],  false]
    - ["dc2896035", "decimal.Underflow.__dict__.__contains__",      ["__ifloordiv__"], false]
    - ["dc2896036", "decimal.FloatOperation.__dict__.__contains__", ["__imod__"],      false]
