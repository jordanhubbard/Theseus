spec: decimal_extra2
version: ">=3.0"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Decimal.__name__ == 'Decimal'."
    - "decimal.Context.__name__ == 'Context'."
    - "decimal.DecimalException.__name__ == 'DecimalException'."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — rounding constant is a string."
    - "decimal.ROUND_DOWN == 'ROUND_DOWN' — rounding constant is a string."
    - "decimal.MAX_PREC is an int (999999999999999999 on CPython 3.12) and is greater than 0."
    - "Decimal+Decimal arithmetic cannot be tested via ZSDL method_args (no call_args support); int addition is used instead."
    - "Decimal('1.5').__add__(2) == Decimal('3.5') — __str__ gives '3.5'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name identity
# ---------------------------------------------------------------------------

invariant decimal_extra2.Decimal.dunder_name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra2.Context.dunder_name:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra2.DecimalException.dunder_name:
  description: "decimal.DecimalException.__name__ == 'DecimalException'"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

# ---------------------------------------------------------------------------
# Rounding constants
# ---------------------------------------------------------------------------

invariant decimal_extra2.ROUND_HALF_UP.value:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra2.ROUND_DOWN.value:
  description: "decimal.ROUND_DOWN == 'ROUND_DOWN'"
  category: constants
  kind: python_call_eq
  function: ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

# ---------------------------------------------------------------------------
# MAX_PREC is an int and is positive
# ---------------------------------------------------------------------------

invariant decimal_extra2.MAX_PREC.is_int:
  description: "type(decimal.MAX_PREC).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra2.MAX_PREC.is_positive:
  description: "decimal.MAX_PREC > 0"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Basic arithmetic — Decimal + int (Decimal+Decimal cannot be expressed in ZSDL)
# ---------------------------------------------------------------------------

invariant decimal_extra2.Decimal.add_int:
  description: "Decimal('1.5').__add__(2).__str__() == '3.5'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __add__
  method_args: [2]
  method_chain: __str__
  expected: "3.5"
