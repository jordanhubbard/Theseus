# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant itertools_extra104.chain_qualname_len:
  description: "itertools.chain.__qualname__.__len__() == 5 — C extension type qualname is 'chain'; wave 257; new to extra104"
  kind: python_call_eq
  function: chain.__qualname__.__len__
  args: []
  expected: 5

invariant itertools_extra104.combinations_with_replacement_qualname_len:
  description: "itertools.combinations_with_replacement.__qualname__.__len__() == 29 — longest qualname in itertools; wave 257; new to extra104"
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__len__
  args: []
  expected: 29

invariant itertools_extra104.accumulate_qualname_eq:
  description: "itertools.accumulate.__qualname__ == 'accumulate' — C extension type qualname matches type name; wave 257; new to extra104"
  kind: python_call_eq
  function: accumulate.__qualname__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra104.permutations_qualname_len:
  description: "itertools.permutations.__qualname__.__len__() == 12 — C extension type qualname 'permutations' has 12 chars; wave 257; new to extra104"
