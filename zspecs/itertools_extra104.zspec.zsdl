spec: itertools_extra104
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra99

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra99.zspec.zsdl."
    - "This spec covers: itertools C-type __qualname__ string lengths for all 17 types; the __qualname__ value equals the simple type name for all C extension types (Wave 257)."
    - "itertools.chain.__qualname__ == 'chain', len 5. Verified with Python 3.14.3."
    - "itertools.cycle.__qualname__ == 'cycle', len 5. Verified with Python 3.14.3."
    - "itertools.repeat.__qualname__ == 'repeat', len 6. Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count', len 5. Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product', len 7. Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations', len 12. Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations', len 12. Verified with Python 3.14.3."
    - "itertools.accumulate.__qualname__ == 'accumulate', len 10. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest', len 11. Verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress', len 8. Verified with Python 3.14.3."
    - "itertools.dropwhile.__qualname__ == 'dropwhile', len 9. Verified with Python 3.14.3."
    - "itertools.takewhile.__qualname__ == 'takewhile', len 9. Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby', len 7. Verified with Python 3.14.3."
    - "itertools.islice.__qualname__ == 'islice', len 6. Verified with Python 3.14.3."
    - "itertools.filterfalse.__qualname__ == 'filterfalse', len 11. Verified with Python 3.14.3."
    - "itertools.starmap.__qualname__ == 'starmap', len 7. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement', len 29. Verified with Python 3.14.3."
    - "itertools.pairwise.__qualname__ == 'pairwise', len 8. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __qualname__ string lengths (short types)
#
# Wave 257 theme: itertools C-type __qualname__ lengths — short names (len <= 8).
#
# itertools.chain.__qualname__.__len__() == 5
# itertools.cycle.__qualname__.__len__() == 5
# itertools.count.__qualname__.__len__() == 5
# itertools.repeat.__qualname__.__len__() == 6
# itertools.islice.__qualname__.__len__() == 6
# itertools.product.__qualname__.__len__() == 7
# itertools.groupby.__qualname__.__len__() == 7
# itertools.starmap.__qualname__.__len__() == 7
# itertools.compress.__qualname__.__len__() == 8
# itertools.pairwise.__qualname__.__len__() == 8
#
# C extension types have __qualname__ equal to the simple type name (no module prefix).
# New to extra104.
# ---------------------------------------------------------------------------

table itertools_extra104.qualname_lengths_short:
  description: "itertools C-type __qualname__.__len__() for short names (len 5-8): chain/cycle/count/repeat/islice/product/groupby/starmap/compress/pairwise; wave 257; new to extra104"
  kind: python_call_eq
  category: string_lengths
  id_prefix: itertoolsqn104

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_len_5,
       "chain.__qualname__.__len__",
       [],
       5,
       "itertools.chain.__qualname__.__len__() == 5 — itertools.chain is a C extension type; its __qualname__ is 'chain' (5 characters), equal to its simple type name; len('chain') == 5; new to extra104"]
    - [cycle_qualname_len_5,
       "cycle.__qualname__.__len__",
       [],
       5,
       "itertools.cycle.__qualname__.__len__() == 5 — itertools.cycle is a C extension type; its __qualname__ is 'cycle' (5 characters); len('cycle') == 5; new to extra104"]
    - [count_qualname_len_5,
       "count.__qualname__.__len__",
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — itertools.count is a C extension type; its __qualname__ is 'count' (5 characters); len('count') == 5; new to extra104"]
    - [repeat_qualname_len_6,
       "repeat.__qualname__.__len__",
       [],
       6,
       "itertools.repeat.__qualname__.__len__() == 6 — itertools.repeat is a C extension type; its __qualname__ is 'repeat' (6 characters); len('repeat') == 6; new to extra104"]
    - [islice_qualname_len_6,
       "islice.__qualname__.__len__",
       [],
       6,
       "itertools.islice.__qualname__.__len__() == 6 — itertools.islice is a C extension type; its __qualname__ is 'islice' (6 characters); len('islice') == 6; new to extra104"]
    - [product_qualname_len_7,
       "product.__qualname__.__len__",
       [],
       7,
       "itertools.product.__qualname__.__len__() == 7 — itertools.product is a C extension type; its __qualname__ is 'product' (7 characters); len('product') == 7; new to extra104"]
    - [groupby_qualname_len_7,
       "groupby.__qualname__.__len__",
       [],
       7,
       "itertools.groupby.__qualname__.__len__() == 7 — itertools.groupby is a C extension type; its __qualname__ is 'groupby' (7 characters); len('groupby') == 7; new to extra104"]
    - [starmap_qualname_len_7,
       "starmap.__qualname__.__len__",
       [],
       7,
       "itertools.starmap.__qualname__.__len__() == 7 — itertools.starmap is a C extension type; its __qualname__ is 'starmap' (7 characters); len('starmap') == 7; new to extra104"]
    - [compress_qualname_len_8,
       "compress.__qualname__.__len__",
       [],
       8,
       "itertools.compress.__qualname__.__len__() == 8 — itertools.compress is a C extension type; its __qualname__ is 'compress' (8 characters); len('compress') == 8; new to extra104"]
    - [pairwise_qualname_len_8,
       "pairwise.__qualname__.__len__",
       [],
       8,
       "itertools.pairwise.__qualname__.__len__() == 8 — itertools.pairwise is a C extension type added in Python 3.10; its __qualname__ is 'pairwise' (8 characters); len('pairwise') == 8; new to extra104"]

