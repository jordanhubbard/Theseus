# ---------------------------------------------------------------------------
# Table 3: itertools C-type __qualname__ string equality (selected types)
#
# Wave 257 theme: itertools C-type __qualname__ string value identity.
#
# itertools.chain.__qualname__.__eq__('chain') == True
# itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True
# itertools.zip_longest.__qualname__.__eq__('zip_longest') == True
# itertools.filterfalse.__qualname__.__eq__('filterfalse') == True
# itertools.accumulate.__qualname__.__eq__('accumulate') == True
# itertools.pairwise.__qualname__.__eq__('pairwise') == True
#
# New to extra104.
# ---------------------------------------------------------------------------

table itertools_extra104.qualname_eq_values:
  description: "itertools C-type __qualname__.__eq__(value) identity checks for selected types; wave 257; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqneq104

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq_chain,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — itertools.chain is a C extension type; __qualname__ equals the simple type name 'chain'; str.__eq__('chain') returns True; new to extra104"]
    - [combinations_with_replacement_qualname_eq,
       "combinations_with_replacement.__qualname__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True — the __qualname__ of this C extension type is the full type name 'combinations_with_replacement'; str.__eq__('combinations_with_replacement') returns True; new to extra104"]
    - [zip_longest_qualname_eq,
       "zip_longest.__qualname__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — itertools.zip_longest's __qualname__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra104"]
    - [filterfalse_qualname_eq,
       "filterfalse.__qualname__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — itertools.filterfalse's __qualname__ is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra104"]
    - [accumulate_qualname_eq,
       "accumulate.__qualname__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — itertools.accumulate's __qualname__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra104"]
    - [pairwise_qualname_eq,
       "pairwise.__qualname__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__qualname__.__eq__('pairwise') == True — itertools.pairwise (added Python 3.10) __qualname__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra104"]

