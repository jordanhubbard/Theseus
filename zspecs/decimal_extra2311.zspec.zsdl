spec: decimal_extra2311
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks."
    - "decimal module types are all concrete — none are abstract."
    - "decimal.Decimal and decimal.Context are C extension types (from _decimal); decimal.DecimalException is a Python Exception subclass."
    - "All DecimalException subclasses (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal) are also non-abstract."
    - "None of these types set __abstractmethods__ in their own __dict__."
    - "Accessing .__abstractmethods__ on any decimal type raises AttributeError."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ dict-presence for decimal types
#
# None of the decimal public types set __abstractmethods__ in their own __dict__.
# Expected: False for all.
# ---------------------------------------------------------------------------

table decimal_extra2311.abstract_absence:
  description: "decimal types have no __abstractmethods__ in class __dict__ — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2311

  columns: [id, function, args, expected]
  rows:
    - ["dc2311001", "decimal.Decimal.__dict__.__contains__",          ["__abstractmethods__"], false]
    - ["dc2311002", "decimal.Context.__dict__.__contains__",          ["__abstractmethods__"], false]
    - ["dc2311003", "decimal.DecimalException.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["dc2311004", "decimal.InvalidOperation.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["dc2311005", "decimal.DivisionByZero.__dict__.__contains__",   ["__abstractmethods__"], false]
    - ["dc2311006", "decimal.Overflow.__dict__.__contains__",         ["__abstractmethods__"], false]
    - ["dc2311007", "decimal.Underflow.__dict__.__contains__",        ["__abstractmethods__"], false]
    - ["dc2311008", "decimal.Inexact.__dict__.__contains__",          ["__abstractmethods__"], false]
    - ["dc2311009", "decimal.Rounded.__dict__.__contains__",          ["__abstractmethods__"], false]
    - ["dc2311010", "decimal.Subnormal.__dict__.__contains__",        ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__.__len__ raises AttributeError
#
# Since __abstractmethods__ is absent from each type's __dict__ and no MRO
# base provides it, .__abstractmethods__.__len__ raises AttributeError.
# ---------------------------------------------------------------------------

table decimal_extra2311.abstract_len_error:
  description: "decimal types raise AttributeError on __abstractmethods__.__len__ — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: dc2311

  columns: [id, function, args, expected]
  rows:
    - ["dc2311011", "decimal.Decimal.__abstractmethods__.__len__",          [], "AttributeError"]
    - ["dc2311012", "decimal.Context.__abstractmethods__.__len__",          [], "AttributeError"]
    - ["dc2311013", "decimal.DecimalException.__abstractmethods__.__len__", [], "AttributeError"]
    - ["dc2311014", "decimal.InvalidOperation.__abstractmethods__.__len__", [], "AttributeError"]
    - ["dc2311015", "decimal.DivisionByZero.__abstractmethods__.__len__",   [], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__.__contains__ raises AttributeError — decimal.Decimal
#
# Chained .__abstractmethods__.__contains__ raises AttributeError because the
# intermediate __abstractmethods__ attribute does not exist on the Decimal C type.
# Representative method names: __add__, __mul__, sqrt, quantize, compare.
# ---------------------------------------------------------------------------

table decimal_extra2311.decimal_contains_error:
  description: "decimal.Decimal __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: dc2311

  columns: [id, function, args, expected]
  rows:
    - ["dc2311016", "decimal.Decimal.__abstractmethods__.__contains__", ["__add__"],   "AttributeError"]
    - ["dc2311017", "decimal.Decimal.__abstractmethods__.__contains__", ["__mul__"],   "AttributeError"]
    - ["dc2311018", "decimal.Decimal.__abstractmethods__.__contains__", ["sqrt"],      "AttributeError"]
    - ["dc2311019", "decimal.Decimal.__abstractmethods__.__contains__", ["quantize"],  "AttributeError"]
    - ["dc2311020", "decimal.Decimal.__abstractmethods__.__contains__", ["compare"],   "AttributeError"]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__.__contains__ raises AttributeError — decimal.Context
#
# Representative method names: create_decimal, sqrt, quantize, clear_traps.
# ---------------------------------------------------------------------------

table decimal_extra2311.context_contains_error:
  description: "decimal.Context __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: dc2311

  columns: [id, function, args, expected]
  rows:
    - ["dc2311021", "decimal.Context.__abstractmethods__.__contains__", ["create_decimal"], "AttributeError"]
    - ["dc2311022", "decimal.Context.__abstractmethods__.__contains__", ["sqrt"],           "AttributeError"]
    - ["dc2311023", "decimal.Context.__abstractmethods__.__contains__", ["quantize"],       "AttributeError"]
    - ["dc2311024", "decimal.Context.__abstractmethods__.__contains__", ["clear_traps"],    "AttributeError"]

# ---------------------------------------------------------------------------
# Table 5: __abstractmethods__.__contains__ raises AttributeError — exception subclasses
#
# All DecimalException subclasses are non-abstract exception classes.
# Chained __abstractmethods__.__contains__ access raises AttributeError.
# ---------------------------------------------------------------------------

table decimal_extra2311.exception_contains_error:
  description: "decimal exception subclasses __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: dc2311

  columns: [id, function, args, expected]
  rows:
    - ["dc2311025", "decimal.DecimalException.__abstractmethods__.__contains__", ["__str__"],  "AttributeError"]
    - ["dc2311026", "decimal.InvalidOperation.__abstractmethods__.__contains__", ["handle"],   "AttributeError"]
    - ["dc2311027", "decimal.DivisionByZero.__abstractmethods__.__contains__",   ["handle"],   "AttributeError"]
    - ["dc2311028", "decimal.Overflow.__abstractmethods__.__contains__",         ["handle"],   "AttributeError"]
    - ["dc2311029", "decimal.Underflow.__abstractmethods__.__contains__",        ["handle"],   "AttributeError"]
    - ["dc2311030", "decimal.Inexact.__abstractmethods__.__contains__",          ["handle"],   "AttributeError"]
