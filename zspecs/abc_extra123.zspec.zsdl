#
# ABCMeta.__init__.__qualname__                == 'type.__init__'    (len=13)
# ABCMeta.__init__.__class__.__name__          == 'wrapper_descriptor'
# ABCMeta.register.__code__.co_varnames[0]     == 'cls'
# ABCMeta.register.__code__.co_varnames[1]     == 'subclass'
# ABCMeta.register.__code__.co_varnames.__len__() == 2
# ABCMeta.__new__.__qualname__.__len__()       == 15  ('ABCMeta.__new__')
# ---------------------------------------------------------------------------

table abc_extra123.abc_abcmeta_init_register_details:
  description: "abc.ABCMeta.__init__ qualname and ABCMeta.register co_varnames checks in abcmetanew123 namespace — wave 256 theme: ABCMeta.__init__ is inherited from type (not defined in Lib/abc.py); abc.ABCMeta.__init__.__class__.__name__.__eq__('wrapper_descriptor')==True (C-level wrapper around type.__init__; covered in extra99 for cross-reference); abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__')==True (len=13: 'type.'=5+'__init__'=8=13; qualname uses defining class 'type'); abc.ABCMeta.__init__.__qualname__.__len__()==13; this contrasts with ABCMeta.__new__ whose qualname is 'ABCMeta.__new__' (len=15, Python-defined); abc.ABCMeta.register.__code__.co_varnames.__getitem__(0).__eq__('cls')==True (register is a classmethod; first param is 'cls' not 'mcls' — the metaclass convention of 'mcls' is only used in __new__); abc.ABCMeta.register.__code__.co_varnames.__getitem__(1).__eq__('subclass')==True (second param is 'subclass': the class being registered as a virtual subclass); abc.ABCMeta.register.__code__.co_varnames.__len__()==2 (only 2 co_varnames: cls and subclass; no extra locals); ABCMeta.__new__.__qualname__.__len__()==15 (len=15: 'ABCMeta.'=8+'__new__'=7=15, two more than __init__'s 13); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: abcmetanew123b

  columns: [id, function, args, expected, description]
  rows:
    - [init_cls_eq,   abc.ABCMeta.__init__.__class__.__name__.__eq__,              ["wrapper_descriptor"],  true,      "abc.ABCMeta.__init__.__class__.__name__ == 'wrapper_descriptor' (inherited from type, C-level); verified with Python 3.14.3"]
    - [init_qn_eq,    abc.ABCMeta.__init__.__qualname__.__eq__,                     ["type.__init__"],       true,      "abc.ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13, qualname uses defining class 'type'); verified with Python 3.14.3"]
    - [init_qn_len,   abc.ABCMeta.__init__.__qualname__.__len__,                    [],                      13,        "abc.ABCMeta.__init__.__qualname__.__len__() == 13 ('type.'=5+'__init__'=8=13); verified with Python 3.14.3"]
    - [reg_var0,      abc.ABCMeta.register.__code__.co_varnames.__getitem__,        [0],                     "cls",     "abc.ABCMeta.register.__code__.co_varnames[0] == 'cls' (classmethod uses 'cls', not 'mcls'); verified with Python 3.14.3"]
    - [reg_var1,      abc.ABCMeta.register.__code__.co_varnames.__getitem__,        [1],                     "subclass","abc.ABCMeta.register.__code__.co_varnames[1] == 'subclass' (the class being registered); verified with Python 3.14.3"]
    - [reg_varlen,    abc.ABCMeta.register.__code__.co_varnames.__len__,            [],                      2,         "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2 (cls, subclass; no extra locals); verified with Python 3.14.3"]
    - [new_qn_len,    abc.ABCMeta.__new__.__qualname__.__len__,                     [],                      15,        "abc.ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.'=8+'__new__'=7=15, two more than type.__init__=13); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant abc_extra123.ABCMeta_new_var0_is_mcls:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__getitem__(0) == 'mcls' — ABCMeta.__new__.__code__.co_varnames[0] is 'mcls'; this is the metaclass convention: in a metaclass __new__, the first parameter receives the metaclass object itself; Python convention uses 'mcls' (short for 'metaclass') to distinguish it from 'cls' (used in classmethods where it receives a class instance) and 'self' (used in instance methods); compare: ABCMeta.register uses 'cls' as co_varnames[0] (classmethod convention), ABCMeta.__new__ uses 'mcls' (metaclass __new__ convention); ABCMeta.__new__.__code__.co_argcount is 4 (mcls, name, bases, namespace); ABCMeta.__new__.__code__.co_varnames.__len__() is 6 (4 positional + kwargs + cls local); NEW in extra123: first standalone ABCMeta.__new__ co_varnames[0] invariant in abcmetanew123 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_varnames.__getitem__
  args: [0]
  expected: "mcls"

invariant abc_extra123.ABCMeta_new_varnames_len_6:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — ABCMeta.__new__.__code__.co_varnames is ('mcls', 'name', 'bases', 'namespace', 'kwargs', 'cls'); the 6 entries consist of: 4 positional params (mcls, name, bases, namespace as counted by co_argcount=4), 1 variadic dict local ('kwargs' from **kwargs), and 1 local variable ('cls': the new class created by super().__new__); co_varnames.__len__()==6 while co_argcount==4: the 2-entry difference is 'kwargs' + 'cls'; compare ABCMeta method co_varnames lengths: register=2 (cls, subclass), __new__=6 (mcls, name, bases, namespace, kwargs, cls); ABCMeta.__new__.__code__.co_name is '__new__' (len=7); ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (len=15); NEW in extra123: first standalone ABCMeta.__new__ co_varnames length invariant in abcmetanew123 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant abc_extra123.ABCMeta_mro_len_is_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — abc.ABCMeta.__mro__ is [ABCMeta, type, object]; this 3-element MRO reflects that ABCMeta inherits from type (the root metaclass); ABCMeta.__bases__[0].__name__ is 'type' (direct base); ABCMeta.__mro__[1].__name__ is 'type' (second in MRO); ABCMeta.__mro__[2].__name__ is 'object' (root); compare: abc.ABC.__mro__.__len__()==2 ([ABC, object]) because ABC is a regular class inheriting from object; ABCMeta.__mro__.__len__()==3 because ABCMeta is a metaclass inheriting from type, inserting type between ABCMeta and object; ABCMeta.__name__ is 'ABCMeta' (len=7); NEW in extra123: first standalone ABCMeta MRO length invariant in abcmetanew123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra123.ABCMeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — abc.ABCMeta inherits directly from type; this single inheritance from type makes ABCMeta a metaclass: instances of ABCMeta are themselves classes (class objects); the inheritance from type gives ABCMeta all the metaclass machinery (class creation, __new__, __init__, etc.) while ABCMeta adds abstract method tracking; ABCMeta.__bases__[0].__name__ is 'type' (not 'object'); contrast with abc.ABC.__bases__[0].__name__ which is 'object' (ABC is a regular class); ABCMeta.__mro__ is [ABCMeta, type, object] (3-element chain with type as the intermediate class); NEW in extra123: first standalone ABCMeta base class 'type' invariant in abcmetanew123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra123.ABCMeta_new_co_name_len_7:
  description: "abc.ABCMeta.__new__.__code__.co_name.__len__() == 7 — abc.ABCMeta.__new__.__code__.co_name is '__new__' (7 chars: '__'=2+'new'=3+'__'=2=7); co_name is the name of the function as stored in the code object; compare co_name lengths for ABCMeta methods: '__new__'=7, '__init__'=8 (but __init__ is inherited from type and lacks __code__); for Python-defined methods: '__new__'=7 (shortest dunder in spec), 'register'=8 (no dunder wrappers); ABCMeta.__new__.__qualname__.__len__() is 15 ('ABCMeta.__new__': qualname has 'ABCMeta.' prefix adding 8 chars before '__new__'); ABCMeta.__new__.__code__.co_argcount is 4; ABCMeta.__new__.__code__.co_varnames.__len__() is 6; NEW in extra123: first standalone ABCMeta.__new__ co_name length invariant in abcmetanew123 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_name.__len__
  args: []
  expected: 7

