spec: abc_extra123
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 256 theme — abc.ABCMeta.__new__ co_varnames details and ABCMeta class hierarchy. NEW in extra123: ABCMeta.__new__.__code__.co_varnames[0]=='mcls' (metaclass instance, not 'cls' or 'self'); ABCMeta.__new__.__code__.co_varnames[1]=='name'; ABCMeta.__new__.__code__.co_varnames[4]=='kwargs'; ABCMeta.__new__.__code__.co_varnames[5]=='cls'; ABCMeta.__new__.__code__.co_varnames.__len__()==6 (4 positional + kwargs dict + cls local); ABCMeta.__new__.__code__.co_name=='__new__' (len=7); ABCMeta.__init__.__qualname__=='type.__init__' (len=13, inherited from type); abc.ABCMeta.__mro__.__len__()==3 (MRO=[ABCMeta, type, object]); abc.ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type, not directly from object); abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.register.__code__.co_varnames.__len__()==2 (cls, subclass only). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__.__code__.co_varnames[0] == 'mcls'. ABCMeta.__new__ uses 'mcls' (not 'cls' or 'self') as the first parameter name — this is the metaclass convention: __new__ on a metaclass receives the metaclass itself as the first arg (abbreviated 'mcls'); co_argcount==4 covers mcls, name, bases, namespace; co_varnames has 6 entries total with 'kwargs' and 'cls' as locals (verified in extra99: co_argcount==4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__mro__.__len__() == 3. ABCMeta's MRO is [ABCMeta, type, object]; ABCMeta inherits from type (the metaclass for all Python classes), so ABCMeta is itself a metaclass; this contrasts with abc.ABC whose __mro__.__len__()==2 ([ABC, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type'. ABCMeta inherits directly from type (not from object); this makes ABCMeta a metaclass — instances of ABCMeta are themselves classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ co_varnames details — extra123
#
# Wave 256 theme: abc.ABCMeta.__new__ co_varnames details and ABCMeta class hierarchy.
#
# ABCMeta.__new__.__code__.co_varnames[0]     == 'mcls'       (metaclass convention)
# ABCMeta.__new__.__code__.co_varnames[1]     == 'name'
# ABCMeta.__new__.__code__.co_varnames[4]     == 'kwargs'     (local from **kwargs)
# ABCMeta.__new__.__code__.co_varnames[5]     == 'cls'        (local: the new class)
# ABCMeta.__new__.__code__.co_varnames.__len__() == 6
# ABCMeta.__new__.__code__.co_name            == '__new__'    (len=7)
# ---------------------------------------------------------------------------

table abc_extra123.abc_abcmeta_new_varnames:
  description: "abc.ABCMeta.__new__ __code__.co_varnames detail checks in abcmetanew123 namespace — wave 256 theme: abc.ABCMeta.__new__ is Python-defined in Lib/abc.py with signature '__new__(mcls, name, bases, namespace, /, **kwargs)'; co_varnames[0] is 'mcls' — the metaclass convention uses 'mcls' (not 'cls' or 'self') to distinguish the metaclass instance from regular class instances; abc.ABCMeta.__new__.__code__.co_varnames.__getitem__(0).__eq__('mcls')==True; abc.ABCMeta.__new__.__code__.co_varnames.__getitem__(1).__eq__('name')==True (the class name string being created); abc.ABCMeta.__new__.__code__.co_varnames.__getitem__(4).__eq__('kwargs')==True (co_varnames[4] is the 'kwargs' dict collected from **kwargs — position 4 because co_argcount=4 positional params come first at indices 0-3, then variadic **kwargs dict at index 4); abc.ABCMeta.__new__.__code__.co_varnames.__getitem__(5).__eq__('cls')==True (co_varnames[5] is 'cls': a local variable holding the new class instance after it is created by super().__new__); abc.ABCMeta.__new__.__code__.co_varnames.__len__()==6 (6 total: 4 positional params + kwargs dict + cls local); abc.ABCMeta.__new__.__code__.co_name.__eq__('__new__')==True (the function name stored in the code object); abc.ABCMeta.__new__.__code__.co_name.__len__()==7 (len=7: '__'=2+'new'=3+'__'=2=7); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: abcmetanew123

  columns: [id, function, args, expected, description]
  rows:
    - [new_var0,     abc.ABCMeta.__new__.__code__.co_varnames.__getitem__,    [0],   "mcls",    "ABCMeta.__new__.__code__.co_varnames[0] == 'mcls' (metaclass convention, not 'cls' or 'self'); verified with Python 3.14.3"]
    - [new_var1,     abc.ABCMeta.__new__.__code__.co_varnames.__getitem__,    [1],   "name",    "ABCMeta.__new__.__code__.co_varnames[1] == 'name' (the new class name string); verified with Python 3.14.3"]
    - [new_var4,     abc.ABCMeta.__new__.__code__.co_varnames.__getitem__,    [4],   "kwargs",  "ABCMeta.__new__.__code__.co_varnames[4] == 'kwargs' (the **kwargs dict, at index 4 after 4 positional params); verified with Python 3.14.3"]
    - [new_var5,     abc.ABCMeta.__new__.__code__.co_varnames.__getitem__,    [5],   "cls",     "ABCMeta.__new__.__code__.co_varnames[5] == 'cls' (local variable holding the new class instance); verified with Python 3.14.3"]
    - [new_varlen,   abc.ABCMeta.__new__.__code__.co_varnames.__len__,        [],    6,         "ABCMeta.__new__.__code__.co_varnames.__len__() == 6 (4 positional + kwargs + cls local); verified with Python 3.14.3"]
    - [new_cn_eq,    abc.ABCMeta.__new__.__code__.co_name.__eq__,             ["__new__"], true, "ABCMeta.__new__.__code__.co_name == '__new__' (the function name in the code object); verified with Python 3.14.3"]
    - [new_cn_len,   abc.ABCMeta.__new__.__code__.co_name.__len__,            [],    7,         "ABCMeta.__new__.__code__.co_name.__len__() == 7 ('__'=2+'new'=3+'__'=2=7); verified with Python 3.14.3"]
    - [new_argc,     abc.ABCMeta.__new__.__code__.co_argcount.__eq__,         [4],   true,      "ABCMeta.__new__.__code__.co_argcount == 4 (mcls, name, bases, namespace; covered in extra99 for cross-ref); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class hierarchy identity — extra123
#
# Wave 256 theme: ABCMeta class hierarchy.
#
# abc.ABCMeta.__name__              == 'ABCMeta'   (len=7)
# abc.ABCMeta.__mro__.__len__()     == 3   [ABCMeta, type, object]
# abc.ABCMeta.__bases__[0].__name__ == 'type'   (inherits from type — ABCMeta is a metaclass)
# abc.ABCMeta.__mro__[1].__name__   == 'type'
# abc.ABCMeta.__mro__[2].__name__   == 'object'
# abc.ABCMeta.__class__.__name__    == 'type'
# ---------------------------------------------------------------------------

table abc_extra123.abc_abcmeta_class_hierarchy:
  description: "abc.ABCMeta class hierarchy identity checks in abcmetanew123 namespace — wave 256 theme: abc.ABCMeta is a metaclass defined in Lib/abc.py; ABCMeta inherits from type (not from object directly), making instances of ABCMeta themselves classes with abstract method support; abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABC'=3+'Meta'=4=7); abc.ABCMeta.__name__.__len__()==7; abc.ABCMeta.__mro__.__len__()==3 (MRO=[ABCMeta, type, object]; 3-element chain because ABCMeta inserts type between itself and object); abc.ABCMeta.__mro__[1].__name__.__eq__('type')==True (second element is type — the metaclass for all Python classes); abc.ABCMeta.__mro__[2].__name__.__eq__('object')==True (third element is object — the root of all Python classes); abc.ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta directly inherits from type, not from object); abc.ABCMeta.__class__.__name__.__eq__('type')==True (ABCMeta is an instance of type — all classes are instances of type); abc.ABCMeta.__module__.__eq__('abc')==True (defined in Lib/abc.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanew123a

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name_eq,   abc.ABCMeta.__name__.__eq__,                       ["ABCMeta"],  true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); verified with Python 3.14.3"]
    - [meta_name_len,  abc.ABCMeta.__name__.__len__,                      [],           7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [meta_mro_len,   abc.ABCMeta.__mro__.__len__,                       [],           3,    "abc.ABCMeta.__mro__.__len__() == 3 (MRO: [ABCMeta, type, object]); verified with Python 3.14.3"]
    - [meta_mro1,      "abc.ABCMeta.__mro__[1].__name__.__eq__",          ["type"],     true, "abc.ABCMeta.__mro__[1].__name__ == 'type' (second in MRO — ABCMeta inherits from type); verified with Python 3.14.3"]
    - [meta_mro2,      "abc.ABCMeta.__mro__[2].__name__.__eq__",          ["object"],   true, "abc.ABCMeta.__mro__[2].__name__ == 'object' (third in MRO — root class); verified with Python 3.14.3"]
    - [meta_base0,     "abc.ABCMeta.__bases__[0].__name__.__eq__",        ["type"],     true, "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta inherits from type, making it a metaclass); verified with Python 3.14.3"]
    - [meta_cls_eq,    abc.ABCMeta.__class__.__name__.__eq__,             ["type"],     true, "abc.ABCMeta.__class__.__name__ == 'type' (ABCMeta is an instance of type — as all classes are); verified with Python 3.14.3"]
    - [meta_module,    abc.ABCMeta.__module__.__eq__,                     ["abc"],      true, "abc.ABCMeta.__module__ == 'abc' (defined in Lib/abc.py); verified with Python 3.14.3"]

