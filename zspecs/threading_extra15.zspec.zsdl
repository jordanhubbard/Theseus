spec: threading_extra15
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra14."
    - "threading_extra11 covers: Thread.start/run/join/is_alive __qualname__."
    - "threading_extra4 covers: active_count/__name__; enumerate/__name__; settrace/__name__."
    - "threading_extra3 covers: current_thread/__name__; main_thread/__name__."
    - "threading_extra6 covers: setprofile/__name__."
    - "NOT yet covered in any prior spec: Thread.isDaemon.__qualname__ == 'Thread.isDaemon'."
    - "NOT yet covered: Thread.setDaemon.__qualname__ == 'Thread.setDaemon'."
    - "NOT yet covered: Thread.getName.__qualname__ == 'Thread.getName'."
    - "NOT yet covered: Thread.setName.__qualname__ == 'Thread.setName'."
    - "NOT yet covered: main_thread.__qualname__ == 'main_thread'."
    - "NOT yet covered: current_thread.__qualname__ == 'current_thread'."
    - "NOT yet covered: active_count.__qualname__ == 'active_count'."
    - "NOT yet covered: enumerate.__qualname__ == 'enumerate'."
    - "NOT yet covered: settrace.__qualname__ == 'settrace'."
    - "NOT yet covered: setprofile.__qualname__ == 'setprofile'."
    - "threading.Thread.isDaemon.__qualname__ == 'Thread.isDaemon' — deprecated compatibility shim defined directly on Thread."
    - "threading.Thread.setDaemon.__qualname__ == 'Thread.setDaemon' — deprecated compatibility shim."
    - "threading.Thread.getName.__qualname__ == 'Thread.getName' — deprecated compatibility shim."
    - "threading.Thread.setName.__qualname__ == 'Thread.setName' — deprecated compatibility shim."
    - "threading.main_thread.__qualname__ == 'main_thread' — top-level function, qualname == name."
    - "threading.current_thread.__qualname__ == 'current_thread'."
    - "threading.active_count.__qualname__ == 'active_count'."
    - "threading.enumerate.__qualname__ == 'enumerate'."
    - "threading.settrace.__qualname__ == 'settrace'."
    - "threading.setprofile.__qualname__ == 'setprofile'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread deprecated compatibility method __qualname__ checks
#
# threading_extra11 covers Thread.start/run/join/is_alive __qualname__.
# No prior spec checks __qualname__ for the deprecated-but-still-present
# Thread methods: isDaemon, setDaemon, getName, setName. These are defined
# directly on Thread in Lib/threading.py and their __qualname__ is
# 'Thread.<method>'.
# ---------------------------------------------------------------------------

table threading_extra15.Thread_deprecated_method_qualnames:
  description: "threading.Thread deprecated methods have correct __qualname__ values"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: thddepmqname

  columns: [id, function, args, expected]
  rows:
    - [isDaemon, Thread.isDaemon.__qualname__.__eq__, ["Thread.isDaemon"], true]
    - [setDaemon, Thread.setDaemon.__qualname__.__eq__, ["Thread.setDaemon"], true]
    - [getName,  Thread.getName.__qualname__.__eq__,  ["Thread.getName"],  true]
    - [setName,  Thread.setName.__qualname__.__eq__,  ["Thread.setName"],  true]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ checks
#
# threading_extra3 covers main_thread/__name__ and current_thread/__name__.
# threading_extra4 covers active_count/__name__, enumerate/__name__,
# settrace/__name__. threading_extra6 covers setprofile/__name__.
# No prior spec checks __qualname__ for any of these functions. For top-level
# module functions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table threading_extra15.module_function_qualnames:
  description: "threading module-level functions have __qualname__ == function name"
  kind: python_call_eq
  category: function_names
  id_prefix: mfqname

  columns: [id, function, args, expected]
  rows:
    - [main_thread,    main_thread.__qualname__.__eq__,    ["main_thread"],    true]
    - [current_thread, current_thread.__qualname__.__eq__, ["current_thread"], true]
    - [active_count,   active_count.__qualname__.__eq__,   ["active_count"],   true]
    - [enumerate,      enumerate.__qualname__.__eq__,       ["enumerate"],       true]
    - [settrace,       settrace.__qualname__.__eq__,        ["settrace"],        true]
    - [setprofile,     setprofile.__qualname__.__eq__,      ["setprofile"],      true]
