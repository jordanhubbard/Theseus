spec: zlib_extra2
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
    - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib.zspec.zsdl — covers C library via ctypes"
    - "zlib_extra.zspec.zsdl — covers compress/decompress/__name__, compressobj/decompressobj/__name__, adler32/crc32 __name__, error.__name__ and base class, DEFLATED and Z_DEFAULT_COMPRESSION int type, adler32/crc32 empty bytes, roundtrip"
  notes:
    - "Extends zlib_extra.zspec.zsdl. Does NOT duplicate invariants already present in zlib.zspec.zsdl or zlib_extra.zspec.zsdl."
    - "zlib.Compress and zlib.Decompress are not module-level names; they are the types returned by compressobj() and decompressobj() respectively."
    - "type(zlib.compressobj()).__name__ == 'Compress' — the internal C type name."
    - "type(zlib.decompressobj()).__name__ == 'Decompress' — the internal C type name."
    - "zlib.DEF_MEM_LEVEL is an int constant (value 8 in CPython); its __class__.__name__ is 'int'."
    - "zlib.Z_BEST_COMPRESSION == 9 — maximum compression level."
    - "zlib.Z_NO_COMPRESSION == 0 — no compression (store only)."
    - "zlib.Z_BEST_SPEED == 1 — fastest compression level."
    - "zlib.Z_DEFAULT_STRATEGY == 0, zlib.Z_FILTERED == 1, zlib.Z_HUFFMAN_ONLY == 2 — strategy constants."
    - "zlib.error.__module__ == 'zlib' — the error class lives in the zlib module."
    - "zlib.error.__mro__[1].__name__ == 'Exception' — second MRO entry is Exception."
    - "Compress instance has compress, flush, and copy methods."
    - "Decompress instance has decompress, flush, and copy methods."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zlib.error is raised on invalid compressed data or bad arguments."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Compress type name — via compressobj() result
# ---------------------------------------------------------------------------

invariant zlib_extra2.compress_type.name:
  description: "type(zlib.compressobj()).__name__ == 'Compress'"
  category: type_names
  kind: python_call_eq
  function: compressobj
  args: []
  method: __class__
  method_chain: __name__
  expected: "Compress"

# ---------------------------------------------------------------------------
# Decompress type name — via decompressobj() result
# ---------------------------------------------------------------------------

invariant zlib_extra2.decompress_type.name:
  description: "type(zlib.decompressobj()).__name__ == 'Decompress'"
  category: type_names
  kind: python_call_eq
  function: decompressobj
  args: []
  method: __class__
  method_chain: __name__
  expected: "Decompress"

# ---------------------------------------------------------------------------
# Compress instance method names
# ---------------------------------------------------------------------------

invariant zlib_extra2.compressobj.compress_method_name:
  description: "zlib.compressobj().compress.__name__ == 'compress'"
  category: method_names
  kind: python_call_eq
  function: compressobj
  args: []
  method: compress.__name__.__eq__
  method_args: ["compress"]
  expected: true

invariant zlib_extra2.compressobj.flush_method_name:
  description: "zlib.compressobj().flush.__name__ == 'flush'"
  category: method_names
  kind: python_call_eq
  function: compressobj
  args: []
  method: flush.__name__.__eq__
  method_args: ["flush"]
  expected: true

invariant zlib_extra2.compressobj.copy_method_name:
  description: "zlib.compressobj().copy.__name__ == 'copy'"
  category: method_names
  kind: python_call_eq
  function: compressobj
  args: []
  method: copy.__name__.__eq__
  method_args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# Decompress instance method names
# ---------------------------------------------------------------------------

invariant zlib_extra2.decompressobj.decompress_method_name:
  description: "zlib.decompressobj().decompress.__name__ == 'decompress'"
  category: method_names
  kind: python_call_eq
  function: decompressobj
  args: []
  method: decompress.__name__.__eq__
  method_args: ["decompress"]
  expected: true

invariant zlib_extra2.decompressobj.flush_method_name:
  description: "zlib.decompressobj().flush.__name__ == 'flush'"
  category: method_names
  kind: python_call_eq
  function: decompressobj
  args: []
  method: flush.__name__.__eq__
  method_args: ["flush"]
  expected: true

invariant zlib_extra2.decompressobj.copy_method_name:
  description: "zlib.decompressobj().copy.__name__ == 'copy'"
  category: method_names
  kind: python_call_eq
  function: decompressobj
  args: []
  method: copy.__name__.__eq__
  method_args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# Constants — integer type and value checks
# ---------------------------------------------------------------------------

invariant zlib_extra2.DEF_MEM_LEVEL.class_is_int:
  description: "zlib.DEF_MEM_LEVEL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEF_MEM_LEVEL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zlib_extra2.Z_DEFAULT_COMPRESSION.class_is_int:
  description: "zlib.Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: Z_DEFAULT_COMPRESSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zlib_extra2.Z_BEST_COMPRESSION.value:
  description: "zlib.Z_BEST_COMPRESSION == 9 — maximum compression level"
  category: constants
  kind: python_call_eq
  function: Z_BEST_COMPRESSION.__eq__
  args: [9]
  expected: true

invariant zlib_extra2.Z_NO_COMPRESSION.value:
  description: "zlib.Z_NO_COMPRESSION == 0 — no compression (store only)"
  category: constants
  kind: python_call_eq
  function: Z_NO_COMPRESSION.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Level constants table — Z_BEST_SPEED, Z_BEST_COMPRESSION, Z_NO_COMPRESSION
# ---------------------------------------------------------------------------

table zlib_extra2.constants.levels:
  kind: python_call_eq
  category: constants
  id_prefix: level

  columns: [id, function, args, expected]
  rows:
    - [Z_BEST_SPEED,       Z_BEST_SPEED.__eq__,       [1], true]
    - [Z_BEST_COMPRESSION, Z_BEST_COMPRESSION.__eq__, [9], true]
    - [Z_NO_COMPRESSION,   Z_NO_COMPRESSION.__eq__,   [0], true]

# ---------------------------------------------------------------------------
# Strategy constants table — Z_DEFAULT_STRATEGY, Z_FILTERED, Z_HUFFMAN_ONLY
# ---------------------------------------------------------------------------

table zlib_extra2.constants.strategies:
  kind: python_call_eq
  category: constants
  id_prefix: strategy

  columns: [id, function, args, expected]
  rows:
    - [Z_DEFAULT_STRATEGY, Z_DEFAULT_STRATEGY.__eq__, [0], true]
    - [Z_FILTERED,         Z_FILTERED.__eq__,         [1], true]
    - [Z_HUFFMAN_ONLY,     Z_HUFFMAN_ONLY.__eq__,     [2], true]

# ---------------------------------------------------------------------------
# error class — __module__
# ---------------------------------------------------------------------------

invariant zlib_extra2.error.module:
  description: "zlib.error.__module__ == 'zlib'"
  category: hierarchy
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# error hierarchy — __mro__[1].__name__ == 'Exception'
# ---------------------------------------------------------------------------

invariant zlib_extra2.error.mro_base_is_exception:
  description: "zlib.error.__mro__[1].__name__ == 'Exception' — second MRO entry is Exception"
  category: hierarchy
  kind: python_call_eq
  function: error.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"
