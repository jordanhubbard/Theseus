spec: functools_extra77
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra76.zspec.zsdl."
    - "Wave 238 theme: functools function __annotations__ attributes — first __annotations__ coverage for functools."
    - "lru_cache.__annotations__.__class__.__name__ == 'dict' — lru_cache is a pure-Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "lru_cache.__annotations__.__len__() == 0 — no parameter or return annotations in the CPython lru_cache definition. Verified with Python 3.14.3."
    - "cache.__annotations__.__class__.__name__ == 'dict' — cache is a pure-Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "cache.__annotations__.__len__() == 0 — no parameter or return annotations in the CPython cache definition. Verified with Python 3.14.3."
    - "wraps.__annotations__.__class__.__name__ == 'dict' — wraps is a pure-Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "wraps.__annotations__.__len__() == 0 — no parameter or return annotations in the CPython wraps definition. Verified with Python 3.14.3."
    - "singledispatch.__annotations__.__class__.__name__ == 'dict' — singledispatch is a pure-Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "singledispatch.__annotations__.__len__() == 0 — no parameter or return annotations in the CPython singledispatch definition. Verified with Python 3.14.3."
    - "update_wrapper.__annotations__.__class__.__name__ == 'dict' — update_wrapper is a pure-Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# lru_cache __annotations__ — extra77
#
# Wave 238 theme: lru_cache and cache __annotations__ are empty dicts.
#
# functools.lru_cache is a pure-Python function defined in Lib/functools.py.
# Its __annotations__ attribute is a dict with no entries:
#   lru_cache.__annotations__.__class__.__name__ == 'dict'
#   lru_cache.__annotations__.__len__()          == 0
#
# No prior functools spec checks lru_cache.__annotations__ via functoolsann77. New to extra77.
# ---------------------------------------------------------------------------

table functools_extra77.lru_cache_annotations:
  description: "lru_cache.__annotations__.__class__.__name__=='dict', __len__()==0; wave 238 lru_cache __annotations__; new to extra77"
  kind: python_call_eq
  category: annotations
  id_prefix: functoolsann77

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_ann_class_name_eq_dict,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.lru_cache.__annotations__.__class__.__name__.__eq__('dict') == True — lru_cache is a pure-Python function in Lib/functools.py; Python functions carry an __annotations__ dict that maps parameter names and 'return' to their annotations; the CPython lru_cache implementation has no annotations so this dict is empty; __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior functools spec checks lru_cache.__annotations__.__class__.__name__ via functoolsann77; new to extra77"]
    - [lru_cache_ann_len_eq_0,
       lru_cache.__annotations__.__len__,
       [],
       0,
       "functools.lru_cache.__annotations__.__len__() == 0 — lru_cache is defined as 'def lru_cache(maxsize=128, typed=False):' with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior functools spec checks lru_cache.__annotations__.__len__ via functoolsann77; new to extra77"]

# ---------------------------------------------------------------------------
# cache __annotations__ — extra77
#
# Wave 238 theme: cache __annotations__ is an empty dict.
#
# functools.cache is a pure-Python function defined in Lib/functools.py.
# Its __annotations__ attribute is an empty dict.
#
# No prior functools spec checks cache.__annotations__ via functoolsann77. New to extra77.
# ---------------------------------------------------------------------------

table functools_extra77.cache_annotations:
  description: "cache.__annotations__.__class__.__name__=='dict', __len__()==0; wave 238 cache __annotations__; new to extra77"
  kind: python_call_eq
  category: annotations
  id_prefix: functoolsann77

  columns: [id, function, args, expected, description]
  rows:
    - [cache_ann_class_name_eq_dict,
       cache.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.cache.__annotations__.__class__.__name__.__eq__('dict') == True — cache is a pure-Python function in Lib/functools.py (added in Python 3.9) defined as 'def cache(user_function):' with no type annotations; its __annotations__ dict is empty; __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior functools spec checks cache.__annotations__.__class__.__name__ via functoolsann77; new to extra77"]
    - [cache_ann_len_eq_0,
       cache.__annotations__.__len__,
       [],
       0,
       "functools.cache.__annotations__.__len__() == 0 — cache is defined as 'def cache(user_function):' with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior functools spec checks cache.__annotations__.__len__ via functoolsann77; new to extra77"]

# ---------------------------------------------------------------------------
