#
# functools.wraps is defined in Lib/functools.py. Its __annotations__ is {}.
# functools.singledispatch is defined in Lib/functools.py. Its __annotations__ is {}.
#
# No prior functools spec checks wraps or singledispatch __annotations__ via functoolsann77. New to extra77.
# ---------------------------------------------------------------------------

table functools_extra77.wraps_singledispatch_annotations:
  description: "wraps.__annotations__.__class__.__name__=='dict'; singledispatch.__annotations__.__len__()==0; wave 238 wraps/singledispatch __annotations__; new to extra77"
  kind: python_call_eq
  category: annotations
  id_prefix: functoolsann77

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_ann_class_name_eq_dict,
       wraps.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.wraps.__annotations__.__class__.__name__.__eq__('dict') == True — wraps is a pure-Python function in Lib/functools.py that is a convenience wrapper around update_wrapper; it is defined with no type annotations so its __annotations__ dict is empty; __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior functools spec checks wraps.__annotations__.__class__.__name__ via functoolsann77; new to extra77"]
    - [singledispatch_ann_len_eq_0,
       singledispatch.__annotations__.__len__,
       [],
       0,
       "functools.singledispatch.__annotations__.__len__() == 0 — singledispatch is a pure-Python function in Lib/functools.py defined as 'def singledispatch(func):' with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior functools spec checks singledispatch.__annotations__.__len__ via functoolsann77; new to extra77"]

