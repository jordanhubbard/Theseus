    - ["re3391005", operator.contains, [re.Match.__dict__,     "__float__"], false]
    - ["re3391006", operator.contains, [re.RegexFlag.__dict__, "__float__"], false]

# ---------------------------------------------------------------------------
# __complex__ dict-presence — operator.contains(Cls.__dict__, '__complex__')
#
# No re class defines __complex__ in its own __dict__; all false.
# re.Pattern and re.Match are not numeric types. re.RegexFlag is an IntFlag
# subclass but __complex__ is not stored in re.RegexFlag.__dict__ itself;
# it is not inherited from the IntFlag/int MRO as __complex__ is not defined
# on int.
# ---------------------------------------------------------------------------

table re3391.complex:
