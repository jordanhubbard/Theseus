    - ["re3391008", operator.contains, [re.Match.__dict__,     "__complex__"], false]
    - ["re3391009", operator.contains, [re.RegexFlag.__dict__, "__complex__"], false]

# ---------------------------------------------------------------------------
# combined — __int__, __float__, __complex__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows.
