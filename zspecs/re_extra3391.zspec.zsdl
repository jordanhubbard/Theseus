spec: re3391
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (re3391): __int__, __float__, __complex__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "No re class defines __int__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; int() has no meaning for them. re.RegexFlag is an IntFlag enum but __int__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __float__ in its own __dict__: re types are not numeric operands; float() is not defined on any re type. re.RegexFlag (IntFlag) does not define __float__ in its own __dict__."
    - "No re class defines __complex__ in its own __dict__: re.Pattern and re.Match are not numeric types. re.RegexFlag is an IntFlag subclass but __complex__ is not stored in re.RegexFlag.__dict__ itself."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all numeric conversion operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __int__ dict-presence — operator.contains(Cls.__dict__, '__int__')
#
# No re class defines __int__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but int() support is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3391.int:
  description: "re types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3391

  columns: [id, function, args, expected]
  rows:
    - ["re3391001", operator.contains, [re.Pattern.__dict__,   "__int__"], false]
    - ["re3391002", operator.contains, [re.Match.__dict__,     "__int__"], false]
    - ["re3391003", operator.contains, [re.RegexFlag.__dict__, "__int__"], false]

# ---------------------------------------------------------------------------
# __float__ dict-presence — operator.contains(Cls.__dict__, '__float__')
#
# No re class defines __float__ in its own __dict__; all false.
# re types are not numeric operands; float() is not part of the re type
# protocol. re.RegexFlag (IntFlag) does not define __float__ in its own __dict__.
# ---------------------------------------------------------------------------

table re3391.float:
  description: "re types __float__ dict-presence checks; wave 673"
