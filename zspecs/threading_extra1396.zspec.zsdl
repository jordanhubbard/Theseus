spec: threading_extra1396
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence for threading classes."
    - "threading.Thread, Lock, Event, Semaphore, Barrier, and Condition do NOT define __class_getitem__ in their __dict__."
    - "No threading class has generic alias support; none are designed to be used as parameterized generic types."
    - "No threading class defines __init_subclass__ in its __dict__; all inherit it from object as a builtin_function_or_method."
    - "threading.Thread, Event, Semaphore, Barrier, and Condition are pure Python classes; threading.Lock is _thread.lock, a C extension type."
    - "All class __dict__ attributes are mappingproxy instances regardless of whether the class is defined in C or Python."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1396.class_getitem_not_in_dict_thread_lock_event:
  description: "threading.Thread, Lock, and Event do not define __class_getitem__ in their __dict__; none support generic alias syntax"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: th1396cg
  columns: [id, function, args, expected]
  rows:
    - [th1396cg001, threading.Thread.__dict__.__contains__, ["__class_getitem__"], false]
    - [th1396cg002, threading.Lock.__dict__.__contains__,   ["__class_getitem__"], false]
    - [th1396cg003, threading.Event.__dict__.__contains__,  ["__class_getitem__"], false]
    - [th1396cg004, threading.Thread.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [th1396cg005, threading.Lock.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [th1396cg006, threading.Event.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]

table threading_extra1396.class_getitem_not_in_dict_semaphore_barrier_condition:
  description: "threading.Semaphore, Barrier, and Condition do not define __class_getitem__ in their __dict__; none support generic alias syntax"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: th1396sb
  columns: [id, function, args, expected]
  rows:
    - [th1396sb001, threading.Semaphore.__dict__.__contains__, ["__class_getitem__"], false]
    - [th1396sb002, threading.Barrier.__dict__.__contains__,   ["__class_getitem__"], false]
    - [th1396sb003, threading.Condition.__dict__.__contains__,  ["__class_getitem__"], false]
    - [th1396sb004, threading.Semaphore.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [th1396sb005, threading.Barrier.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [th1396sb006, threading.Condition.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]

table threading_extra1396.init_subclass_not_in_dict:
  description: "No threading class defines __init_subclass__ in its __dict__; all inherit it from object and it resolves to builtin_function_or_method on the class"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: th1396is
  columns: [id, function, args, expected]
  rows:
    - [th1396is001, threading.Thread.__dict__.__contains__,     ["__init_subclass__"], false]
    - [th1396is002, threading.Lock.__dict__.__contains__,        ["__init_subclass__"], false]
    - [th1396is003, threading.Event.__dict__.__contains__,       ["__init_subclass__"], false]
    - [th1396is004, threading.Semaphore.__dict__.__contains__,   ["__init_subclass__"], false]
    - [th1396is005, threading.Barrier.__dict__.__contains__,     ["__init_subclass__"], false]
    - [th1396is006, threading.Condition.__dict__.__contains__,   ["__init_subclass__"], false]
    - [th1396is007, threading.Thread.__init_subclass__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [th1396is008, threading.Semaphore.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
