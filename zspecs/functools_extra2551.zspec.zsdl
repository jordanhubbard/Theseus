spec: functools_extra2551
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks."
    - "functools.partial: C extension type — defines __reduce__ and __setstate__ for pickle support, but NOT __reduce_ex__ or __getnewargs__."
    - "functools._lru_cache_wrapper: C extension type — defines __reduce__ for pickling, but NOT __reduce_ex__ or __getnewargs__."
    - "functools._CacheInfo: namedtuple subclass — defines __getnewargs__ (namedtuple protocol) but NOT __reduce__ or __reduce_ex__."
    - "functools.partialmethod: pure-Python class — defines none of __reduce__, __reduce_ex__, __getnewargs__."
    - "functools.cached_property: pure-Python descriptor — defines none of __reduce__, __reduce_ex__, __getnewargs__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __reduce__ dict-presence for functools types
#
# functools.partial and functools._lru_cache_wrapper are C extension types
# that implement __reduce__ to support pickling.
# functools.partialmethod, functools.cached_property define no __reduce__.
# functools._CacheInfo is a namedtuple — no explicit __reduce__ in its dict.
# ---------------------------------------------------------------------------

table functools_extra2551.reduce_protocol:
  description: "functools types __reduce__ dict-presence checks — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2551

  columns: [id, function, args, expected]
  rows:
    - ["ft2551001", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["ft2551002", "functools._lru_cache_wrapper.__dict__.__contains__", ["__reduce__"], true]
    - ["ft2551003", "functools.partialmethod.__dict__.__contains__", ["__reduce__"], false]
    - ["ft2551004", "functools.cached_property.__dict__.__contains__", ["__reduce__"], false]
    - ["ft2551005", "functools._CacheInfo.__dict__.__contains__", ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 2: __reduce_ex__ dict-presence for functools types
#
# No functools class defines __reduce_ex__ in its own __dict__.
# __reduce_ex__ is inherited from object, not overridden.
# ---------------------------------------------------------------------------

table functools_extra2551.reduce_ex_protocol:
  description: "functools types __reduce_ex__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2551

  columns: [id, function, args, expected]
  rows:
    - ["ft2551006", "functools.partial.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2551007", "functools._lru_cache_wrapper.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2551008", "functools.partialmethod.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2551009", "functools.cached_property.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2551010", "functools._CacheInfo.__dict__.__contains__", ["__reduce_ex__"], false]

# ---------------------------------------------------------------------------
# Table 3: __getnewargs__ dict-presence for functools types
#
# functools._CacheInfo is a namedtuple and gains __getnewargs__ from the
# namedtuple machinery (used for copy/pickle reconstruction).
# functools.partial, functools._lru_cache_wrapper, functools.partialmethod,
# and functools.cached_property do NOT define __getnewargs__.
# ---------------------------------------------------------------------------

table functools_extra2551.getnewargs_protocol:
  description: "functools types __getnewargs__ dict-presence checks — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2551

  columns: [id, function, args, expected]
  rows:
    - ["ft2551011", "functools.partial.__dict__.__contains__", ["__getnewargs__"], false]
    - ["ft2551012", "functools._lru_cache_wrapper.__dict__.__contains__", ["__getnewargs__"], false]
    - ["ft2551013", "functools.partialmethod.__dict__.__contains__", ["__getnewargs__"], false]
    - ["ft2551014", "functools.cached_property.__dict__.__contains__", ["__getnewargs__"], false]
    - ["ft2551015", "functools._CacheInfo.__dict__.__contains__", ["__getnewargs__"], true]

# ---------------------------------------------------------------------------
# Table 4: __setstate__ and cross-checks for functools.partial pickling protocol
#
# functools.partial defines both __reduce__ and __setstate__ (the setter
# complement for pickling), but none of __reduce_ex__, __getnewargs__,
# __copy__, or __deepcopy__.
# ---------------------------------------------------------------------------

table functools_extra2551.partial_pickle_protocol:
  description: "functools.partial full pickling-protocol dict-presence summary — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2551

  columns: [id, function, args, expected]
  rows:
    - ["ft2551016", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["ft2551017", "functools.partial.__dict__.__contains__", ["__setstate__"], true]
    - ["ft2551018", "functools.partial.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2551019", "functools.partial.__dict__.__contains__", ["__getnewargs__"], false]
