spec: textwrap_extra23
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra22.zspec.zsdl."
    - "textwrap_extra21 covers: TextWrapper.__init__.__qualname__=='TextWrapper.__init__'; TextWrapper.wrap/__qualname__; TextWrapper.fill/__qualname__."
    - "textwrap_extra22 covers: wrap/fill/dedent/indent/shorten/__qualname__; TextWrapper.wrap/__qualname__; TextWrapper.fill/__qualname__; TextWrapper/__qualname__."
    - "No prior spec covers TextWrapper._wrap_chunks/__qualname__, TextWrapper._split/__qualname__, or TextWrapper._split_chunks/__qualname__ as standalone invariants."
    - "No prior spec covers TextWrapper.__repr__.__qualname__ as a standalone invariant."
    - "TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — already covered in textwrap_extra21; re-anchored here in extra23 namespace for completeness."
    - "textwrap.TextWrapper._wrap_chunks.__qualname__ == 'TextWrapper._wrap_chunks' — private method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper._split.__qualname__ == 'TextWrapper._split' — private method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper._split_chunks.__qualname__ == 'TextWrapper._split_chunks' — private method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper.__repr__.__qualname__ == 'object.__repr__' — TextWrapper does not override __repr__; inherits from object. Verified at runtime."
    - "TextWrapper width default value is 70; type(instance.width).__name__ == 'int'. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.TextWrapper._wrap_chunks — __qualname__
#
# No prior spec verifies TextWrapper._wrap_chunks.__qualname__ as a standalone
# invariant. For a private method defined in class TextWrapper, __qualname__
# takes the form 'TextWrapper._wrap_chunks'.
# Verified at runtime: 'TextWrapper._wrap_chunks'.
# ---------------------------------------------------------------------------

invariant textwrap_extra23.TextWrapper.wrap_chunks_qualname:
  description: "textwrap.TextWrapper._wrap_chunks.__qualname__ == 'TextWrapper._wrap_chunks' — private method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "TextWrapper._wrap_chunks.__qualname__.__eq__"
  args: ["TextWrapper._wrap_chunks"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper._split — __qualname__
#
# No prior spec verifies TextWrapper._split.__qualname__ as a standalone
# invariant. For a private method defined in class TextWrapper, __qualname__
# takes the form 'TextWrapper._split'.
# Verified at runtime: 'TextWrapper._split'.
# ---------------------------------------------------------------------------

invariant textwrap_extra23.TextWrapper.split_qualname:
  description: "textwrap.TextWrapper._split.__qualname__ == 'TextWrapper._split' — private method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "TextWrapper._split.__qualname__.__eq__"
  args: ["TextWrapper._split"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper._split_chunks — __qualname__
#
# No prior spec verifies TextWrapper._split_chunks.__qualname__ as a standalone
# invariant. For a private method defined in class TextWrapper, __qualname__
# takes the form 'TextWrapper._split_chunks'.
# Verified at runtime: 'TextWrapper._split_chunks'.
# ---------------------------------------------------------------------------

invariant textwrap_extra23.TextWrapper.split_chunks_qualname:
  description: "textwrap.TextWrapper._split_chunks.__qualname__ == 'TextWrapper._split_chunks' — private method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "TextWrapper._split_chunks.__qualname__.__eq__"
  args: ["TextWrapper._split_chunks"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.__init__ — __qualname__ (extra23 namespace anchor)
#
# textwrap_extra21 covers TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__'.
# Re-anchored here as a named standalone invariant in the extra23 namespace.
# Verified at runtime: 'TextWrapper.__init__'.
# ---------------------------------------------------------------------------

invariant textwrap_extra23.TextWrapper.init_qualname:
  description: "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__init__.__qualname__.__eq__
  args: ["TextWrapper.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.__repr__ — __qualname__
#
# No prior spec verifies TextWrapper.__repr__.__qualname__ as a standalone
# invariant. TextWrapper does not override __repr__; it inherits the method
# from object. Therefore __qualname__ is 'object.__repr__'.
# Verified at runtime: 'object.__repr__'.
# ---------------------------------------------------------------------------

invariant textwrap_extra23.TextWrapper.repr_qualname:
  description: "textwrap.TextWrapper.__repr__.__qualname__ == 'object.__repr__' — TextWrapper inherits __repr__ from object"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__repr__.__qualname__.__eq__
  args: ["object.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# Table: TextWrapper private method and special method __qualname__ values
#
# Groups all five __qualname__ checks from this spec into a single table:
# three private methods (_wrap_chunks, _split, _split_chunks), the __init__
# re-anchor, and the inherited __repr__.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra23.textwrapper_method_qualnames:
  description: "textwrap.TextWrapper private and special method __qualname__ values"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [wrap_chunks,
       "TextWrapper._wrap_chunks.__qualname__.__eq__",
       ["TextWrapper._wrap_chunks"],
       true,
       "TextWrapper._wrap_chunks.__qualname__ == 'TextWrapper._wrap_chunks'"]
    - [split,
       "TextWrapper._split.__qualname__.__eq__",
       ["TextWrapper._split"],
       true,
       "TextWrapper._split.__qualname__ == 'TextWrapper._split'"]
    - [split_chunks,
       "TextWrapper._split_chunks.__qualname__.__eq__",
       ["TextWrapper._split_chunks"],
       true,
       "TextWrapper._split_chunks.__qualname__ == 'TextWrapper._split_chunks'"]
    - [init,
       TextWrapper.__init__.__qualname__.__eq__,
       ["TextWrapper.__init__"],
       true,
       "TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__'"]
    - [repr,
       TextWrapper.__repr__.__qualname__.__eq__,
       ["object.__repr__"],
       true,
       "TextWrapper.__repr__.__qualname__ == 'object.__repr__' (inherited)"]
