spec: deep_diff
version: ">=1.0.2"
backend: node(deep-diff)

docs: https://www.npmjs.com/package/deep-diff

provenance:
  derived_from:
    - "deep-diff README — https://www.npmjs.com/package/deep-diff"
    - "Test vectors verified with deep-diff via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "deep-diff source"
  notes:
    - "deep-diff is an npm package. Install: npm install deep-diff"
    - "Returns an array of difference records between two objects. Each record has kind (E=edited, N=new, D=deleted, A=array), path, lhs, rhs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of diff records, or undefined if objects are equal."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table deep_diff.diff:
  kind: node_module_call_eq
  function: diff
  category: object
  id_prefix: ddiff

  columns: [id, args, expected]
  rows:
    - [edited,   [{"a": 1, "b": 2}, {"a": 1, "b": 3}],  [{"kind": "E", "path": ["b"], "lhs": 2, "rhs": 3}]]
    - [new_key,  [{"a": 1}, {"a": 1, "b": 2}],           [{"kind": "N", "path": ["b"], "rhs": 2}]]
    - [deleted,  [{"a": 1, "b": 2}, {"a": 1}],           [{"kind": "D", "path": ["b"], "lhs": 2}]]
