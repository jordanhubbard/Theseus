spec: glob_extra12
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra11.zspec.zsdl — covers __module__ table for glob/iglob/escape; __qualname__ and __name__ standalone invariants for all three functions."
    - "glob_extra8.zspec.zsdl — covers glob.__package__ == ''."
    - "glob_extra7.zspec.zsdl — covers glob.__name__ (module-level) == 'glob'."
  notes:
    - "This spec extends glob_extra11.zspec.zsdl."
    - "Focus: glob module __spec__ attributes and __loader__ class name."
    - "No prior glob spec covers glob.__spec__.name, glob.__spec__.submodule_search_locations, or glob.__loader__.__class__.__name__."
    - "glob.__spec__.name == 'glob' — the ModuleSpec name matches the module name."
    - "glob.__spec__.submodule_search_locations is None — glob is a simple module, not a package."
    - "glob.__loader__.__class__.__name__ == 'SourceFileLoader' — glob is loaded from source (.py)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# glob.__spec__.name — ModuleSpec identity
#
# The ModuleSpec for glob records the fully qualified module name.
# For a top-level module like glob, __spec__.name == 'glob'.
# No prior glob spec covers __spec__.name.
# Verified: glob.__spec__.name == 'glob'
# ---------------------------------------------------------------------------

invariant glob_extra12.spec.name:
  description: "glob.__spec__.name == 'glob' — ModuleSpec name equals the module name"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.name.__eq__"
  args: ["glob"]
  expected: true

# ---------------------------------------------------------------------------
# glob.__spec__.submodule_search_locations — not a package
#
# For simple modules (not packages), __spec__.submodule_search_locations is
# None. glob has no sub-modules so this attribute is None.
# No prior glob spec covers this attribute.
# Verified: glob.__spec__.submodule_search_locations is None
# ---------------------------------------------------------------------------

invariant glob_extra12.spec.submodule_search_locations_is_none:
  description: "glob.__spec__.submodule_search_locations is None — glob is a simple module, not a package"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.submodule_search_locations.__eq__"
  args: [~]
  expected: true

# ---------------------------------------------------------------------------
# glob.__loader__.__class__.__name__ — SourceFileLoader
#
# On CPython, pure-Python modules are loaded by importlib's SourceFileLoader.
# The loader class name identifies how the module was loaded.
# No prior glob spec covers __loader__.__class__.__name__.
# Verified: glob.__loader__.__class__.__name__ == 'SourceFileLoader'
# ---------------------------------------------------------------------------

invariant glob_extra12.loader.class_name:
  description: "glob.__loader__.__class__.__name__ == 'SourceFileLoader' — glob is loaded from source by SourceFileLoader"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true
