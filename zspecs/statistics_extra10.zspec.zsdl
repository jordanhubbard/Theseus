spec: statistics_extra10
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra9.zspec.zsdl."
    - "statistics.zspec.zsdl covers mean([1,2,3,4,5])==3, mean([1.0,2.0,3.0])==2.0, mean([0,0,0])==0, mean([10])==10."
    - "statistics.zspec.zsdl covers median([1,2,3,4,5])==3, median([1,2,3,4])==2.5, median([7])==7."
    - "statistics.zspec.zsdl covers variance([2,4,4,4,5,5,7,9])==4.571..., stdev([2,4,4,4,5,5,7,9])==2.138..."
    - "statistics_extra covers stdev([2,4])==sqrt(2)."
    - "No prior spec covers mean([10, 20, 30]) == 20 — three-element arithmetic mean."
    - "No prior spec covers mean([-1, -2, -3]) == -2 — mean of all-negative integers."
    - "No prior spec covers median([2, 4, 6, 8]) == 5.0 — even-length list, result is float midpoint."
    - "No prior spec covers variance([1, 2, 3, 4]) — four-element sample variance."
    - "No prior spec covers stdev([1, 2, 3, 4]) — four-element sample standard deviation."
    - "No prior spec covers variance([0, 0]) == 0 — variance of two equal values is zero."
    - "statistics.mean([10, 20, 30]) == 20 — mean of 3 integers; returns int on Python 3.11+."
    - "statistics.mean([-1, -2, -3]) == -2 — mean of negative integers."
    - "statistics.median([2, 4, 6, 8]) == 5.0 — (4+6)/2 == 5.0 for even-length list."
    - "statistics.variance([1, 2, 3, 4]) == 5/3 ≈ 1.6666... — sample variance with ddof=1."
    - "statistics.stdev([1, 2, 3, 4]) == sqrt(5/3) ≈ 1.2909... — sample stdev with ddof=1."
    - "statistics.variance([0, 0]) == 0 — all values identical means zero variance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mean — additional value vectors
#
# statistics.zspec.zsdl covers mean([1,2,3,4,5])==3, mean([1.0,2.0,3.0])==2.0,
# mean([0,0,0])==0, mean([10])==10.
# No prior spec covers mean([10,20,30])==20 (different integer triple) or
# mean([-1,-2,-3])==-2 (all-negative dataset).
# ---------------------------------------------------------------------------

invariant statistics_extra10.mean.three_tens:
  description: "statistics.mean([10, 20, 30]) == 20 — arithmetic mean of an integer triple"
  category: mean
  kind: python_call_eq
  function: mean
  args: [[10, 20, 30]]
  expected: 20

invariant statistics_extra10.mean.all_negative:
  description: "statistics.mean([-1, -2, -3]) == -2 — mean of all-negative integers"
  category: mean
  kind: python_call_eq
  function: mean
  args: [[-1, -2, -3]]
  expected: -2

# ---------------------------------------------------------------------------
# median — additional value vectors
#
# statistics.zspec.zsdl covers median([1,2,3,4,5])==3, median([1,2,3,4])==2.5,
# median([7])==7.
# No prior spec covers median([2,4,6,8])==5.0 — an even-length list whose
# midpoint is a non-trivial float (the average of the two middle values 4 and 6).
# ---------------------------------------------------------------------------

invariant statistics_extra10.median.even_length_midpoint:
  description: "statistics.median([2, 4, 6, 8]) == 5.0 — midpoint of (4+6)/2 for even-length list"
  category: median
  kind: python_call_eq
  function: median
  args: [[2, 4, 6, 8]]
  expected: 5.0

invariant statistics_extra10.median.two_elements:
  description: "statistics.median([3, 7]) == 5.0 — two-element list: (3+7)/2 == 5.0"
  category: median
  kind: python_call_eq
  function: median
  args: [[3, 7]]
  expected: 5.0

# ---------------------------------------------------------------------------
# variance — additional value vectors
#
# statistics.zspec.zsdl covers variance([2,4,4,4,5,5,7,9])==4.571...
# statistics.zspec.zsdl covers variance([5]) raises StatisticsError.
# No prior spec covers variance([1,2,3,4]) or variance([0,0]).
# variance([1,2,3,4]): mean=2.5, deviations=[-1.5,-0.5,0.5,1.5],
# sum-of-sq=5.0, ddof=1 so result=5.0/3 ≈ 1.6666666666666667.
# variance([0,0]) == 0 — all equal values, zero spread.
# ---------------------------------------------------------------------------

invariant statistics_extra10.variance.four_elements:
  description: "statistics.variance([1, 2, 3, 4]) == 5/3 ≈ 1.6666... — sample variance with ddof=1"
  category: variance
  kind: python_call_eq
  function: variance
  args: [[1, 2, 3, 4]]
  expected: 1.6666666666666667

invariant statistics_extra10.variance.all_equal:
  description: "statistics.variance([0, 0]) == 0 — two equal values have zero variance"
  category: variance
  kind: python_call_eq
  function: variance
  args: [[0, 0]]
  expected: 0

# ---------------------------------------------------------------------------
# stdev — additional value vectors
#
# statistics.zspec.zsdl covers stdev([2,4,4,4,5,5,7,9])==2.138...
# statistics_extra covers stdev([2,4])==sqrt(2)≈1.4142...
# No prior spec covers stdev([1,2,3,4]).
# stdev([1,2,3,4]) == sqrt(variance([1,2,3,4])) == sqrt(5/3) ≈ 1.2909944487358056.
# ---------------------------------------------------------------------------

invariant statistics_extra10.stdev.four_elements:
  description: "statistics.stdev([1, 2, 3, 4]) == sqrt(5/3) ≈ 1.2909... — sample stdev with ddof=1"
  category: stdev
  kind: python_call_eq
  function: stdev
  args: [[1, 2, 3, 4]]
  expected: 1.2909944487358056
