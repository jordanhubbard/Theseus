spec: io_extra107
version: ">=3.9"
backend: python_module(io)
extends: io_extra106

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec extends io_extra106.zspec.zsdl."
    - "This spec covers: io.BufferedReader and io.BufferedWriter method __qualname__ lengths for tell, readinto; io.BytesIO and io.StringIO method __qualname__ values and lengths."
    - "io.BufferedReader.tell.__qualname__ = 'BufferedReader.tell' (length 19)."
    - "io.BufferedReader.readinto.__qualname__ = 'BufferedReader.readinto' (length 23; same length as readline)."
    - "io.BufferedWriter.seek.__qualname__ = 'BufferedWriter.seek' (length 19)."
    - "io.BufferedWriter.tell.__qualname__ = 'BufferedWriter.tell' (length 19)."
    - "io.BytesIO.read.__qualname__ = 'BytesIO.read' (length 12)."
    - "io.BytesIO.write.__qualname__ = 'BytesIO.write' (length 13)."
    - "io.BytesIO.seek.__qualname__ = 'BytesIO.seek' (length 12; same length as BytesIO.read)."
    - "io.StringIO.read.__qualname__ = 'StringIO.read' (length 13)."
    - "io.StringIO.write.__qualname__ = 'StringIO.write' (length 14)."
    - "io.StringIO.getvalue.__qualname__ = 'StringIO.getvalue' (length 17)."
    - "All BytesIO and StringIO methods are C method_descriptors because these classes are C extension types from _io."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader and io.BufferedWriter additional method __qualname__ lengths
# tell and readinto for BufferedReader; seek and tell for BufferedWriter.
# All are C method_descriptors with qualname 'ClassName.method_name'.
# ---------------------------------------------------------------------------

table io_extra107.BufferedReader_BufferedWriter_extra_qualnames:
  description: "io.BufferedReader tell (19) and readinto (23) __qualname__ lengths; io.BufferedWriter seek (19) and tell (19) __qualname__ lengths"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iobytesstr107

  columns: [id, function, args, expected, description]
  rows:
    - [br_tell_qn,      BufferedReader.tell.__qualname__.__eq__,      ["BufferedReader.tell"],    true, "BufferedReader.tell.__qualname__ == 'BufferedReader.tell'"]
    - [br_tell_qn_len,  BufferedReader.tell.__qualname__.__len__,     [],                         19,   "BufferedReader.tell.__qualname__.__len__() == 19 ('BufferedReader.tell' has 19 characters)"]
    - [br_rdinto_qn,    BufferedReader.readinto.__qualname__.__eq__,  ["BufferedReader.readinto"], true, "BufferedReader.readinto.__qualname__ == 'BufferedReader.readinto'"]
    - [br_rdinto_len,   BufferedReader.readinto.__qualname__.__len__, [],                         23,   "BufferedReader.readinto.__qualname__.__len__() == 23 ('BufferedReader.readinto' has 23 characters; same length as readline)"]
    - [bw_seek_qn,      BufferedWriter.seek.__qualname__.__eq__,      ["BufferedWriter.seek"],    true, "BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek'"]
    - [bw_seek_qn_len,  BufferedWriter.seek.__qualname__.__len__,     [],                         19,   "BufferedWriter.seek.__qualname__.__len__() == 19 ('BufferedWriter.seek' has 19 characters)"]
    - [bw_tell_qn,      BufferedWriter.tell.__qualname__.__eq__,      ["BufferedWriter.tell"],    true, "BufferedWriter.tell.__qualname__ == 'BufferedWriter.tell'"]
    - [bw_tell_qn_len,  BufferedWriter.tell.__qualname__.__len__,     [],                         19,   "BufferedWriter.tell.__qualname__.__len__() == 19 ('BufferedWriter.tell' has 19 characters; same as seek and read)"]

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ values and lengths
# BytesIO is a C extension type from _io. Its methods are method_descriptors.
# __qualname__ uses the 'BytesIO.method_name' pattern.
# ---------------------------------------------------------------------------

table io_extra107.BytesIO_method_qualnames:
  description: "io.BytesIO method __qualname__ values and lengths: read (12), write (13), seek (12)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iobytesstr107

  columns: [id, function, args, expected, description]
  rows:
    - [bio_read_qn,      BytesIO.read.__qualname__.__eq__,   ["BytesIO.read"],  true, "BytesIO.read.__qualname__ == 'BytesIO.read'"]
    - [bio_read_qn_len,  BytesIO.read.__qualname__.__len__,  [],                12,   "BytesIO.read.__qualname__.__len__() == 12 ('BytesIO.read' has 12 characters)"]
    - [bio_write_qn,     BytesIO.write.__qualname__.__eq__,  ["BytesIO.write"], true, "BytesIO.write.__qualname__ == 'BytesIO.write'"]
    - [bio_write_qn_len, BytesIO.write.__qualname__.__len__, [],                13,   "BytesIO.write.__qualname__.__len__() == 13 ('BytesIO.write' has 13 characters)"]
    - [bio_seek_qn,      BytesIO.seek.__qualname__.__eq__,   ["BytesIO.seek"],  true, "BytesIO.seek.__qualname__ == 'BytesIO.seek'"]
    - [bio_seek_qn_len,  BytesIO.seek.__qualname__.__len__,  [],                12,   "BytesIO.seek.__qualname__.__len__() == 12 ('BytesIO.seek' has 12 characters; same length as BytesIO.read)"]

# ---------------------------------------------------------------------------
# io.StringIO method __qualname__ values and lengths
# StringIO is a C extension type from _io. Its methods are method_descriptors.
# __qualname__ uses the 'StringIO.method_name' pattern.
# ---------------------------------------------------------------------------

table io_extra107.StringIO_method_qualnames:
  description: "io.StringIO method __qualname__ values and lengths: read (13), write (14), getvalue (17)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iobytesstr107

  columns: [id, function, args, expected, description]
  rows:
    - [sio_read_qn,      StringIO.read.__qualname__.__eq__,      ["StringIO.read"],     true, "StringIO.read.__qualname__ == 'StringIO.read'"]
    - [sio_read_qn_len,  StringIO.read.__qualname__.__len__,     [],                    13,   "StringIO.read.__qualname__.__len__() == 13 ('StringIO.read' has 13 characters)"]
    - [sio_write_qn,     StringIO.write.__qualname__.__eq__,     ["StringIO.write"],    true, "StringIO.write.__qualname__ == 'StringIO.write'"]
    - [sio_write_qn_len, StringIO.write.__qualname__.__len__,    [],                    14,   "StringIO.write.__qualname__.__len__() == 14 ('StringIO.write' has 14 characters)"]
    - [sio_gv_qn,        StringIO.getvalue.__qualname__.__eq__,  ["StringIO.getvalue"], true, "StringIO.getvalue.__qualname__ == 'StringIO.getvalue'"]
    - [sio_gv_qn_len,    StringIO.getvalue.__qualname__.__len__, [],                    17,   "StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.getvalue' has 17 characters; longest StringIO method qualname in this spec)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra107.BufferedReader.tell_qualname_len:
  description: "io.BufferedReader.tell.__qualname__.__len__() == 19 ('BufferedReader.tell' has 19 characters; same length as BufferedReader.read and BufferedReader.seek)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedReader.tell.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra107.BufferedReader.readinto_qualname_len:
  description: "io.BufferedReader.readinto.__qualname__.__len__() == 23 ('BufferedReader.readinto' has 23 characters; same length as BufferedReader.readline)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedReader.readinto.__qualname__.__len__
  args: []
  expected: 23

invariant io_extra107.BytesIO.read_qualname:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read' (BytesIO is a C extension type from _io; its method qualnames use the 'BytesIO.method_name' pattern)"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__eq__
  args: ["BytesIO.read"]
  expected: true

invariant io_extra107.StringIO.getvalue_qualname_len:
  description: "io.StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.getvalue' is the longest StringIO method qualname in this spec at 17 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__len__
  args: []
  expected: 17

invariant io_extra107.BytesIO.seek_qualname_len:
  description: "io.BytesIO.seek.__qualname__.__len__() == 12 ('BytesIO.seek' and 'BytesIO.read' both have 12 characters, the same length)"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.seek.__qualname__.__len__
  args: []
  expected: 12
