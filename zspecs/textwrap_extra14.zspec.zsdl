spec: textwrap_extra14
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra13.zspec.zsdl."
    - "textwrap_extra13 covers: TextWrapper().expand_tabs==True; TextWrapper().max_lines==None; TextWrapper(width=20).width==20; wrap/fill two-words at width=5; dedent three-line two-space; indent double-angle prefix; shorten default placeholder width=8."
    - "textwrap_extra12 covers: TextWrapper().replace_whitespace==True; TextWrapper(width=30).width==30; dedent single-line four-space; indent exclamation and plus-prefix; shorten lowercase/space-dot; wrap/fill five-words at width=10."
    - "textwrap_extra8 covers: TextWrapper.__module__/__name__; width=40/80; initial_indent/subsequent_indent/break_long_words/break_on_hyphens defaults."
    - "textwrap_extra5 covers: TextWrapper drop_whitespace/fix_sentence_endings/placeholder defaults."
    - "NOT yet covered: textwrap.TextWrapper().tabsize == 8 — tabsize default attribute."
    - "NOT yet covered: textwrap.wrap('hello world', 100) == ['hello world'] — wide width, single line."
    - "NOT yet covered: textwrap.wrap('a b', 1) == ['a', 'b'] — width=1 splits on single chars."
    - "NOT yet covered: textwrap.fill('a b c', 3) == 'a\\nb\\nc' — width=3 one word per line."
    - "NOT yet covered: textwrap.dedent('\\thello\\n\\tworld') == 'hello\\nworld' — tab-indented common prefix stripped."
    - "NOT yet covered: textwrap.indent('foo\\nbar', '-- ') == '-- foo\\n-- bar' — dash-space prefix."
    - "NOT yet covered: textwrap.shorten('the quick brown fox', 10) == 'the quick [...]' — mid-sentence truncation."
    - "NOT yet covered: textwrap.TextWrapper.__qualname__ == 'TextWrapper' — TextWrapper is a module-scope class."
    - "textwrap.TextWrapper().tabsize == 8 — default tab expansion width is 8 spaces."
    - "textwrap.wrap('hello world', 100) == ['hello world'] — all text fits on one line at width=100."
    - "textwrap.wrap('a b', 1) == ['a', 'b'] — width=1 forces each word to its own line."
    - "textwrap.fill('a b c', 3) == 'a\\nb\\nc' — width=3, one word per line, joined with newlines."
    - "textwrap.dedent('\\thello\\n\\tworld') == 'hello\\nworld' — common tab prefix stripped."
    - "textwrap.indent('foo\\nbar', '-- ') == '-- foo\\n-- bar' — dash-space prefix on each line."
    - "textwrap.shorten('the quick brown fox', 10) == 'the quick [...]' — truncated with default placeholder."
    - "textwrap.TextWrapper.__qualname__ == 'TextWrapper' — module-scope class qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper().tabsize — default attribute
#
# textwrap_extra8 covers initial_indent, subsequent_indent, break_long_words,
# break_on_hyphens. textwrap_extra5 covers drop_whitespace, fix_sentence_endings,
# placeholder. textwrap_extra13 covers expand_tabs and max_lines.
# No prior spec records the tabsize attribute. It defaults to 8: tabs are
# expanded to the next multiple of 8 spaces before wrapping.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.TextWrapper.tabsize_default:
  description: "textwrap.TextWrapper().tabsize == 8 — tab expansion width defaults to 8"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: tabsize.__eq__
  method_args: [8]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper.__qualname__ — class qualname
#
# textwrap_extra2 covers wrap/__qualname__, fill/__qualname__, indent/__qualname__,
# dedent/__qualname__, shorten/__qualname__. textwrap_extra8 covers
# TextWrapper.__name__. No prior spec checks TextWrapper.__qualname__.
# TextWrapper is defined at module scope so __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.TextWrapper.qualname:
  description: "textwrap.TextWrapper.__qualname__ == 'TextWrapper' — module-scope class qualname"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__qualname__.__eq__
  args: ["TextWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.wrap — wide width (all on one line) and width=1 (one word per line)
#
# textwrap_extra13 covers wrap at width=5 (two words). textwrap_extra12 covers
# wrap at width=10 (five words). No prior spec tests wrap with a very wide
# width (100) or a very narrow width (1).
# wrap('hello world', 100) == ['hello world'] — both words fit on one line.
# wrap('a b', 1) == ['a', 'b'] — each single-char word gets its own line.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.wrap.wide_width_single_line:
  description: "textwrap.wrap('hello world', 100) == ['hello world'] — wide width, all text on one line"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world", 100]
  expected: ["hello world"]

invariant textwrap_extra14.wrap.width_one_one_word_per_line:
  description: "textwrap.wrap('a b', 1) == ['a', 'b'] — width=1 forces each word onto its own line"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["a b", 1]
  expected: ["a", "b"]

# ---------------------------------------------------------------------------
# textwrap.fill — width=3, three words on separate lines
#
# textwrap_extra13 covers fill at width=5 (two words). textwrap_extra12 covers
# fill at width=10 (five words). No prior spec uses width=3 with three
# single-char words. fill('a b c', 3) == 'a\nb\nc'.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.fill.three_words_width3:
  description: "textwrap.fill('a b c', 3) == 'a\\nb\\nc' — width=3, one word per line"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["a b c", 3]
  expected: "a\nb\nc"

# ---------------------------------------------------------------------------
# textwrap.dedent — tab-indented common prefix
#
# textwrap_extra13 covers dedent with two-space common indent.
# textwrap_extra12 covers dedent with four-space single line.
# No prior spec tests dedent with a TAB character as the common indent prefix.
# dedent('\thello\n\tworld') == 'hello\nworld' — leading tab stripped from both lines.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.dedent.tab_prefix:
  description: "textwrap.dedent('\\thello\\n\\tworld') == 'hello\\nworld' — common tab prefix stripped"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["\thello\n\tworld"]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# textwrap.indent — dash-space prefix
#
# Prior specs cover: '  ', '# ', '* ', '> ', '! ', '+ ', '>> ' prefixes.
# No prior spec uses '-- ' (dash-space) as the prefix.
# indent('foo\nbar', '-- ') == '-- foo\n-- bar'.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.indent.dash_space_prefix:
  description: "textwrap.indent('foo\\nbar', '-- ') == '-- foo\\n-- bar' — dash-space prefix"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["foo\nbar", "-- "]
  expected: "-- foo\n-- bar"

# ---------------------------------------------------------------------------
# textwrap.shorten — mid-sentence truncation with default placeholder
#
# textwrap_extra13 covers shorten('hello world', width=8) == 'hello [...]'.
# No prior spec uses 'the quick brown fox' (19 chars) shortened to width=10.
# shorten('the quick brown fox', 10) == 'the quick [...]'.
# ---------------------------------------------------------------------------

invariant textwrap_extra14.shorten.mid_sentence_width10:
  description: "textwrap.shorten('the quick brown fox', 10) == 'the quick [...]' — mid-sentence truncation"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["the quick brown fox", 10]
  expected: "the quick [...]"

# ---------------------------------------------------------------------------
# Table: TextWrapper default attribute checks — extra14 anchors
#
# Groups tabsize default in a table alongside previously established defaults.
# ---------------------------------------------------------------------------

table textwrap_extra14.TextWrapper_extra14_defaults:
  description: "TextWrapper default attribute checks — extra14 namespace"
  kind: python_call_eq
  category: TextWrapper_defaults
  id_prefix: te14

  columns: [id, function, method, method_args, expected]
  rows:
    - [tabsize, TextWrapper, tabsize.__eq__, [8], true]

# ---------------------------------------------------------------------------
# Table: wrap edge cases — wide and narrow width
#
# Groups the wide-width and narrow-width wrap vectors in one table.
# ---------------------------------------------------------------------------

table textwrap_extra14.wrap_edge_cases:
  description: "textwrap.wrap edge cases — wide width single line and width=1 per-word"
  kind: python_call_eq
  category: wrap
  id_prefix: wec

  columns: [id, function, args, expected]
  rows:
    - [wide_width, wrap, ["hello world", 100], ["hello world"]]
    - [width_one,  wrap, ["a b",           1], ["a", "b"]]
