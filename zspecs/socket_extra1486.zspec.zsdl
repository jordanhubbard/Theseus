spec: socket_extra1486
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "POSIX socket specification"
  notes:
    - "Wave 546 extra1486: context manager protocol checks for socket classes."
    - "socket.socket IS a context manager: both __enter__ and __exit__ are present in socket.socket.__dict__ as plain functions."
    - "socket.socket.__enter__.__class__.__name__ == 'function' (Python-level function, not wrapper_descriptor or method_descriptor)."
    - "socket.socket.__exit__.__class__.__name__ == 'function' (Python-level function)."
    - "socket.error is an alias for OSError (builtins); it has no __enter__ or __exit__ in its __dict__."
    - "socket.timeout is an alias for TimeoutError (builtins); it also lacks __enter__ and __exit__."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1486.socket_class_context_manager:
  description: "socket.socket IS a context manager: __enter__ and __exit__ present in __dict__ as 'function'"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: sk1486sx
  columns: [id, function, args, expected]
  rows:
    - [sk1486sx001, socket.socket.__dict__.__contains__,              ["__enter__"],  true]
    - [sk1486sx002, socket.socket.__dict__.__contains__,              ["__exit__"],   true]
    - [sk1486sx003, socket.socket.__enter__.__class__.__name__.__eq__, ["function"],  true]
    - [sk1486sx004, socket.socket.__exit__.__class__.__name__.__eq__,  ["function"],  true]
    - [sk1486sx005, socket.socket.__enter__.__qualname__.__eq__,       ["socket.__enter__"], true]
    - [sk1486sx006, socket.socket.__exit__.__qualname__.__eq__,        ["socket.__exit__"],  true]
    - [sk1486sx007, socket.socket.__enter__.__module__.__eq__,         ["socket"],    true]

table socket_extra1486.socket_error_context_manager:
  description: "socket.error (alias for OSError) has no context manager protocol in its own __dict__"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: sk1486ex
  columns: [id, function, args, expected]
  rows:
    - [sk1486ex001, socket.error.__dict__.__contains__, ["__enter__"],         false]
    - [sk1486ex002, socket.error.__dict__.__contains__, ["__exit__"],          false]
    - [sk1486ex003, socket.error.__name__.__eq__,       ["OSError"],           true]
    - [sk1486ex004, socket.error.__qualname__.__eq__,   ["OSError"],           true]
    - [sk1486ex005, socket.error.__module__.__eq__,     ["builtins"],          true]
    - [sk1486ex006, socket.error.__class__.__name__.__eq__, ["type"],          true]

table socket_extra1486.socket_timeout_context_manager:
  description: "socket.timeout (alias for TimeoutError) has no context manager protocol in its own __dict__"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: sk1486tx
  columns: [id, function, args, expected]
  rows:
    - [sk1486tx001, socket.timeout.__dict__.__contains__, ["__enter__"],       false]
    - [sk1486tx002, socket.timeout.__dict__.__contains__, ["__exit__"],        false]
    - [sk1486tx003, socket.timeout.__name__.__eq__,       ["TimeoutError"],    true]
    - [sk1486tx004, socket.timeout.__qualname__.__eq__,   ["TimeoutError"],    true]
    - [sk1486tx005, socket.timeout.__module__.__eq__,     ["builtins"],        true]
    - [sk1486tx006, socket.timeout.__class__.__name__.__eq__, ["type"],        true]
