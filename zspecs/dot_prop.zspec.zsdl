spec: dot_prop
version: ">=6.0.0"
backend: node(dot-prop)

docs: https://github.com/sindresorhus/dot-prop#readme

provenance:
  derived_from:
    - "dot-prop README — https://github.com/sindresorhus/dot-prop#readme"
    - "Test vectors verified with dot-prop@6.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "dot-prop source: index.js"
  notes:
    - "dot-prop exports { get, has, setProperty, deleteProperty } as named exports."
    - "get(obj, path) retrieves a nested value using dot notation."
    - "has(obj, path) returns true if the path exists."
    - "Only spec cases where the property exists to avoid undefined serialization issues."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "get returns value or undefined; has returns boolean. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dot_prop.get:
  kind: node_module_call_eq
  function: get
  category: get
  id_prefix: dp_get

  columns: [id, args, expected]
  rows:
    - [shallow,  [{"a": 1}, "a"],           1]
    - [nested,   [{"a": {"b": 1}}, "a.b"],  1]
    - [string,   [{"x": "hello"}, "x"],     "hello"]

table dot_prop.has:
  kind: node_module_call_eq
  function: has
  category: has
  id_prefix: dp_has

  columns: [id, args, expected]
  rows:
    - [exists,       [{"a": {"b": 1}}, "a.b"],  true]
    - [not_exists,   [{"a": 1}, "b"],            false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:34:29Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
