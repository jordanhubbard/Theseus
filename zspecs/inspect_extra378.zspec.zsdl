spec: inspect_extra378
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.isfunction.__name__ == 'isfunction' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod.__name__ == 'ismethod' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismodule.__name__ == 'ismodule' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismodule.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect type-predicate function identity (isfunction, isclass, ismethod, ismodule)
#
# inspect.isfunction.__name__ == 'isfunction'  / __module__ == 'inspect'
# inspect.isclass.__name__ == 'isclass'        / __module__ == 'inspect'
# inspect.ismethod.__name__ == 'ismethod'      / __module__ == 'inspect'
# inspect.ismodule.__name__ == 'ismodule'      / __module__ == 'inspect'
#
# All four are pure-Python predicate functions defined in Lib/inspect.py that
# test what kind of object is passed. They all carry __name__ equal to the
# function name and __module__ equal to 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra378.predicate_identity_group1:
  description: "inspect.isfunction, isclass, ismethod, ismodule predicate function identity: __name__ and __module__; all pure-Python in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpred1_378

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_eq,
       "isfunction.__name__.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a pure-Python predicate in Lib/inspect.py that returns True if the object is a Python function created by a def statement; its __name__ is 'isfunction'; str.__eq__('isfunction') returns True; new to extra378"]
    - [isfunction_module_eq,
       "isfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]
    - [isclass_name_eq,
       "isclass.__name__.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a pure-Python predicate in Lib/inspect.py that returns True if the object is a class; its __name__ is 'isclass'; str.__eq__('isclass') returns True; new to extra378"]
    - [isclass_module_eq,
       "isclass.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]
    - [ismethod_name_eq,
       "ismethod.__name__.__eq__",
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — ismethod is a pure-Python predicate in Lib/inspect.py that returns True if the object is a bound method; its __name__ is 'ismethod'; str.__eq__('ismethod') returns True; new to extra378"]
    - [ismethod_module_eq,
       "ismethod.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — ismethod is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]
    - [ismodule_name_eq,
       "ismodule.__name__.__eq__",
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — ismodule is a pure-Python predicate in Lib/inspect.py that returns True if the object is a module; its __name__ is 'ismodule'; str.__eq__('ismodule') returns True; new to extra378"]
    - [ismodule_module_eq,
       "ismodule.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Table 2: inspect type-predicate function identity (isbuiltin, isgeneratorfunction, iscoroutinefunction)
#
# inspect.isbuiltin.__name__ == 'isbuiltin'                    / __module__ == 'inspect'
# inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' / __module__ == 'inspect'
# inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' / __module__ == 'inspect'
#
# All three are pure-Python predicate functions defined in Lib/inspect.py.
# isbuiltin tests for C-level builtins. isgeneratorfunction tests whether a
# function is a generator. iscoroutinefunction tests for coroutine functions.
# ---------------------------------------------------------------------------

table inspect_extra378.predicate_identity_group2:
  description: "inspect.isbuiltin, isgeneratorfunction, iscoroutinefunction predicate function identity: __name__ and __module__; all pure-Python in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpred2_378

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_eq,
       "isbuiltin.__name__.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin is a pure-Python predicate in Lib/inspect.py that returns True if the object is a built-in function or bound built-in method; its __name__ is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra378"]
    - [isbuiltin_module_eq,
       "isbuiltin.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]
    - [isgeneratorfunction_name_eq,
       "isgeneratorfunction.__name__.__eq__",
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__name__.__eq__('isgeneratorfunction') == True — isgeneratorfunction is a pure-Python predicate in Lib/inspect.py that returns True if the object is a generator function (contains yield); its __name__ is 'isgeneratorfunction'; str.__eq__('isgeneratorfunction') returns True; new to extra378"]
    - [isgeneratorfunction_module_eq,
       "isgeneratorfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isgeneratorfunction.__module__.__eq__('inspect') == True — isgeneratorfunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]
    - [iscoroutinefunction_name_eq,
       "iscoroutinefunction.__name__.__eq__",
       ["iscoroutinefunction"],
       true,
       "inspect.iscoroutinefunction.__name__.__eq__('iscoroutinefunction') == True — iscoroutinefunction is a pure-Python predicate in Lib/inspect.py that returns True if the object is a coroutine function defined with async def; its __name__ is 'iscoroutinefunction'; str.__eq__('iscoroutinefunction') returns True; new to extra378"]
    - [iscoroutinefunction_module_eq,
       "iscoroutinefunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.iscoroutinefunction.__module__.__eq__('inspect') == True — iscoroutinefunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra378
# ---------------------------------------------------------------------------

invariant inspect_extra378.isfunction_name:
  description: "inspect.isfunction.__name__ == 'isfunction' — pure-Python predicate returning True for def-created functions; new to extra378"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra378.isfunction_module:
  description: "inspect.isfunction.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra378.isclass_name:
  description: "inspect.isclass.__name__ == 'isclass' — pure-Python predicate returning True for class objects; new to extra378"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra378.isclass_module:
  description: "inspect.isclass.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra378.ismethod_name:
  description: "inspect.ismethod.__name__ == 'ismethod' — pure-Python predicate returning True for bound methods; new to extra378"
  kind: python_call_eq
  function: ismethod.__name__.__eq__
  args: ["ismethod"]
  expected: true

invariant inspect_extra378.ismethod_module:
  description: "inspect.ismethod.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: ismethod.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra378.ismodule_name:
  description: "inspect.ismodule.__name__ == 'ismodule' — pure-Python predicate returning True for module objects; new to extra378"
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra378.ismodule_module:
  description: "inspect.ismodule.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra378.isbuiltin_name:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — pure-Python predicate returning True for C-level builtins; new to extra378"
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra378.isbuiltin_module:
  description: "inspect.isbuiltin.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra378.isgeneratorfunction_name:
  description: "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' — pure-Python predicate returning True for generator functions; new to extra378"
  kind: python_call_eq
  function: isgeneratorfunction.__name__.__eq__
  args: ["isgeneratorfunction"]
  expected: true

invariant inspect_extra378.isgeneratorfunction_module:
  description: "inspect.isgeneratorfunction.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: isgeneratorfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra378.iscoroutinefunction_name:
  description: "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' — pure-Python predicate returning True for async def coroutine functions; new to extra378"
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect_extra378.iscoroutinefunction_module:
  description: "inspect.iscoroutinefunction.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra378"
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["inspect"]
